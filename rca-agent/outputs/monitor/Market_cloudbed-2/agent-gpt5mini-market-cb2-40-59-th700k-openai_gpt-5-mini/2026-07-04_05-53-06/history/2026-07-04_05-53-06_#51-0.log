        top5_samples = ""
    rows.append({
        'cmdb_id': comp,
        'distinct_anomalous_kpi_count': distinct_anomalous_kpi_count,
        'sum_anomaly_points': sum_anomaly_points,
        'earliest_anomaly_timestamp_ASIA/Shanghai': earliest_iso,
        'top5_kpi_samples': top5_samples
    })

