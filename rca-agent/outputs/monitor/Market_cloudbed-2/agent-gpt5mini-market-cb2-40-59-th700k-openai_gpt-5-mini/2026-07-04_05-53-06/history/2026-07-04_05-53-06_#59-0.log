import pandas as pd
import numpy as np
import pytz

# reuse existing dataframes from kernel
tz = pytz.timezone('Asia/Shanghai')

# ensure df_metric, df_err, df_trace exist
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv', low_memory=False)
    df_metric['timestamp'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
try:
    df_err
except NameError:
    df_err = pd.read_csv('error_logs.csv', low_memory=False)
    if 'timestamp' in df_err.columns:
        df_err['timestamp'] = pd.to_datetime(df_err['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv', low_memory=False)
    if 'timestamp' in df_trace.columns:
        df_trace['timestamp'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# ensure timestamp tz and ts_min
if 'timestamp' in df_metric.columns and not pd.api.types.is_datetime64tz_dtype(df_metric['timestamp']):
    df_metric['timestamp'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_metric['ts_min'] = df_metric['timestamp'].dt.floor('T')

if 'timestamp' in df_err.columns and not pd.api.types.is_datetime64tz_dtype(df_err['timestamp']):
    df_err['timestamp'] = pd.to_datetime(df_err['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_err['ts_min'] = df_err['timestamp'].dt.floor('T')

if 'timestamp' in df_trace.columns and not pd.api.types.is_datetime64tz_dtype(df_trace['timestamp']):
    df_trace['timestamp'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_trace['ts_min'] = df_trace['timestamp'].dt.floor('T')

# 1) specified timestamps
spike_strs = ['2022-03-21T14:30:00+08:00','2022-03-21T14:49:00+08:00','2022-03-21T14:50:00+08:00']
spike_ts = [pd.Timestamp(s).tz_convert(tz) for s in spike_strs]

# 1A) Node-level metric substrings to match
node_subs = {
    'transmit_MB': 'container.node-5.container_network_transmit_MB',
    'receive_MB':  'container.node-5.container_network_receive_MB',
    'transmit_packets': 'container.node-5.container_network_transmit_pa',  # match transmit_packets substring
    'receive_packets':  'container.node-5.container_network_receive_pa',   # match receive_packets substring
    'cpu_cfs_throttled': 'container_cpu_cfs_throttled'
}

# find distinct kpi_names matching these substrings
node_kpis = {}
for key, sub in node_subs.items():
    matches = df_metric['kpi_name'].loc[df_metric['kpi_name'].str.contains(sub, na=False)].unique().tolist()
    # keep up to 20 per category
    node_kpis[key] = matches[:20]

# flatten to a list of distinct node kpis to evaluate
node_kpi_list = []
for vals in node_kpis.values():
    node_kpi_list.extend(vals)
node_kpi_list = sorted(list(dict.fromkeys(node_kpi_list)))  # preserve order unique

# 2) Compute global aggregated time series for each node-level kpi (aggregate across all cmdb_id using sum or mean)
# Determine aggregation function per kpi (sum for packets/MB, mean for cpu_cfs_throttled)
def agg_func_for_kpi(kpi_name):
    if ('packets' in kpi_name) or ('_MB' in kpi_name):
        return 'sum'
    if 'container_cpu_cfs_throttled' in kpi_name or 'cpu_cfs_throttled' in kpi_name or 'cfs_throttled' in kpi_name:
        return 'mean'
    # fallback sum
    return 'sum'

# Build global aggregated per-minute series for each node kpi and compute P95/P5
node_global_stats = []
node_agg_timeseries = {}  # store series for reuse
for kpi in node_kpi_list:
    df_k = df_metric[df_metric['kpi_name'] == kpi]
    if df_k.empty:
        # no data
        agg_series = pd.Series(dtype=float)
    else:
        if agg_func_for_kpi(kpi) == 'sum':
            agg_series = df_k.groupby('ts_min')['value'].sum().sort_index()
        else:
            agg_series = df_k.groupby('ts_min')['value'].mean().sort_index()
    node_agg_timeseries[kpi] = agg_series
    if not agg_series.empty:
        gp95 = float(agg_series.quantile(0.95))
        gp5  = float(agg_series.quantile(0.05))
        gmax = float(agg_series.max())
        gmin = float(agg_series.min())
        count = int(agg_series.shape[0])
    else:
        gp95 = np.nan; gp5 = np.nan; gmax = np.nan; gmin = np.nan; count = 0
    node_global_stats.append({'kpi_name': kpi, 'agg_func': agg_func_for_kpi(kpi), 'global_count': count,
                              'global_p95': gp95, 'global_p5': gp5, 'global_max': gmax, 'global_min': gmin})
node_global_stats = pd.DataFrame(node_global_stats)

# 3 & 4) For each (timestamp, kpi) compute aggregated value across all cmdb_id at that timestamp and compare to global thresholds
node_rows = []
for ts in spike_ts:
    for kpi in node_kpi_list:
        agg_series = node_agg_timeseries.get(kpi, pd.Series(dtype=float))
        if agg_series.empty or ts not in agg_series.index:
            agg_value = np.nan
        else:
            agg_value = float(agg_series.loc[ts])
        gs = node_global_stats.loc[node_global_stats['kpi_name']==kpi].squeeze()
        gp95 = float(gs['global_p95']) if not pd.isna(gs['global_p95']) else np.nan
        gp5  = float(gs['global_p5']) if not pd.isna(gs['global_p5']) else np.nan
        breach = 'none'; severity = 0.0
        if not np.isnan(agg_value):
            if (not np.isnan(gp95)) and (agg_value >= gp95):
                breach = 'high'
                severity = (agg_value - gp95) / gp95 if gp95 != 0 else (agg_value - gp95)
            elif (not np.isnan(gp5)) and (agg_value <= gp5):
                breach = 'low'
                severity = (gp5 - agg_value) / gp5 if gp5 != 0 else (gp5 - agg_value)
        node_rows.append({
            'timestamp': ts.isoformat(),
            'entity': 'node-5',
            'metric_name': kpi,
            'agg_value': agg_value,
            'global_p95': gp95,
            'global_p5': gp5,
            'breach_type': breach,
            'severity': float(severity)
        })
node_table = pd.DataFrame.from_records(node_rows)

# 5) Frontend pod-level metrics
frontends = ['frontend-0','frontend-1','frontend-2']

# select frontend network MB KPIs and cpu-related KPIs per frontend
frontend_kpis = {}
# explicit network MB kpis (exact matching substring)
for fn in frontends:
    frontend_kpis.setdefault(fn, [])
    for sub in ['container.node-5.container_network_transmit_MB', 'container.node-5.container_network_receive_MB']:
        matches = df_metric.loc[(df_metric['cmdb_id']==fn) & (df_metric['kpi_name'].str.contains(sub, na=False)), 'kpi_name'].unique().tolist()
        frontend_kpis[fn].extend(matches)
    # cpu/cfs related KPIs
    cpu_matches = df_metric.loc[(df_metric['cmdb_id']==fn) & (df_metric['kpi_name'].str.contains('cpu|cfs', na=False)), 'kpi_name'].value_counts().reset_index()
    if not cpu_matches.empty:
        top3 = cpu_matches['index'].head(3).tolist()
        frontend_kpis[fn].extend(top3)
    # dedupe
    frontend_kpis[fn] = [k for k in pd.unique(frontend_kpis[fn])][:10]  # keep some limit

# Compute global P95/P5 per (cmdb_id,kpi_name) across full file (no time filter)
frontend_global_stats = []
for fn, kpis in frontend_kpis.items():
    for kpi in kpis:
        ser = df_metric.loc[(df_metric['cmdb_id']==fn) & (df_metric['kpi_name']==kpi), :]
        if ser.empty:
            gp95 = np.nan; gp5 = np.nan; gmax = np.nan; gmin = np.nan; count = 0
        else:
            gp95 = float(ser['value'].quantile(0.95))
            gp5  = float(ser['value'].quantile(0.05))
            gmax = float(ser['value'].max()); gmin = float(ser['value'].min()); count = int(ser.shape[0])
        frontend_global_stats.append({'cmdb_id':fn,'kpi_name':kpi,'global_count':count,'global_p95':gp95,'global_p5':gp5,'global_max':gmax,'global_min':gmin})
frontend_global_stats = pd.DataFrame(frontend_global_stats)

# For each spike ts and each frontend cmdb/kpi compute agg_value at that timestamp (mean if multiple)
frontend_rows = []
for ts in spike_ts:
    for fn, kpis in frontend_kpis.items():
        for kpi in kpis:
            ser = df_metric.loc[(df_metric['ts_min']==ts) & (df_metric['cmdb_id']==fn) & (df_metric['kpi_name']==kpi), 'value']
            if ser.empty:
                agg_value = np.nan
            else:
                agg_value = float(ser.mean())
            gs = frontend_global_stats[(frontend_global_stats['cmdb_id']==fn) & (frontend_global_stats['kpi_name']==kpi)]
            if gs.empty:
                gp95 = np.nan; gp5 = np.nan
            else:
                gp95 = float(gs['global_p95'].iloc[0]); gp5 = float(gs['global_p5'].iloc[0])
            breach = 'none'; severity = 0.0
            if not np.isnan(agg_value):
                if (not np.isnan(gp95)) and (agg_value >= gp95):
                    breach = 'high'
                    severity = (agg_value - gp95) / gp95 if gp95 != 0 else (agg_value - gp95)
                elif (not np.isnan(gp5)) and (agg_value <= gp5):
                    breach = 'low'
                    severity = (gp5 - agg_value) / gp5 if gp5 != 0 else (gp5 - agg_value)
            frontend_rows.append({
                'timestamp': ts.isoformat(),
                'entity': fn,
                'metric_name': kpi,
                'agg_value': agg_value,
                'global_p95': gp95,
                'global_p5': gp5,
                'breach_type': breach,
                'severity': float(severity)
            })
frontend_table = pd.DataFrame.from_records(frontend_rows)

# 4) Additionally return error_logs counts for that minute and trace aggregates at that minute:
# error counts total and per frontend
err_counts = []
for ts in spike_ts:
    df_e = df_err[df_err['ts_min']==ts]
    total = int(df_e.shape[0])
    c0 = int(df_e[df_e['cmdb_id']=='frontend-0'].shape[0])
    c1 = int(df_e[df_e['cmdb_id']=='frontend-1'].shape[0])
    c2 = int(df_e[df_e['cmdb_id']=='frontend-2'].shape[0])
    err_counts.append({'timestamp': ts.isoformat(), 'err_total': total, 'frontend-0': c0, 'frontend-1': c1, 'frontend-2': c2})
err_counts = pd.DataFrame(err_counts)

# trace aggregates: avg_error_rate and avg_duration_p95 across frontend traces at that minute
# filter trace rows of interest
trace_mask = df_trace['trace_name'].str.contains('trace.from_frontend-', na=False) & df_trace['trace_name'].str.endswith(('.error_rate','.duration_p95'))
trace_f = df_trace[trace_mask].copy()
# identify metric type
trace_f['metric_type'] = trace_f['trace_name'].apply(lambda n: 'error_rate' if n.endswith('.error_rate') else ('duration_p95' if n.endswith('.duration_p95') else None))

trace_aggs = []
for ts in spike_ts:
    df_t = trace_f[trace_f['ts_min']==ts]
    avg_err = float(df_t[df_t['metric_type']=='error_rate']['value'].mean()) if not df_t[df_t['metric_type']=='error_rate'].empty else np.nan
    avg_p95 = float(df_t[df_t['metric_type']=='duration_p95']['value'].mean()) if not df_t[df_t['metric_type']=='duration_p95'].empty else np.nan
    trace_aggs.append({'timestamp': ts.isoformat(), 'avg_error_rate': avg_err, 'avg_duration_p95': avg_p95})
trace_aggs = pd.DataFrame(trace_aggs)

# merge error and trace summaries into a small lookup to attach to frontend_table if desired
summary_lookup = err_counts.merge(trace_aggs, on='timestamp', how='left')

# Attach error/trace summary to frontend_table by timestamp (for display convenience)
frontend_table_with_summary = frontend_table.merge(summary_lookup, left_on='timestamp', right_on='timestamp', how='left')

# 6) Prepare final compact outputs: Node-5 table and frontend-pod table (limit rows)
node_display = node_table.loc[:, ['timestamp','entity','metric_name','agg_value','global_p95','global_p5','breach_type','severity']].head(50)
frontend_display = frontend_table_with_summary.loc[:, ['timestamp','entity','metric_name','agg_value','global_p95','global_p5','breach_type','severity','err_total','frontend-0','frontend-1','frontend-2','avg_error_rate','avg_duration_p95']].head(50)

# Final displayed variables
node_display, frontend_display
