import pandas as pd
import numpy as np
import pytz

# Reuse agg, start_ts, end_ts from kernel state (agg is the per-(cmdb_id,kpi_name) anomaly table)
# If agg not present, raise informative error
try:
    agg
except NameError:
    raise RuntimeError("Required variable 'agg' not found in kernel. Run the previous metric aggregation step first.")

# 1) Filter to anomalous series (total_anomalies > 0) within the incident window context
anomaly_df = agg[agg['total_anomalies'] > 0].copy()

# Ensure earliest_timestamp_of_anomaly is numeric (it may be NaN for non-anomalous series)
anomaly_df['earliest_timestamp_of_anomaly'] = pd.to_numeric(anomaly_df['earliest_timestamp_of_anomaly'], errors='coerce')

# Helper to produce up to 5 unique earliest timestamps per cmdb_id, sorted ascending
def sample_ts(series):
    vals = series.dropna().unique()
    if vals.size == 0:
        return ""
    vals_sorted = np.sort(vals.astype(int))
    return ",".join(map(str, vals_sorted[:5]))

# 1) Aggregate by cmdb_id
cmdb_grouped = anomaly_df.groupby('cmdb_id').agg(
    number_of_anomalous_kpis = ('kpi_name', 'nunique'),
    earliest_anomaly_ts = ('earliest_timestamp_of_anomaly', 'min'),
    latest_anomaly_ts = ('earliest_timestamp_of_anomaly', 'max')
).reset_index()

# add sample_timestamps column (up to 5 unique earliest timestamps sorted ascending)
sample_series = anomaly_df.groupby('cmdb_id')['earliest_timestamp_of_anomaly'].apply(sample_ts).reset_index(name='sample_timestamps')
cmdb_agg = cmdb_grouped.merge(sample_series, on='cmdb_id', how='left')

# Normalize timestamp columns to integer where present
cmdb_agg['earliest_anomaly_ts'] = cmdb_agg['earliest_anomaly_ts'].dropna().astype('Int64')
cmdb_agg['latest_anomaly_ts'] = cmdb_agg['latest_anomaly_ts'].dropna().astype('Int64')

# 2) Top 20 cmdb_id rows ordered by number_of_anomalous_kpis desc
cmdb_top20 = cmdb_agg.sort_values(by='number_of_anomalous_kpis', ascending=False).head(20)

# 3) Global count of earliest_anomaly_ts across all anomalous (cmdb_id,kpi_name) series
earliest_ts_counts = (
    anomaly_df['earliest_timestamp_of_anomaly']
    .dropna()
    .astype(int)
    .value_counts()
    .rename_axis('earliest_anomaly_ts')
    .reset_index(name='count')
    .sort_values(by='count', ascending=False)
)

earliest_ts_top20 = earliest_ts_counts.head(20)

# Return compact summaries
cmdb_top20, earliest_ts_top20
