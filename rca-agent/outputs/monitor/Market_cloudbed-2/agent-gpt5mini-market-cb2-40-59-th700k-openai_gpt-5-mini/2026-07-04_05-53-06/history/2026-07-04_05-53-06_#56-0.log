# 1) Compute global P95 and P05 per (cmdb_id, trace_name) using full trace.csv
trace_thresholds = df_trace.groupby(['cmdb_id', 'trace_name'], as_index=False).agg(
    global_P95 = ('value', lambda x: float(x.quantile(0.95)) if not x.dropna().empty else np.nan),
    global_P05 = ('value', lambda x: float(x.quantile(0.05)) if not x.dropna().empty else np.nan)
)

# 2) Filter trace.csv to the incident window
df_tw = df_trace[(df_trace['timestamp'] >= start_ts) & (df_trace['timestamp'] < end_ts)].copy()

# 3) Merge thresholds and compute anomalies per point, then aggregate per series
df_tw = df_tw.merge(trace_thresholds, on=['cmdb_id','trace_name'], how='left')
df_tw['above_P95'] = df_tw['value'] > df_tw['global_P95']
df_tw['below_P05'] = df_tw['value'] < df_tw['global_P05']
df_tw['is_anomaly'] = df_tw['above_P95'] | df_tw['below_P05']

# aggregate per (cmdb_id, trace_name)
agg_counts = df_tw.groupby(['cmdb_id','trace_name'], as_index=False).agg(
    total_points_in_window = ('value', 'size'),
    count_above_P95 = ('above_P95', 'sum'),
    count_below_P05 = ('below_P05', 'sum')
)

# earliest anomaly timestamp if any
earliest_anom = df_tw[df_tw['is_anomaly']].groupby(['cmdb_id','trace_name'], as_index=False).agg(
    earliest_timestamp_of_anomaly = ('timestamp', 'min')
)

# combine aggregates with earliest timestamp and thresholds
trace_anomalies = agg_counts.merge(earliest_anom, on=['cmdb_id','trace_name'], how='left')
trace_anomalies['total_anomalies'] = trace_anomalies['count_above_P95'] + trace_anomalies['count_below_P05']
trace_anomalies = trace_anomalies.merge(trace_thresholds, on=['cmdb_id','trace_name'], how='left')

# filter to anomalous series (total_anomalies>0) and drop those without earliest timestamp (shouldn't happen)
anoms = trace_anomalies[trace_anomalies['total_anomalies'] > 0].copy()
anoms = anoms.dropna(subset=['earliest_timestamp_of_anomaly'])

# If no anomalies found, return explicit message
if anoms.shape[0] == 0:
    no_anom_msg = "No anomalous (cmdb_id, trace_name) series found in the incident window."
    no_anom_msg
else:
    # 4) Aggregate by earliest_timestamp_of_anomaly: count series and sample up to 10 distinct cmdb_id values (sorted)
    ts_group = anoms.groupby('earliest_timestamp_of_anomaly', as_index=False).agg(
        count_of_series = ('trace_name', 'size'),
        sample_cmdb_ids = ('cmdb_id', lambda s: ','.join(sorted(set(s))[:10]))
    )
    ts_top20 = ts_group.sort_values(by='count_of_series', ascending=False).head(20)

    # 5) summary numbers
    total_anomalous_series = anoms.shape[0]
    unique_earliest_ts_count = anoms['earliest_timestamp_of_anomaly'].nunique(dropna=True)

    # Return compact aggregates: top20 timestamps with counts and sample cmdb_ids, plus two summary numbers
    ts_top20, total_anomalous_series, unique_earliest_ts_count
