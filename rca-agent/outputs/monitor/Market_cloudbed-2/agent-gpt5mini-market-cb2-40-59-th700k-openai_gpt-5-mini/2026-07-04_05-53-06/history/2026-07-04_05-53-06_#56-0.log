import pandas as pd
import numpy as np
import pytz

# Ensure required base variables exist
try:
    df_metric
except NameError:
    raise RuntimeError("df_metric not found in kernel. Please load metric.csv first.")

# incident window bounds (should exist from earlier steps), else define
try:
    start_ts, end_ts
except NameError:
    start_ts = 1647840600
    end_ts = 1647842400

# Ensure numeric 'value'
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

# Determine or compute global thresholds for metric (per (cmdb_id, kpi_name))
# If a variable named df_thresholds exists and has 'kpi_name', assume it's metric thresholds.
use_existing = False
if 'df_thresholds' in globals():
    if isinstance(df_thresholds, pd.DataFrame) and {'cmdb_id', 'kpi_name', 'global_P95', 'global_P05'}.issubset(df_thresholds.columns):
        metric_thresholds = df_thresholds
        use_existing = True

if not use_existing:
    metric_thresholds = df_metric.groupby(['cmdb_id', 'kpi_name'], as_index=False).agg(
        global_P95 = ('value', lambda x: float(x.quantile(0.95)) if not x.dropna().empty else np.nan),
        global_P05 = ('value', lambda x: float(x.quantile(0.05)) if not x.dropna().empty else np.nan)
    )

# Filter df_metric to the incident window [start_ts, end_ts)
df_metric_window = df_metric[(df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] < end_ts)].copy()

# Merge thresholds into windowed data
df_mw = df_metric_window.merge(metric_thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# Mark anomalies
df_mw['above_P95'] = df_mw['value'] > df_mw['global_P95']
df_mw['below_P05'] = df_mw['value'] < df_mw['global_P05']
df_mw['is_anomaly'] = df_mw['above_P95'] | df_mw['below_P05']

# Aggregate per (cmdb_id, kpi_name) within window to get total_anomalies and earliest anomaly timestamp
per_kpi_agg = df_mw.groupby(['cmdb_id', 'kpi_name'], as_index=False).agg(
    total_points_in_window = ('value', 'size'),
    count_above_P95 = ('above_P95', 'sum'),
    count_below_P05 = ('below_P05', 'sum'),
    earliest_timestamp_of_anomaly = ('timestamp', lambda x: int(x[df_mw.loc[x.index, 'is_anomaly']].min()) if any(df_mw.loc[x.index, 'is_anomaly']) else np.nan)
)

# total_anomalies
per_kpi_agg['total_anomalies'] = per_kpi_agg['count_above_P95'] + per_kpi_agg['count_below_P05']

# Keep only anomalous kpis for cmdb-level aggregation
anomalous_kpis = per_kpi_agg[per_kpi_agg['total_anomalies'] > 0].copy()
anomalous_kpis['earliest_timestamp_of_anomaly'] = pd.to_numeric(anomalous_kpis['earliest_timestamp_of_anomaly'], errors='coerce').astype('Int64')

# Helper to sample up to 5 unique earliest timestamps sorted ascending
def sample_ts(series):
    vals = series.dropna().unique()
    if len(vals) == 0:
        return ""
    vals_sorted = np.sort(vals.astype(int))
    return ",".join(map(str, vals_sorted[:5]))

# 1) Aggregate by cmdb_id
cmdb_grouped = anomalous_kpis.groupby('cmdb_id').agg(
    number_of_anomalous_kpis = ('kpi_name', 'nunique'),
    earliest_anomaly_ts = ('earliest_timestamp_of_anomaly', 'min'),
    latest_anomaly_ts = ('earliest_timestamp_of_anomaly', 'max')
).reset_index()

sample_series = anomalous_kpis.groupby('cmdb_id')['earliest_timestamp_of_anomaly'].apply(sample_ts).reset_index(name='sample_timestamps')
cmdb_agg = cmdb_grouped.merge(sample_series, on='cmdb_id', how='left')

# Normalize timestamp columns to integer where present
cmdb_agg['earliest_anomaly_ts'] = cmdb_agg['earliest_anomaly_ts'].dropna().astype('Int64')
cmdb_agg['latest_anomaly_ts'] = cmdb_agg['latest_anomaly_ts'].dropna().astype('Int64')

# 2) Top 20 cmdb_id rows ordered by number_of_anomalous_kpis desc
cmdb_top20 = cmdb_agg.sort_values(by='number_of_anomalous_kpis', ascending=False).head(20).loc[
    :, ['cmdb_id', 'number_of_anomalous_kpis', 'earliest_anomaly_ts', 'latest_anomaly_ts', 'sample_timestamps']
]

# 3) Global count of earliest_anomaly_ts across all anomalous (cmdb_id,kpi_name) series
