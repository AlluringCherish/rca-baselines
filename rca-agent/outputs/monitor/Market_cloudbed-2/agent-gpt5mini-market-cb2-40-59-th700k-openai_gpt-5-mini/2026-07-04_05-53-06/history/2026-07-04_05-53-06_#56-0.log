import pandas as pd
import numpy as np
import pytz

# reuse df_error from kernel
try:
    df_error
except NameError:
    raise RuntimeError("df_error not found in kernel. Please load error_logs.csv as df_error before running this cell.")

tz = pytz.timezone('Asia/Shanghai')  # per rules (UTC+8)

frontends = ["frontend-0", "frontend-1", "frontend-2"]
minutes = [1647841380, 1647841920]

rows = []
for T in minutes:
    subset = df_error[
        (df_error['timestamp'] >= T) &
        (df_error['timestamp'] < T + 60) &
        (df_error['cmdb_id'].isin(frontends))
    ].copy()
    total_message_count = int(subset.shape[0])
    if total_message_count == 0:
        rows.append({
            'minute_T': T,
            'total_message_count': 0,
            'earliest_message_ts_overall': np.nan,
            'per_cmdb_id_counts': 'no messages for frontends in this minute',
            'top_messages': 'no messages'
        })
        continue

    earliest_message_ts_overall = int(subset['timestamp'].min())

    # per-cmdb_id counts and earliest_ts
    per_cmdb = subset.groupby('cmdb_id', as_index=False).agg(
        count=('timestamp','size'),
        earliest_ts=('timestamp','min')
    )
    # ensure all three frontends present in display
    per_cmdb_map = {r['cmdb_id']:(int(r['count']), int(r['earliest_ts'])) for _, r in per_cmdb.iterrows()}
    per_cmdb_entries = []
    for pod in frontends:
        if pod in per_cmdb_map:
            cnt, ets = per_cmdb_map[pod]
            per_cmdb_entries.append(f"{pod}:{cnt}/{ets}")
        else:
            per_cmdb_entries.append(f"{pod}:0/NA")
    per_cmdb_id_counts = "; ".join(per_cmdb_entries)

    # top up to 5 distinct messages with their counts and earliest timestamp when each appeared in this minute
    # Truncate message text to 120 chars for compactness
    def snip(msg, n=120):
        msg = str(msg)
        return msg if len(msg) <= n else msg[:n-1] + "…"
    msg_grp = subset.groupby('message', as_index=False).agg(
        count=('message','size'),
        earliest_ts=('timestamp','min')
    )
    msg_grp = msg_grp.sort_values(by=['count','earliest_ts'], ascending=[False, True]).head(5)
    msg_entries = []
    for _, r in msg_grp.iterrows():
        msg_text = snip(r['message'])
        msg_entries.append(f"{int(r['count'])}x '{msg_text}' @ {int(r['earliest_ts'])}")
    top_messages = " | ".join(msg_entries)

    rows.append({
        'minute_T': T,
        'total_message_count': total_message_count,
        'earliest_message_ts_overall': earliest_message_ts_overall,
        'per_cmdb_id_counts': per_cmdb_id_counts,
        'top_messages': top_messages
    })

results_df = pd.DataFrame(rows, columns=[
    'minute_T',
    'total_message_count',
    'earliest_message_ts_overall',
    'per_cmdb_id_counts',
    'top_messages'
])

