import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# reuse kernel variables when possible
try:
    df_metric
except NameError:
    raise RuntimeError("df_metric not found in kernel. Please load metric.csv as df_metric first.")

# time window bounds (should exist from previous steps); if not, define explicitly
try:
    start_ts, end_ts
except NameError:
    start_ts = 1647840600
    end_ts = 1647842400

# Step: ensure metric_thresholds (global P95/P05 per (cmdb_id,kpi_name)) exists, otherwise compute
try:
    metric_thresholds
except NameError:
    # compute global thresholds using the full df_metric (requirement: before filtering)
    df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')
    metric_thresholds = df_metric.groupby(['cmdb_id','kpi_name'], as_index=False).agg(
        global_P95 = ('value', lambda x: float(x.quantile(0.95)) if not x.dropna().empty else np.nan),
        global_P05 = ('value', lambda x: float(x.quantile(0.05)) if not x.dropna().empty else np.nan)
    )

# Step: ensure metric_anomalies exists, otherwise create it by analyzing the incident window
try:
    metric_anomalies
except NameError:
    # filter df_metric to the incident window
    df_window = df_metric[(df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] < end_ts)].copy()
    # merge global thresholds
    df_wt = df_window.merge(metric_thresholds, on=['cmdb_id','kpi_name'], how='left')
    # mark anomalies
    df_wt['above_P95'] = df_wt['value'] > df_wt['global_P95']
    df_wt['below_P05'] = df_wt['value'] < df_wt['global_P05']
    df_wt['is_anomaly'] = df_wt['above_P95'] | df_wt['below_P05']
    # aggregate per series
    metric_anomalies = df_wt.groupby(['cmdb_id','kpi_name'], as_index=False).agg(
        total_points_in_window = ('value', 'size'),
        count_above_P95 = ('above_P95', 'sum'),
        count_below_P05 = ('below_P05', 'sum')
    )
    # earliest anomaly timestamp if any
    earliest = df_wt[df_wt['is_anomaly']].groupby(['cmdb_id','kpi_name'], as_index=False).agg(
        earliest_timestamp_of_anomaly = ('timestamp', 'min')
    )
    metric_anomalies = metric_anomalies.merge(earliest, on=['cmdb_id','kpi_name'], how='left')
    # total anomalies
    metric_anomalies['total_anomalies'] = metric_anomalies['count_above_P95'] + metric_anomalies['count_below_P05']
    # attach global thresholds for reference
    metric_anomalies = metric_anomalies.merge(metric_thresholds, on=['cmdb_id','kpi_name'], how='left')

# Filter to anomalous series (total_anomalies > 0)
anom_series = metric_anomalies[metric_anomalies['total_anomalies'] > 0].copy()

# If no anomalies found, report explicitly
if anom_series.shape[0] == 0:
    summary_msg = "No anomalous (cmdb_id,kpi_name) series found in the incident window."
    summary_msg
else:
    # 1) Aggregate by earliest_timestamp_of_anomaly: count series per earliest timestamp
    # drop NaN earliest timestamps prior to counting
    ts_counts = anom_series.dropna(subset=['earliest_timestamp_of_anomaly']).groupby(
        'earliest_timestamp_of_anomaly', as_index=False
    ).size().rename(columns={'size':'count_of_series'})
    ts_counts = ts_counts.sort_values(by='count_of_series', ascending=False).head(20)
    # 2) compute totals
    total_anomalous_series = anom_series.shape[0]
    unique_earliest_ts_count = anom_series['earliest_timestamp_of_anomaly'].nunique(dropna=True)
    # Return compact aggregates
    ts_counts, total_anomalous_series, unique_earliest_ts_count
