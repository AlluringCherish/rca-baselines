import pandas as pd
import numpy as np
import pytz

# reuse variables from kernel: df_trace, start_ts, end_ts, tz (if not present, define tz)
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure 'value' is numeric
df_trace['value'] = pd.to_numeric(df_trace['value'], errors='coerce')

# Candidate cmdb_ids from prior metric analysis
candidates = ["shippingservice2-0", "adservice", "shippingservice-2", "checkoutservice-0"]

# 1) Compute global P95 and P05 per (cmdb_id, trace_name) using the full df_trace
trace_thresholds = df_trace.groupby(['cmdb_id', 'trace_name'], as_index=False).agg(
    global_P95 = ('value', lambda x: float(x.quantile(0.95)) if not x.dropna().empty else np.nan),
    global_P05 = ('value', lambda x: float(x.quantile(0.05)) if not x.dropna().empty else np.nan)
)

# 2) Filter df_trace to incident window [start_ts, end_ts) and to the candidate cmdb_ids
df_trace_window = df_trace[(df_trace['timestamp'] >= start_ts) & (df_trace['timestamp'] < end_ts)].copy()
df_trace_window = df_trace_window[df_trace_window['cmdb_id'].isin(candidates)].copy()

# 3) Merge thresholds and mark anomalies
df_tw = df_trace_window.merge(trace_thresholds, on=['cmdb_id', 'trace_name'], how='left')
df_tw['above_P95'] = df_tw['value'] > df_tw['global_P95']
df_tw['below_P05'] = df_tw['value'] < df_tw['global_P05']
df_tw['is_anomaly'] = df_tw['above_P95'] | df_tw['below_P05']

# 4) Aggregate per (cmdb_id, trace_name) within the window
agg_counts = df_tw.groupby(['cmdb_id', 'trace_name'], as_index=False).agg(
    total_points_in_window = ('value', 'size'),
    count_above_P95 = ('above_P95', 'sum'),
    count_below_P05 = ('below_P05', 'sum')
)

earliest_anom = df_tw[df_tw['is_anomaly']].groupby(['cmdb_id', 'trace_name'], as_index=False).agg(
    earliest_timestamp_of_anomaly = ('timestamp', 'min')
)

# Combine aggregates with earliest anomaly timestamp and thresholds
agg = agg_counts.merge(earliest_anom, on=['cmdb_id', 'trace_name'], how='left')
agg = agg.merge(trace_thresholds, on=['cmdb_id', 'trace_name'], how='left')
agg['total_anomalies'] = agg['count_above_P95'] + agg['count_below_P05']

# Order by total_anomalies desc, then earliest anomaly asc
agg_sorted = agg.sort_values(by=['total_anomalies', 'earliest_timestamp_of_anomaly'], ascending=[False, True])

# Prepare compact top-20 table
top20_trace = agg_sorted.loc[:, [
    'cmdb_id',
    'trace_name',
    'total_points_in_window',
    'count_above_P95',
    'count_below_P05',
    'total_anomalies',
    'earliest_timestamp_of_anomaly',
    'global_P95',
    'global_P05'
]].head(20)

# Return compact results: window bounds, number of thresholded groups, and top-20 anomaly summary
start_ts, end_ts, trace_thresholds.shape, top20_trace
