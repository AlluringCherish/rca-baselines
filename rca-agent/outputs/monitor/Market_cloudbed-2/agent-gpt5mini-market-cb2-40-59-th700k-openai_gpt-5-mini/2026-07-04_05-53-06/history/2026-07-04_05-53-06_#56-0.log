import pandas as pd
import numpy as np
import datetime
import pytz

# reuse existing df_metric from kernel
# 1) convert given datetimes in UTC+8 to Unix timestamps
tz = pytz.timezone('Asia/Shanghai')
start_dt = tz.localize(datetime.datetime.strptime('2022-03-21 13:30:00', '%Y-%m-%d %H:%M:%S'))
end_dt   = tz.localize(datetime.datetime.strptime('2022-03-21 14:00:00', '%Y-%m-%d %H:%M:%S'))
start_ts = int(start_dt.timestamp())
end_ts   = int(end_dt.timestamp())

# 2) compute global P95 and P05 per (cmdb_id, kpi_name) using the full df_metric
# Ensure numeric 'value' exists
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

df_thresholds = df_metric.groupby(['cmdb_id', 'kpi_name'], as_index=False).agg(
    global_P95 = ('value', lambda x: float(x.quantile(0.95)) if not x.dropna().empty else np.nan),
    global_P05 = ('value', lambda x: float(x.quantile(0.05)) if not x.dropna().empty else np.nan)
)

# 3) filter df_metric to incident window [start_ts, end_ts)
df_window = df_metric[(df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] < end_ts)].copy()

# merge thresholds into windowed data
df_wt = df_window.merge(df_thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# mark anomalies relative to global thresholds
df_wt['above_P95'] = df_wt['value'] > df_wt['global_P95']
df_wt['below_P05'] = df_wt['value'] < df_wt['global_P05']
df_wt['is_anomaly'] = df_wt['above_P95'] | df_wt['below_P05']

# aggregate per (cmdb_id, kpi_name) within window
agg_counts = df_wt.groupby(['cmdb_id', 'kpi_name'], as_index=False).agg(
    total_points_in_window = ('value', 'size'),
    count_above_P95 = ('above_P95', 'sum'),
    count_below_P05 = ('below_P05', 'sum')
)

# earliest timestamp of anomaly per group (if any)
earliest_anom = df_wt[df_wt['is_anomaly']].groupby(['cmdb_id','kpi_name'], as_index=False).agg(
    earliest_timestamp_of_anomaly = ('timestamp', 'min')
)

# combine aggregated counts with earliest anomaly timestamp and thresholds
agg = agg_counts.merge(earliest_anom, on=['cmdb_id','kpi_name'], how='left')
agg = agg.merge(df_thresholds, on=['cmdb_id','kpi_name'], how='left')

# compute total anomaly count and rank
agg['total_anomalies'] = agg['count_above_P95'] + agg['count_below_P05']
agg_sorted = agg.sort_values(by='total_anomalies', ascending=False)

# 4) prepare compact top-20 table with requested columns
top20_df = agg_sorted.loc[:, [
    'cmdb_id',
    'kpi_name',
    'total_points_in_window',
    'count_above_P95',
    'count_below_P05',
    'earliest_timestamp_of_anomaly',
    'global_P95',
    'global_P05',
    'total_anomalies'
]].head(20)

# Keep intermediate variables in kernel (df_thresholds, df_window, df_wt, agg)
start_ts, end_ts, df_thresholds.shape, top20_df.head(20)
