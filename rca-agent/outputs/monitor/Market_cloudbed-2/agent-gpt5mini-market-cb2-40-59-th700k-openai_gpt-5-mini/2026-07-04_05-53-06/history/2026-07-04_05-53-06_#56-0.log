import pandas as pd
import numpy as np
import pytz

# reuse existing dataframes and window bounds from kernel
try:
    df_log
    df_error
except NameError:
    raise RuntimeError("df_log or df_error not found in kernel. Please load log.csv as df_log and error_logs.csv as df_error first.")

# ensure window bounds
try:
    start_ts, end_ts
except NameError:
    start_ts = 1647840600
    end_ts = 1647842400

tz = pytz.timezone('Asia/Shanghai')

frontends = ["frontend-0","frontend-1","frontend-2"]

# 1) log.csv: filter and aggregate per-minute summed_error_count and per-pod contributions
df_log['value'] = pd.to_numeric(df_log['value'], errors='coerce')

log_window_fe = df_log[
    (df_log['timestamp'] >= start_ts) &
    (df_log['timestamp'] < end_ts) &
    (df_log['cmdb_id'].isin(frontends)) &
    (df_log['log_name'] == 'log.error_count')
].copy()

if log_window_fe.shape[0] == 0:
    log_top10 = "No log.error_count rows for frontends in the incident window."
else:
    # pivot to get per-pod sums per timestamp
    pivot = log_window_fe.groupby(['timestamp','cmdb_id'])['value'].sum().unstack(fill_value=0)
    # ensure all frontend columns present
    for pod in frontends:
        if pod not in pivot.columns:
            pivot[pod] = 0.0
    pivot = pivot[frontends]  # order columns
    pivot['summed_error_count'] = pivot.sum(axis=1)
    pivot_df = pivot.reset_index().rename_axis(None, axis=1)
    # top 10 timestamps by summed_error_count desc
    log_top10 = pivot_df.sort_values(by='summed_error_count', ascending=False).head(10)
    # select/arrange columns: timestamp, summed_error_count, per-pod columns
    log_top10 = log_top10.loc[:, ['timestamp', 'summed_error_count'] + frontends]

# 2) error_logs.csv: filter frontends and window, group by timestamp count messages
err_window_fe = df_error[
    (df_error['timestamp'] >= start_ts) &
    (df_error['timestamp'] < end_ts) &
    (df_error['cmdb_id'].isin(frontends))
].copy()

if err_window_fe.shape[0] == 0:
    err_top10 = "No error_logs rows for frontends in the incident window."
else:
    err_ts_counts = err_window_fe.groupby('timestamp', as_index=False).size().rename(columns={'size':'message_count'})
    err_top10 = err_ts_counts.sort_values(by='message_count', ascending=False).head(10)

# 3) Identify top 2 distinct peak timestamps if both lists non-empty
peak_timestamps = []
if isinstance(log_top10, pd.DataFrame) and isinstance(err_top10, pd.DataFrame) and (not log_top10.empty) and (not err_top10.empty):
    log_ts_set = set(log_top10['timestamp'].astype(int).tolist())
    err_ts_set = set(err_top10['timestamp'].astype(int).tolist())
    intersection = sorted(list(log_ts_set & err_ts_set))
    if len(intersection) >= 2:
        # choose top 2 by summed_error_count (from log_top10)
        candidates = log_top10[log_top10['timestamp'].isin(intersection)].sort_values(by='summed_error_count', ascending=False)
        peak_timestamps = candidates['timestamp'].astype(int).head(2).tolist()
    elif len(intersection) == 1:
        # include the one in intersection and then the next top from log_top10
        first = int(intersection[0])
        others = log_top10[~log_top10['timestamp'].isin(intersection)].sort_values(by='summed_error_count', ascending=False)
        if not others.empty:
            peak_timestamps = [first, int(others.iloc[0]['timestamp'])]
        else:
            peak_timestamps = [first]
    else:
        # no intersection: pick top 2 timestamps by summed_error_count
        top_two = log_top10.sort_values(by='summed_error_count', ascending=False).head(2)
        peak_timestamps = top_two['timestamp'].astype(int).tolist()
elif isinstance(log_top10, pd.DataFrame) and (not log_top10.empty):
    # only log list available -> pick top 2 from log_top10
    peak_timestamps = log_top10.sort_values(by='summed_error_count', ascending=False).head(2)['timestamp'].astype(int).tolist()
elif isinstance(err_top10, pd.DataFrame) and (not err_top10.empty):
    # only error_logs available -> pick top 2 from err_top10 by message_count
    peak_timestamps = err_top10.sort_values(by='message_count', ascending=False).head(2)['timestamp'].astype(int).tolist()
else:
    peak_timestamps = []

# Final compact outputs
log_top10, err_top10, peak_timestamps
