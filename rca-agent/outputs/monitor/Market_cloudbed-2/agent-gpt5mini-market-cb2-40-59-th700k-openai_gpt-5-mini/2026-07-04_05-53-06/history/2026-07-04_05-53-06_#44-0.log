import numpy as np
import pandas as pd
import pytz

# Reuse variables from kernel: metric_incident, metric_thresholds
tz = pytz.timezone('Asia/Shanghai')

# 1) Filter to frontend components (exact matches)
frontends = ['frontend-0','frontend-1','frontend-2','frontend2-0','frontend']
metric_frontend_incident = metric_incident[metric_incident['cmdb_id'].isin(frontends)].copy()

# Ensure thresholds are present by merging metric_thresholds (thresholds were computed globally before filtering)
metric_frontend_incident = metric_frontend_incident.merge(
    metric_thresholds[['cmdb_id', 'kpi_name', 'global_p95', 'global_p5']],
    on=['cmdb_id', 'kpi_name'],
    how='left'
)

# 2) Compute strict anomaly booleans and helper earliest strict epoch column
metric_frontend_incident['anomaly_high_strict'] = metric_frontend_incident['value'] > metric_frontend_incident['global_p95']
metric_frontend_incident['anomaly_low_strict']  = metric_frontend_incident['value'] < metric_frontend_incident['global_p5']
metric_frontend_incident['any_strict'] = metric_frontend_incident['anomaly_high_strict'] | metric_frontend_incident['anomaly_low_strict']
metric_frontend_incident['strict_anom_epoch'] = np.where(metric_frontend_incident['any_strict'], metric_frontend_incident['timestamp'], np.nan)

# 3) Aggregate per (cmdb_id, kpi_name)
def sample_values_fn(s):
    vals = pd.Series(s).dropna().unique()[:5]
    return " | ".join(map(lambda x: str(x), vals))

frontend_kpi_agg = (
    metric_frontend_incident
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        count_points_incident = ('value', 'count'),
        anomaly_count_high_strict = ('anomaly_high_strict', 'sum'),
        anomaly_count_low_strict  = ('anomaly_low_strict', 'sum'),
        max_value_incident = ('value', 'max'),
        min_value_incident = ('value', 'min'),
        earliest_strict_anomaly_epoch = ('strict_anom_epoch', 'min'),
        sample_values = ('value', sample_values_fn)
    )
)

# Post-process types and compute totals
frontend_kpi_agg['anomaly_count_high_strict'] = frontend_kpi_agg['anomaly_count_high_strict'].astype(int)
frontend_kpi_agg['anomaly_count_low_strict'] = frontend_kpi_agg['anomaly_count_low_strict'].astype(int)
frontend_kpi_agg['total_anomalies_strict'] = frontend_kpi_agg['anomaly_count_high_strict'] + frontend_kpi_agg['anomaly_count_low_strict']

# Convert earliest epoch to int where present and add local string
def epoch_to_local_str(x):
    if pd.isna(x):
        return ''
    return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S')

frontend_kpi_agg['earliest_strict_anomaly_epoch'] = frontend_kpi_agg['earliest_strict_anomaly_epoch'].apply(lambda v: int(v) if not pd.isna(v) else np.nan)
frontend_kpi_agg['earliest_strict_anomaly_local'] = frontend_kpi_agg['earliest_strict_anomaly_epoch'].apply(lambda v: epoch_to_local_str(v) if not pd.isna(v) else '')

# 4) Join back global thresholds for final output columns (ensure present)
frontend_kpi_agg = frontend_kpi_agg.merge(
    metric_thresholds[['cmdb_id', 'kpi_name', 'global_p95', 'global_p5']],
    on=['cmdb_id', 'kpi_name'],
    how='left'
)

# 5) Prepare top-20 (cmdb_id, kpi_name) sorted by total_anomalies_strict desc
frontend_top20 = frontend_kpi_agg.sort_values('total_anomalies_strict', ascending=False).head(20).reset_index(drop=True)

# Select column order requested
frontend_top20 = frontend_top20[[
    'cmdb_id', 'kpi_name',
    'count_points_incident',
    'anomaly_count_high_strict', 'anomaly_count_low_strict', 'total_anomalies_strict',
    'earliest_strict_anomaly_epoch', 'earliest_strict_anomaly_local',
    'max_value_incident', 'min_value_incident', 'sample_values',
    'global_p95', 'global_p5'
]]

# 6) Aggregated per-cmdb_id summary for these frontend cmdb_ids
agg_cmdb = (
    frontend_kpi_agg
    .groupby('cmdb_id', as_index=False)
    .agg(
        sum_total_anomalies_strict = ('total_anomalies_strict', 'sum'),
        num_kpis_with_strict_anomaly = ('total_anomalies_strict', lambda s: int((s > 0).sum())),
        earliest_strict_anomaly_epoch = ('earliest_strict_anomaly_epoch', 'min')
    )
)

agg_cmdb['earliest_strict_anomaly_epoch'] = agg_cmdb['earliest_strict_anomaly_epoch'].apply(lambda v: int(v) if not pd.isna(v) else np.nan)
agg_cmdb['earliest_strict_anomaly_local'] = agg_cmdb['earliest_strict_anomaly_epoch'].apply(lambda v: epoch_to_local_str(v) if not pd.isna(v) else '')

frontend_cmdb_summary_top20 = agg_cmdb.sort_values('sum_total_anomalies_strict', ascending=False).head(20).reset_index(drop=True)
frontend_cmdb_summary_top20 = frontend_cmdb_summary_top20[[
    'cmdb_id', 'sum_total_anomalies_strict', 'num_kpis_with_strict_anomaly',
    'earliest_strict_anomaly_epoch', 'earliest_strict_anomaly_local'
]]

# Expose the two bounded tables for inspection
frontend_top20, frontend_cmdb_summary_top20
