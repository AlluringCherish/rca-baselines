import pandas as pd
import numpy as np
import pytz

# Reuse existing timezone
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure df_metric_anoms exists
if 'df_metric_anoms' not in globals():
    raise RuntimeError("df_metric_anoms not found in kernel. Run previous steps to create it.")

# Ensure ts_dt exists and is tz-aware
if 'ts_dt' not in df_metric_anoms.columns:
    df_metric_anoms['timestamp'] = pd.to_numeric(df_metric_anoms['timestamp'], errors='coerce').astype('Int64')
    df_metric_anoms['ts_dt'] = pd.to_datetime(df_metric_anoms['timestamp'].astype('int64'), unit='s', utc=True).dt.tz_convert(tz)
else:
    # coerce to datetime & tz if needed
    df_metric_anoms['ts_dt'] = pd.to_datetime(df_metric_anoms['ts_dt']).dt.tz_convert(tz)

# Define window
start_ts = pd.Timestamp('2022-03-21 10:00:00', tz=tz)
end_ts = pd.Timestamp('2022-03-21 10:30:00', tz=tz)
full_minutes = pd.date_range(start=start_ts, end=end_ts, freq='T', tz=tz)

# 1) Per-minute total anomaly count across all component-KPIs in window
df_window_anoms = df_metric_anoms[(df_metric_anoms['ts_dt'] >= start_ts) & (df_metric_anoms['ts_dt'] <= end_ts)].copy()
df_anom_total_per_min = (
    df_window_anoms.groupby('ts_dt').size().reindex(full_minutes, fill_value=0).rename('total_anom_count').reset_index()
    .rename(columns={'index':'ts_dt'})  # though index name may differ, ensure column names as requested
)
df_anom_total_per_min.columns = ['ts_dt', 'total_anom_count']

# 2) Top 3 minutes with highest total_anom_count; mean and std across window
df_anom_top3 = df_anom_total_per_min.sort_values('total_anom_count', ascending=False).head(3).reset_index(drop=True)
anom_mean = float(df_anom_total_per_min['total_anom_count'].mean())
anom_std = float(df_anom_total_per_min['total_anom_count'].std(ddof=0))  # population std (ddof=0)

# 3) Top 6 components by num_faulty_kpis from df_anom_by_component
if 'df_anom_by_component' not in globals():
    raise RuntimeError("df_anom_by_component not found in kernel.")

top6_components = df_anom_by_component.sort_values('num_faulty_kpis', ascending=False).head(6)['cmdb_id'].tolist()

# Per-minute anomaly counts for those top6 components over the window (31 rows)
# Group df_window_anoms by ts_dt and cmdb_id and count
df_counts_by_min_comp = df_window_anoms.groupby(['ts_dt', 'cmdb_id']).size().reset_index(name='count')
# Pivot to have one column per component
df_anom_top6_per_min = (
    df_counts_by_min_comp.pivot(index='ts_dt', columns='cmdb_id', values='count')
    .reindex(full_minutes)  # ensure full minute index
    .fillna(0)
    .astype(int)
)
# Keep only top6 columns and reset index to have ts_dt column
missing_cols = [c for c in top6_components if c not in df_anom_top6_per_min.columns]
# add missing columns as zeros if any
for c in missing_cols:
    df_anom_top6_per_min[c] = 0
df_anom_top6_per_min = df_anom_top6_per_min[top6_components].reset_index().rename(columns={'index':'ts_dt'})

# 4) For each of the top 3 minutes, list up to 20 components that had >0 anomalies at that minute
rows = []
for _, r in df_anom_top3.iterrows():
    ts = r['ts_dt']
    # get per-component counts at this minute
    comp_counts = df_window_anoms[df_window_anoms['ts_dt'] == ts].groupby('cmdb_id').size().reset_index(name='count')
    comp_counts = comp_counts.sort_values('count', ascending=False).head(20).reset_index(drop=True)
    rows.append({'ts_dt': ts, 'top_components': comp_counts})
df_top3_components_per_min = pd.DataFrame(rows)

# Keep intermediate full DataFrames in kernel variables:
# df_window_anoms, df_anom_total_per_min, df_anom_top3, df_anom_top6_per_min, df_top3_components_per_min

# Return compact outputs (variables displayed)
df_anom_total_per_min, df_anom_top3, pd.Series({'mean_total_anom_count': anom_mean, 'std_total_anom_count': anom_std}), df_anom_top6_per_min, df_top3_components_per_min
