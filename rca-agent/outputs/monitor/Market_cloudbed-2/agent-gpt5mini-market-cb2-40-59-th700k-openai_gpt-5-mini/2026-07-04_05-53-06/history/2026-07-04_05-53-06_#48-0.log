import pandas as pd
import numpy as np
import pytz

# reuse tz if available
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure df_anom_by_component and df_trace_anom_by_component exist
if 'df_anom_by_component' not in globals():
    raise RuntimeError("df_anom_by_component not found in kernel.")
if 'df_trace_anom_by_component' not in globals():
    # not strictly required for this step, but warning if missing
    df_trace_anom_by_component = pd.DataFrame()

# 1) Group df_anom_by_component by earliest_anom_ts -> component_count
_df_comp = df_anom_by_component.copy()
# normalize column type
_df_comp['earliest_anom_ts'] = pd.to_datetime(_df_comp['earliest_anom_ts'])
df_earliest_counts = (
    _df_comp.groupby('earliest_anom_ts', sort=True)
            .agg(component_count=('cmdb_id','count'))
            .reset_index()
            .sort_values('earliest_anom_ts', ascending=True)
)
# limit to up to 50 rows as requested (full list up to 50)
df_earliest_counts = df_earliest_counts.head(50)

# 2) For the top 10 earliest_anom_ts by component_count (chronologically sorted),
#    list up to 20 cmdb_id values per timestamp.
# First select top 10 by component_count, then sort those timestamps chronologically.
_top_ts = (
    df_earliest_counts
    .sort_values('component_count', ascending=False)
    .head(10)
)
_top_ts = _top_ts.sort_values('earliest_anom_ts', ascending=True)

# For each timestamp, collect up to 20 cmdb_id that have that earliest_anom_ts
rows = []
for ts in _top_ts['earliest_anom_ts']:
    cmdbs = _df_comp[_df_comp['earliest_anom_ts'] == ts]['cmdb_id'].tolist()[:20]
    rows.append({'earliest_anom_ts': ts, 'cmdb_ids': cmdbs})

df_top10_cmdbs_per_ts = pd.DataFrame(rows)

# 3) error_logs processing
# Determine error dataframe variable name (df_error or df_error_logs)
if 'df_error' in globals():
    df_error_logs = df_error.copy()
elif 'df_error_logs' in globals():
    df_error_logs = df_error_logs.copy()
else:
    raise RuntimeError("error_logs DataFrame not found (expected df_error or df_error_logs).")

# Ensure timestamp numeric and tz-aware datetime column
df_error_logs['timestamp'] = pd.to_numeric(df_error_logs['timestamp'], errors='coerce').astype('Int64')
df_error_logs['ts_dt'] = pd.to_datetime(df_error_logs['timestamp'].astype('int64'), unit='s', utc=True).dt.tz_convert(tz)

# Filter to window March 21, 2022 10:00:00 to 10:30:00 inclusive (UTC+8)
start_ts = pd.Timestamp('2022-03-21 10:00:00', tz=tz)
end_ts = pd.Timestamp('2022-03-21 10:30:00', tz=tz)
df_error_window = df_error_logs[(df_error_logs['ts_dt'] >= start_ts) & (df_error_logs['ts_dt'] <= end_ts)].copy()

# Build full minute index for the window to ensure missing minutes show zero
full_minutes = pd.date_range(start=start_ts, end=end_ts, freq='T', tz=tz)

# Per-minute total error count across all cmdb_id
df_error_total_per_min = (
    df_error_window.groupby('ts_dt').size().reindex(full_minutes, fill_value=0).rename('total_error_count').reset_index()
    .rename(columns={'index':'ts_dt'})
)
# Ensure column names
df_error_total_per_min.columns = ['ts_dt','total_error_count']

# Top 5 cmdb_id by total errors in this window
df_error_top5 = (
    df_error_window.groupby('cmdb_id').size().reset_index(name='total_errors')
    .sort_values('total_errors', ascending=False)
    .head(5)
)
# If fewer than 5, will just have fewer rows

top5_cmdbs = df_error_top5['cmdb_id'].tolist()

# For each top5 cmdb_id, compute per-minute counts and pivot into a single DataFrame
if top5_cmdbs:
    df_err_by_min_and_cmdb = (
        df_error_window.groupby(['ts_dt','cmdb_id']).size().reset_index(name='count')
    )
    # Pivot to have columns per cmdb_id
    df_error_top5_ts = df_err_by_min_and_cmdb.pivot(index='ts_dt', columns='cmdb_id', values='count').reindex(full_minutes).fillna(0).astype(int)
    # Keep only top5 columns in order
    df_error_top5_ts = df_error_top5_ts[top5_cmdbs]
    df_error_top5_ts.index.name = 'ts_dt'
    # Reset index to show ts_dt as column for compact display
    df_error_top5_ts = df_error_top5_ts.reset_index()
    # Limit each per-cmdb series to up to 30 rows for compactness when displayed later (we will return head(30))
    df_error_top5_ts_limited = df_error_top5_ts.head(30)
else:
    # Empty structure
    df_error_top5_ts = pd.DataFrame(columns=['ts_dt'] + top5_cmdbs)
    df_error_top5_ts_limited = df_error_top5_ts

# Save intermediate full structures in kernel variables:
# df_earliest_counts, df_top10_cmdbs_per_ts, df_error_window, df_error_total_per_min, df_error_top5, df_error_top5_ts

# Return compact outputs (variables). Use commas to display multiple items.
df_earliest_counts, df_top10_cmdbs_per_ts, df_error_total_per_min, df_error_top5, df_error_top5_ts_limited
