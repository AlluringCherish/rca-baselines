import pandas as pd
import numpy as np
import pytz

# Reuse existing df_trace and tz if present; otherwise set tz
try:
    df_trace
except NameError:
    raise RuntimeError("df_trace not found in kernel. Please load trace.csv first.")

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure numeric values and tz-aware datetime column exist
df_trace['value'] = pd.to_numeric(df_trace['value'], errors='coerce')
if 'ts_dt' not in df_trace.columns:
    df_trace['timestamp'] = pd.to_numeric(df_trace['timestamp'], errors='coerce').astype('Int64')
    df_trace['ts_dt'] = pd.to_datetime(df_trace['timestamp'].astype('int64'), unit='s', utc=True).dt.tz_convert(tz)

# 1) Global thresholds per (cmdb_id, trace_name) using the full series
df_trace_thresholds = (
    df_trace
    .dropna(subset=['value'])
    .groupby(['cmdb_id', 'trace_name'])['value']
    .agg(p95=lambda x: x.quantile(0.95), p05=lambda x: x.quantile(0.05))
    .reset_index()
)

# 2) Filter to the time window March 21, 2022 10:00:00 to 10:30:00 inclusive (UTC+8)
start_ts = pd.Timestamp('2022-03-21 10:00:00', tz=tz)
end_ts = pd.Timestamp('2022-03-21 10:30:00', tz=tz)
df_trace_window = df_trace[(df_trace['ts_dt'] >= start_ts) & (df_trace['ts_dt'] <= end_ts)].copy()

# 3) Flag anomalies in the window using global thresholds (merge thresholds)
df_trace_window = df_trace_window.merge(df_trace_thresholds, on=['cmdb_id','trace_name'], how='left')
df_trace_window['high_anom'] = df_trace_window['value'] >= df_trace_window['p95']
df_trace_window['low_anom'] = df_trace_window['value'] <= df_trace_window['p05']

df_trace_anoms = df_trace_window[df_trace_window['high_anom'] | df_trace_window['low_anom']].copy()

# 4) Aggregate by (cmdb_id, trace_name)
if not df_trace_anoms.empty:
    df_trace_anom_summary = (
        df_trace_anoms
        .groupby(['cmdb_id','trace_name'])
        .agg(
            count_high = ('high_anom', 'sum'),
            count_low = ('low_anom', 'sum'),
            earliest_anom_ts = ('ts_dt', 'min'),
            max_value_in_window = ('value', 'max'),
            min_value_in_window = ('value', 'min'),
            p95 = ('p95', 'first'),
            p05 = ('p05', 'first')
        )
        .reset_index()
    )
else:
    df_trace_anom_summary = pd.DataFrame(columns=[
        'cmdb_id','trace_name','count_high','count_low','earliest_anom_ts',
        'max_value_in_window','min_value_in_window','p95','p05'
    ])

# 5) Aggregate by component (cmdb_id)
_df = df_trace_anom_summary.copy()
if not _df.empty:
    _df['total_count'] = _df['count_high'].fillna(0).astype(int) + _df['count_low'].fillna(0).astype(int)
    # example_top_trace per component
    best_trace = (
        _df.sort_values(['cmdb_id','total_count'], ascending=[True, False])
           .drop_duplicates(subset=['cmdb_id'])
           .loc[:, ['cmdb_id','trace_name','total_count']]
           .rename(columns={'trace_name':'example_top_trace','total_count':'example_top_trace_count'})
    )
    agg_comp = _df.groupby('cmdb_id').agg(
        num_faulty_traces = ('trace_name', 'nunique'),
        sum_count_high = ('count_high', 'sum'),
        sum_count_low = ('count_low', 'sum'),
        earliest_anom_ts = ('earliest_anom_ts', 'min'),
        latest_anom_ts = ('earliest_anom_ts', 'max')
    ).reset_index()
    df_trace_anom_by_component = agg_comp.merge(best_trace[['cmdb_id','example_top_trace']], on='cmdb_id', how='left')
else:
    df_trace_anom_by_component = pd.DataFrame(columns=[
        'cmdb_id','num_faulty_traces','sum_count_high','sum_count_low',
        'earliest_anom_ts','latest_anom_ts','example_top_trace'
    ])

# Prepare compact outputs
df_trace_anom_by_component_top20 = df_trace_anom_by_component.sort_values(
    by='num_faulty_traces', ascending=False
).head(20)[
    ['cmdb_id','num_faulty_traces','sum_count_high','sum_count_low','earliest_anom_ts','latest_anom_ts','example_top_trace']
]

total_components_with_faulty_traces = int(df_trace_anom_by_component.shape[0])

# Distinct earliest_anom_ts values across components (chronologically sorted), up to 10
if not df_trace_anom_by_component.empty:
    earliest_ts_unique_df = (
        df_trace_anom_by_component[['earliest_anom_ts']]
        .drop_duplicates()
        .sort_values('earliest_anom_ts', ascending=True)
        .head(10)
        .reset_index(drop=True)
    )
else:
    earliest_ts_unique_df = pd.DataFrame(columns=['earliest_anom_ts'])

# Return compact results (variables)
df_trace_thresholds.shape, df_trace_anom_by_component_top20, total_components_with_faulty_traces, earliest_ts_unique_df
