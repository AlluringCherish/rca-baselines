import pandas as pd
import pytz

# timezone UTC+8
tz = pytz.timezone('Asia/Shanghai')

# Load CSVs into kernel variables (full DataFrames retained)
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')
df_log = pd.read_csv('log.csv')
df_error = pd.read_csv('error_logs.csv')

# Ensure timestamp is numeric and create timezone-aware datetime columns (UTC->convert to Asia/Shanghai)
for df in (df_metric, df_trace, df_log, df_error):
    # coerce to numeric to avoid issues
    df['timestamp'] = pd.to_numeric(df['timestamp'], errors='coerce').astype('Int64')
    df['ts_dt'] = pd.to_datetime(df['timestamp'].astype('int64'), unit='s', utc=True).dt.tz_convert(tz)

# 1) metric.csv summary
metric_count = df_metric.shape[0]
metric_top_pairs = (
    df_metric.groupby(['cmdb_id', 'kpi_name'])
    .size()
    .sort_values(ascending=False)
    .head(20)
    .reset_index(name='count')
)
metric_unique_cmdb = pd.DataFrame(pd.Series(df_metric['cmdb_id'].dropna().unique()[:50]), columns=['cmdb_id'])
metric_unique_kpi = pd.DataFrame(pd.Series(df_metric['kpi_name'].dropna().unique()[:50]), columns=['kpi_name'])
metric_ts_min = df_metric['ts_dt'].min()
metric_ts_max = df_metric['ts_dt'].max()

# 2) trace.csv summary
trace_count = df_trace.shape[0]
trace_top_pairs = (
    df_trace.groupby(['cmdb_id', 'trace_name'])
    .size()
    .sort_values(ascending=False)
    .head(20)
    .reset_index(name='count')
)
trace_unique_cmdb = pd.DataFrame(pd.Series(df_trace['cmdb_id'].dropna().unique()[:50]), columns=['cmdb_id'])
trace_unique_trace = pd.DataFrame(pd.Series(df_trace['trace_name'].dropna().unique()[:50]), columns=['trace_name'])
trace_ts_min = df_trace['ts_dt'].min()
trace_ts_max = df_trace['ts_dt'].max()

# 3) log.csv summary
log_count = df_log.shape[0]
log_top_pairs = (
    df_log.groupby(['cmdb_id', 'log_name'])
    .size()
    .sort_values(ascending=False)
    .head(20)
    .reset_index(name='count')
)
log_unique_cmdb = pd.DataFrame(pd.Series(df_log['cmdb_id'].dropna().unique()[:50]), columns=['cmdb_id'])
log_unique_logname = pd.DataFrame(pd.Series(df_log['log_name'].dropna().unique()[:50]), columns=['log_name'])
log_ts_min = df_log['ts_dt'].min()
log_ts_max = df_log['ts_dt'].max()

# 4) error_logs.csv summary
error_count = df_error.shape[0]
error_top_cmdb = (
    df_error.groupby(['cmdb_id'])
    .size()
    .sort_values(ascending=False)
    .head(20)
    .reset_index(name='count')
)
error_unique_cmdb = pd.DataFrame(pd.Series(df_error['cmdb_id'].dropna().unique()[:50]), columns=['cmdb_id'])
error_ts_min = df_error['ts_dt'].min()
error_ts_max = df_error['ts_dt'].max()

# Compact summary outputs (variables displayed; limited rows for DataFrames)
metric_count, metric_top_pairs, metric_unique_cmdb, metric_unique_kpi, metric_ts_min, metric_ts_max, \
trace_count, trace_top_pairs, trace_unique_cmdb, trace_unique_trace, trace_ts_min, trace_ts_max, \
log_count, log_top_pairs, log_unique_cmdb, log_unique_logname, log_ts_min, log_ts_max, \
error_count, error_top_cmdb, error_unique_cmdb, error_ts_min, error_ts_max
