    if 'earliest_anom_ts' in df_t.columns:
        df_t['earliest_anom_ts'] = pd.to_datetime(df_t['earliest_anom_ts']).dt.tz_convert(tz)
    # Filter to component and window (df_trace_anom_summary should already be from window, but ensure)
    df_f = df_t[(df_t['cmdb_id'] == component) & (df_t['earliest_anom_ts'] >= start_ts) & (df_t['earliest_anom_ts'] <= end_ts)].copy()
    if df_f.empty:
        # return empty with requested columns
        cols = ['trace_name','count_high','count_low','earliest_anom_ts','max_value_in_window','p95','p05']
        return pd.DataFrame(columns=cols)
    df_f['total_count'] = df_f['count_high'].fillna(0).astype(int) + df_f['count_low'].fillna(0).astype(int)
    df_top = df_f.sort_values('total_count', ascending=False).head(20)
    # select/rename columns as requested
    out = df_top[['trace_name','count_high','count_low','earliest_anom_ts','max_value_in_window','p95','p05']].reset_index(drop=True)
    return out

# Helper: get trace-anom-by-component row
def get_trace_comp_row(component):
    df_tb = df_trace_anom_by_component.copy()
    if component in df_tb['cmdb_id'].values:
        row = df_tb[df_tb['cmdb_id'] == component][['cmdb_id','num_faulty_traces','sum_count_high','sum_count_low','earliest_anom_ts','latest_anom_ts','example_top_trace']].reset_index(drop=True)
        return row
    else:
