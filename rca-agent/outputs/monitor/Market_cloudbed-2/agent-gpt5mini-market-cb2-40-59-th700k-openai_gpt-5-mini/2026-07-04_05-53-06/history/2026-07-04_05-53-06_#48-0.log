import pandas as pd
import numpy as np
import pytz

# Ensure required DataFrame exists
if 'df_anom_summary' not in globals():
    raise RuntimeError("df_anom_summary not found in kernel.")

# timezone UTC+8
tz = pytz.timezone('Asia/Shanghai')

# Normalize earliest_anom_ts to timezone-aware datetime
df_anom_summary['earliest_anom_ts'] = pd.to_datetime(df_anom_summary['earliest_anom_ts'])
# If naive, localize to UTC then convert; safest: assume timestamps are timezone-aware or represent local time in UTC+8
# We'll convert any tz-naive to tz-aware using Asia/Shanghai
if df_anom_summary['earliest_anom_ts'].dt.tz is None:
    df_anom_summary['earliest_anom_ts'] = df_anom_summary['earliest_anom_ts'].dt.tz_localize(tz)
else:
    df_anom_summary['earliest_anom_ts'] = df_anom_summary['earliest_anom_ts'].dt.tz_convert(tz)

# Ensure numeric columns
df_anom_summary['max_value_in_window'] = pd.to_numeric(df_anom_summary['max_value_in_window'], errors='coerce')
df_anom_summary['p95'] = pd.to_numeric(df_anom_summary['p95'], errors='coerce')
df_anom_summary['p05'] = pd.to_numeric(df_anom_summary['p05'], errors='coerce')
df_anom_summary['count_high'] = pd.to_numeric(df_anom_summary['count_high'], errors='coerce').fillna(0).astype(int)
df_anom_summary['count_low'] = pd.to_numeric(df_anom_summary['count_low'], errors='coerce').fillna(0).astype(int)

# Function to produce top20 and count for a given target timestamp string
def analyze_peak(ts_str):
    target_ts = pd.Timestamp(ts_str, tz=tz)
    df_f = df_anom_summary[df_anom_summary['earliest_anom_ts'] == target_ts].copy()
    total_faulty_kpis = int(df_f.shape[0])
    if total_faulty_kpis == 0:
        top20 = df_f.head(20)[['cmdb_id','kpi_name','earliest_anom_ts','count_high','count_low','max_value_in_window','p95','p05']]
        top20['severity_ratio'] = np.nan
        # Reorder columns to requested order with severity_ratio after earliest_anom_ts
        top20 = top20[['cmdb_id','kpi_name','earliest_anom_ts','severity_ratio','count_high','count_low','max_value_in_window','p95','p05']]
        return total_faulty_kpis, top20
    # compute severity_ratio safely
    df_f['severity_ratio'] = np.where(df_f['p95'].fillna(0) != 0, df_f['max_value_in_window'] / df_f['p95'], np.nan)
