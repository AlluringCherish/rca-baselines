import pandas as pd
import numpy as np
import pytz

# Reuse timezone and existing variables where possible
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure we have the per-window anomaly rows in df_window_anoms (created earlier)
if 'df_window_anoms' in globals():
    df_anom_window = df_window_anoms
elif 'df_metric_anoms' in globals():
    # filter df_metric_anoms into window if df_window_anoms not present
    df_anom_window = df_metric_anoms.copy()
else:
    raise RuntimeError("No df_window_anoms or df_metric_anoms found in kernel.")

# Normalize timestamps to tz-aware ts_dt
if 'ts_dt' not in df_anom_window.columns:
    df_anom_window['timestamp'] = pd.to_numeric(df_anom_window['timestamp'], errors='coerce').astype('Int64')
    df_anom_window['ts_dt'] = pd.to_datetime(df_anom_window['timestamp'].astype('int64'), unit='s', utc=True).dt.tz_convert(tz)
else:
    df_anom_window['ts_dt'] = pd.to_datetime(df_anom_window['ts_dt']).dt.tz_convert(tz)

# Define window minutes
start_ts = pd.Timestamp('2022-03-21 10:00:00', tz=tz)
end_ts = pd.Timestamp('2022-03-21 10:30:00', tz=tz)
full_minutes = pd.date_range(start=start_ts, end=end_ts, freq='T', tz=tz)

# 1) Compute per-minute per-component anomaly counts (pivot table)
df_counts_min_comp = (
    df_anom_window
    .loc[(df_anom_window['ts_dt'] >= start_ts) & (df_anom_window['ts_dt'] <= end_ts), :]
    .groupby(['ts_dt', 'cmdb_id'])
    .size()
    .reset_index(name='count')
)

df_counts_pivot = (
    df_counts_min_comp
    .pivot(index='ts_dt', columns='cmdb_id', values='count')
    .reindex(full_minutes)  # ensure full minute index
    .fillna(0)
    .astype(int)
)

# store full intermediate in kernel variable
df_comp_min_counts = df_counts_pivot.copy()

# 2) For target minutes 10:29 and 10:28, compute counts and baseline means
ts_1029 = pd.Timestamp('2022-03-21 10:29:00', tz=tz)
ts_1028 = pd.Timestamp('2022-03-21 10:28:00', tz=tz)

# Ensure index contains these timestamps; if not, they'll raise KeyError when selecting - handle safely
def get_min_series(pivot_df, ts):
    if ts in pivot_df.index:
        return pivot_df.loc[ts]
