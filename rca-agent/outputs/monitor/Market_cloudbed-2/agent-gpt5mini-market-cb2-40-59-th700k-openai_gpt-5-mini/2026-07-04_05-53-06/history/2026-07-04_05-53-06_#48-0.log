import pandas as pd
import pytz
import numpy as np

# timezone UTC+8
tz = pytz.timezone('Asia/Shanghai')

# Reuse existing kernel variables: df_metric_window, df_metric_thresholds, df_metric_anoms, df_anom_summary
# Ensure required DataFrames exist
for name in ('df_metric_window', 'df_metric_thresholds'):
    if name not in globals():
        raise RuntimeError(f"{name} not found in kernel.")

# Ensure ts_dt exists and is timezone-aware in df_metric_window
if 'ts_dt' not in df_metric_window.columns:
    df_metric_window['timestamp'] = pd.to_numeric(df_metric_window['timestamp'], errors='coerce').astype('Int64')
    df_metric_window['ts_dt'] = pd.to_datetime(df_metric_window['timestamp'].astype('int64'), unit='s', utc=True).dt.tz_convert(tz)
else:
    df_metric_window['ts_dt'] = pd.to_datetime(df_metric_window['ts_dt']).dt.tz_convert(tz)

# Targets and minute timestamps
component = 'frontend-0'
ts_1028 = pd.Timestamp('2022-03-21 10:28:00', tz=tz)
ts_1029 = pd.Timestamp('2022-03-21 10:29:00', tz=tz)

# Filter metric rows for the component within the window (df_metric_window already restricted to window)
df_f = df_metric_window[df_metric_window['cmdb_id'] == component].copy()

# Aggregate values at 10:28 and 10:29 by kpi_name (mean if multiple rows)
vals_1028 = (
    df_f[df_f['ts_dt'] == ts_1028]
    .groupby('kpi_name')['value']
    .mean()
    .rename('value_1028')
)
vals_1029 = (
    df_f[df_f['ts_dt'] == ts_1029]
    .groupby('kpi_name')['value']
    .mean()
    .rename('value_1029')
)

# Combine KPI list (union of KPIs seen in either minute)
df_vals = pd.concat([vals_1028, vals_1029], axis=1).reset_index()

# Merge global thresholds for frontend-0 from df_metric_thresholds (global p95/p05 precomputed)
df_thresh_f = df_metric_thresholds[df_metric_thresholds['cmdb_id'] == component][['kpi_name','p95','p05']]
df_kpi = df_vals.merge(df_thresh_f, on='kpi_name', how='left')

# Compute delta and severity_ratio (use p95; if p95==0 set NaN)
df_kpi['delta'] = df_kpi['value_1029'] - df_kpi['value_1028']
df_kpi['severity_ratio'] = np.where(df_kpi['p95'].fillna(0) != 0, df_kpi['value_1029'] / df_kpi['p95'], np.nan)

# Add count_high_in_window from df_metric_anoms (sum of high_anom per KPI for this component)
if 'df_metric_anoms' in globals():
    grp_high = (
        df_metric_anoms[df_metric_anoms['cmdb_id'] == component]
        .groupby('kpi_name')['high_anom']
        .sum()
        .rename('count_high_in_window')
    )
    df_kpi = df_kpi.merge(grp_high.reset_index(), on='kpi_name', how='left')
else:
    df_kpi['count_high_in_window'] = 0

df_kpi['count_high_in_window'] = df_kpi['count_high_in_window'].fillna(0).astype(int)

# Add earliest_anom_ts for each KPI from df_anom_summary if available
if 'df_anom_summary' in globals():
    df_earliest = df_anom_summary[df_anom_summary['cmdb_id'] == component][['kpi_name','earliest_anom_ts']].drop_duplicates(subset=['kpi_name'])
    # ensure tz-aware
    if not df_earliest.empty:
        df_earliest['earliest_anom_ts'] = pd.to_datetime(df_earliest['earliest_anom_ts']).dt.tz_convert(tz)
    df_kpi = df_kpi.merge(df_earliest, on='kpi_name', how='left')
else:
    df_kpi['earliest_anom_ts'] = pd.NaT

# Reorder columns as requested and sort by delta desc
df_frontend0_kpi_changes_all = df_kpi[[
    'kpi_name','value_1028','value_1029','delta','p95','p05','severity_ratio','count_high_in_window','earliest_anom_ts'
]].copy()

df_frontend0_kpi_changes_all = df_frontend0_kpi_changes_all.sort_values(by='delta', ascending=False).reset_index(drop=True)

# Top 20 rows
df_frontend0_kpi_changes_top20 = df_frontend0_kpi_changes_all.head(20)

# Count of frontend-0 KPIs with positive delta
number_of_frontend0_kpis_with_positive_delta = int((df_frontend0_kpi_changes_all['delta'] > 0).sum())

# Store full intermediate in kernel variables for follow-up
df_frontend0_kpi_changes_all = df_frontend0_kpi_changes_all  # full table
df_frontend0_kpi_changes_top20 = df_frontend0_kpi_changes_top20

# Compact outputs (variables to display)
df_frontend0_kpi_changes_top20, number_of_frontend0_kpis_with_positive_delta
