# Helper: log and error summaries for a component
def get_log_error_summaries(component):
    # Log rows in window for component
    df_log_win = df_log[(df_log['cmdb_id'] == component) & (df_log['ts_dt'] >= start_ts) & (df_log['ts_dt'] <= end_ts)].copy()
    total_log_rows = int(df_log_win.shape[0])
    # Per-minute log.error_count totals: filter log_name == 'log.error_count'
    df_log_errcount = df_log_win[df_log_win['log_name'] == 'log.error_count'].copy()
    if not df_log_errcount.empty:
        per_min = df_log_errcount.groupby('ts_dt')['value'].sum().reindex(full_minutes, fill_value=0).reset_index().rename(columns={'index':'ts_dt','value':'log_error_count'})
        per_min.columns = ['ts_dt','log_error_count']
    else:
        # create zero-filled per-minute series
        per_min = pd.DataFrame({'ts_dt': full_minutes, 'log_error_count': [0]*len(full_minutes)})
    # Error logs raw messages for component in window (up to 20): df_err has columns timestamp, cmdb_id, message, ts_dt
    if not df_err.empty and 'cmdb_id' in df_err.columns:
        df_err_win = df_err[(df_err['cmdb_id'] == component) & (df_err['ts_dt'] >= start_ts) & (df_err['ts_dt'] <= end_ts)].copy()
        if 'message' in df_err_win.columns:
