import numpy as np
import pandas as pd

# Reuse existing df_anom_summary from kernel
# Ensure expected columns exist
_expected_cols = {'cmdb_id','kpi_name','count_high','count_low','earliest_anom_ts','max_value_in_window','p95'}
missing = _expected_cols - set(df_anom_summary.columns)
if missing:
    raise RuntimeError(f"df_anom_summary is missing expected columns: {missing}")

# Work on a copy
_df = df_anom_summary.copy()

# Compute severity ratio per KPI: max_value_in_window / p95 when p95 != 0, else NaN
_df['p95'] = pd.to_numeric(_df['p95'], errors='coerce')
_df['max_value_in_window'] = pd.to_numeric(_df['max_value_in_window'], errors='coerce')
_df['severity_ratio'] = np.where(_df['p95'].fillna(0) != 0, _df['max_value_in_window'] / _df['p95'], np.nan)

# Compute total counts per KPI to choose example_top_kpi
_df['total_count'] = _df['count_high'].fillna(0).astype(int) + _df['count_low'].fillna(0).astype(int)

# Prepare example_top_kpi mapping: for each cmdb_id, pick kpi_name with highest total_count (tie -> first)
_best = (
    _df.sort_values(['cmdb_id', 'total_count'], ascending=[True, False])
       .drop_duplicates(subset=['cmdb_id'])
       .loc[:, ['cmdb_id', 'kpi_name', 'total_count']]
       .rename(columns={'kpi_name': 'example_top_kpi', 'total_count': 'example_top_kpi_count'})
)

# Aggregate per component
agg = _df.groupby('cmdb_id').agg(
    num_faulty_kpis = ('kpi_name', 'nunique'),
    sum_count_high = ('count_high', 'sum'),
    sum_count_low = ('count_low', 'sum'),
    earliest_anom_ts = ('earliest_anom_ts', 'min'),
    latest_anom_ts = ('earliest_anom_ts', 'max'),  # per instructions: max of earliest_anom_ts across KPIs
    max_severity_metric = ('severity_ratio', 'max')
).reset_index()

# Merge the example_top_kpi
df_anom_by_component = agg.merge(_best[['cmdb_id','example_top_kpi']], on='cmdb_id', how='left')

# Ensure ordering of columns as requested
df_anom_by_component = df_anom_by_component[
    ['cmdb_id','num_faulty_kpis','sum_count_high','sum_count_low',
     'earliest_anom_ts','latest_anom_ts','max_severity_metric','example_top_kpi']
]

# Prepare outputs
df_anom_by_component_top20 = df_anom_by_component.sort_values(
    by='num_faulty_kpis', ascending=False
).head(20)

total_components_with_faults = int(df_anom_by_component.shape[0])

# List up to 10 components whose earliest_anom_ts is the earliest chronologically
earliest_components_top10 = df_anom_by_component.sort_values('earliest_anom_ts', ascending=True).head(10)[
    ['cmdb_id','earliest_anom_ts']
]

# Return compact results (variables)
df_anom_by_component, df_anom_by_component_top20, total_components_with_faults, earliest_components_top10
