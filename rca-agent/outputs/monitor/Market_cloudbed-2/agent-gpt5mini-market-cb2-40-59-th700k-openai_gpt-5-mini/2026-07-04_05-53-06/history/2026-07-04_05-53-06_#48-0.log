import pandas as pd
import pytz

# reuse existing df_metric and tz if present; otherwise set tz
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# ensure value is numeric
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

# 1) Compute global p95 and p05 per (cmdb_id, kpi_name)
df_metric_thresholds = (
    df_metric
    .dropna(subset=['value'])
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(p95=lambda x: x.quantile(0.95), p05=lambda x: x.quantile(0.05))
    .reset_index()
)

# 2) Filter to the time window March 21, 2022 10:00:00 to 10:30:00 inclusive (UTC+8)
start_ts = pd.Timestamp('2022-03-21 10:00:00', tz=tz)
end_ts = pd.Timestamp('2022-03-21 10:30:00', tz=tz)
# ensure ts_dt exists and is tz-aware; if not, create it
if 'ts_dt' not in df_metric.columns:
    df_metric['ts_dt'] = pd.to_datetime(df_metric['timestamp'].astype('int64'), unit='s', utc=True).dt.tz_convert(tz)

df_metric_window = df_metric[(df_metric['ts_dt'] >= start_ts) & (df_metric['ts_dt'] <= end_ts)].copy()

# 3) Flag anomalies using global thresholds (merge thresholds first)
df_metric_window = df_metric_window.merge(df_metric_thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# Create boolean flags (treat missing thresholds as False)
df_metric_window['high_anom'] = df_metric_window['value'] >= df_metric_window['p95']
df_metric_window['low_anom'] = df_metric_window['value'] <= df_metric_window['p05']

df_metric_anoms = df_metric_window[df_metric_window['high_anom'] | df_metric_window['low_anom']].copy()

# 4) Aggregate anomalies by (cmdb_id, kpi_name)
if not df_metric_anoms.empty:
    df_anom_summary = (
        df_metric_anoms
        .groupby(['cmdb_id', 'kpi_name'])
        .agg(
            count_high = ('high_anom', 'sum'),
            count_low = ('low_anom', 'sum'),
            earliest_anom_ts = ('ts_dt', 'min'),
            max_value_in_window = ('value', 'max'),
            min_value_in_window = ('value', 'min'),
            p95 = ('p95', 'first'),
            p05 = ('p05', 'first')
        )
        .reset_index()
    )
else:
    # empty summary
    df_anom_summary = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','count_high','count_low','earliest_anom_ts',
        'max_value_in_window','min_value_in_window','p95','p05'
    ])

# 5) Prepare compact top-20 table sorted by max(count_high,count_low) descending
if not df_anom_summary.empty:
    df_anom_summary['max_count'] = df_anom_summary[['count_high','count_low']].max(axis=1)
    df_anom_summary = df_anom_summary.sort_values(by='max_count', ascending=False).drop(columns=['max_count'])
    df_anom_top20 = df_anom_summary[
        ['cmdb_id','kpi_name','count_high','count_low','earliest_anom_ts',
         'max_value_in_window','min_value_in_window','p95','p05']
    ].head(20)
    anom_pairs_count = int(df_anom_summary.shape[0])
else:
    df_anom_top20 = df_anom_summary.head(20)
    anom_pairs_count = 0

# Display compact results (variables returned)
df_metric_thresholds.shape, df_metric_thresholds.head(5), df_metric_window.shape, df_metric_anoms.shape, df_anom_top20, anom_pairs_count
