import pandas as pd

# Reuse metric_df if present, otherwise load
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

# Ensure expected columns exist
if 'kpi_name' not in metric_df.columns or 'cmdb_id' not in metric_df.columns:
    raise ValueError("metric.csv must contain 'kpi_name' and 'cmdb_id' columns")

# 1) Top 50 unique kpi_name values across the full metric.csv with their counts
top_kpis_df = (
    metric_df['kpi_name']
    .value_counts()
    .head(50)
    .reset_index()
    .rename(columns={'index': 'kpi_name', 'kpi_name': 'count'})
)

# 2) List all unique cmdb_id values that contain 'frontend' and 'adservice' with their row counts
frontend_counts_df = (
    metric_df[metric_df['cmdb_id'].str.contains('frontend', na=False)]
    ['cmdb_id']
    .value_counts()
    .reset_index()
    .rename(columns={'index': 'cmdb_id', 'cmdb_id': 'count'})
)

adservice_counts_df = (
    metric_df[metric_df['cmdb_id'].str.contains('adservice', na=False)]
    ['cmdb_id']
    .value_counts()
    .reset_index()
    .rename(columns={'index': 'cmdb_id', 'cmdb_id': 'count'})
)

# 3) For each cmdb_id found in (2), list the top 20 kpi_name for that cmdb_id with counts
def top_kpis_for_cmdb(cmdb_id, top_n=20):
    s = metric_df.loc[metric_df['cmdb_id'] == cmdb_id, 'kpi_name'].value_counts().head(top_n)
    return s.reset_index().rename(columns={'index': 'kpi_name', 'kpi_name': 'count'})

# Build dicts for frontend_kpis_by_cmdb and adservice_kpis_by_cmdb
frontend_kpis_by_cmdb = {}
for cmdb in frontend_counts_df['cmdb_id'].tolist():
    frontend_kpis_by_cmdb[cmdb] = top_kpis_for_cmdb(cmdb).to_dict(orient='records')

adservice_kpis_by_cmdb = {}
for cmdb in adservice_counts_df['cmdb_id'].tolist():
    adservice_kpis_by_cmdb[cmdb] = top_kpis_for_cmdb(cmdb).to_dict(orient='records')

# Assemble final JSON-serializable result (compact)
result = {
    "top_kpis": top_kpis_df.to_dict(orient='records'),                      # up to 50 rows
    "frontend_cmdbs": frontend_counts_df.to_dict(orient='records'),         # all frontend cmdbs with counts
    "adservice_cmdbs": adservice_counts_df.to_dict(orient='records'),       # all adservice cmdbs with counts
    "frontend_kpis_by_cmdb": frontend_kpis_by_cmdb,                         # for each frontend cmdb, top 20 kpis
    "adservice_kpis_by_cmdb": adservice_kpis_by_cmdb                        # for each adservice cmdb, top 20 kpis
}

