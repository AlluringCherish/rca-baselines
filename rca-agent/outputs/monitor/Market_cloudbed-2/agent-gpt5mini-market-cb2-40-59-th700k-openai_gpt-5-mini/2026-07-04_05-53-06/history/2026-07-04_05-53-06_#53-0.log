import pandas as pd
import pytz
from datetime import datetime

# Load or reuse error_logs dataframe
try:
    df_err
except NameError:
    df_err = pd.read_csv('error_logs.csv')

tz = pytz.timezone('Asia/Shanghai')

# Ensure dtypes
df_err['timestamp'] = df_err['timestamp'].astype(int)
df_err['cmdb_id'] = df_err['cmdb_id'].astype(str)
df_err['message'] = df_err['message'].astype(str).fillna('')

# Prepare lower-cased messages for case-insensitive matching
msg_lower = df_err['message'].str.lower()

# Keywords to scan (case-insensitive). Keep originals for reporting.
keywords = [
    'ENOSPC', 'no space', 'no space left', 'i/o error', 'i/o', 'io error',
    'read-only', 'filesystem', 'vda1', 'device', 'disk', 'fs', 'input/output', 'I/O'
]

rows = []
for kw in keywords:
    kw_lower = kw.lower()
    mask = msg_lower.str.contains(kw_lower, na=False)
    match_count = int(mask.sum())
    if match_count == 0:
        continue
    matched = df_err.loc[mask].copy()
    earliest_ts = int(matched['timestamp'].min())
    earliest_ts_str = pd.to_datetime(earliest_ts, unit='s', utc=True).dt.tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
    distinct_cmdbs = list(matched['cmdb_id'].dropna().unique())[:10]
    ex_rows = matched.sort_values('timestamp').head(5)
    examples = []
    for _, r in ex_rows.iterrows():
        tstr = pd.to_datetime(int(r['timestamp']), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
        msg_short = str(r['message']).replace('\n', ' ').strip()[:200]
        examples.append(f"{tstr} {r['cmdb_id']}: {msg_short}")
    rows.append({
        'keyword': kw,
        'match_count': match_count,
        'earliest_matching_timestamp': earliest_ts_str,
        'distinct_cmdb_ids_with_matches': distinct_cmdbs,
        'example_messages': examples
    })

# Build DataFrame (handle case of no matches)
if rows:
    keyword_summary_df = pd.DataFrame(rows).sort_values('match_count', ascending=False).reset_index(drop=True)
else:
    keyword_summary_df = pd.DataFrame(columns=[
        'keyword','match_count','earliest_matching_timestamp','distinct_cmdb_ids_with_matches','example_messages'
    ])

# Incident window for frontends (Asia/Shanghai)
start_dt = tz.localize(datetime(2022, 3, 21, 12, 0, 0))
end_dt = tz.localize(datetime(2022, 3, 21, 12, 29, 59))
start_ts = int(start_dt.timestamp())
end_ts = int(end_dt.timestamp())

front_mask = (
    df_err['cmdb_id'].isin(['frontend-0', 'frontend-1', 'frontend-2']) &
    (df_err['timestamp'] >= start_ts) &
    (df_err['timestamp'] <= end_ts)
)
frontend_errors = df_err.loc[front_mask].copy()
frontend_total_rows = int(frontend_errors.shape[0])
if frontend_total_rows > 0:
    frontend_earliest_ts = int(frontend_errors['timestamp'].min())
    frontend_earliest_ts_str = pd.to_datetime(frontend_earliest_ts, unit='s', utc=True).dt.tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
else:
    frontend_earliest_ts_str = None

frontend_summary = pd.DataFrame([{
    'components': 'frontend-0, frontend-1, frontend-2',
    'total_error_rows_in_window': frontend_total_rows,
    'earliest_timestamp_in_window': frontend_earliest_ts_str
}])

# Keep outputs compact: limit example_messages lists to up to 5 (already done) and distinct cmdb list to 10.
# Return results (ensures Kernel prints them)
keyword_summary_df, frontend_summary
