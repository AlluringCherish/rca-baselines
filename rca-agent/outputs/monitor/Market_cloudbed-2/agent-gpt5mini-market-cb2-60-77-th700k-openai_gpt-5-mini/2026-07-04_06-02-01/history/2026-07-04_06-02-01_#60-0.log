import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Filenames
metric_csv = "metric.csv"
trace_csv = "trace.csv"
log_csv = "log.csv"
error_logs_csv = "error_logs.csv"

# Read CSVs into DataFrames (reuse variable names where sensible)
metric_df = pd.read_csv(metric_csv)
trace_df = pd.read_csv(trace_csv)
log_df = pd.read_csv(log_csv)
error_logs_df = pd.read_csv(error_logs_csv)

def summarize_df(df, name_col=None, feature_col=None, message_col=None):
    # Basic counts
    row_count = len(df)
    # Timestamps: handle missing/NaN
    if 'timestamp' in df.columns and df['timestamp'].notna().any():
        min_ts = pd.to_datetime(df['timestamp'].min(), unit='s', utc=True').tz_convert(tz)
        max_ts = pd.to_datetime(df['timestamp'].max(), unit='s', utc=True').tz_convert(tz)
        # compact string form
        min_ts_s = min_ts.strftime('%Y-%m-%d %H:%M:%S %Z')
        max_ts_s = max_ts.strftime('%Y-%m-%d %H:%M:%S %Z')
    else:
        min_ts_s = None
        max_ts_s = None

    # cmdb_id list
    if 'cmdb_id' in df.columns:
        cmdb_ids = sorted(df['cmdb_id'].dropna().unique())[:50]
    else:
        cmdb_ids = []

    # feature / KPI names depending on file
    if feature_col and feature_col in df.columns:
        feature_names = sorted(df[feature_col].dropna().unique())[:50]
    else:
        feature_names = []

    # For error_logs, provide messages list if requested
    if message_col and message_col in df.columns:
        messages = sorted(df[message_col].dropna().unique())[:50]
    else:
        messages = []

    # Sample rows (up to first 20). Convert timestamp to tz-aware human readable if present.
    sample = df.head(20).copy()
    if 'timestamp' in sample.columns and sample['timestamp'].notna().any():
        sample['timestamp'] = pd.to_datetime(sample['timestamp'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')

    summary = {
        'row_count': row_count,
        'min_timestamp': min_ts_s,
        'max_timestamp': max_ts_s,
        'cmdb_ids_first_50': cmdb_ids,
        'feature_names_first_50': feature_names,
        'messages_first_50': messages,
        'sample_head_20': sample  # pandas DataFrame
    }
    return summary

# Build summaries for each file
metric_summary = summarize_df(metric_df, name_col='cmdb_id', feature_col='kpi_name')
trace_summary = summarize_df(trace_df, name_col='cmdb_id', feature_col='trace_name')
log_summary = summarize_df(log_df, name_col='cmdb_id', feature_col='log_name')
error_logs_summary = summarize_df(error_logs_df, name_col='cmdb_id', message_col='message')

summary = {
    'metric.csv': metric_summary,
    'trace.csv': trace_summary,
    'log.csv': log_summary,
    'error_logs.csv': error_logs_summary
}

# Display the compact summary dictionary
summary
