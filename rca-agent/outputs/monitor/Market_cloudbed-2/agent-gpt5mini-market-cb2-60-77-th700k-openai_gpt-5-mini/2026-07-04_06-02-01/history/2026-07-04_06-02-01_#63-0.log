import pandas as pd
import pytz

# reuse existing df_metric if present, otherwise load
if 'df_metric' not in globals():
    df_metric = pd.read_csv('metric.csv')
    tz = pytz.timezone('Asia/Shanghai')
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# ensure tz and ts exist
tz = pytz.timezone('Asia/Shanghai')
if 'ts' not in df_metric.columns or df_metric['ts'].dtype == object:
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Recompute global P95 per (cmdb_id, kpi_name) using the full series (must be done BEFORE filtering)
group_keys = ['cmdb_id', 'kpi_name']
p95_series = df_metric.groupby(group_keys)['value'].quantile(0.95)
p95_df = p95_series.reset_index().rename(columns={'value': 'global_p95'})

# 2) Filter to incident window (UTC+8) inclusive
start = pd.Timestamp('2022-03-21 18:00:00').tz_localize(tz)
end = pd.Timestamp('2022-03-21 18:30:00').tz_localize(tz)
df_window = df_metric[(df_metric['ts'] >= start) & (df_metric['ts'] <= end)].copy()

# merge global p95 into window rows (thresholds computed from full series)
df_win = df_window.merge(p95_df, on=group_keys, how='left')

# mark exceedances: value > global_p95
df_win['exceed'] = df_win['value'] > df_win['global_p95']

# 1) Per-minute summary: group by minute, count exceedances and distinct cmdb_id count
df_win['minute'] = df_win['ts'].dt.floor('T')  # floor to minute
per_minute = (
    df_win[df_win['exceed']]
    .groupby('minute')
    .agg(
        exceedance_count=('exceed', 'sum'),
        distinct_cmdb_id_count=('cmdb_id', 'nunique')
    )
    .reset_index()
    .rename(columns={'minute': 'timestamp'})
)

# top 10 minutes by exceedance_count desc
per_minute_top10 = per_minute.sort_values('exceedance_count', ascending=False).head(10)
# format timestamp as ISO-like strings for compactness
per_minute_top10['timestamp'] = per_minute_top10['timestamp'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')

# 2) Per-cmdb_id summary for the whole window
cmdb_summary = (
    df_win[df_win['exceed']]
    .groupby('cmdb_id')
    .agg(
        exceedance_count=('exceed', 'sum'),
        earliest_exceed_timestamp=('ts', 'min'),
        latest_exceed_timestamp=('ts', 'max'),
        distinct_kpi_count_exceeded=('kpi_name', 'nunique')
    )
    .reset_index()
)

# format timestamps
cmdb_summary['earliest_exceed_timestamp'] = cmdb_summary['earliest_exceed_timestamp'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
cmdb_summary['latest_exceed_timestamp'] = cmdb_summary['latest_exceed_timestamp'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')

# top 20 cmdb_id by exceedance_count
cmdb_top20 = cmdb_summary.sort_values('exceedance_count', ascending=False).head(20)

# Display the two compact aggregated outputs
per_minute_top10, cmdb_top20
