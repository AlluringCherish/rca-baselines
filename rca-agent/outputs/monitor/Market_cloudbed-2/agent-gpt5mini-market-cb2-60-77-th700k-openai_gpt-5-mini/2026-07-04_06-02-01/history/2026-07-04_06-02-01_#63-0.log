import pandas as pd
import numpy as np
import pytz

# timezone UTC+8
tz = pytz.timezone('Asia/Shanghai')

# incident window
start = pd.Timestamp('2022-03-21 18:00:00').tz_localize(tz)
end = pd.Timestamp('2022-03-21 18:30:00').tz_localize(tz)

# reuse loaded DataFrames if available
# df_metric, df_trace, df_log, df_error assumed present from prior steps; otherwise load
if 'df_metric' not in globals():
    df_metric = pd.read_csv('metric.csv')
if 'df_trace' not in globals():
    df_trace = pd.read_csv('trace.csv')
if 'df_log' not in globals():
    df_log = pd.read_csv('log.csv')
if 'df_error' not in globals():
    df_error = pd.read_csv('error_logs.csv')

# ensure tz-aware timestamps and minute columns
if 'ts' not in df_metric.columns or df_metric['ts'].dtype == object:
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_metric['minute'] = df_metric['ts'].dt.floor('T')

if 'ts' not in df_trace.columns or df_trace['ts'].dtype == object:
    df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_trace['minute'] = df_trace['ts'].dt.floor('T')

if 'ts' not in df_log.columns or df_log['ts'].dtype == object:
    df_log['ts'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_log['minute'] = df_log['ts'].dt.floor('T')

if 'ts' not in df_error.columns or df_error['ts'].dtype == object:
    df_error['ts'] = pd.to_datetime(df_error['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_error['minute'] = df_error['ts'].dt.floor('T')

# -------------- Compute global P95 thresholds over full series if not present --------------
if 'p95_metric' not in globals():
    p95_metric = df_metric.groupby(['cmdb_id','kpi_name'])['value'].quantile(0.95).reset_index().rename(columns={'value':'global_p95'})

if 'trace_p95' not in globals():
    trace_p95 = df_trace.groupby(['cmdb_id','trace_name'])['value'].quantile(0.95).reset_index().rename(columns={'value':'global_p95'})

if 'log_p95' not in globals():
    log_p95 = df_log.groupby(['cmdb_id','log_name'])['value'].quantile(0.95).reset_index().rename(columns={'value':'global_p95'})

# helper to compute relative breach (inf if p95==0 and value>0)
def relative_breach_series(val, p95):
    # returns numpy array
    p95f = p95.values
    valf = val.values
    out = np.full(len(valf), np.nan, dtype='float64')
    mask = (~np.isnan(p95f)) & (valf > p95f)
    # finite p95
    fin = mask & (p95f > 0)
    out[fin] = (valf[fin] - p95f[fin]) / p95f[fin]
    # zero p95 and positive value => inf
    zero = mask & (p95f == 0) & (valf > 0)
    out[zero] = np.inf
    return out

# filter metric/trace/log to incident window once
df_metric_window = df_metric[(df_metric['ts'] >= start) & (df_metric['ts'] <= end)].copy()
df_trace_window = df_trace[(df_trace['ts'] >= start) & (df_trace['ts'] <= end)].copy()
df_log_window = df_log[(df_log['ts'] >= start) & (df_log['ts'] <= end)].copy()
df_error_window = df_error[(df_error['ts'] >= start) & (df_error['ts'] <= end)].copy()

# ----------------- 1) checkoutservice mesh faults -----------------
checkout_pods = ['checkoutservice2-0','checkoutservice-0','checkoutservice-1','checkoutservice-2']
# select mesh.* rows in window for these pods
mask_mesh = df_metric_window['kpi_name'].str.startswith('mesh.source') | df_metric_window['kpi_name'].str.startswith('mesh.destination')
df_chk_mesh = df_metric_window[df_metric_window['cmdb_id'].isin(checkout_pods) & mask_mesh].copy()
# merge global p95
df_chk_mesh = df_chk_mesh.merge(p95_metric, on=['cmdb_id','kpi_name'], how='left')
# compute exceed and relative breach
df_chk_mesh['exceed'] = (~df_chk_mesh['global_p95'].isna()) & (df_chk_mesh['value'] > df_chk_mesh['global_p95'])
df_chk_mesh['relative_breach'] = relative_breach_series(df_chk_mesh['value'], df_chk_mesh['global_p95'])
# keep only exceed rows
df_chk_mesh_ex = df_chk_mesh[df_chk_mesh['exceed']].copy()

# For each pod, compute per-minute anomalous flag (True if any exceed)
chk_minutes = (
    df_chk_mesh_ex.groupby(['cmdb_id','minute'])
    .agg(
        max_rel=('relative_breach','max'),
        distinct_kpis=('kpi_name','nunique')
    )
    .reset_index()
)

# function to extract consecutive runs per pod
def extract_runs(df_minutes):
    runs = []
    for pod, g in df_minutes.groupby('cmdb_id'):
        gp = g.sort_values('minute').reset_index(drop=True).copy()
        if gp.empty:
            continue
        # minute ordinal
        gp['minute_ord'] = (gp['minute'] - gp['minute'].min()).dt.total_seconds()//60
        # identify consecutive blocks by gap >1 minute
        gp['gap'] = gp['minute'].diff().dt.total_seconds().fillna(0)
        gp['new_group'] = (gp['gap'] > 60).cumsum()
        for grp_id, grp in gp.groupby('new_group'):
            start_min = grp['minute'].min()
            end_min = grp['minute'].max()
            duration = int(((end_min - start_min).total_seconds()//60) + 1)
            # max relative breach in this fault
            max_rel = grp['max_rel'].max()
            # detect any inf
            has_inf = np.isinf(grp['max_rel'].values).any()
            max_rel_report = 'inf' if has_inf else float(max_rel)
            # count distinct mesh kpis exceeded within fault (use original df_chk_mesh_ex)
            pod_kpis = df_chk_mesh_ex[(df_chk_mesh_ex['cmdb_id']==pod) & (df_chk_mesh_ex['minute']>=start_min) & (df_chk_mesh_ex['minute']<=end_min)]['kpi_name'].nunique()
            runs.append({
                'cmdb_id': pod,
                'fault_start_minute': start_min,
                'fault_end_minute': end_min,
                'fault_duration_minutes': duration,
                'max_relative_breach_within_fault': max_rel_report,
                'count_distinct_mesh_kpis_exceeded_within_fault': int(pod_kpis)
            })
    return pd.DataFrame(runs)

chk_runs = extract_runs(chk_minutes)

# choose top 10 faults by duration desc then severity (inf considered highest)
if chk_runs.empty:
    checkout_faults_out = chk_runs
else:
    # create numeric severity for sorting: inf -> large number
    def sev_val(x):
        if x == 'inf':
            return np.inf
        return float(x)
    chk_runs['sev_sort'] = chk_runs['max_relative_breach_within_fault'].apply(sev_val)
    chk_top = chk_runs.sort_values(['fault_duration_minutes','sev_sort'], ascending=[False,False]).head(10).drop(columns=['sev_sort'])
    # final sort by fault_start_minute ascending as required for output
    checkout_faults_out = chk_top.sort_values('fault_start_minute').reset_index(drop=True)

# ----------------- 2) frontend pods trace.self + log.error_count faults -----------------
frontends = ['frontend-0','frontend-1','frontend-2']
# prepare trace.self rows in window for these frontends
trace_targets = ['trace.self.duration_mean','trace.self.duration_p95','trace.self.error_rate']
df_front_trace = df_trace_window[df_trace_window['cmdb_id'].isin(frontends) & df_trace_window['trace_name'].isin(trace_targets)].copy()
df_front_trace = df_front_trace.merge(trace_p95, on=['cmdb_id','trace_name'], how='left')
df_front_trace['exceed'] = (~df_front_trace['global_p95'].isna()) & (df_front_trace['value'] > df_front_trace['global_p95'])
df_front_trace['relative_breach'] = relative_breach_series(df_front_trace['value'], df_front_trace['global_p95'])

# prepare log.error_count rows
df_front_log = df_log_window[df_log_window['cmdb_id'].isin(frontends) & (df_log_window['log_name']=='log.error_count')].copy()
df_front_log = df_front_log.merge(log_p95, on=['cmdb_id','log_name'], how='left')
df_front_log['exceed'] = (~df_front_log['global_p95'].isna()) & (df_front_log['value'] > df_front_log['global_p95'])
df_front_log['relative_breach'] = relative_breach_series(df_front_log['value'], df_front_log['global_p95'])

# compute per-minute anomalies: a minute is anomalous for a frontend if any trace.self exceed OR log.error_count exceed
# combine trace and log exceed flags per pod-minute
trace_flags = df_front_trace[df_front_trace['exceed']].groupby(['cmdb_id','minute']).agg(
    max_trace_rel=('relative_breach','max'),
    trace_kpis_exceeded=('trace_name','nunique')
).reset_index()

log_flags = df_front_log[df_front_log['exceed']].groupby(['cmdb_id','minute']).agg(
    max_log_rel=('relative_breach','max'),
    log_kpis_exceeded=('log_name','nunique')
).reset_index()

# merge flags
minutes_all = []
for pod in frontends:
    # union of minutes where any exceed (trace or log)
    t = trace_flags[trace_flags['cmdb_id']==pod][['minute','max_trace_rel','trace_kpis_exceeded']].copy()
    l = log_flags[log_flags['cmdb_id']==pod][['minute','max_log_rel','log_kpis_exceeded']].copy()
    merged = pd.merge(t, l, on='minute', how='outer')
    if merged.empty:
        continue
    merged['cmdb_id'] = pod
    merged = merged.fillna({'max_trace_rel': np.nan, 'trace_kpis_exceeded':0, 'max_log_rel': np.nan, 'log_kpis_exceeded':0})
    minutes_all.append(merged[['cmdb_id','minute','max_trace_rel','trace_kpis_exceeded','max_log_rel','log_kpis_exceeded']])
if minutes_all:
    df_front_minutes = pd.concat(minutes_all, ignore_index=True)
else:
    df_front_minutes = pd.DataFrame(columns=['cmdb_id','minute','max_trace_rel','trace_kpis_exceeded','max_log_rel','log_kpis_exceeded'])

# find consecutive runs per frontend pod similar to checkout logic
def extract_front_runs(df_minutes):
    runs = []
    for pod, g in df_minutes.groupby('cmdb_id'):
        gp = g.sort_values('minute').reset_index(drop=True).copy()
        if gp.empty:
            continue
        gp['gap'] = gp['minute'].diff().dt.total_seconds().fillna(0)
        gp['new_group'] = (gp['gap'] > 60).cumsum()
        for gid, grp in gp.groupby('new_group'):
            start_min = grp['minute'].min()
            end_min = grp['minute'].max()
            duration = int(((end_min - start_min).total_seconds()//60) + 1)
            # max trace relative breach within fault (consider NaN and inf)
            trace_vals = grp['max_trace_rel'].values
            log_vals = grp['max_log_rel'].values
            max_trace = np.nanmax(trace_vals) if not np.all(np.isnan(trace_vals)) else np.nan
            max_log = np.nanmax(log_vals) if not np.all(np.isnan(log_vals)) else np.nan
            # detect inf
            has_inf_trace = np.isinf(trace_vals).any()
            has_inf_log = np.isinf(log_vals).any()
            max_trace_report = 'inf' if has_inf_trace else (float(max_trace) if not np.isnan(max_trace) else np.nan)
            max_log_report = 'inf' if has_inf_log else (float(max_log) if not np.isnan(max_log) else np.nan)
            # count distinct exceeded trace or log metrics in the fault (use original dfs)
            distinct_traces = df_front_trace[(df_front_trace['cmdb_id']==pod) & (df_front_trace['minute']>=start_min) & (df_front_trace['minute']<=end_min) & (df_front_trace['exceed'])]['trace_name'].nunique()
            distinct_logs = df_front_log[(df_front_log['cmdb_id']==pod) & (df_front_log['minute']>=start_min) & (df_front_log['minute']<=end_min) & (df_front_log['exceed'])]['log_name'].nunique()
            total_distinct = int(distinct_traces + distinct_logs)
            runs.append({
                'cmdb_id': pod,
                'fault_start_minute': start_min,
                'fault_end_minute': end_min,
                'fault_duration_minutes': duration,
                'max_trace_relative_breach_within_fault': max_trace_report,
                'max_log_relative_breach_within_fault': max_log_report,
                'count_distinct_trace_or_log_metrics_exceeded': total_distinct
            })
    return pd.DataFrame(runs)

front_runs = extract_front_runs(df_front_minutes)

# select top 10 by duration then severity (use trace severity as primary)
if front_runs.empty:
    frontend_faults_out = front_runs
else:
    def sev_front(x):
        if x == 'inf':
            return np.inf
        try:
            return float(x)
        except:
            return -np.inf
    front_runs['trace_sev_sort'] = front_runs['max_trace_relative_breach_within_fault'].apply(sev_front)
    front_runs['log_sev_sort'] = front_runs['max_log_relative_breach_within_fault'].apply(sev_front)
    front_top = front_runs.sort_values(['fault_duration_minutes','trace_sev_sort','log_sev_sort'], ascending=[False,False,False]).head(10).drop(columns=['trace_sev_sort','log_sev_sort'])
    frontend_faults_out = front_top.sort_values('fault_start_minute').reset_index(drop=True)

# ----------------- 3) node system.* faults -----------------
nodes = ['node-1','node-2','node-3','node-4','node-6']
# filter metric window for nodes and system.* prefixes (system.cpu*, system.io*, system.fs*)
mask_system = df_metric_window['kpi_name'].str.startswith('system.cpu') | df_metric_window['kpi_name'].str.startswith('system.io') | df_metric_window['kpi_name'].str.startswith('system.fs')
df_node_sys = df_metric_window[df_metric_window['cmdb_id'].isin(nodes) & mask_system].copy()
df_node_sys = df_node_sys.merge(p95_metric, on=['cmdb_id','kpi_name'], how='left')
df_node_sys['exceed'] = (~df_node_sys['global_p95'].isna()) & (df_node_sys['value'] > df_node_sys['global_p95'])
df_node_sys['relative_breach'] = relative_breach_series(df_node_sys['value'], df_node_sys['global_p95'])
df_node_sys_ex = df_node_sys[df_node_sys['exceed']].copy()

# per-node per-minute aggregation
node_minutes = df_node_sys_ex.groupby(['cmdb_id','minute']).agg(
    max_rel=('relative_breach','max'),
    distinct_kpis=('kpi_name','nunique')
).reset_index()

# extract runs similar to before
def extract_node_runs(df_minutes):
    runs = []
    for node, g in df_minutes.groupby('cmdb_id'):
        gp = g.sort_values('minute').reset_index(drop=True).copy()
        if gp.empty:
            continue
        gp['gap'] = gp['minute'].diff().dt.total_seconds().fillna(0)
        gp['new_group'] = (gp['gap'] > 60).cumsum()
        for gid, grp in gp.groupby('new_group'):
            start_min = grp['minute'].min()
            end_min = grp['minute'].max()
            duration = int(((end_min - start_min).total_seconds()//60) + 1)
            max_rel = grp['max_rel'].max()
            has_inf = np.isinf(grp['max_rel'].values).any()
            max_rel_report = 'inf' if has_inf else float(max_rel)
            # count distinct system kpis exceeded within fault
            distinct = df_node_sys_ex[(df_node_sys_ex['cmdb_id']==node) & (df_node_sys_ex['minute']>=start_min) & (df_node_sys_ex['minute']<=end_min)]['kpi_name'].nunique()
            runs.append({
                'cmdb_id': node,
                'fault_start_minute': start_min,
                'fault_end_minute': end_min,
                'fault_duration_minutes': duration,
                'max_relative_breach_within_fault': max_rel_report,
                'count_distinct_system_kpis_exceeded': int(distinct)
            })
    return pd.DataFrame(runs)

node_runs = extract_node_runs(node_minutes)

# select top 10 by duration then severity
if node_runs.empty:
    node_faults_out = node_runs
else:
    node_runs['sev_sort'] = node_runs['max_relative_breach_within_fault'].apply(lambda x: np.inf if x=='inf' else float(x))
    node_top = node_runs.sort_values(['fault_duration_minutes','sev_sort'], ascending=[False,False]).head(10).drop(columns=['sev_sort'])
    node_faults_out = node_top.sort_values('fault_start_minute').reset_index(drop=True)

# Final compact outputs: three tables (<=10 rows each), sorted by fault_start_minute ascending
checkout_faults_out, frontend_faults_out, node_faults_out
