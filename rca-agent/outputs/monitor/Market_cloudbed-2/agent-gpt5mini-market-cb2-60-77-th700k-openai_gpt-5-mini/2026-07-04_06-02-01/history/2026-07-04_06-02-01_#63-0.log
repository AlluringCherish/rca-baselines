        .agg(
            exceed_count=('trace_name', 'count'),
            distinct_exceeded_trace_count=('trace_name', 'nunique')
        )
        .reset_index()
    )
    
    # prepare list_of_exceeded_traces limited to top 10 by relative_breach per cmdb_id
    def top_traces_for_cmdb(cmdb):
        sub = df_m_ex[df_m_ex['cmdb_id'] == cmdb].copy()
        sub = sub.sort_values('relative_breach', ascending=False)
        top = sub.head(10)
        # format tuples: (trace_name, value, global_p95, relative_breach)
        formatted = top.apply(
            lambda r: (r['trace_name'], float(r['value']), float(r['global_p95']) if pd.notna(r['global_p95']) else None,
                       float(r['relative_breach']) if pd.notna(r['relative_breach']) else None),
            axis=1
        ).tolist()
        return formatted

    agg['list_of_exceeded_traces'] = agg['cmdb_id'].apply(top_traces_for_cmdb)
    
    # indicator if any of the exceeded traces are error_rate or self duration p95/mean
    agg['has_error_or_self_trace'] = agg['cmdb_id'].apply(
        lambda c: has_special_traces(df_m_ex[df_m_ex['cmdb_id'] == c]['trace_name'])
    )
    
    # add minute column and sort by exceed_count desc, limit top 20
    agg['minute'] = minute.strftime('%Y-%m-%dT%H:%M:%S%z')
    agg = agg[['minute','cmdb_id','exceed_count','list_of_exceeded_traces',
               'distinct_exceeded_trace_count','has_error_or_self_trace']]
    agg = agg.sort_values('exceed_count', ascending=False).head(20).reset_index(drop=True)
    
    per_minute_aggregates.append(agg)
    
    # minute summary
    top_cmdb = agg.iloc[0]['cmdb_id'] if not agg.empty else None
    minute_summaries.append({
        'timestamp': minute.strftime('%Y-%m-%dT%H:%M:%S%z'),
        'total_exceedance_count': total_exceedance_count,
        'distinct_cmdb_id_count': distinct_cmdb_id_count,
        'top_cmdb_id_by_exceed_count': top_cmdb
    })

# combine per-minute top results into one DataFrame (rows up to 40 = 20 per minute)
combined_top_traces = pd.concat(per_minute_aggregates, ignore_index=True)

# minute summary DataFrame
minute_summary_df = pd.DataFrame(minute_summaries)

# final compact outputs
combined_top_traces, minute_summary_df
