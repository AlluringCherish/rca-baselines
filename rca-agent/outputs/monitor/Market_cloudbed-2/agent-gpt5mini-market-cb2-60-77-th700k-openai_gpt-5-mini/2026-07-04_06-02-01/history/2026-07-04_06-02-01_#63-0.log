import pandas as pd
import numpy as np
import pytz

# timezone UTC+8
tz = pytz.timezone('Asia/Shanghai')

# target checkoutservice pods
pods = ['checkoutservice2-0','checkoutservice-0','checkoutservice-1','checkoutservice-2']

# ensure metric, trace, error dataframes are loaded (reuse from kernel if present)
if 'df_metric' not in globals():
    df_metric = pd.read_csv('metric.csv')
if 'df_trace' not in globals():
    df_trace = pd.read_csv('trace.csv')
if 'df_error' not in globals():
    df_error = pd.read_csv('error_logs.csv')

# ensure ts and minute columns (tz-aware UTC+8) for metric, trace, error
if 'ts' not in df_metric.columns:
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    if df_metric['ts'].dt.tz is None:
        df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_metric['minute'] = df_metric['ts'].dt.floor('T')

if 'ts' not in df_trace.columns:
    df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    if df_trace['ts'].dt.tz is None:
        df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_trace['minute'] = df_trace['ts'].dt.floor('T')

if 'ts' not in df_error.columns:
    df_error['ts'] = pd.to_datetime(df_error['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    if df_error['ts'].dt.tz is None:
        df_error['ts'] = pd.to_datetime(df_error['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_error['minute'] = df_error['ts'].dt.floor('T')

# 1) Compute global P95 per (cmdb_id, kpi_name) over full metric series (if not already computed)
if 'p95_metric' not in globals():
    p95_metric = (
        df_metric
        .groupby(['cmdb_id','kpi_name'])['value']
        .quantile(0.95)
        .reset_index()
        .rename(columns={'value':'global_p95'})
    )

# Filter metric rows to incident window (inclusive)
start = pd.Timestamp('2022-03-21 18:00:00').tz_localize(tz)
end = pd.Timestamp('2022-03-21 18:30:00').tz_localize(tz)
df_window = df_metric[(df_metric['ts'] >= start) & (df_metric['ts'] <= end)].copy()

# Merge global p95 into window rows
df_window = df_window.merge(p95_metric, on=['cmdb_id','kpi_name'], how='left')

# mark exceedances and compute relative breach safely
df_window['exceed'] = (~df_window['global_p95'].isna()) & (df_window['value'] > df_window['global_p95'])
df_window['relative_breach'] = np.where(
    df_window['exceed'] & (df_window['global_p95'] > 0),
    (df_window['value'] - df_window['global_p95']) / df_window['global_p95'],
    np.where(df_window['exceed'] & (df_window['global_p95'] == 0) & (df_window['value'] > 0), np.inf, np.nan)
)

# Helper to format timestamp ISO
def fmt_ts(ts):
    return pd.to_datetime(ts).tz_convert(tz).strftime('%Y-%m-%dT%H:%M:%S%z')

# Prepare pod-level summary rows
pod_rows = []
for pod in pods:
    df_p = df_window[(df_window['cmdb_id'] == pod) & (df_window['exceed'])].copy()
    if df_p.empty:
        pod_rows.append({
            'cmdb_id': pod,
            'earliest_exceed_timestamp': None,
            'total_exceeded_kpis_at_that_minute': 0,
            'top_kpi_name': None,
            'top_kpi_value': None,
            'top_kpi_global_p95': None,
            'top_kpi_relative_breach': None
        })
        continue
    # earliest timestamp (minute) when any exceed occurs
    earliest_min = df_p['minute'].min()
    # rows at that minute for this pod that exceed
    df_p_min = df_p[df_p['minute'] == earliest_min].copy()
    # count distinct kpi_name exceeded at that minute
    count_kpis = int(df_p_min['kpi_name'].nunique())
    # choose top KPI by relative_breach
    df_p_min_sorted = df_p_min.sort_values('relative_breach', ascending=False)
    top = df_p_min_sorted.iloc[0]
    pod_rows.append({
        'cmdb_id': pod,
        'earliest_exceed_timestamp': earliest_min.strftime('%Y-%m-%dT%H:%M:%S%z'),
        'total_exceeded_kpis_at_that_minute': count_kpis,
        'top_kpi_name': top['kpi_name'],
        'top_kpi_value': float(top['value']),
        'top_kpi_global_p95': float(top['global_p95']) if pd.notna(top['global_p95']) else None,
        'top_kpi_relative_breach': float(top['relative_breach']) if pd.notna(top['relative_breach']) else None
    })

pod_summary = pd.DataFrame(pod_rows)

# 2) For each pod's earliest_exceed_timestamp, check trace.csv at that exact minute for trace.self.* exceedances
# compute trace-level global p95 if not already present
if 'trace_p95' not in globals():
    trace_p95 = (
        df_trace
        .groupby(['cmdb_id','trace_name'])['value']
        .quantile(0.95)
        .reset_index()
        .rename(columns={'value':'global_p95'})
    )

# target trace names
target_trace_names = {'trace.self.duration_mean','trace.self.duration_p95','trace.self.error_rate'}
trace_hits_list = []

for _, row in pod_summary.iterrows():
    pod = row['cmdb_id']
    ts_str = row['earliest_exceed_timestamp']
    if ts_str is None:
        continue
    minute_ts = pd.to_datetime(ts_str).tz_localize(None).tz_localize(tz) if isinstance(ts_str, str) else pd.to_datetime(ts_str)
    # select trace rows for this pod at that minute with the target trace names
    df_t = df_trace[(df_trace['cmdb_id'] == pod) & (df_trace['minute'] == minute_ts) & (df_trace['trace_name'].isin(target_trace_names))].copy()
    if df_t.empty:
        continue
    # merge trace p95
    df_t = df_t.merge(trace_p95, on=['cmdb_id','trace_name'], how='left')
    # mark exceed and relative breach
    df_t['exceed'] = (~df_t['global_p95'].isna()) & (df_t['value'] > df_t['global_p95'])
    df_t['relative_breach'] = np.where(
        df_t['exceed'] & (df_t['global_p95'] > 0),
        (df_t['value'] - df_t['global_p95']) / df_t['global_p95'],
        np.where(df_t['exceed'] & (df_t['global_p95'] == 0) & (df_t['value'] > 0), np.inf, np.nan)
    )
    df_t_ex = df_t[df_t['exceed']].copy()
    if df_t_ex.empty:
        continue
    # select needed columns and add minute info
    df_t_ex['minute_timestamp'] = df_t_ex['minute'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
    trace_hits_list.append(df_t_ex[['minute_timestamp','cmdb_id','trace_name','value','global_p95','relative_breach']])

# combine and limit to top 10 trace rows by relative_breach
if trace_hits_list:
    trace_hits = pd.concat(trace_hits_list, ignore_index=True)
    trace_hits = trace_hits.sort_values('relative_breach', ascending=False).head(10)
else:
    trace_hits = pd.DataFrame(columns=['minute_timestamp','cmdb_id','trace_name','value','global_p95','relative_breach'])

# 3) For each pod's earliest_exceed_timestamp, check error_logs for entries in that minute: boolean and count
error_info = []
for _, row in pod_summary.iterrows():
    pod = row['cmdb_id']
    ts_str = row['earliest_exceed_timestamp']
    if ts_str is None:
        error_info.append({'cmdb_id': pod, 'error_log_count': 0, 'error_log_present': False})
        continue
    minute_ts = pd.to_datetime(ts_str).tz_localize(None).tz_localize(tz) if isinstance(ts_str, str) else pd.to_datetime(ts_str)
    cnt = int(df_error[(df_error['cmdb_id']==pod) & (df_error['minute'] == minute_ts)].shape[0])
    error_info.append({'cmdb_id': pod, 'error_log_count': cnt, 'error_log_present': cnt>0})

error_df = pd.DataFrame(error_info)

# merge error counts into pod_summary
pod_summary = pod_summary.merge(error_df, on='cmdb_id', how='left')

# Keep final outputs compact: pod_summary (4 rows) and trace_hits (<=10 rows)
pod_summary, trace_hits
