import pandas as pd
import numpy as np
import pytz

# reuse existing loaded DataFrames where possible
tz = pytz.timezone('Asia/Shanghai')

# Ensure dataframes and ts/minute columns exist
if 'df_trace' not in globals():
    df_trace = pd.read_csv('trace.csv')
if 'df_log' not in globals():
    df_log = pd.read_csv('log.csv')
if 'df_metric' not in globals():
    df_metric = pd.read_csv('metric.csv')

for df, name in [(df_trace, 'df_trace'), (df_log, 'df_log'), (df_metric, 'df_metric')]:
    if 'ts' not in df.columns or df['ts'].dtype == object:
        df['ts'] = pd.to_datetime(df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    df['minute'] = df['ts'].dt.floor('T')

# Compute global P95 thresholds if not present
if 'trace_p95' not in globals():
    trace_p95 = df_trace.groupby(['cmdb_id','trace_name'])['value'].quantile(0.95).reset_index().rename(columns={'value':'global_p95'})
if 'log_p95' not in globals():
    log_p95 = df_log.groupby(['cmdb_id','log_name'])['value'].quantile(0.95).reset_index().rename(columns={'value':'global_p95'})
if 'p95_metric' not in globals():
    p95_metric = df_metric.groupby(['cmdb_id','kpi_name'])['value'].quantile(0.95).reset_index().rename(columns={'value':'global_p95'})

# helper for relative breach (vectorized)
def compute_rel_breach(val_series, p95_series):
    val = val_series.values.astype(float)
    p95 = p95_series.values.astype(float)
    out = np.full(len(val), np.nan, dtype='float64')
    mask = (~np.isnan(p95)) & (val > p95)
    fin = mask & (p95 > 0)
    out[fin] = (val[fin] - p95[fin]) / p95[fin]
    zero = mask & (p95 == 0) & (val > 0)
    out[zero] = np.inf
    return out

# candidate minutes
m1 = pd.Timestamp('2022-03-21 18:14:00').tz_localize(tz)
m2 = pd.Timestamp('2022-03-21 18:29:00').tz_localize(tz)

# 1) Checkoutservice trace exceedances at 18:14
checkout_pods = ['checkoutservice2-0','checkoutservice-0','checkoutservice-1','checkoutservice-2']
# filter relevant trace rows at m1 and pods and trace_name conditions
cond_name = df_trace['trace_name'].str.contains('from_frontend') | df_trace['trace_name'].str.contains('to_') | df_trace['trace_name'].str.startswith('trace.self')
chk_traces = df_trace[(df_trace['minute']==m1) & (df_trace['cmdb_id'].isin(checkout_pods)) & cond_name].copy()
# merge p95 and compute exceed & relative breach
chk_traces = chk_traces.merge(trace_p95, on=['cmdb_id','trace_name'], how='left')
chk_traces['relative_breach'] = compute_rel_breach(chk_traces['value'], chk_traces['global_p95'])
chk_traces['exceed'] = (~chk_traces['global_p95'].isna()) & (chk_traces['value'] > chk_traces['global_p95'])
chk_traces['is_self_or_error'] = chk_traces['trace_name'].str.contains('self') | chk_traces['trace_name'].str.contains('error_rate')
chk_exceed = chk_traces[chk_traces['exceed']].copy()
chk_exceed['minute_timestamp'] = chk_exceed['minute'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
# sort by cmdb_id then descending relative_breach and limit 50
checkout_trace_out = chk_exceed.sort_values(['cmdb_id','relative_breach'], ascending=[True, False])[
    ['minute_timestamp','cmdb_id','trace_name','value','global_p95','relative_breach','is_self_or_error']
].head(50)

# 2a) Frontend trace.self exceedances at 18:29
frontends = ['frontend-0','frontend-1','frontend-2']
trace_names_target = ['trace.self.duration_mean','trace.self.duration_p95','trace.self.error_rate']
front_traces = df_trace[(df_trace['minute']==m2) & (df_trace['cmdb_id'].isin(frontends)) & (df_trace['trace_name'].isin(trace_names_target))].copy()
front_traces = front_traces.merge(trace_p95, on=['cmdb_id','trace_name'], how='left')
front_traces['relative_breach'] = compute_rel_breach(front_traces['value'], front_traces['global_p95'])
front_traces['exceed'] = (~front_traces['global_p95'].isna()) & (front_traces['value'] > front_traces['global_p95'])
front_traces_ex = front_traces[front_traces['exceed']].copy()
front_traces_ex['minute_timestamp'] = front_traces_ex['minute'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
frontend_trace_out = front_traces_ex[['minute_timestamp','cmdb_id','trace_name','value','global_p95','relative_breach']].sort_values('relative_breach',ascending=False).head(20)

# 2b) Frontend logs at 18:29 for log.error_count and log.row_count
log_names_target = ['log.error_count','log.row_count']
front_logs = df_log[(df_log['minute']==m2) & (df_log['cmdb_id'].isin(frontends)) & (df_log['log_name'].isin(log_names_target))].copy()
front_logs = front_logs.merge(log_p95, on=['cmdb_id','log_name'], how='left')
front_logs['relative_breach'] = compute_rel_breach(front_logs['value'], front_logs['global_p95'])
front_logs['exceed'] = (~front_logs['global_p95'].isna()) & (front_logs['value'] > front_logs['global_p95'])
front_logs_ex = front_logs[front_logs['exceed']].copy()
front_logs_ex['minute_timestamp'] = front_logs_ex['minute'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
frontend_log_out = front_logs_ex[['minute_timestamp','cmdb_id','log_name','value','global_p95','relative_breach']].sort_values('relative_breach',ascending=False).head(20)

# combine frontend trace & logs into one compact table (limit combined to 40 rows)
frontend_combined = pd.concat([
    frontend_trace_out.assign(source='trace'),
    frontend_log_out.assign(source='log').rename(columns={'log_name':'trace_name'})  # temporary name for alignment
], ignore_index=True, sort=False)
# normalize column names for combined view
frontend_combined = frontend_combined.rename(columns={'trace_name':'metric_name'})
# reorder and sort by relative_breach desc, limit 40
frontend_combined = frontend_combined[['minute_timestamp','cmdb_id','metric_name','value','global_p95','relative_breach','source']].sort_values('relative_breach',ascending=False).head(40)

# 3) Node system.* metric exceedances at 18:29
nodes = ['node-1','node-2','node-3','node-4','node-6']
node_sys = df_metric[(df_metric['minute']==m2) & (df_metric['cmdb_id'].isin(nodes)) & (df_metric['kpi_name'].str.startswith('system.'))].copy()
node_sys = node_sys.merge(p95_metric, on=['cmdb_id','kpi_name'], how='left')
node_sys['relative_breach'] = compute_rel_breach(node_sys['value'], node_sys['global_p95'])
node_sys['exceed'] = (~node_sys['global_p95'].isna()) & (node_sys['value'] > node_sys['global_p95'])
node_sys_ex = node_sys[node_sys['exceed']].copy()
node_sys_ex['minute_timestamp'] = node_sys_ex['minute'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
node_sys_out = node_sys_ex[['minute_timestamp','cmdb_id','kpi_name','value','global_p95','relative_breach']].sort_values('relative_breach',ascending=False).head(30)

# Final compact outputs: three DataFrames
checkout_trace_out, frontend_combined, node_sys_out
