df_min['exceed'] = (~df_min['global_p95'].isna()) & (df_min['value'] > df_min['global_p95'])
df_min['relative_breach'] = np.where(
    df_min['exceed'] & (df_min['global_p95'] > 0),
    (df_min['value'] - df_min['global_p95']) / df_min['global_p95'],
    np.nan
)

# helper to detect special traces in a list of trace_names
def has_special_traces(trace_names_series):
    # check for any trace_name containing 'error_rate' OR equal to trace.self.duration_p95 or trace.self.duration_mean
    s = trace_names_series.astype(str)
    return s.str.contains('error_rate').any() or (s == 'trace.self.duration_p95').any() or (s == 'trace.self.duration_mean').any()

# 3) For each minute, aggregate per cmdb_id and prepare top lists
