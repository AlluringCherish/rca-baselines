    'min_timestamp': df_error['ts'].min().isoformat() if not df_error['ts'].isna().all() else None,
    'max_timestamp': df_error['ts'].max().isoformat() if not df_error['ts'].isna().all() else None,
    'cmdb_ids': df_error['cmdb_id'].dropna().unique()[:20].tolist()
}

