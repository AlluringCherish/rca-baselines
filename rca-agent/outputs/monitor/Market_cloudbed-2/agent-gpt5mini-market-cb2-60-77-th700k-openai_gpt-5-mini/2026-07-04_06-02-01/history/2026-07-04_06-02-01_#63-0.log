import pandas as pd
import numpy as np
import pytz

# reuse df_metric and p95_df if present; otherwise load/compute
tz = pytz.timezone('Asia/Shanghai')
if 'df_metric' not in globals():
    df_metric = pd.read_csv('metric.csv')
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# ensure ts exists and is tz-aware
if 'ts' not in df_metric.columns:
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    if df_metric['ts'].dt.tz is None:
        df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Recompute global P95 per (cmdb_id, kpi_name) over the full available series (before filtering)
group_keys = ['cmdb_id', 'kpi_name']
p95_series = df_metric.groupby(group_keys)['value'].quantile(0.95)
p95_df = p95_series.reset_index().rename(columns={'value': 'global_p95'})

# prepare minute column (floored to minute, UTC+8)
df_metric['minute'] = df_metric['ts'].dt.floor('T')

# 2) Filter to only the two candidate minutes
candidate_minutes = [
    pd.Timestamp('2022-03-21 18:14:00').tz_localize(tz),
    pd.Timestamp('2022-03-21 18:29:00').tz_localize(tz)
]
df_min = df_metric[df_metric['minute'].isin(candidate_minutes)].copy()

# merge global p95 into these rows
df_min = df_min.merge(p95_df, on=group_keys, how='left')

# mark exceedances and compute relative breach safely (avoid divide-by-zero)
df_min['exceed'] = df_min['value'] > df_min['global_p95']
df_min['relative_breach'] = np.where(
    df_min['exceed'] & (df_min['global_p95'] > 0),
    (df_min['value'] - df_min['global_p95']) / df_min['global_p95'],
    np.nan
)

# 3) For each minute, compute per-cmdb_id aggregates and top-kpis list
per_minute_results = []
minute_summaries = []

for minute in candidate_minutes:
    df_m = df_min[df_min['minute'] == minute].copy()
    # only consider exceeded rows for severity and top-kpis
    df_m_ex = df_m[df_m['exceed']].copy()
    if df_m_ex.empty:
        # produce empty structures if no exceedances
        per_minute_results.append(pd.DataFrame(columns=[
            'minute','cmdb_id','exceedance_count','severity','distinct_kpi_names_exceeded_count','top_kpis'
        ]))
        minute_summaries.append({
            'timestamp': minute.strftime('%Y-%m-%dT%H:%M:%S%z'),
            'total_exceedance_count': 0,
            'distinct_cmdb_id_count': 0,
            'top_cmdb_id_by_severity': None
        })
        continue

    # aggregate severity and counts per cmdb_id
    agg = (
        df_m_ex
        .groupby('cmdb_id')
        .agg(
            exceedance_count=('kpi_name', 'count'),
            severity=('relative_breach', 'sum'),
            distinct_kpi_names_exceeded_count=('kpi_name', 'nunique')
        )
        .reset_index()
    )

    # prepare top_kpis list per cmdb_id: up to top 5 by relative_breach
    def top_kpis_for_cmdb(cmdb):
        sub = df_m_ex[df_m_ex['cmdb_id'] == cmdb].copy()
        sub = sub.sort_values('relative_breach', ascending=False)
        top = sub.head(5)
        # format as tuple-like strings for compactness
        formatted = top.apply(
            lambda r: (r['kpi_name'], float(r['value']), float(r['global_p95']), float(r['relative_breach'])),
            axis=1
        ).tolist()
        return formatted

    agg['top_kpis'] = agg['cmdb_id'].apply(top_kpis_for_cmdb)

    # sort by severity descending and keep top 20
    agg = agg.sort_values('severity', ascending=False).head(20)
    agg.insert(0, 'minute', minute.strftime('%Y-%m-%dT%H:%M:%S%z'))

    per_minute_results.append(agg[['minute','cmdb_id','exceedance_count','severity',
                                  'distinct_kpi_names_exceeded_count','top_kpis']])

    # 4) per-minute summary line
    total_exceedance_count = int(df_m_ex.shape[0])
    distinct_cmdb_id_count = int(df_m_ex['cmdb_id'].nunique())
    top_cmdb = agg.iloc[0]['cmdb_id'] if not agg.empty else None
    minute_summaries.append({
        'timestamp': minute.strftime('%Y-%m-%dT%H:%M:%S%z'),
        'total_exceedance_count': total_exceedance_count,
        'distinct_cmdb_id_count': distinct_cmdb_id_count,
        'top_cmdb_id_by_severity': top_cmdb
    })

# combine per-minute top results into one DataFrame for compact display
combined_top = pd.concat(per_minute_results, ignore_index=True)

# minute summaries as DataFrame
minute_summary_df = pd.DataFrame(minute_summaries)

# final compact outputs: combined_top (top cmdb_id rows per minute) and minute_summary_df
combined_top, minute_summary_df
