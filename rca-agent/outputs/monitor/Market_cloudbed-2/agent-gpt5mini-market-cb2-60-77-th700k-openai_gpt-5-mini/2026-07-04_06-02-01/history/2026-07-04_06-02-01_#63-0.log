2026-07-04 06:06:40,020 | DEBUG | Raw Code:
import pandas as pd
import numpy as np
import pytz

# timezone
tz = pytz.timezone('Asia/Shanghai')

# target cmdb_ids and candidate minutes
target_cmdbs = [
    'frontend-0', 'frontend-1', 'frontend-2',
    'checkoutservice2-0', 'checkoutservice-0', 'checkoutservice-1', 'checkoutservice-2',
    'adservice2-0', 'adservice2', 'adservice',
    'productcatalogservice-0', 'productcatalogservice-1', 'productcatalogservice-2', 'productcatalogservice2-0',
    'node-1', 'node-2', 'node-3', 'node-4', 'node-6'
]
candidate_minutes = [
    pd.Timestamp('2022-03-21 18:14:00').tz_localize(tz),
    pd.Timestamp('2022-03-21 18:29:00').tz_localize(tz)
]

# load metric.csv if not already loaded
if 'df_metric' not in globals():
    df_metric = pd.read_csv('metric.csv')

# ensure ts and minute columns (UTC+8)
if 'ts' not in df_metric.columns:
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    if df_metric['ts'].dt.tz is None:
        df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_metric['minute'] = df_metric['ts'].dt.floor('T')

# 1) Compute global P95 per (cmdb_id, kpi_name) using full series (BEFORE filtering)
p95_metric = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .quantile(0.95)
    .reset_index()
    .rename(columns={'value': 'global_p95'})
)

# 2) Filter metric rows to the two exact minutes and target cmdb_ids
df_min = df_metric[df_metric['minute'].isin(candidate_minutes) & df_metric['cmdb_id'].isin(target_cmdbs)].copy()

# merge p95 thresholds
df_min = df_min.merge(p95_metric, on=['cmdb_id','kpi_name'], how='left')

# compute exceed flag and relative_breach (handle p95==0)
df_min['exceed'] = (~df_min['global_p95'].isna()) & (df_min['value'] > df_min['global_p95'])
df_min['relative_breach'] = np.where(
    df_min['exceed'] & (df_min['global_p95'] > 0),
    (df_min['value'] - df_min['global_p95']) / df_min['global_p95'],
    np.where(df_min['exceed'] & (df_min['global_p95'] == 0) & (df_min['value'] > 0), np.inf, np.nan)
)

# 1) All metric rows at those minutes where value > global_p95 (limit 200)
metric_exceed = df_min[df_min['exceed']].copy()
metric_exceed['minute_timestamp'] = metric_exceed['minute'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')

# select and sort as requested
metric_exceed_out = metric_exceed[['minute_timestamp','cmdb_id','kpi_name','value','global_p95','relative_breach']].sort_values(
    ['minute_timestamp','relative_breach'], ascending=[True, False]
).head(200)

# 2) Aggregated summary per minute: bucket kpi_name prefix and compute counts and relative_breach sums
def kpi_prefix(k):
    if not isinstance(k, str) or k == '':
        return ''
    parts = k.split('.')
    # treat mesh.source and mesh.destination as two-token prefix
    if parts[0] == 'mesh' and len(parts) > 1 and parts[1] in ('destination','source'):
        return parts[0] + '.' + parts[1]
    return parts[0]

metric_exceed['kpi_bucket'] = metric_exceed['kpi_name'].apply(kpi_prefix)

summaries = []
for minute in candidate_minutes:
    mstr = minute.strftime('%Y-%m-%dT%H:%M:%S%z')
    df_m = metric_exceed[metric_exceed['minute'].dt.strftime('%Y-%m-%dT%H:%M:%S%z') == mstr].copy()
    if df_m.empty:
        summaries.append({'timestamp': mstr, 'total_exceedances': 0, 'top5_by_count': [], 'top5_by_severity': []})
        continue
    grp = df_m.groupby('kpi_bucket').agg(
        count=('kpi_name','size'),
        severity_sum=('relative_breach','sum')
    ).reset_index()
    top_by_count = grp.sort_values('count', ascending=False).head(5)
    top_by_sev = grp.sort_values('severity_sum', ascending=False).head(5)
    # convert to small list of tuples
    top_count_list = list(top_by_count[['kpi_bucket','count']].itertuples(index=False, name=None))
    top_sev_list = list(top_by_sev[['kpi_bucket','severity_sum']].itertuples(index=False, name=None))
    summaries.append({
        'timestamp': mstr,
        'total_exceedances': int(df_m.shape[0]),
        'top5_by_count': top_count_list,
        'top5_by_severity': top_sev_list
    })

summary_df = pd.DataFrame(summaries)

# Final compact outputs: metric_exceed_out (raw rows limited to 200) and summary_df
metric_exceed_out, summary_df
