2026-07-04 06:06:05,375 | DEBUG | Raw Code:
import pandas as pd
import numpy as np
import pytz

# timezone
tz = pytz.timezone('Asia/Shanghai')

# target cmdb_ids and candidate minutes
target_cmdbs = [
    'checkoutservice2-0', 'checkoutservice-0', 'checkoutservice-1', 'checkoutservice-2',
    'adservice2-0', 'adservice2', 'adservice',
    'frontend-0', 'frontend-1', 'frontend-2',
    'productcatalogservice-0', 'productcatalogservice-2', 'productcatalogservice2-0',
    'node-2', 'node-6'
]
candidate_minutes = [
    pd.Timestamp('2022-03-21 18:14:00').tz_localize(tz),
    pd.Timestamp('2022-03-21 18:29:00').tz_localize(tz)
]

# --- Load trace.csv, log.csv, error_logs.csv if not already loaded ---
if 'df_trace' not in globals():
    df_trace = pd.read_csv('trace.csv')
if 'df_log' not in globals():
    df_log = pd.read_csv('log.csv')
if 'df_error' not in globals():
    df_error = pd.read_csv('error_logs.csv')

# ensure timezone-aware ts and minute columns for all
if 'ts' not in df_trace.columns:
    df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    if df_trace['ts'].dt.tz is None:
        df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_trace['minute'] = df_trace['ts'].dt.floor('T')

if 'ts' not in df_log.columns:
    df_log['ts'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    if df_log['ts'].dt.tz is None:
        df_log['ts'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_log['minute'] = df_log['ts'].dt.floor('T')

if 'ts' not in df_error.columns:
    df_error['ts'] = pd.to_datetime(df_error['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    if df_error['ts'].dt.tz is None:
        df_error['ts'] = pd.to_datetime(df_error['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_error['minute'] = df_error['ts'].dt.floor('T')

# --- 1) Compute global P95 thresholds using full series (do NOT filter by time) ---
# trace global p95 per (cmdb_id, trace_name)
trace_p95 = (
    df_trace
    .groupby(['cmdb_id', 'trace_name'])['value']
    .quantile(0.95)
    .reset_index()
    .rename(columns={'value': 'global_p95'})
)

# log global p95 per (cmdb_id, log_name)
log_p95 = (
    df_log
    .groupby(['cmdb_id', 'log_name'])['value']
    .quantile(0.95)
    .reset_index()
    .rename(columns={'value': 'global_p95'})
)

# --- 2 & 3) Filter to the two minutes and target cmdb_ids, evaluate exceedances ---

# TRACE: filter rows to candidate minutes and target cmdb_ids
trace_min_df = df_trace[df_trace['minute'].isin(candidate_minutes) & df_trace['cmdb_id'].isin(target_cmdbs)].copy()
# merge p95
trace_min_df = trace_min_df.merge(trace_p95, on=['cmdb_id','trace_name'], how='left')
# compute exceed and relative breach
trace_min_df['exceed'] = (~trace_min_df['global_p95'].isna()) & (trace_min_df['value'] > trace_min_df['global_p95'])
# handle divide-by-zero: if global_p95 == 0, set relative_breach to np.inf where value>0
trace_min_df['relative_breach'] = np.where(
    trace_min_df['exceed'] & (trace_min_df['global_p95'] > 0),
    (trace_min_df['value'] - trace_min_df['global_p95']) / trace_min_df['global_p95'],
    np.where(trace_min_df['exceed'] & (trace_min_df['global_p95'] == 0) & (trace_min_df['value'] > 0), np.inf, np.nan)
)
# flag error_rate or trace.self*
trace_min_df['is_error_or_self'] = trace_min_df['trace_name'].astype(str).str.contains('error_rate') | trace_min_df['trace_name'].astype(str).str.startswith('trace.self')
# select exceed rows for requested cmdb_ids and minutes
trace_exceed = trace_min_df[trace_min_df['exceed']].copy()
# format minute_timestamp column
trace_exceed['minute_timestamp'] = trace_exceed['minute'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
# select requested columns and limit to 200 rows; sort by minute_timestamp, cmdb_id, relative_breach desc
trace_exceed_out = trace_exceed[['minute_timestamp','cmdb_id','trace_name','value','global_p95','relative_breach','is_error_or_self']].sort_values(['minute_timestamp','cmdb_id','relative_breach'], ascending=[True,True,False]).head(200)

# --- LOGS: filter rows to candidate minutes and target cmdb_ids
log_min_df = df_log[df_log['minute'].isin(candidate_minutes) & df_log['cmdb_id'].isin(target_cmdbs)].copy()
log_min_df = log_min_df.merge(log_p95, on=['cmdb_id','log_name'], how='left')
log_min_df['exceed'] = (~log_min_df['global_p95'].isna()) & (log_min_df['value'] > log_min_df['global_p95'])
log_min_df['relative_breach'] = np.where(
    log_min_df['exceed'] & (log_min_df['global_p95'] > 0),
    (log_min_df['value'] - log_min_df['global_p95']) / log_min_df['global_p95'],
    np.where(log_min_df['exceed'] & (log_min_df['global_p95'] == 0) & (log_min_df['value'] > 0), np.inf, np.nan)
)
log_exceed = log_min_df[log_min_df['exceed']].copy()
log_exceed['minute_timestamp'] = log_exceed['minute'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
log_exceed_out = log_exceed[['minute_timestamp','cmdb_id','log_name','value','global_p95','relative_breach']].sort_values(['minute_timestamp','cmdb_id','relative_breach'], ascending=[True,True,False]).head(100)

# --- ERROR LOGS: raw entries for target cmdb_ids whose minute matches candidate minutes ---
error_min_df = df_error[df_error['minute'].isin(candidate_minutes) & df_error['cmdb_id'].isin(target_cmdbs)].copy()
# select requested columns and limit to 200
error_min_df['timestamp_iso'] = error_min_df['ts'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
error_out = error_min_df[['timestamp_iso','cmdb_id','message']].rename(columns={'timestamp_iso':'timestamp'}).head(200)

# --- Per-minute compact summaries and intersection of cmdb_ids appearing in all three sources ---
summary_rows = []
for minute in candidate_minutes:
    mstr = minute.strftime('%Y-%m-%dT%H:%M:%S%z')
    t_count = int(trace_exceed[trace_exceed['minute'].dt.strftime('%Y-%m-%dT%H:%M:%S%z') == mstr].shape[0]) if 'minute' in trace_exceed.columns else int(trace_exceed[trace_exceed['minute_timestamp'] == mstr].shape[0])
    l_count = int(log_exceed[log_exceed['minute_timestamp'] == mstr].shape[0])
    e_count = int(error_min_df[error_min_df['minute'] == minute].shape[0])
    # cmdb_ids present in each source for that minute
    cm_trace = set(trace_exceed[trace_exceed['minute_timestamp'] == mstr]['cmdb_id'].unique())
    cm_log = set(log_exceed[log_exceed['minute_timestamp'] == mstr]['cmdb_id'].unique())
    cm_err = set(error_min_df[error_min_df['minute'] == minute]['cmdb_id'].unique())
    common_all_three = sorted(list(cm_trace & cm_log & cm_err))
    summary_rows.append({
        'timestamp': mstr,
        'total_trace_exceedances_returned': t_count,
        'total_log_exceedances_returned': l_count,
        'total_error_log_rows_returned': e_count,
        'cmdb_ids_in_all_three_sources': common_all_three
    })

summary_df = pd.DataFrame(summary_rows)

# Final compact outputs (limited sizes as requested)
trace_exceed_out, log_exceed_out, error_out, summary_df
