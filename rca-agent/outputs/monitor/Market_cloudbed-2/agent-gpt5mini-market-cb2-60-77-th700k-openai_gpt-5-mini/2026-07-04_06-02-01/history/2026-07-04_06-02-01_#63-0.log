import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# metric.csv
df_metric = pd.read_csv('metric.csv')
df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
summary_metric = {
    'file': 'metric.csv',
    'count': int(df_metric.shape[0]),
    'min_timestamp': df_metric['ts'].min().isoformat() if not df_metric['ts'].isna().all() else None,
    'max_timestamp': df_metric['ts'].max().isoformat() if not df_metric['ts'].isna().all() else None,
    'cmdb_ids': df_metric['cmdb_id'].dropna().unique()[:20].tolist(),
    'kpi_names': pd.Series(df_metric['kpi_name'].dropna().unique())[:50].tolist()
}

# trace.csv
df_trace = pd.read_csv('trace.csv')
df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
summary_trace = {
    'file': 'trace.csv',
    'count': int(df_trace.shape[0]),
    'min_timestamp': df_trace['ts'].min().isoformat() if not df_trace['ts'].isna().all() else None,
    'max_timestamp': df_trace['ts'].max().isoformat() if not df_trace['ts'].isna().all() else None,
    'cmdb_ids': df_trace['cmdb_id'].dropna().unique()[:20].tolist(),
    'trace_names': pd.Series(df_trace['trace_name'].dropna().unique())[:50].tolist()
}

# log.csv
df_log = pd.read_csv('log.csv')
df_log['ts'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
summary_log = {
    'file': 'log.csv',
    'count': int(df_log.shape[0]),
    'min_timestamp': df_log['ts'].min().isoformat() if not df_log['ts'].isna().all() else None,
    'max_timestamp': df_log['ts'].max().isoformat() if not df_log['ts'].isna().all() else None,
    'cmdb_ids': df_log['cmdb_id'].dropna().unique()[:20].tolist(),
    'log_names': pd.Series(df_log['log_name'].dropna().unique())[:50].tolist()
}

# error_logs.csv
df_error = pd.read_csv('error_logs.csv')
df_error['ts'] = pd.to_datetime(df_error['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
summary_error = {
    'file': 'error_logs.csv',
