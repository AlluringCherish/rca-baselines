import pandas as pd
import numpy as np
import pytz

# reuse existing variables if available
tz = pytz.timezone('Asia/Shanghai')

# ensure df_metric loaded
if 'df_metric' not in globals():
    df_metric = pd.read_csv('metric.csv')

# ensure ts and minute columns (UTC+8)
if 'ts' not in df_metric.columns:
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    if df_metric['ts'].dt.tz is None:
        df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_metric['minute'] = df_metric['ts'].dt.floor('T')

# 1) Compute global P95 per (cmdb_id, kpi_name) over full series (must be before filtering)
if 'p95_metric' not in globals():
    p95_metric = (
        df_metric
        .groupby(['cmdb_id', 'kpi_name'])['value']
        .quantile(0.95)
        .reset_index()
        .rename(columns={'value': 'global_p95'})
    )

# candidate minutes
m1 = pd.Timestamp('2022-03-21 18:14:00').tz_localize(tz)
m2 = pd.Timestamp('2022-03-21 18:29:00').tz_localize(tz)

# helper: compute relative breach safely
def compute_relative_breach(df, val_col='value', p95_col='global_p95'):
    # returns series
    p95 = df[p95_col]
    val = df[val_col]
    rel = np.where(
        (~p95.isna()) & (val > p95) & (p95 > 0),
        (val - p95) / p95,
        np.where((~p95.isna()) & (val > p95) & (p95 == 0) & (val > 0), np.inf, np.nan)
    )
    return rel

# prefixes to include
prefixes = ('container','system','runtime','app','mesh')

# kpi bucket function for summaries (mesh.destination and mesh.source as two-token)
def kpi_bucket(k):
    if not isinstance(k, str) or k == '':
        return ''
    parts = k.split('.')
    if parts[0] == 'mesh' and len(parts) > 1 and parts[1] in ('destination','source'):
        return parts[0] + '.' + parts[1]
    return parts[0]

# 2a) For checkoutservice pods at 18:14
checkout_pods = ['checkoutservice2-0','checkoutservice-0','checkoutservice-1','checkoutservice-2']
df_chk_min = df_metric[(df_metric['minute'] == m1) & (df_metric['cmdb_id'].isin(checkout_pods))].copy()
# merge p95
df_chk_min = df_chk_min.merge(p95_metric, on=['cmdb_id','kpi_name'], how='left')
# filter by prefix and exceed
df_chk_min = df_chk_min[df_chk_min['kpi_name'].str.startswith(prefixes)]
df_chk_min['exceed'] = (~df_chk_min['global_p95'].isna()) & (df_chk_min['value'] > df_chk_min['global_p95'])
df_chk_min = df_chk_min[df_chk_min['exceed']].copy()
df_chk_min['relative_breach'] = compute_relative_breach(df_chk_min)
df_chk_min['minute_timestamp'] = df_chk_min['minute'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
# select & sort & limit 100
checkout_exceed_out = df_chk_min[['minute_timestamp','cmdb_id','kpi_name','value','global_p95','relative_breach']].sort_values(
    by='relative_breach', ascending=False
).head(100)

# aggregated summary per-minute for checkout minute: bucket -> count and mean relative_breach, top 6 by count
if not df_chk_min.empty:
    df_chk_min['kpi_bucket'] = df_chk_min['kpi_name'].apply(kpi_bucket)
    chk_grp = df_chk_min.groupby('kpi_bucket').agg(
        count=('kpi_name','size'),
        mean_relative_breach=('relative_breach', 'mean')
    ).reset_index().sort_values('count', ascending=False)
    checkout_summary_top6 = chk_grp.head(6)
else:
    checkout_summary_top6 = pd.DataFrame(columns=['kpi_bucket','count','mean_relative_breach'])

# 2b) For frontend and node components at 18:29
frontend_node = ['frontend-0','frontend-1','frontend-2','node-1','node-2','node-3','node-4','node-6']
df_fn_min = df_metric[(df_metric['minute'] == m2) & (df_metric['cmdb_id'].isin(frontend_node))].copy()
# merge p95
df_fn_min = df_fn_min.merge(p95_metric, on=['cmdb_id','kpi_name'], how='left')
# filter by prefixes and exceed
df_fn_min = df_fn_min[df_fn_min['kpi_name'].str.startswith(prefixes)]
df_fn_min['exceed'] = (~df_fn_min['global_p95'].isna()) & (df_fn_min['value'] > df_fn_min['global_p95'])
df_fn_min = df_fn_min[df_fn_min['exceed']].copy()
df_fn_min['relative_breach'] = compute_relative_breach(df_fn_min)
df_fn_min['minute_timestamp'] = df_fn_min['minute'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
# select & sort & limit 100
frontend_node_exceed_out = df_fn_min[['minute_timestamp','cmdb_id','kpi_name','value','global_p95','relative_breach']].sort_values(
    by='relative_breach', ascending=False
).head(100)

# aggregated summary per-minute for frontend/node minute: bucket -> count and mean relative_breach, top 6 by count
if not df_fn_min.empty:
    df_fn_min['kpi_bucket'] = df_fn_min['kpi_name'].apply(kpi_bucket)
    fn_grp = df_fn_min.groupby('kpi_bucket').agg(
        count=('kpi_name','size'),
        mean_relative_breach=('relative_breach', 'mean')
    ).reset_index().sort_values('count', ascending=False)
    frontend_node_summary_top6 = fn_grp.head(6)
else:
    frontend_node_summary_top6 = pd.DataFrame(columns=['kpi_bucket','count','mean_relative_breach'])

# Final compact outputs: raw tables (<=100 rows) and small aggregated summaries (top 6 buckets)
checkout_exceed_out, checkout_summary_top6, frontend_node_exceed_out, frontend_node_summary_top6
