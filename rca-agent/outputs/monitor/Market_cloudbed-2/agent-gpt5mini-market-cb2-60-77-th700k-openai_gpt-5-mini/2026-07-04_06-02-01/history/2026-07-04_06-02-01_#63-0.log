import pandas as pd
import pytz

# reuse df_metric if available, otherwise load
if 'df_metric' not in globals():
    df_metric = pd.read_csv('metric.csv')

# ensure timestamp column as timezone-aware in UTC+8
tz = pytz.timezone('Asia/Shanghai')
if 'ts' not in df_metric.columns:
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    # ensure tz-aware conversion if needed
    if df_metric['ts'].dt.tz is None:
        df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) compute global P95 per (cmdb_id, kpi_name) using the whole series
group_keys = ['cmdb_id', 'kpi_name']
p95_series = df_metric.groupby(group_keys)['value'].quantile(0.95)
p95_df = p95_series.reset_index().rename(columns={'value':'global_p95'})

# total distinct pairs scanned
total_pairs_scanned = int(p95_df.shape[0])

# 2) filter to the incident window (UTC+8) March 21, 2022 18:00:00 to 18:30:00 inclusive
start = pd.Timestamp('2022-03-21 18:00:00').tz_localize(tz)
end = pd.Timestamp('2022-03-21 18:30:00').tz_localize(tz)
df_window = df_metric[(df_metric['ts'] >= start) & (df_metric['ts'] <= end)].copy()

# merge global p95 into window rows
df_win_merged = df_window.merge(p95_df, on=group_keys, how='left')

# identify exceedances (value > global_p95). If global_p95 is NaN, treat as no exceedance.
df_win_merged['exceed'] = df_win_merged['value'] > df_win_merged['global_p95']

# 3) For pairs with at least one exceedance, aggregate required info
agg_exceeds = (
    df_win_merged[df_win_merged['exceed']]
    .groupby(group_keys)
    .agg(
        exceed_count_in_window=('exceed', 'sum'),
        earliest_exceed_timestamp=('ts', 'min'),
        max_value_in_window=('value', 'max')
    )
    .reset_index()
)

# total rows in window per pair (needed even if zero exceeds; but we only return pairs with >=1 exceed)
rows_in_window = (
    df_win_merged.groupby(group_keys)
    .size()
    .reset_index(name='total_rows_in_window')
)

# join totals and global_p95
result = (
    agg_exceeds
    .merge(rows_in_window, on=group_keys, how='left')
    .merge(p95_df, on=group_keys, how='left')
)

# format earliest_exceed_timestamp as ISO strings in UTC+8
result['earliest_exceed_timestamp'] = result['earliest_exceed_timestamp'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')

# reorder columns as requested
result = result[['cmdb_id', 'kpi_name', 'global_p95', 'exceed_count_in_window',
                 'earliest_exceed_timestamp', 'max_value_in_window', 'total_rows_in_window']]

# top 20 by exceed_count descending
top20 = result.sort_values('exceed_count_in_window', ascending=False).head(20)

# Display compact results: top20 table and total_pairs_scanned
top20, total_pairs_scanned
