# Now compute in-window metrics: points_in_window and earliest timestamp in-window
mask_window = (df_metric['timestamp'].notna()) & (df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] <= end_ts)
df_window = df_metric[mask_window]

# points count in window
window_counts = df_window.groupby(['cmdb_id', 'kpi_name']).agg(
    points_in_window = ('value','count'),
    earliest_in_window_ts = ('timestamp','min')
).reset_index()

# Merge global stats with window info
merged = stats_df.merge(window_counts, on=['cmdb_id','kpi_name'], how='left')

# Fill NA for window counts
merged['points_in_window'] = merged['points_in_window'].fillna(0).astype(int)
merged['earliest_in_window_ts'] = merged['earliest_in_window_ts'].where(merged['earliest_in_window_ts'].notna(), None)

# Convert earliest_in_window_ts to ISO strings in UTC+8
