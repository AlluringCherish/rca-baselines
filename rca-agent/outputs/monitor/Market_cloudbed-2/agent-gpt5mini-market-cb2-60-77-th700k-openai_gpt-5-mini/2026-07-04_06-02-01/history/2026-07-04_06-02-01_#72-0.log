import numpy as np
import pandas as pd
import pytz

# reuse df_metric loaded earlier; if not present, load it
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

tz = pytz.timezone('Asia/Shanghai')

# helper to convert epoch seconds to Asia/Shanghai ISO string (UTC+8)
def ts_to_iso(ts):
    if pd.isna(ts):
        return None
    ts_int = int(ts)
    return pd.to_datetime(ts_int, unit='s', utc=True).tz_convert(tz).isoformat()

# Incident window bounds in UTC+8
start_local = pd.Timestamp('2022-03-21 22:30:00', tz=tz)
end_local = pd.Timestamp('2022-03-21 22:59:59', tz=tz)
# Convert to epoch seconds (UTC)
start_ts = int(start_local.tz_convert('UTC').timestamp())
end_ts = int(end_local.tz_convert('UTC').timestamp())

# Ensure timestamp column is numeric
df_metric['timestamp'] = pd.to_numeric(df_metric['timestamp'], errors='coerce').astype('Int64')

# Compute global stats per (cmdb_id, kpi_name) using full series BEFORE filtering
grp = df_metric.groupby(['cmdb_id', 'kpi_name'])['value']

def series_stats(s):
    arr = s.dropna().values.astype(float)
    cnt = int(arr.size)
    if cnt == 0:
        return pd.Series({
            'count': 0,
            'mean': np.nan,
            'min': np.nan,
            'p5': np.nan,
            'p95': np.nan,
            'max': np.nan
        })
    return pd.Series({
        'count': cnt,
        'mean': float(np.nanmean(arr)),
        'min': float(np.nanmin(arr)),
        'p5': float(np.nanpercentile(arr, 5)),
        'p95': float(np.nanpercentile(arr, 95)),
        'max': float(np.nanmax(arr))
    })

