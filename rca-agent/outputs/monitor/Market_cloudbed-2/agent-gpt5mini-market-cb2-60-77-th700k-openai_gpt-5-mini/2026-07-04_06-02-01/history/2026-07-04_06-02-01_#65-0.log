import pandas as pd
import pytz

# Load CSVs into memory (full tables stored in variables for later use)
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")
log_df = pd.read_csv("log.csv")
error_logs_df = pd.read_csv("error_logs.csv")

# timezone for UTC+8
tz = pytz.timezone('Asia/Shanghai')

# helper to compute min/max timestamp strings in UTC+8
def ts_min_max(df, ts_col='timestamp'):
    ts = pd.to_datetime(df[ts_col], unit='s', utc=True)
    ts_local = ts.dt.tz_convert(tz)
    tmin = ts_local.min()
    tmax = ts_local.max()
    # compact ISO-like strings
    return (None if pd.isna(tmin) else tmin.strftime("%Y-%m-%d %H:%M:%S %Z")),
           (None if pd.isna(tmax) else tmax.strftime("%Y-%m-%d %H:%M:%S %Z"))

# Build summaries

# 1) metric.csv summary
metric_unique_cmdb = sorted(metric_df['cmdb_id'].dropna().unique())[:50]
metric_unique_cmdb_count = metric_df['cmdb_id'].nunique(dropna=True)
metric_kpi_counts = metric_df['kpi_name'].value_counts().head(50)
metric_tmin, metric_tmax = ts_min_max(metric_df, 'timestamp')
metric_rows = metric_df.shape[0]

metric_summary = {
    "rows": int(metric_rows),
    "timestamp_min": metric_tmin,
    "timestamp_max": metric_tmax,
    "unique_cmdb_count": int(metric_unique_cmdb_count),
    "unique_cmdb_sample_sorted_up_to_50": metric_unique_cmdb,
    "top_kpi_name_counts_top_50": metric_kpi_counts.reset_index().rename(columns={'index':'kpi_name','kpi_name':'count'}).to_dict(orient='records')
}

# 2) trace.csv summary
trace_unique_cmdb = sorted(trace_df['cmdb_id'].dropna().unique())[:50]
trace_unique_cmdb_count = trace_df['cmdb_id'].nunique(dropna=True)
trace_name_counts = trace_df['trace_name'].value_counts().head(50)
trace_tmin, trace_tmax = ts_min_max(trace_df, 'timestamp')
trace_rows = trace_df.shape[0]

trace_summary = {
    "rows": int(trace_rows),
    "timestamp_min": trace_tmin,
    "timestamp_max": trace_tmax,
    "unique_cmdb_count": int(trace_unique_cmdb_count),
    "unique_cmdb_sample_sorted_up_to_50": trace_unique_cmdb,
    "top_trace_name_counts_top_50": trace_name_counts.reset_index().rename(columns={'index':'trace_name','trace_name':'count'}).to_dict(orient='records')
}

# 3) log.csv summary
log_unique_cmdb = sorted(log_df['cmdb_id'].dropna().unique())[:50]
log_unique_cmdb_count = log_df['cmdb_id'].nunique(dropna=True)
log_name_counts = log_df['log_name'].value_counts().head(50)
log_tmin, log_tmax = ts_min_max(log_df, 'timestamp')
log_rows = log_df.shape[0]

log_summary = {
    "rows": int(log_rows),
    "timestamp_min": log_tmin,
    "timestamp_max": log_tmax,
    "unique_cmdb_count": int(log_unique_cmdb_count),
    "unique_cmdb_sample_sorted_up_to_50": log_unique_cmdb,
    "top_log_name_counts_top_50": log_name_counts.reset_index().rename(columns={'index':'log_name','log_name':'count'}).to_dict(orient='records')
}

# 4) error_logs.csv summary
error_rows = error_logs_df.shape[0]
error_unique_cmdb = sorted(error_logs_df['cmdb_id'].dropna().unique())[:50]
error_unique_cmdb_count = error_logs_df['cmdb_id'].nunique(dropna=True)
error_tmin, error_tmax = ts_min_max(error_logs_df, 'timestamp')
# sample up to 5 distinct message values
if 'message' in error_logs_df.columns:
    msg_values = pd.Series(error_logs_df['message'].dropna().unique()[:5]).tolist()
else:
    msg_values = []

error_summary = {
    "rows": int(error_rows),
    "timestamp_min": error_tmin,
    "timestamp_max": error_tmax,
    "unique_cmdb_count": int(error_unique_cmdb_count),
    "unique_cmdb_sample_sorted_up_to_50": error_unique_cmdb,
    "sample_distinct_messages_up_to_5": msg_values
}

# Combined compact summary (JSON-like / dict-style)
summary = {
    "metric.csv": metric_summary,
    "trace.csv": trace_summary,
    "log.csv": log_summary,
    "error_logs.csv": error_summary
}

