import pandas as pd
import pytz
from datetime import datetime

# reuse trace_df from kernel
tz = pytz.timezone('Asia/Shanghai')

# 1) select trace rows where trace_name contains 'trace.to_'
mask_to = trace_df['trace_name'].str.contains('trace.to_', na=False)
trace_to = trace_df[mask_to].copy()
trace_to['value'] = pd.to_numeric(trace_to['value'], errors='coerce')
trace_to['timestamp'] = pd.to_numeric(trace_to['timestamp'], errors='coerce')

# 2) compute global P95 per trace_name using full series (no time restriction)
global_p95 = trace_to.groupby('trace_name', as_index=False)['value'].agg(global_p95=lambda s: float(s.quantile(0.95)) if s.dropna().shape[0]>0 else float('nan'))

# 3) restrict to incident window (UTC+8)
start_local = tz.localize(datetime(2022,3,21,19,0,0))
end_local   = tz.localize(datetime(2022,3,21,19,30,0))
start_epoch = int(start_local.astimezone(pytz.utc).timestamp())
end_epoch   = int(end_local.astimezone(pytz.utc).timestamp())

trace_window = trace_to[(trace_to['timestamp'] >= start_epoch) & (trace_to['timestamp'] <= end_epoch)].copy()

# Merge global_p95 into window to evaluate breaches; ensure all trace_names included by merging later
trace_window = trace_window.merge(global_p95, on='trace_name', how='left')

# compute per-trace window aggregates
# window_points, window_points_above_p95, earliest_above_epoch, max_value_in_window
agg_all = trace_window.groupby('trace_name', as_index=False).agg(
    window_points=('value','count'),
    window_points_above_p95=('value', lambda s: int((s > trace_window.loc[s.index, 'global_p95']).sum()) if s.size>0 else 0),
    earliest_above_epoch=('timestamp', lambda s: int(s[s.index[ (trace_window.loc[s.index, 'value'] > trace_window.loc[s.index, 'global_p95']) ].tolist()].min()) if s.size>0 and ((trace_window.loc[s.index,'value'] > trace_window.loc[s.index,'global_p95']).any()) else pd.NA),
    max_value_in_window=('value','max')
)

# Note: the above lambda uses alignment via indices; however, safer approach is to compute boolean column then aggregate
# Recompute more robustly:
if not trace_window.empty:
    trace_window['above_p95'] = trace_window['value'] > trace_window['global_p95']
    agg_window = trace_window.groupby('trace_name', as_index=False).agg(
        window_points=('value','count'),
        window_points_above_p95=('above_p95','sum'),
        earliest_above_epoch=('timestamp', lambda s: int(s[trace_window.loc[s.index,'above_p95']].min()) if s.size>0 and trace_window.loc[s.index,'above_p95'].any() else pd.NA),
        max_value_in_window=('value','max')
    )
else:
    agg_window = pd.DataFrame(columns=['trace_name','window_points','window_points_above_p95','earliest_above_epoch','max_value_in_window'])

# 4) combine with global_p95 to include traces that might have zero window rows
result = global_p95.merge(agg_window, on='trace_name', how='left')

# fill NaNs
result['window_points'] = result['window_points'].fillna(0).astype(int)
result['window_points_above_p95'] = result['window_points_above_p95'].fillna(0).astype(int)
result['earliest_above_epoch'] = result['earliest_above_epoch'].where('earliest_above_epoch' in result.columns, pd.NA)  # safe if missing
# ensure earliest_above_epoch column exists
if 'earliest_above_epoch' not in result.columns:
    result['earliest_above_epoch'] = pd.NA
else:
    result['earliest_above_epoch'] = result['earliest_above_epoch']

result['max_value_in_window'] = result['max_value_in_window'].where(~result['max_value_in_window'].isna(), pd.NA)

# format earliest timestamp
def fmt_epoch(ep):
    if pd.isna(ep):
        return pd.NA
    return pd.to_datetime(int(ep), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

result['earliest_above_p95_timestamp'] = result['earliest_above_epoch'].apply(fmt_epoch)

# severity_ratio = max_value_in_window / global_p95 (if global_p95>0)
def sev_ratio(row):
    gp = row['global_p95']
    mv = row['max_value_in_window']
    if pd.isna(mv) or pd.isna(gp) or gp == 0:
        return pd.NA
    try:
        return float(mv) / float(gp)
    except Exception:
        return pd.NA

result['severity_ratio'] = result.apply(sev_ratio, axis=1)

# sort by earliest_above_p95_timestamp ascending, place NA at end
def sort_key(ep):
    if pd.isna(ep):
        return 10**18
    # parse formatted string back to epoch
    dt = pd.to_datetime(ep).tz_localize(tz)
    return int(dt.astimezone(pytz.utc).timestamp())

result['sort_key'] = result['earliest_above_p95_timestamp'].apply(lambda x: sort_key(x))

# select and order columns
final = result[['trace_name','global_p95','window_points','window_points_above_p95','earliest_above_p95_timestamp','max_value_in_window','severity_ratio','sort_key']]

final_sorted = final.sort_values(by=['sort_key','trace_name'], ascending=[True,True]).drop(columns=['sort_key']).head(20)

# compact output
trace_down_summary = final_sorted.reset_index(drop=True)
trace_down_summary
