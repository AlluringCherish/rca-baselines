end = tz.localize(pd.Timestamp('2022-03-21 21:59:00'))
check_time = tz.localize(pd.Timestamp('2022-03-21 21:34:00'))

out_rows = []
for series_type, cmdb_id, series_name in targets:
    if series_type == 'metric':
