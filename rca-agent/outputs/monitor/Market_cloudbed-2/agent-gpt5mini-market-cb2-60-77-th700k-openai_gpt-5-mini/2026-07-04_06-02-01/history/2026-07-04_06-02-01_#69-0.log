    df_node_runs['start_timestamp'] = df_node_runs['start_timestamp'].astype(int)
    df_node_runs['end_timestamp'] = df_node_runs['end_timestamp'].astype(int)

# 1) Top 20 node runs sorted by breach_ratio desc (selected columns)
