       result_df_sorted['target_earliest_anomaly_timestamp_in_window'].notna() & \
       (result_df_sorted['target_earliest_anomaly_timestamp_in_window'] <= result_df_sorted['frontend_earliest_anomaly_timestamp_in_window'])

