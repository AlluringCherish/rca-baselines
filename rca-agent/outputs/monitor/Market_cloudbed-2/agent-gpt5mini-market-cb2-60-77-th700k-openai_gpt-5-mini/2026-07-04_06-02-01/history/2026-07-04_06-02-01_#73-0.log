# Reuse metric_df and tz from previous session
import pandas as pd
import pytz

# ensure tz exists
tz = pytz.timezone('Asia/Shanghai')

# Compute top 10 cmdb_id by number of metric rows
top_cmdb_series = metric_df['cmdb_id'].value_counts().head(10)
top_cmdb_df = top_cmdb_series.reset_index().rename(columns={'index': 'cmdb_id', 'cmdb_id': 'count'})

# For each top cmdb_id, compute top 10 kpi_name counts and min/max timestamps (formatted UTC+8)
top_details = {}
for cid, cnt in zip(top_cmdb_df['cmdb_id'], top_cmdb_df['count']):
    subset = metric_df.loc[metric_df['cmdb_id'] == cid]
    # timestamps
    mn_epoch = int(subset['timestamp'].min())
    mx_epoch = int(subset['timestamp'].max())
    mn_ts = pd.to_datetime(mn_epoch, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
    mx_ts = pd.to_datetime(mx_epoch, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
    # top kpis
    top_kpis_ser = subset['kpi_name'].value_counts().head(10)
    top_kpis = list(zip(top_kpis_ser.index.tolist(), top_kpis_ser.values.tolist()))
    top_details[cid] = {
        'rows': int(cnt),
        'min_epoch': mn_epoch,
        'min_ts': mn_ts,
        'max_epoch': mx_epoch,
        'max_ts': mx_ts,
        'top_kpi_name_counts': top_kpis
    }

# Compose compact JSON-like summary
summary = {
    'top_10_cmdb': top_cmdb_df,            # DataFrame (10 rows: cmdb_id, count)
    'top_kpis_by_cmdb': top_details        # dict: cmdb_id -> compact metadata + top 10 kpis
}

