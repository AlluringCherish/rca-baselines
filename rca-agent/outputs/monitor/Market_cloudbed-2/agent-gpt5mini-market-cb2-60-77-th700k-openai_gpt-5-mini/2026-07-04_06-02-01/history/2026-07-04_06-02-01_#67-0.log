# 2) log.csv: prepare dt and ensure numeric value
df_log['dt'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_log['value'] = pd.to_numeric(df_log['value'], errors='coerce')

