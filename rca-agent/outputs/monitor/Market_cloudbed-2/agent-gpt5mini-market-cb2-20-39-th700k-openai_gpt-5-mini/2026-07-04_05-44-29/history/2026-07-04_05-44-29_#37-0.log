end_window   = pd.Timestamp("2022-03-21 02:59:00").tz_localize(tz)

mask = (
    (trace_anomalies_full['cmdb_id'] == 'shippingservice-0') &
    (trace_anomalies_full['ts_tz'] >= start_window) &
    (trace_anomalies_full['ts_tz'] <= end_window)
)

