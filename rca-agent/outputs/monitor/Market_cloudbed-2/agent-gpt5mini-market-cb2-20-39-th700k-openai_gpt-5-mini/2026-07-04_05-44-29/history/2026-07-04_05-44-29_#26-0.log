import pandas as pd
import numpy as np
import pytz
from datetime import datetime

tz = pytz.timezone('Asia/Shanghai')

# Reuse metric_df if present; otherwise load
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')

# Ensure types
metric_df['timestamp'] = metric_df['timestamp'].astype(int)
metric_df['value'] = pd.to_numeric(metric_df['value'], errors='coerce')
metric_df['cmdb_id'] = metric_df['cmdb_id'].astype(str)
metric_df['kpi_name'] = metric_df['kpi_name'].astype(str)

# 1) Compute global P95 thresholds per (cmdb_id, kpi_name) from full series (if not already)
if 'metric_thresholds' not in globals():
    metric_thresholds = (
        metric_df
        .groupby(['cmdb_id','kpi_name'], dropna=False)['value']
        .quantile(0.95)
        .reset_index()
        .rename(columns={'value':'p95'})
    )

# 2) Incident window bounds (Asia/Shanghai) and filter to node-5
start_dt = tz.localize(datetime(2022, 3, 20, 22, 0, 0))
end_dt   = tz.localize(datetime(2022, 3, 20, 22, 29, 0))
start_ts = int(start_dt.astimezone(pytz.utc).timestamp())
end_ts   = int(end_dt.astimezone(pytz.utc).timestamp())

node5_win = metric_df[
    (metric_df['cmdb_id'] == 'node-5') &
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts)
].copy()

# 3) Join with global thresholds
node5_merged = node5_win.merge(metric_thresholds, on=['cmdb_id','kpi_name'], how='left')
# Drop rows without p95 since cannot evaluate
node5_merged = node5_merged.dropna(subset=['p95']).copy()
node5_merged['is_anomaly'] = node5_merged['value'] > node5_merged['p95']

# Helper to compute longest consecutive run where diffs == 60s
def longest_run_info(timestamps):
    if len(timestamps) == 0:
        return 0, None  # run length, start_ts
    ts = np.sort(np.asarray(timestamps, dtype=np.int64))
    max_run = 1
    max_start_idx = 0
    cur_run = 1
    cur_start = 0
    for i in range(1, len(ts)):
        if ts[i] - ts[i-1] == 60:
            cur_run += 1
        else:
            if cur_run > max_run:
                max_run = cur_run
                max_start_idx = cur_start
            cur_run = 1
            cur_start = i
    if cur_run > max_run:
        max_run = cur_run
        max_start_idx = cur_start
    start_ts = int(ts[max_start_idx])
    return int(max_run), start_ts

# Aggregate per (node-5, kpi_name)
rows = []
grp = node5_merged.groupby('kpi_name', dropna=False)
for kpi, g in grp:
    total_points = int(g['value'].count())
    anomaly_count = int(g['is_anomaly'].sum())
    p95_val = float(g['p95'].iloc[0])
    max_value = float(g['value'].max())
    # earliest anomaly timestamp (if any)
    if anomaly_count > 0:
        earliest_anom_ts = int(g.loc[g['is_anomaly'],'timestamp'].min())
        earliest_anom_str = pd.to_datetime(earliest_anom_ts, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
        # longest consecutive run among anomaly timestamps
        anom_ts = g.loc[g['is_anomaly'],'timestamp'].astype(int).to_numpy()
        run_len, run_start_ts = longest_run_info(anom_ts)
        if run_start_ts is not None:
            run_start_str = pd.to_datetime(int(run_start_ts), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
        else:
            run_start_str = pd.NA
    else:
        earliest_anom_str = pd.NA
        run_len = 0
        run_start_str = pd.NA
    # severity ratio (handle p95 == 0)
    if p95_val == 0:
        severity_ratio = float('nan')
    else:
        severity_ratio = float((max_value - p95_val) / p95_val)
    mean_value = float(g['value'].mean())
    rows.append({
        'cmdb_id': 'node-5',
        'kpi_name': kpi,
        'p95': round(p95_val, 6),
        'total_points_in_window': total_points,
        'anomaly_count': anomaly_count,
        'longest_consecutive_anomaly_run_minutes': run_len,
        'earliest_anomaly_timestamp': earliest_anom_str,
        'max_value_in_window': round(max_value, 6),
        'severity_ratio': severity_ratio
    })

result_df = pd.DataFrame(rows)

# 4) Sort by earliest_anomaly_timestamp asc (NULLs last) then severity_ratio desc
def sort_key(x):
    return pd.to_datetime(x) if pd.notna(x) else pd.NaT

result_df['_sort_ts'] = pd.to_datetime(result_df['earliest_anomaly_timestamp'], utc=True).dt.tz_convert(tz)
# Put NaT at end by filling with max
result_df['_sort_ts_filled'] = result_df['_sort_ts'].fillna(pd.Timestamp.max)
result_df = result_df.sort_values(by=['_sort_ts_filled','severity_ratio'], ascending=[True, False]).drop(columns=['_sort_ts','_sort_ts_filled']).reset_index(drop=True)

node5_anomalies_top20 = result_df.head(20)[[
    'cmdb_id','kpi_name','p95','total_points_in_window','anomaly_count',
    'longest_consecutive_anomaly_run_minutes','earliest_anomaly_timestamp','max_value_in_window','severity_ratio'
]]

# 5) earliest_node5_anomaly scalar
valid_earlies = node5_anomalies_top20['earliest_anomaly_timestamp'].dropna()
earliest_node5_anomaly = valid_earlies.min() if not valid_earlies.empty else pd.NA

# Final compact outputs
node5_anomalies_top20, earliest_node5_anomaly
