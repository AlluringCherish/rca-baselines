    trace_window.loc[mask_other, 'anomalous_above'] = trace_window.loc[mask_other, 'value'] > trace_window.loc[mask_other, 'global_p95']
    trace_window.loc[mask_other, 'anomalous_below'] = trace_window.loc[mask_other, 'value'] < trace_window.loc[mask_other, 'global_p5']
    trace_window['is_anom'] = trace_window['anomalous_above'] | trace_window['anomalous_below']
