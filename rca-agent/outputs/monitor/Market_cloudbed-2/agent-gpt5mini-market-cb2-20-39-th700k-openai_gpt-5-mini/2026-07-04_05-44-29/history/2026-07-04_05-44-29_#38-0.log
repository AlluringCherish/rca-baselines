import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# reuse existing DataFrames if available
metric_df = globals().get('metric_df', pd.read_csv('metric.csv'))
trace_df = globals().get('trace_df', pd.read_csv('trace.csv'))
log_df = globals().get('log_df', pd.read_csv('log.csv'))
error_df = globals().get('error_df', pd.read_csv('error_logs.csv'))

# ensure timestamp and localized datetime columns
for df, name in [(metric_df,'metric_df'), (trace_df,'trace_df'), (log_df,'log_df'), (error_df,'error_df')]:
    df['timestamp'] = pd.to_numeric(df['timestamp'], errors='coerce').astype('Int64')
    if '_ts_local' not in df.columns:
        df['_ts_local'] = pd.to_datetime(df['timestamp'].astype('int64'), unit='s', utc=True).dt.tz_convert(tz)
    # ensure numeric value column where present
    if 'value' in df.columns:
        df['value'] = pd.to_numeric(df['value'], errors='coerce')

# frontends of interest
frontends = ['frontend-0','frontend-1','frontend-2','frontend2-0']

# incident window
start = pd.Timestamp('2022-03-21 03:00:00', tz=tz)
end   = pd.Timestamp('2022-03-21 03:30:00', tz=tz)

# --- Metric anomalies ---
# reuse precomputed global thresholds if present, else compute
global_thresh_metric = globals().get('_global_thresh_for_next_steps') or globals().get('global_thresh')
if global_thresh_metric is None:
    global_thresh_metric = (
        metric_df.groupby(['cmdb_id','kpi_name'], dropna=False)['value']
        .agg(global_p95=lambda x: float(x.dropna().quantile(0.95)) if x.dropna().size>0 else np.nan,
             global_p5 =lambda x: float(x.dropna().quantile(0.05)) if x.dropna().size>0 else np.nan)
        .reset_index()
    )

# filter metric rows to window and frontends
metric_window = metric_df[(metric_df['_ts_local'] >= start) & (metric_df['_ts_local'] <= end) & (metric_df['cmdb_id'].isin(frontends))].copy()
# merge thresholds
metric_window = metric_window.merge(global_thresh_metric, on=['cmdb_id','kpi_name'], how='left')

# mark anomalies per row (value > p95 or value < p5)
metric_window['anom_above'] = metric_window['value'] > metric_window['global_p95']
metric_window['anom_below'] = metric_window['value'] < metric_window['global_p5']
metric_window['is_anom'] = metric_window['anom_above'] | metric_window['anom_below']

# count distinct anomalous kpi_name per (cmdb_id, minute)
metric_anom_by_min = (
    metric_window[metric_window['is_anom']]
    .groupby(['cmdb_id','_ts_local'], dropna=False)
    .agg(metric_anomaly_count = ('kpi_name', lambda s: int(s.nunique())))
    .reset_index()
)

# --- Trace anomalies ---
# reuse precomputed anomalies if available
anomalies_trace_df = globals().get('_anomalies_trace_df') or globals().get('anomalies_trace_df')
_global_thresh_trace = globals().get('_global_thresh_trace') or globals().get('global_thresh_trace')

if anomalies_trace_df is None or _global_thresh_trace is None:
    # compute global thresholds for traces (full series) and mark anomalies per rules
    global_thresh_trace = (
        trace_df.groupby(['cmdb_id','trace_name'], dropna=False)['value']
        .agg(global_p95=lambda x: float(x.dropna().quantile(0.95)) if x.dropna().size>0 else np.nan,
             global_p5 =lambda x: float(x.dropna().quantile(0.05)) if x.dropna().size>0 else np.nan)
        .reset_index()
    )
    # filter window for traces
    trace_window = trace_df[(trace_df['_ts_local'] >= start) & (trace_df['_ts_local'] <= end)].copy()
    trace_window = trace_window.merge(global_thresh_trace, on=['cmdb_id','trace_name'], how='left')
    # classify types
    trace_window['is_row_count'] = trace_window['trace_name'].str.contains('row_count', na=False)
    trace_window['is_error_rate'] = trace_window['trace_name'].str.contains('error_rate', na=False)
    trace_window['is_duration'] = trace_window['trace_name'].str.contains('duration', na=False)
    # apply rules
    trace_window['anomalous_above'] = False
    trace_window['anomalous_below'] = False
    mask_row = trace_window['is_row_count'] & trace_window['value'].notna()
    trace_window.loc[mask_row, 'anomalous_below'] = trace_window.loc[mask_row, 'value'] < trace_window.loc[mask_row, 'global_p5']
    mask_err = trace_window['is_error_rate'] & trace_window['value'].notna()
    trace_window.loc[mask_err, 'anomalous_above'] = trace_window.loc[mask_err, 'value'] > trace_window.loc[mask_err, 'global_p95']
    mask_dur = trace_window['is_duration'] & trace_window['value'].notna()
    trace_window.loc[mask_dur, 'anomalous_above'] = trace_window.loc[mask_dur, 'value'] > trace_window.loc[mask_dur, 'global_p95']
    mask_other = ~(trace_window['is_row_count'] | trace_window['is_error_rate'] | trace_window['is_duration']) & trace_window['value'].notna()
    trace_window.loc[mask_other, 'anomalous_above'] = trace_window.loc[mask_other, 'value'] > trace_window.loc[mask_other, 'global_p95']
    trace_window.loc[mask_other, 'anomalous_below'] = trace_window.loc[mask_other, 'value'] < trace_window.loc[mask_other, 'global_p5']
    trace_window['is_anom'] = trace_window['anomalous_above'] | trace_window['anomalous_below']
    anomalies_trace_df = trace_window[trace_window['is_anom']].copy()
