error_window = error_df[(error_df['_ts_local'] >= start) & (error_df['_ts_local'] <= end) & (error_df['cmdb_id'].isin(frontends))].copy()
if error_window.empty:
    error_by_min = pd.DataFrame(columns=['cmdb_id','_ts_local','error_log_count'])
else:
    error_by_min = (
        error_window
        .groupby(['cmdb_id','_ts_local'], dropna=False)
        .size()
        .rename('error_log_count')
        .reset_index()
    )

# -----------------------
# Combine per-minute aggregates
# -----------------------
# collect keys
frames = []
for df in [metric_anom_by_min, trace_anom_by_min, log_error_by_min, error_by_min]:
    if df is not None and not df.empty:
        frames.append(df[['cmdb_id','_ts_local']].drop_duplicates())
if frames:
    all_keys = pd.concat(frames, ignore_index=True).drop_duplicates().reset_index(drop=True)
else:
    all_keys = pd.DataFrame(columns=['cmdb_id','_ts_local'])

# merge counts (fill missing with 0)
corr = all_keys.merge(metric_anom_by_min, on=['cmdb_id','_ts_local'], how='left') \
               .merge(trace_anom_by_min, on=['cmdb_id','_ts_local'], how='left') \
               .merge(log_error_by_min, on=['cmdb_id','_ts_local'], how='left') \
               .merge(error_by_min, on=['cmdb_id','_ts_local'], how='left')

# fillna and types
corr['metric_anomaly_count'] = corr.get('metric_anomaly_count', pd.Series()).fillna(0).astype(int) if 'metric_anomaly_count' in corr else 0
corr['trace_anomaly_count']  = corr.get('trace_anomaly_count', pd.Series()).fillna(0).astype(int)  if 'trace_anomaly_count' in corr else 0
corr['log_error_count']      = corr.get('log_error_count', pd.Series()).fillna(0).astype(int)      if 'log_error_count' in corr else 0
corr['error_log_count']      = corr.get('error_log_count', pd.Series()).fillna(0).astype(int)      if 'error_log_count' in corr else 0

