    global_thresh_trace = (
        trace_df
        .groupby(['cmdb_id','trace_name'], dropna=False)['value']
        .agg(global_p95=lambda x: float(x.dropna().quantile(0.95)) if x.dropna().size>0 else np.nan,
             global_p5 =lambda x: float(x.dropna().quantile(0.05)) if x.dropna().size>0 else np.nan)
        .reset_index()
    )
    trace_window = trace_df[(trace_df['_ts_local'] >= start) & (trace_df['_ts_local'] <= end)].copy()
    trace_window = trace_window.merge(global_thresh_trace, on=['cmdb_id','trace_name'], how='left')
    trace_window['is_row_count'] = trace_window['trace_name'].str.contains('row_count', na=False)
    trace_window['is_error_rate'] = trace_window['trace_name'].str.contains('error_rate', na=False)
    trace_window['is_duration'] = trace_window['trace_name'].str.contains('duration', na=False)
    trace_window['anomalous_above'] = False
    trace_window['anomalous_below'] = False
    mask_row = trace_window['is_row_count'] & trace_window['value'].notna()
    trace_window.loc[mask_row, 'anomalous_below'] = trace_window.loc[mask_row, 'value'] < trace_window.loc[mask_row, 'global_p5']
    mask_err = trace_window['is_error_rate'] & trace_window['value'].notna()
    trace_window.loc[mask_err, 'anomalous_above'] = trace_window.loc[mask_err, 'value'] > trace_window.loc[mask_err, 'global_p95']
