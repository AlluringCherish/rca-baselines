if log_error.empty:
    log_error_by_min = pd.DataFrame(columns=['cmdb_id','_ts_local','log_error_count'])
else:
    log_error['value'] = pd.to_numeric(log_error['value'], errors='coerce').fillna(0.0)
    log_error_by_min = (
