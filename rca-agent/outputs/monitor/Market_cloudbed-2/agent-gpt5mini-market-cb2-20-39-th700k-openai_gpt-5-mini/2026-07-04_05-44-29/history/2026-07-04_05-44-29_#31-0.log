2026-07-04 05:47:37,824 | DEBUG | Raw Code:
import pandas as pd
import pytz

# reuse existing variables from kernel
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Incident window (UTC+8 -> epoch seconds UTC)
start_local = tz.localize(pd.Timestamp('2022-03-20 14:00:00'))
end_local = tz.localize(pd.Timestamp('2022-03-20 14:29:59'))
start_ts = int(start_local.tz_convert(pytz.UTC).timestamp())
end_ts = int(end_local.tz_convert(pytz.UTC).timestamp())

# Top 12 components (as provided)
top_components = [
    "adservice","adservice2","frontend2-0","frontend-0","frontend-1","frontend-2",
    "productcatalogservice-2","productcatalogservice-0","productcatalogservice-1",
    "cartservice-1","productcatalogservice2-0","adservice2-0"
]

# 1) Compute global P95 per (cmdb_id, kpi_name) using full df_metric but restrict to the selected components.
p95_selected = (
    df_metric[df_metric['cmdb_id'].isin(top_components)]
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'p95_threshold'})
)

# 2) Filter metric rows to incident window and selected components, merge thresholds, mark anomalies (value >= p95)
df_metric_window_sel = df_metric[
    (df_metric['timestamp'] >= start_ts) &
    (df_metric['timestamp'] <= end_ts) &
    (df_metric['cmdb_id'].isin(top_components))
].copy()

df_metric_window_sel = df_metric_window_sel.merge(p95_selected, on=['cmdb_id','kpi_name'], how='left')
# mark anomaly only where p95 exists
df_metric_window_sel['is_anomaly'] = False
mask_thr = df_metric_window_sel['p95_threshold'].notna()
df_metric_window_sel.loc[mask_thr, 'is_anomaly'] = df_metric_window_sel.loc[mask_thr, 'value'] >= df_metric_window_sel.loc[mask_thr, 'p95_threshold']

# 3) Identify consecutive anomaly streaks per (cmdb_id,kpi_name); streak requires consecutive timestamps incrementing by 60s.
anom_rows = df_metric_window_sel[df_metric_window_sel['is_anomaly']].copy()
# sort
anom_rows = anom_rows.sort_values(['cmdb_id','kpi_name','timestamp']).reset_index(drop=True)

# function to extract streaks within a group
def extract_streaks(g):
    if g.shape[0] == 0:
        return pd.DataFrame(columns=[
            'cmdb_id','kpi_name','streak_length_minutes','streak_start_ts','max_value_in_streak','p95_threshold'
        ])
    # compute time diff
    g = g.sort_values('timestamp').reset_index(drop=True)
    g['ts_diff'] = g['timestamp'].diff().fillna(60).astype(int)
    # new streak when diff != 60
    g['new_streak'] = (g['ts_diff'] != 60).astype(int)
    g['streak_id'] = g['new_streak'].cumsum()
    agg = (
        g.groupby('streak_id', as_index=False)
        .agg(
            cmdb_id=('cmdb_id','first'),
            kpi_name=('kpi_name','first'),
            streak_length_minutes=('timestamp','size'),
            streak_start_ts=('timestamp','min'),
            max_value_in_streak=('value','max'),
            p95_threshold=('p95_threshold','first')
        )
    )
    # keep only streaks length >= 10
    agg = agg[agg['streak_length_minutes'] >= 10]
    return agg

# apply per (cmdb_id,kpi_name)
streaks_list = []
grouped = anom_rows.groupby(['cmdb_id','kpi_name'], sort=False)
for (cmdb,kpi), grp in grouped:
    s = extract_streaks(grp)
    if not s.empty:
        streaks_list.append(s)

if streaks_list:
    streaks_all = pd.concat(streaks_list, ignore_index=True)
else:
    streaks_all = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','streak_length_minutes','streak_start_ts','max_value_in_streak','p95_threshold'
    ])

# keep at most top 200 in memory by streak_length desc then max_value
if not streaks_all.empty:
    streaks_all = streaks_all.sort_values(['streak_length_minutes','max_value_in_streak'], ascending=[False,False]).reset_index(drop=True)
    streaks_top200 = streaks_all.head(200).copy()
    # format earliest timestamp to UTC+8
    streaks_top200['earliest_anomaly_timestamp_UTC+8'] = pd.to_datetime(streaks_top200['streak_start_ts'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    streaks_top200 = streaks_top200[['cmdb_id','kpi_name','streak_length_minutes','earliest_anomaly_timestamp_UTC+8','max_value_in_streak','p95_threshold']]
    # final returned top-20
    streaks_top20 = streaks_top200.head(20).reset_index(drop=True)
else:
    streaks_top200 = streaks_all
    streaks_top20 = streaks_all

# 4) Aggregated per-component summary: number_of_kpis_with_long_streaks and earliest streak timestamp
if not streaks_all.empty:
    comp_agg = (
        streaks_all
        .groupby('cmdb_id', as_index=False)
        .agg(
            number_of_kpis_with_long_streaks=('kpi_name', lambda s: s.nunique()),
            earliest_streak_ts=('streak_start_ts','min')
        )
    )
    comp_agg['earliest_streak_timestamp_UTC+8'] = pd.to_datetime(comp_agg['earliest_streak_ts'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    comp_summary = comp_agg[['cmdb_id','number_of_kpis_with_long_streaks','earliest_streak_timestamp_UTC+8']].sort_values('number_of_kpis_with_long_streaks', ascending=False).reset_index(drop=True)
    # limit to top 20 (we only have 12 components anyway)
    comp_summary = comp_summary.head(20)
else:
    # empty summary for components: show zeros for selected components
    comp_summary = pd.DataFrame({
        'cmdb_id': top_components,
        'number_of_kpis_with_long_streaks': [0]*len(top_components),
        'earliest_streak_timestamp_UTC+8': [pd.NA]*len(top_components)
    })[['cmdb_id','number_of_kpis_with_long_streaks','earliest_streak_timestamp_UTC+8']].head(20)

# Final compact outputs (limit to at most 20 rows each)
streaks_top20, comp_summary
