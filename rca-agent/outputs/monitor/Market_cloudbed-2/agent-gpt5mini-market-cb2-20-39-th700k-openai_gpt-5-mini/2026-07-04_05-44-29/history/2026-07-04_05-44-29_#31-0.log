import pandas as pd
import pytz

# reuse variables if available
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# ensure incident window timestamps (UTC epoch seconds) available/recompute
try:
    start_ts, end_ts
except NameError:
    start_local = tz.localize(pd.Timestamp('2022-03-20 14:00:00'))
    end_local = tz.localize(pd.Timestamp('2022-03-20 14:29:59'))
    start_ts = int(start_local.tz_convert(pytz.UTC).timestamp())
    end_ts = int(end_local.tz_convert(pytz.UTC).timestamp())

# 1) global P95 per (cmdb_id, trace_name) using full series
p95_trace = (
    df_trace
    .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'p95_threshold'})
)

# 2) filter to incident window (inclusive)
df_trace_window = df_trace[(df_trace['timestamp'] >= start_ts) & (df_trace['timestamp'] <= end_ts)].copy()

# 3) mark anomalies: value >= P95 (merge thresholds)
df_trace_window = df_trace_window.merge(p95_trace, on=['cmdb_id', 'trace_name'], how='left')
df_trace_window['is_anomaly'] = False
mask_has_threshold = df_trace_window['p95_threshold'].notna()
df_trace_window.loc[mask_has_threshold, 'is_anomaly'] = df_trace_window.loc[mask_has_threshold, 'value'] >= df_trace_window.loc[mask_has_threshold, 'p95_threshold']

# 4) aggregate anomalies by (cmdb_id, trace_name) and return top-20 by anomaly_count
anoms_trace = df_trace_window[df_trace_window['is_anomaly']].copy()

if anoms_trace.shape[0] > 0:
    agg_trace = (
        anoms_trace
        .groupby(['cmdb_id', 'trace_name'], as_index=False)
        .agg(
            anomaly_count=('is_anomaly', 'size'),
            earliest_anomaly_timestamp=('timestamp', 'min'),
            max_value_in_window=('value', 'max'),
            p95_threshold=('p95_threshold', 'first')
        )
    )
    agg_trace['earliest_anomaly_timestamp_UTC+8'] = pd.to_datetime(agg_trace['earliest_anomaly_timestamp'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    agg_trace = agg_trace[['cmdb_id', 'trace_name', 'anomaly_count', 'earliest_anomaly_timestamp_UTC+8', 'max_value_in_window', 'p95_threshold']]
    agg_trace_top20 = agg_trace.sort_values('anomaly_count', ascending=False).head(20).reset_index(drop=True)
else:
    agg_trace_top20 = pd.DataFrame(columns=['cmdb_id', 'trace_name', 'anomaly_count', 'earliest_anomaly_timestamp_UTC+8', 'max_value_in_window', 'p95_threshold'])

# 5) top-20 components by total trace anomaly_count
if anoms_trace.shape[0] > 0:
    agg_comp = (
        anoms_trace
        .groupby('cmdb_id', as_index=False)
        .agg(
            total_anomaly_count=('is_anomaly', 'size'),
            number_of_trace_names_with_anomaly=('trace_name', lambda s: s.nunique()),
            earliest_anomaly_timestamp=('timestamp', 'min')
        )
    )
    agg_comp['earliest_anomaly_timestamp_UTC+8'] = pd.to_datetime(agg_comp['earliest_anomaly_timestamp'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    agg_comp = agg_comp[['cmdb_id', 'total_anomaly_count', 'number_of_trace_names_with_anomaly', 'earliest_anomaly_timestamp_UTC+8']]
    agg_comp_top20 = agg_comp.sort_values('total_anomaly_count', ascending=False).head(20).reset_index(drop=True)
else:
    agg_comp_top20 = pd.DataFrame(columns=['cmdb_id', 'total_anomaly_count', 'number_of_trace_names_with_anomaly', 'earliest_anomaly_timestamp_UTC+8'])

# display compact results (up to 20 rows each)
agg_trace_top20, agg_comp_top20
