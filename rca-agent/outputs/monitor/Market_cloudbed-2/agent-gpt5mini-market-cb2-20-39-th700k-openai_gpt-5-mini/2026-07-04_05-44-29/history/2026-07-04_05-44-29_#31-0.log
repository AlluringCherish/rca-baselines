import pandas as pd
import pytz
import numpy as np

# Reuse variables if present
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')
try:
    df_error
except NameError:
    df_error = pd.read_csv('error_logs.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Incident window bounds (UTC+8 -> epoch seconds UTC)
start_local = tz.localize(pd.Timestamp('2022-03-20 14:00:00'))
end_local = tz.localize(pd.Timestamp('2022-03-20 14:29:59'))
start_ts = int(start_local.tz_convert(pytz.UTC).timestamp())
end_ts = int(end_local.tz_convert(pytz.UTC).timestamp())

# Task 1: Trace breach scan for selected components
components = [
    "checkoutservice-0","checkoutservice-1","checkoutservice-2",
    "frontend-0","frontend-1","frontend-2","frontend2-0","shippingservice2-0"
]

# 1) global P95 per (cmdb_id, trace_name) computed on full trace.csv (before filtering)
p95_trace_all = (
    df_trace[df_trace['cmdb_id'].isin(components)]
    .groupby(['cmdb_id','trace_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value':'p95_threshold'})
)

# 2) filter trace rows to incident window and selected components
df_trace_window = df_trace[
    (df_trace['timestamp'] >= start_ts) &
    (df_trace['timestamp'] <= end_ts) &
    (df_trace['cmdb_id'].isin(components))
].copy()

# Merge thresholds in
df_trace_window = df_trace_window.merge(p95_trace_all, on=['cmdb_id','trace_name'], how='left')

# Only consider series where we have a p95 (drop NaN p95)
df_trace_window = df_trace_window[df_trace_window['p95_threshold'].notna()].copy()

# 3) mark breaches: strictly greater; for p95==0 mark if value>0 as 'p95_zero'
df_trace_window['gt_p95_strict'] = df_trace_window['value'] > df_trace_window['p95_threshold']
df_trace_window['p95_is_zero'] = (df_trace_window['p95_threshold'] == 0)
df_trace_window['p95_zero_breach'] = df_trace_window['p95_is_zero'] & (df_trace_window['value'] > 0)
# effective breach flag
df_trace_window['is_breach'] = df_trace_window['gt_p95_strict'] | df_trace_window['p95_zero_breach']

# Aggregate per series
grp = df_trace_window.groupby(['cmdb_id','trace_name'], sort=False)
agg_max = grp['value'].max().reset_index().rename(columns={'value':'max_value_in_window'})
agg_count = df_trace_window[df_trace_window['is_breach']].groupby(['cmdb_id','trace_name'], sort=False).size().reset_index(name='anomaly_count_in_window')
agg_earliest = df_trace_window[df_trace_window['is_breach']].groupby(['cmdb_id','trace_name'], sort=False)['timestamp'].min().reset_index().rename(columns={'timestamp':'earliest_ts_value_gt_p95'})

# Compose summary
trace_summary = p95_trace_all.merge(agg_max, on=['cmdb_id','trace_name'], how='left')
trace_summary = trace_summary.merge(agg_count, on=['cmdb_id','trace_name'], how='left')
trace_summary = trace_summary.merge(agg_earliest, on=['cmdb_id','trace_name'], how='left')

# Keep only series with anomaly_count_in_window > 0
trace_summary = trace_summary[trace_summary['anomaly_count_in_window'].fillna(0) > 0].copy()

# Compute breach ratio when p95>0; mark p95_zero otherwise
def compute_breach(row):
    p95 = row['p95_threshold']
    maxv = row['max_value_in_window']
    if pd.isna(maxv):
        return (np.nan, np.nan, False)
    if p95 == 0:
        if maxv > 0:
            return ('p95_zero', np.nan, True)
        else:
            return (np.nan, np.nan, False)
    else:
        denom = max(1e-9, float(p95))
        br = (float(maxv) - float(p95)) / denom
        return (round(float(br), 6), float(br), br >= 0)  # note boolean for any positive breach (we keep all breaches here)

trace_summary[['breach_display','breach_numeric','breach_positive_flag']] = trace_summary.apply(
    lambda r: pd.Series(compute_breach(r)), axis=1
)

# For ordering: p95_zero first, then by breach_numeric desc
trace_summary['p95_zero_flag'] = (trace_summary['breach_display'] == 'p95_zero').astype(int)
trace_summary['breach_sort_value'] = trace_summary['breach_numeric'].fillna(-9999.0)

trace_summary = trace_summary.sort_values(['p95_zero_flag','breach_sort_value'], ascending=[False, False])

# Format earliest timestamp
trace_summary['earliest_timestamp_value_gt_p95_UTC+8'] = pd.to_datetime(trace_summary['earliest_ts_value_gt_p95'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')
trace_summary.loc[trace_summary['earliest_ts_value_gt_p95'].isna(), 'earliest_timestamp_value_gt_p95_UTC+8'] = pd.NA

# Prepare final top-20 trace table with requested columns
trace_top20 = trace_summary[['cmdb_id','trace_name','p95_threshold','max_value_in_window','breach_display','earliest_timestamp_value_gt_p95_UTC+8','anomaly_count_in_window']].head(20).reset_index(drop=True)

