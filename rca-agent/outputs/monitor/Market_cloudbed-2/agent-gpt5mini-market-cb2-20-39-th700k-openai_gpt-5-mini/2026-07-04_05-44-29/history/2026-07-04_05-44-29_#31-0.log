import pandas as pd
import pytz
import numpy as np

# Reuse existing loaded DataFrames if present
try:
    df_log
except NameError:
    df_log = pd.read_csv('log.csv')
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
try:
    df_error
except NameError:
    df_error = pd.read_csv('error_logs.csv')

tz = pytz.timezone('Asia/Shanghai')

# Incident window bounds (UTC+8 -> epoch seconds UTC)
start_local = tz.localize(pd.Timestamp('2022-03-20 14:00:00'))
end_local = tz.localize(pd.Timestamp('2022-03-20 14:29:59'))
start_ts = int(start_local.tz_convert(pytz.UTC).timestamp())
end_ts = int(end_local.tz_convert(pytz.UTC).timestamp())

# ---------- Task 1: log.error_count per frontend pods ----------
frontends = ['frontend-0','frontend-1','frontend-2','frontend2-0']
df_log_window = df_log[
    (df_log['log_name'] == 'log.error_count') &
    (df_log['cmdb_id'].isin(frontends)) &
    (df_log['timestamp'] >= start_ts) &
    (df_log['timestamp'] <= end_ts)
].copy()

# Nonzero error_count rows
df_log_nonzero = df_log_window[df_log_window['value'] > 0].copy()

# Per-frontend earliest timestamp where value > 0 and count of nonzero rows
if not df_log_nonzero.empty:
    frontend_earliest = (
        df_log_nonzero.groupby('cmdb_id', as_index=False)['timestamp']
        .min()
        .rename(columns={'timestamp':'earliest_ts_nonzero'})
    )
    frontend_counts = (
        df_log_nonzero.groupby('cmdb_id', as_index=False).size().rename(columns={'size':'nonzero_count'})
    )
    log_frontend_summary = frontend_earliest.merge(frontend_counts, on='cmdb_id', how='outer')
else:
    # create empty summary with frontends
    log_frontend_summary = pd.DataFrame({'cmdb_id': frontends, 'earliest_ts_nonzero': [pd.NA]*len(frontends), 'nonzero_count':[0]*len(frontends)})

# Format earliest timestamp to UTC+8
def fmt_ts_col(df, col):
    df = df.copy()
    df[col+'_UTC+8'] = pd.to_datetime(df[col], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    df.loc[df[col].isna(), col+'_UTC+8'] = pd.NA
    return df

log_frontend_summary = fmt_ts_col(log_frontend_summary, 'earliest_ts_nonzero')
log_frontend_summary = log_frontend_summary[['cmdb_id','nonzero_count','earliest_ts_nonzero_UTC+8']]

# Small sample (up to 10 rows total) of nonzero error_count rows across frontends
if not df_log_nonzero.empty:
    sample_rows = df_log_nonzero.sort_values('timestamp').head(10).copy()
    sample_rows['timestamp_UTC+8'] = pd.to_datetime(sample_rows['timestamp'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    log_sample_df = sample_rows[['timestamp_UTC+8','cmdb_id','value']].reset_index(drop=True)
else:
    log_sample_df = pd.DataFrame(columns=['timestamp_UTC+8','cmdb_id','value'])

# ---------- Task 2: Checkoutservice-0 KPI confirmation ----------
checkout_kpis = [
    'container.node-5.container_memory_mapped_file',
    'container.node-5.container_fs_writes./dev/vda',
    'container.node-5.container_fs_writes_MB./dev/vda',
    'container.node-5.container_cpu_system_seconds'
]

# Compute global P95 per KPI using full metric.csv (rule: compute before filtering)
p95_checkout = (
    df_metric[(df_metric['cmdb_id']=='checkoutservice-0') & (df_metric['kpi_name'].isin(checkout_kpis))]
    .groupby('kpi_name', as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value':'p95_threshold'})
)

# Window rows for checkoutservice-0 and these KPIs
df_checkout_win = df_metric[
    (df_metric['cmdb_id']=='checkoutservice-0') &
    (df_metric['kpi_name'].isin(checkout_kpis)) &
    (df_metric['timestamp'] >= start_ts) &
    (df_metric['timestamp'] <= end_ts)
].copy()

# Merge p95
df_checkout_win = df_checkout_win.merge(p95_checkout, on='kpi_name', how='left')

# For each KPI compute earliest timestamp when value > p95 (strict), max_value_in_window, and max streak length of consecutive minutes > p95
rows = []
for kpi in checkout_kpis:
    p95_row = p95_checkout[p95_checkout['kpi_name']==kpi]
    if p95_row.empty:
        p95_val = np.nan
    else:
        p95_val = float(p95_row['p95_threshold'].iloc[0])
    dfk = df_checkout_win[df_checkout_win['kpi_name']==kpi].sort_values('timestamp').reset_index(drop=True)
    if dfk.empty:
        earliest_ts = pd.NA
        maxv = np.nan
        max_streak = 0
    else:
        maxv = float(dfk['value'].max())
        # earliest strict > p95
        mask_gt = dfk['value'] > p95_val
        if mask_gt.any():
            earliest_ts = int(dfk.loc[mask_gt,'timestamp'].min())
            # compute streaks: consider only rows where value > p95
            df_st = dfk[mask_gt].copy().reset_index(drop=True)
            if df_st.shape[0] == 0:
                max_streak = 0
            else:
                df_st['ts_diff'] = df_st['timestamp'].diff().fillna(60).astype(int)
                df_st['new_streak'] = (df_st['ts_diff'] != 60).astype(int)
                df_st['streak_id'] = df_st['new_streak'].cumsum()
                streaks = df_st.groupby('streak_id', as_index=False).size().rename(columns={'size':'length'})
                max_streak = int(streaks['length'].max())
        else:
            earliest_ts = pd.NA
            max_streak = 0
    rows.append({
        'kpi_name': kpi,
        'p95_threshold': p95_val,
        'earliest_timestamp_value_gt_p95_UTC+8': (pd.to_datetime(earliest_ts, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z') if (earliest_ts is not pd.NA and not pd.isna(earliest_ts)) else pd.NA),
        'max_value_in_window': maxv,
        'streak_length_minutes': max_streak
    })

checkout_kpi_table = pd.DataFrame(rows)

# ---------- Task 3: Cartservice-0 CPU throttling ----------
# find KPIs for cartservice-0 containing 'container_cpu_cfs_throttled'
cart_kpis_all = df_metric[(df_metric['cmdb_id']=='cartservice-0')]['kpi_name'].unique()
cart_kpis = [k for k in cart_kpis_all if 'container_cpu_cfs_throttled' in k]
# compute full-series P95 for these KPIs (per KPI)
if cart_kpis:
    p95_cart = (
        df_metric[(df_metric['cmdb_id']=='cartservice-0') & (df_metric['kpi_name'].isin(cart_kpis))]
        .groupby('kpi_name', as_index=False)['value'].quantile(0.95)
        .rename(columns={'value':'p95_threshold'})
    )
else:
    p95_cart = pd.DataFrame(columns=['kpi_name','p95_threshold'])

# window rows for cartservice-0 and these KPIs
df_cart_win = df_metric[
    (df_metric['cmdb_id']=='cartservice-0') &
    (df_metric['kpi_name'].isin(cart_kpis)) &
    (df_metric['timestamp'] >= start_ts) &
    (df_metric['timestamp'] <= end_ts)
].copy()

df_cart_win = df_cart_win.merge(p95_cart, on='kpi_name', how='left')

# For each KPI compute earliest timestamp when (value > p95) OR (p95==0 and value>0), max_value_in_window, anomaly_count_in_window
cart_rows = []
for kpi in cart_kpis:
    p95r = p95_cart[p95_cart['kpi_name']==kpi]
    if p95r.empty:
        p95v = np.nan
    else:
        p95v = float(p95r['p95_threshold'].iloc[0])
    dfk = df_cart_win[df_cart_win['kpi_name']==kpi].sort_values('timestamp').reset_index(drop=True)
    if dfk.empty:
        earliest_ts = pd.NA
        maxv = np.nan
        count_anom = 0
    else:
        maxv = float(dfk['value'].max())
        if p95v == 0:
            mask_anom = dfk['value'] > 0
        else:
            mask_anom = dfk['value'] > p95v
        if mask_anom.any():
            earliest_ts = int(dfk.loc[mask_anom,'timestamp'].min())
            count_anom = int(mask_anom.sum())
        else:
            earliest_ts = pd.NA
            count_anom = 0
    cart_rows.append({
        'kpi_name': kpi,
        'p95_threshold': p95v,
        'earliest_timestamp_value_gt_p95_UTC+8': (pd.to_datetime(earliest_ts, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z') if (earliest_ts is not pd.NA and not pd.isna(earliest_ts)) else pd.NA),
        'max_value_in_window': maxv,
        'anomaly_count_in_window': count_anom
    })

cart_cpu_table = pd.DataFrame(cart_rows).head(5)

# ---------- Final compact outputs ----------
# Limit overall rows: log_frontend_summary (<=4 rows), log_sample_df (<=10 rows), checkout_kpi_table (4 rows), cart_cpu_table (<=5 rows)
# Display as three result tables: log summary & sample, checkout KPIs, cart CPU throttling
log_frontend_summary, log_sample_df, checkout_kpi_table, cart_cpu_table
