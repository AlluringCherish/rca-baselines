# Reuse existing variables where possible
import pandas as pd
import pytz

try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')
try:
    df_log
except NameError:
    df_log = pd.read_csv('log.csv')
try:
    df_error
except NameError:
    df_error = pd.read_csv('error_logs.csv')

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Incident window in UTC+8 -> epoch seconds in UTC
start_local = tz.localize(pd.Timestamp('2022-03-20 14:00:00'))
end_local = tz.localize(pd.Timestamp('2022-03-20 14:29:59'))
start_ts = int(start_local.tz_convert(pytz.UTC).timestamp())
end_ts = int(end_local.tz_convert(pytz.UTC).timestamp())

# 1) metric: global P95 per (cmdb_id, kpi_name) BEFORE filtering
try:
    p95_df
except NameError:
    p95_df = (
        df_metric
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
        .quantile(0.95)
        .rename(columns={'value': 'p95_threshold'})
    )

# filter metric to window and mark anomalies value >= p95
df_metric_window = df_metric[(df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] <= end_ts)].copy()
df_metric_window = df_metric_window.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')
df_metric_window['is_anomaly'] = False
mask = df_metric_window['p95_threshold'].notna()
df_metric_window.loc[mask, 'is_anomaly'] = df_metric_window.loc[mask, 'value'] >= df_metric_window.loc[mask, 'p95_threshold']

metric_counts = (
    df_metric_window[df_metric_window['is_anomaly']]
    .groupby('timestamp', as_index=False).size()
    .rename(columns={'size': 'metric_anomaly_count'})
)

# 2) trace: global P95 per (cmdb_id, trace_name) BEFORE filtering
try:
    p95_trace
except NameError:
    p95_trace = (
        df_trace
        .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
        .quantile(0.95)
        .rename(columns={'value': 'p95_threshold'})
    )

# filter trace to window and mark anomalies value >= p95
df_trace_window = df_trace[(df_trace['timestamp'] >= start_ts) & (df_trace['timestamp'] <= end_ts)].copy()
df_trace_window = df_trace_window.merge(p95_trace, on=['cmdb_id', 'trace_name'], how='left')
df_trace_window['is_anomaly'] = False
mask_t = df_trace_window['p95_threshold'].notna()
df_trace_window.loc[mask_t, 'is_anomaly'] = df_trace_window.loc[mask_t, 'value'] >= df_trace_window.loc[mask_t, 'p95_threshold']

trace_counts = (
    df_trace_window[df_trace_window['is_anomaly']]
    .groupby('timestamp', as_index=False).size()
    .rename(columns={'size': 'trace_anomaly_count'})
)

# 3) error_logs: count rows per timestamp within window
df_error_window = df_error[(df_error['timestamp'] >= start_ts) & (df_error['timestamp'] <= end_ts)].copy()
error_counts = (
    df_error_window
    .groupby('timestamp', as_index=False).size()
    .rename(columns={'size': 'error_log_count'})
)

# 4) log.csv: sum log.error_count per timestamp within window (only log_name == 'log.error_count')
df_log_window = df_log[(df_log['timestamp'] >= start_ts) & (df_log['timestamp'] <= end_ts) & (df_log['log_name'] == 'log.error_count')].copy()
log_counts = (
    df_log_window
    .groupby('timestamp', as_index=False)['value']
    .sum()
    .rename(columns={'value': 'sum_log_error_count'})
)

# Build full per-minute timeline for the 30 minutes (timestamps at minute granularity)
minutes = [start_ts + i*60 for i in range(30)]
timeline = pd.DataFrame({'timestamp': minutes})

# Merge counts, fill missing with 0
timeline = timeline.merge(metric_counts, on='timestamp', how='left')
timeline = timeline.merge(trace_counts, on='timestamp', how='left')
timeline = timeline.merge(error_counts, on='timestamp', how='left')
timeline = timeline.merge(log_counts, on='timestamp', how='left')

timeline[['metric_anomaly_count','trace_anomaly_count','error_log_count']] = timeline[['metric_anomaly_count','trace_anomaly_count','error_log_count']].fillna(0).astype(int)
timeline['sum_log_error_count'] = timeline['sum_log_error_count'].fillna(0)

# combined score
timeline['combined_score'] = timeline['metric_anomaly_count'] + timeline['trace_anomaly_count'] + timeline['error_log_count'] + timeline['sum_log_error_count']

# formatted timestamp in UTC+8
timeline['timestamp_UTC+8'] = pd.to_datetime(timeline['timestamp'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')

# A) top-10 minutes by combined_score
top_minutes = timeline.sort_values('combined_score', ascending=False).head(10)[[
    'timestamp_UTC+8','metric_anomaly_count','trace_anomaly_count','error_log_count','sum_log_error_count','combined_score'
]].reset_index(drop=True)

# B) full per-minute timeline for 30 minutes, but limit to earliest 10 rows for compactness
timeline_display = timeline.sort_values('timestamp').head(10)[[
    'timestamp_UTC+8','metric_anomaly_count','trace_anomaly_count','error_log_count','sum_log_error_count'
]].reset_index(drop=True)

# Display compact results (two variables)
top_minutes, timeline_display
