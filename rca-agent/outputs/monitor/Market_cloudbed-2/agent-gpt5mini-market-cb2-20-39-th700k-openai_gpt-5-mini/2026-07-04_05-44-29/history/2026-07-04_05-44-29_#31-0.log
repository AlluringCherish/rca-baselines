import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# reuse df_metric if already loaded; otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

# 1) Compute global P95 per (cmdb_id, kpi_name) using the full series (before any filtering)
p95_df = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'p95_threshold'})
)

# 2) Filter metric rows to the incident window 2022-03-20 14:00:00 — 2022-03-20 14:29:59 in UTC+8
start_local = tz.localize(pd.Timestamp('2022-03-20 14:00:00'))
end_local = tz.localize(pd.Timestamp('2022-03-20 14:29:59'))
# convert to UTC epoch seconds
start_ts = int(start_local.tz_convert(pytz.UTC).timestamp())
end_ts = int(end_local.tz_convert(pytz.UTC).timestamp())

df_window = df_metric[(df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] <= end_ts)].copy()

# 3) Mark anomalies when value >= P95 (merge thresholds in)
df_window = df_window.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')
df_window['is_anomaly'] = False
# Only mark anomaly if p95_threshold is finite (not NaN)
mask_has_threshold = df_window['p95_threshold'].notna()
df_window.loc[mask_has_threshold, 'is_anomaly'] = df_window.loc[mask_has_threshold, 'value'] >= df_window.loc[mask_has_threshold, 'p95_threshold']

# 4) Aggregate anomalies by (cmdb_id, kpi_name) and produce top-20 by anomaly count
anomalies = df_window[df_window['is_anomaly']].copy()

if anomalies.shape[0] > 0:
    agg_kpi = (
        anomalies
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)
        .agg(
            anomaly_count=('is_anomaly', 'size'),
            earliest_anomaly_timestamp=('timestamp', 'min'),
            max_value_in_window=('value', 'max'),
            p95_threshold=('p95_threshold', 'first')
        )
    )
    # format earliest timestamp to UTC+8 string
    agg_kpi['earliest_anomaly_timestamp_UTC+8'] = pd.to_datetime(agg_kpi['earliest_anomaly_timestamp'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    # select and order columns
    agg_kpi = agg_kpi[['cmdb_id', 'kpi_name', 'anomaly_count', 'earliest_anomaly_timestamp_UTC+8', 'max_value_in_window', 'p95_threshold']]
    agg_kpi_top20 = agg_kpi.sort_values('anomaly_count', ascending=False).head(20).reset_index(drop=True)
else:
    agg_kpi_top20 = pd.DataFrame(columns=['cmdb_id', 'kpi_name', 'anomaly_count', 'earliest_anomaly_timestamp_UTC+8', 'max_value_in_window', 'p95_threshold'])

# Also produce top-20 cmdb_id by total anomaly_count summed over KPIs
if anomalies.shape[0] > 0:
    agg_comp = (
        anomalies
        .groupby(['cmdb_id'], as_index=False)
        .agg(
            total_anomaly_count=('is_anomaly', 'size'),
            number_of_kpis_with_anomaly=('kpi_name', lambda s: s.nunique()),
            earliest_anomaly_timestamp=('timestamp', 'min')
        )
    )
    agg_comp['earliest_anomaly_timestamp_UTC+8'] = pd.to_datetime(agg_comp['earliest_anomaly_timestamp'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    agg_comp = agg_comp[['cmdb_id', 'total_anomaly_count', 'number_of_kpis_with_anomaly', 'earliest_anomaly_timestamp_UTC+8']]
    agg_comp_top20 = agg_comp.sort_values('total_anomaly_count', ascending=False).head(20).reset_index(drop=True)
else:
    agg_comp_top20 = pd.DataFrame(columns=['cmdb_id', 'total_anomaly_count', 'number_of_kpis_with_anomaly', 'earliest_anomaly_timestamp_UTC+8'])

# Display compact results (up to 20 rows each)
agg_kpi_top20, agg_comp_top20
