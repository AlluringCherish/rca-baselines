import pandas as pd
import pytz
import numpy as np

# reuse existing variables where possible
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Incident window (UTC+8 to epoch seconds UTC)
start_local = tz.localize(pd.Timestamp('2022-03-20 14:00:00'))
end_local = tz.localize(pd.Timestamp('2022-03-20 14:29:59'))
start_ts = int(start_local.tz_convert(pytz.UTC).timestamp())
end_ts = int(end_local.tz_convert(pytz.UTC).timestamp())

# Top-20 components as specified
top_components = [
    "adservice","adservice2","frontend2-0","frontend-0","frontend-1","frontend-2",
    "productcatalogservice-2","productcatalogservice-0","productcatalogservice-1",
    "cartservice-1","productcatalogservice2-0","adservice2-0","cartservice-0","cartservice2-0",
    "adservice-0","adservice-1","checkoutservice-0","emailservice-0","emailservice-1","emailservice-2"
]

# 1) Compute global P95 per (cmdb_id, kpi_name) using full metric.csv for selected components
p95_selected = (
    df_metric[df_metric['cmdb_id'].isin(top_components)]
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'p95_threshold'})
)

# 2) Filter metric rows to the incident window and selected components
df_win = df_metric[
    (df_metric['timestamp'] >= start_ts) &
    (df_metric['timestamp'] <= end_ts) &
    (df_metric['cmdb_id'].isin(top_components))
].copy()

# Merge p95 thresholds into window rows
df_win = df_win.merge(p95_selected, on=['cmdb_id','kpi_name'], how='left')

# Drop series without p95 (if any)
df_win = df_win[df_win['p95_threshold'].notna()].copy()

# 2 continued) For each series compute max_value_in_window and earliest timestamp when value > p95 (strict >)
grp = df_win.groupby(['cmdb_id','kpi_name'], sort=False)

max_vals = grp['value'].max().reset_index().rename(columns={'value':'max_value_in_window'})
# earliest timestamp where value > p95
# create boolean column
df_win['gt_p95'] = df_win['value'] > df_win['p95_threshold']

earliest_gt = (
    df_win[df_win['gt_p95']]
    .groupby(['cmdb_id','kpi_name'], sort=False)['timestamp']
    .min()
    .reset_index()
    .rename(columns={'timestamp':'earliest_ts_gt_p95'})
)

# combine results with p95
series_summary = p95_selected.merge(max_vals, on=['cmdb_id','kpi_name'], how='left')
series_summary = series_summary.merge(earliest_gt, on=['cmdb_id','kpi_name'], how='left')

# 3) compute breach_ratio or tag p95_zero
def compute_breach(row):
    p95 = row['p95_threshold']
    maxv = row['max_value_in_window']
    if pd.isna(maxv):
        return np.nan, False  # no data in window
    if p95 == 0:
        if maxv > 0:
            return 'p95_zero', True
        else:
            return np.nan, False
    else:
        # p95 > 0
        denom = max(1e-9, float(p95))
        br = (float(maxv) - float(p95)) / denom
        return float(br), (br >= 0.5)

series_summary[['breach_ratio_raw','meets_criteria']] = series_summary.apply(
    lambda r: pd.Series(compute_breach(r)), axis=1
)

# 4) Keep only series satisfying either condition:
# - p95 == 0 and max_value_in_window > 0 (we marked as 'p95_zero' and meets_criteria True)
# - breach_ratio >= 0.5 (meets_criteria True)
filtered = series_summary[series_summary['meets_criteria'] == True].copy()

if not filtered.empty:
    # Prepare display fields
    # Format earliest timestamp to UTC+8 string
    filtered['earliest_timestamp_value_gt_p95_UTC+8'] = pd.to_datetime(
        filtered['earliest_ts_gt_p95'], unit='s', utc=True
    ).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    # For rows where earliest_ts is NaN (shouldn't happen if meets_criteria True), leave as NA
    filtered.loc[filtered['earliest_ts_gt_p95'].isna(), 'earliest_timestamp_value_gt_p95_UTC+8'] = pd.NA

    # Create a display column for breach_ratio/tag: 'p95_zero' or numeric rounded
    def format_breach(x):
        if x == 'p95_zero':
            return 'p95_zero'
        try:
            return round(float(x), 3)
        except:
            return pd.NA

    filtered['breach'] = filtered['breach_ratio_raw'].apply(format_breach)

    # Order: p95_zero first, then by numeric breach_ratio desc
    def sort_key(row):
        if row['breach'] == 'p95_zero':
            return (0, 0.0)
        else:
            # convert to float safe
            try:
                return (1, float(row['breach']))
            except:
                return (1, 0.0)

    filtered['_sort_tuple'] = filtered.apply(sort_key, axis=1)
    filtered = filtered.sort_values('_sort_tuple', ascending=[True, False]).drop(columns=['_sort_tuple'])

    # Select and limit top-20 for return
    top_series_table = filtered[['cmdb_id','kpi_name','p95_threshold','max_value_in_window','breach','earliest_timestamp_value_gt_p95_UTC+8']].head(20).reset_index(drop=True)
else:
    top_series_table = pd.DataFrame(columns=['cmdb_id','kpi_name','p95_threshold','max_value_in_window','breach','earliest_timestamp_value_gt_p95_UTC+8'])

# Component-level summary: for each component count number_of_kpis_with_large_breach and earliest breach timestamp among its KPIs
if not filtered.empty:
    comp_agg = (
        filtered
        .groupby('cmdb_id', as_index=False)
        .agg(
            number_of_kpis_with_large_breach = ('kpi_name', lambda s: s.nunique()),
            earliest_breach_ts = ('earliest_ts_gt_p95', 'min')
        )
    )
    comp_agg['earliest_breach_timestamp_UTC+8'] = pd.to_datetime(comp_agg['earliest_breach_ts'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    comp_summary = comp_agg[['cmdb_id','number_of_kpis_with_large_breach','earliest_breach_timestamp_UTC+8']].sort_values('number_of_kpis_with_large_breach', ascending=False).head(20).reset_index(drop=True)
else:
    # empty summary: return components with zeros
    comp_summary = pd.DataFrame({
        'cmdb_id': top_components,
        'number_of_kpis_with_large_breach': [0]*len(top_components),
        'earliest_breach_timestamp_UTC+8': [pd.NA]*len(top_components)
    })[['cmdb_id','number_of_kpis_with_large_breach','earliest_breach_timestamp_UTC+8']].head(20)

# Display compact results (two variables)
top_series_table, comp_summary
