import pandas as pd
import numpy as np

# Reuse df_metric from kernel state
targets = [
    "frontend-0", "frontend-1", "frontend-2", "frontend2-0",
    "checkoutservice-0", "checkoutservice-1", "checkoutservice-2",
    "productcatalogservice-0", "productcatalogservice-1", "productcatalogservice-2"
]

# Ensure value column is numeric
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

result_dict = {}
# Aggregate per target component
for cm in targets:
    subset = df_metric[df_metric['cmdb_id'] == cm]
    if subset.empty:
        result_dict[cm] = []
        continue
    # basic aggregations
    agg_basic = subset.groupby('kpi_name')['value'].agg(count='count', mean='mean', max='max')
    # quantiles
    q = subset.groupby('kpi_name')['value'].quantile([0.95, 0.05]).unstack(level=1)
    # q columns are [0.95, 0.05] or [0.05,0.95], ensure names
    # Normalize column names
    q = q.rename(columns={0.95: 'p95', 0.05: 'p5'}) if 0.95 in q.columns else q.rename(columns={0.05: 'p5', 0.95: 'p95'})
    # join
    agg = agg_basic.join(q)
    # Select and order columns: kpi_name, count, p95, p5, mean, max
    agg = agg.reset_index()[['kpi_name', 'count', 'p95', 'p5', 'mean', 'max']]
    # Sort by count desc then kpi_name for stability, limit to 50
    agg = agg.sort_values(['count', 'kpi_name'], ascending=[False, True]).head(50)
    # Round numeric columns for compactness
    agg[['p95','p5','mean','max']] = agg[['p95','p5','mean','max']].round(6)
    # Ensure types are native python where reasonable
    records = agg.to_dict(orient='records')
    # Convert numpy types to native Python types for cleanliness
    def _normalize(rec):
        return {
            'kpi_name': rec['kpi_name'],
            'count': int(rec['count']),
            'p95': None if pd.isna(rec['p95']) else float(rec['p95']),
            'p5': None if pd.isna(rec['p5']) else float(rec['p5']),
            'mean': None if pd.isna(rec['mean']) else float(rec['mean']),
            'max': None if pd.isna(rec['max']) else float(rec['max']),
        }
    result_dict[cm] = [_normalize(r) for r in records]

# Build a compact summary DataFrame for display: number of kpis included per component and total rows
summary_rows = []
for cm in targets:
    total_rows = int(df_metric[df_metric['cmdb_id']==cm].shape[0])
    kpi_count = len(result_dict[cm])
    # track top kpi by count if exists
    top_kpi = result_dict[cm][0]['kpi_name'] if kpi_count>0 else None
    summary_rows.append({'cmdb_id': cm, 'total_rows': total_rows, 'kpi_entries_included': kpi_count, 'top_kpi_sample': top_kpi})

summary_df = pd.DataFrame(summary_rows)

# Display compact summary; full mapping is available in result_dict variable.
summary_df, result_dict
