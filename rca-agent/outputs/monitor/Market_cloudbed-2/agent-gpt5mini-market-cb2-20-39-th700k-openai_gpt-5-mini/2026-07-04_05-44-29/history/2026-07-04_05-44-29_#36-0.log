import re
import pandas as pd

# Reuse frontend_logs_df from kernel (assumed available) and ensure dt exists
# If dt not present, create from timestamp using Asia/Shanghai timezone
import pytz
tz = pytz.timezone('Asia/Shanghai')
if 'dt' not in frontend_logs_df.columns:
    frontend_logs_df['dt'] = pd.to_datetime(frontend_logs_df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Top 20 unique full message strings with their counts
top20_messages = (
    frontend_logs_df['message']
    .value_counts()
    .head(20)
    .rename_axis('message')
    .reset_index(name='count')
)

# 2) Extract tokens from each of the top-20 messages
url_re = re.compile(r'(https?://\S+)', re.IGNORECASE)
http_code_re = re.compile(r'\b(\d{3})\b')
service_re = re.compile(r'\b\w*service\w*\b', re.IGNORECASE)

def extract_tokens(msg):
    if not isinstance(msg, str):
        return [], [], []
    urls = url_re.findall(msg) or []
    codes = http_code_re.findall(msg) or []
    services = service_re.findall(msg) or []
    # Normalize/unique
    urls = list(dict.fromkeys(urls))
    codes = list(dict.fromkeys(codes))
    services = list(dict.fromkeys([s for s in services]))
    return urls, codes, services

# Apply extraction to top20 messages
extracted_rows = []
for _, row in top20_messages.iterrows():
    msg = row['message']
    urls, codes, services = extract_tokens(msg)
    extracted_rows.append({
        'message': msg,
        'count': row['count'],
        'extracted_urls': urls,
        'extracted_http_codes': codes,
        'extracted_service_names': services
    })

top20_extracted = pd.DataFrame(extracted_rows)[
    ['message', 'count', 'extracted_urls', 'extracted_http_codes', 'extracted_service_names']
]

# 3) If any of the top-20 messages contain no extracted tokens, return up to 20 raw frontend log rows (earliest)
no_tokens_mask = top20_extracted.apply(
    lambda r: (len(r['extracted_urls'])==0) and (len(r['extracted_http_codes'])==0) and (len(r['extracted_service_names'])==0),
    axis=1
)
if no_tokens_mask.any():
    frontend_raw_sample = frontend_logs_df[['timestamp', 'cmdb_id', 'message']].sort_values('dt').head(20)
else:
    frontend_raw_sample = frontend_logs_df.iloc[0:0][['timestamp', 'cmdb_id', 'message']]  # empty with same columns

# Return compact results (DataFrames)
top20_extracted, frontend_raw_sample
