    else:
        anom_agg['earliest_anomaly_timestamp_in_window'] = pd.NA
    series_summary = thresholds[['cmdb_id','kpi_name','P95','P5','total_points_full_series']].merge(
        points_in_window, on=['cmdb_id','kpi_name'], how='left'
