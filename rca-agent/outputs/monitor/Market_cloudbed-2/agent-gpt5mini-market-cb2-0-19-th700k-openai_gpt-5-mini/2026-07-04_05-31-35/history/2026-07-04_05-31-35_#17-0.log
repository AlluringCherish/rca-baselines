import pandas as pd
import numpy as np
import pytz

# Reuse existing kernel variables: frontend_error_timeseries, trace_df, tz
# Ensure they exist
try:
    frontend_error_timeseries
    trace_df
    tz
except NameError as e:
    raise RuntimeError("Expected frontend_error_timeseries, trace_df, and tz in kernel state.") from e

# 1) Identify top two minute timestamps with highest total_error_count (tie -> earliest)
# Parse timestamp strings back to epoch seconds (Asia/Shanghai)
ts_clean = frontend_error_timeseries['timestamp'].str.replace(' CST', '', regex=False)
ts_dt = pd.to_datetime(ts_clean, format='%Y-%m-%d %H:%M:%S').dt.tz_localize(tz)
frontend_error_timeseries = frontend_error_timeseries.copy()
frontend_error_timeseries['ts_epoch'] = (ts_dt.view('int64') // 10**9).astype(int)

# Sort by total_error_count desc, then ts_epoch asc to break ties by earliest
sorted_peaks = frontend_error_timeseries.sort_values(['total_error_count','ts_epoch'], ascending=[False, True]).reset_index(drop=True)

# Select top two (handle case with fewer rows)
top_two = sorted_peaks.head(2).copy()

# Build peaks_table with timestamp string (original), epoch, and per-pod counts
peaks_table = top_two[['timestamp','ts_epoch','frontend-0','frontend-1','frontend-2','total_error_count']].reset_index(drop=True)

# 2) Compute global P95 for every (cmdb_id, trace_name) using full trace_df
trace_p95 = trace_df.dropna(subset=['value']).groupby(['cmdb_id','trace_name'], as_index=False)['value'].quantile(0.95)
trace_p95 = trace_p95.rename(columns={'value':'global_p95'})

# 2b) Filter trace_df to rows where timestamp equals either of the two selected peak epochs and cmdb_id in frontends
frontends = ['frontend-0','frontend-1','frontend-2']
peak_epochs = peaks_table['ts_epoch'].tolist()

trace_peak_rows = trace_df[
    trace_df['timestamp'].isin(peak_epochs) &
    trace_df['cmdb_id'].isin(frontends)
].copy()

# Merge global_p95
trace_peak_rows = trace_peak_rows.merge(trace_p95, on=['cmdb_id','trace_name'], how='left')

# Compute exceed condition and exceed_ratio
trace_peak_rows['is_anomaly'] = trace_peak_rows['global_p95'].notna() & (trace_peak_rows['value'] > trace_peak_rows['global_p95'])
# Compute exceed_ratio where global_p95>0 else NaN
def calc_ratio(row):
    p = row['global_p95']
    v = row['value']
    if pd.isna(p) or p == 0:
        return np.nan
    return (v - p) / p

trace_peak_rows['exceed_ratio'] = trace_peak_rows.apply(calc_ratio, axis=1)

# Keep only anomalies (value > global_p95)
frontend_peak_trace_anomalies = trace_peak_rows[trace_peak_rows['is_anomaly']].copy()

# Add readable timestamp column
frontend_peak_trace_anomalies['timestamp_readable'] = pd.to_datetime(frontend_peak_trace_anomalies['timestamp'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')

# Select and order columns, sort by exceed_ratio desc, limit to 50 rows
frontend_peak_trace_anomalies = frontend_peak_trace_anomalies[[
    'timestamp_readable','cmdb_id','trace_name','value','global_p95','exceed_ratio'
]].sort_values('exceed_ratio', ascending=False).head(50).reset_index(drop=True)

# 3) For each peak timestamp produce one-line summary: timestamp, total number of trace-anomaly rows (frontends), top 3 trace_name by exceed_ratio
summaries = []
for epoch in peak_epochs:
    ts_read = pd.to_datetime(int(epoch), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
    subset = trace_peak_rows[(trace_peak_rows['timestamp']==epoch) & (trace_peak_rows['cmdb_id'].isin(frontends)) & (trace_peak_rows['is_anomaly'])]
    total_anoms = int(subset.shape[0])
    top3 = subset.sort_values('exceed_ratio', ascending=False).head(3)[['trace_name','exceed_ratio']]
    top3_list = [f"{r.trace_name}({r.exceed_ratio:.4f})" for _, r in top3.iterrows()]
    summaries.append({'timestamp': ts_read, 'total_trace_anomalies': total_anoms, 'top3_by_exceed_ratio': top3_list})

peak_summaries_df = pd.DataFrame(summaries)

# Final compact outputs stored in kernel variables:
# peaks_table (two timestamps with per-pod counts), frontend_peak_trace_anomalies (trace anomalies table), peak_summaries_df (one-line summaries)
peaks_table, frontend_peak_trace_anomalies, peak_summaries_df
