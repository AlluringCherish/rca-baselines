import pandas as pd
import pytz

# Load CSVs into DataFrames (store in kernel variables as requested)
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")
log_df = pd.read_csv("log.csv")
error_df = pd.read_csv("error_logs.csv")

# Helper: convert unix-second timestamps to Asia/Shanghai timezone strings
tz = pytz.timezone('Asia/Shanghai')
def ts_min_max_to_str(s):
    if s.empty:
        return (None, None)
    mins = pd.to_datetime(s.min(), unit='s', utc=True).dt.tz_convert(tz) if not hasattr(s.min(), 'astype') else pd.to_datetime(s.min(), unit='s', utc=True).tz_convert(tz)
    maxs = pd.to_datetime(s.max(), unit='s', utc=True).dt.tz_convert(tz) if not hasattr(s.max(), 'astype') else pd.to_datetime(s.max(), unit='s', utc=True).tz_convert(tz)
    # When single scalar returned by pandas operations, ensure formatting
    if hasattr(mins, 'strftime'):
        min_str = mins.strftime('%Y-%m-%d %H:%M:%S %Z')
    else:
        min_str = mins.dt.strftime('%Y-%m-%d %H:%M:%S %Z').iloc[0]
    if hasattr(maxs, 'strftime'):
        max_str = maxs.strftime('%Y-%m-%d %H:%M:%S %Z')
    else:
        max_str = maxs.dt.strftime('%Y-%m-%d %H:%M:%S %Z').iloc[0]
    return min_str, max_str

# Prepare metric summary
metric_total_rows = len(metric_df)
metric_min_ts, metric_max_ts = ts_min_max_to_str(metric_df['timestamp'])
metric_unique_cmdb = sorted(metric_df['cmdb_id'].dropna().unique())
metric_unique_kpi = sorted(metric_df['kpi_name'].dropna().unique())
metric_summary = pd.DataFrame([{
    'file': 'metric.csv',
    'total_rows': metric_total_rows,
    'min_timestamp_ASIA/SHANGHAI': metric_min_ts,
    'max_timestamp_ASIA/SHANGHAI': metric_max_ts,
