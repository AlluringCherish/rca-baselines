    start_local = tz.localize(datetime.strptime("2022-03-20 15:30:00", "%Y-%m-%d %H:%M:%S"))
    end_local = tz.localize(datetime.strptime("2022-03-20 16:00:00", "%Y-%m-%d %H:%M:%S"))
    start_ts = int(start_local.astimezone(pytz.utc).timestamp())
    end_ts = int(end_local.astimezone(pytz.utc).timestamp())

candidates = ['frontend-0','frontend-1','frontend-2','frontend2-0','checkoutservice2-0','checkoutservice-1']

# 1) Compute global P95 per (cmdb_id, kpi_name) using full metric_df
metric_p95 = metric_df.dropna(subset=['value']).groupby(['cmdb_id','kpi_name'], as_index=False)['value'].quantile(0.95)
metric_p95 = metric_p95.rename(columns={'value':'global_p95'})

# 2) Filter metric points to the incident window and to candidate cmdb_ids
metric_window = metric_df[
    (metric_df['cmdb_id'].isin(candidates)) &
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] < end_ts)
].copy()

# 3) Merge global_p95 into windowed data
metric_win = metric_window.merge(metric_p95, on=['cmdb_id','kpi_name'], how='left')

# Compute max_value_in_window per (cmdb_id,kpi_name) from the filtered window (even if no anomalies)
max_in_window = metric_win.groupby(['cmdb_id','kpi_name'], as_index=False)['value'].max().rename(columns={'value':'max_value_in_window'})

# Identify anomaly points where value > global_p95 (and global_p95 not null)
metric_win['is_anomaly'] = metric_win['global_p95'].notna() & (metric_win['value'] > metric_win['global_p95'])

# Aggregate anomaly_count and earliest_anomaly_timestamp per (cmdb_id,kpi_name)
anomaly_agg = metric_win[metric_win['is_anomaly']].groupby(['cmdb_id','kpi_name'], as_index=False).agg(
    anomaly_count=('is_anomaly','sum'),
    earliest_anomaly_ts=('timestamp','min')
)

# Merge aggregates with max_in_window and global_p95
kpi_summary = anomaly_agg.merge(max_in_window, on=['cmdb_id','kpi_name'], how='left')
kpi_summary = kpi_summary.merge(metric_p95, on=['cmdb_id','kpi_name'], how='left')

# Compute severity_ratio
def compute_sev(row):
    p95 = row['global_p95']
    mv = row['max_value_in_window']
    if pd.isna(p95) or p95 == 0:
        return None
    return (mv - p95) / p95

kpi_summary['severity_ratio'] = kpi_summary.apply(compute_sev, axis=1)

# Format earliest_anomaly_timestamp to Asia/Shanghai readable string
def fmt_ts(x):
    if pd.isna(x):
        return None
    return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

kpi_summary['earliest_anomaly_timestamp'] = kpi_summary['earliest_anomaly_ts'].apply(fmt_ts)

# Select and reorder columns
kpi_summary = kpi_summary[[
    'cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp',
    'max_value_in_window','global_p95','severity_ratio'
]]

# 4) For each cmdb_id, get top 10 KPIs by anomaly_count (only KPIs with anomaly_count>0 are present)
top_kpis_list = []
for cid in candidates:
    sub = kpi_summary[kpi_summary['cmdb_id']==cid].sort_values('anomaly_count', ascending=False).head(10)
    if not sub.empty:
        top_kpis_list.append(sub)
if top_kpis_list:
    kpi_summary_top = pd.concat(top_kpis_list, ignore_index=True)
else:
    kpi_summary_top = pd.DataFrame(columns=kpi_summary.columns)

# Enforce overall cap of 60 rows
kpi_summary_top = kpi_summary_top.head(60)

# 5) For each cmdb_id, pick the single KPI with highest anomaly_count and return up to 20 anomaly-point rows (timestamp, value)
top_kpi_per_cmdb = kpi_summary_top.sort_values(['cmdb_id','anomaly_count'], ascending=[True,False]).groupby('cmdb_id', as_index=False).first()

anomaly_points_frames = []
for _, r in top_kpi_per_cmdb.iterrows():
    cid = r['cmdb_id']
    kpi = r['kpi_name']
    # Select anomaly points from metric_win (which has is_anomaly flag) for this pair, sorted by timestamp
    pts = metric_win[(metric_win['cmdb_id']==cid) & (metric_win['kpi_name']==kpi) & (metric_win['is_anomaly'])][['timestamp','value']].sort_values('timestamp').head(20).copy()
    if pts.empty:
        continue
    # format timestamp to Asia/Shanghai
    pts['timestamp'] = pts['timestamp'].apply(lambda t: pd.to_datetime(int(t), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z'))
    pts.insert(0,'cmdb_id',cid)
    pts.insert(1,'kpi_name',kpi)
    anomaly_points_frames.append(pts)

if anomaly_points_frames:
    top_kpi_anomaly_points = pd.concat(anomaly_points_frames, ignore_index=True)
else:
    top_kpi_anomaly_points = pd.DataFrame(columns=['cmdb_id','kpi_name','timestamp','value'])

# Keep final outputs compact: kpi_summary_top (<=60 rows) and top_kpi_anomaly_points (<=20 rows per top KPI)
kpi_summary_top, top_kpi_anomaly_points
