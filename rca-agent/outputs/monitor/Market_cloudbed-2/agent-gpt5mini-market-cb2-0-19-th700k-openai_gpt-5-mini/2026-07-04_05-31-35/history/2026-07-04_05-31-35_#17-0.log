import pandas as pd
import pytz
from datetime import datetime

# Reuse existing kernel variables if present
try:
    error_df
    tz
    start_ts
    end_ts
except NameError:
    tz = pytz.timezone('Asia/Shanghai')
    start_local = tz.localize(datetime.strptime("2022-03-20 15:30:00", "%Y-%m-%d %H:%M:%S"))
    end_local = tz.localize(datetime.strptime("2022-03-20 16:00:00", "%Y-%m-%d %H:%M:%S"))
    start_ts = int(start_local.astimezone(pytz.utc).timestamp())
    end_ts = int(end_local.astimezone(pytz.utc).timestamp())

frontends = ['frontend-0','frontend-1','frontend-2']

# 1) Filter error_df to the incident window and frontend pods
err_fw = error_df[
    (error_df['cmdb_id'].isin(frontends)) &
    (error_df['timestamp'] >= start_ts) &
    (error_df['timestamp'] < end_ts)
].copy()

# Ensure message is string
err_fw['message'] = err_fw['message'].astype(str)

# 2) Pattern extraction (first 120 chars) and aggregation
err_fw['pattern'] = err_fw['message'].str.slice(0,120)

# Aggregate counts and min/max timestamps per pattern
pattern_stats = err_fw.groupby('pattern', as_index=False).agg(
    total_count=('message','count'),
    earliest_error_ts=('timestamp','min'),
    latest_error_ts=('timestamp','max')
)

# Get up to 5 sample full messages per pattern (first 5 occurrences)
samples = err_fw.groupby('pattern', sort=False).apply(lambda g: g['message'].head(5).tolist()).reset_index()
samples.columns = ['pattern','sample_messages']

# Merge stats and samples
error_patterns_df = pattern_stats.merge(samples, on='pattern', how='left')

# Format timestamps to Asia/Shanghai human-readable strings
def fmt_ts(e):
    return pd.to_datetime(int(e), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

error_patterns_df['earliest_error_timestamp'] = error_patterns_df['earliest_error_ts'].apply(fmt_ts)
error_patterns_df['latest_error_timestamp'] = error_patterns_df['latest_error_ts'].apply(fmt_ts)

# Keep requested columns and sort top 10 by total_count
error_patterns_df = error_patterns_df[[
    'pattern','total_count','earliest_error_timestamp','latest_error_timestamp','sample_messages'
]].sort_values('total_count', ascending=False).head(10).rename(columns={'pattern':'pattern_text'})

# 3) Per-minute error count series for the three frontends
# Build full list of minute timestamps (epoch seconds) within the incident window (inclusive start, exclusive end)
minute_epochs = list(range(start_ts, end_ts, 60))

# Count occurrences per timestamp and cmdb_id
counts_long = err_fw.groupby(['timestamp','cmdb_id'], as_index=False).size().rename(columns={'size':'count'})

# Pivot to have per-pod columns
pivot = counts_long.pivot(index='timestamp', columns='cmdb_id', values='count')

# Reindex to include all minutes in window, fill missing with 0
pivot = pivot.reindex(minute_epochs, fill_value=0)

# Ensure columns for all three frontends exist
for f in frontends:
    if f not in pivot.columns:
        pivot[f] = 0

# Reset index to have timestamp column
frontend_error_timeseries = pivot.reset_index().rename(columns={'index':'timestamp'})

# Compute total_error_count across the three frontends
frontend_error_timeseries['total_error_count'] = frontend_error_timeseries[frontends].sum(axis=1)

# Format timestamp to Asia/Shanghai human-readable string
frontend_error_timeseries['timestamp'] = frontend_error_timeseries['timestamp'].apply(lambda e: pd.to_datetime(int(e), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z'))

# Reorder columns: timestamp, total_error_count, per-pod counts
frontend_error_timeseries = frontend_error_timeseries[['timestamp','total_error_count'] + frontends]

# Limit to up to 30 rows (the window should be 30 minutes)
frontend_error_timeseries = frontend_error_timeseries.head(30)

# Final compact outputs (stored in kernel variables as requested)
error_patterns_df, frontend_error_timeseries
