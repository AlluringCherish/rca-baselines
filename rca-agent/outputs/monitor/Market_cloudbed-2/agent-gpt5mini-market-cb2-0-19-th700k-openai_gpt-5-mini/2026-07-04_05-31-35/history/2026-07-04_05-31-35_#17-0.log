import pandas as pd
import pytz
import numpy as np

# Reuse kernel variables: top_kpi_per_cmdb, top_kpi_anomaly_points
# Create local copies to avoid modifying original kernel variables
top_kpi_meta = top_kpi_per_cmdb.copy()
anomaly_pts = top_kpi_anomaly_points.copy()

tz = pytz.timezone('Asia/Shanghai')

# Ensure timestamp strings do not carry ambiguous tz tokens when parsing.
# Remove trailing " CST" if present, then parse as naive and localize to Asia/Shanghai.
if 'timestamp' in anomaly_pts.columns and anomaly_pts['timestamp'].dtype == object:
    ts_clean = anomaly_pts['timestamp'].str.replace(' CST', '', regex=False)
    anomaly_pts['ts_dt'] = pd.to_datetime(ts_clean, format='%Y-%m-%d %H:%M:%S')
    anomaly_pts['ts_dt'] = anomaly_pts['ts_dt'].dt.tz_localize(tz)
else:
    # if timestamp already datetime-like
    anomaly_pts['ts_dt'] = pd.to_datetime(anomaly_pts['timestamp']).dt.tz_convert(tz)

# Merge global_p95 from meta into anomaly points to ensure we have the threshold per point
meta_small = top_kpi_meta[['cmdb_id','kpi_name','global_p95']].drop_duplicates()
anomaly_pts = anomaly_pts.merge(meta_small, on=['cmdb_id','kpi_name'], how='left')

# Convert ts_dt to epoch seconds for diff calculation
anomaly_pts['ts_epoch'] = anomaly_pts['ts_dt'].astype('int64') // 10**9

# Sort points
anomaly_pts = anomaly_pts.sort_values(['cmdb_id','kpi_name','ts_epoch']).reset_index(drop=True)

# Group and identify consecutive runs where difference == 60 seconds
def compute_runs(df):
    df = df.copy()
    df['diff'] = df['ts_epoch'].diff().fillna(9999)  # large for first row
    # A new run starts when diff != 60
    df['new_run'] = (df['diff'] != 60).astype(int)
    df['run_id'] = df['new_run'].cumsum()
    return df

anomaly_pts_runs = anomaly_pts.groupby(['cmdb_id','kpi_name'], sort=False).apply(compute_runs).reset_index(drop=True)

# Aggregate per run
agg = anomaly_pts_runs.groupby(['cmdb_id','kpi_name','run_id'], as_index=False).agg(
    run_start_epoch=('ts_epoch','min'),
    run_end_epoch=('ts_epoch','max'),
    run_length_minutes=('ts_epoch','count'),
    run_max_value=('value','max'),
    global_p95=('global_p95','first')
)

# Compute formatted timestamps and severity ratio
def epoch_to_str(e):
    return pd.to_datetime(int(e), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

agg['run_start_timestamp'] = agg['run_start_epoch'].apply(epoch_to_str)
agg['run_end_timestamp'] = agg['run_end_epoch'].apply(epoch_to_str)

def compute_run_sev(row):
    p95 = row['global_p95']
    mv = row['run_max_value']
    if pd.isna(p95) or p95 == 0:
        return None
    return (mv - p95) / p95

agg['run_severity_ratio'] = agg.apply(compute_run_sev, axis=1)

# likely_fault: True if run_length_minutes >=2 AND run_severity_ratio > 0.5
agg['likely_fault'] = agg.apply(lambda r: bool((r['run_length_minutes'] >= 2) and (pd.notna(r['run_severity_ratio']) and r['run_severity_ratio'] > 0.5)), axis=1)

# Select and order columns as requested
fault_runs_df = agg[[
    'cmdb_id','kpi_name','run_start_timestamp','run_end_timestamp',
    'run_length_minutes','run_max_value','global_p95','run_severity_ratio','likely_fault'
]].sort_values(by=['likely_fault', 'run_start_timestamp'], ascending=[False, True]).reset_index(drop=True)

# Limit to top 20 rows
fault_runs_df = fault_runs_df.head(20)

# Build plain-English summary listing any runs marked likely_fault with their cmdb_id and run_start_timestamp
likely = fault_runs_df[fault_runs_df['likely_fault']]
if not likely.empty:
    entries = likely.apply(lambda r: f"{r['cmdb_id']} at {r['run_start_timestamp']}", axis=1).tolist()
    fault_runs_summary = "Likely fault runs detected: " + "; ".join(entries) + "."
else:
    fault_runs_summary = "No runs meet the 'likely_fault' criteria."

# Display compact outputs (variables)
fault_runs_df, fault_runs_summary
