    'unique_cmdb_sample_up_to_20': metric_unique_cmdb[:20],
    'unique_kpi_count': len(metric_unique_kpi),
    'unique_kpi_sample_up_to_20': metric_unique_kpi[:20]
}])

# Prepare trace summary
trace_total_rows = len(trace_df)
