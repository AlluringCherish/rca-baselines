import pandas as pd
import pytz
from datetime import datetime
import numpy as np

# Reuse existing kernel variables: metric_df, metric_p95 (compute if missing), tz
try:
    metric_df
except NameError:
    raise RuntimeError("metric_df not found in kernel.")

try:
    metric_p95
except NameError:
    metric_p95 = metric_df.dropna(subset=['value']).groupby(['cmdb_id','kpi_name'], as_index=False)['value'].quantile(0.95)
    metric_p95 = metric_p95.rename(columns={'value':'global_p95'})

tz = pytz.timezone('Asia/Shanghai')

# Target timestamps (local) and conversion to epoch seconds (UTC)
ts_ship_local = "2022-03-20 15:31:00"
ts_checkout_local = "2022-03-20 15:41:00"

def local_to_epoch(local_ts_str):
    local_dt = tz.localize(datetime.strptime(local_ts_str, "%Y-%m-%d %H:%M:%S"))
    return int(local_dt.astimezone(pytz.utc).timestamp())

epoch_ship = local_to_epoch(ts_ship_local)
epoch_checkout = local_to_epoch(ts_checkout_local)

# Filter metric_df for the two specific (cmdb_id, timestamp) conditions
mask = (
    ((metric_df['cmdb_id'] == 'shippingservice-0') & (metric_df['timestamp'] == epoch_ship)) |
    ((metric_df['cmdb_id'] == 'checkoutservice2-0') & (metric_df['timestamp'] == epoch_checkout))
)
confirm_candidates = metric_df[mask].copy()

# Merge global P95 thresholds (precomputed on full series)
confirm_candidates = confirm_candidates.merge(metric_p95, on=['cmdb_id','kpi_name'], how='left')

# Determine exceed rows where value > global_p95 (and p95 exists)
confirm_candidates['is_exceed'] = confirm_candidates['global_p95'].notna() & (confirm_candidates['value'] > confirm_candidates['global_p95'])

# Keep only exceed rows
confirm_pod_exceeds = confirm_candidates[confirm_candidates['is_exceed']].copy()

# Compute exceed_ratio (handle p95==0)
confirm_pod_exceeds['exceed_ratio'] = confirm_pod_exceeds.apply(
    lambda r: (r['value'] - r['global_p95']) / r['global_p95'] if (pd.notna(r['global_p95']) and r['global_p95'] != 0) else np.nan,
    axis=1
)

# Add readable local timestamp column
confirm_pod_exceeds['timestamp_readable'] = pd.to_datetime(confirm_pod_exceeds['timestamp'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')

# Select and order columns as requested, sort by exceed_ratio desc, limit top 50
confirm_pod_exceeds = confirm_pod_exceeds[[
    'cmdb_id','kpi_name','timestamp_readable','value','global_p95','exceed_ratio'
]].sort_values('exceed_ratio', ascending=False).head(50).reset_index(drop=True)

# Display the compact result (variable, not print)
confirm_pod_exceeds
