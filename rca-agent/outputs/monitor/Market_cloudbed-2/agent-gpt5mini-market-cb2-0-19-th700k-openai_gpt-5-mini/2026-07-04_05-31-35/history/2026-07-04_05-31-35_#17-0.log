import pandas as pd
import pytz
from datetime import datetime
import numpy as np

# Reuse existing kernel variables where possible
try:
    metric_df
    error_df
    tz
    start_ts
    end_ts
except NameError:
    tz = pytz.timezone('Asia/Shanghai')
    start_local = tz.localize(datetime.strptime("2022-03-20 15:30:00", "%Y-%m-%d %H:%M:%S"))
    end_local = tz.localize(datetime.strptime("2022-03-20 16:00:00", "%Y-%m-%d %H:%M:%S"))
    start_ts = int(start_local.astimezone(pytz.utc).timestamp())
    end_ts = int(end_local.astimezone(pytz.utc).timestamp())

# Target service tokens
tokens = ['shippingservice','cartservice','checkoutservice']

# Helper: cmdb_id startswith any token
def cmdb_matches(cmdb):
    return any(str(cmdb).startswith(t) for t in tokens)

# 1) Metric anomalies

# Compute global P95 per (cmdb_id, kpi_name) using full metric_df (rule: thresholds before filtering)
metric_p95 = metric_df.dropna(subset=['value']).groupby(['cmdb_id','kpi_name'], as_index=False)['value'].quantile(0.95)
metric_p95 = metric_p95.rename(columns={'value':'global_p95'})

# Filter metric_df to incident window and matching cmdb_id tokens
metric_window = metric_df[
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] < end_ts) &
    (metric_df['cmdb_id'].apply(cmdb_matches))
].copy()

# If no rows, create empty results
if metric_window.empty:
    dest_metric_anoms = pd.DataFrame(columns=['cmdb_id','total_anomaly_count','distinct_kpi_count','earliest_anomaly_timestamp','max_severity_ratio'])
else:
    # Merge p95 into window
    metric_win = metric_window.merge(metric_p95, on=['cmdb_id','kpi_name'], how='left')

    # Compute per-point anomaly flag: value > global_p95 (only when p95 exists)
    metric_win['is_anomaly'] = metric_win['global_p95'].notna() & (metric_win['value'] > metric_win['global_p95'])

    # KPI-level aggregates for anomalies: anomaly_count and earliest anomaly timestamp
    kpi_anoms = metric_win[metric_win['is_anomaly']].groupby(['cmdb_id','kpi_name'], as_index=False).agg(
        anomaly_count=('is_anomaly','sum'),
        earliest_anom_ts=('timestamp','min')
    )

    # Compute max value in window per KPI (even if KPI had no anomalies, needed for severity but we'll only use KPIs with anomalies)
    max_in_window = metric_win.groupby(['cmdb_id','kpi_name'], as_index=False)['value'].max().rename(columns={'value':'max_value_in_window'})

    # Merge KPI-level anomalies with max and p95
    kpi_summary = kpi_anoms.merge(max_in_window, on=['cmdb_id','kpi_name'], how='left')
    kpi_summary = kpi_summary.merge(metric_p95, on=['cmdb_id','kpi_name'], how='left')

    # Compute KPI-level severity_ratio
    def compute_sev(row):
        p95 = row['global_p95']
        mv = row['max_value_in_window']
        if pd.isna(p95) or p95 == 0:
            return np.nan
        return (mv - p95) / p95

    kpi_summary['severity_ratio'] = kpi_summary.apply(compute_sev, axis=1)

    # Aggregate to per-cmdb_id
    dest_metric_anoms = kpi_summary.groupby('cmdb_id', as_index=False).agg(
        total_anomaly_count=('anomaly_count','sum'),
        distinct_kpi_count=('kpi_name','nunique'),
        earliest_anomaly_ts=('earliest_anom_ts','min'),
        max_severity_ratio=('severity_ratio','max')
    )

    # Format earliest timestamp to Asia/Shanghai readable string
    dest_metric_anoms['earliest_anomaly_timestamp'] = dest_metric_anoms['earliest_anomaly_ts'].apply(
        lambda x: pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
    )

    # Clean up columns and sort by total_anomaly_count desc, limit top 20
    dest_metric_anoms = dest_metric_anoms[[
        'cmdb_id','total_anomaly_count','distinct_kpi_count','earliest_anomaly_timestamp','max_severity_ratio'
    ]].sort_values('total_anomaly_count', ascending=False).head(20).reset_index(drop=True)

# 2) Error-log presence

# Filter error_df to incident window and matching cmdb_id tokens
err_window = error_df[
    (error_df['timestamp'] >= start_ts) &
    (error_df['timestamp'] < end_ts) &
    (error_df['cmdb_id'].apply(cmdb_matches))
].copy()

if err_window.empty:
    dest_error_summary = pd.DataFrame(columns=['cmdb_id','error_count','earliest_error_timestamp','sample_messages'])
else:
    err_window['message'] = err_window['message'].astype(str)
    # Aggregate counts and earliest timestamp per cmdb_id
    err_stats = err_window.groupby('cmdb_id', as_index=False).agg(
        error_count=('message','count'),
        earliest_error_ts=('timestamp','min')
    )

    # Sample up to 5 full messages per cmdb_id
    samples = err_window.groupby('cmdb_id', sort=False).apply(lambda g: g['message'].head(5).tolist()).reset_index()
    samples.columns = ['cmdb_id','sample_messages']

    dest_error_summary = err_stats.merge(samples, on='cmdb_id', how='left')

    # Format earliest timestamp
    dest_error_summary['earliest_error_timestamp'] = dest_error_summary['earliest_error_ts'].apply(
        lambda x: pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
    )

    # Keep only cmdb_id with error_count>0 and limit to 20 rows
    dest_error_summary = dest_error_summary[dest_error_summary['error_count']>0][
        ['cmdb_id','error_count','earliest_error_timestamp','sample_messages']
    ].sort_values('error_count', ascending=False).head(20).reset_index(drop=True)

# Final compact outputs (stored in kernel variables)
dest_metric_anoms, dest_error_summary
