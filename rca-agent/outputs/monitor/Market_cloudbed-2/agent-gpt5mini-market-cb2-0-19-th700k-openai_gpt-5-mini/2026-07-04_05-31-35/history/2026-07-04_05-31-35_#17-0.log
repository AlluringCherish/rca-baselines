import pandas as pd
import pytz
from datetime import datetime

# Reuse existing DataFrames: metric_df, trace_df, log_df, error_df

tz = pytz.timezone('Asia/Shanghai')
# Incident window in Asia/Shanghai -> convert to UTC epoch seconds for filtering
start_local = tz.localize(datetime.strptime("2022-03-20 15:30:00", "%Y-%m-%d %H:%M:%S"))
end_local = tz.localize(datetime.strptime("2022-03-20 16:00:00", "%Y-%m-%d %H:%M:%S"))
start_ts = int(start_local.astimezone(pytz.utc).timestamp())
end_ts = int(end_local.astimezone(pytz.utc).timestamp())

# 1) Metric scan
# Compute global P95 per (cmdb_id, kpi_name) using full metric_df
metric_p95 = metric_df.dropna(subset=['value']).groupby(['cmdb_id','kpi_name'], as_index=False)['value'].quantile(0.95)
metric_p95 = metric_p95.rename(columns={'value':'p95'})

# Filter to incident window
metric_window = metric_df[(metric_df['timestamp'] >= start_ts) & (metric_df['timestamp'] < end_ts)].copy()

# Merge p95
metric_win_with_p95 = metric_window.merge(metric_p95, on=['cmdb_id','kpi_name'], how='left')

# Determine anomalies: value > p95 (if p95 is NaN, treat as no threshold -> no anomaly)
metric_win_with_p95['is_anomaly'] = (metric_win_with_p95['p95'].notna()) & (metric_win_with_p95['value'] > metric_win_with_p95['p95'])

# Aggregate per (cmdb_id, kpi_name)
metric_group = metric_win_with_p95[metric_win_with_p95['is_anomaly']].groupby(['cmdb_id','kpi_name'], as_index=False).agg(
    anomaly_count=('is_anomaly','sum'),
    earliest_anom_ts=('timestamp','min')
)

# Aggregate to per-cmdb_id
metric_agg = metric_group.groupby('cmdb_id', as_index=False).agg(
    total_anomaly_count=('anomaly_count','sum'),
    distinct_kpi_count=('kpi_name','nunique'),
    earliest_anomaly_timestamp=('earliest_anom_ts','min')
)

# Format earliest timestamp to Asia/Shanghai readable string
metric_agg['earliest_anomaly_timestamp'] = metric_agg['earliest_anomaly_timestamp'].apply(
    lambda x: pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
)

# Top 20 by total_anomaly_count
metric_result = metric_agg.sort_values('total_anomaly_count', ascending=False).head(20)[
    ['cmdb_id','total_anomaly_count','distinct_kpi_count','earliest_anomaly_timestamp']
]

# 2) Trace scan
trace_p95 = trace_df.dropna(subset=['value']).groupby(['cmdb_id','trace_name'], as_index=False)['value'].quantile(0.95)
trace_p95 = trace_p95.rename(columns={'value':'p95'})

trace_window = trace_df[(trace_df['timestamp'] >= start_ts) & (trace_df['timestamp'] < end_ts)].copy()
trace_win_with_p95 = trace_window.merge(trace_p95, on=['cmdb_id','trace_name'], how='left')
trace_win_with_p95['is_anomaly'] = (trace_win_with_p95['p95'].notna()) & (trace_win_with_p95['value'] > trace_win_with_p95['p95'])

trace_group = trace_win_with_p95[trace_win_with_p95['is_anomaly']].groupby(['cmdb_id','trace_name'], as_index=False).agg(
    anomaly_count=('is_anomaly','sum'),
    earliest_anom_ts=('timestamp','min')
)
trace_agg = trace_group.groupby('cmdb_id', as_index=False).agg(
    total_trace_anomaly_count=('anomaly_count','sum'),
    distinct_trace_count=('trace_name','nunique'),
    earliest_trace_anomaly_timestamp=('earliest_anom_ts','min')
)
trace_agg['earliest_trace_anomaly_timestamp'] = trace_agg['earliest_trace_anomaly_timestamp'].apply(
    lambda x: pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
)
trace_result = trace_agg.sort_values('total_trace_anomaly_count', ascending=False).head(20)[
    ['cmdb_id','total_trace_anomaly_count','distinct_trace_count','earliest_trace_anomaly_timestamp']
]

# 3) Log scan
log_p95 = log_df.dropna(subset=['value']).groupby(['cmdb_id','log_name'], as_index=False)['value'].quantile(0.95)
log_p95 = log_p95.rename(columns={'value':'p95'})

log_window = log_df[(log_df['timestamp'] >= start_ts) & (log_df['timestamp'] < end_ts)].copy()
log_win_with_p95 = log_window.merge(log_p95, on=['cmdb_id','log_name'], how='left')
log_win_with_p95['is_anomaly'] = (log_win_with_p95['p95'].notna()) & (log_win_with_p95['value'] > log_win_with_p95['p95'])

log_group = log_win_with_p95[log_win_with_p95['is_anomaly']].groupby(['cmdb_id','log_name'], as_index=False).agg(
    anomaly_count=('is_anomaly','sum'),
    earliest_anom_ts=('timestamp','min')
)
log_agg = log_group.groupby('cmdb_id', as_index=False).agg(
    total_log_anomaly_count=('anomaly_count','sum'),
    distinct_log_count=('log_name','nunique'),
    earliest_log_anomaly_timestamp=('earliest_anom_ts','min')
)
log_agg['earliest_log_anomaly_timestamp'] = log_agg['earliest_log_anomaly_timestamp'].apply(
    lambda x: pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
)

# Limit to cmdb_id with any log anomalies, up to 20 rows
log_result = log_agg.sort_values('total_log_anomaly_count', ascending=False).head(20)[
    ['cmdb_id','total_log_anomaly_count','distinct_log_count','earliest_log_anomaly_timestamp']
]

# 4) Error log summary
error_window = error_df[(error_df['timestamp'] >= start_ts) & (error_df['timestamp'] < end_ts)].copy()
# Ensure message is string
error_window['message'] = error_window['message'].astype(str)

def sample_snippets(group):
    msgs = group['message'].head(5).tolist()
    # short snippets (first 120 chars)
    snippets = [m[:120] for m in msgs]
    return snippets

error_grouped = error_window.groupby('cmdb_id').agg(
    error_count=('message','count'),
    earliest_error_timestamp=('timestamp','min')
).reset_index()
# add sample messages
samples = error_window.groupby('cmdb_id').apply(lambda g: sample_snippets(g)).reset_index()
samples.columns = ['cmdb_id','sample_messages']
error_summary = error_grouped.merge(samples, on='cmdb_id', how='left')
error_summary['earliest_error_timestamp'] = error_summary['earliest_error_timestamp'].apply(
    lambda x: pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
)

# Limit rows to cmdb_id that appear in error_df (all of them), keep compact
error_result = error_summary[['cmdb_id','error_count','earliest_error_timestamp','sample_messages']]

# Display compact results (variables, not prints)
metric_result, trace_result, log_result, error_result
