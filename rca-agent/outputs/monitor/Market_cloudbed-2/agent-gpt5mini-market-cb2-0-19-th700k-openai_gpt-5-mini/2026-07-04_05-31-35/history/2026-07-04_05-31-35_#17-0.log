import pandas as pd
import pytz
from datetime import datetime
import numpy as np

# Reuse existing variables where available
try:
    metric_df
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Target cmdb_id list
targets = [
    'shippingservice-0','shippingservice-1','shippingservice-2','shippingservice2-0',
    'cartservice-0','cartservice-1','cartservice-2','cartservice2-0',
    'checkoutservice-0','checkoutservice-1','checkoutservice-2','checkoutservice2-0'
]

# Ensure global P95 per (cmdb_id,kpi_name) exists (compute if not present)
try:
    metric_p95  # reuse if present in kernel
except NameError:
    metric_p95 = metric_df.dropna(subset=['value']).groupby(['cmdb_id','kpi_name'], as_index=False)['value'].quantile(0.95)
    metric_p95 = metric_p95.rename(columns={'value':'global_p95'})

# Convert the two local timestamps to epoch seconds (UTC) consistent with metric_df timestamps
def to_epoch(local_ts_str):
    local_dt = tz.localize(datetime.strptime(local_ts_str, "%Y-%m-%d %H:%M:%S"))
    return int(local_dt.astimezone(pytz.utc).timestamp())

ts1_local = "2022-03-20 15:31:00"
ts2_local = "2022-03-20 15:41:00"
epoch_ts1 = to_epoch(ts1_local)
epoch_ts2 = to_epoch(ts2_local)
target_epochs = {epoch_ts1, epoch_ts2}

# 3) Filter metric_df to those two timestamps and target cmdb_ids
metric_filtered = metric_df[
    metric_df['timestamp'].isin(target_epochs) &
    metric_df['cmdb_id'].isin(targets)
].copy()

# 4) Merge global P95 and compute exceed rows
metric_filtered = metric_filtered.merge(metric_p95, on=['cmdb_id','kpi_name'], how='left')

# Compute exceed condition where global_p95 exists and value > global_p95
metric_filtered['is_exceed'] = metric_filtered['global_p95'].notna() & (metric_filtered['value'] > metric_filtered['global_p95'])

# Keep only exceed rows
anoms = metric_filtered[metric_filtered['is_exceed']].copy()

# Compute exceed_ratio (or NaN if global_p95==0)
def calc_exceed_ratio(row):
    p = row['global_p95']
    v = row['value']
    if pd.isna(p) or p == 0:
        return np.nan
    return (v - p) / p

anoms['exceed_ratio'] = anoms.apply(calc_exceed_ratio, axis=1)

# Add readable local timestamp
anoms['timestamp_readable'] = pd.to_datetime(anoms['timestamp'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')

# Select required columns and sort by exceed_ratio desc, limit top 50
anomalies_df = anoms[[
    'cmdb_id','kpi_name','timestamp_readable','value','global_p95','exceed_ratio'
]].sort_values('exceed_ratio', ascending=False).head(50).reset_index(drop=True)

# 5) Build 1-2 sentence summary per timestamp identifying largest exceed_ratio pods/KPIs
summary_lines = []
for epoch, local_ts in [(epoch_ts1, ts1_local), (epoch_ts2, ts2_local)]:
    subset = anomalies_df[anomalies_df['timestamp_readable'].str.contains(local_ts)]
    if subset.empty:
        summary_lines.append(f"{local_ts} CST: no metric exceedances found for target pods.")
        continue
    # Find max exceed_ratio
    max_row = subset.iloc[0]
    # top 3 by exceed_ratio for this minute
    top3 = subset.sort_values('exceed_ratio', ascending=False).head(3)
    top3_list = [f"{r['cmdb_id']}|{r['kpi_name']} (ratio={r['exceed_ratio']:.4f})" for _, r in top3.iterrows()]
    summary_lines.append(f"{local_ts} CST: highest exceed_ratio on {max_row['cmdb_id']} / KPI {max_row['kpi_name']} (ratio={max_row['exceed_ratio']:.4f}). Top3: " + "; ".join(top3_list))

summary_str = " ".join(summary_lines)

# Display compact outputs (variables)
anomalies_df, summary_str
