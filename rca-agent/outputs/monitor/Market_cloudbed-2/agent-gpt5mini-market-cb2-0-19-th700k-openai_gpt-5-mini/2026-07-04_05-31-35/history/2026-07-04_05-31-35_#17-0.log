import pandas as pd
import re
import pytz
from datetime import datetime
import numpy as np

# Reuse kernel variables where available
try:
    trace_df
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure global P95 per (cmdb_id, trace_name) exists (compute if missing)
try:
    trace_p95
except NameError:
    trace_p95 = trace_df.dropna(subset=['value']).groupby(['cmdb_id','trace_name'], as_index=False)['value'].quantile(0.95)
    trace_p95 = trace_p95.rename(columns={'value':'global_p95'})

# Target timestamps (Asia/Shanghai) as strings
ts_str_15_41 = "2022-03-20 15:41:00"
ts_str_15_31 = "2022-03-20 15:31:00"

# Convert to epoch seconds (UTC) consistent with stored timestamps
def to_epoch_seconds(local_ts_str):
    local_dt = tz.localize(datetime.strptime(local_ts_str, "%Y-%m-%d %H:%M:%S"))
    return int(local_dt.astimezone(pytz.utc).timestamp())

epoch_15_41 = to_epoch_seconds(ts_str_15_41)
epoch_15_31 = to_epoch_seconds(ts_str_15_31)
peak_epochs = [epoch_15_41, epoch_15_31]

frontends = ['frontend-0','frontend-1','frontend-2']

# Filter trace_df to relevant rows (these timestamps and frontends)
trace_peaks = trace_df[
    (trace_df['timestamp'].isin(peak_epochs)) &
    (trace_df['cmdb_id'].isin(frontends))
].copy()

# Merge global P95 thresholds (global, computed from full series)
trace_peaks = trace_peaks.merge(trace_p95, on=['cmdb_id','trace_name'], how='left')

# Compute exceed_ratio and filter anomalies (value > global_p95)
def calc_ratio(row):
    p = row['global_p95']
    v = row['value']
    if pd.isna(p) or p == 0:
        return np.nan
    return (v - p) / p

trace_peaks['exceed_ratio'] = trace_peaks.apply(calc_ratio, axis=1)
trace_peaks['is_anomaly'] = trace_peaks['global_p95'].notna() & (trace_peaks['value'] > trace_peaks['global_p95'])

trace_anoms = trace_peaks[trace_peaks['is_anomaly']].copy()

# Function to extract destination service token
def extract_dest(trace_name):
    # Try regex capture after 'trace.to_' of alphabetic service token
    m = re.search(r'trace\.to_([A-Za-z]+)', trace_name)
    if m:
        return m.group(1)
    # fallback: split after 'trace.to_' then by '.' and '-' 
    if 'trace.to_' in trace_name:
        token = trace_name.split('trace.to_')[1].split('.')[0]
        token = token.split('-')[0]
        return token
    return 'unknown'

trace_anoms['destination_service'] = trace_anoms['trace_name'].apply(extract_dest)

# Prepare aggregation function per timestamp
def aggregate_by_destination(df):
    # df contains anomalies for a single timestamp
    agg = df.groupby('destination_service').agg(
        anomaly_count=('trace_name','count'),
        max_exceed_ratio=('exceed_ratio','max'),
        sample_trace_names=('trace_name', lambda s: list(pd.Series(s).unique()[:5]))
    ).reset_index()
    # Sort by anomaly_count desc, limit to top 10
    agg = agg.sort_values('anomaly_count', ascending=False).head(10)
    return agg

# Split by timestamp and aggregate
anoms_15_41 = trace_anoms[trace_anoms['timestamp']==epoch_15_41].copy()
anoms_15_31 = trace_anoms[trace_anoms['timestamp']==epoch_15_31].copy()

dest_aggr_15_41 = aggregate_by_destination(anoms_15_41)
dest_aggr_15_31 = aggregate_by_destination(anoms_15_31)

# Add readable timestamp column for clarity
readable_15_41 = pd.to_datetime(epoch_15_41, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
readable_15_31 = pd.to_datetime(epoch_15_31, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

dest_aggr_15_41.insert(0, 'timestamp', readable_15_41)
dest_aggr_15_31.insert(0, 'timestamp', readable_15_31)

# Keep columns in requested order and compact representation (sample_trace_names as list)
dest_aggr_15_41 = dest_aggr_15_41[['timestamp','destination_service','anomaly_count','max_exceed_ratio','sample_trace_names']]
dest_aggr_15_31 = dest_aggr_15_31[['timestamp','destination_service','anomaly_count','max_exceed_ratio','sample_trace_names']]

# Display compact aggregated tables (variables)
dest_aggr_15_41, dest_aggr_15_31
