agg_full['earliest_anomaly_low_ts'] = agg_full['earliest_anomaly_low_ts'].apply(to_local_str)

# suggested_direction per rules
def suggest(row):
    hi = int(row['anomalies_high'])
    lo = int(row['anomalies_low'])
    if hi>lo:
        return 'high'
    if lo>hi:
        return 'low'
    if hi==lo and hi>0:
        return 'both'
    return 'none'

agg_full['suggested_direction'] = agg_full.apply(suggest, axis=1)

# Keep only required columns and sort by total anomalies desc, limit top 20
cols = ['cmdb_id','trace_name','global_p95','global_p5','points_in_window',
        'anomalies_high','anomalies_low','earliest_anomaly_high_ts','earliest_anomaly_low_ts',
