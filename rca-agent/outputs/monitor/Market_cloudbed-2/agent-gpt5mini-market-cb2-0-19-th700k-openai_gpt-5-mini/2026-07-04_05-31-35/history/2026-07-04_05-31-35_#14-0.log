    anomalies_low = ('anomaly_low','sum'),
    earliest_anomaly_high_ts = ('timestamp', lambda s: int(s[win_with_thr.loc[s.index,'anomaly_high']].min()) if win_with_thr.loc[s.index,'anomaly_high'].any() else pd.NA),
    earliest_anomaly_low_ts  = ('timestamp', lambda s: int(s[win_with_thr.loc[s.index,'anomaly_low']].min()) if win_with_thr.loc[s.index,'anomaly_low'].any() else pd.NA),
