# suggested_direction
def suggest(row):
    hi = int(row['anomalies_high'])
    lo = int(row['anomalies_low'])
    if hi>lo:
        return 'high'
    if lo>hi:
        return 'low'
    if hi==lo and hi>0:
        return 'both'
    return 'none'

