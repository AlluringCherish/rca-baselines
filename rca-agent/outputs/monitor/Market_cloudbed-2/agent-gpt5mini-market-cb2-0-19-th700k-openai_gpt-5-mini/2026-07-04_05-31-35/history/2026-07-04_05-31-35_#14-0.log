agg_full['points_in_window'] = agg_full['points_in_window'].fillna(0).astype(int)
agg_full['anomalies_high'] = agg_full['anomalies_high'].fillna(0).astype(int)
agg_full['anomalies_low'] = agg_full['anomalies_low'].fillna(0).astype(int)
# Keep global_p95/p5 from thresholds (they should be present); if missing, keep NaN
agg_full = agg_full.merge(thresholds, on=['cmdb_id','trace_name'], how='left', suffixes=('', '_thr'))
