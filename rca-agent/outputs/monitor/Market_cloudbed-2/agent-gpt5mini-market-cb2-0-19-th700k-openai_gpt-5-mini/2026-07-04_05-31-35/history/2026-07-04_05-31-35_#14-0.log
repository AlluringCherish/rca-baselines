agg_full['global_p95'] = agg_full['global_p95'].fillna(agg_full['global_p95_thr'])
agg_full['global_p5'] = agg_full['global_p5'].fillna(agg_full['global_p5_thr'])
agg_full = agg_full.drop(columns=['global_p95_thr','global_p5_thr'])

# Convert earliest anomaly timestamps to localized strings
def to_local_str(x):
    if pd.isna(x):
        return None
    try:
        return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
    except Exception:
        return None

