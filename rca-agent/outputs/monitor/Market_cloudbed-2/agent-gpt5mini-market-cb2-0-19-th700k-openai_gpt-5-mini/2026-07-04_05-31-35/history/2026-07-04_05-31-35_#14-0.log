window_mask = mask_components & name_mask & (trace['timestamp'] >= start_epoch) & (trace['timestamp'] < end_epoch)
window_df = trace[window_mask].copy()

# Merge thresholds into window rows to evaluate anomalies; this ensures thresholds are global (precomputed)
win_with_thr = window_df.merge(thresholds, on=['cmdb_id','trace_name'], how='left')

# Determine anomaly flags
win_with_thr['anomaly_high'] = (win_with_thr['value'] >= win_with_thr['global_p95']).fillna(False)
win_with_thr['anomaly_low'] = (win_with_thr['value'] <= win_with_thr['global_p5']).fillna(False)

