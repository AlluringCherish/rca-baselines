import pandas as pd
import numpy as np
import pytz

# Reuse 'final' from previous kernel state which contains per-(cmdb_id,kpi_name) stats
# If 'final' is not present, fall back to 'anomalous_series' + 'thresholds' (should not be necessary in this session)
df = final.reset_index().copy()

# Consider only series with points in the window for "scanned"
scanned = df[df['total_points_in_window'] > 0].copy()

# Compute per-series deviation (only meaningful if series had anomalies)
def compute_series_deviation(row):
    # Use small epsilon to avoid division by zero per instructions
    eps = 1e-9
    dev = 0.0
    # check high-side anomaly
    if row.get('anomaly_max_value', np.nan) >= row.get('global_P95', np.nan):
        denom = max(row.get('global_P95', 0.0), eps)
        dev = max(dev, abs(row.get('anomaly_max_value', 0.0) - row.get('global_P95', 0.0)) / denom)
    # check low-side anomaly
    if row.get('anomaly_min_value', np.nan) <= row.get('global_P5', np.nan):
        denom = max(row.get('global_P5', 0.0), eps)
        dev = max(dev, abs(row.get('global_P5', 0.0) - row.get('anomaly_min_value', 0.0)) / denom)
    return dev

scanned['series_deviation'] = scanned.apply(compute_series_deviation, axis=1)

# Mark series that have anomalies (anomaly_count_in_window > 0)
scanned['has_anom'] = scanned['anomaly_count_in_window'] > 0

# Aggregate per cmdb_id
grouped = scanned.groupby('cmdb_id')

def top_kpis(series_df, top_n=5):
    # series_df is the subset for one cmdb_id
    anom_series = series_df[series_df['has_anom']].copy()
    if anom_series.empty:
        return ""
    top = anom_series.sort_values('anomaly_count_in_window', ascending=False).head(top_n)
    return "; ".join(f"{r['kpi_name']}({int(r['anomaly_count_in_window'])})" for _, r in top.iterrows())

agg = grouped.agg(
    series_scanned=('kpi_name', 'nunique'),
    series_with_anoms=('has_anom', 'sum'),
    total_anomaly_points=('anomaly_count_in_window', 'sum'),
    earliest_anomaly_timestamp=('earliest_anomaly_timestamp', lambda x: int(x[min(~x.isna().to_numpy().nonzero()[0])]) if (x.notna().any()) else pd.NA),
    max_series_deviation=('series_deviation', 'max')
).reset_index()

# The lambda above for earliest_anomaly_timestamp is a bit complex; safer to compute separately:
earliest_ts = scanned[scanned['has_anom']].groupby('cmdb_id')['earliest_anomaly_timestamp'].min().rename('earliest_anomaly_timestamp')
agg = agg.set_index('cmdb_id')
agg['earliest_anomaly_timestamp'] = earliest_ts
agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_timestamp'].where(agg['series_with_anoms']>0, pd.NA)

# Convert max_series_deviation to percentage-like value per instructions (e.g., 250% -> 2.5)
agg['max_relative_deviation'] = agg['max_series_deviation'].fillna(0.0).astype(float)

# Build top_kpis_with_anoms strings
