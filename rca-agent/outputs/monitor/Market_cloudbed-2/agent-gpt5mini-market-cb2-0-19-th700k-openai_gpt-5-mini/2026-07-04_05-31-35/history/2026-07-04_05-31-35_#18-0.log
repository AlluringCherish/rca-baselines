dyn_keywords = ['cpu','memory','mem','load','io','fs_io','io_time','network','net','app.http','app.grpc','duration']
dyn_pat = re.compile('(' + '|'.join([re.escape(k) for k in sorted(set(dyn_keywords), key=len, reverse=True)]) + ')', flags=re.IGNORECASE)

