# kpi_name contains any of the substrings (case-sensitive)
cond_kpi = anomalies_df['kpi_name'].str.contains(pattern, na=False)

filtered = anomalies_df[cond_cmdb & cond_kpi].copy()

# Aggregate by cmdb_id and kpi_name
