import pandas as pd
import pytz

# Reuse existing df_metric and tz if available, otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Target components
targets = ['frontend-0','frontend-1','frontend-2','adservice-0','adservice-1','adservice-2','node-5']

# Identify memory-related KPI rows for these components using substrings (case-sensitive)
mask_comp = df_metric['cmdb_id'].isin(targets)
mask_kpi = df_metric['kpi_name'].notna() & (
    df_metric['kpi_name'].str.contains('memory') | df_metric['kpi_name'].str.contains('container.node-5')
)
mask = mask_comp & mask_kpi

df_memory_candidates = df_metric[mask].copy()

# Compute global P95 per (cmdb_id, kpi_name) using the full series (no time filtering)
p95_series = (
    df_memory_candidates
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'p95'})
)

# Count distinct memory-related groups
total_memory_groups = p95_series.shape[0]

# Prepare incident window (UTC+8) filtering
start_ts = pd.Timestamp('2022-03-20 13:00:00').tz_localize(tz)
end_ts = pd.Timestamp('2022-03-20 13:30:00').tz_localize(tz)
ts_dt_full = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
mask_window = (ts_dt_full >= start_ts) & (ts_dt_full <= end_ts)
df_metric_window = df_metric[mask_window].copy()
df_metric_window['ts_dt'] = pd.to_datetime(df_metric_window['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Keep only the same target memory-related groups in the window
df_memory_window = df_metric_window[ df_metric_window['cmdb_id'].isin(targets) & 
                                    df_metric_window['kpi_name'].notna() &
                                    (df_metric_window['kpi_name'].str.contains('memory') | df_metric_window['kpi_name'].str.contains('container.node-5'))
                                  ].copy()

# For each group in the p95 list, compute anomaly_count (value >= p95), earliest anomaly timestamp, and max value in window
# Merge p95 into windowed memory rows
df_mem_w_with_p95 = df_memory_window.merge(p95_series, on=['cmdb_id', 'kpi_name'], how='right')

# After merge, rows from p95_series without window data will have NaNs for window columns
# Compute anomaly flags only where window rows exist
df_mem_w_with_p95['is_anom'] = False
mask_has_value = df_mem_w_with_p95['value'].notna()
df_mem_w_with_p95.loc[mask_has_value, 'is_anom'] = df_mem_w_with_p95.loc[mask_has_value, 'value'] >= df_mem_w_with_p95.loc[mask_has_value, 'p95']

# Aggregate per group
agg_window = (
    df_mem_w_with_p95
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        p95=('p95', 'first'),
        anomaly_count_in_window=('is_anom', 'sum'),
        earliest_anomaly_timestamp_secs=('timestamp', lambda s: s[df_mem_w_with_p95.loc[s.index, 'is_anom']].min() if any(df_mem_w_with_p95.loc[s.index, 'is_anom']) else pd.NA),
        max_value_in_window=('value', 'max')
    )
)

# Ensure integer counts and format earliest timestamp to UTC+8 string or None
agg_window['anomaly_count_in_window'] = agg_window['anomaly_count_in_window'].fillna(0).astype(int)

def fmt_ts_nullable(s):
    if pd.isna(s) or s is pd.NA:
        return None
    return pd.to_datetime(int(s), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

agg_window['earliest_anomaly_timestamp'] = agg_window['earliest_anomaly_timestamp_secs'].apply(fmt_ts_nullable)

# Select and order required columns
df_memory_grouped_results_all = agg_window[[
    'cmdb_id',
    'kpi_name',
    'p95',
    'anomaly_count_in_window',
    'earliest_anomaly_timestamp',
    'max_value_in_window'
]].copy()

# Sort by cmdb_id then anomaly_count_in_window desc
df_memory_grouped_results_all = df_memory_grouped_results_all.sort_values(by=['cmdb_id', 'anomaly_count_in_window'], ascending=[True, False]).reset_index(drop=True)

# Prepare compact top-20 table
df_memory_grouped_results_head = df_memory_grouped_results_all.head(20)

# Store full grouped results in kernel variable (already assigned above)
# Return compact table and total count of distinct memory-related groups
df_memory_grouped_results_head, total_memory_groups
