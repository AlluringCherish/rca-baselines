import pandas as pd
import pytz

# Reuse existing df_log and tz if available
try:
    df_log
except NameError:
    df_log = pd.read_csv('log.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Target components
targets = ['frontend-0','frontend-1','frontend-2','adservice-0','adservice-1','adservice-2']

# Prepare helper for timestamp formatting
def fmt_ts_nullable(s):
    if pd.isna(s):
        return None
    return pd.to_datetime(int(s), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

# 1) Compute global P95 and P5 per (cmdb_id, log_name) using full series (no time filtering)
df_log_targets = df_log[df_log['cmdb_id'].isin(targets)].copy()

thresholds_p95 = (
    df_log_targets
    .groupby(['cmdb_id','log_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value':'p95'})
)
thresholds_p5 = (
    df_log_targets
    .groupby(['cmdb_id','log_name'], as_index=False)['value']
    .quantile(0.05)
    .rename(columns={'value':'p5'})
)
thresholds = thresholds_p95.merge(thresholds_p5, on=['cmdb_id','log_name'], how='outer')

# 2) Filter log rows to incident window (inclusive) in UTC+8
start_ts = pd.Timestamp('2022-03-20 13:00:00').tz_localize(tz)
end_ts = pd.Timestamp('2022-03-20 13:30:00').tz_localize(tz)
ts_dt_full = pd.to_datetime(df_log['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
mask_window = (ts_dt_full >= start_ts) & (ts_dt_full <= end_ts)
df_log_window = df_log[mask_window & df_log['cmdb_id'].isin(targets)].copy()
df_log_window['ts_dt'] = pd.to_datetime(df_log_window['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 3) Join thresholds into windowed data to evaluate above/below
df_lw = df_log_window.merge(thresholds, on=['cmdb_id','log_name'], how='left')

# Determine above/below flags (only where thresholds exist)
df_lw['is_above'] = df_lw['value'].notna() & df_lw['p95'].notna() & (df_lw['value'] >= df_lw['p95'])
df_lw['is_below'] = df_lw['value'].notna() & df_lw['p5'].notna() & (df_lw['value'] <= df_lw['p5'])

# Aggregations for above and below events (from windowed rows)
above_agg = (
    df_lw[df_lw['is_above']]
    .groupby(['cmdb_id','log_name'], as_index=False)
    .agg(
        count_above_p95_in_window=('is_above','sum'),
        earliest_above_secs=('timestamp','min'),
        max_value_in_window=('value','max')
    )
)

below_agg = (
    df_lw[df_lw['is_below']]
    .groupby(['cmdb_id','log_name'], as_index=False)
    .agg(
        count_below_p5_in_window=('is_below','sum'),
        earliest_below_secs=('timestamp','min'),
        min_value_in_window=('value','min')
    )
)

# Also capture overall max/min in-window even if not above/below (for completeness)
overall_window_agg = (
    df_log_window
    .groupby(['cmdb_id','log_name'], as_index=False)
    .agg(
        max_value_in_window_overall=('value','max'),
        min_value_in_window_overall=('value','min'),
        points_in_window=('value','size')
    )
)

# Build base result from thresholds to include groups even with no window rows
df_log_grouped_results_all = thresholds.copy()

# Merge in overall window aggregates (may be missing for some groups)
df_log_grouped_results_all = df_log_grouped_results_all.merge(overall_window_agg, on=['cmdb_id','log_name'], how='left')

# Merge above/below aggregates
df_log_grouped_results_all = df_log_grouped_results_all.merge(above_agg, on=['cmdb_id','log_name'], how='left')
df_log_grouped_results_all = df_log_grouped_results_all.merge(below_agg, on=['cmdb_id','log_name'], how='left')

# Normalize columns: ensure existence and fill NAs
for col in ['count_above_p95_in_window','count_below_p5_in_window','max_value_in_window_overall','min_value_in_window_overall','points_in_window']:
    if col not in df_log_grouped_results_all.columns:
        df_log_grouped_results_all[col] = pd.NA

df_log_grouped_results_all['count_above_p95_in_window'] = df_log_grouped_results_all['count_above_p95_in_window'].fillna(0).astype(int)
df_log_grouped_results_all['count_below_p5_in_window'] = df_log_grouped_results_all['count_below_p5_in_window'].fillna(0).astype(int)

# Format earliest timestamps
df_log_grouped_results_all['earliest_above_p95_timestamp'] = df_log_grouped_results_all['earliest_above_secs'].apply(lambda s: fmt_ts_nullable(s) if 'earliest_above_secs' in df_log_grouped_results_all.columns else None)
df_log_grouped_results_all['earliest_below_p5_timestamp'] = df_log_grouped_results_all['earliest_below_secs'].apply(lambda s: fmt_ts_nullable(s) if 'earliest_below_secs' in df_log_grouped_results_all.columns else None)

# Select and rename columns to requested output names, using overall max/min where specific columns may be missing
