df_tw['is_low'] = df_tw['value'] <= df_tw['p5']

# Aggregations for highs
high_agg = (
    df_tw[df_tw['is_high']]
    .groupby(['cmdb_id', 'trace_name'], as_index=False)
    .agg(count_high=('is_high', 'sum'),
         earliest_high_timestamp_secs=('timestamp', 'min'),
         max_value_in_window=('value', 'max'))
)

# Aggregations for lows
low_agg = (
    df_tw[df_tw['is_low']]
    .groupby(['cmdb_id', 'trace_name'], as_index=False)
    .agg(count_low=('is_low', 'sum'),
         earliest_low_timestamp_secs=('timestamp', 'min'),
         min_value_in_window=('value', 'min'))
)

# Aggregations for groups that have any data in window to capture max/min even if not high/low
window_overall_agg = (
    df_trace_window
    .groupby(['cmdb_id', 'trace_name'], as_index=False)
