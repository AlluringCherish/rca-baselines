import pandas as pd
import pytz

# Reuse existing df_metric and tz if available
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure timezone-aware datetime column for window filtering (UTC+8)
if 'ts_dt' not in df_metric.columns:
    df_metric['ts_dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Incident window bounds (inclusive) in UTC+8
start_ts = pd.Timestamp('2022-03-20 13:00:00').tz_localize(tz)
end_ts = pd.Timestamp('2022-03-20 13:30:00').tz_localize(tz)

# Helper to format earliest timestamp secs -> string or None
def fmt_ts_nullable(s):
    if pd.isna(s):
        return None
    return pd.to_datetime(int(s), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

# Part 1: Node-level KPIs for node-5
node5_kpis = [
    'system.tcp.retrans_pct',
    'system.net.udp.rcv_buf_errors',
    'system.net.udp.snd_buf_errors'
]

# Find which of these exist in the dataset for node-5
mask_node5_full = (df_metric['cmdb_id'] == 'node-5') & df_metric['kpi_name'].isin(node5_kpis)
available_node5 = df_metric[mask_node5_full].copy()

# Compute global P95 per kpi_name (full series)
p95_node5 = (
    available_node5
    .groupby(['cmdb_id','kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value':'p95'})
)

# Windowed rows for node-5 & those KPIs
mask_window = (df_metric['ts_dt'] >= start_ts) & (df_metric['ts_dt'] <= end_ts)
df_node5_window = df_metric[mask_window & (df_metric['cmdb_id']=='node-5') & df_metric['kpi_name'].isin(node5_kpis)].copy()

# Merge p95 into window rows and evaluate anomalies
df_node5_win_with_p95 = df_node5_window.merge(p95_node5, on=['cmdb_id','kpi_name'], how='left')
df_node5_win_with_p95['is_anom'] = df_node5_win_with_p95['value'].notna() & df_node5_win_with_p95['p95'].notna() & (df_node5_win_with_p95['value'] >= df_node5_win_with_p95['p95'])

# Aggregate per KPI for node-5 from window
agg_node5_window = (
    df_node5_win_with_p95
    .groupby(['cmdb_id','kpi_name'], as_index=False)
    .agg(
        anomaly_count_in_window=('is_anom','sum'),
        earliest_anomaly_timestamp_secs=('timestamp', lambda s: s[df_node5_win_with_p95.loc[s.index,'is_anom']].min() if any(df_node5_win_with_p95.loc[s.index,'is_anom']) else pd.NA),
        max_value_in_window=('value','max')
    )
)

# Merge with p95 to include KPIs that may have p95 but no window rows
node5_results = p95_node5.merge(agg_node5_window, on=['cmdb_id','kpi_name'], how='left')
node5_results['anomaly_count_in_window'] = node5_results['anomaly_count_in_window'].fillna(0).astype(int)
node5_results['earliest_anomaly_timestamp'] = node5_results['earliest_anomaly_timestamp_secs'].apply(fmt_ts_nullable)
node5_results = node5_results[[
    'cmdb_id','kpi_name','p95','anomaly_count_in_window','earliest_anomaly_timestamp','max_value_in_window'
]]

# Store full results variable
node5_network_results_full = node5_results.copy()

# Part 2: Container-scoped network KPIs for frontend and adservice pods
targets = ['frontend-0','frontend-1','frontend-2','adservice-0','adservice-1','adservice-2']
sub_kpis = [
    'container_network_receive_errors',
    'container_network_transmit_errors',
    'container_network_receive_packets',
    'container_network_transmit_packets'
]
pattern = '|'.join(sub_kpis)

# Select full-series groups for these targets where kpi_name contains any of the exact substrings
mask_containers_full = df_metric['cmdb_id'].isin(targets) & df_metric['kpi_name'].notna() & df_metric['kpi_name'].str.contains(pattern, regex=True, na=False)
df_containers_full = df_metric[mask_containers_full].copy()

# Compute global P95 per (cmdb_id,kpi_name) from full series
p95_containers = (
    df_containers_full
    .groupby(['cmdb_id','kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value':'p95'})
)

# Windowed rows for these targets and KPI patterns
df_containers_window = df_metric[mask_window & df_metric['cmdb_id'].isin(targets) & df_metric['kpi_name'].notna() & df_metric['kpi_name'].str.contains(pattern, regex=True, na=False)].copy()

# Merge p95 into window rows and evaluate anomalies
df_cont_win_with_p95 = df_containers_window.merge(p95_containers, on=['cmdb_id','kpi_name'], how='left')
df_cont_win_with_p95['is_anom'] = df_cont_win_with_p95['value'].notna() & df_cont_win_with_p95['p95'].notna() & (df_cont_win_with_p95['value'] >= df_cont_win_with_p95['p95'])

# Aggregate per (cmdb_id,kpi_name)
agg_cont_window = (
    df_cont_win_with_p95
    .groupby(['cmdb_id','kpi_name'], as_index=False)
    .agg(
        anomaly_count_in_window=('is_anom','sum'),
        earliest_anomaly_timestamp_secs=('timestamp', lambda s: s[df_cont_win_with_p95.loc[s.index,'is_anom']].min() if any(df_cont_win_with_p95.loc[s.index,'is_anom']) else pd.NA),
        max_value_in_window=('value','max')
    )
)

# Merge p95 list with aggregated window data to include groups with p95 but no window rows
container_results = p95_containers.merge(agg_cont_window, on=['cmdb_id','kpi_name'], how='left')
container_results['anomaly_count_in_window'] = container_results['anomaly_count_in_window'].fillna(0).astype(int)
container_results['earliest_anomaly_timestamp'] = container_results['earliest_anomaly_timestamp_secs'].apply(fmt_ts_nullable)
container_results = container_results[[
    'cmdb_id','kpi_name','p95','anomaly_count_in_window','earliest_anomaly_timestamp','max_value_in_window'
]]

# Sort container results by earliest_anomaly_timestamp asc (nulls last), then anomaly_count desc
container_results['earliest_sort_key'] = pd.to_datetime(container_results['earliest_anomaly_timestamp'], utc=True).fillna(pd.Timestamp.max.tz_localize('UTC'))
container_results_sorted = container_results.sort_values(by=['earliest_sort_key','anomaly_count_in_window'], ascending=[True, False]).drop(columns=['earliest_sort_key']).reset_index(drop=True)

# Store full results variables for follow-ups
container_network_results_full = container_results_sorted.copy()

# Prepare compact display tables
node5_table = node5_network_results_full.head(10)
container_table = container_network_results_full.head(20)

# Compute overall earliest anomaly timestamp across both result sets
all_earliest = pd.Series(
    pd.concat([
        node5_network_results_full['earliest_anomaly_timestamp'].dropna(),
        container_network_results_full['earliest_anomaly_timestamp'].dropna()
