start_ts = pd.Timestamp('2022-03-20 13:00:00').tz_localize(tz)
end_ts = pd.Timestamp('2022-03-20 13:30:00').tz_localize(tz)

ts_dt_full = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
mask_window = (ts_dt_full >= start_ts) & (ts_dt_full <= end_ts)
df_trace_window = df_trace[mask_window].copy()
df_trace_window['ts_dt'] = pd.to_datetime(df_trace_window['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

