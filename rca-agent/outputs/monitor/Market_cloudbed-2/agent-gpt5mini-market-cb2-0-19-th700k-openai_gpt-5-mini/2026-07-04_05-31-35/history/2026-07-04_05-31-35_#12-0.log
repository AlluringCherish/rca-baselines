)

# Compute window counts per kpi_name
agg_window_counts = (
    df_metric_matches_window
    .groupby('kpi_name', as_index=False)
    .agg(count_of_rows_within_incident_window=('kpi_name', 'size'))
)

# Merge and prepare display-friendly example list (joined string)
