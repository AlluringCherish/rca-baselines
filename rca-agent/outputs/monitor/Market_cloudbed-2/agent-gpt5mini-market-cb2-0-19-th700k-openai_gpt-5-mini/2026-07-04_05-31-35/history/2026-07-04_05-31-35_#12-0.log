# Compute sorting key and sort by max(count_above, count_below) desc then max_value_in_window desc
df_log_grouped_results_all['max_count'] = df_log_grouped_results_all[['count_above_p95_in_window','count_below_p5_in_window']].max(axis=1)
df_log_grouped_results_all_sorted = df_log_grouped_results_all.sort_values(by=['max_count','max_value_in_window'], ascending=[False, False]).reset_index(drop=True)
df_log_grouped_results_all_sorted = df_log_grouped_results_all_sorted.drop(columns=['max_count'])

# Compute overall earliest in-window timestamp among all above-P95 or below-P5 events for these groups (from df_lw)
events_mask = (df_lw['is_above'] | df_lw['is_below'])
if events_mask.any():
    overall_earliest_event_ts_secs = int(df_lw.loc[events_mask, 'timestamp'].min())
    overall_earliest_event_ts = pd.to_datetime(overall_earliest_event_ts_secs, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
else:
    overall_earliest_event_ts = None

# Prepare compact top-20 table for display
df_log_grouped_results_top20 = df_log_grouped_results_all_sorted.head(20)

# Store full grouped results in kernel variable for later steps
# (variable name preserved: df_log_grouped_results_all_sorted)

