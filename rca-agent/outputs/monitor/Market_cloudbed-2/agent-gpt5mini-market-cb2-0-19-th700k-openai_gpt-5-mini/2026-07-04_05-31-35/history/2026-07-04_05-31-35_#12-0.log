import pandas as pd
import pytz

# Reuse existing df_error_logs and tz if present; otherwise load defensively
try:
    df_error_logs
except NameError:
    df_error_logs = pd.read_csv('error_logs.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Convert timestamps to timezone-aware datetimes (UTC+8) and keep in df_error_logs
df_error_logs['ts_dt'] = pd.to_datetime(df_error_logs['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Incident window (inclusive) in UTC+8
start_ts = pd.Timestamp('2022-03-20 13:00:00').tz_localize(tz)
end_ts = pd.Timestamp('2022-03-20 13:30:00').tz_localize(tz)

# Filter rows within window and store for later steps
df_error_logs_window = df_error_logs[(df_error_logs['ts_dt'] >= start_ts) & (df_error_logs['ts_dt'] <= end_ts)].copy()

# Overall earliest error_logs timestamp across all components in the window
if df_error_logs_window.empty:
    overall_earliest_ts_str = None
else:
    overall_earliest_ts = df_error_logs_window['timestamp'].min()
    overall_earliest_ts_str = pd.to_datetime(int(overall_earliest_ts), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

# Group by cmdb_id and compute counts and earliest/latest timestamps and up to 5 distinct sample messages
def top_unique_messages(series, limit=5):
    vals = pd.Series(series.dropna().unique())
    if vals.empty:
        return None
    # join into a single compact string for display
    samples = vals.astype(str).tolist()[:limit]
    return '; '.join(samples)

if df_error_logs_window.empty:
    df_error_logs_agg = pd.DataFrame(columns=[
        'cmdb_id','count_of_messages','earliest_timestamp','latest_timestamp','sample_messages'
    ])
else:
    agg = df_error_logs_window.groupby('cmdb_id', sort=False).agg(
        count_of_messages=('timestamp', 'size'),
        earliest_timestamp_secs=('timestamp', 'min'),
        latest_timestamp_secs=('timestamp', 'max'),
        sample_messages_raw=('message', lambda x: top_unique_messages(x, limit=5))
    ).reset_index()

    # Format timestamps to UTC+8 strings
    agg['earliest_timestamp'] = agg['earliest_timestamp_secs'].apply(
        lambda s: pd.to_datetime(int(s), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
    )
    agg['latest_timestamp'] = agg['latest_timestamp_secs'].apply(
        lambda s: pd.to_datetime(int(s), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
    )

    df_error_logs_agg = agg[[
        'cmdb_id',
        'count_of_messages',
        'earliest_timestamp',
        'latest_timestamp',
        'sample_messages_raw'
    ]].rename(columns={'sample_messages_raw': 'sample_messages'})

# Sort by count_of_messages descending and limit top 20 for compact display
df_error_logs_agg_top20 = df_error_logs_agg.sort_values(by='count_of_messages', ascending=False).head(20).reset_index(drop=True)

# Display compact aggregate results only and keep df_error_logs_window stored for later steps
df_error_logs_agg_top20, overall_earliest_ts_str
