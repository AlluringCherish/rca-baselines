import pandas as pd
import pytz

# Reuse existing df_metric and tz if available
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# 1) Find distinct cmdb_id values that have any kpi_name containing 'container.node-5'
mask_node5_kpi = df_metric['kpi_name'].notna() & df_metric['kpi_name'].str.contains('container.node-5', na=False)
cmdbs_with_node5_kpi = sorted(df_metric.loc[mask_node5_kpi, 'cmdb_id'].dropna().unique())
count_of_unique_cmdb_ids = len(cmdbs_with_node5_kpi)
top20_cmdb_ids = cmdbs_with_node5_kpi[:20]

# Check presence of frontend-0/1/2
frontend_presence = {
    'frontend-0': 'yes' if 'frontend-0' in cmdbs_with_node5_kpi else 'no',
    'frontend-1': 'yes' if 'frontend-1' in cmdbs_with_node5_kpi else 'no',
    'frontend-2': 'yes' if 'frontend-2' in cmdbs_with_node5_kpi else 'no'
}

# Compact summary DataFrame for part 1
summary_cmdbs = pd.DataFrame({
    'count_of_unique_cmdb_ids': [count_of_unique_cmdb_ids],
    'top_cmdb_ids': [top20_cmdb_ids],
    'frontend-0_present': [frontend_presence['frontend-0']],
    'frontend-1_present': [frontend_presence['frontend-1']],
    'frontend-2_present': [frontend_presence['frontend-2']]
})

# 2) For cmdb_id == 'node-5', identify kpi_name containing 'memory' (case-insensitive) or 'mem'
mask_node5 = df_metric['cmdb_id'] == 'node-5'
mask_mem = df_metric['kpi_name'].notna() & df_metric['kpi_name'].str.contains('memory|mem', case=False, na=False)
df_node5_full = df_metric[mask_node5].copy()
df_node5_mem_candidates = df_node5_full[mask_mem].copy()

# Compute global P95 per kpi_name for node-5 using full series (no time filtering)
p95_node5 = (
    df_node5_mem_candidates
    .groupby(['kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'p95'})
)
# Add cmdb_id column for merges
p95_node5['cmdb_id'] = 'node-5'
# Count distinct memory-related groups for node-5
total_node5_memory_groups = p95_node5.shape[0]

# Incident window filter (UTC+8)
start_ts = pd.Timestamp('2022-03-20 13:00:00').tz_localize(tz)
end_ts = pd.Timestamp('2022-03-20 13:30:00').tz_localize(tz)
ts_dt_full = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
mask_window = (ts_dt_full >= start_ts) & (ts_dt_full <= end_ts)
df_metric_window = df_metric[mask_window].copy()
df_metric_window['ts_dt'] = pd.to_datetime(df_metric_window['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Keep only node-5 memory-related rows in the window
df_node5_window = df_metric_window[(df_metric_window['cmdb_id']=='node-5') & (df_metric_window['kpi_name'].notna()) & (df_metric_window['kpi_name'].str.contains('memory|mem', case=False, na=False))].copy()

# Merge global p95 (computed from full series) with window rows; ensure groups with no window rows are kept
df_p95_with_window = p95_node5.merge(df_node5_window, on=['cmdb_id','kpi_name'], how='left')

# Flag anomalies where value >= p95 (only for rows where value exists)
df_p95_with_window['is_anom'] = df_p95_with_window['value'].notna() & (df_p95_with_window['value'] >= df_p95_with_window['p95'])

# Aggregate per (cmdb_id, kpi_name)
agg_node5 = (
    df_p95_with_window
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        p95=('p95', 'first'),
        anomaly_count_in_window=('is_anom', 'sum'),
        earliest_anomaly_timestamp_secs=('timestamp', lambda s: s[df_p95_with_window.loc[s.index, 'is_anom']].min() if any(df_p95_with_window.loc[s.index, 'is_anom']) else pd.NA),
        max_value_in_window=('value', 'max')
    )
)

# Ensure integer counts and format earliest timestamps
agg_node5['anomaly_count_in_window'] = agg_node5['anomaly_count_in_window'].fillna(0).astype(int)

def fmt_ts_nullable(s):
    if pd.isna(s) or s is pd.NA:
        return None
    return pd.to_datetime(int(s), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

agg_node5['earliest_anomaly_timestamp'] = agg_node5['earliest_anomaly_timestamp_secs'].apply(fmt_ts_nullable)

# Select required columns and sort by anomaly_count desc then max_value desc
df_node5_memory_grouped_all = agg_node5[[
    'cmdb_id',
    'kpi_name',
    'p95',
    'anomaly_count_in_window',
    'earliest_anomaly_timestamp',
    'max_value_in_window'
]].copy()

df_node5_memory_grouped_all = df_node5_memory_grouped_all.sort_values(by=['anomaly_count_in_window','max_value_in_window'], ascending=[False, False]).reset_index(drop=True)

# Compact top-20 table
df_node5_memory_grouped_head = df_node5_memory_grouped_all.head(20)

# Store results in kernel variables for later steps:
# - summary_cmdbs
# - p95_node5
# - df_node5_memory_grouped_all

summary_cmdbs, df_node5_memory_grouped_head, total_node5_memory_groups
