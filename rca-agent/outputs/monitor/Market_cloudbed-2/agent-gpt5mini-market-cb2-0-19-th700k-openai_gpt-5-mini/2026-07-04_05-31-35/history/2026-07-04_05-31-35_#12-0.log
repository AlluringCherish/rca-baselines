if 'ts_dt' not in df_metric.columns:
    df_metric['ts_dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Substrings to search (case-insensitive)
substrings = ['restart','oom','kill','exit','crash','process','terminated','tcp','retransmit','retrans','packet','loss','latency','throttled','error']
# Build regex pattern, escape substrings just in case, join with |
pattern = '|'.join(re.escape(s) for s in substrings)

# Find matching kpi_name rows (case-insensitive)
mask_matches = df_metric['kpi_name'].notna() & df_metric['kpi_name'].str.contains(pattern, case=False, na=False)
df_metric_matches = df_metric[mask_matches].copy()  # store full set for later inspection as required

# Incident window (inclusive) in UTC+8
start_ts = pd.Timestamp('2022-03-20 13:00:00').tz_localize(tz)
end_ts = pd.Timestamp('2022-03-20 13:30:00').tz_localize(tz)
mask_window = (df_metric_matches['ts_dt'] >= start_ts) & (df_metric_matches['ts_dt'] <= end_ts)
df_metric_matches_window = df_metric_matches[mask_window]

# Aggregate results per kpi_name
