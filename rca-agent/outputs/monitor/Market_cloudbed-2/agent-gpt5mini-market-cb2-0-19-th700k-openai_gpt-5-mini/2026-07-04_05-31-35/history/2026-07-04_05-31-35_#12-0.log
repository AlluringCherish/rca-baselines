import pandas as pd
import pytz

# Reuse existing df_trace and tz if present; otherwise load
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# 1) Compute global P95 and P5 per (cmdb_id, trace_name) using full series
p95_df = df_trace.groupby(['cmdb_id', 'trace_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value': 'p95'})
p5_df = df_trace.groupby(['cmdb_id', 'trace_name'], as_index=False)['value'].quantile(0.05).rename(columns={'value': 'p5'})

thresholds = p95_df.merge(p5_df, on=['cmdb_id', 'trace_name'], how='outer')

