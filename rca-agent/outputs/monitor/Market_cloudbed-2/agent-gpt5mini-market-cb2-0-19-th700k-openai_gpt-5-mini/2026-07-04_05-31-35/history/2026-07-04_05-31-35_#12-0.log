2026-07-04 05:39:30,409 | DEBUG | Raw Code:
import pandas as pd
import pytz

# Reuse existing df_trace and tz if available
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure timezone-aware datetime column for window filtering
if 'ts_dt' not in df_trace.columns:
    df_trace['ts_dt'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Select groups whose trace_name contains 'from_frontend' (case-sensitive)
mask_from_frontend = df_trace['trace_name'].str.contains('from_frontend', na=False)
df_trace_ff = df_trace[mask_from_frontend].copy()

# 2) Compute global P95 and P5 using full series
p95_df = (
    df_trace_ff
    .groupby(['cmdb_id','trace_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value':'p95'})
)
p5_df = (
    df_trace_ff
    .groupby(['cmdb_id','trace_name'], as_index=False)['value']
    .quantile(0.05)
    .rename(columns={'value':'p5'})
)

# Compute full-series max and min without using named-agg tuple syntax
max_df = df_trace_ff.groupby(['cmdb_id','trace_name'], as_index=False)['value'].max().rename(columns={'value':'full_series_max'})
min_df = df_trace_ff.groupby(['cmdb_id','trace_name'], as_index=False)['value'].min().rename(columns={'value':'full_series_min'})

thresholds = p95_df.merge(p5_df, on=['cmdb_id','trace_name'], how='outer')\
                  .merge(max_df, on=['cmdb_id','trace_name'], how='outer')\
                  .merge(min_df, on=['cmdb_id','trace_name'], how='outer')

# 3) Keep only groups where p95 > 0 OR full_series_max > 0
thresholds_nonzero = thresholds[(thresholds['p95'].fillna(0) > 0) | (thresholds['full_series_max'].fillna(0) > 0)].copy()

# 4) Incident window filter (UTC+8) inclusive
start_ts = pd.Timestamp('2022-03-20 13:00:00').tz_localize(tz)
end_ts = pd.Timestamp('2022-03-20 13:30:00').tz_localize(tz)
mask_window = (df_trace['ts_dt'] >= start_ts) & (df_trace['ts_dt'] <= end_ts)
df_trace_window = df_trace[mask_window & df_trace['trace_name'].str.contains('from_frontend', na=False)].copy()

# 5) Merge thresholds_nonzero with window rows (left join to keep groups even without window rows)
df_thresh_window = thresholds_nonzero.merge(df_trace_window, on=['cmdb_id','trace_name'], how='left', suffixes=('_th','_win'))

# 6) Determine above/below flags in-window (only where value exists)
df_thresh_window['is_above'] = df_thresh_window['value'].notna() & df_thresh_window['p95'].notna() & (df_thresh_window['value'] >= df_thresh_window['p95'])
df_thresh_window['is_below'] = df_thresh_window['value'].notna() & df_thresh_window['p5'].notna() & (df_thresh_window['value'] <= df_thresh_window['p5'])

# 7) Aggregate per group
agg = (
    df_thresh_window
    .groupby(['cmdb_id','trace_name'], as_index=False)
    .agg(
        p95=('p95','first'),
        p5=('p5','first'),
        full_series_max=('full_series_max','first'),
        count_above_p95_in_window=('is_above','sum'),
        earliest_above_secs=('timestamp','min'),
        max_value_in_window=('value','max'),
        count_below_p5_in_window=('is_below','sum'),
        earliest_below_secs=('timestamp','min'),
        min_value_in_window=('value','min')
    )
)

# 8) Normalize counts and format earliest timestamps to UTC+8 strings (nullable)
agg['count_above_p95_in_window'] = agg['count_above_p95_in_window'].fillna(0).astype(int)
agg['count_below_p5_in_window'] = agg['count_below_p5_in_window'].fillna(0).astype(int)

def fmt_ts_nullable(s):
    if pd.isna(s):
        return None
    return pd.to_datetime(int(s), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

agg['earliest_above_p95_timestamp'] = agg['earliest_above_secs'].apply(fmt_ts_nullable)
agg['earliest_below_p5_timestamp'] = agg['earliest_below_secs'].apply(fmt_ts_nullable)

# 9) Select required columns and compute sorting key
df_trace_from_frontend_grouped_all = agg[[
    'cmdb_id',
    'trace_name',
    'p95',
    'p5',
    'full_series_max',
    'count_above_p95_in_window',
    'earliest_above_p95_timestamp',
    'max_value_in_window',
    'count_below_p5_in_window',
    'earliest_below_p5_timestamp',
    'min_value_in_window'
]].copy()

df_trace_from_frontend_grouped_all['max_count'] = df_trace_from_frontend_grouped_all[['count_above_p95_in_window','count_below_p5_in_window']].max(axis=1)

df_trace_from_frontend_grouped_all_sorted = df_trace_from_frontend_grouped_all.sort_values(by=['max_count','full_series_max'], ascending=[False, False]).reset_index(drop=True).drop(columns=['max_count'])

# Store full grouped results in kernel variable for later steps
df_trace_from_frontend_grouped_all_sorted_full = df_trace_from_frontend_grouped_all_sorted

# Display compact top-20 table only
df_trace_from_frontend_grouped_all_sorted_full.head(20)
