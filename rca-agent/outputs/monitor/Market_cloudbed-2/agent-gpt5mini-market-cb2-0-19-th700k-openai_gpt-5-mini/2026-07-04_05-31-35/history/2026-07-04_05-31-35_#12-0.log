import pandas as pd
import pytz
import re

# Reuse existing df_metric and tz if available
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure timezone-aware datetime column for window filtering (UTC+8)
if 'ts_dt' not in df_metric.columns:
    df_metric['ts_dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Selection criteria:
# (cmdb_id == 'node-5') OR (kpi_name contains 'container.node-5')
mask_node5_scope = (df_metric['cmdb_id'] == 'node-5') | df_metric['kpi_name'].str.contains('container.node-5', na=False)

# Keywords (case-insensitive) to match in kpi_name
keywords = ['network', 'transmit', 'receive', 'error', 'err', 'retrans', 'tcp', 'udp', 'throttled']
pattern = '|'.join(re.escape(k) for k in keywords)
mask_keywords = df_metric['kpi_name'].notna() & df_metric['kpi_name'].str.contains(pattern, case=False, na=False)

# Combined mask
mask_combined = mask_node5_scope & mask_keywords

# Selected rows (store for potential later inspection)
df_node5_network_candidates = df_metric[mask_combined].copy()

# Identify distinct groups (cmdb_id, kpi_name) to analyze
groups_df = df_node5_network_candidates[['cmdb_id', 'kpi_name']].drop_duplicates()

# Compute global P95 per group using the full series (no time filtering) - rule: thresholds from full series
p95_df = (
    df_metric
    .merge(groups_df, on=['cmdb_id','kpi_name'], how='inner')
    .groupby(['cmdb_id','kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value':'p95'})
)

# Incident window (inclusive) in UTC+8
start_ts = pd.Timestamp('2022-03-20 13:00:00').tz_localize(tz)
end_ts = pd.Timestamp('2022-03-20 13:30:00').tz_localize(tz)
mask_window = (df_metric['ts_dt'] >= start_ts) & (df_metric['ts_dt'] <= end_ts)

# Windowed rows for the selected groups
df_window_selected = (
    df_metric[mask_window]
    .merge(groups_df, on=['cmdb_id','kpi_name'], how='inner')
    .copy()
)
df_window_selected['is_anom'] = False

# Merge p95 into windowed rows to evaluate anomalies
df_window_selected = df_window_selected.merge(p95_df, on=['cmdb_id','kpi_name'], how='left')
mask_has_value = df_window_selected['value'].notna() & df_window_selected['p95'].notna()
df_window_selected.loc[mask_has_value, 'is_anom'] = df_window_selected.loc[mask_has_value, 'value'] >= df_window_selected.loc[mask_has_value, 'p95']

# Aggregate anomaly metrics per group from windowed data
agg_window = (
    df_window_selected
    .groupby(['cmdb_id','kpi_name'], as_index=False)
    .agg(
        anomaly_count_in_window=('is_anom','sum'),
        earliest_anomaly_timestamp_secs=('timestamp', lambda s: s[df_window_selected.loc[s.index, 'is_anom']].min() if any(df_window_selected.loc[s.index, 'is_anom']) else pd.NA),
        max_value_in_window=('value','max')
    )
)

# Merge p95 (all groups) with aggregated window results to include groups with no window data
df_node5_network_grouped_all = p95_df.merge(agg_window, on=['cmdb_id','kpi_name'], how='left')

# Fill missing anomaly counts with 0; keep max_value_in_window as NaN if no window rows
df_node5_network_grouped_all['anomaly_count_in_window'] = df_node5_network_grouped_all['anomaly_count_in_window'].fillna(0).astype(int)

# Format earliest_anomaly_timestamp to UTC+8 string or None
def fmt_ts_nullable(s):
    if pd.isna(s):
        return None
    return pd.to_datetime(int(s), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

df_node5_network_grouped_all['earliest_anomaly_timestamp'] = df_node5_network_grouped_all['earliest_anomaly_timestamp_secs'].apply(fmt_ts_nullable)

# Select required columns
df_node5_network_grouped_all = df_node5_network_grouped_all[[
    'cmdb_id',
    'kpi_name',
    'p95',
    'anomaly_count_in_window',
    'earliest_anomaly_timestamp',
    'max_value_in_window'
]].copy()

