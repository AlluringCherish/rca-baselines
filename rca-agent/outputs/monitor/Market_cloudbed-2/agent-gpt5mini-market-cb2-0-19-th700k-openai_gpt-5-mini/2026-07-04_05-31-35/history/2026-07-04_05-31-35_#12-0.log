import pandas as pd
import pytz

# Timezone for all timestamp conversions (UTC+8)
tz = pytz.timezone('Asia/Shanghai')

# Load CSVs into DataFrames and keep in kernel variables
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')
df_log = pd.read_csv('log.csv')
df_error_logs = pd.read_csv('error_logs.csv')

# Helper to convert unix seconds to timezone-aware string (Asia/Shanghai)
def ts_range_to_strings(series):
    if series.dropna().empty:
        return None, None
    dt = pd.to_datetime(series.astype('int64'), unit='s', utc=True)
    dt = dt.dt.tz_convert(tz)
    mn = dt.min().strftime('%Y-%m-%d %H:%M:%S %Z')
    mx = dt.max().strftime('%Y-%m-%d %H:%M:%S %Z')
    return mn, mx

# Summaries
# metric.csv
metric_min_ts, metric_max_ts = ts_range_to_strings(df_metric['timestamp'])
metric_cmdb_ids = sorted(df_metric['cmdb_id'].dropna().unique())[:20]
metric_kpis = sorted(df_metric['kpi_name'].dropna().unique())[:20]
summary_metric = {
    'filename': 'metric.csv',
    'row_count': int(df_metric.shape[0]),
    'min_timestamp': metric_min_ts,
    'max_timestamp': metric_max_ts,
    'top_cmdb_ids': metric_cmdb_ids,
    'top_kpi_names': metric_kpis
}

# trace.csv
trace_min_ts, trace_max_ts = ts_range_to_strings(df_trace['timestamp'])
trace_cmdb_ids = sorted(df_trace['cmdb_id'].dropna().unique())[:20]
trace_kpis = sorted(df_trace['trace_name'].dropna().unique())[:20]
summary_trace = {
    'filename': 'trace.csv',
    'row_count': int(df_trace.shape[0]),
    'min_timestamp': trace_min_ts,
    'max_timestamp': trace_max_ts,
    'top_cmdb_ids': trace_cmdb_ids,
    'top_trace_names': trace_kpis
}

# log.csv
log_min_ts, log_max_ts = ts_range_to_strings(df_log['timestamp'])
log_cmdb_ids = sorted(df_log['cmdb_id'].dropna().unique())[:20]
log_kpis = sorted(df_log['log_name'].dropna().unique())[:20]
summary_log = {
    'filename': 'log.csv',
    'row_count': int(df_log.shape[0]),
    'min_timestamp': log_min_ts,
    'max_timestamp': log_max_ts,
    'top_cmdb_ids': log_cmdb_ids,
    'top_log_names': log_kpis
}

# error_logs.csv
err_min_ts, err_max_ts = ts_range_to_strings(df_error_logs['timestamp'])
err_cmdb_ids = sorted(df_error_logs['cmdb_id'].dropna().unique())[:20]
err_messages = list(pd.Series(df_error_logs['message'].dropna().unique())[:10])
summary_error_logs = {
    'filename': 'error_logs.csv',
    'row_count': int(df_error_logs.shape[0]),
    'min_timestamp': err_min_ts,
    'max_timestamp': err_max_ts,
    'top_cmdb_ids': err_cmdb_ids,
    'sample_messages': err_messages
}

# Display compact summaries only (as requested)
summary_metric, summary_trace, summary_log, summary_error_logs
