import pandas as pd
import pytz

# Reuse existing df_metric and tz from kernel
# If they are not present (fresh kernel), load them (defensive)
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# 1) Compute global P95 per (cmdb_id, kpi_name) using the full series (no time filtering)
p95_df = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'p95'})
)

# 2) Filter metric.csv to the incident time window March 20, 2022 13:00 to 13:30 (inclusive) in UTC+8
# Create timezone-aware datetimes for the filter
start_ts = pd.Timestamp('2022-03-20 13:00:00').tz_localize(tz)
end_ts = pd.Timestamp('2022-03-20 13:30:00').tz_localize(tz)

# Convert metric timestamps to timezone-aware datetimes for filtering
ts_dt = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
mask_window = (ts_dt >= start_ts) & (ts_dt <= end_ts)
df_metric_window = df_metric[mask_window].copy()
df_metric_window['ts_dt'] = pd.to_datetime(df_metric_window['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 3) For each group, count points in-window where value >= p95, earliest such timestamp, and max value in-window
# Aggregate max value per group in window (if any)
window_agg = (
    df_metric_window
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(max_value_in_window=('value', 'max'),
         total_points_in_window=('value', 'size'))
)

# Identify anomaly rows in-window by joining p95
anomalies_df = df_metric_window.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')
anomalies_df['is_anom'] = anomalies_df['value'] >= anomalies_df['p95']

# Aggregate anomaly counts and earliest anomaly timestamp (as integer seconds)
anomaly_agg = (
    anomalies_df[anomalies_df['is_anom']]
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(anomaly_count_in_window=('is_anom', 'sum'),
         earliest_anomaly_timestamp_secs=('timestamp', 'min'))
)

# Merge p95 (all groups) with window aggregates and anomaly aggregates to ensure all groups are included
df_metric_grouped_results = (
    p95_df
    .merge(window_agg, on=['cmdb_id', 'kpi_name'], how='left')
    .merge(anomaly_agg, on=['cmdb_id', 'kpi_name'], how='left')
)

# Fill missing counts with 0; keep max_value_in_window as NaN when no data in window
df_metric_grouped_results['anomaly_count_in_window'] = df_metric_grouped_results['anomaly_count_in_window'].fillna(0).astype(int)
df_metric_grouped_results['total_points_in_window'] = df_metric_grouped_results['total_points_in_window'].fillna(0).astype(int)

# Convert earliest_anomaly_timestamp_secs to timezone-aware string, keep NaN as None
def format_ts(s):
    if pd.isna(s):
        return None
    return pd.to_datetime(int(s), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

df_metric_grouped_results['earliest_anomaly_timestamp'] = df_metric_grouped_results['earliest_anomaly_timestamp_secs'].apply(format_ts)

# Select and order required columns
df_metric_grouped_results = df_metric_grouped_results[[
    'cmdb_id',
    'kpi_name',
    'p95',
    'anomaly_count_in_window',
    'earliest_anomaly_timestamp',
    'max_value_in_window'
]]

# Sort by anomaly_count_in_window desc, then max_value_in_window desc
df_metric_grouped_results_sorted = df_metric_grouped_results.sort_values(
    by=['anomaly_count_in_window', 'max_value_in_window'],
    ascending=[False, False]
).reset_index(drop=True)

# Store full grouped results in kernel variable for later steps
# (Already stored as df_metric_grouped_results_sorted; also keep original full results variable name)
df_metric_grouped_results_all = df_metric_grouped_results_sorted

# Display a compact top-20 table only
df_metric_grouped_results_all.head(20)
