import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')
large_inf = 1e9

# Reuse kernel variables: metric_df, window_merged, thresholds, trace_df, log_df, error_logs_df
# Ensure dt exists and tz-aware
for df in (metric_df, window_merged, trace_df, log_df, error_logs_df):
    if 'dt' not in df.columns:
        df['timestamp'] = pd.to_numeric(df['timestamp'], errors='coerce')
        df['dt'] = pd.to_datetime(df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    else:
        if df['dt'].dt.tz is None:
            df['dt'] = pd.to_datetime(df['dt'], utc=True).dt.tz_convert(tz)

# Candidate definitions and windows
candidates = {
    'checkoutservice-0_A': {
        'cmdb_ids': ['checkoutservice-0'],
        'start': pd.Timestamp('2022-03-20 15:04:00', tz=tz),
        'end':   pd.Timestamp('2022-03-20 15:06:00', tz=tz)
    },
    # Service-level adservice: aggregate cmdb_id 'adservice' and pods 'adservice-0/1/2'
    'adservice_B': {
        'cmdb_ids': ['adservice','adservice-0','adservice-1','adservice-2'],
        'start': pd.Timestamp('2022-03-20 15:23:00', tz=tz),
        'end':   pd.Timestamp('2022-03-20 15:27:00', tz=tz)
    },
    # Individual pods in B
    'adservice-0_B': {
        'cmdb_ids': ['adservice-0'],
        'start': pd.Timestamp('2022-03-20 15:23:00', tz=tz),
        'end':   pd.Timestamp('2022-03-20 15:27:00', tz=tz)
    },
    'adservice-1_B': {
        'cmdb_ids': ['adservice-1'],
        'start': pd.Timestamp('2022-03-20 15:23:00', tz=tz),
        'end':   pd.Timestamp('2022-03-20 15:27:00', tz=tz)
    },
    'adservice-2_B': {
        'cmdb_ids': ['adservice-2'],
        'start': pd.Timestamp('2022-03-20 15:23:00', tz=tz),
        'end':   pd.Timestamp('2022-03-20 15:27:00', tz=tz)
    }
}

# Helper: compute per-row breach_ratio (using row p95/p5 and value)
def row_breach_ratio(row):
    p95 = row.get('p95', np.nan)
    p5 = row.get('p5', np.nan)
    val = row.get('value', np.nan)
    # high
    if pd.notna(p95) and val >= p95:
        if p95 > 0:
            return (val - p95) / p95
        else:
            if val > p95:
                return large_inf
            else:
                return 0.0
    # low
    if pd.notna(p5) and val <= p5:
        if p5 > 0:
            return (p5 - val) / p5
        else:
            if val < p5:
                return large_inf
            else:
                return 0.0
    return 0.0

# Containers for outputs per candidate
outputs = {}

for name, meta in candidates.items():
    cmdb_ids = meta['cmdb_ids']
    start = meta['start']
    end = meta['end']
    window_label = name.split('_')[-1]  # A or B

    # Filter windowed metric rows for these cmdb_ids using window_merged (already has p95/p5 and anomaly flag)
    w = window_merged[
        (window_merged['dt'] >= start) & (window_merged['dt'] <= end) &
        (window_merged['cmdb_id'].isin(cmdb_ids))
    ].copy()

    # If candidate is a service aggregate (multiple cmdb_ids), we aggregate by kpi_name across cmdb_ids
    # Compute per-row breach_ratio for anomalies
    if w.shape[0] > 0:
        w['breach_ratio'] = w.apply(row_breach_ratio, axis=1)
    else:
        w['breach_ratio'] = pd.Series(dtype=float)

    # 1) Top 10 KPI names ranked by anomaly points within window
    # For service aggregate group by kpi_name across cmdb_ids; for single pod it's equivalent
    # total_points_in_window: count of rows for that kpi_name (across cmdb_ids)
    # anomaly_count_in_window: count where anomaly==True
    # earliest/latest anomaly timestamps, run_max/min values in window for that KPI (based on value)
    grouped = w.groupby('kpi_name')
    kpi_agg = grouped.agg(
        global_p95 = ('p95','max'),   # aggregated p95 across cmdb_ids: use max (conservative)
        global_p5  = ('p5','min'),    # aggregated p5 across cmdb_ids: use min
        total_points_in_window = ('value','size'),
        anomaly_count_in_window = ('anomaly',lambda x: int(x.fillna(False).sum())),
        earliest_anomaly_timestamp_in_window = ('dt', lambda x: x[x.index[x.to_series().index.isin(w.index)]][w['anomaly']].min() if True else np.nan),
        latest_anomaly_timestamp_in_window = ('dt', lambda x: x[x.index[x.to_series().index.isin(w.index)]][w['anomaly']].max() if True else np.nan),
        run_max_value_in_window = ('value','max'),
        run_min_value_in_window = ('value','min'),
        breach_ratio_max = ('breach_ratio','max')
    ).reset_index()

    # The lambda above for earliest/latest anomaly timestamps is overly complex; simpler approach:
    # compute earliest/latest only where anomaly True
    if 'anomaly' in w.columns:
        anomaly_rows = w[w['anomaly']==True].copy()
        an_ts = anomaly_rows.groupby('kpi_name').agg(
            earliest_anomaly_timestamp_in_window = ('dt','min'),
            latest_anomaly_timestamp_in_window = ('dt','max')
        ).reset_index()
        # merge into kpi_agg
        kpi_agg = kpi_agg.drop(columns=['earliest_anomaly_timestamp_in_window','latest_anomaly_timestamp_in_window'])
        kpi_agg = kpi_agg.merge(an_ts, on='kpi_name', how='left')
    else:
        kpi_agg['earliest_anomaly_timestamp_in_window'] = pd.NaT
        kpi_agg['latest_anomaly_timestamp_in_window'] = pd.NaT

    # Fill NaNs for counts with 0
    kpi_agg['total_points_in_window'] = kpi_agg['total_points_in_window'].fillna(0).astype(int)
    kpi_agg['anomaly_count_in_window'] = kpi_agg['anomaly_count_in_window'].fillna(0).astype(int)
    kpi_agg['breach_ratio_max'] = kpi_agg['breach_ratio_max'].replace({np.nan:0.0})

    # 1: top 10 by anomaly_count_in_window
    kpi_top10_by_count = kpi_agg.sort_values('anomaly_count_in_window', ascending=False).head(10).reset_index(drop=True)

    # 2) severity score = anomaly_count_in_window * max(1, breach_ratio_max)
    # Treat large_inf as inf for display but use numeric large_inf for sorting
    kpi_top10_by_count['breach_ratio_max_display'] = kpi_top10_by_count['breach_ratio_max'].replace({large_inf: np.inf})
    kpi_top10_by_count['severity_score'] = kpi_top10_by_count['anomaly_count_in_window'] * kpi_top10_by_count['breach_ratio_max'].clip(lower=1.0)
    kpi_top10_by_severity = kpi_top10_by_count.sort_values('severity_score', ascending=False).head(10)

    # Prepare display columns for metric outputs
    metric_display_count = kpi_top10_by_count[[
        'kpi_name','global_p95','global_p5','total_points_in_window','anomaly_count_in_window',
        'earliest_anomaly_timestamp_in_window','latest_anomaly_timestamp_in_window',
        'run_max_value_in_window','run_min_value_in_window'
    ]].copy().reset_index(drop=True)

    metric_display_severity = kpi_top10_by_severity[[
        'kpi_name','global_p95','global_p5','total_points_in_window','anomaly_count_in_window',
        'earliest_anomaly_timestamp_in_window','latest_anomaly_timestamp_in_window',
        'run_max_value_in_window','run_min_value_in_window','severity_score'
    ]].copy().reset_index(drop=True)
    # Convert any large_inf in severity_score to inf string for display clarity (but keep numeric)
    metric_display_severity['severity_score'] = metric_display_severity['severity_score'].replace({large_inf*np.max([1,1]): np.inf})

    # 3) Traces: filter trace_df in window for cmdb_ids and trace_name contains 'duration_p95' or 'error_rate'
    t = trace_df[
        (trace_df['dt'] >= start) & (trace_df['dt'] <= end) &
        (trace_df['cmdb_id'].isin(cmdb_ids)) &
        (trace_df['trace_name'].str.contains('duration_p95|error_rate', na=False))
    ].copy()
    t_sorted = t.sort_values('value', ascending=False).head(10)[['trace_name','cmdb_id','dt','value']].rename(columns={'dt':'timestamp'}).reset_index(drop=True)

    # 4a) log.csv entries within window for these cmdb_ids sorted by value desc
    lwin = log_df[
        (log_df['dt'] >= start) & (log_df['dt'] <= end) &
        (log_df['cmdb_id'].isin(cmdb_ids))
    ].copy()
    logs_top = lwin.sort_values('value', ascending=False).head(10)[['cmdb_id','log_name','dt','value']].rename(columns={'dt':'timestamp'}).reset_index(drop=True)

    # 4b) error_logs aggregation by message within window for these cmdb_ids (exact-second timestamps)
    ewin = error_logs_df[
        (error_logs_df['dt'] >= start) & (error_logs_df['dt'] <= end) &
        (error_logs_df['cmdb_id'].isin(cmdb_ids))
    ].copy()
    if 'message' in ewin.columns and ewin.shape[0] > 0:
