        count=('timestamp','size'),
        earliest_ts=('timestamp','min'),
        latest_ts=('timestamp','max')
    ).reset_index()

    samples = df_win.groupby('cmdb_id')['message'].apply(sample_msgs).rename('sample_messages').reset_index()
