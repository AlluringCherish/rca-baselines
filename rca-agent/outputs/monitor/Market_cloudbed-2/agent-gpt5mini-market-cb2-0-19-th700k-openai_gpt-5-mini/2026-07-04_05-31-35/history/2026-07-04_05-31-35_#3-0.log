import pandas as pd
import pytz

# reuse df_err if available, otherwise load
try:
    df_err
except NameError:
    df_err = pd.read_csv('error_logs.csv')

# ensure types
df_err['cmdb_id'] = df_err['cmdb_id'].astype(str)
if 'message' not in df_err.columns:
    df_err['message'] = ''
else:
    df_err['message'] = df_err['message'].astype(str)
df_err['timestamp'] = pd.to_numeric(df_err['timestamp'], errors='coerce').astype('Int64')

# timezone and window bounds (UTC+8)
tz = pytz.timezone('Asia/Shanghai')
start_epoch = int(pd.Timestamp('2022-03-20 09:30:00', tz=tz).tz_convert('UTC').timestamp())
end_epoch   = int(pd.Timestamp('2022-03-20 09:33:00', tz=tz).tz_convert('UTC').timestamp())

# target cmdb_ids
targets = ['frontend-0', 'frontend-1', 'frontend-2']

# filter to window and targets
mask_window = (df_err['timestamp'] >= start_epoch) & (df_err['timestamp'] <= end_epoch)
mask_targets = df_err['cmdb_id'].isin(targets)
df_win = df_err.loc[mask_window & mask_targets].copy()

# If empty, prepare empty result with required columns
if df_win.empty:
    df_results = pd.DataFrame(columns=[
        'cmdb_id','count','earliest_timestamp','latest_timestamp',
        'num_messages_with_500','num_messages_with_failed_to_retrieve_ads','sample_messages'
    ])
else:
    # group and aggregate
    def sample_msgs(series):
        return list(pd.Index(series.dropna().astype(str).unique())[:10])
    grp = df_win.groupby('cmdb_id', sort=False).agg(
        count = ('timestamp', 'size'),
        earliest_ts = ('timestamp', 'min'),
        latest_ts = ('timestamp', 'max'),
        sample_messages = ('message', sample_msgs),
        num_messages_with_500 = ('message', lambda s: int(s.str.contains('500', case=False, na=False).sum())),
        num_messages_with_failed_to_retrieve_ads = ('message', lambda s: int(s.str.contains('failed to retrieve ads', case=False, na=False).sum()))
    ).reset_index()

    # convert timestamps to ISO in UTC+8
    grp['earliest_timestamp'] = grp['earliest_ts'].apply(lambda t: pd.to_datetime(int(t), unit='s', utc=True).tz_convert(tz).isoformat())
    grp['latest_timestamp'] = grp['latest_ts'].apply(lambda t: pd.to_datetime(int(t), unit='s', utc=True).tz_convert(tz).isoformat())

    df_results = grp[[
        'cmdb_id','count','earliest_timestamp','latest_timestamp',
        'num_messages_with_500','num_messages_with_failed_to_retrieve_ads','sample_messages'
    ]]

# Ensure results include all three target rows (fill missing with zeros/nulls)
missing = [t for t in targets if t not in df_results['cmdb_id'].values]
if missing:
    for m in missing:
        df_results = pd.concat([df_results, pd.DataFrame([{
            'cmdb_id': m,
            'count': 0,
            'earliest_timestamp': None,
            'latest_timestamp': None,
            'num_messages_with_500': 0,
            'num_messages_with_failed_to_retrieve_ads': 0,
            'sample_messages': []
        }])], ignore_index=True)

# keep order consistent with targets
df_results['cmdb_id'] = df_results['cmdb_id'].astype(str)
df_results = pd.Categorical(df_results['cmdb_id'], categories=targets, ordered=True).to_frame().join(df_results.set_index('cmdb_id'), on=0).reset_index(drop=True)
df_results = df_results[['cmdb_id','count','earliest_timestamp','latest_timestamp','num_messages_with_500','num_messages_with_failed_to_retrieve_ads','sample_messages']]

# compact result for display
df_results
