import pandas as pd
import pytz

# Reuse existing dataframes and timezone if present
try:
    error_df
except NameError:
    error_df = pd.read_csv("error_logs.csv")

try:
    log_df
except NameError:
    log_df = pd.read_csv("log.csv")

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

frontends = ['frontend-0', 'frontend-1', 'frontend-2']

# --- Part 1: error_logs summary for frontends ---
# Filter error logs to the three frontends
err_front = error_df[error_df['cmdb_id'].isin(frontends)].copy()

# Ensure timezone-aware datetime column (UTC+8)
err_front['dt'] = pd.to_datetime(err_front['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Total rows and overall earliest/latest per cmdb_id
err_counts = err_front.groupby('cmdb_id').size().rename('total_error_rows').reset_index()
err_times = err_front.groupby('cmdb_id').agg(
    earliest_dt=('dt', 'min'),
    latest_dt=('dt', 'max')
).reset_index()
err_times['earliest_timestamp'] = err_times['earliest_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
err_times['latest_timestamp'] = err_times['latest_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')

# Top 5 distinct message snippets per cmdb_id with counts and earliest sample timestamp
# Truncate message snippet to first 200 chars for compactness
err_front['msg_snip'] = err_front['message'].astype(str).str.slice(0, 200)

msg_grp = (
    err_front
    .groupby(['cmdb_id', 'msg_snip'])
    .agg(count=('message', 'size'), earliest_dt=('dt', 'min'))
    .reset_index()
)
msg_grp['earliest_ts'] = msg_grp['earliest_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')

# For each cmdb_id, get top 5 messages by count desc then earliest asc
top_msgs_list = []
for cid, sub in msg_grp.groupby('cmdb_id'):
    top = sub.sort_values(by=['count', 'earliest_dt'], ascending=[False, True]).head(5)
    # compose compact representation: "snippet (count) [earliest_ts]"
    compact = "; ".join([f"{row.msg_snip} ({int(row.count)}) [{row.earliest_ts}]" for _, row in top.iterrows()])
    top_msgs_list.append({'cmdb_id': cid, 'top_messages': compact})

top_msgs_df = pd.DataFrame(top_msgs_list)

# Merge summaries into a compact table (one row per frontend)
error_summary_df = (
    pd.merge(err_counts, err_times[['cmdb_id', 'earliest_timestamp', 'latest_timestamp']], on='cmdb_id', how='right')
    .merge(top_msgs_df, on='cmdb_id', how='left')
)

# Ensure rows for all three frontends are present (fill zeros/nulls if absent)
for f in frontends:
    if f not in error_summary_df['cmdb_id'].values:
        error_summary_df = pd.concat([error_summary_df, pd.DataFrame([{
            'cmdb_id': f,
            'total_error_rows': 0,
            'earliest_timestamp': None,
            'latest_timestamp': None,
            'top_messages': None
        }])], ignore_index=True)

error_summary_df = error_summary_df[['cmdb_id', 'total_error_rows', 'earliest_timestamp', 'latest_timestamp', 'top_messages']]
error_summary_df = error_summary_df.sort_values('cmdb_id').reset_index(drop=True)

# --- Part 2: log.error_count summary for frontends in incident window ---
# Prepare timezone-aware dt for log_df
log_df['dt'] = pd.to_datetime(log_df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

start_dt = tz.localize(pd.Timestamp('2022-03-20 09:00:00'))
end_dt = tz.localize(pd.Timestamp('2022-03-20 09:30:00'))  # exclusive upper bound

log_front = log_df[
    (log_df['cmdb_id'].isin(frontends)) &
    (log_df['log_name'] == 'log.error_count') &
    (log_df['dt'] >= start_dt) &
    (log_df['dt'] < end_dt)
].copy()

# Aggregate per frontend
if log_front.shape[0] > 0:
    log_agg = log_front.groupby('cmdb_id').agg(
        sum_error_count_over_window=('value', 'sum'),
        max_error_count_minute=('value', 'max'),
        earliest_minute_with_error_count_gt0=('dt', lambda s: s[log_front.loc[s.index, 'value'] > 0].min() if any(log_front.loc[s.index, 'value'] > 0) else pd.NaT),
        number_of_minutes_with_error_count_gt0=('value', lambda v: (v > 0).sum())
    ).reset_index()
    # Format earliest timestamp
    def fmt_dt_maybe(x):
        if pd.isna(x) or x is pd.NaT:
            return None
        return pd.to_datetime(x).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z')
    log_agg['earliest_minute_with_error_count_gt0'] = log_agg['earliest_minute_with_error_count_gt0'].apply(fmt_dt_maybe)
    log_agg = log_agg[['cmdb_id', 'sum_error_count_over_window', 'max_error_count_minute', 'earliest_minute_with_error_count_gt0', 'number_of_minutes_with_error_count_gt0']]
else:
    # Return zeroed rows for each frontend if no data in window
    rows = []
    for f in frontends:
        rows.append({
            'cmdb_id': f,
            'sum_error_count_over_window': 0.0,
            'max_error_count_minute': 0.0,
            'earliest_minute_with_error_count_gt0': None,
            'number_of_minutes_with_error_count_gt0': 0
        })
    log_agg = pd.DataFrame(rows)

# Ensure one row per frontend in the order requested
log_summary_df = pd.DataFrame({'cmdb_id': frontends}).merge(log_agg, on='cmdb_id', how='left')
log_summary_df = log_summary_df.fillna({
    'sum_error_count_over_window': 0.0,
    'max_error_count_minute': 0.0,
    'earliest_minute_with_error_count_gt0': None,
    'number_of_minutes_with_error_count_gt0': 0
})

# Convert numeric columns to appropriate dtypes
log_summary_df['sum_error_count_over_window'] = log_summary_df['sum_error_count_over_window'].astype(float)
log_summary_df['max_error_count_minute'] = log_summary_df['max_error_count_minute'].astype(float)
log_summary_df['number_of_minutes_with_error_count_gt0'] = log_summary_df['number_of_minutes_with_error_count_gt0'].astype(int)

# Store intermediates for later steps
err_front, msg_grp, top_msgs_df, log_front, log_agg

# Return the two compact tables (error_summary_df and log_summary_df)
error_summary_df, log_summary_df
