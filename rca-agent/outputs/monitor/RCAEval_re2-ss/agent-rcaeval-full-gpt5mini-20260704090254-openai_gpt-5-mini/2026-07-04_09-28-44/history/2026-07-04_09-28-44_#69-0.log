import numpy as np
import pandas as pd

# Reuse df_metric from session; focus on requested services
services = ["carts","catalogue","orders","payment","user"]
df_m = df_metric[df_metric['cmdb_id'].isin(services)].copy()

# 1) Compute global P95 per (cmdb_id, kpi_name) using the full series (before any window filtering)
p95_df = (
    df_m.groupby(['cmdb_id', 'kpi_name'], dropna=False)['value']
    .agg(lambda s: float(np.percentile(s.dropna(), 95)) if s.dropna().size > 0 else np.nan)
    .reset_index()
    .rename(columns={'value': 'global_p95'})
)

# Merge global_p95 back
df_m = df_m.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# 2) Filter to the incident window (inclusive)
start = pd.to_datetime('2024-01-19 07:08:40', utc=True)
end = pd.to_datetime('2024-01-19 07:38:40', utc=True)
window_rows = df_m[(df_m['timestamp'] >= start) & (df_m['timestamp'] <= end)].copy()

# Exclude series with global_p95 == 0 or NaN; keep only rows for candidate series
window_rows = window_rows[window_rows['global_p95'].notna() & (window_rows['global_p95'] > 0)].copy()

if window_rows.empty:
    runs_top = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','run_start_timestamp','run_end_timestamp',
        'run_length_points','max_value_in_run','global_p95','severity_ratio'
    ])
else:
    # 3) Identify consecutive runs where value >= global_p95, per (cmdb_id,kpi_name)
    window_rows = window_rows.sort_values(['cmdb_id','kpi_name','timestamp']).copy()
    window_rows['exceed'] = window_rows['value'] >= window_rows['global_p95']

    # segment consecutive equal exceed boolean within each group
    window_rows['segment'] = window_rows.groupby(['cmdb_id','kpi_name'])['exceed'].apply(lambda s: (s != s.shift()).cumsum())

    # select only segments where exceed == True and aggregate each run
    exceed_rows = window_rows[window_rows['exceed']].copy()
    if exceed_rows.empty:
        runs_top = pd.DataFrame(columns=[
            'cmdb_id','kpi_name','run_start_timestamp','run_end_timestamp',
            'run_length_points','max_value_in_run','global_p95','severity_ratio'
        ])
    else:
        runs = (
            exceed_rows
            .groupby(['cmdb_id','kpi_name','segment'], as_index=False)
            .agg(
                run_start_timestamp=('timestamp','min'),
                run_end_timestamp=('timestamp','max'),
                run_length_points=('value','size'),
                max_value_in_run=('value','max'),
                global_p95=('global_p95','first')
            )
        )

        # severity ratio
        runs['severity_ratio'] = runs['max_value_in_run'] / runs['global_p95']

        # 4) sort and limit to top 20
        runs_top = runs.sort_values(['run_length_points','severity_ratio'], ascending=[False, False])[
            ['cmdb_id','kpi_name','run_start_timestamp','run_end_timestamp',
             'run_length_points','max_value_in_run','global_p95','severity_ratio']
        ].head(20).reset_index(drop=True)

# Display compact top runs
runs_top
