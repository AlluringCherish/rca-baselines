    ql_max_ts = pd.to_datetime(ql_row['timestamp']).isoformat()

summary = (
    f"queue-master diskio: earliest datapoint at {qm_earliest}, peak value {qm_max_val:.6g} at {qm_max_ts}; "
    f"queue-master log.row_count: earliest datapoint at {ql_earliest}, peak value {ql_max_val} at {ql_max_ts}."
)

summary
