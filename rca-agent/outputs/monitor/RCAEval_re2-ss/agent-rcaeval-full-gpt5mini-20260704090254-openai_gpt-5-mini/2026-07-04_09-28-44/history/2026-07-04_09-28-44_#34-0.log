import numpy as np
import pandas as pd

# Reuse metric_res and log_res from the kernel state
# Ensure copies so we don't mutate original objects
m = metric_res.copy()
l = log_res.copy()

# 1) Metrics: filter groups with exceedances
m_exceed = m[m['count_points_exceeding_p95'] > 0].copy()

# Safe breach_pct calculation handling zero global_p95
# breach_pct = 100*(max_value_in_window - global_p95)/global_p95
g = m_exceed['global_p95'].astype(float)
mx = m_exceed['max_value_in_window'].astype(float)

# compute breach_pct with safe division
breach_pct = pd.Series(np.nan, index=m_exceed.index, dtype=float)
nonzero_mask = g != 0
breach_pct[nonzero_mask] = 100.0 * (mx[nonzero_mask] - g[nonzero_mask]) / g[nonzero_mask]
# for zero global_p95, set to inf if max > 0, else 0
zero_mask = ~nonzero_mask
breach_pct[zero_mask] = np.where(mx[zero_mask] > g[zero_mask], np.inf, 0.0)

m_exceed['breach_pct'] = breach_pct
# Sort by breach_pct desc and select top 20
m_breach_sorted = m_exceed.sort_values(by='breach_pct', ascending=False).head(20)

# Round breach_pct to 2 decimals for compact display
m_breach_sorted['breach_pct'] = m_breach_sorted['breach_pct'].replace(np.inf, np.nan)  # show NaN for inf to keep compactness
m_breach_sorted['breach_pct'] = m_breach_sorted['breach_pct'].round(2)

metric_breach_res = m_breach_sorted[[
    'cmdb_id','kpi_name','global_p95','max_value_in_window',
    'count_points_exceeding_p95','earliest_timestamp_exceeding_p95','breach_pct'
]].reset_index(drop=True)

# Count metric groups with breach_pct > 50
# Recompute using original numeric (treat inf as >50)
count_breach_gt_50 = int(((m_exceed['breach_pct'] > 50) | (np.isinf(m_exceed['breach_pct']))).sum())

# 2) Logs: return rows with exceedances (limit 20)
log_exceeds = l[l['count_points_exceeding_p95'] > 0].copy()
log_exceeds_res = log_exceeds[[
    'cmdb_id','log_name','global_p95','max_value_in_window',
    'count_points_exceeding_p95','earliest_timestamp_exceeding_p95'
]].sort_values(by=['count_points_exceeding_p95','max_value_in_window'], ascending=[False, False]).head(20).reset_index(drop=True)

# Final compact outputs
metric_breach_res, count_breach_gt_50, log_exceeds_res
