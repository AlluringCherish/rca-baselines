import pandas as pd
import numpy as np

# Load metric and log data (reuse variable names where reasonable)
metric_df = pd.read_csv("metric.csv")
metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True)

log_df = pd.read_csv("log.csv")
log_df['timestamp'] = pd.to_datetime(log_df['timestamp'], unit='s', utc=True)

# Incident window (UTC)
start = pd.to_datetime("2024-01-19 23:14:06+00:00", utc=True)
end = pd.to_datetime("2024-01-19 23:44:06+00:00", utc=True)

# --- Metrics processing ---
# 1) compute global P95 per (cmdb_id, kpi_name) using entire series
metric_p95 = (
    metric_df
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# 2) filter metric rows to incident window
metric_window = metric_df[(metric_df['timestamp'] >= start) & (metric_df['timestamp'] <= end)].copy()

# attach global_p95 to window rows (for exceed detection)
metric_win_merged = metric_window.merge(metric_p95, on=['cmdb_id', 'kpi_name'], how='left')

# aggregate window stats per group
if not metric_win_merged.empty:
    agg_win = (
        metric_win_merged
        .assign(exceed=lambda d: d['value'] > d['global_p95'])
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)
        .agg(
            total_points_in_window=('value', 'size'),
            count_points_exceeding_p95=('exceed', 'sum'),
            earliest_timestamp_exceeding_p95=('timestamp', lambda s: s[d.loc[s.index, 'exceed']].min() if True else pd.NaT), # placeholder replaced below
            max_value_in_window=('value', 'max')
        )
    )
    # Compute earliest_timestamp_exceeding_p95 robustly
    # Build series of earliest timestamps where value > global_p95
    exceed_rows = metric_win_merged[metric_win_merged['value'] > metric_win_merged['global_p95']]
    earliest_ts = exceed_rows.groupby(['cmdb_id', 'kpi_name'], as_index=False)['timestamp'].min().rename(columns={'timestamp':'earliest_timestamp_exceeding_p95'})
    agg_win = agg_win.drop(columns=['earliest_timestamp_exceeding_p95']).merge(earliest_ts, on=['cmdb_id','kpi_name'], how='left')
else:
    # empty window -> empty aggregated
    agg_win = pd.DataFrame(columns=['cmdb_id','kpi_name','total_points_in_window','count_points_exceeding_p95','max_value_in_window','earliest_timestamp_exceeding_p95'])

# Now left-join p95 table with aggregated window stats so every group is present
metric_summary_df = metric_p95.merge(agg_win, on=['cmdb_id','kpi_name'], how='left')

# Fill NaNs for groups with no points in window
metric_summary_df['total_points_in_window'] = metric_summary_df['total_points_in_window'].fillna(0).astype(int)
metric_summary_df['count_points_exceeding_p95'] = metric_summary_df['count_points_exceeding_p95'].fillna(0).astype(int)
metric_summary_df['max_value_in_window'] = metric_summary_df['max_value_in_window'].astype(float)  # NaN remains if none
# earliest_timestamp_exceeding_p95 stays NaT if missing

# reorder columns
metric_summary_df = metric_summary_df[['cmdb_id','kpi_name','global_p95','total_points_in_window',
                                       'count_points_exceeding_p95','earliest_timestamp_exceeding_p95','max_value_in_window']]

# sort and take top 20
metric_res = metric_summary_df.sort_values(
    by=['count_points_exceeding_p95','max_value_in_window'], ascending=[False, False]
).head(20).reset_index(drop=True)

# Count how many distinct cmdb_id-kpi groups had any exceedances
metric_exceed_count = int((metric_summary_df['count_points_exceeding_p95'] > 0).sum())

# --- Logs processing (similar) ---
log_p95 = (
    log_df
    .groupby(['cmdb_id', 'log_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

log_window = log_df[(log_df['timestamp'] >= start) & (log_df['timestamp'] <= end)].copy()
log_win_merged = log_window.merge(log_p95, on=['cmdb_id','log_name'], how='left')

if not log_win_merged.empty:
    log_win_merged = log_win_merged.assign(exceed=lambda d: d['value'] > d['global_p95'])
    agg_log_win = (
        log_win_merged
        .groupby(['cmdb_id','log_name'], as_index=False)
        .agg(
            total_points_in_window=('value','size'),
            count_points_exceeding_p95=('exceed','sum'),
            max_value_in_window=('value','max')
        )
    )
    exceed_log_rows = log_win_merged[log_win_merged['value'] > log_win_merged['global_p95']]
    earliest_log_ts = exceed_log_rows.groupby(['cmdb_id','log_name'], as_index=False)['timestamp'].min().rename(columns={'timestamp':'earliest_timestamp_exceeding_p95'})
    agg_log_win = agg_log_win.merge(earliest_log_ts, on=['cmdb_id','log_name'], how='left')
else:
    agg_log_win = pd.DataFrame(columns=['cmdb_id','log_name','total_points_in_window','count_points_exceeding_p95','max_value_in_window','earliest_timestamp_exceeding_p95'])

log_summary_df = log_p95.merge(agg_log_win, on=['cmdb_id','log_name'], how='left')
log_summary_df['total_points_in_window'] = log_summary_df['total_points_in_window'].fillna(0).astype(int)
log_summary_df['count_points_exceeding_p95'] = log_summary_df['count_points_exceeding_p95'].fillna(0).astype(int)
log_summary_df['max_value_in_window'] = log_summary_df['max_value_in_window'].astype(float)

log_summary_df = log_summary_df[['cmdb_id','log_name','global_p95','total_points_in_window',
                                 'count_points_exceeding_p95','earliest_timestamp_exceeding_p95','max_value_in_window']]

log_res = log_summary_df.sort_values(by=['count_points_exceeding_p95','max_value_in_window'], ascending=[False, False]).head(20).reset_index(drop=True)
log_exceed_count = int((log_summary_df['count_points_exceeding_p95'] > 0).sum())

# Final compact outputs
metric_res, log_res, metric_exceed_count, log_exceed_count
