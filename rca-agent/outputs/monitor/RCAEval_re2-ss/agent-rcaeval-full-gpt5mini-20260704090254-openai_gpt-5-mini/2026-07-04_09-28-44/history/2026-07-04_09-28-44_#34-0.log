import pandas as pd
import numpy as np

# Reuse existing dataframes if present; otherwise load and parse
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")
try:
    log_df
except NameError:
    log_df = pd.read_csv("log.csv")

# Ensure timestamps are parsed as UTC datetimes
metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True)
log_df['timestamp'] = pd.to_datetime(log_df['timestamp'], unit='s', utc=True)

# Incident window (UTC)
start = pd.to_datetime("2024-01-19 23:14:06+00:00", utc=True)
end = pd.to_datetime("2024-01-19 23:44:06+00:00", utc=True)

# 1) Metrics: queue-master, diskio
q_metric = metric_df[
    (metric_df['cmdb_id'] == 'queue-master') &
    (metric_df['kpi_name'] == 'diskio') &
    (metric_df['timestamp'] >= start) &
    (metric_df['timestamp'] <= end)
].loc[:, ['timestamp','value']].sort_values('timestamp').reset_index(drop=True)

q_metric_table = q_metric.head(20)

# 2) Logs: queue-master, log.row_count
q_log = log_df[
    (log_df['cmdb_id'] == 'queue-master') &
    (log_df['log_name'] == 'log.row_count') &
    (log_df['timestamp'] >= start) &
    (log_df['timestamp'] <= end)
].loc[:, ['timestamp','value']].sort_values('timestamp').reset_index(drop=True)

q_log_table = q_log.head(20)

# Summaries: earliest timestamp and max value for each table
def earliest_and_max(df):
    if df.empty:
        return pd.NaT, np.nan
    return df['timestamp'].min(), df['value'].max()

metric_earliest_ts, metric_max_val = earliest_and_max(q_metric_table)
log_earliest_ts, log_max_val = earliest_and_max(q_log_table)

def ts_to_str(ts):
    return ts.isoformat() if pd.notna(ts) else "NaT"

summary = (
    f"queue-master diskio -> earliest: {ts_to_str(metric_earliest_ts)}, max: {metric_max_val}\n"
    f"queue-master log.row_count -> earliest: {ts_to_str(log_earliest_ts)}, max: {log_max_val}"
)

# Display compact results
q_metric_table, q_log_table, summary
