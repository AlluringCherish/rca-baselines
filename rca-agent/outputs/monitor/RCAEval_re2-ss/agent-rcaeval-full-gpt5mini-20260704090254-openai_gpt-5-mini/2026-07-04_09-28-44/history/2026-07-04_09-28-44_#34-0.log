import pandas as pd
# Reuse metric_res and log_res from kernel state
m = metric_res.copy()
l = log_res.copy()

# Filter only groups with exceedances
m_exc = m[m['count_points_exceeding_p95'] > 0].copy()
l_exc = l[l['count_points_exceeding_p95'] > 0].copy()

# For metrics: get earliest exceed timestamp per cmdb_id and the corresponding kpi_name
if not m_exc.empty:
    m_exc_sorted = m_exc.sort_values(['cmdb_id','earliest_timestamp_exceeding_p95'])
    metric_earliest = m_exc_sorted.drop_duplicates(subset=['cmdb_id'], keep='first')[
        ['cmdb_id','earliest_timestamp_exceeding_p95','kpi_name']
    ].rename(columns={
        'earliest_timestamp_exceeding_p95':'earliest_metric_exceeding_timestamp',
        'kpi_name':'metric_kpi_of_earliest_metric_exceed'
    }).reset_index(drop=True)
else:
    metric_earliest = pd.DataFrame(columns=[
        'cmdb_id','earliest_metric_exceeding_timestamp','metric_kpi_of_earliest_metric_exceed'
    ])

# For logs: get earliest exceed timestamp per cmdb_id and corresponding log_name
if not l_exc.empty:
    l_exc_sorted = l_exc.sort_values(['cmdb_id','earliest_timestamp_exceeding_p95'])
    log_earliest = l_exc_sorted.drop_duplicates(subset=['cmdb_id'], keep='first')[
        ['cmdb_id','earliest_timestamp_exceeding_p95','log_name']
    ].rename(columns={
        'earliest_timestamp_exceeding_p95':'earliest_log_exceeding_timestamp',
        'log_name':'log_name_of_earliest_log_exceed'
    }).reset_index(drop=True)
else:
    log_earliest = pd.DataFrame(columns=[
        'cmdb_id','earliest_log_exceeding_timestamp','log_name_of_earliest_log_exceed'
    ])

# Outer join on cmdb_id to include services with either type of exceedance
timeline = pd.merge(metric_earliest, log_earliest, on='cmdb_id', how='outer')

# Compute earliest_any_exceeding_timestamp as row-wise minimum of the two timestamps
def row_min_timestamp(row):
    ts1 = row.get('earliest_metric_exceeding_timestamp')
    ts2 = row.get('earliest_log_exceeding_timestamp')
    # Both may be NaT; handle accordingly
    if pd.isna(ts1) and pd.isna(ts2):
        return pd.NaT
    if pd.isna(ts1):
        return ts2
    if pd.isna(ts2):
        return ts1
    return min(ts1, ts2)

timeline['earliest_any_exceeding_timestamp'] = timeline.apply(row_min_timestamp, axis=1)

# Sort by earliest_any_exceeding_timestamp ascending and limit to 20 rows
