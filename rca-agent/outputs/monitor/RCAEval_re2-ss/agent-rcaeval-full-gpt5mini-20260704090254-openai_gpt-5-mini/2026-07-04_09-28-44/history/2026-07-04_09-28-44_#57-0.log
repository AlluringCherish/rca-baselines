import pandas as pd

# Ensure metric_df and metric_groups exist in kernel; if not, load and compute them.
if 'metric_df' not in globals() or 'metric_groups' not in globals():
    metric_df = pd.read_csv('metric.csv')
    metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True)
    metric_df['value'] = pd.to_numeric(metric_df['value'], errors='coerce')
    agg_values = metric_df.groupby(['cmdb_id', 'kpi_name'])['value'].agg(
        count='count',
        mean='mean',
        std='std',
        p95=lambda x: x.quantile(0.95)
    ).reset_index()
    agg_timestamps = metric_df.groupby(['cmdb_id', 'kpi_name'])['timestamp'].agg(
        min_timestamp='min',
        max_timestamp='max'
    ).reset_index()
    metric_groups = pd.merge(agg_values, agg_timestamps, on=['cmdb_id', 'kpi_name'])
    metric_groups = metric_groups[['cmdb_id', 'kpi_name', 'count', 'min_timestamp', 'max_timestamp', 'mean', 'std', 'p95']]

# Incident window (UTC)
start = pd.to_datetime('2024-01-19 07:35:25', utc=True)
end = pd.to_datetime('2024-01-19 08:05:25', utc=True)

# Make sure timestamps in metric_df are datetimes with UTC
metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True)

# Filter metric_df to the incident window (inclusive)
metric_window = metric_df[(metric_df['timestamp'] >= start) & (metric_df['timestamp'] <= end)].copy()

# Prepare groups with global P95 thresholds (from metric_groups)
groups_df = metric_groups[['cmdb_id', 'kpi_name', 'p95']].copy()

# Left-merge groups with metric_window so groups with no rows in window are kept
merged = groups_df.merge(metric_window, on=['cmdb_id', 'kpi_name'], how='left', validate='many_to_many', suffixes=('', '_m'))

# Define computation per group
def compute_group(df):
    p95 = df['p95'].iloc[0]
    vals = df['value']
    times = df['timestamp']
    # anomaly mask: value >= p95 (NaNs -> False)
    mask = vals >= p95
    anomaly_count = int(mask.sum())
    earliest_anom = times[mask].min() if anomaly_count > 0 else pd.NaT
    # max value in window for this group (NaN if no rows)
    max_val = vals.max() if vals.notna().any() else float('nan')
    severity = (max_val - p95) / max(p95, 1e-12) if pd.notna(max_val) else float('nan')
    return pd.Series({
        'p95_threshold': p95,
        'anomaly_count_in_window': anomaly_count,
        'earliest_anomaly_timestamp': earliest_anom,
        'max_value_in_window': max_val,
        'severity_ratio': severity
    })

anomalies_df = merged.groupby(['cmdb_id', 'kpi_name', 'p95'], sort=False).apply(compute_group).reset_index(drop=False)

# Ensure correct column names and types
anomalies_df = anomalies_df[['cmdb_id', 'kpi_name', 'p95_threshold', 'anomaly_count_in_window', 'earliest_anomaly_timestamp', 'max_value_in_window', 'severity_ratio']]

# For sorting, treat NaNs in numeric severity as -inf so they appear later; but do not modify anomalies_df itself.
anomalies_for_sort = anomalies_df.fillna({'anomaly_count_in_window': 0, 'severity_ratio': -1e18})

anomalies_top20 = anomalies_df.loc[anomalies_for_sort.sort_values(['anomaly_count_in_window', 'severity_ratio'], ascending=[False, False]).head(20).index].reset_index(drop=True)

anomalies_top20
