import pandas as pd

# Load CSVs
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")
log_df = pd.read_csv("log.csv")
error_logs_df = pd.read_csv("error_logs.csv")

# Parse timestamps as UTC datetimes (Unix seconds)
metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True)
trace_df['timestamp'] = pd.to_datetime(trace_df['timestamp'], unit='s', utc=True)
log_df['timestamp'] = pd.to_datetime(log_df['timestamp'], unit='s', utc=True)
error_logs_df['timestamp'] = pd.to_datetime(error_logs_df['timestamp'], unit='s', utc=True)

# 1) metric.csv: group by cmdb_id and kpi_name and compute stats (global on full series)
metric_grp = metric_df.groupby(['cmdb_id', 'kpi_name'], as_index=False)

# basic aggregations
metric_stats = metric_grp.agg(
    count=('value', 'count'),
    min_timestamp=('timestamp', 'min'),
    max_timestamp=('timestamp', 'max'),
    mean=('value', 'mean'),
    std=('value', 'std')
)

# p95 per group (quantile on full series)
metric_p95 = metric_grp['value'].quantile(0.95).reset_index(name='p95')

# merge
metric_grouped_full = metric_stats.merge(metric_p95, on=['cmdb_id', 'kpi_name'])

# sort and keep top 20 for display
metric_grouped_top20 = metric_grouped_full.sort_values('count', ascending=False).head(20)[
    ['cmdb_id', 'kpi_name', 'count', 'min_timestamp', 'max_timestamp', 'mean', 'std', 'p95']
]

# 2) trace.csv: unique trace_name with counts and stats
trace_grp = trace_df.groupby(['trace_name'], as_index=False)

trace_stats = trace_grp.agg(
    count=('value', 'count'),
    min_timestamp=('timestamp', 'min'),
    max_timestamp=('timestamp', 'max'),
    mean_value=('value', 'mean')
)

trace_p95 = trace_grp['value'].quantile(0.95).reset_index(name='p95_value')

trace_grouped_full = trace_stats.merge(trace_p95, on='trace_name')

trace_grouped_top20 = trace_grouped_full.sort_values('count', ascending=False).head(20)[
    ['trace_name', 'count', 'min_timestamp', 'max_timestamp', 'mean_value', 'p95_value']
]

# 3) log.csv: unique log_name with counts and stats
log_grp = log_df.groupby(['log_name'], as_index=False)

log_stats = log_grp.agg(
    count=('value', 'count'),
    min_timestamp=('timestamp', 'min'),
    max_timestamp=('timestamp', 'max'),
    mean_value=('value', 'mean')
)

log_p95 = log_grp['value'].quantile(0.95).reset_index(name='p95_value')

log_grouped_full = log_stats.merge(log_p95, on='log_name')

log_grouped_top20 = log_grouped_full.sort_values('count', ascending=False).head(20)[
    ['log_name', 'count', 'min_timestamp', 'max_timestamp', 'mean_value', 'p95_value']
]

# 4) error_logs.csv: total row count and top 10 rows for inspection
error_count = len(error_logs_df)
# select and show top 10 rows (keep timestamp as datetime, keep order as-is)
error_top10 = error_logs_df[['timestamp', 'cmdb_id', 'message']].head(10)

# Display compact summaries (keep full grouped DataFrames in kernel variables as requested)
metric_grouped_top20, trace_grouped_top20, log_grouped_top20, error_count, error_top10
