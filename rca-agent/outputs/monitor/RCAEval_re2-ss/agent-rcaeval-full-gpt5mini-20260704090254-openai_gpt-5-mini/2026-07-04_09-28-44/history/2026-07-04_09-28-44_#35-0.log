import pandas as pd

# Load CSVs
df_metric = pd.read_csv("metric.csv")
df_trace = pd.read_csv("trace.csv")
df_log = pd.read_csv("log.csv")
df_err = pd.read_csv("error_logs.csv")

# Parse timestamps as UTC datetimes (unit='s', utc=True)
df_metric['timestamp'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)
df_trace['timestamp'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True)
df_log['timestamp'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True)
df_err['timestamp'] = pd.to_datetime(df_err['timestamp'], unit='s', utc=True)

# 1) Metric aggregates across the full file (global thresholds computed here)
metric_agg = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(
        count='count',
        min='min',
        max='max',
        mean='mean',
        p50=lambda x: x.quantile(0.5),
        p95=lambda x: x.quantile(0.95)
    )
    .reset_index()
    .sort_values('count', ascending=False)
)

metric_agg_top20 = metric_agg.head(20)

# 2) Trace: unique (cmdb_id, trace_name) pairs and up to 20 example rows
trace_pairs = df_trace[['cmdb_id', 'trace_name']].drop_duplicates().reset_index(drop=True)
trace_pairs_head20 = trace_pairs.head(20)

trace_sample = df_trace.loc[:, ['timestamp', 'cmdb_id', 'trace_name', 'value']].sort_values('timestamp').head(20)

# 3) Log: unique (cmdb_id, log_name) pairs and up to 20 example rows
log_pairs = df_log[['cmdb_id', 'log_name']].drop_duplicates().reset_index(drop=True)
log_pairs_head20 = log_pairs.head(20)

log_sample = df_log.loc[:, ['timestamp', 'cmdb_id', 'log_name', 'value']].sort_values('timestamp').head(20)

# 4) Error logs: counts per cmdb_id (top 20) and up to 5 sample messages per cmdb_id that has messages
error_counts = df_err.groupby('cmdb_id').size().reset_index(name='count').sort_values('count', ascending=False)
error_counts_top20 = error_counts.head(20).reset_index(drop=True)

# Prepare up to 5 sample messages per cmdb_id (for those with messages). Limit output to top20 cmdb_ids for display.
def sample_messages(group):
    # take up to 5 messages in timestamp order
    msgs = group.sort_values('timestamp')['message'].dropna().astype(str).head(5).tolist()
    return " || ".join(msgs) if msgs else ""

err_samples_all = (
    df_err
    .groupby('cmdb_id')
    .apply(sample_messages)
    .reset_index(name='sample_messages')
)

# Join sample messages with top20 counts
error_samples = error_counts_top20.merge(err_samples_all, on='cmdb_id', how='left')

# Final compact outputs (variables displayed)
metric_agg_top20, trace_pairs_head20, trace_sample, log_pairs_head20, log_sample, error_counts_top20, error_samples
