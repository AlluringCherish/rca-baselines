import pandas as pd
import numpy as np

# Reuse metric if already loaded in the session; otherwise read and parse timestamps
try:
    metric
except NameError:
    metric = pd.read_csv("metric.csv")
    metric['timestamp'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)

# Ensure timestamp is datetime UTC
if not pd.api.types.is_datetime64_any_dtype(metric['timestamp']):
    metric['timestamp'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)

# 1) Compute global P95 and P05 per (cmdb_id, kpi_name) using full series (must be done BEFORE window filtering)
thresholds = (
    metric
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .agg(global_p95=lambda x: x.quantile(0.95), global_p05=lambda x: x.quantile(0.05))
)

# 2) Define incident window (UTC) and filter metric rows to the window
start_ts = pd.Timestamp("2024-01-21 06:28:36", tz="UTC")
end_ts   = pd.Timestamp("2024-01-21 06:58:36", tz="UTC")
window = metric[(metric['timestamp'] >= start_ts) & (metric['timestamp'] <= end_ts)].copy()

# 3) Aggregate per (cmdb_id, kpi_name) present in the window
if not window.empty:
    grp = window.groupby(['cmdb_id', 'kpi_name'], as_index=False)
    agg_basic = grp['value'].agg(window_count='count', window_max='max', window_min='min')
    
    # earliest timestamp where value equals window_max or window_min
    def earliest_extreme_timestamp(df):
        vmax = df['value'].max()
        vmin = df['value'].min()
        extremes = df[(df['value'] == vmax) | (df['value'] == vmin)]
        if extremes.empty:
            return pd.NaT
        return extremes['timestamp'].min()
    
    earliest = grp.apply(earliest_extreme_timestamp).reset_index().rename(columns={0: 'earliest_timestamp_of_window_extreme'})
    # Merge
    agg = agg_basic.merge(earliest, on=['cmdb_id', 'kpi_name'], how='left')
    
    # 4) Merge global thresholds (computed earlier)
    agg = agg.merge(thresholds, on=['cmdb_id', 'kpi_name'], how='left')
    
    # 5) Compute breach percentages with safe divisions
    # max_breach_pct = (window_max - global_p95)/global_p95 if window_max > global_p95 else 0
    # min_breach_pct = (global_p05 - window_min)/global_p05 if window_min < global_p05 and global_p05>0 else 0
    def safe_div(numer, denom):
        if denom is None or denom == 0 or pd.isna(denom):
            return 0.0
        return numer / denom

    # Vectorized computation with conditions
    agg['max_breach_pct'] = np.where(
        agg['window_max'] > agg['global_p95'],
        (agg['window_max'] - agg['global_p95']) / agg['global_p95'].where(agg['global_p95'] != 0, np.nan),
        0.0
    )
    # replace inf/nan resulting from division by zero with 0.0
    agg['max_breach_pct'] = agg['max_breach_pct'].replace([np.inf, -np.inf], 0).fillna(0.0)

    agg['min_breach_pct'] = np.where(
        (agg['window_min'] < agg['global_p05']) & (agg['global_p05'] > 0),
        (agg['global_p05'] - agg['window_min']) / agg['global_p05'],
        0.0
    )
    agg['min_breach_pct'] = agg['min_breach_pct'].replace([np.inf, -np.inf], 0).fillna(0.0)

    agg['peak_breach_pct'] = agg[['max_breach_pct', 'min_breach_pct']].max(axis=1)

    # 6) Format earliest timestamp and round numeric columns for compactness
    agg['earliest_timestamp_of_window_extreme_utc'] = pd.to_datetime(agg['earliest_timestamp_of_window_extreme'], utc=True).dt.strftime('%Y-%m-%dT%H:%M:%SZ')
    agg['earliest_timestamp_of_window_extreme_utc'] = agg['earliest_timestamp_of_window_extreme_utc'].where(agg['earliest_timestamp_of_window_extreme'].notna(), None)

    agg['global_p95'] = agg['global_p95'].round(6)
    agg['global_p05'] = agg['global_p05'].round(6)
    agg['window_max'] = agg['window_max'].round(6)
    agg['window_min'] = agg['window_min'].round(6)
    agg['peak_breach_pct'] = agg['peak_breach_pct'].round(6)

    # 7) Select columns and sort by peak_breach_pct desc, limit top 20
    result = agg[['cmdb_id', 'kpi_name', 'global_p95', 'global_p05',
                  'window_count', 'window_max', 'window_min',
                  'peak_breach_pct', 'earliest_timestamp_of_window_extreme_utc']].sort_values(
        by='peak_breach_pct', ascending=False
    ).reset_index(drop=True).head(20)
else:
    # No rows in window -> empty result with expected columns
    result = pd.DataFrame(columns=['cmdb_id', 'kpi_name', 'global_p95', 'global_p05',
                                   'window_count', 'window_max', 'window_min',
                                   'peak_breach_pct', 'earliest_timestamp_of_window_extreme_utc'])

# Display compact CSV-like table
result
