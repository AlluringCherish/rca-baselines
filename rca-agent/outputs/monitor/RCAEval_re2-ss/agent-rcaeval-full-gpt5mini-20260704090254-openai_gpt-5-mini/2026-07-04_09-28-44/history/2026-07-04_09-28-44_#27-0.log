df_win = df_cand[(df_cand['timestamp_dt'] >= window_start) & (df_cand['timestamp_dt'] <= window_end)].copy()

# If no data in window, return empty results and message
if df_win.empty:
    selected_rows = pd.DataFrame(columns=[
