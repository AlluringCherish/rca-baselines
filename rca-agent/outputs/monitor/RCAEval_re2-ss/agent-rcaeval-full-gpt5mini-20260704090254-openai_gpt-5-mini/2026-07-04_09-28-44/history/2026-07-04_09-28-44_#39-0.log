# Compute requested exceedance/severity table for candidate services using metric.csv
import pandas as pd
candidates = ["carts","catalogue","orders","payment","user"]

# Incident window (UTC)
start_ts = pd.Timestamp("2024-01-19 06:01:32", tz="UTC")
end_ts   = pd.Timestamp("2024-01-19 06:31:32", tz="UTC")

# 1) Global P95 per (cmdb_id,kpi_name) for candidate cmdb_ids using full metric_df
p95_candidates = (
    metric_df[metric_df['cmdb_id'].isin(candidates)]
    .groupby(['cmdb_id','kpi_name'])['value']
    .quantile(0.95)
    .reset_index(name='series_global_p95')
)

# Count of candidate series examined
total_candidate_series_examined = p95_candidates.shape[0]

# 2) Filter metric to the incident window and candidate cmdb_ids
metric_window_candidates = metric_df[
    (metric_df['dt'] >= start_ts) & (metric_df['dt'] <= end_ts) & (metric_df['cmdb_id'].isin(candidates))
].copy()

# Merge global P95 into windowed points
metric_window_candidates = metric_window_candidates.merge(
    p95_candidates, on=['cmdb_id','kpi_name'], how='left'
)

# Mark exceedances using strict '>' as requested
metric_window_candidates['exceed'] = metric_window_candidates['value'] > metric_window_candidates['series_global_p95']

# Aggregate per series present in window
def agg_group(g):
    total = int(g.shape[0])
    count_exc = int(g['exceed'].sum())
    earliest_exc = g.loc[g['exceed'], 'dt'].min() if count_exc>0 else pd.NaT
    maxv = float(g['value'].max()) if total>0 else float('nan')
    p95 = float(g['series_global_p95'].iloc[0]) if 'series_global_p95' in g.columns else float('nan')
    return pd.Series({
        'total_points_in_window': total,
        'count_exceedances': count_exc,
        'earliest_exceedance_timestamp_utc': earliest_exc,
        'max_value_in_window': maxv,
        'series_global_p95': p95
    })

if metric_window_candidates.shape[0] > 0:
    agg_window = metric_window_candidates.groupby(['cmdb_id','kpi_name']).apply(agg_group).reset_index()
else:
    agg_window = pd.DataFrame(columns=['cmdb_id','kpi_name','total_points_in_window','count_exceedances',
                                       'earliest_exceedance_timestamp_utc','max_value_in_window','series_global_p95'])

# 2b) Ensure series that exist in full data but had zero points in window are included (with zeros/NaT)
# Left-join p95_candidates with agg_window
full_pairs = p95_candidates.copy()
merged = full_pairs.merge(agg_window, on=['cmdb_id','kpi_name'], how='left')

# Fill missing aggregates for series absent in window
merged['total_points_in_window'] = merged['total_points_in_window'].fillna(0).astype(int)
merged['count_exceedances'] = merged['count_exceedances'].fillna(0).astype(int)
merged['earliest_exceedance_timestamp_utc'] = pd.to_datetime(merged['earliest_exceedance_timestamp_utc'], utc=True)
merged['max_value_in_window'] = merged['max_value_in_window'].fillna(float('nan'))

# 2c) Exclude trivial zeros where series_global_p95 == 0 AND max_value_in_window == 0
# Note: treat only explicit zeros; NaN max_value_in_window will not be considered equal to 0
is_trivial_zero = (merged['series_global_p95'] == 0) & (merged['max_value_in_window'] == 0)
excluded_count = int(is_trivial_zero.sum())

filtered = merged[~is_trivial_zero].copy()

# 3) Compute severity
eps = 1e-9
filtered['severity'] = (filtered['max_value_in_window'] - filtered['series_global_p95']) / filtered['series_global_p95'].apply(lambda x: max(eps, x))

# Replace possible infinite or NaN severity (e.g., when both are NaN) with large/safe numeric - but keep as is per rule
# 4) Prepare final table sorted by severity desc, top 10 rows
final_cols = [
    'cmdb_id','kpi_name','total_points_in_window','count_exceedances',
    'earliest_exceedance_timestamp_utc','max_value_in_window','series_global_p95','severity'
]
final_sorted = filtered.sort_values('severity', ascending=False).reset_index(drop=True)
top10 = final_sorted.loc[:, final_cols].head(10)

# Counts to return
counts = pd.DataFrame([
    {'metric':'total_candidate_series_examined','value': total_candidate_series_examined},
    {'metric':'excluded_trivial_zero_series','value': excluded_count}
])

# Display compact results: top10 and counts
top10, counts
