import pandas as pd
import numpy as np

# Reuse existing metric_df if available; otherwise load
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")
    metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True)

# Ensure timestamp parsed as required
metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True)

# 1) Compute global thresholds (P95) and full-series counts per cmdb_id + kpi_name
thresholds = (
    metric_df
    .groupby(['cmdb_id', 'kpi_name'], dropna=False)['value']
    .agg(
        total_points_full_series='count',
        global_p95_value=lambda x: x.quantile(0.95)
    )
    .reset_index()
)

# 2) Filter metric.csv to the incident window (inclusive)
start = pd.to_datetime("2024-01-20 21:02:21", utc=True)
end = pd.to_datetime("2024-01-20 21:32:21", utc=True)
metric_window = metric_df[(metric_df['timestamp'] >= start) & (metric_df['timestamp'] <= end)].copy()

# 3) Merge global thresholds into windowed data so we can mark anomalies (value >= global_p95_value)
metric_window = metric_window.merge(
    thresholds[['cmdb_id', 'kpi_name', 'global_p95_value']],
    on=['cmdb_id', 'kpi_name'],
    how='left'
)

# If any series in window lacks a global threshold (shouldn't happen), treat as no anomaly threshold (NaN)
metric_window['is_anomaly'] = metric_window['value'] >= metric_window['global_p95_value']

# 4) Aggregate per series within the window
agg_window = (
    metric_window
    .groupby(['cmdb_id', 'kpi_name'], dropna=False)
    .agg(
        total_points_in_window=('value', 'count'),
        anomalies_in_window_count=('is_anomaly', 'sum'),
        earliest_anomaly_timestamp_in_window=('timestamp', lambda x: x[x.index[(metric_window.loc[x.index, 'is_anomaly'])]].min() if any(metric_window.loc[x.index, 'is_anomaly']) else pd.NaT)
    )
    .reset_index()
)

# The lambda above uses index alignment to find earliest anomaly timestamp per group.
# For groups with no points in window, they won't appear in agg_window; we need to include all series from thresholds.

# 5) Combine thresholds (full series) with window aggregates, filling missing window data with zeros/NaT
result = thresholds.merge(
    agg_window,
    on=['cmdb_id', 'kpi_name'],
    how='left'
)

# Fill NaNs for counts with zeros and convert anomaly timestamp NaT -> None later
result['total_points_in_window'] = result['total_points_in_window'].fillna(0).astype(int)
result['anomalies_in_window_count'] = result['anomalies_in_window_count'].fillna(0).astype(int)

# earliest_anomaly_timestamp_in_window currently may be dtype object due to lambda; ensure datetime or NaT
result['earliest_anomaly_timestamp_in_window'] = pd.to_datetime(result['earliest_anomaly_timestamp_in_window'], utc=True)

# Create ISO string column for output as required (None if no anomaly)
result['earliest_anomaly_timestamp_iso'] = result['earliest_anomaly_timestamp_in_window'].apply(
    lambda x: x.isoformat() if pd.notnull(x) else None
)

# 6) Select and sort as requested
out_cols = [
    'cmdb_id',
    'kpi_name',
    'global_p95_value',
    'total_points_full_series',
    'total_points_in_window',
    'anomalies_in_window_count',
    'earliest_anomaly_timestamp_iso'
]
# Sort by anomalies desc, then earliest anomaly ascending (NaT/None will appear last)
result_sorted = result.sort_values(
    by=['anomalies_in_window_count', 'earliest_anomaly_timestamp_in_window'],
    ascending=[False, True]
).reset_index(drop=True)

# Limit to top 20 rows
top20 = result_sorted[out_cols].head(20)

# Total number of distinct cmdb_id-kpi_name series detected
total_series_count = int(thresholds.shape[0])

# Display compact outputs (DataFrame and count)
top20, total_series_count
