import pandas as pd

# Reuse variable names where reasonable
fn_metric = "metric.csv"
fn_trace = "trace.csv"
fn_log = "log.csv"
fn_error = "error_logs.csv"

# Load CSVs
metric_df = pd.read_csv(fn_metric)
trace_df = pd.read_csv(fn_trace)
log_df = pd.read_csv(fn_log)
error_df = pd.read_csv(fn_error)

# Parse timestamp columns to UTC datetimes (unit='s', utc=True)
for df in (metric_df, trace_df, log_df, error_df):
    df['timestamp'] = pd.to_datetime(df['timestamp'], unit='s', utc=True)

# Helper to build compact summary dataframe for a file
def build_summary_df(df, name_col):
    row_count = len(df)
    min_ts = df['timestamp'].min()
    max_ts = df['timestamp'].max()
    unique_cmdb = pd.Index(df['cmdb_id'].dropna().unique())
    unique_cmdb_count = unique_cmdb.size
    unique_cmdb_list = list(unique_cmdb[:50])  # limit to first 50

    unique_names = pd.Index(df[name_col].dropna().unique())
    unique_names_count = unique_names.size
    unique_names_list = list(unique_names[:50])  # limit to first 50

    summary = pd.DataFrame([{
        'filename': name_col.split('.')[0] if '.' in name_col else name_col,
        'row_count': row_count,
        'min_timestamp_utc_iso': min_ts.isoformat() if pd.notnull(min_ts) else None,
        'max_timestamp_utc_iso': max_ts.isoformat() if pd.notnull(max_ts) else None,
        'unique_cmdb_count': unique_cmdb_count,
        'unique_cmdb_list_first_50': ", ".join(map(str, unique_cmdb_list)),
        'unique_names_count': unique_names_count,
        'unique_names_list_first_50': ", ".join(map(str, unique_names_list))
    }])
    return summary

# Build summaries
metric_summary = build_summary_df(metric_df, 'kpi_name')
trace_summary = build_summary_df(trace_df, 'trace_name')
log_summary = build_summary_df(log_df, 'log_name')
error_summary = build_summary_df(error_df, 'message')

# Prepare top-10 rows for each file (showing all columns)
metric_top10 = metric_df.head(10)
trace_top10 = trace_df.head(10)
log_top10 = log_df.head(10)
error_top10 = error_df.head(10)

# Display compact results (variables separated by commas as required)
metric_summary, metric_top10, trace_summary, trace_top10, log_summary, log_top10, error_summary, error_top10
