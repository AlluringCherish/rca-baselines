import pandas as pd
import numpy as np

# Reuse existing dataframes if present, otherwise load and parse timestamps
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")
    metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True)

try:
    log_df
except NameError:
    log_df = pd.read_csv("log.csv")
    log_df['timestamp'] = pd.to_datetime(log_df['timestamp'], unit='s', utc=True)

# Ensure timestamps parsed as required
metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True)
log_df['timestamp'] = pd.to_datetime(log_df['timestamp'], unit='s', utc=True)

components = ['carts','catalogue','orders','payment','user']

# Incident window (inclusive)
start = pd.to_datetime("2024-01-20 21:02:21", utc=True)
end = pd.to_datetime("2024-01-20 21:32:21", utc=True)

rows = []
for comp in components:
    # SOCKET KPI: compute global P95 on full series first
    sock_series = metric_df[(metric_df['cmdb_id'] == comp) & (metric_df['kpi_name'] == 'socket')]['value']
    socket_global_p95 = float(sock_series.quantile(0.95)) if not sock_series.empty else np.nan

    # Filter metric to window for this component/socket
    sock_win = metric_df[
        (metric_df['cmdb_id'] == comp) &
        (metric_df['kpi_name'] == 'socket') &
        (metric_df['timestamp'] >= start) &
        (metric_df['timestamp'] <= end)
    ].copy()

    socket_total_points_in_window = int(len(sock_win))
    if not np.isnan(socket_global_p95):
        socket_anomalies_count = int((sock_win['value'] >= socket_global_p95).sum())
        if socket_anomalies_count > 0:
            earliest_sock_anom_ts = sock_win.loc[sock_win['value'] >= socket_global_p95, 'timestamp'].min()
        else:
            earliest_sock_anom_ts = pd.NaT
    else:
        socket_anomalies_count = 0
        earliest_sock_anom_ts = pd.NaT

    socket_max_value_in_window = sock_win['value'].max() if not sock_win.empty else np.nan

    # LOG: log.error_count global P95 on full series
    log_series = log_df[(log_df['cmdb_id'] == comp) & (log_df['log_name'] == 'log.error_count')]['value']
    log_global_p95 = float(log_series.quantile(0.95)) if not log_series.empty else np.nan

    # Filter logs to window for this component/log.error_count
    log_win = log_df[
        (log_df['cmdb_id'] == comp) &
        (log_df['log_name'] == 'log.error_count') &
        (log_df['timestamp'] >= start) &
        (log_df['timestamp'] <= end)
    ].copy()

    log_total_points_in_window = int(len(log_win))
    if not np.isnan(log_global_p95):
        log_anomalies_high_count = int((log_win['value'] >= log_global_p95).sum())
        if log_anomalies_high_count > 0:
            earliest_log_high_ts = log_win.loc[log_win['value'] >= log_global_p95, 'timestamp'].min()
        else:
            earliest_log_high_ts = pd.NaT
    else:
        log_anomalies_high_count = 0
        earliest_log_high_ts = pd.NaT

    rows.append({
        'component': comp,
        'socket_global_p95': socket_global_p95 if not np.isnan(socket_global_p95) else None,
        'socket_total_points_in_window': socket_total_points_in_window,
        'socket_anomalies_count': socket_anomalies_count,
        'socket_earliest_anomaly_timestamp_iso': earliest_sock_anom_ts.isoformat() if pd.notnull(earliest_sock_anom_ts) else None,
        'socket_max_value_in_window': socket_max_value_in_window if not np.isnan(socket_max_value_in_window) else None,
        'log_global_p95': log_global_p95 if not np.isnan(log_global_p95) else None,
        'log_total_points_in_window': log_total_points_in_window,
        'log_anomalies_high_count': log_anomalies_high_count,
        'log_earliest_high_anomaly_timestamp_iso': earliest_log_high_ts.isoformat() if pd.notnull(earliest_log_high_ts) else None
    })

comp_summary_df = pd.DataFrame(rows)

# Sort by socket anomalies desc then earliest socket anomaly asc (NaT/None last)
# Convert earliest timestamp to datetime for sorting
comp_summary_df['socket_earliest_dt'] = pd.to_datetime(comp_summary_df['socket_earliest_anomaly_timestamp_iso'], utc=True)
comp_summary_df = comp_summary_df.sort_values(
    by=['socket_anomalies_count', 'socket_earliest_dt'],
    ascending=[False, True]
).drop(columns=['socket_earliest_dt']).reset_index(drop=True)

# Keep only the requested five components (already limited) and display compactly
comp_summary_df
