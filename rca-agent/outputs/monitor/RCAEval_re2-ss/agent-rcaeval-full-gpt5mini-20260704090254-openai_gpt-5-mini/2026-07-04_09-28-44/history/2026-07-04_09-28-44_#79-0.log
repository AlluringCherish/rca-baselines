import pandas as pd

# Reuse existing log_df if present, otherwise load
try:
    log_df
except NameError:
    log_df = pd.read_csv("log.csv")
    log_df['timestamp'] = pd.to_datetime(log_df['timestamp'], unit='s', utc=True)

# Ensure timestamp parsed correctly
log_df['timestamp'] = pd.to_datetime(log_df['timestamp'], unit='s', utc=True)

# 1) Compute global P95 and P05 and full-series counts per cmdb_id + log_name (using full available series)
thresholds = (
    log_df
    .groupby(['cmdb_id', 'log_name'], dropna=False)['value']
    .agg(
        total_points_full_series='count',
        global_p95_value=lambda x: x.quantile(0.95),
        global_p05_value=lambda x: x.quantile(0.05)
    )
    .reset_index()
)

# 2) Filter log.csv to the incident window (inclusive)
start = pd.to_datetime("2024-01-20 21:02:21", utc=True)
end = pd.to_datetime("2024-01-20 21:32:21", utc=True)
log_window = log_df[(log_df['timestamp'] >= start) & (log_df['timestamp'] <= end)].copy()

# 3) Merge thresholds into windowed data to mark anomalies
log_window = log_window.merge(
    thresholds[['cmdb_id', 'log_name', 'global_p95_value', 'global_p05_value']],
    on=['cmdb_id', 'log_name'],
    how='left'
)

# If thresholds missing for any series, global_* will be NaN (unlikely). Mark anomalies accordingly.
log_window['is_high'] = log_window['value'] >= log_window['global_p95_value']
log_window['is_low'] = log_window['value'] <= log_window['global_p05_value']

# Helper to get earliest timestamp for a boolean condition in a group
def earliest_ts_for_condition(g, cond_col):
    sub = g.loc[g[cond_col], 'timestamp']
    return sub.min() if not sub.empty else pd.NaT

# 4) Aggregate per series within the window
agg_window = (
    log_window
    .groupby(['cmdb_id', 'log_name'], dropna=False)
    .apply(lambda g: pd.Series({
        'total_points_in_window': int(len(g)),
        'anomalies_high_count': int(g['is_high'].sum()),
        'anomalies_low_count': int(g['is_low'].sum()),
        'earliest_high_timestamp': earliest_ts_for_condition(g, 'is_high'),
        'earliest_low_timestamp': earliest_ts_for_condition(g, 'is_low'),
    }))
    .reset_index()
)

# 5) Combine thresholds (full series) with window aggregates, filling missing window data
result = thresholds.merge(
    agg_window,
    on=['cmdb_id', 'log_name'],
    how='left'
)

# Fill NaNs for counts with zeros
result['total_points_in_window'] = result['total_points_in_window'].fillna(0).astype(int)
result['anomalies_high_count'] = result['anomalies_high_count'].fillna(0).astype(int)
result['anomalies_low_count'] = result['anomalies_low_count'].fillna(0).astype(int)

# Ensure timestamp columns are datetimes and convert to ISO strings or None
result['earliest_high_timestamp'] = pd.to_datetime(result['earliest_high_timestamp'], utc=True)
result['earliest_low_timestamp'] = pd.to_datetime(result['earliest_low_timestamp'], utc=True)
result['earliest_high_timestamp_iso'] = result['earliest_high_timestamp'].apply(lambda x: x.isoformat() if pd.notnull(x) else None)
result['earliest_low_timestamp_iso'] = result['earliest_low_timestamp'].apply(lambda x: x.isoformat() if pd.notnull(x) else None)

# 6) Select required columns and sort as requested
out_cols = [
    'cmdb_id',
    'log_name',
    'global_p95_value',
    'global_p05_value',
    'total_points_full_series',
    'total_points_in_window',
    'anomalies_high_count',
    'anomalies_low_count',
    'earliest_high_timestamp_iso',
    'earliest_low_timestamp_iso'
]

result_sorted = result.sort_values(
    by=['anomalies_high_count', 'anomalies_low_count'],
    ascending=[False, False]
).reset_index(drop=True)

top20 = result_sorted[out_cols].head(20)

# 7) Additional requested outputs
total_series_count = int(thresholds.shape[0])

# Short list (up to 10) of cmdb_id that have anomalies_high_count > 0 for log.error_count
error_high_df = result_sorted[(result_sorted['log_name'] == 'log.error_count') & (result_sorted['anomalies_high_count'] > 0)]
error_cmdb_list = list(error_high_df['cmdb_id'].unique()[:10])

# Display compact outputs
top20, total_series_count, error_cmdb_list
