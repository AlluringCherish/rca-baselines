import pandas as pd
import numpy as np

# Reuse existing variables if present, otherwise load metric.csv
if "df_metric" not in globals():
    df_metric = pd.read_csv("metric.csv")
# Ensure timestamp parsed as UTC-aware datetime in 'ts'
if "ts" not in df_metric.columns:
    df_metric["ts"] = pd.to_datetime(df_metric["timestamp"], unit="s", utc=True)

# Incident window (UTC)
if "start_ts" not in globals():
    start_ts = pd.Timestamp("2024-01-20 04:43:33", tz="UTC")
if "end_ts" not in globals():
    end_ts = pd.Timestamp("2024-01-20 05:13:33", tz="UTC")

candidates = ["carts", "catalogue", "orders", "payment", "user"]

# Filter global series to only candidate cmdb_ids
df_candidates = df_metric[df_metric["cmdb_id"].isin(candidates)].copy()

# Compute global stats (must be done BEFORE any window filtering)
global_stats = (
    df_candidates.groupby(["cmdb_id", "kpi_name"])["value"]
    .agg(
        global_count="count",
        global_mean="mean",
        global_min="min",
        global_max="max",
        global_p95=lambda x: x.quantile(0.95),
    )
    .reset_index()
)

# Per-cmdb overall earliest/latest timestamps (for reporting when in-window rows = 0)
cmdb_times = (
    df_candidates.groupby("cmdb_id")["ts"]
    .agg(cmdb_earliest_ts="min", cmdb_latest_ts="max")
    .reset_index()
)

# Now filter to incident window
mask = (df_candidates["ts"] >= start_ts) & (df_candidates["ts"] <= end_ts)
df_window = df_candidates[mask].copy()

# In-window aggregated stats per (cmdb_id, kpi_name)
in_window_grp = (
    df_window.groupby(["cmdb_id", "kpi_name"])["value"]
    .agg(
        in_window_count="count",
        in_window_max="max",
    )
    .reset_index()
)

# For counting anomalies >= global P95, we need to join global p95 to full rows, then filter in-window points
# Join global p95 to df_window rows
df_window = df_window.merge(global_stats[["cmdb_id", "kpi_name", "global_p95"]], on=["cmdb_id", "kpi_name"], how="left")

# Flag anomalies where value >= global_p95 (global threshold computed on full series)
df_window["is_anomaly"] = df_window["value"] >= df_window["global_p95"]

# Count anomalies and earliest anomaly timestamp per group
anomaly_grp = (
    df_window[df_window["is_anomaly"]]
    .groupby(["cmdb_id", "kpi_name"])
    .agg(
        in_window_anomalies=("is_anomaly", "sum"),
        earliest_anomaly_ts=("ts", "min"),
    )
    .reset_index()
)

# Merge everything: start from global_stats to ensure inclusion of zero in-window rows
summary = global_stats.merge(in_window_grp, on=["cmdb_id", "kpi_name"], how="left")
summary = summary.merge(in_window_grp[["cmdb_id", "kpi_name"]], on=["cmdb_id", "kpi_name"], how="left")  # no-op but kept for clarity
summary = summary.merge(in_window_grp.rename(columns={"in_window_count":"_tmp"}).drop(columns=["_tmp"]), on=["cmdb_id","kpi_name"], how="left")
# Actually merge the real in-window counts and max
summary = summary.merge(in_window_grp.rename(columns={"in_window_count":"in_window_count", "in_window_max":"in_window_max"}), on=["cmdb_id","kpi_name"], how="left")
summary = summary.merge(anomaly_grp, on=["cmdb_id", "kpi_name"], how="left")

# Fill NaNs for groups with no in-window rows
summary["in_window_count"] = summary["in_window_count"].fillna(0).astype(int)
summary["in_window_max"] = summary["in_window_max"].where(summary["in_window_max"].notna(), np.nan)
summary["in_window_anomalies"] = summary["in_window_anomalies"].fillna(0).astype(int)
summary["earliest_anomaly_ts"] = pd.to_datetime(summary["earliest_anomaly_ts"])

# Attach cmdb earliest/latest overall timestamps
summary = summary.merge(cmdb_times, on="cmdb_id", how="left")

# Compute ratio (max_in_window / global_p95). Handle p95 == 0
def compute_ratio(row):
    p95 = row["global_p95"]
    m = row["in_window_max"]
    if pd.isna(m):
        return np.nan
    if pd.isna(p95) or p95 == 0:
        return np.inf if m > 0 else np.nan
    return m / p95

summary["ratio"] = summary.apply(compute_ratio, axis=1)

# Reorder and select columns for compact output
cols = [
    "cmdb_id",
    "kpi_name",
    "global_count",
    "global_p95",
    "in_window_count",
    "in_window_anomalies",
    "earliest_anomaly_ts",
    "in_window_max",
    "ratio",
    "cmdb_earliest_ts",
    "cmdb_latest_ts",
]
summary = summary[cols]

# Sort by anomalies desc, then ratio desc
summary = summary.sort_values(["in_window_anomalies", "ratio"], ascending=[False, False])

# Limit to top 50
anomaly_summary = summary.head(50).reset_index(drop=True)

# Brief notes: pick most persistent (max anomalies) and most severe (max ratio)
if not anomaly_summary.empty:
    # persistent: highest in_window_anomalies, tie-breaker earliest anomaly timestamp
    persistent = anomaly_summary.sort_values(["in_window_anomalies", "earliest_anomaly_ts"], ascending=[False, True]).iloc[0]
    # severe: highest ratio (ignore inf unless present; handle inf as highest)
    severe = anomaly_summary.sort_values("ratio", ascending=False).iloc[0]
    notes = (
        f"Most persistent anomaly: {persistent['cmdb_id']} / {persistent['kpi_name']} "
        f"(anomalies={persistent['in_window_anomalies']}, earliest={persistent['earliest_anomaly_ts']})\n"
        f"Most severe anomaly by ratio: {severe['cmdb_id']} / {severe['kpi_name']} "
        f"(ratio={severe['ratio']:.3g}, in_window_max={severe['in_window_max']}, P95={severe['global_p95']})"
    )
else:
    notes = "No candidate metric series found for the specified components."

# Display compact results
anomaly_summary, notes
