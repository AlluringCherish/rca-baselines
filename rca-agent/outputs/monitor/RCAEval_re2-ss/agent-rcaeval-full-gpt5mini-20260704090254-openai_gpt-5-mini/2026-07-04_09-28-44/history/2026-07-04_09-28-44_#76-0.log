import pandas as pd
import numpy as np

# Load trace.csv (reuse trace_df if present)
try:
    trace_df
except NameError:
    trace_df = pd.read_csv("trace.csv")

# 1) Distinct (cmdb_id, trace_name) pairs and counts (top 50 by count)
pairs_count_trace = (
    trace_df
    .groupby(['cmdb_id', 'trace_name'], dropna=False)
    .size()
    .reset_index(name='count')
    .sort_values('count', ascending=False)
)
pairs_top50 = pairs_count_trace.head(50)  # as requested in step 1

# Ensure timestamp parsed (we'll parse for filtering only, per rules)
if 'ts' not in trace_df.columns:
    trace_df['ts'] = pd.to_datetime(trace_df['timestamp'], unit='s', utc=True)

# 2) Compute global P95 per (cmdb_id, trace_name) using full series (before filtering)
global_p95_trace = (
    trace_df
    .groupby(['cmdb_id', 'trace_name'], dropna=False)['value']
    .quantile(0.95)
    .reset_index(name='global_P95')
)

# 3) Filter to incident window (UTC)
start_ts = pd.to_datetime("2024-01-20 22:55:32", utc=True)
end_ts = pd.to_datetime("2024-01-20 23:25:32", utc=True)
window_trace = trace_df[(trace_df['ts'] >= start_ts) & (trace_df['ts'] <= end_ts)].copy()

# Merge window with global P95 and mark anomalies (value > global_P95)
window_trace = window_trace.merge(global_p95_trace, on=['cmdb_id', 'trace_name'], how='left')
window_trace['anomaly'] = window_trace['value'] > window_trace['global_P95']

# 4) Aggregate per (cmdb_id, trace_name) present in window
def agg_trace_group(g):
    gp95 = g['global_P95'].iloc[0]
    num_in = len(g)
    num_above = int(g['anomaly'].sum())
    max_val = g['value'].max()
    if num_above == 0:
        earliest_iso = None
    else:
        earliest_iso = g.loc[g['anomaly'], 'ts'].min().isoformat()
    # ratio handling: if gp95 == 0 or NaN
    if pd.isna(gp95) or gp95 == 0:
        ratio = float('inf') if max_val > gp95 else 0.0
    else:
        ratio = (max_val - gp95) / gp95
    return pd.Series({
        'cmdb_id': g.name[0],
        'trace_name': g.name[1],
        'global_P95': gp95,
        'number_of_points_in_window': num_in,
        'number_of_points_above_P95': num_above,
        'earliest_timestamp_of_point_above_P95': earliest_iso,
        'max_value_in_window': max_val,
        'max_over_threshold_ratio': ratio
    })

grouped_trace = window_trace.groupby(['cmdb_id', 'trace_name'], sort=False)
trace_agg = grouped_trace.apply(agg_trace_group).reset_index(drop=True)

# 5) Filter to anomalies > 0, sort as requested and return top 20
trace_anomalies = trace_agg[trace_agg['number_of_points_above_P95'] > 0].copy()
trace_anomalies = trace_anomalies.sort_values(
    ['number_of_points_above_P95', 'max_over_threshold_ratio'],
    ascending=[False, False]
).reset_index(drop=True)
trace_anomalies_top20 = trace_anomalies.head(20)

# Small list of distinct cmdb_id values that had any trace anomalies in the window
anomalous_trace_cmdbs = pd.DataFrame({'cmdb_id': sorted(trace_anomalies['cmdb_id'].unique())})

# Focus on services of interest: carts, user, queue-master
services = ['carts', 'user', 'queue-master']
services_of_interest = []
for svc in services:
    df_svc = trace_anomalies[trace_anomalies['cmdb_id'] == svc]
    had_anom = not df_svc.empty
    earliest = df_svc['earliest_timestamp_of_point_above_P95'].min() if had_anom else None
    services_of_interest.append({'cmdb_id': svc, 'had_trace_anomaly': had_anom, 'earliest_anomaly': earliest})
services_of_interest = pd.DataFrame(services_of_interest)

# Check whether 'carts' appears referenced in trace_name of other services during the window
# (look for 'carts' substring in trace_name of window_trace rows where cmdb_id != 'carts')
mentions = window_trace[window_trace['trace_name'].str.contains('carts', case=False, na=False) & (window_trace['cmdb_id'] != 'carts')].copy()
# Summarize mentions: by cmdb_id (who mentions carts), count and earliest mention time
if not mentions.empty:
    mentions_summary = (
        mentions.groupby('cmdb_id', sort=False)
        .agg(count_mentions=('trace_name', 'size'),
             earliest_mention_ts=('ts', 'min'))
        .reset_index()
