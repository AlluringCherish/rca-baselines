import pandas as pd

# Load CSVs and parse timestamps as UTC datetimes
metric_df = pd.read_csv("metric.csv")
log_df = pd.read_csv("log.csv")
trace_df = pd.read_csv("trace.csv")
error_df = pd.read_csv("error_logs.csv")

metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True)
log_df['timestamp'] = pd.to_datetime(log_df['timestamp'], unit='s', utc=True)
trace_df['timestamp'] = pd.to_datetime(trace_df['timestamp'], unit='s', utc=True)
error_df['timestamp'] = pd.to_datetime(error_df['timestamp'], unit='s', utc=True)

# Helper to compute aggregated statistics for a grouped numeric series
def compute_stats(df, group_cols, value_col, name_map=None, top_n=20):
    # base aggregations
    grp = df.groupby(group_cols)[value_col]
    agg_base = grp.agg(count='size', min='min', max='max', mean='mean')
    # quantiles
    q50 = grp.quantile(0.5).rename('p50')
    q90 = grp.quantile(0.9).rename('p90')
    q95 = grp.quantile(0.95).rename('p95')
    # combine
    combined = agg_base.join(q50).join(q90).join(q95)
    combined = combined.reset_index()
    # rename columns if provided (map old group col names to requested)
    if name_map:
        combined = combined.rename(columns=name_map)
    # order columns: group cols..., count, min, p50, p90, p95, max, mean
    col_order = list(name_map.values()) if name_map else group_cols
    col_order = col_order + ['count', 'min', 'p50', 'p90', 'p95', 'max', 'mean']
    combined = combined[col_order]
    # sort by count desc and limit
    combined = combined.sort_values('count', ascending=False).head(top_n)
    # round numeric fields for compact display
    numeric_cols = ['min', 'p50', 'p90', 'p95', 'max', 'mean']
    for c in numeric_cols:
        if c in combined.columns:
            combined[c] = combined[c].round(6)
    return combined

# 1) metric.csv summary: (cmdb_id, kpi_name)
metric_name_map = {'cmdb_id':'cmdb_id', 'kpi_name':'kpi_name'}
metric_summary = compute_stats(metric_df, ['cmdb_id','kpi_name'], 'value', name_map=metric_name_map, top_n=20)

# 2) log.csv summary: (cmdb_id, log_name)
log_name_map = {'cmdb_id':'cmdb_id', 'log_name':'log_name'}
log_summary = compute_stats(log_df, ['cmdb_id','log_name'], 'value', name_map=log_name_map, top_n=20)

# 3) trace.csv summary: (cmdb_id, trace_name)
trace_name_map = {'cmdb_id':'cmdb_id', 'trace_name':'trace_name'}
trace_summary = compute_stats(trace_df, ['cmdb_id','trace_name'], 'value', name_map=trace_name_map, top_n=20)

# 4) error_logs.csv summary
error_total_rows = len(error_df)
cmdb_counts = error_df['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count')
# overall earliest and latest timestamps
error_earliest_overall = error_df['timestamp'].min()
error_latest_overall = error_df['timestamp'].max()
# per-cmdb_id earliest/latest, limited to top 20 by count
per_cmdb = error_df.groupby('cmdb_id')['timestamp'].agg(min='min', max='max').reset_index()
per_cmdb = per_cmdb.merge(cmdb_counts, on='cmdb_id')
per_cmdb = per_cmdb.sort_values('count', ascending=False).head(20)
# Compose compact error summary objects
error_overall = pd.DataFrame({
    'total_rows':[error_total_rows],
    'distinct_cmdb_count':[cmdb_counts.shape[0]],
    'earliest_utc':[error_earliest_overall],
    'latest_utc':[error_latest_overall]
})
# Rename per_cmdb timestamp columns for clarity
per_cmdb = per_cmdb.rename(columns={'min':'earliest_utc', 'max':'latest_utc'})

# Display compact outputs (use variable names as per rules)
metric_summary, log_summary, trace_summary, error_overall, per_cmdb
