import pandas as pd
import numpy as np

# Load trace data and parse timestamps in UTC
df_trace = pd.read_csv("trace.csv")
df_trace['timestamp'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True)

# 1) Compute global p95 per (cmdb_id, trace_name) using the full trace series
grouped_trace_p95 = (
    df_trace.groupby(['cmdb_id', 'trace_name'])['value']
    .quantile(0.95)
    .reset_index()
    .rename(columns={'value': 'p95'})
)

# Candidate substrings (reuse same candidate list)
candidates = ['orders', 'catalogue', 'carts', 'payment', 'user']

# Helper to detect candidate cmdb_ids (case-insensitive substring match)
mask_candidate_cmdb = df_trace['cmdb_id'].astype(str).str.lower().apply(lambda s: any(c in s for c in candidates))
matched_trace_cmdbs = sorted(df_trace.loc[mask_candidate_cmdb, 'cmdb_id'].astype(str).unique())
df_matched_trace_cmdbs = pd.DataFrame({'cmdb_id': matched_trace_cmdbs})

# 2) Filter trace.csv to the incident window (inclusive)
start_ts = pd.to_datetime("2024-01-21 07:36:20", utc=True)
end_ts   = pd.to_datetime("2024-01-21 08:06:20", utc=True)
df_trace_window = df_trace[(df_trace['timestamp'] >= start_ts) & (df_trace['timestamp'] <= end_ts)].copy()

# 3) Keep only trace rows in the window whose cmdb_id matches candidate substrings
df_trace_incident_candidates_full = df_trace_window[
    df_trace_window['cmdb_id'].astype(str).str.lower().apply(lambda s: any(c in s for c in candidates))
].copy()

# 4) Join global p95 to each trace-row (join on cmdb_id and trace_name)
df_trace_joined = df_trace_incident_candidates_full.merge(
    grouped_trace_p95,
    on=['cmdb_id', 'trace_name'],
    how='left'
)

# Aggregate per (cmdb_id, trace_name): anomaly_count, earliest_anomaly_timestamp, max_value_in_window, global_p95
def agg_trace_group(g):
    p95 = g['p95'].iloc[0]
    anomalies = g[g['value'] > p95]
    anomaly_count = int(anomalies.shape[0])
    earliest_anom = anomalies['timestamp'].min() if anomaly_count > 0 else pd.NaT
    max_value = float(g['value'].max())
    return pd.Series({
        'anomaly_count': anomaly_count,
        'earliest_anomaly_timestamp': earliest_anom,
        'max_value_in_window': max_value,
        'global_p95': float(p95) if not pd.isna(p95) else np.nan
    })

trace_agg = (
    df_trace_joined.groupby(['cmdb_id', 'trace_name'], dropna=False)
    .apply(agg_trace_group)
    .reset_index()
)

# Compute severity safely
def compute_sev(row):
    p95 = row['global_p95']
    maxv = row['max_value_in_window']
    if pd.isna(p95):
        return np.nan
    if p95 == 0:
        return np.inf if maxv > 0 else 0.0
    return (maxv - p95) / p95

trace_agg['severity'] = trace_agg.apply(compute_sev, axis=1)

# Keep only rows with anomaly_count > 0
trace_agg_pos = trace_agg[trace_agg['anomaly_count'] > 0].copy()

# Format earliest_anomaly_timestamp as UTC string
trace_agg_pos['earliest_anomaly_timestamp'] = trace_agg_pos['earliest_anomaly_timestamp'].dt.tz_convert('UTC').dt.strftime('%Y-%m-%d %H:%M:%S%z')

# Sort by severity descending and limit to top 20
trace_result = trace_agg_pos.sort_values('severity', ascending=False).head(20)

# Final compact outputs:
# - df_matched_trace_cmdbs: distinct candidate cmdb_ids found in trace data
# - trace_result: top anomaly summaries per (cmdb_id, trace_name)
# - df_trace_incident_candidates_full: stored for later inspection
df_matched_trace_cmdbs, trace_result, df_trace_incident_candidates_full
