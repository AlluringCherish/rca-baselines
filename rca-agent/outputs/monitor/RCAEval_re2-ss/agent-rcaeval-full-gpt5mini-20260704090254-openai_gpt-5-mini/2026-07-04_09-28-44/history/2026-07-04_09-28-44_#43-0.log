candidates = ['orders','catalogue','carts','payment','user']
mask = df_trace_window['cmdb_id'].astype(str).apply(lambda s: any(sub in s for sub in candidates))
trace_incident_candidates = df_trace_window[mask].copy()  # stored for later inspection

# 4) Merge global p95 mapping into the windowed candidate traces
trace_joined = trace_incident_candidates.merge(grouped_trace_p95, on=['cmdb_id', 'trace_name'], how='left')

