trace_joined = trace_joined.dropna(subset=['global_p95'])

# Aggregate per (cmdb_id, trace_name)
def agg_group(g):
    p95 = g['global_p95'].iloc[0]
    anomalies = g[g['value'] > p95]
    anomaly_count = int(anomalies.shape[0])
    earliest_anom = anomalies['timestamp'].min() if anomaly_count > 0 else pd.NaT
    max_val = float(g['value'].max())
    return pd.Series({
        'anomaly_count': anomaly_count,
        'earliest_anomaly_timestamp': earliest_anom,
        'max_value_in_window': max_val,
        'global_p95': float(p95)
    })

agg = (
    trace_joined
    .groupby(['cmdb_id', 'trace_name'], dropna=False)
    .apply(agg_group)
    .reset_index()
)

# Compute severity safely (handle global_p95 == 0)
def compute_severity(row):
    p95 = row['global_p95']
    maxv = row['max_value_in_window']
    if p95 == 0:
        if maxv > 0:
            return np.inf
        else:
            return 0.0
    return (maxv - p95) / p95

