import numpy as np
import pandas as pd

components = ["carts","catalogue","orders","payment","user"]

# incident window (UTC)
start = pd.Timestamp("2024-01-19 11:21:49", tz="UTC")
end   = pd.Timestamp("2024-01-19 11:51:49", tz="UTC")

# ---- Metrics analysis ----
# Full-series stats (global P95 and total points) for the selected components
metrics_full = metric_df[metric_df['cmdb_id'].isin(components)].copy()
metrics_stats = (
    metrics_full
    .groupby(['cmdb_id','kpi_name'], observed=True)['value']
    .agg(global_p95=lambda x: float(x.quantile(0.95)),
         total_points_in_full_series='size')
    .reset_index()
)

# Points within the incident window (for selected components)
metrics_window = metric_df[
    (metric_df['timestamp'] >= start) &
    (metric_df['timestamp'] <= end) &
    (metric_df['cmdb_id'].isin(components))
].copy()

# Merge global thresholds into window points to mark anomalies
metrics_window = metrics_window.merge(metrics_stats[['cmdb_id','kpi_name','global_p95']],
                                      on=['cmdb_id','kpi_name'], how='left')
# mark anomalies
metrics_window['is_anomaly'] = metrics_window['value'] >= metrics_window['global_p95']

# Aggregate window-level stats per (cmdb_id, kpi_name)
if not metrics_window.empty:
    m_grp = metrics_window.groupby(['cmdb_id','kpi_name'], observed=True)
    m_window_agg = pd.DataFrame({
        'points_in_window': m_grp.size(),
        'anomaly_count_in_window': m_grp['is_anomaly'].sum(),
        'earliest_anomaly_timestamp_in_window': m_grp.apply(lambda g: g.loc[g['is_anomaly'],'timestamp'].min() if g['is_anomaly'].any() else pd.NaT),
        'max_value_in_window': m_grp['value'].max()
    }).reset_index()
else:
