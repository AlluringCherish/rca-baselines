import pandas as pd

# Load CSVs
metric_df = pd.read_csv('metric.csv')
trace_df = pd.read_csv('trace.csv')
log_df = pd.read_csv('log.csv')
error_df = pd.read_csv('error_logs.csv')

# Parse timestamps as UTC datetimes (keep UTC)
metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True)
trace_df['timestamp'] = pd.to_datetime(trace_df['timestamp'], unit='s', utc=True)
log_df['timestamp'] = pd.to_datetime(log_df['timestamp'], unit='s', utc=True)
error_df['timestamp'] = pd.to_datetime(error_df['timestamp'], unit='s', utc=True)

# 1) metric.csv summary: unique (cmdb_id, kpi_name) pairs
metric_group = (
    metric_df
    .groupby(['cmdb_id', 'kpi_name'], observed=True)
    .agg(count=('timestamp', 'size'),
         min_timestamp=('timestamp', 'min'),
         max_timestamp=('timestamp', 'max'))
    .reset_index()
    .sort_values('count', ascending=False)
)
metric_summary = metric_group.head(20)

# 2) trace.csv summary: unique (cmdb_id, trace_name) pairs
trace_group = (
    trace_df
    .groupby(['cmdb_id', 'trace_name'], observed=True)
    .agg(count=('timestamp', 'size'),
         min_timestamp=('timestamp', 'min'),
         max_timestamp=('timestamp', 'max'))
    .reset_index()
    .sort_values('count', ascending=False)
)
trace_summary = trace_group.head(20)

# 3) log.csv summary: unique (cmdb_id, log_name) pairs
log_group = (
    log_df
    .groupby(['cmdb_id', 'log_name'], observed=True)
    .agg(count=('timestamp', 'size'),
         min_timestamp=('timestamp', 'min'),
         max_timestamp=('timestamp', 'max'))
    .reset_index()
    .sort_values('count', ascending=False)
)
log_summary = log_group.head(20)

# 4) error_logs.csv summary: unique cmdb_id with counts
error_group = (
    error_df
    .groupby(['cmdb_id'], observed=True)
    .agg(count=('timestamp', 'size'),
         min_timestamp=('timestamp', 'min'),
         max_timestamp=('timestamp', 'max'))
    .reset_index()
    .sort_values('count', ascending=False)
)
error_summary = error_group.head(20)

# Display the four compact summary tables (limited to top 20 rows each)
metric_summary, trace_summary, log_summary, error_summary
