import pandas as pd
import numpy as np

# Reuse existing variables if present; otherwise (re)load/define
components = ["carts","catalogue","orders","payment","user"]
start = pd.Timestamp("2024-01-19 11:21:49", tz="UTC")
end   = pd.Timestamp("2024-01-19 11:51:49", tz="UTC")

# Ensure metric_df exists and timestamp parsed
metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True)

# 1) Compute global P95 for each (cmdb_id, kpi_name) for the listed components using full series
metrics_stats = (
    metric_df[metric_df['cmdb_id'].isin(components)]
    .groupby(['cmdb_id','kpi_name'], observed=True)['value']
    .agg(global_p95=lambda x: float(x.quantile(0.95)),
         total_points_in_full_series='size')
    .reset_index()
)

# 2) Filter metric points to the incident window
metrics_window = metric_df[
    (metric_df['timestamp'] >= start) &
    (metric_df['timestamp'] <= end) &
    (metric_df['cmdb_id'].isin(components))
].copy()

# Merge global P95 into window points
metrics_window = metrics_window.merge(metrics_stats[['cmdb_id','kpi_name','global_p95']],
                                      on=['cmdb_id','kpi_name'], how='left')

# 3) Identify consecutive anomaly runs within the window where value >= global_p95
metrics_window['is_anomaly'] = metrics_window['value'] >= metrics_window['global_p95']

# Consider only anomaly rows and sort
anoms = metrics_window[metrics_window['is_anomaly']].copy()
anoms.sort_values(['cmdb_id','kpi_name','timestamp'], inplace=True)

# Detect gaps of more than 1 minute within each (cmdb_id,kpi_name)
# time_diff in minutes
anoms['time_diff_min'] = anoms.groupby(['cmdb_id','kpi_name'])['timestamp'].diff().dt.total_seconds().div(60)
anoms['new_run'] = anoms['time_diff_min'].ne(1)  # True when first row in group or gap != 1 minute
# run_id cumulative within each group
anoms['run_id'] = anoms.groupby(['cmdb_id','kpi_name'])['new_run'].cumsum()

# Aggregate runs
if not anoms.empty:
    faults = (
        anoms
        .groupby(['cmdb_id','kpi_name','run_id'], observed=True)
        .agg(fault_start_timestamp=('timestamp','min'),
             fault_end_timestamp=('timestamp','max'),
             num_points=('timestamp','size'),
             max_value_in_fault=('value','max'))
        .reset_index()
    )
else:
    faults = pd.DataFrame(columns=['cmdb_id','kpi_name','run_id','fault_start_timestamp',
                                   'fault_end_timestamp','num_points','max_value_in_fault'])

# Attach global_p95
faults = faults.merge(metrics_stats[['cmdb_id','kpi_name','global_p95']],
                      on=['cmdb_id','kpi_name'], how='left')

# Compute duration_minutes (num_points corresponds to consecutive minutes) and severity_factor
faults['duration_minutes'] = faults['num_points']  # one point per minute -> duration equals num_points
faults['severity_factor'] = faults.apply(
    lambda r: None if r['max_value_in_fault'] == 0 else (r['max_value_in_fault'] - r['global_p95'])/r['max_value_in_fault'],
    axis=1
)

# Filter runs with length >= 3
faults = faults[faults['num_points'] >= 3].copy()

# Select and order required columns
faults = faults[
    ['cmdb_id','kpi_name','global_p95','fault_start_timestamp','fault_end_timestamp',
     'duration_minutes','num_points','max_value_in_fault','severity_factor']
]

# 4) Sort faults table by num_points desc then cmdb_id, limit top 50
faults = faults.sort_values(by=['num_points','cmdb_id'], ascending=[False, True]).head(50)

# 5) Full in-window time series for catalogue.socket (timestamp, value) sorted by timestamp (limit 100)
catalogue_socket_series = metrics_window[
    (metrics_window['cmdb_id'] == 'catalogue') &
    (metrics_window['kpi_name'] == 'socket')
][['timestamp','value']].sort_values('timestamp').head(100)

# Final compact outputs
faults, catalogue_socket_series
