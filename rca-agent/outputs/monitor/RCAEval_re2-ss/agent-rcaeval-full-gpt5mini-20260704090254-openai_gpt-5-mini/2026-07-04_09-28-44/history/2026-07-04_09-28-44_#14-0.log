import pandas as pd
import numpy as np

# Reuse existing DataFrames if present; otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv("metric.csv")
try:
    df_log
except NameError:
    df_log = pd.read_csv("log.csv")

# Parse timestamps to UTC (timestamps are unix seconds)
for df in (df_metric, df_log):
    if 'timestamp' in df.columns:
        df['timestamp'] = pd.to_datetime(df['timestamp'], unit='s', utc=True)

# Incident window (UTC)
start = pd.Timestamp("2024-01-19 16:13:51", tz="UTC")
end = pd.Timestamp("2024-01-19 16:43:51", tz="UTC")

# Target components
targets = ['carts','catalogue','orders','payment','user']

# Helper: compute global P95 per series (must be computed on full series before window filtering)
def compute_p95(df, group_keys, value_col='value'):
    return df.groupby(group_keys, dropna=False)[value_col].quantile(0.95).reset_index().rename(columns={value_col: 'p95'})

# Helper: max run length of consecutive True in boolean series (preserve order)
def max_run_length_bool(bool_series):
    if len(bool_series) == 0:
        return 0
    arr = bool_series.values
    max_run = 0
    cur = 0
    for v in arr:
        if v:
            cur += 1
            if cur > max_run:
                max_run = cur
        else:
            cur = 0
    return int(max_run)

# Helper: formatting to 4 significant digits
def fmt_sig(x):
    if pd.isna(x):
        return ""
    if np.isinf(x):
        return "inf"
    try:
        return "{:.4g}".format(float(x))
    except Exception:
        return str(x)

# --- Metrics processing ---
metric_keys = ['cmdb_id', 'kpi_name']
p95_metric = compute_p95(df_metric, metric_keys, 'value')
# Filter to target cmdb_ids (for output selection) but p95 computed globally above
p95_metric_targets = p95_metric[p95_metric['cmdb_id'].isin(targets)].copy()

# Incident-window rows for metrics
df_metric_inc = df_metric[(df_metric['timestamp'] >= start) & (df_metric['timestamp'] <= end)].copy()
# Merge p95 into incident rows
df_metric_inc = df_metric_inc.merge(p95_metric, on=metric_keys, how='left')

# Compute per-series aggregations within incident window
if not df_metric_inc.empty:
    df_metric_inc = df_metric_inc.sort_values(metric_keys + ['timestamp'])
    df_metric_inc['is_anom'] = df_metric_inc['value'] > df_metric_inc['p95']
    agg_metric = df_metric_inc.groupby(metric_keys).agg(
        anomaly_count = ('is_anom', 'sum'),
        earliest_anom_ts = ('timestamp', lambda s: s[df_metric_inc.loc[s.index, 'is_anom']].min() if any(df_metric_inc.loc[s.index, 'is_anom']) else pd.NaT),
        max_value = ('value', 'max')
    ).reset_index()
    # max run length
    maxruns_metric = df_metric_inc.groupby(metric_keys)['is_anom'].apply(lambda s: max_run_length_bool(s)).reset_index(name='max_run_length')
    metric_stats = agg_metric.merge(maxruns_metric, on=metric_keys, how='left')
else:
    metric_stats = pd.DataFrame(columns=metric_keys + ['anomaly_count','earliest_anom_ts','max_value','max_run_length'])

# Merge p95 (global) with stats for target cmdbs
metric_full_targets = p95_metric_targets.merge(metric_stats, on=metric_keys, how='left')
metric_full_targets['anomaly_count'] = metric_full_targets['anomaly_count'].fillna(0).astype(int)
metric_full_targets['earliest_anom_ts'] = pd.to_datetime(metric_full_targets['earliest_anom_ts']).dt.tz_convert('UTC')
metric_full_targets['max_run_length'] = metric_full_targets['max_run_length'].fillna(0).astype(int)
# compute severity
def severity_calc(row):
    p95 = row['p95']
    mv = row['max_value']
    if pd.isna(mv):
        return np.nan
    if p95 == 0:
        return np.inf if mv > 0 else np.nan
    return mv / p95
metric_full_targets['severity'] = metric_full_targets.apply(severity_calc, axis=1)

# Prepare metric display
metric_full_targets = metric_full_targets.rename(columns={'kpi_name': 'kpi_or_log_name'})
metric_full_targets['source'] = 'metric'
metric_display = metric_full_targets[['source','cmdb_id','kpi_or_log_name','p95','anomaly_count','earliest_anom_ts','max_run_length','max_value','severity']]

# --- Logs processing ---
log_keys = ['cmdb_id', 'log_name']
p95_log = compute_p95(df_log, log_keys, 'value')
p95_log_targets = p95_log[p95_log['cmdb_id'].isin(targets)].copy()

df_log_inc = df_log[(df_log['timestamp'] >= start) & (df_log['timestamp'] <= end)].copy()
df_log_inc = df_log_inc.merge(p95_log, on=log_keys, how='left')

if not df_log_inc.empty:
    df_log_inc = df_log_inc.sort_values(log_keys + ['timestamp'])
    df_log_inc['is_anom'] = df_log_inc['value'] > df_log_inc['p95']
    agg_log = df_log_inc.groupby(log_keys).agg(
        anomaly_count = ('is_anom', 'sum'),
        earliest_anom_ts = ('timestamp', lambda s: s[df_log_inc.loc[s.index, 'is_anom']].min() if any(df_log_inc.loc[s.index, 'is_anom']) else pd.NaT),
        max_value = ('value', 'max')
    ).reset_index()
    maxruns_log = df_log_inc.groupby(log_keys)['is_anom'].apply(lambda s: max_run_length_bool(s)).reset_index(name='max_run_length')
    log_stats = agg_log.merge(maxruns_log, on=log_keys, how='left')
else:
    log_stats = pd.DataFrame(columns=log_keys + ['anomaly_count','earliest_anom_ts','max_value','max_run_length'])

log_full_targets = p95_log_targets.merge(log_stats, on=log_keys, how='left')
log_full_targets['anomaly_count'] = log_full_targets['anomaly_count'].fillna(0).astype(int)
log_full_targets['earliest_anom_ts'] = pd.to_datetime(log_full_targets['earliest_anom_ts']).dt.tz_convert('UTC')
log_full_targets['max_run_length'] = log_full_targets['max_run_length'].fillna(0).astype(int)
log_full_targets['severity'] = log_full_targets.apply(severity_calc, axis=1)

log_full_targets = log_full_targets.rename(columns={'log_name': 'kpi_or_log_name'})
log_full_targets['source'] = 'log'
log_display = log_full_targets[['source','cmdb_id','kpi_or_log_name','p95','anomaly_count','earliest_anom_ts','max_run_length','max_value','severity']]

# Combine metric and log displays for targets
combined_targets = pd.concat([metric_display, log_display], ignore_index=True, sort=False)

# Format numeric display columns to 4 significant digits for output
combined_targets['p95'] = combined_targets['p95'].apply(fmt_sig)
combined_targets['max_value'] = combined_targets['max_value'].apply(fmt_sig)
combined_targets['severity'] = combined_targets['severity'].apply(lambda x: "inf" if x==np.inf else (fmt_sig(x) if pd.notna(x) else ""))

# Format earliest_anom_ts to ISO UTC string or NaT
combined_targets['earliest_anom_timestamp'] = combined_targets['earliest_anom_ts'].apply(lambda t: t.isoformat() if pd.notna(t) else pd.NaT)

