import pandas as pd

# Load CSVs
df_metric = pd.read_csv("metric.csv")
df_log = pd.read_csv("log.csv")
df_trace = pd.read_csv("trace.csv")
df_err = pd.read_csv("error_logs.csv")

# Parse timestamps to UTC datetime
for df in (df_metric, df_log, df_trace, df_err):
    df['timestamp'] = pd.to_datetime(df['timestamp'], unit='s', utc=True)

# 1) metric.csv summary: unique (cmdb_id, kpi_name) pairs with counts (top 50) and overall min/max timestamp
metric_pairs = (
    df_metric.groupby(['cmdb_id', 'kpi_name'])
    .size()
    .reset_index(name='count')
    .sort_values('count', ascending=False)
)
metric_summary = metric_pairs.head(50)
metric_time_range = pd.DataFrame({
    'min_timestamp': [df_metric['timestamp'].min()],
    'max_timestamp': [df_metric['timestamp'].max()]
})

# 2) log.csv summary: unique (cmdb_id, log_name) pairs with counts (top 50) and min/max timestamp
log_pairs = (
    df_log.groupby(['cmdb_id', 'log_name'])
    .size()
    .reset_index(name='count')
    .sort_values('count', ascending=False)
)
log_summary = log_pairs.head(50)
log_time_range = pd.DataFrame({
    'min_timestamp': [df_log['timestamp'].min()],
    'max_timestamp': [df_log['timestamp'].max()]
})

# 3) trace.csv summary: unique (cmdb_id, trace_name) pairs with counts (top 50) and min/max timestamp
trace_pairs = (
    df_trace.groupby(['cmdb_id', 'trace_name'])
    .size()
    .reset_index(name='count')
    .sort_values('count', ascending=False)
)
trace_summary = trace_pairs.head(50)
trace_time_range = pd.DataFrame({
    'min_timestamp': [df_trace['timestamp'].min()],
    'max_timestamp': [df_trace['timestamp'].max()]
})

# 4) error_logs.csv summary: unique cmdb_id with counts and up to 5 sample messages (timestamp, cmdb_id, first 200 chars)
err_counts = (
    df_err.groupby('cmdb_id')
    .size()
    .reset_index(name='count')
    .sort_values('count', ascending=False)
)

# Prepare sample messages per cmdb_id (up to 5), show timestamp (ISO), cmdb_id, and first 200 chars of message
sample_rows = []
max_rows_per_cmdb = 5
for cmdb in err_counts['cmdb_id'].tolist():
    rows = df_err[df_err['cmdb_id'] == cmdb].sort_values('timestamp').head(max_rows_per_cmdb)
    samples = []
    for _, r in rows.iterrows():
        ts = r['timestamp'].isoformat()
        msg = (r.get('message') or "")
        samples.append(f"{ts} {r['cmdb_id']} {msg[:200]}")
    sample_rows.append({'cmdb_id': cmdb, 'count': int(err_counts.loc[err_counts['cmdb_id']==cmdb,'count'].iloc[0]), 'sample_messages': " || ".join(samples)})

error_summary = pd.DataFrame(sample_rows).sort_values('count', ascending=False).reset_index(drop=True)
# limit to top 50 cmdb_ids for compactness
error_summary = error_summary.head(50)

error_time_range = pd.DataFrame({
    'min_timestamp': [df_err['timestamp'].min()] if not df_err.empty else [pd.NaT],
    'max_timestamp': [df_err['timestamp'].max()] if not df_err.empty else [pd.NaT]
})

# Display compact results (variables only)
metric_summary, metric_time_range, log_summary, log_time_range, trace_summary, trace_time_range, error_summary, error_time_range
