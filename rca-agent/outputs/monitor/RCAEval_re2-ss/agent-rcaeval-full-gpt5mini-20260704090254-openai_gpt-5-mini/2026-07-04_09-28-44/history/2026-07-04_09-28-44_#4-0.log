import pandas as pd
import numpy as np

# Reuse existing 'metric' DataFrame loaded earlier (timestamps already parsed as UTC)
components = ['carts','catalogue','orders','payment','user']

# 1) Restrict consideration to selected components (but thresholds computed from full series of those components)
metric_selected = metric[metric['cmdb_id'].isin(components)].copy()

# 2) Compute global thresholds (P95, P90, P05) for each (cmdb_id, kpi_name) using the entire available series
def pctile(arr, q):
    arr2 = np.array(arr.dropna(), dtype=float)
    return float(np.nanpercentile(arr2, q)) if arr2.size>0 else np.nan

thresholds = (
    metric_selected
    .groupby(['cmdb_id','kpi_name'], as_index=False)['value']
    .agg(
        global_p95=lambda x: pctile(x, 95),
        global_p90=lambda x: pctile(x, 90),
        global_p05=lambda x: pctile(x, 5),
        global_count=('value','count')
    )
)

# 3) Filter metric rows to the incident window (UTC)
start = pd.Timestamp('2024-01-20 04:17:04', tz='UTC')
end   = pd.Timestamp('2024-01-20 04:47:04', tz='UTC')
metric_window = metric_selected[(metric_selected['timestamp'] >= start) & (metric_selected['timestamp'] <= end)].copy()

# Attach thresholds to window rows
metric_window = metric_window.merge(thresholds, on=['cmdb_id','kpi_name'], how='left')

# 4) Detect anomalies: value >= global_p95. If no anomalies found at all, fallback to global_p90.
anomalies = metric_window[metric_window['value'] >= metric_window['global_p95']].copy()
used_threshold = 'p95'
if anomalies.empty:
    anomalies = metric_window[metric_window['value'] >= metric_window['global_p90']].copy()
    used_threshold = 'p90'

# 5) Aggregate anomalies by (cmdb_id,kpi_name)
if not anomalies.empty:
    anomalies_grouped = (
        anomalies
        .groupby(['cmdb_id','kpi_name'], as_index=False)
        .agg(
            anomaly_count=('value','count'),
            earliest_anomaly_timestamp=('timestamp','min'),
            max_value_in_window=('value','max')
        )
        .merge(thresholds[['cmdb_id','kpi_name','global_p95']], on=['cmdb_id','kpi_name'], how='left')
        .sort_values('anomaly_count', ascending=False)
        .reset_index(drop=True)
    )
else:
    # empty structured DataFrame for consistent display
    anomalies_grouped = pd.DataFrame(columns=['cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp','max_value_in_window','global_p95'])

# Also compute groups with zero anomalies and check for significant drops: value <= global_p05 in the window
# First compute per-group min value and earliest time of that min within the window
group_window_stats = (
    metric_window
    .groupby(['cmdb_id','kpi_name'], as_index=False)
    .agg(
        points_in_window=('value','count'),
        min_value_in_window=('value','min'),
        earliest_min_timestamp=('timestamp', 'min')  # earliest timestamp among the group's rows; we'll refine below
    )
)

# Merge thresholds
group_window_stats = group_window_stats.merge(thresholds, on=['cmdb_id','kpi_name'], how='left')

# Identify groups with zero anomalies
anomalous_keys = set(zip(anomalies_grouped['cmdb_id'], anomalies_grouped['kpi_name']))
group_window_stats['had_anomaly'] = group_window_stats.apply(lambda r: (r['cmdb_id'], r['kpi_name']) in anomalous_keys, axis=1)
no_anom = group_window_stats[group_window_stats['had_anomaly']==False].copy()

# For no-anomaly groups, find those where min_value_in_window <= global_p05 (significant drop)
no_anom['drop_flag'] = no_anom.apply(lambda r: (not pd.isna(r['min_value_in_window'])) and (not pd.isna(r['global_p05'])) and (r['min_value_in_window'] <= r['global_p05']), axis=1)
drops = no_anom[no_anom['drop_flag']].copy()

# Compute drop severity: difference between global_p95 and min_value_in_window (larger is more severe)
drops['drop_severity'] = drops['global_p95'] - drops['min_value_in_window']

# For better context, get the timestamp when min_value_in_window occurred (exact earliest timestamp where value == min)
if not drops.empty:
    # create a helper map for earliest timestamp of min per group
    min_ts_rows = (
        metric_window
        .merge(drops[['cmdb_id','kpi_name','min_value_in_window']], on=['cmdb_id','kpi_name'], how='inner')
    )
    # filter rows equal to min and get earliest timestamp per group
    min_ts = (
        min_ts_rows[min_ts_rows['value'] == min_ts_rows['min_value_in_window']]
        .groupby(['cmdb_id','kpi_name'], as_index=False)
        .agg(earliest_min_timestamp=('timestamp','min'))
    )
    drops = drops.merge(min_ts, on=['cmdb_id','kpi_name'], how='left')

# Prepare compact outputs: top anomalies (up to 20) and top drops (up to 10)
anomalies_top20 = anomalies_grouped[['cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp','max_value_in_window','global_p95']].head(20)
drops_top10 = drops.sort_values('drop_severity', ascending=False)[['cmdb_id','kpi_name','points_in_window','min_value_in_window','global_p05','global_p95','drop_severity','earliest_min_timestamp']].head(10)

# Also include a short status string about which threshold was used
threshold_used_flag = pd.DataFrame([{'used_threshold': used_threshold, 'anomalies_found': bool(not anomalies_grouped.empty)}])

# Display (as variables)
metric_selected.shape, thresholds.head(50), metric_window.shape, threshold_used_flag, anomalies_top20, drops_top10
