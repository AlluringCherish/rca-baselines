import pandas as pd

# 1) Load files and normalize columns
metric = pd.read_csv("metric.csv")
log = pd.read_csv("log.csv")
trace = pd.read_csv("trace.csv")

for df in (metric, log, trace):
    # parse timestamp to UTC datetime as required
    df['timestamp'] = pd.to_datetime(df['timestamp'], unit='s', utc=True)

# Rename KPI column in log and trace to unify with metric
log = log.rename(columns={'log_name': 'kpi_name'})
trace = trace.rename(columns={'trace_name': 'kpi_name'})

# Keep only relevant columns and ensure numeric values
metric = metric[['timestamp', 'cmdb_id', 'kpi_name', 'value']]
log = log[['timestamp', 'cmdb_id', 'kpi_name', 'value']]
trace = trace[['timestamp', 'cmdb_id', 'kpi_name', 'value']]

for df in (metric, log, trace):
    df['value'] = pd.to_numeric(df['value'], errors='coerce')

# Tag source
metric['source_file'] = 'metric'
log['source_file'] = 'log'
trace['source_file'] = 'trace'

# 2) Compute global P95 per (source_file, cmdb_id, kpi_name) using entire series
all_df = pd.concat([metric, log, trace], ignore_index=True)

# drop NaNs in value for threshold calculation
valid_vals = all_df.dropna(subset=['value'])
group_cols = ['source_file', 'cmdb_id', 'kpi_name']
global_p95 = (
    valid_vals
    .groupby(group_cols)['value']
    .quantile(0.95)
    .reset_index()
    .rename(columns={'value': 'global_p95'})
)

# 3) Filter to incident window and compute counts & anomalies
start = pd.to_datetime("2024-01-19 21:31:51", utc=True)
end = pd.to_datetime("2024-01-19 22:01:51", utc=True)

window_df = all_df[(all_df['timestamp'] >= start) & (all_df['timestamp'] <= end)].copy()

# Merge to get global_p95 attached to windowed points (some series may not exist in global_p95 if all values were NaN)
window_with_p95 = window_df.merge(global_p95, on=group_cols, how='left')

# Count points and anomalies per series
agg = (
    window_with_p95
    .assign(is_anomaly = lambda d: (d['value'] >= d['global_p95']).fillna(False))
    .groupby(group_cols + ['source_file'], as_index=False)
    .agg(
        count_in_window = ('value', 'count'),
        count_anomalies_in_window = ('is_anomaly', 'sum'),
        earliest_anomaly_ts = (lambda d: d.loc[d['is_anomaly'], 'timestamp'].min() if d['is_anomaly'].any() else pd.NaT)
    )
)

# The above agg with a lambda for earliest_anomaly_ts may not behave as named aggregation in older pandas.
# Ensure earliest_anomaly_ts is present by computing separately if needed:
if 'earliest_anomaly_ts' not in agg.columns:
    grouped = window_with_p95.groupby(group_cols + ['source_file'])
    agg = grouped.agg(
        count_in_window = ('value', 'count'),
        count_anomalies_in_window = (lambda d: (d['value'] >= d['global_p95']).fillna(False).sum())
    ).reset_index()
    # compute earliest anomaly timestamp
    def earliest_anom(g):
        s = g.loc[g['value'] >= g['global_p95'], 'timestamp']
        return s.min() if not s.empty else pd.NaT
    earliest = window_with_p95.groupby(group_cols + ['source_file']).apply(earliest_anom).reset_index(name='earliest_anomaly_ts')
    agg = agg.merge(earliest, on=group_cols + ['source_file'], how='left')

# Merge global_p95 into the aggregated summary
summary = agg.merge(global_p95, on=group_cols, how='left')

# Format earliest_anomaly_ts as ISO UTC string (or keep NaN)
summary['earliest_anomaly_timestamp_utc'] = summary['earliest_anomaly_ts'].dt.strftime('%Y-%m-%dT%H:%M:%SZ')
summary.loc[summary['earliest_anomaly_ts'].isna(), 'earliest_anomaly_timestamp_utc'] = pd.NA

# Select and order requested columns
summary_df = summary[
    ['source_file', 'cmdb_id', 'kpi_name', 'global_p95', 'count_in_window', 'count_anomalies_in_window', 'earliest_anomaly_timestamp_utc']
].sort_values(by=['count_anomalies_in_window', 'source_file'], ascending=[False, True]).head(50).reset_index(drop=True)

# 5) Also return unique cmdb_id values across all files and unique KPI names per source (top 50 each)
unique_cmdb_ids = pd.Series(sorted(all_df['cmdb_id'].dropna().unique()), name='cmdb_id')

# unique KPI names per source
kpis_per_source = (
    all_df[['source_file', 'kpi_name']]
    .drop_duplicates()
    .sort_values(['source_file', 'kpi_name'])
    .groupby('source_file')
    .head(50)
    .reset_index(drop=True)
)

# Display the requested outputs compactly
summary_df, unique_cmdb_ids, kpis_per_source
