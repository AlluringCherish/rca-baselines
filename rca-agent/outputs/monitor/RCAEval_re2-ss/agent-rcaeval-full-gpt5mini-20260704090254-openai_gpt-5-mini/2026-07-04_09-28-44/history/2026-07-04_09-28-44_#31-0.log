import pandas as pd
import numpy as np

# Load trace.csv
trace = pd.read_csv("trace.csv")

# Parse timestamp as UTC datetimes (Unix seconds)
trace['timestamp'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True)

# Detect trace name column and normalize to 'trace_name'
cols = trace.columns.tolist()
if 'trace_name' in cols:
    pass
elif 'kpi_name' in cols:
    trace = trace.rename(columns={'kpi_name': 'trace_name'})
else:
    # try to find a column that contains 'trace' or 'name'
    found = None
    for c in cols:
        if 'trace' in c.lower() or 'name' in c.lower():
            if c not in ('cmdb_id','timestamp','value'):
                found = c
                break
    if found:
        trace = trace.rename(columns={found: 'trace_name'})
    else:
        raise KeyError("No trace name column found in trace.csv")

# Focus candidates
candidates = ['catalogue', 'front-end', 'orders', 'payment', 'queue-master']
trace = trace[trace['cmdb_id'].isin(candidates)].copy()
trace['value'] = pd.to_numeric(trace['value'], errors='coerce')

# Compute global P95 per (cmdb_id, trace_name) using all available points (do NOT filter by window)
group_keys = ['cmdb_id', 'trace_name']
global_p95 = (
    trace.dropna(subset=['value'])
    .groupby(group_keys, as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# Incident window (UTC)
start = pd.to_datetime("2024-01-19 21:31:51", utc=True)
end = pd.to_datetime("2024-01-19 22:01:51", utc=True)

# Filter rows to the incident window (inclusive)
trace_window = trace[(trace['timestamp'] >= start) & (trace['timestamp'] <= end)].copy()

# Attach global_p95 to windowed rows
trace_window = trace_window.merge(global_p95, on=group_keys, how='left')

# Determine anomalies (value >= global_p95). If global_p95 is NaN or value NaN -> False
mask = trace_window['global_p95'].notna() & trace_window['value'].notna()
trace_window['is_anom'] = False
trace_window.loc[mask, 'is_anom'] = trace_window.loc[mask, 'value'] >= trace_window.loc[mask, 'global_p95']

# Aggregate per (cmdb_id, trace_name)
rows = []
for (cmdb_id, trace_name), grp in trace_window.groupby(group_keys):
    count_in_window = int(grp['value'].count())
    count_anoms = int(grp['is_anom'].sum())
    if count_anoms > 0:
        anom_grp = grp[grp['is_anom']]
        earliest_iso = anom_grp['timestamp'].min().strftime('%Y-%m-%dT%H:%M:%SZ')
        max_anom = float(anom_grp['value'].max())
        mean_anom = float(anom_grp['value'].mean())
    else:
        earliest_iso = pd.NA
        max_anom = np.nan
        mean_anom = np.nan
    gp95 = grp['global_p95'].iloc[0] if 'global_p95' in grp.columns else np.nan
    rows.append({
        'cmdb_id': cmdb_id,
        'trace_name': trace_name,
        'global_p95': gp95,
        'count_in_window': count_in_window,
        'count_anomalies_in_window': count_anoms,
        'earliest_anomaly_timestamp_utc': earliest_iso,
        'max_anomaly_value_in_window': max_anom,
        'mean_anomaly_value_in_window': mean_anom
    })

result_df = pd.DataFrame(rows)

# Include series that have global_p95 but no points in window (ensure they appear with count_in_window=0)
all_series = global_p95.copy()
all_series = all_series.merge(result_df, on=['cmdb_id','trace_name','global_p95'], how='left')
# Fill missing window stats with zeros/NA
all_series['count_in_window'] = all_series['count_in_window'].fillna(0).astype(int)
all_series['count_anomalies_in_window'] = all_series['count_anomalies_in_window'].fillna(0).astype(int)
all_series['earliest_anomaly_timestamp_utc'] = all_series['earliest_anomaly_timestamp_utc'].where(all_series['earliest_anomaly_timestamp_utc'].notna(), pd.NA)
all_series['max_anomaly_value_in_window'] = all_series['max_anomaly_value_in_window'].astype(float)
all_series['mean_anomaly_value_in_window'] = all_series['mean_anomaly_value_in_window'].astype(float)

# Sort by count_anomalies_in_window desc, then by max_anomaly_value_in_window desc, limit top 20
result_df = all_series.sort_values(by=['count_anomalies_in_window', 'max_anomaly_value_in_window'], ascending=[False, False]).head(20)

# Keep only requested columns in compact order and display
