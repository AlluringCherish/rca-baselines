import pandas as pd
import numpy as np

# Reuse trace if present, otherwise load
try:
    trace
except NameError:
    trace = pd.read_csv("trace.csv")

# Ensure timestamp parsed as UTC datetimes (Unix seconds)
if not pd.api.types.is_datetime64_any_dtype(trace['timestamp']):
    trace['timestamp'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True)

# Focused components
candidates = ['catalogue', 'front-end', 'orders', 'payment', 'queue-master']

# Filter to candidate cmdb_ids for threshold calculation and windowing
trace_cand = trace[trace['cmdb_id'].isin(candidates)].copy()
trace_cand['value'] = pd.to_numeric(trace_cand['value'], errors='coerce')

# Compute global P95 per (cmdb_id, trace_name) using all available points (do NOT filter by window)
group_keys = ['cmdb_id', 'trace_name']
global_p95 = (
    trace_cand.dropna(subset=['value'])
    .groupby(group_keys, as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# Incident window (UTC)
start = pd.to_datetime("2024-01-19 21:31:51", utc=True)
end = pd.to_datetime("2024-01-19 22:01:51", utc=True)

# Filter rows to the incident window (inclusive)
trace_window = trace_cand[(trace_cand['timestamp'] >= start) & (trace_cand['timestamp'] <= end)].copy()

# Attach global_p95 to windowed rows
trace_window = trace_window.merge(global_p95, on=group_keys, how='left')

# Determine anomalies (value >= global_p95). If global_p95 is NaN, treat as non-anomaly.
mask = trace_window['global_p95'].notna() & trace_window['value'].notna()
trace_window['is_anom'] = False
trace_window.loc[mask, 'is_anom'] = trace_window.loc[mask, 'value'] >= trace_window.loc[mask, 'global_p95']

# Aggregate required fields per (cmdb_id, trace_name)
agg = (
    trace_window
    .groupby(group_keys, as_index=False)
    .agg(
        global_p95 = ('global_p95', 'first'),
        count_in_window = ('value', 'count'),
        count_anomalies_in_window = ('is_anom', 'sum'),
        earliest_anomaly_ts = ('timestamp', lambda x: x[trace_window.loc[x.index, 'is_anom']].min() if any(trace_window.loc[x.index, 'is_anom']) else pd.NaT),
        max_anomaly_value_in_window = ('value', lambda x: x[trace_window.loc[x.index, 'is_anom']].max() if any(trace_window.loc[x.index, 'is_anom']) else np.nan),
        mean_anomaly_value_in_window = ('value', lambda x: x[trace_window.loc[x.index, 'is_anom']].mean() if any(trace_window.loc[x.index, 'is_anom']) else np.nan)
    )
)

# Format earliest anomaly timestamp to ISO UTC string, or NA
agg['earliest_anomaly_timestamp_utc'] = agg['earliest_anomaly_ts'].dt.strftime('%Y-%m-%dT%H:%M:%SZ')
agg.loc[agg['earliest_anomaly_ts'].isna(), 'earliest_anomaly_timestamp_utc'] = pd.NA
agg = agg.drop(columns=['earliest_anomaly_ts'])

# Ensure numeric types
agg['count_anomalies_in_window'] = agg['count_anomalies_in_window'].astype(int)
agg['count_in_window'] = agg['count_in_window'].astype(int)

# Sort by count_anomalies_in_window desc, then by max_anomaly_value_in_window desc, limit top 20
result_df = agg.sort_values(by=['count_anomalies_in_window', 'max_anomaly_value_in_window'], ascending=[False, False]).head(20)

# Keep only requested columns in compact order
result_df = result_df[[
    'cmdb_id', 'trace_name', 'global_p95', 'count_in_window', 'count_anomalies_in_window',
    'earliest_anomaly_timestamp_utc', 'max_anomaly_value_in_window', 'mean_anomaly_value_in_window'
]]

result_df
