from datetime import datetime

def fmt_top(df, namecol, limit=20):
    if df is None or df.empty:
        return "none"
    pairs = [f"{row[0]} ({row[1]})" for row in df[[namecol, 'count']].head(limit).itertuples(index=False, name=None)]
    return ", ".join(pairs)

summary = (
