def get_stats(df, cmdb, name_col, name):
    sub = df[(df['cmdb_id']==cmdb) & (df[name_col]==name)]
    if sub.empty:
        return None
    row = sub.iloc[0]
    return row['mean(value)'], row['max(value)'], int(row['count'])

