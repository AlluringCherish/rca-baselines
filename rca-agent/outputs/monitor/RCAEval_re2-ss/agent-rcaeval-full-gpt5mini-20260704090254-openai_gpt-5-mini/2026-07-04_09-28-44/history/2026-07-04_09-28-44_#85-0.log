import pandas as pd

# Read CSVs and parse timestamps as UTC
metric_df = pd.read_csv("metric.csv")
metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True)

trace_df = pd.read_csv("trace.csv")
trace_df['timestamp'] = pd.to_datetime(trace_df['timestamp'], unit='s', utc=True)

log_df = pd.read_csv("log.csv")
log_df['timestamp'] = pd.to_datetime(log_df['timestamp'], unit='s', utc=True)

error_df = pd.read_csv("error_logs.csv")
error_df['timestamp'] = pd.to_datetime(error_df['timestamp'], unit='s', utc=True)

# Aggregation helper: compute count, min, max, mean, p95 for a given dataframe and grouping columns/value column
def summarize(df, group_cols, value_col, value_label):
    agg = df.groupby(group_cols)[value_col].agg(
        **{
            'count': ('count'),
            'min(value)': ('min'),
            'max(value)': ('max'),
            'mean(value)': ('mean'),
            'p95(value)': (lambda x: x.quantile(0.95))
        }
    )
    # The above named-agg with lambda produces a column named '<lambda>' unless explicitly set;
    # So re-create with explicit tuple syntax to ensure proper names across pandas versions.
    agg = df.groupby(group_cols)[value_col].agg(
        count='count',
        **{'min(value)': 'min', 'max(value)': 'max', 'mean(value)': 'mean'}
    )
    # compute p95 separately to avoid lambda naming inconsistencies
    p95 = df.groupby(group_cols)[value_col].quantile(0.95).rename('p95(value)')
    agg = agg.join(p95)
    agg = agg.reset_index()
    agg = agg.sort_values('count', ascending=False)
    return agg

# Summaries as requested (top up to 50 rows)
metric_summary = summarize(metric_df, ['cmdb_id', 'kpi_name'], 'value', 'kpi_name').head(50)
trace_summary  = summarize(trace_df,   ['cmdb_id', 'trace_name'], 'value', 'trace_name').head(50)
log_summary    = summarize(log_df,     ['cmdb_id', 'log_name'], 'value', 'log_name').head(50)

# Unique cmdb_id values across all four files
cmdb_ids = sorted(set(metric_df['cmdb_id'].dropna().unique()) |
                  set(trace_df['cmdb_id'].dropna().unique()) |
                  set(log_df['cmdb_id'].dropna().unique()) |
                  set(error_df['cmdb_id'].dropna().unique()))
cmdb_ids_series = pd.Series(cmdb_ids, name='cmdb_id')

# Return the summaries and the cmdb_id list (compact)
metric_summary, trace_summary, log_summary, cmdb_ids_series
