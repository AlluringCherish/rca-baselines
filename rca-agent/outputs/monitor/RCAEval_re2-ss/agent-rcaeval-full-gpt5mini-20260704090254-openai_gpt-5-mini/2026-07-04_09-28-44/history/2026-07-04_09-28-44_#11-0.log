# reuse df_metric if available; otherwise load
try:
    df_metric
except NameError:
    import pandas as pd
    df_metric = pd.read_csv("metric.csv")
    df_metric['timestamp'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)

import pandas as pd

# Ensure timestamp parsed
if df_metric['timestamp'].dtype == object:
    df_metric['timestamp'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)

# 1) Calculate global P95 and P05 per (cmdb_id, kpi_name) using entire series (before filtering)
grp = df_metric.groupby(['cmdb_id', 'kpi_name'])['value']
global_p95 = grp.quantile(0.95).rename('global_p95')
global_p05 = grp.quantile(0.05).rename('global_p05')
thresholds = pd.concat([global_p95, global_p05], axis=1).reset_index()

# 2) Filter metric rows to the incident window (UTC)
start_ts = pd.Timestamp("2024-01-20 05:42:43", tz='UTC')
end_ts   = pd.Timestamp("2024-01-20 06:12:43", tz='UTC')
df_window = df_metric[(df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] <= end_ts)].copy()

# 3) Merge thresholds into window rows so comparisons use global thresholds
df_w = df_window.merge(thresholds, on=['cmdb_id','kpi_name'], how='left')

# 4) Aggregate per (cmdb_id, kpi_name)
def agg_window(g):
    cnt = len(g)
    # counts relative to global thresholds (which were merged in)
    ge_mask = g['value'] >= g['global_p95']
    le_mask = g['value'] <= g['global_p05']
    count_ge_p95 = int(ge_mask.sum())
    count_le_p05 = int(le_mask.sum())
    # earliest timestamps where conditions hold
    first_ge_ts = g.loc[ge_mask, 'timestamp'].min() if count_ge_p95>0 else pd.NaT
    first_le_ts = g.loc[le_mask, 'timestamp'].min() if count_le_p05>0 else pd.NaT
    # convert to ISO strings or None
    first_ge_iso = first_ge_ts.isoformat() if pd.notna(first_ge_ts) else None
    first_le_iso = first_le_ts.isoformat() if pd.notna(first_le_ts) else None
    return pd.Series({
        'count_in_window': cnt,
        'global_p95': float(g['global_p95'].iloc[0]) if pd.notna(g['global_p95'].iloc[0]) else float('nan'),
        'global_p05': float(g['global_p05'].iloc[0]) if pd.notna(g['global_p05'].iloc[0]) else float('nan'),
        'count_ge_p95': count_ge_p95,
        'first_ge_p95_ts': first_ge_iso,
        'max_value_in_window': float(g['value'].max()) if cnt>0 else float('nan'),
        'count_le_p05': count_le_p05,
        'first_le_p05_ts': first_le_iso,
        'min_value_in_window': float(g['value'].min()) if cnt>0 else float('nan')
    })

agg = df_w.groupby(['cmdb_id','kpi_name']).apply(agg_window).reset_index()

# Keep only pairs that had at least one row in the window
agg_nonzero = agg[agg['count_in_window']>0].copy()

# Sort by combined anomalies (count_ge_p95 + count_le_p05) descending and take top 20
agg_nonzero['severity_sum'] = agg_nonzero['count_ge_p95'] + agg_nonzero['count_le_p05']
result = agg_nonzero.sort_values(['severity_sum','count_in_window'], ascending=[False, False]).head(20)

# Select and order the requested fields for compact display
result_df = result[[
    'cmdb_id','kpi_name',
    'count_in_window',
    'global_p95','global_p05',
    'count_ge_p95','first_ge_p95_ts','max_value_in_window',
    'count_le_p05','first_le_p05_ts','min_value_in_window'
]].reset_index(drop=True)

result_df
