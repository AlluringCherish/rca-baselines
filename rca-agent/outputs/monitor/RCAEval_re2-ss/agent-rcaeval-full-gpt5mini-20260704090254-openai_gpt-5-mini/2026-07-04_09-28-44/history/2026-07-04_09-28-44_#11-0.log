import pandas as pd

# filenames
metric_file = "metric.csv"
trace_file = "trace.csv"
log_file = "log.csv"
error_file = "error_logs.csv"

# Load CSVs and parse timestamps (UTC)
df_metric = pd.read_csv(metric_file)
df_metric['timestamp'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)

df_trace = pd.read_csv(trace_file)
df_trace['timestamp'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True)

df_log = pd.read_csv(log_file)
df_log['timestamp'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True)

df_error = pd.read_csv(error_file)
df_error['timestamp'] = pd.to_datetime(df_error['timestamp'], unit='s', utc=True)

# Helper to build a compact one-row summary DataFrame
def compact_summary(df, ts_col='timestamp'):
    nrows = len(df)
    if nrows:
        min_ts = df[ts_col].min().isoformat()
        max_ts = df[ts_col].max().isoformat()
    else:
        min_ts = None
        max_ts = None
    uniq_cmdb = int(df['cmdb_id'].nunique()) if 'cmdb_id' in df.columns else 0
    return pd.DataFrame([{
        'nrows': nrows,
        'min_timestamp_utc': min_ts,
        'max_timestamp_utc': max_ts,
        'unique_cmdb_id_count': uniq_cmdb
    }])

# Summaries
metric_summary = compact_summary(df_metric)
trace_summary = compact_summary(df_trace)
log_summary = compact_summary(df_log)
error_summary = compact_summary(df_error)

# Top up to 20 cmdb_id counts per file
metric_cmdb_top = df_metric['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count').head(20)
trace_cmdb_top = df_trace['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count').head(20)
log_cmdb_top = df_log['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count').head(20)
error_cmdb_top = df_error['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count').head(20)

# Metric: top up to 20 kpi_name values and counts
if 'kpi_name' in df_metric.columns:
    metric_kpi_top = df_metric['kpi_name'].value_counts().rename_axis('kpi_name').reset_index(name='count').head(20)
else:
    metric_kpi_top = pd.DataFrame(columns=['kpi_name', 'count'])

# Trace: top up to 20 trace_name values and counts
if 'trace_name' in df_trace.columns:
    trace_name_top = df_trace['trace_name'].value_counts().rename_axis('trace_name').reset_index(name='count').head(20)
else:
    trace_name_top = pd.DataFrame(columns=['trace_name', 'count'])

# Log: top up to 20 log_name values and counts
if 'log_name' in df_log.columns:
    log_name_top = df_log['log_name'].value_counts().rename_axis('log_name').reset_index(name='count').head(20)
else:
    log_name_top = pd.DataFrame(columns=['log_name', 'count'])

# Error logs: up to first 5 distinct messages with counts, and top 20 cmdb_id counts (already computed)
if 'message' in df_error.columns:
    error_messages_top5 = df_error['message'].value_counts().rename_axis('message').reset_index(name='count').head(5)
else:
    error_messages_top5 = pd.DataFrame(columns=['message', 'count'])

# Final compact outputs (variables to display)
metric_summary, metric_cmdb_top, metric_kpi_top, trace_summary, trace_cmdb_top, trace_name_top, log_summary, log_cmdb_top, log_name_top, error_summary, error_messages_top5, error_cmdb_top
