# Reuse df_log if available, otherwise load and parse timestamps
try:
    df_log
except NameError:
    import pandas as pd
    df_log = pd.read_csv("log.csv")
    df_log['timestamp'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True)

import pandas as pd
# Ensure timestamp parsed and value numeric
if df_log['timestamp'].dtype == object:
    df_log['timestamp'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True)
df_log['value'] = pd.to_numeric(df_log['value'], errors='coerce')

# Incident window (UTC)
start_ts = pd.Timestamp("2024-01-20 05:42:43", tz='UTC')
end_ts   = pd.Timestamp("2024-01-20 06:12:43", tz='UTC')

# Filter rows to window
df_log_window = df_log[(df_log['timestamp'] >= start_ts) & (df_log['timestamp'] <= end_ts)].copy()

# Aggregate per (cmdb_id, log_name)
def agg_logs(g):
    cnt = len(g)
    nonzero_mask = g['value'] > 0
    count_nonzero = int(nonzero_mask.sum())
    if count_nonzero > 0:
        first_nonzero_ts = g.loc[nonzero_mask, 'timestamp'].min().isoformat()
    else:
        first_nonzero_ts = None
    return pd.Series({
        'count_in_window': cnt,
        'count_nonzero': count_nonzero,
        'first_nonzero_ts': first_nonzero_ts,
        'max_value_in_window': float(g['value'].max()) if cnt>0 else float('nan'),
        'min_value_in_window': float(g['value'].min()) if cnt>0 else float('nan'),
        'mean_value_in_window': float(g['value'].mean()) if cnt>0 else float('nan')
    })

agg = df_log_window.groupby(['cmdb_id','log_name']).apply(agg_logs).reset_index()

# Sort by count_nonzero descending and take top 20
result_df = agg.sort_values(['count_nonzero','count_in_window'], ascending=[False, False]).head(20).reset_index(drop=True)

# Additionally: for log.error_count, list cmdb_id with count_nonzero>0 and their earliest non-zero timestamps (top 20)
error_mask = (df_log_window['log_name'] == 'log.error_count')
if error_mask.any():
    err_agg = df_log_window[error_mask].groupby('cmdb_id').apply(
        lambda g: pd.Series({
            'count_in_window': int(len(g)),
            'count_nonzero': int((g['value']>0).sum()),
            'first_nonzero_ts': (g.loc[g['value']>0, 'timestamp'].min().isoformat() if (g['value']>0).any() else None)
        })
    ).reset_index()
    error_nonzero_df = err_agg[err_agg['count_nonzero']>0].sort_values(['count_nonzero','count_in_window'], ascending=[False, False]).head(20).reset_index(drop=True)
else:
    error_nonzero_df = pd.DataFrame(columns=['cmdb_id','count_in_window','count_nonzero','first_nonzero_ts'])

# Return the two compact DataFrames
result_df, error_nonzero_df
