import pandas as pd
import numpy as np

# reuse df_metric if available
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
# ensure timestamp_dt exists and is UTC-aware
if 'timestamp_dt' not in df_metric.columns:
    df_metric['timestamp_dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)

# 1) Compute global P95 and P5 per (cmdb_id, kpi_name) using the full series (BEFORE filtering)
thresholds = (
    df_metric.groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(global_p95=lambda x: x.quantile(0.95), global_p5=lambda x: x.quantile(0.05))
    .reset_index()
)

# 2) Filter metric rows to the incident window and target cmdb_ids
start = pd.to_datetime("2024-01-20 07:02:05", utc=True)
end = pd.to_datetime("2024-01-20 07:32:05", utc=True)
target_cmdb = ["carts", "catalogue", "orders", "payment", "user"]

df_window = df_metric[
    (df_metric['timestamp_dt'] >= start) &
    (df_metric['timestamp_dt'] <= end) &
    (df_metric['cmdb_id'].isin(target_cmdb))
].copy()

# attach thresholds (computed on full series)
df_window = df_window.merge(thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# 3) Mark anomalies: 'high' if value >= global_p95 else 'low' if value <= global_p5 else NaN
# Ensure deterministic precedence: prefer 'high' when both conditions hold.
cond_high = df_window['value'] >= df_window['global_p95']
cond_low = df_window['value'] <= df_window['global_p5']
df_window['anomaly_type'] = np.where(cond_high, 'high', np.where(cond_low, 'low', np.nan))

# 4) Keep only anomaly rows and compute consecutive runs
df_anom = df_window[df_window['anomaly_type'].notna()].copy()

if df_anom.empty:
    runs = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','anomaly_type',
        'run_start_timestamp','run_end_timestamp','run_length',
        'min_value_in_run','max_value_in_run','global_p95','global_p5','severity_metric'
    ])
else:
    # sort for run detection
    df_anom = df_anom.sort_values(['cmdb_id','kpi_name','timestamp_dt']).reset_index(drop=True)

    # compute time difference in seconds from previous row within same (cmdb_id,kpi_name)
    df_anom['prev_ts'] = df_anom.groupby(['cmdb_id','kpi_name'])['timestamp_dt'].shift(1)
    df_anom['prev_type'] = df_anom.groupby(['cmdb_id','kpi_name'])['anomaly_type'].shift(1)
    df_anom['dt_seconds'] = (df_anom['timestamp_dt'] - df_anom['prev_ts']).dt.total_seconds()

    # A new run starts when:
    # - previous row is missing (first row for group), OR
    # - anomaly_type changed compared to previous, OR
    # - timestamp is not consecutive (not exactly 60s apart)
    df_anom['new_run'] = (
        df_anom['prev_ts'].isna() |
        (df_anom['anomaly_type'] != df_anom['prev_type']) |
        (df_anom['dt_seconds'] != 60)
    )

    # cumulative run id per group
    df_anom['run_id'] = df_anom.groupby(['cmdb_id','kpi_name'])['new_run'].cumsum()

    # aggregate per run (group by cmdb_id,kpi_name,run_id,anomaly_type)
    agg = (
        df_anom.groupby(['cmdb_id','kpi_name','anomaly_type','run_id'])
        .agg(
            run_start_timestamp=('timestamp_dt', 'min'),
            run_end_timestamp=('timestamp_dt', 'max'),
            run_length=('timestamp_dt', 'size'),
            min_value_in_run=('value', 'min'),
            max_value_in_run=('value', 'max'),
            global_p95=('global_p95', 'first'),
            global_p5=('global_p5', 'first'),
        )
        .reset_index(drop=False)
    )

    # compute severity_metric per run
    def compute_severity(row):
        if row['anomaly_type'] == 'high':
            denom = max(1e-9, float(row['global_p95']))
            return (float(row['max_value_in_run']) - float(row['global_p95'])) / denom
        else:  # low
            denom = max(1e-9, float(row['global_p5']))
            return (float(row['global_p5']) - float(row['min_value_in_run'])) / denom

    agg['severity_metric'] = agg.apply(compute_severity, axis=1)

    # select and order columns as requested
    runs = agg[[
        'cmdb_id','kpi_name','anomaly_type',
        'run_start_timestamp','run_end_timestamp','run_length',
        'min_value_in_run','max_value_in_run','global_p95','global_p5','severity_metric'
    ]].copy()

    # make timestamps ISO strings for compact display
    runs['run_start_timestamp'] = runs['run_start_timestamp'].dt.tz_convert(None)  # naive UTC
    runs['run_end_timestamp'] = runs['run_end_timestamp'].dt.tz_convert(None)

    # round numeric columns for compactness
    for c in ['min_value_in_run','max_value_in_run','global_p95','global_p5','severity_metric']:
        runs[c] = runs[c].astype(float).round(6)

# 5) Sort by run_length desc then severity_metric desc, limit top 20
runs_sorted = runs.sort_values(['run_length','severity_metric'], ascending=[False, False]).head(20)

# total number of runs found
total_runs = int(runs.shape[0])

# final compact output (store intermediate variables in kernel as requested)
runs_sorted, total_runs
