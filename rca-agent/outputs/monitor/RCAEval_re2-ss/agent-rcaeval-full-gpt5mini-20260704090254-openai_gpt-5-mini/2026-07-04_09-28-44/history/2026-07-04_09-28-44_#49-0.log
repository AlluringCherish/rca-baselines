import pandas as pd

# load metric data
df_metric = pd.read_csv('metric.csv')

# parse timestamps to UTC datetimes (rule 10)
df_metric['timestamp_dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)

# global totals and bounds
total_rows = df_metric.shape[0]
global_min_ts = df_metric['timestamp_dt'].min()
global_max_ts = df_metric['timestamp_dt'].max()

# aggregated statistics per (cmdb_id, kpi_name) using the full series (no filtering)
agg = df_metric.groupby(['cmdb_id', 'kpi_name']).agg(
    count=('value', 'size'),
    min_timestamp=('timestamp_dt', 'min'),
    max_timestamp=('timestamp_dt', 'max'),
    mean_value=('value', 'mean'),
    p50=('value', lambda x: x.quantile(0.5)),
    p95=('value', lambda x: x.quantile(0.95)),
    max_value=('value', 'max'),
).reset_index()

# round numeric columns for compact display
for c in ['mean_value', 'p50', 'p95', 'max_value']:
    if c in agg.columns:
        agg[c] = agg[c].round(6)

# sort by count descending and keep top 20
aggregated_top20 = agg.sort_values('count', ascending=False).head(20)

# display compact results: aggregated_top20, total rows, global min/max timestamps
aggregated_top20, total_rows, global_min_ts, global_max_ts
