import pandas as pd

# reuse df_metric if present; otherwise load and parse timestamps
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
if 'timestamp_dt' not in df_metric.columns:
    df_metric['timestamp_dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)

# 1) Compute global thresholds (P95 and P5) per (cmdb_id, kpi_name) using the full series BEFORE filtering
thresholds = (
    df_metric.groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(global_p95=lambda x: x.quantile(0.95), global_p5=lambda x: x.quantile(0.05))
    .reset_index()
)

# 2) Define incident window in UTC and target cmdb_ids
start = pd.to_datetime("2024-01-20 07:02:05", utc=True)
end = pd.to_datetime("2024-01-20 07:32:05", utc=True)
target_cmdb = ["carts", "catalogue", "orders", "payment", "user"]

# 3) Filter metric rows to the incident window and to target cmdb_ids
df_window = df_metric[
    (df_metric['timestamp_dt'] >= start) &
    (df_metric['timestamp_dt'] <= end) &
    (df_metric['cmdb_id'].isin(target_cmdb))
].copy()
window_total_rows = df_window.shape[0]

# 4) Attach global thresholds to the windowed rows (thresholds computed on full series)
df_window = df_window.merge(thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# 5) Detect anomalies using the precomputed global thresholds
high_mask = df_window['value'] >= df_window['global_p95']
low_mask = df_window['value'] <= df_window['global_p5']

df_high = df_window[high_mask].copy()
df_high['anomaly_type'] = 'high'
df_low = df_window[low_mask].copy()
df_low['anomaly_type'] = 'low'

df_anom = pd.concat([df_high, df_low], ignore_index=True)
# If no anomalies, produce an empty aggregated frame with expected columns
if df_anom.empty:
    agg_result = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','anomaly_type','anomaly_count',
        'earliest_anomaly_timestamp','latest_anomaly_timestamp',
        'min_value_in_window','max_value_in_window','global_p95','global_p5'
    ])
else:
    agg_result = (
        df_anom.groupby(['cmdb_id', 'kpi_name', 'anomaly_type'])
        .agg(
            anomaly_count=('value', 'size'),
            earliest_anomaly_timestamp=('timestamp_dt', 'min'),
            latest_anomaly_timestamp=('timestamp_dt', 'max'),
            min_value_in_window=('value', 'min'),
            max_value_in_window=('value', 'max'),
            global_p95=('global_p95', 'first'),
            global_p5=('global_p5', 'first'),
        )
        .reset_index()
    )
    # Round numeric columns for compact display
    for c in ['min_value_in_window', 'max_value_in_window', 'global_p95', 'global_p5']:
        if c in agg_result.columns:
            agg_result[c] = agg_result[c].round(6)

# 6) Sort by anomaly_count descending and limit to top 50
agg_result_sorted = agg_result.sort_values('anomaly_count', ascending=False).head(50)

# Display compact result and the number of window rows considered
agg_result_sorted, window_total_rows
