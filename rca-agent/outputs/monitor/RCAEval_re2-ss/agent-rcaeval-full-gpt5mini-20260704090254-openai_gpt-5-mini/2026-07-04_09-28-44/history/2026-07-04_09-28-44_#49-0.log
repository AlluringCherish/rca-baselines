import pandas as pd

# reuse df_metric if available; otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
    df_metric['timestamp_dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)

# ensure timestamp_dt exists and is UTC-aware
if 'timestamp_dt' not in df_metric.columns:
    df_metric['timestamp_dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)

# 1) Compute global P95 and P5 per (cmdb_id, kpi_name) using the full series (do BEFORE filtering)
thresholds = (
    df_metric.groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(global_p95=lambda x: x.quantile(0.95), global_p5=lambda x: x.quantile(0.05))
    .reset_index()
)

# 2) Define incident window in UTC
start = pd.to_datetime("2024-01-20 07:02:05", utc=True)
end = pd.to_datetime("2024-01-20 07:32:05", utc=True)

# 3) Filter metric rows to the incident window (inclusive)
df_window = df_metric[(df_metric['timestamp_dt'] >= start) & (df_metric['timestamp_dt'] <= end)].copy()
window_total_rows = df_window.shape[0]

# 4) Attach global thresholds to windowed rows
df_window = df_window.merge(thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# 5) Detect anomalies within the window using the precomputed global thresholds
# high: value >= global_p95, low: value <= global_p5
def detect_anomaly(row):
    if pd.isna(row['value']) or pd.isna(row['global_p95']) or pd.isna(row['global_p5']):
        return None
    if row['value'] >= row['global_p95']:
        return 'high'
    if row['value'] <= row['global_p5']:
        return 'low'
    return None

df_window['anomaly_type'] = df_window.apply(detect_anomaly, axis=1)
df_anom = df_window[df_window['anomaly_type'].notna()].copy()

# 6) Aggregate per (cmdb_id, kpi_name, anomaly_type)
if not df_anom.empty:
    agg_anom = (
        df_anom.groupby(['cmdb_id', 'kpi_name', 'anomaly_type'])
        .agg(
            anomaly_count=('value', 'size'),
            earliest_anomaly_timestamp=('timestamp_dt', 'min'),
            latest_anomaly_timestamp=('timestamp_dt', 'max'),
            min_value_in_window=('value', 'min'),
            max_value_in_window=('value', 'max'),
            global_p95=('global_p95', 'first'),
            global_p5=('global_p5', 'first'),
        )
        .reset_index()
    )

    # sort by anomaly_count desc and limit to top 20
    agg_anom_sorted = agg_anom.sort_values('anomaly_count', ascending=False).head(20)

    # round numeric columns for compact display
    for c in ['min_value_in_window', 'max_value_in_window', 'global_p95', 'global_p5']:
        if c in agg_anom_sorted.columns:
            agg_anom_sorted[c] = agg_anom_sorted[c].round(6)
else:
    # empty DataFrame with expected columns
    agg_anom_sorted = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','anomaly_type','anomaly_count',
        'earliest_anomaly_timestamp','latest_anomaly_timestamp',
        'min_value_in_window','max_value_in_window','global_p95','global_p5'
    ])

# 7) Display compact results: top anomaly groups and total window rows
agg_anom_sorted, window_total_rows
