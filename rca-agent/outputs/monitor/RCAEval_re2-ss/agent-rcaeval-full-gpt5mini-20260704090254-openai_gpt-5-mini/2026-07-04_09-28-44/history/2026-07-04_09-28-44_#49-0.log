import pandas as pd
import numpy as np

# load trace data (reuse variable if present)
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')

# ensure timestamp_dt exists and is parsed as UTC
if 'timestamp_dt' not in df_trace.columns:
    df_trace['timestamp_dt'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True)

# target services and incident window (UTC)
target_cmdb = ["carts", "catalogue", "orders", "payment", "user"]
start = pd.to_datetime("2024-01-20 07:02:05", utc=True)
end = pd.to_datetime("2024-01-20 07:32:05", utc=True)

# 1) Compute global P95 per (cmdb_id, trace_name) using the full series (BEFORE filtering)
trace_thresholds = (
    df_trace.groupby(['cmdb_id', 'trace_name'])['value']
    .quantile(0.95)
    .reset_index()
    .rename(columns={'value': 'global_p95'})
)

# 2) Filter trace rows to the incident window and target cmdb_ids
df_trace_window = df_trace[
    (df_trace['timestamp_dt'] >= start) &
    (df_trace['timestamp_dt'] <= end) &
    (df_trace['cmdb_id'].isin(target_cmdb))
].copy()

total_trace_rows_in_window = df_trace_window.shape[0]

# 3) Attach global_p95 to windowed rows
df_trace_window = df_trace_window.merge(trace_thresholds, on=['cmdb_id', 'trace_name'], how='left')

# 4) Mark high anomalies in window: value >= global_p95
df_trace_window['is_high'] = df_trace_window['value'] >= df_trace_window['global_p95']

# 5) Aggregate per (cmdb_id, trace_name)
def summarize_group(g):
    gp95 = g['global_p95'].iloc[0] if not g['global_p95'].isna().all() else np.nan
    anom_mask = g['is_high']
    anom_count = int(anom_mask.sum())
    if anom_count > 0:
        earliest = g.loc[anom_mask, 'timestamp_dt'].min()
        latest = g.loc[anom_mask, 'timestamp_dt'].max()
    else:
        earliest = pd.NaT
        latest = pd.NaT
    mean_in_window = float(g['value'].mean()) if not g['value'].empty else np.nan
    max_in_window = float(g['value'].max()) if not g['value'].empty else np.nan
    return pd.Series({
        'global_p95': gp95,
        'anomaly_count_in_window': anom_count,
        'earliest_anomaly_timestamp': earliest,
        'latest_anomaly_timestamp': latest,
        'mean_value_in_window': mean_in_window,
        'max_value_in_window': max_in_window
    })

if df_trace_window.empty:
    trace_summary = pd.DataFrame(columns=[
        'cmdb_id','trace_name','global_p95','anomaly_count_in_window',
        'earliest_anomaly_timestamp','latest_anomaly_timestamp',
        'mean_value_in_window','max_value_in_window'
    ])
else:
    trace_summary = (
        df_trace_window
        .groupby(['cmdb_id', 'trace_name'], as_index=False)
        .apply(summarize_group)
        .reset_index()
    )

# 6) Sort by anomaly_count_in_window descending and limit to top 20
trace_summary_sorted = trace_summary.sort_values('anomaly_count_in_window', ascending=False).head(20)

# Round numeric columns for compact display
for c in ['global_p95', 'mean_value_in_window', 'max_value_in_window']:
    if c in trace_summary_sorted.columns:
        trace_summary_sorted[c] = trace_summary_sorted[c].round(6)

# Final compact outputs: top summary and total rows in window
trace_summary_sorted, total_trace_rows_in_window
