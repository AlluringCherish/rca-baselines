import pandas as pd
import numpy as np

# reuse loaded data if present, otherwise load
try:
    df_log
except NameError:
    df_log = pd.read_csv('log.csv')
if 'timestamp_dt' not in df_log.columns:
    df_log['timestamp_dt'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True)

# Candidate services and incident window
candidates = ["carts", "catalogue", "orders", "payment", "user"]
start = pd.to_datetime("2024-01-20 07:02:05", utc=True)
end = pd.to_datetime("2024-01-20 07:32:05", utc=True)

# 1) Compute global P95 and P5 per (cmdb_id, log_name) using the full series (BEFORE filtering)
log_thresholds = (
    df_log.groupby(['cmdb_id', 'log_name'])['value']
    .agg(global_p95=lambda x: x.quantile(0.95), global_p5=lambda x: x.quantile(0.05))
    .reset_index()
)

# 2) Filter log rows to incident window and candidate services
df_log_window = df_log[
    (df_log['timestamp_dt'] >= start) &
    (df_log['timestamp_dt'] <= end) &
    (df_log['cmdb_id'].isin(candidates))
].copy()
log_window_total_rows = int(df_log_window.shape[0])

# 3) Attach global thresholds to the filtered rows
df_log_window = df_log_window.merge(log_thresholds, on=['cmdb_id', 'log_name'], how='left')

# 4) Aggregate per (cmdb_id, log_name) for the window, including global thresholds
if df_log_window.empty:
    aggregated_log_top50 = pd.DataFrame(columns=[
        'cmdb_id','log_name','count_in_window',
        'earliest_timestamp_in_window','latest_timestamp_in_window',
        'min_value_in_window','max_value_in_window','mean_value_in_window',
        'global_p95','global_p5'
    ])
else:
    agg_log = (
        df_log_window.groupby(['cmdb_id', 'log_name'])
        .agg(
            count_in_window=('value', 'size'),
            earliest_timestamp_in_window=('timestamp_dt', 'min'),
            latest_timestamp_in_window=('timestamp_dt', 'max'),
            min_value_in_window=('value', 'min'),
            max_value_in_window=('value', 'max'),
            mean_value_in_window=('value', 'mean'),
            global_p95=('global_p95', 'first'),
            global_p5=('global_p5', 'first'),
        )
        .reset_index()
    )

    # round numeric columns for compact display
    for c in ['min_value_in_window','max_value_in_window','mean_value_in_window','global_p95','global_p5']:
        if c in agg_log.columns:
            agg_log[c] = agg_log[c].astype(float).round(6)

    # sort by count_in_window desc and limit to top 50
    aggregated_log_top50 = agg_log.sort_values('count_in_window', ascending=False).head(50)

# ------------- error_logs.csv processing -------------
try:
    df_error
except NameError:
    df_error = pd.read_csv('error_logs.csv')
if 'timestamp_dt' not in df_error.columns:
    df_error['timestamp_dt'] = pd.to_datetime(df_error['timestamp'], unit='s', utc=True)

df_error_window = df_error[
    (df_error['timestamp_dt'] >= start) &
    (df_error['timestamp_dt'] <= end) &
    (df_error['cmdb_id'].isin(candidates))
].copy()

error_window_total_rows = int(df_error_window.shape[0])

if df_error_window.empty:
    # explicit empty indicator
    error_rows = pd.DataFrame(columns=['timestamp','cmdb_id','message'])
    error_empty = True
else:
    # return up to 50 rows with columns (timestamp, cmdb_id, message) sorted by timestamp ascending
    df_error_window = df_error_window.sort_values('timestamp_dt', ascending=True)
    error_rows = df_error_window[['timestamp_dt','cmdb_id','message']].rename(columns={'timestamp_dt':'timestamp'}).head(50)
    error_empty = False

# Final compact outputs for controller
aggregated_log_top50, error_rows
