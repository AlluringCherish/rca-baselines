).reset_index()

log_summary = filtered_log.groupby('cmdb_id').agg(
    count=('value', 'count'),
    earliest_timestamp=('timestamp', 'min')
).reset_index()

# Combine summaries
combined_summary = pd.concat([error_log_summary, log_summary], ignore_index=True)

# Display the top 20 rows of the combined summary
