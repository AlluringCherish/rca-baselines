import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# reuse result_df from kernel
df_res = result_df.copy()

# Ensure numeric types
for col in ['count_high', 'count_low', 'severity_high', 'severity_low']:
    df_res[col] = pd.to_numeric(df_res[col], errors='coerce').fillna(0)

# Parse earliest timestamps to timezone-aware datetimes (UTC -> convert to Asia/Shanghai)
df_res['earliest_high_dt'] = pd.to_datetime(df_res['earliest_high_ts'], errors='coerce', utc=True).dt.tz_convert(tz)
df_res['earliest_low_dt']  = pd.to_datetime(df_res['earliest_low_ts'],  errors='coerce', utc=True).dt.tz_convert(tz)

# Aggregation by cmdb_id
def agg_component(g):
    total_anomaly_count = int(((g['count_high'] + g['count_low']).fillna(0)).sum())
    num_kpis_with_anomaly = int(((g['count_high'] + g['count_low']).fillna(0) > 0).sum())
    max_severity_high = float(g['severity_high'].replace([np.inf, -np.inf], np.nan).max(skipna=True)) if not g['severity_high'].dropna().empty else 0.0
    max_severity_low  = float(g['severity_low'].replace([np.inf, -np.inf], np.nan).max(skipna=True))  if not g['severity_low'].dropna().empty  else 0.0
    # earliest non-null among earliest_high_dt and earliest_low_dt
    times = pd.concat([g['earliest_high_dt'], g['earliest_low_dt']]).dropna()
    earliest = times.min() if not times.empty else pd.NaT
    earliest_str = str(earliest) if pd.notnull(earliest) else ''
    return pd.Series({
        'total_anomaly_count': total_anomaly_count,
        'num_kpis_with_anomaly': num_kpis_with_anomaly,
        'max_severity_high': max_severity_high,
        'max_severity_low': max_severity_low,
        'earliest_anomaly_ts': earliest_str
    })

agg_df = df_res.groupby('cmdb_id', as_index=False).apply(lambda g: agg_component(g)).reset_index(drop=True)

# infer component_level
def comp_level(cid):
    s = str(cid)
    if s.startswith('os_'):
        return 'node'
    if s.startswith('docker_'):
        return 'container'
    if s.startswith('db_') or s.startswith('redis_') or s.startswith('osb_'):
        return 'service'
    return 'other'

agg_df['component_level'] = agg_df['cmdb_id'].apply(comp_level)

# Round numeric fields
agg_df['max_severity_high'] = agg_df['max_severity_high'].round(4)
agg_df['max_severity_low'] = agg_df['max_severity_low'].round(4)

# Sort and select top 20
agg_sorted = agg_df.sort_values(by='total_anomaly_count', ascending=False).reset_index(drop=True)
agg_top20 = agg_sorted[['cmdb_id', 'component_level', 'total_anomaly_count', 'num_kpis_with_anomaly', 'max_severity_high', 'max_severity_low', 'earliest_anomaly_ts']].head(20)

# Top 3 components and their KPI rows from result_df (limit to top 20 rows per component)
