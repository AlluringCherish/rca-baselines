import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# reuse df_trace and thresholds_trace_df if present, else load/compute
if 'df_trace' not in globals():
    df_trace = pd.read_csv('trace.csv')
if 'ts' not in df_trace.columns:
    df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

if 'thresholds_trace_df' not in globals():
    thresholds_trace_df = (
        df_trace
        .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
        .agg(sample_count='count',
             global_P95=lambda x: float(x.quantile(0.95)),
             global_P5=lambda x: float(x.quantile(0.05)))
    )

# 1) Filter to incident window (inclusive)
start = pd.Timestamp('2020-05-31 03:30:00', tz=tz)
end = pd.Timestamp('2020-05-31 04:00:00', tz=tz)
df_trace_window = df_trace[(df_trace['ts'] >= start) & (df_trace['ts'] <= end)].copy()

# 2) Left-join with thresholds_trace_df and drop rows with missing thresholds
before_merge_rows = df_trace_window.shape[0]
df_tw = df_trace_window.merge(
    thresholds_trace_df[['cmdb_id', 'trace_name', 'global_P95', 'global_P5']],
    on=['cmdb_id', 'trace_name'],
    how='left'
)
after_merge_rows = df_tw.shape[0]
# drop missing thresholds
df_tw_valid = df_tw[df_tw['global_P95'].notnull() & df_tw['global_P5'].notnull()].copy()
dropped_count = after_merge_rows - df_tw_valid.shape[0]

# 3) Per-(cmdb_id, trace_name) computations -> trace_pair_anom_df
def summarize_trace_group(g):
    P95 = float(g['global_P95'].iloc[0])
    P5 = float(g['global_P5'].iloc[0])
    count_total = int(len(g))
    count_high = int((g['value'] >= P95).sum())
    count_low = int((g['value'] <= P5).sum())
    eh_series = g.loc[g['value'] >= P95, 'ts']
    el_series = g.loc[g['value'] <= P5, 'ts']
    earliest_high_ts = eh_series.min() if not eh_series.empty else pd.NaT
    earliest_low_ts = el_series.min() if not el_series.empty else pd.NaT
    max_value_in_window = float(g['value'].max())
    min_value_in_window = float(g['value'].min())
    severity_high = (max_value_in_window - P95) / (P95 + 1e-9)
    severity_low = (P5 - min_value_in_window) / (P5 + 1e-9)
    return pd.Series({
        'count_total': count_total,
        'count_high': count_high,
        'count_low': count_low,
        'earliest_high_ts': earliest_high_ts,
        'earliest_low_ts': earliest_low_ts,
        'max_value_in_window': max_value_in_window,
        'min_value_in_window': min_value_in_window,
        'global_P95': P95,
        'global_P5': P5,
        'severity_high': severity_high,
        'severity_low': severity_low
    })

trace_pair_anom_df = df_tw_valid.groupby(['cmdb_id', 'trace_name']).apply(summarize_trace_group).reset_index()

# format timestamp fields as strings for compact display later
trace_pair_anom_df['earliest_high_ts'] = trace_pair_anom_df['earliest_high_ts'].apply(lambda x: str(x) if pd.notnull(x) else '')
trace_pair_anom_df['earliest_low_ts'] = trace_pair_anom_df['earliest_low_ts'].apply(lambda x: str(x) if pd.notnull(x) else '')

# Round numeric columns to 4 decimals for storage/display
for c in ['max_value_in_window', 'min_value_in_window', 'global_P95', 'global_P5', 'severity_high', 'severity_low']:
    trace_pair_anom_df[c] = trace_pair_anom_df[c].astype(float).round(4)

# 4) Aggregate by cmdb_id to per-component summary
# compute earliest per pair as minimum of earliest_high_ts and earliest_low_ts (string->pd.Timestamp)
def parse_ts_or_nat(s):
    if s == '' or pd.isnull(s):
        return pd.NaT
    try:
        return pd.to_datetime(s).tz_convert(tz)
    except Exception:
        return pd.to_datetime(s)

# create earliest_pair_ts as pd.Timestamp or NaT
trace_pair_anom_df['earliest_pair_ts'] = trace_pair_anom_df.apply(
    lambda r: (parse_ts_or_nat(r['earliest_high_ts']) if r['earliest_high_ts'] else pd.NaT)
              if not r['earliest_low_ts'] else
              (parse_ts_or_nat(r['earliest_low_ts']) if not r['earliest_high_ts'] else
               min(parse_ts_or_nat(r['earliest_high_ts']), parse_ts_or_nat(r['earliest_low_ts']))),
    axis=1
)

comp_agg = trace_pair_anom_df.groupby('cmdb_id').agg(
    total_anomaly_count = ('count_high', lambda s: int((s + trace_pair_anom_df.loc[s.index, 'count_low']).sum())),
    num_traces_with_anomaly = ('count_high', lambda s: int(((s + trace_pair_anom_df.loc[s.index, 'count_low']) > 0).sum())),
    max_severity_high = ('severity_high', 'max'),
    max_severity_low = ('severity_low', 'max'),
    earliest_anomaly_ts = ('earliest_pair_ts', 'min')
).reset_index()

# format earliest_anomaly_ts as string
comp_agg['earliest_anomaly_ts'] = comp_agg['earliest_anomaly_ts'].apply(lambda x: str(x) if pd.notnull(x) else '')

# round max severities
comp_agg['max_severity_high'] = comp_agg['max_severity_high'].fillna(0).astype(float).round(4)
comp_agg['max_severity_low'] = comp_agg['max_severity_low'].fillna(0).astype(float).round(4)

# 5A) Top 20 components by total_anomaly_count desc (compact)
comp_summary_top20 = comp_agg.sort_values(by='total_anomaly_count', ascending=False)[
    ['cmdb_id', 'total_anomaly_count', 'num_traces_with_anomaly', 'max_severity_high', 'max_severity_low', 'earliest_anomaly_ts']
].head(20).reset_index(drop=True)

# 5B) For top 3 components, return up to 5 trace rows each from trace_pair_anom_df
top3_cmdb = comp_summary_top20['cmdb_id'].head(3).tolist()

trace_display_cols = ['cmdb_id','trace_name','count_total','count_high','count_low',
                      'earliest_high_ts','earliest_low_ts','severity_high','severity_low']

top3_trace_rows = []
for cm in top3_cmdb:
    sub = trace_pair_anom_df[trace_pair_anom_df['cmdb_id'] == cm].copy()
    # sort by anomaly count desc
    sub['anomaly_count_pair'] = sub['count_high'] + sub['count_low']
    sub = sub.sort_values(by='anomaly_count_pair', ascending=False).head(5)
    top3_trace_rows.append(sub[trace_display_cols])

if top3_trace_rows:
    top3_traces_df = pd.concat(top3_trace_rows, ignore_index=True)
else:
    top3_traces_df = pd.DataFrame(columns=trace_display_cols)

# Final compact outputs
comp_summary_top20, top3_traces_df, dropped_count
