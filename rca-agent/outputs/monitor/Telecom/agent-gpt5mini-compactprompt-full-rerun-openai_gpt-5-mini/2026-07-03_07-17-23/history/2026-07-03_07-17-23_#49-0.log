    sub['severity_low']  = pd.to_numeric(sub['severity_low'], errors='coerce').round(4).fillna(0)
    sub_sel = sub[['cmdb_id', 'kpi_name', 'count_total', 'count_high', 'count_low', 'earliest_high_ts', 'earliest_low_ts', 'severity_high', 'severity_low']]
    sub_sel = sub_sel.sort_values(by=['count_high', 'count_low'], ascending=False).head(20)
