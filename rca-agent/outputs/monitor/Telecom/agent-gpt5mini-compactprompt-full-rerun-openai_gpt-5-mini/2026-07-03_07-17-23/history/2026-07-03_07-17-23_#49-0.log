import pandas as pd
import pytz

# reuse existing variables where possible
tz = pytz.timezone('Asia/Shanghai')

# ensure df_metric loaded and ts column exists
if 'df_metric' not in globals():
    df_metric = pd.read_csv('metric.csv')
if 'ts' not in df_metric.columns:
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# ensure thresholds_df exists (recompute if absent)
if 'thresholds_df' not in globals():
    thresholds_df = (
        df_metric
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
        .agg(sample_count='count',
             global_P95=lambda x: float(x.quantile(0.95)),
             global_P5=lambda x: float(x.quantile(0.05)))
    )

# 1) Filter to incident window (inclusive)
start = pd.Timestamp('2020-05-31 03:30:00', tz=tz)
end = pd.Timestamp('2020-05-31 04:00:00', tz=tz)
df_window = df_metric[(df_metric['ts'] >= start) & (df_metric['ts'] <= end)].copy()
initial_window_rows = df_window.shape[0]

# 2) Left-join with thresholds_df and drop rows missing thresholds
df_w = df_window.merge(thresholds_df[['cmdb_id','kpi_name','global_P95','global_P5']],
                       on=['cmdb_id','kpi_name'], how='left')
before_drop = df_w.shape[0]
df_w = df_w[df_w['global_P95'].notnull() & df_w['global_P5'].notnull()].copy()
after_drop = df_w.shape[0]
dropped_count = before_drop - after_drop

# 3) Per-(cmdb_id,kpi_name) computations and store in pair_anom_df
def summarize_group(g):
    P95 = float(g['global_P95'].iloc[0])
    P5 = float(g['global_P5'].iloc[0])
    count_total = int(len(g))
    count_high = int((g['value'] >= P95).sum())
    count_low = int((g['value'] <= P5).sum())
    eh = g.loc[g['value'] >= P95, 'ts']
    el = g.loc[g['value'] <= P5, 'ts']
    earliest_high_ts = eh.min() if not eh.empty else pd.NaT
    earliest_low_ts = el.min() if not el.empty else pd.NaT
    max_value_in_window = float(g['value'].max())
    min_value_in_window = float(g['value'].min())
    severity_high = (max_value_in_window - P95) / (P95 + 1e-9)
    severity_low = (P5 - min_value_in_window) / (P5 + 1e-9)
    return pd.Series({
        'count_total': count_total,
        'count_high': count_high,
        'count_low': count_low,
        'earliest_high_ts': earliest_high_ts,
        'earliest_low_ts': earliest_low_ts,
        'max_value_in_window': max_value_in_window,
        'min_value_in_window': min_value_in_window,
        'global_P95': P95,
        'global_P5': P5,
        'severity_high': severity_high,
        'severity_low': severity_low
    })

pair_anom_df = df_w.groupby(['cmdb_id','kpi_name']).apply(summarize_group).reset_index()

# 4) Aggregate by cmdb_id to produce per-component summary
# compute earliest per pair (min of earliest_high_ts and earliest_low_ts)
def min_timestamp(a, b):
    # a and b are timestamps or NaT
    if pd.isnull(a) and pd.isnull(b):
        return pd.NaT
    if pd.isnull(a):
        return b
    if pd.isnull(b):
        return a
    return min(a, b)

pair_anom_df['earliest_pair_ts'] = pair_anom_df.apply(
    lambda r: min_timestamp(r['earliest_high_ts'], r['earliest_low_ts']), axis=1
)

comp_agg = pair_anom_df.groupby('cmdb_id').agg(
    total_anomaly_count = ('count_high', lambda s: int((s + pair_anom_df.loc[s.index, 'count_low']).sum())),
    num_kpis_with_anomaly = ('count_high', lambda s: int(((s + pair_anom_df.loc[s.index, 'count_low']) > 0).sum())),
    max_severity_high = ('severity_high', 'max'),
    max_severity_low = ('severity_low', 'max'),
    earliest_anomaly_ts = ('earliest_pair_ts', 'min')
).reset_index()

# 5) Infer component_level
def infer_level(cmdb):
    if str(cmdb).startswith('os_'):
        return 'node'
    if str(cmdb).startswith('docker_'):
        return 'container'
    if str(cmdb).startswith('db_'):
        return 'service'
    if str(cmdb).startswith('redis_') or str(cmdb).startswith('osb_'):
        return 'service'
    return 'other'

comp_agg['component_level'] = comp_agg['cmdb_id'].apply(infer_level)

# Format earliest_anomaly_ts as string (empty if NaT)
comp_agg['earliest_anomaly_ts'] = comp_agg['earliest_anomaly_ts'].apply(
    lambda x: str(x) if pd.notnull(x) else ''
)

# Round numeric fields to 4 decimals
for c in ['max_severity_high','max_severity_low']:
    comp_agg[c] = comp_agg[c].fillna(0).astype(float).round(4)

# 6A) Top 20 components sorted by total_anomaly_count desc
comp_summary_df = comp_agg.sort_values(by='total_anomaly_count', ascending=False)
comp_summary_df_top20 = comp_summary_df[[
    'cmdb_id','component_level','total_anomaly_count','num_kpis_with_anomaly',
    'max_severity_high','max_severity_low','earliest_anomaly_ts'
]].head(20).reset_index(drop=True)

# 6B) For top 3 cmdb_id from A, return their KPI breakdown rows from pair_anom_df
top3 = comp_summary_df_top20['cmdb_id'].head(3).tolist()

# prepare pair_anom_df display columns and rounding
display_cols = ['cmdb_id','kpi_name','count_total','count_high','count_low',
                'earliest_high_ts','earliest_low_ts','severity_high','severity_low']

pair_anom_df_display = pair_anom_df.copy()
# format timestamps as strings
pair_anom_df_display['earliest_high_ts'] = pair_anom_df_display['earliest_high_ts'].apply(lambda x: str(x) if pd.notnull(x) else '')
pair_anom_df_display['earliest_low_ts'] = pair_anom_df_display['earliest_low_ts'].apply(lambda x: str(x) if pd.notnull(x) else '')
# round severity fields
pair_anom_df_display['severity_high'] = pair_anom_df_display['severity_high'].round(4)
pair_anom_df_display['severity_low'] = pair_anom_df_display['severity_low'].round(4)

# filter for top3 and limit to top 20 per component (sorted by (count_high+count_low) desc)
pair_anom_df_display['anomaly_count_pair'] = pair_anom_df_display['count_high'] + pair_anom_df_display['count_low']
top3_kpis_list = []
for cm in top3:
    sub = pair_anom_df_display[pair_anom_df_display['cmdb_id'] == cm].copy()
    sub = sub.sort_values(by='anomaly_count_pair', ascending=False).head(20)
    top3_kpis_list.append(sub[display_cols])
if top3_kpis_list:
    top3_kpis_df = pd.concat(top3_kpis_list, ignore_index=True)
else:
    top3_kpis_df = pd.DataFrame(columns=display_cols)

# Ensure pair_anom_df is stored in kernel as requested
# pair_anom_df already exists as variable

# Final compact outputs
comp_summary_df_top20, top3_kpis_df, dropped_count
