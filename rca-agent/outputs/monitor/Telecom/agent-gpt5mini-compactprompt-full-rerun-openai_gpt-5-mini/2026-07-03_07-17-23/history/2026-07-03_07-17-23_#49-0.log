import pandas as pd
import pytz

# reuse variables from kernel state
tz = pytz.timezone('Asia/Shanghai')

# assume result_df exists in kernel (per previous steps)
# make a working copy
df_res = result_df.copy()

# parse earliest timestamp strings to timezone-aware datetimes (coerce empty -> NaT)
for col in ['earliest_high_ts', 'earliest_low_ts']:
    dt_col = col + '_dt'
    df_res[dt_col] = pd.to_datetime(df_res[col], errors='coerce', utc=True).dt.tz_convert(tz)

# helper: numeric conversions
for col in ['severity_high', 'severity_low', 'count_high', 'count_low']:
    df_res[col] = pd.to_numeric(df_res[col], errors='coerce')

# 1) Aggregate by cmdb_id
def agg_component(g):
    total_anomaly_count = int(((g['count_high'].fillna(0) + g['count_low'].fillna(0))).sum())
    num_kpis_with_anomaly = int(((g['count_high'].fillna(0) + g['count_low'].fillna(0)) > 0).sum())
    max_severity_high = float(pd.to_numeric(g['severity_high'], errors='coerce').max(skipna=True) or 0.0)
    max_severity_low = float(pd.to_numeric(g['severity_low'], errors='coerce').max(skipna=True) or 0.0)
    # earliest non-null among earliest_high_dt and earliest_low_dt
    times = pd.concat([g['earliest_high_ts_dt'] if 'earliest_high_ts_dt' in g else pd.Series([], dtype='datetime64[ns, UTC]'),
                       g['earliest_low_ts_dt'] if 'earliest_low_ts_dt' in g else pd.Series([], dtype='datetime64[ns, UTC]')], ignore_index=True)
    # above approach may not work inside apply; instead gather from g directly
    times = pd.Series(list(g['earliest_high_ts_dt'].values) + list(g['earliest_low_ts_dt'].values))
    times = pd.to_datetime(times).dt.tz_convert(tz) if not times.dropna().empty else pd.Series([], dtype='datetime64[ns, UTC]')
    earliest = times.dropna().min() if not times.dropna().empty else pd.NaT
    earliest_str = str(earliest) if pd.notnull(earliest) else ''
    return pd.Series({
        'total_anomaly_count': total_anomaly_count,
        'num_kpis_with_anomaly': num_kpis_with_anomaly,
        'max_severity_high': max_severity_high,
        'max_severity_low': max_severity_low,
        'earliest_anomaly_ts': earliest_str
    })

# Note: adjust column names used above
# rename parsed dt cols to simpler names for group apply
df_res = df_res.rename(columns={'earliest_high_ts_dt': 'earliest_high_ts_dt', 'earliest_low_ts_dt': 'earliest_low_ts_dt'})

# group and aggregate
