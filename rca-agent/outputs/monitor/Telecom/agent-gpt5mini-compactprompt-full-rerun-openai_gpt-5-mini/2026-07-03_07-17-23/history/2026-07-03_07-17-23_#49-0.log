import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# ensure pair_anom_df exists
if 'pair_anom_df' not in globals():
    raise RuntimeError("pair_anom_df not found in kernel. Please run previous steps to create it.")

# 1) Filter for cmdb_id == 'os_008'
df_os008 = pair_anom_df[pair_anom_df['cmdb_id'] == 'os_008'].copy()

# Ensure numeric severities and counts
for c in ['severity_high', 'severity_low']:
    df_os008[c] = pd.to_numeric(df_os008.get(c, 0.0), errors='coerce').fillna(0.0)
for c in ['count_total', 'count_high', 'count_low']:
    df_os008[c] = pd.to_numeric(df_os008.get(c, 0), errors='coerce').fillna(0).astype(int)

# Normalize timestamp columns to compact strings (empty if null)
def ts_to_str(x):
    if pd.isnull(x):
        return ''
    # if already string return as is
    if isinstance(x, str):
        return x
    # ensure timezone is Asia/Shanghai
    try:
        if x.tzinfo is None:
            x = x.tz_localize(tz)
        else:
            x = x.tz_convert(tz)
    except Exception:
        try:
            x = pd.to_datetime(x).tz_convert(tz)
        except Exception:
            x = pd.to_datetime(x)
    return str(x)

df_os008['earliest_high_ts'] = df_os008['earliest_high_ts'].apply(ts_to_str)
df_os008['earliest_low_ts'] = df_os008['earliest_low_ts'].apply(ts_to_str)

# 2) Top 10 KPI rows sorted by severity_high desc, tie-breaker count_total desc
df_os008['severity_high'] = df_os008['severity_high'].astype(float)
df_os008['severity_low'] = df_os008['severity_low'].astype(float)

top10 = (
    df_os008
    .sort_values(by=['severity_high', 'count_total'], ascending=[False, False])
    .head(10)
    .copy()
)

# Round numeric fields to 4 decimals
top10['severity_high'] = top10['severity_high'].round(4)
top10['severity_low'] = top10['severity_low'].round(4)

# Select and order columns for output
output_cols = ['cmdb_id','kpi_name','count_total','count_high','count_low',
               'earliest_high_ts','earliest_low_ts','severity_high','severity_low']
top10_df = top10[output_cols].reset_index(drop=True)

# 3) Earliest_high_ts among rows where severity_high >= 0.5
severe_high_rows = df_os008[df_os008['severity_high'] >= 0.5].copy()
if severe_high_rows.empty:
    earliest_severe_high_ts = 'None'
else:
    # parse earliest_high_ts strings to timestamps, ignore empty
    parsed = pd.to_datetime(severe_high_rows['earliest_high_ts'].replace('', pd.NaT)).dropna()
    if parsed.empty:
        earliest_severe_high_ts = 'None'
    else:
        # ensure tz Asia/Shanghai
        parsed = parsed.dt.tz_convert(tz) if parsed.dt.tz is not None else parsed.dt.tz_localize(tz)
        earliest_severe_high_ts = str(parsed.min())

# 4) One-line summary mapping top 3 returned KPI names to resource category
def map_resource(kpi):
    s = str(kpi).lower()
    if 'cpu' in s:
        return 'cpu'
    if 'disk' in s:
        return 'disk'
    if any(x in s for x in ['network','recv','send','incoming','outgoing','sent','recv']):
        return 'network'
    if any(x in s for x in ['icmp','ping']):
        return 'icmp'
    return 'other'

top3_kpis = top10_df['kpi_name'].head(3).tolist()
mapping_pairs = [f"'{k}'->{map_resource(k)}" for k in top3_kpis]
mapping_summary = ", ".join(mapping_pairs) if mapping_pairs else ""

# Final compact outputs
top10_df, earliest_severe_high_ts, mapping_summary
