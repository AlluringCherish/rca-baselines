import pandas as pd
import pytz

# reuse variables across runs
tz = pytz.timezone('Asia/Shanghai')

# load files
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')

# convert timestamp to timezone-aware datetime (UTC -> Asia/Shanghai)
df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Metric summaries
metric_total_rows = int(df_metric.shape[0])
metric_min_ts = df_metric['ts'].min()
metric_max_ts = df_metric['ts'].max()
metric_unique_cmdb = sorted(df_metric['cmdb_id'].unique().tolist())

metric_top_kpis = (
    df_metric['kpi_name']
    .value_counts()
    .head(20)
    .reset_index()
    .rename(columns={'index': 'kpi_name', 'kpi_name': 'count'})
)

metric_samples = df_metric.head(5).copy()

metric_overview = pd.DataFrame({
    'value': [
        metric_total_rows,
        metric_min_ts,
        metric_max_ts,
        ','.join(metric_unique_cmdb) if len(metric_unique_cmdb) <= 20 else ','.join(metric_unique_cmdb[:20]) + '...'
    ]
}, index=['total_rows', 'min_timestamp', 'max_timestamp', 'unique_cmdb_id_list'])

# Trace summaries
trace_total_rows = int(df_trace.shape[0])
trace_min_ts = df_trace['ts'].min()
trace_max_ts = df_trace['ts'].max()
trace_unique_cmdb = sorted(df_trace['cmdb_id'].unique().tolist())

trace_top_names = (
    df_trace['trace_name']
    .value_counts()
    .head(20)
    .reset_index()
    .rename(columns={'index': 'trace_name', 'trace_name': 'count'})
)

trace_samples = df_trace.head(5).copy()

trace_overview = pd.DataFrame({
    'value': [
        trace_total_rows,
        trace_min_ts,
        trace_max_ts,
        ','.join(trace_unique_cmdb) if len(trace_unique_cmdb) <= 20 else ','.join(trace_unique_cmdb[:20]) + '...'
    ]
}, index=['total_rows', 'min_timestamp', 'max_timestamp', 'unique_cmdb_id_list'])

# Final compact outputs (IPython will display these variables)
metric_overview, metric_top_kpis, metric_samples, trace_overview, trace_top_names, trace_samples
