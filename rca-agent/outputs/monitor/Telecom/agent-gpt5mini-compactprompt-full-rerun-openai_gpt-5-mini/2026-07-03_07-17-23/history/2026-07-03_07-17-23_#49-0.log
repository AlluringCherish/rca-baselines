import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# load or reuse metric dataframe
if 'df_metric' not in globals():
    df_metric = pd.read_csv('metric.csv')
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    if 'ts' not in df_metric.columns:
        df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Compute global thresholds using all available rows per (cmdb_id, kpi_name)
agg = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .agg(sample_count='count',
         global_P95=lambda x: float(x.quantile(0.95)),
         global_P5=lambda x: float(x.quantile(0.05)))
)

# store full result table in kernel variable
thresholds_df = agg.copy()

# prepare compact top-20 display sorted by sample_count desc, rounding thresholds
thresholds_top20 = (
    thresholds_df
    .sort_values(by='sample_count', ascending=False)
    .head(20)
    .copy()
)
thresholds_top20['global_P95'] = thresholds_top20['global_P95'].round(4)
thresholds_top20['global_P5'] = thresholds_top20['global_P5'].round(4)
thresholds_top20['sample_count'] = thresholds_top20['sample_count'].astype(int)

# display only the compact top-20 table
thresholds_top20[['cmdb_id', 'kpi_name', 'sample_count', 'global_P95', 'global_P5']]
