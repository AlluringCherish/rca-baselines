import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# reuse pair_anom_df from kernel
df = pair_anom_df.copy()

# ensure numeric severity columns
df['severity_high'] = pd.to_numeric(df.get('severity_high', 0.0), errors='coerce').fillna(0.0)
df['severity_low']  = pd.to_numeric(df.get('severity_low',  0.0), errors='coerce').fillna(0.0)

# 1) select severe rows
mask_severe = (df['severity_high'] >= 0.5) | (df['severity_low'] >= 0.5)
severe_df = df[mask_severe].copy()

# total severe count
severe_count = int(severe_df.shape[0])

# Helper to pick occurrence raw string per row
severe_df['occurrence_raw'] = severe_df.apply(
    lambda r: r['earliest_high_ts'] if r['severity_high'] >= 0.5 else r['earliest_low_ts'],
    axis=1
)

# Parse occurrence timestamps to timezone-aware Asia/Shanghai
# pd.to_datetime(..., utc=True) will handle strings with offsets; errors -> NaT
severe_df['occurrence_ts'] = pd.to_datetime(severe_df['occurrence_raw'], utc=True, errors='coerce').dt.tz_convert(tz)

# 2) find global minimal occurrence timestamp
if severe_df['occurrence_ts'].dropna().empty:
    global_min_ts = pd.NaT
    global_min_ts_str = 'None'
else:
    global_min_ts = severe_df['occurrence_ts'].min()
    global_min_ts_str = str(global_min_ts)

# 3) filter rows whose occurrence equals the global minimal timestamp
if pd.isna(global_min_ts):
    severe_at_min = severe_df.iloc[0:0].copy()  # empty
else:
    severe_at_min = severe_df[severe_df['occurrence_ts'] == global_min_ts].copy()

# prepare output columns
def which_sev_and_value(row):
    if row['severity_high'] >= 0.5:
        return 'high', round(float(row['severity_high']), 4)
    else:
        return 'low', round(float(row['severity_low']), 4)

ws = severe_at_min.apply(lambda r: which_sev_and_value(r), axis=1)
if not severe_at_min.empty:
    severe_at_min['which_severity'] = [w[0] for w in ws]
    severe_at_min['severity_value'] = [w[1] for w in ws]
else:
    severe_at_min['which_severity'] = []
    severe_at_min['severity_value'] = []

# format occurrence_ts as compact strings
severe_at_min['occurrence_ts'] = severe_at_min['occurrence_ts'].apply(
    lambda x: str(x) if pd.notnull(x) else ''
)

# round severities columns for completeness
severe_at_min['severity_high'] = severe_at_min['severity_high'].round(4)
severe_at_min['severity_low']  = severe_at_min['severity_low'].round(4)

# select final display columns and limit to top 20
out_cols = ['cmdb_id','kpi_name','which_severity','severity_value','occurrence_ts']
severe_at_min_out = severe_at_min[out_cols].head(20).reset_index(drop=True)

# 4) one-line mapping of each returned kpi_name to resource category
def map_resource(kpi):
    s = str(kpi).lower()
    if 'cpu' in s:
        return 'cpu'
    if 'disk' in s:
        return 'disk'
    if any(x in s for x in ['network','recv','send','incoming','outgoing','sent']):
        return 'network'
    if any(x in s for x in ['icmp','ping']):
        return 'icmp'
    return 'other'

# build mapping summary for kpis returned (compact one-line)
mapping_pairs = []
for k in severe_at_min_out['kpi_name'].tolist():
    mapping_pairs.append(f"'{k}'->{map_resource(k)}")
mapping_summary = ", ".join(mapping_pairs)

# Final compact outputs (limit rows to top 20)
severe_at_min_out, mapping_summary, global_min_ts_str, severe_count
