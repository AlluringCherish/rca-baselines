import pandas as pd
import pytz

# reuse existing variables if present
tz = pytz.timezone('Asia/Shanghai')

if 'df_metric' not in globals():
    df_metric = pd.read_csv('metric.csv')
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    if 'ts' not in df_metric.columns:
        df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Compute global P95 and P5 per (cmdb_id, kpi_name) using all available rows
thresholds = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .agg(P95=lambda x: float(x.quantile(0.95)), P5=lambda x: float(x.quantile(0.05)))
)

# 2) Filter to incident window (UTC+8) 2020-05-31 03:30:00 to 2020-05-31 04:00:00 inclusive
start = pd.Timestamp('2020-05-31 03:30:00', tz=tz)
end = pd.Timestamp('2020-05-31 04:00:00', tz=tz)
df_window = df_metric[(df_metric['ts'] >= start) & (df_metric['ts'] <= end)].copy()

# 3) Merge thresholds (global) into windowed data
df_w = df_window.merge(thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# Summarize per (cmdb_id, kpi_name)
def summarize_group(g):
    P95 = float(g['P95'].iloc[0])
    P5 = float(g['P5'].iloc[0])
    count_total = int(len(g))
    count_high = int((g['value'] >= P95).sum())
    count_low = int((g['value'] <= P5).sum())
    eh = g.loc[g['value'] >= P95, 'ts'].min()
    el = g.loc[g['value'] <= P5, 'ts'].min()
    # keep timestamp strings compact; empty string if none
    earliest_high_ts = str(eh) if pd.notnull(eh) else ''
    earliest_low_ts = str(el) if pd.notnull(el) else ''
    max_value_in_window = float(g['value'].max())
    min_value_in_window = float(g['value'].min())
    severity_high = (max_value_in_window - P95) / (P95 + 1e-9)
    severity_low = (P5 - min_value_in_window) / (P5 + 1e-9)
    return pd.Series({
        'count_total': count_total,
        'count_high': count_high,
        'count_low': count_low,
        'earliest_high_ts': earliest_high_ts,
        'earliest_low_ts': earliest_low_ts,
        'max_value_in_window': max_value_in_window,
        'min_value_in_window': min_value_in_window,
        'P95': P95,
        'P5': P5,
        'severity_high': severity_high,
        'severity_low': severity_low
    })

grouped = df_w.groupby(['cmdb_id', 'kpi_name']).apply(summarize_group).reset_index()

# 4) Rank by max(count_high, count_low) desc, select top 20 and format
grouped['max_count'] = grouped[['count_high', 'count_low']].max(axis=1)
grouped_sorted = grouped.sort_values(by='max_count', ascending=False)

# Round numeric fields to 4 decimals
for c in ['max_value_in_window', 'min_value_in_window', 'P95', 'P5', 'severity_high', 'severity_low']:
    grouped_sorted[c] = grouped_sorted[c].round(4)

# Select requested output columns and top 20
output_cols = [
    'cmdb_id', 'kpi_name', 'count_total', 'count_high', 'count_low',
    'earliest_high_ts', 'earliest_low_ts', 'severity_high', 'severity_low'
]
result_df = grouped_sorted[output_cols].head(20).reset_index(drop=True)

# 5) Full list of unique cmdb_id values in metric.csv (compact, comma-separated)
unique_cmdb_list = sorted(df_metric['cmdb_id'].unique().tolist())
unique_cmdb_str = ','.join(unique_cmdb_list)

# Compact outputs
result_df, unique_cmdb_str
