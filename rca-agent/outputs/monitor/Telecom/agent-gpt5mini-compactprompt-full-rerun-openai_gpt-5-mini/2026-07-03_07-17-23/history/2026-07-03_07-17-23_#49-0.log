for tcol in ['earliest_high_ts', 'earliest_low_ts']:
    if tcol in df_candidates.columns:
        df_candidates[tcol] = df_candidates[tcol].apply(lambda x: '' if pd.isnull(x) or x == pd.NaT else str(x))
