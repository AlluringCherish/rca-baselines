import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# ensure pair_anom_df exists
if 'pair_anom_df' not in globals():
    raise RuntimeError("pair_anom_df not found in kernel. Please run previous steps to create it.")

# Reuse pair_anom_df
df = pair_anom_df.copy()

# Ensure severity columns are numeric
df['severity_high'] = pd.to_numeric(df.get('severity_high', 0.0), errors='coerce').fillna(0.0)
df['severity_low']  = pd.to_numeric(df.get('severity_low',  0.0), errors='coerce').fillna(0.0)

# Select severe rows
mask = (df['severity_high'] >= 0.5) | (df['severity_low'] >= 0.5)
severe_df = df[mask].copy()

# Count of severe rows
severe_count = int(severe_df.shape[0])

# Prepare earliest selection: use earliest_high_ts if severity_high>=0.5 else earliest_low_ts
# Replace empty strings with NaT for parsing
for col in ['earliest_high_ts', 'earliest_low_ts']:
    if col not in severe_df.columns:
        severe_df[col] = pd.NaT
    # keep existing values; convert '' to NaT
    severe_df[col] = severe_df[col].replace('', pd.NaT)

# Create selected_earliest column per rule
severe_df['selected_earliest_raw'] = severe_df.apply(
    lambda r: r['earliest_high_ts'] if r['severity_high'] >= 0.5 else r['earliest_low_ts'],
    axis=1
)

# Parse selected_earliest_raw to timezone-aware timestamps (Asia/Shanghai)
# Use utc parsing then convert to Asia/Shanghai to correctly handle strings with +08:00
selected_ts = pd.to_datetime(severe_df['selected_earliest_raw'], utc=True, errors='coerce')
# convert to Asia/Shanghai (NaT stays NaT)
selected_ts = selected_ts.dt.tz_convert(tz)
severe_df['selected_earliest'] = selected_ts

# Sort by selected_earliest ascending, put NaT last
severe_df_sorted = severe_df.sort_values(by='selected_earliest', ascending=True, na_position='last')

# Prepare output columns and rounding
out_cols = ['cmdb_id', 'kpi_name', 'severity_high', 'severity_low', 'earliest_high_ts', 'earliest_low_ts']
out_df = severe_df_sorted[out_cols].copy()

# Round numeric severity columns
out_df['severity_high'] = out_df['severity_high'].round(4)
out_df['severity_low']  = out_df['severity_low'].round(4)

# Ensure timestamp columns are compact strings (empty if NaT)
def format_ts(x):
    if pd.isnull(x):
        return ''
    # if already string, return as is
    if isinstance(x, str):
        return x
    try:
        # ensure timezone Asia/Shanghai
        if x.tzinfo is None:
            x = x.tz_localize(tz)
        else:
            x = x.tz_convert(tz)
    except Exception:
        try:
            x = pd.to_datetime(x).tz_convert(tz)
        except Exception:
            x = pd.to_datetime(x)
    return str(x)

out_df['earliest_high_ts'] = out_df['earliest_high_ts'].apply(lambda v: format_ts(v) if v != '' else '')
out_df['earliest_low_ts']  = out_df['earliest_low_ts'].apply(lambda v: format_ts(v) if v != '' else '')

# Limit to earliest 20 rows
severe_out_df = out_df.head(20).reset_index(drop=True)

# Final compact outputs: severe_out_df (top 20) and severe_count
severe_out_df, severe_count
