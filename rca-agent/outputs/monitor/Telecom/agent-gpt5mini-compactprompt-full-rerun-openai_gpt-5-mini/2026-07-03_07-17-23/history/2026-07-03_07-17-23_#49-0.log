import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# reuse df_trace if present, else load
if 'df_trace' not in globals():
    df_trace = pd.read_csv('trace.csv')
# ensure timezone-aware ts column exists
if 'ts' not in df_trace.columns:
    df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Compute global thresholds (using all available rows) per (cmdb_id, trace_name)
thresholds_trace_df = (
    df_trace
    .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
    .agg(sample_count='count',
         global_P95=lambda x: float(x.quantile(0.95)),
         global_P5=lambda x: float(x.quantile(0.05)))
)

# Prepare compact top-20 display sorted by sample_count desc, rounding numeric thresholds
thresholds_top20 = thresholds_trace_df.sort_values(by='sample_count', ascending=False).head(20).copy()
thresholds_top20['global_P95'] = thresholds_top20['global_P95'].round(4)
thresholds_top20['global_P5'] = thresholds_top20['global_P5'].round(4)
thresholds_top20['sample_count'] = thresholds_top20['sample_count'].astype(int)

# Display compact table (stored variable)
thresholds_top20[['cmdb_id', 'trace_name', 'sample_count', 'global_P95', 'global_P5']]
