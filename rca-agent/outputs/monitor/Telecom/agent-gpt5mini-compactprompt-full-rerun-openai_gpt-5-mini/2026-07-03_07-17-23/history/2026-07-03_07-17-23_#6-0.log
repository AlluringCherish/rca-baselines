import pandas as pd
import pytz
import numpy as np

tz = pytz.timezone('Asia/Shanghai')

# Reuse merged_anoms from previous steps; if missing, raise informative error
try:
    merged_anoms
except NameError:
    raise RuntimeError("merged_anoms not found in the environment. Run previous anomaly aggregation steps first.")

df = merged_anoms.copy()

# Ensure numeric fields
for col in ['max_excess_over_p95', 'max_deficit_under_p5', 'anomaly_count']:
    if col in df.columns:
        df[col] = pd.to_numeric(df[col], errors='coerce')

# Ensure earliest anomaly dt exists as datetime; fallback if only string present
if 'earliest_anom_dt' not in df.columns and 'earliest_anomaly_timestamp' in df.columns:
    df['earliest_anom_dt'] = pd.to_datetime(df['earliest_anomaly_timestamp'], utc=True).dt.tz_convert(tz)
else:
    # ensure timezone-aware dtype
    if df['earliest_anom_dt'].dtype == object:
        df['earliest_anom_dt'] = pd.to_datetime(df['earliest_anom_dt']).dt.tz_localize(None)
        df['earliest_anom_dt'] = pd.to_datetime(df['earliest_anom_dt'], utc=True).dt.tz_convert(tz)

# Group by cmdb_id to compute requested metrics
def predominant_dir(series):
    vc = series.value_counts()
    if vc.empty:
        return 'none'
    maxc = vc.max()
    modes = sorted(vc[vc == maxc].index.tolist())
    return '/'.join(modes)

grp = df.groupby('cmdb_id')

cmdb_summary = grp.agg(
    total_anomaly_count = ('anomaly_count', 'sum'),
    num_kpis_with_anomaly = (lambda x: (x['anomaly_count']>0).sum(), lambda s: None)  # placeholder; will fix below
).reset_index()

# num_kpis_with_anomaly cannot be expressed directly in agg when needing a different column; compute separately
num_kpis = df.groupby('cmdb_id').apply(lambda g: (g['anomaly_count'] > 0).sum()).rename('num_kpis_with_anomaly').reset_index()
cmdb_summary = cmdb_summary.drop(columns=[cmdb_summary.columns[1]])  # drop the placeholder column
cmdb_summary = cmdb_summary.merge(num_kpis, on='cmdb_id', how='left')

# Compute numeric and timestamp aggregates
agg_nums = df.groupby('cmdb_id').agg(
    max_excess_over_p95 = ('max_excess_over_p95', lambda x: np.nan if x.dropna().size==0 else x.max(skipna=True)),
    min_deficit_under_p5 = ('max_deficit_under_p5', lambda x: np.nan if x.dropna().size==0 else x.min(skipna=True)),
    earliest_anom_dt = ('earliest_anom_dt', lambda x: pd.NaT if x.dropna().size==0 else x.min())
).reset_index()

# Predominant direction per cmdb_id
pred_dir = df.groupby('cmdb_id')['predominant_direction'].apply(predominant_dir).reset_index().rename(columns={'predominant_direction':'predominant_direction'})

# Merge all pieces
cmdb_summary_df = cmdb_summary.merge(agg_nums, on='cmdb_id', how='left').merge(pred_dir, on='cmdb_id', how='left')

# Format earliest_anom_dt to string in UTC+8
cmdb_summary_df['earliest_anomaly_timestamp'] = cmdb_summary_df['earliest_anom_dt'].dt.strftime('%Y-%m-%d %H:%M:%S %Z')

# Select and order columns
cmdb_summary_df = cmdb_summary_df[[
    'cmdb_id',
    'total_anomaly_count',
    'num_kpis_with_anomaly',
    'max_excess_over_p95',
    'min_deficit_under_p5',
    'earliest_anomaly_timestamp',
    'predominant_direction'
]]

# Sort and limit top 20
cmdb_summary_df = cmdb_summary_df.sort_values('total_anomaly_count', ascending=False).head(20)

# Separate list: components with max_excess_over_p95 >= 1.0
severe = cmdb_summary_df.loc[cmdb_summary_df['max_excess_over_p95'] >= 1.0, ['cmdb_id','max_excess_over_p95','earliest_anomaly_timestamp','total_anomaly_count']]
severe = severe.sort_values(['max_excess_over_p95','total_anomaly_count'], ascending=[False, False]).head(20)

# Display compact outputs
cmdb_summary_df, severe
