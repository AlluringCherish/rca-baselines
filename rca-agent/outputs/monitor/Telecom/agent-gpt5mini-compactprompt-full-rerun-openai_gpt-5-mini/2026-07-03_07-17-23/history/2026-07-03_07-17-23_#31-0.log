import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse kernel variables: anomalies_agg, df_trace, df_metric if present
# If any missing, raise informative error (kernel should already have them per prior steps)
for var in ['anomalies_agg', 'df_trace']:
    if var not in globals():
        raise NameError(f"Required kernel variable '{var}' not found. Ensure previous steps created it.")

# 1) Per-cmdb_id summary from anomalies_agg
metric_cmdb_summary = (
    anomalies_agg
    .groupby('cmdb_id', sort=False)
    .agg(
        number_of_anomalous_series=('kpi_name', 'nunique'),
        max_severity=('severity', 'max'),
        earliest_anomaly_timestamp=('earliest_anomaly_timestamp', 'min')
    )
    .reset_index()
)

# Ensure earliest_anomaly_timestamp is timezone-aware Asia/Shanghai
metric_cmdb_summary['earliest_anomaly_timestamp'] = pd.to_datetime(metric_cmdb_summary['earliest_anomaly_timestamp']).dt.tz_convert(tz)

# Sort as requested and keep top 20
metric_cmdb_summary_top20 = metric_cmdb_summary.sort_values(
    by=['number_of_anomalous_series', 'max_severity'],
    ascending=[False, False],
    na_position='last'
).loc[:, ['cmdb_id','number_of_anomalous_series','max_severity','earliest_anomaly_timestamp']].head(20).reset_index(drop=True)

# 2) Trace-level anomaly detection

# Compute global P95 and P5 per (cmdb_id, trace_name) using full trace series
trace_thresholds = (
    df_trace
    .groupby(['cmdb_id','trace_name'], sort=False)['value']
    .agg(P95=lambda x: x.quantile(0.95), P5=lambda x: x.quantile(0.05))
    .reset_index()
)

# Filter trace records to incident window (inclusive)
start = pd.Timestamp('2020-05-27 01:00:00', tz=tz)
end   = pd.Timestamp('2020-05-27 01:30:00', tz=tz)
trace_incident_window = df_trace[(df_trace['ts_dt'] >= start) & (df_trace['ts_dt'] <= end)].copy()

# Merge thresholds into incident window
trace_incident_with_thr = trace_incident_window.merge(trace_thresholds, on=['cmdb_id','trace_name'], how='left')

# High anomalies: value >= P95
trace_hi = trace_incident_with_thr[trace_incident_with_thr['value'] >= trace_incident_with_thr['P95']].copy()
if not trace_hi.empty:
    trace_hi_agg = (
        trace_hi.groupby(['cmdb_id','trace_name'], as_index=False, sort=False)
        .agg(
            earliest_anomaly_timestamp=('ts_dt','min'),
            anomaly_count=('value','size'),
            max_value=('value','max'),
            min_value=('value','min'),
            P95=('P95','first'),
            P5=('P5','first')
        )
    )
    trace_hi_agg['anomaly_type'] = 'high'
    trace_hi_agg['severity'] = trace_hi_agg.apply(
        lambda r: (r['max_value'] - r['P95'])/r['P95'] if pd.notna(r['P95']) and r['P95'] != 0 else np.nan,
        axis=1
    )
else:
    trace_hi_agg = pd.DataFrame(columns=['cmdb_id','trace_name','earliest_anomaly_timestamp','anomaly_count','max_value','min_value','P95','P5','anomaly_type','severity'])

# Low anomalies: value <= P5
trace_lo = trace_incident_with_thr[trace_incident_with_thr['value'] <= trace_incident_with_thr['P5']].copy()
if not trace_lo.empty:
    trace_lo_agg = (
        trace_lo.groupby(['cmdb_id','trace_name'], as_index=False, sort=False)
        .agg(
            earliest_anomaly_timestamp=('ts_dt','min'),
            anomaly_count=('value','size'),
            max_value=('value','max'),
            min_value=('value','min'),
            P95=('P95','first'),
            P5=('P5','first')
        )
    )
    trace_lo_agg['anomaly_type'] = 'low'
    trace_lo_agg['severity'] = trace_lo_agg.apply(
        lambda r: (r['P5'] - r['min_value'])/r['P5'] if pd.notna(r['P5']) and r['P5'] != 0 else np.nan,
        axis=1
    )
else:
    trace_lo_agg = pd.DataFrame(columns=['cmdb_id','trace_name','earliest_anomaly_timestamp','anomaly_count','max_value','min_value','P95','P5','anomaly_type','severity'])

# Combine trace anomalies
trace_anomalies_agg = pd.concat([trace_hi_agg, trace_lo_agg], ignore_index=True, sort=False)

# Ensure timestamps are timezone-aware Asia/Shanghai
if not trace_anomalies_agg.empty:
    trace_anomalies_agg['earliest_anomaly_timestamp'] = pd.to_datetime(trace_anomalies_agg['earliest_anomaly_timestamp']).dt.tz_convert(tz)

# Top 20 trace anomalies by severity desc
trace_anomalous_top20 = trace_anomalies_agg.sort_values('severity', ascending=False, na_position='last') \
    .loc[:, ['cmdb_id','trace_name','anomaly_type','earliest_anomaly_timestamp','anomaly_count','max_value','min_value','P95','P5','severity']] \
    .head(20).reset_index(drop=True)

# Keep intermediate variables in kernel: metric_cmdb_summary, metric_cmdb_summary_top20, trace_thresholds, trace_incident_window, trace_incident_with_thr, trace_anomalies_agg
metric_cmdb_summary_top20, trace_anomalous_top20
