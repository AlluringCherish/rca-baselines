import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Ensure required kernel variables exist
for var in ['metric_incident_window', 'component_kpi_thresholds', 'anomalies_agg']:
    if var not in globals():
        raise NameError(f"Required kernel variable '{var}' not found in kernel.")

hosts = ['os_010', 'os_021']

# Prepare thresholds lookup (reset index for merge)
thr = component_kpi_thresholds.copy()

# Filter incident-window metrics to target hosts and merge thresholds
df_hosts = metric_incident_window[metric_incident_window['cmdb_id'].isin(hosts)].copy()
# ensure timestamps tz
df_hosts['ts_dt'] = pd.to_datetime(df_hosts['ts_dt']).dt.tz_convert(tz)

df_hosts = df_hosts.merge(thr, on=['cmdb_id','kpi_name'], how='left')  # adds P95, P5

# Mark point-level anomalies using global thresholds
def mark_anomaly(row):
    v = row['value']
    p95 = row['P95']
    p5 = row['P5']
    if pd.isna(v) or (pd.isna(p95) and pd.isna(p5)):
        return None
    # prefer high if equal to both? follow spec: >=P95 high, <=P5 low
    if pd.notna(p95) and v >= p95:
        return 'high'
    if pd.notna(p5) and v <= p5:
        return 'low'
    return None

df_hosts['anomaly_type'] = df_hosts.apply(mark_anomaly, axis=1)

# Aggregate per host+timestamp: count distinct anomalous kpis and list first 10 names
anom_points = df_hosts[df_hosts['anomaly_type'].notnull()].copy()
# ensure kpi_name unique per timestamp
agg = (
    anom_points
    .groupby(['cmdb_id','ts_dt'], sort=True)
    .agg(
        concurrent_anomalous_kpi_count = ('kpi_name', lambda x: x.nunique()),
        kpi_list = ('kpi_name', lambda x: ','.join(list(pd.Series(x.unique())[:10])))
    )
    .reset_index()
)

# For timestamps in the full incident window even with zero anomalies, we don't need to show them;
# we only need earliest timestamp where count >=3 per host and next-minute persistence.
results = []
# precompute max_severity per host from anomalies_agg for context
max_sev_per_host = anomalies_agg.groupby('cmdb_id', sort=False)['severity'].max().to_dict()

for host in hosts:
    host_agg = agg[agg['cmdb_id'] == host].sort_values('ts_dt')
    # earliest timestamp where concurrent_anomalous_kpi_count >= 3
    cond = host_agg[host_agg['concurrent_anomalous_kpi_count'] >= 3]
    if not cond.empty:
        earliest_ts = cond['ts_dt'].min()
        row_at_t = host_agg[host_agg['ts_dt'] == earliest_ts].iloc[0]
        count_at_t = int(row_at_t['concurrent_anomalous_kpi_count'])
        kpi_list_at_t = row_at_t['kpi_list']
        # next minute
        next_ts = earliest_ts + pd.Timedelta(minutes=1)
        next_row = host_agg[host_agg['ts_dt'] == next_ts]
        if not next_row.empty:
            next_count = int(next_row.iloc[0]['concurrent_anomalous_kpi_count'])
            next_kpi_list = next_row.iloc[0]['kpi_list']
        else:
            next_count = 0
            next_kpi_list = ''
    else:
        earliest_ts = pd.NaT
        count_at_t = 0
        kpi_list_at_t = ''
        next_count = 0
        next_kpi_list = ''
    results.append({
        'cmdb_id': host,
        'earliest_multi_kpi_timestamp': earliest_ts,
        'concurrent_anomalous_kpi_count_at_that_time': count_at_t,
        'kpi_list_at_that_time': kpi_list_at_t,
        'next_minute_concurrent_count': next_count,
        'next_minute_kpi_list': next_kpi_list,
        'max_severity': max_sev_per_host.get(host, np.nan)
    })

result_table = pd.DataFrame(results)
# Ensure timestamps are timezone-aware strings for compact display (keep tz)
result_table['earliest_multi_kpi_timestamp'] = pd.to_datetime(result_table['earliest_multi_kpi_timestamp']).dt.tz_convert(tz)

# Final compact two-row result
result_table
