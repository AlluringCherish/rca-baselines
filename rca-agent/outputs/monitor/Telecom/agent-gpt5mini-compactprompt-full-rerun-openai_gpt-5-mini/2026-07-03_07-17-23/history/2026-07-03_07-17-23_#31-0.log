import numpy as np
import pandas as pd
import pytz

# reuse existing df_metric and tz if present; otherwise load minimal from file (but kernel already has df_metric)
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
    df_metric['ts_dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(pytz.timezone('Asia/Shanghai'))
    tz = pytz.timezone('Asia/Shanghai')

# 1) Compute global P95 and P5 for each (cmdb_id, kpi_name) across the entire metric series
component_kpi_thresholds = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'], sort=False)['value']
    .agg(P95=lambda x: x.quantile(0.95), P5=lambda x: x.quantile(0.05))
    .reset_index()
)

# 2) Filter metric.csv to the incident window (inclusive) using Asia/Shanghai timezone
start = pd.Timestamp('2020-05-27 01:00:00', tz=pytz.timezone('Asia/Shanghai'))
end   = pd.Timestamp('2020-05-27 01:30:00', tz=pytz.timezone('Asia/Shanghai'))
metric_incident_window = df_metric[(df_metric['ts_dt'] >= start) & (df_metric['ts_dt'] <= end)].copy()

# count of unique series scanned in the incident window
total_series_scanned = metric_incident_window.groupby(['cmdb_id','kpi_name']).ngroups

# 3) Detect anomalies in the window using precomputed thresholds
# Merge thresholds into the incident-window rows
incident_with_thr = metric_incident_window.merge(component_kpi_thresholds, on=['cmdb_id','kpi_name'], how='left')

# High anomalies: value >= P95
hi = incident_with_thr[incident_with_thr['value'] >= incident_with_thr['P95']].copy()
if not hi.empty:
    hi_agg = (
        hi.groupby(['cmdb_id','kpi_name'], as_index=False, sort=False)
        .agg(
            earliest_anomaly_timestamp=('ts_dt', 'min'),
            anomaly_count=('value', 'size'),
            max_value=('value', 'max'),
            min_value=('value', 'min'),
            P95=('P95', 'first'),
            P5=('P5', 'first')
        )
    )
    hi_agg['anomaly_type'] = 'high'
    # severity: (max_value - P95)/P95, guard divide-by-zero
    hi_agg['severity'] = hi_agg.apply(lambda r: (r['max_value'] - r['P95'])/r['P95'] if r['P95'] != 0 else np.nan, axis=1)
else:
    hi_agg = pd.DataFrame(columns=['cmdb_id','kpi_name','earliest_anomaly_timestamp','anomaly_count','max_value','min_value','P95','P5','anomaly_type','severity'])

# Low anomalies: value <= P5
lo = incident_with_thr[incident_with_thr['value'] <= incident_with_thr['P5']].copy()
if not lo.empty:
    lo_agg = (
        lo.groupby(['cmdb_id','kpi_name'], as_index=False, sort=False)
        .agg(
            earliest_anomaly_timestamp=('ts_dt', 'min'),
            anomaly_count=('value', 'size'),
            max_value=('value', 'max'),
            min_value=('value', 'min'),
            P95=('P95', 'first'),
            P5=('P5', 'first')
        )
    )
    lo_agg['anomaly_type'] = 'low'
    # severity: (P5 - min_value)/P5, guard divide-by-zero
    lo_agg['severity'] = lo_agg.apply(lambda r: (r['P5'] - r['min_value'])/r['P5'] if r['P5'] != 0 else np.nan, axis=1)
else:
    lo_agg = pd.DataFrame(columns=['cmdb_id','kpi_name','earliest_anomaly_timestamp','anomaly_count','max_value','min_value','P95','P5','anomaly_type','severity'])

# Combine high and low anomaly aggregates
anomalies_agg = pd.concat([hi_agg, lo_agg], ignore_index=True, sort=False)

# number of unique (cmdb_id,kpi_name) that had any anomaly in the window
anomaly_series_count = anomalies_agg.groupby(['cmdb_id','kpi_name']).ngroups

# 4) Prepare compact top-20 result sorted by severity descending
# select and order columns for compact display
if not anomalies_agg.empty:
    anomalies_agg = anomalies_agg.assign(
        earliest_anomaly_timestamp=lambda df: pd.to_datetime(df['earliest_anomaly_timestamp']).dt.tz_convert(pytz.timezone('Asia/Shanghai'))
    )
    anomalous_top20 = (
        anomalies_agg
        .sort_values('severity', ascending=False, na_position='last')
        .loc[:, ['cmdb_id','kpi_name','anomaly_type','earliest_anomaly_timestamp','anomaly_count','max_value','min_value','P95','P5','severity']]
        .head(20)
        .reset_index(drop=True)
    )
else:
