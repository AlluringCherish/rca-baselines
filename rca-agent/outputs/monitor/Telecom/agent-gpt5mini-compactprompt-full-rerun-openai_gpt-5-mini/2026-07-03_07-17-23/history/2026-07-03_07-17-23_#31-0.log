import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse kernel-stored variables: component_kpi_thresholds, metric_incident_window, anomalies_agg
for var in ['component_kpi_thresholds', 'metric_incident_window', 'anomalies_agg']:
    if var not in globals():
        raise NameError(f"Required kernel variable '{var}' not found in kernel.")

targets = ['os_010', 'os_021']

# 1) For each target cmdb_id, get top 5 kpi series by severity from anomalies_agg
# Sort by cmdb_id then severity desc, then take top 5 per cmdb_id
_anom_sorted = anomalies_agg.sort_values(['cmdb_id', 'severity'], ascending=[True, False])
top_series_per_cmdb = _anom_sorted[_anom_sorted['cmdb_id'].isin(targets)].groupby('cmdb_id', sort=False).head(5).reset_index(drop=True)

# 2) For each selected (cmdb_id, kpi_name), get incident-window points and mark anomalies using global thresholds
segments = []  # collect segment dicts

# convert component thresholds to lookup for fast access
thr_idx = component_kpi_thresholds.set_index(['cmdb_id', 'kpi_name'])

# iterate selected series (small number, ok to loop)
for _, row in top_series_per_cmdb.iterrows():
    cmdb = row['cmdb_id']
    kpi = row['kpi_name']
    # incident-window series for this series
    ts = metric_incident_window[(metric_incident_window['cmdb_id'] == cmdb) & (metric_incident_window['kpi_name'] == kpi)].copy()
    if ts.empty:
        continue
    # ensure tz-aware ts_dt
    ts['ts_dt'] = pd.to_datetime(ts['ts_dt']).dt.tz_convert(tz)
    ts = ts.sort_values('ts_dt').reset_index(drop=True)
    # lookup thresholds
    try:
        P95 = float(thr_idx.loc[(cmdb, kpi), 'P95'])
        P5  = float(thr_idx.loc[(cmdb, kpi), 'P5'])
    except KeyError:
        # no global threshold found; skip
        continue
    # mark each point
    def point_label(val):
        if pd.isna(val):
            return None
        if val >= P95:
            return 'high'
        if val <= P5:
            return 'low'
        return None
    ts['anomaly_type_point'] = ts['value'].apply(point_label)
    # 3) extract consecutive anomalous segments (same anomaly_type and contiguous in the time-ordered sequence,
    #    contiguous meaning no intervening non-anomalous points in the ordered incident-window series)
    series_segments = []
    current = None
    for _, r in ts.iterrows():
        atype = r['anomaly_type_point']
        t = r['ts_dt']
        val = r['value']
        if atype is None:
            # finalize current if exists
            if current is not None:
                series_segments.append(current)
                current = None
            continue
        # atype is 'high' or 'low'
        if current is None:
            current = {
                'cmdb_id': cmdb,
                'kpi_name': kpi,
                'anomaly_type': atype,
                'fault_start_timestamp': t,
                'fault_end_timestamp': t,
                'point_count': 1,
                'max_value': val,
                'min_value': val,
                'P95': P95,
                'P5': P5
            }
        else:
            # if same type, extend; if different type, finalize and start new
            if atype == current['anomaly_type']:
                current['fault_end_timestamp'] = t
                current['point_count'] += 1
                current['max_value'] = max(current['max_value'], val)
                current['min_value'] = min(current['min_value'], val)
            else:
                series_segments.append(current)
                current = {
                    'cmdb_id': cmdb,
                    'kpi_name': kpi,
                    'anomaly_type': atype,
                    'fault_start_timestamp': t,
                    'fault_end_timestamp': t,
                    'point_count': 1,
                    'max_value': val,
                    'min_value': val,
                    'P95': P95,
                    'P5': P5
                }
    # finalize last
    if current is not None:
        series_segments.append(current)
    # limit to up to 5 segments per series
    series_segments = series_segments[:5]
    # compute segment severity
    for seg in series_segments:
        if seg['anomaly_type'] == 'high':
            seg['segment_severity'] = (seg['max_value'] - seg['P95'])/seg['P95'] if seg['P95'] != 0 else np.nan
        else:
            seg['segment_severity'] = (seg['P5'] - seg['min_value'])/seg['P5'] if seg['P5'] != 0 else np.nan
        segments.append(seg)

# assemble DataFrame, sort by segment_severity desc, limit to top 20
if segments:
    df_segments = pd.DataFrame(segments)
    # ensure timestamp dtype and tz
    df_segments['fault_start_timestamp'] = pd.to_datetime(df_segments['fault_start_timestamp']).dt.tz_convert(tz)
    df_segments['fault_end_timestamp'] = pd.to_datetime(df_segments['fault_end_timestamp']).dt.tz_convert(tz)
    final_segments_top20 = (
        df_segments
        .sort_values('segment_severity', ascending=False, na_position='last')
        .loc[:, ['cmdb_id','kpi_name','anomaly_type','fault_start_timestamp','fault_end_timestamp','point_count','max_value','min_value','P95','P5','segment_severity']]
        .head(20)
        .reset_index(drop=True)
    )
else:
    final_segments_top20 = pd.DataFrame(columns=['cmdb_id','kpi_name','anomaly_type','fault_start_timestamp','fault_end_timestamp','point_count','max_value','min_value','P95','P5','segment_severity'])

# Keep intermediate full time series in kernel variables (ts per series stored in local 'ts' within loop is ephemeral).
# Expose final compact table
final_segments_top20
