import numpy as np
import pandas as pd
import pytz

# Reuse existing df_metric and tz if present; otherwise load and prepare
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
tz = pytz.timezone('Asia/Shanghai')

# Ensure ts column is timezone-aware UTC+8
if 'ts' not in df_metric.columns:
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    # convert/ensure tz
    df_metric['ts'] = pd.to_datetime(df_metric['ts']).dt.tz_localize(None) if df_metric['ts'].dt.tz is None else df_metric['ts']
    df_metric['ts'] = df_metric['ts'].dt.tz_convert(tz)

# Candidate components
db_ids = [f"db_{i:03d}" for i in range(1, 14)]
docker_ids = [f"docker_{i:03d}" for i in range(1, 9)]
os_ids = [f"os_{i:03d}" for i in range(1, 23)]
candidates = set(db_ids + docker_ids + os_ids)

# Filter full metric to candidate components for threshold computation (global)
df_cand_full = df_metric[df_metric['cmdb_id'].isin(candidates)].copy()

# Ensure 'value' is numeric
df_cand_full['value'] = pd.to_numeric(df_cand_full['value'], errors='coerce')

# Compute global thresholds (p95, p5) and total count per component-KPI pair
thresholds = (
    df_cand_full
    .groupby(['cmdb_id', 'kpi_name'], observed=True)['value']
    .agg(
        count='size',
        p95=lambda s: float(np.nanpercentile(s.dropna().values, 95)) if s.dropna().size > 0 else np.nan,
        p5 = lambda s: float(np.nanpercentile(s.dropna().values, 5)) if s.dropna().size > 0 else np.nan
    )
    .reset_index()
)

# Incident window (UTC+8)
start = pd.Timestamp('2020-05-23 01:30:00', tz=tz)
end   = pd.Timestamp('2020-05-23 02:00:00', tz=tz)

# Filter metric to candidate components and window
df_window = df_cand_full[(df_cand_full['ts'] >= start) & (df_cand_full['ts'] <= end)].copy()

# Join window rows with global thresholds
df_join = df_window.merge(thresholds, on=['cmdb_id', 'kpi_name'], how='left', suffixes=('', '_thr'))

# Label anomalies
df_join['high_anom'] = (df_join['value'] >= df_join['p95'])
df_join['low_anom']  = (df_join['value'] <= df_join['p5'])
df_join['is_anom']   = df_join['high_anom'] | df_join['low_anom']

# Aggregate per component-KPI within the window
agg = (
    df_join
    .groupby(['cmdb_id', 'kpi_name'], observed=True)
    .agg(
        anomaly_count = ('is_anom', 'sum'),
        earliest_anomaly_timestamp = (lambda g: (g.loc[g['is_anom'], 'ts'].min() if g['is_anom'].any() else pd.NaT)),
        max_value = ('value', 'max'),
        min_value = ('value', 'min'),
        p95 = ('p95', 'first'),
        p5  = ('p5', 'first')
    )
    .reset_index()
)

# The above lambda in agg may not work in older pandas; handle earliest_anomaly_timestamp separately if NaT results
# Ensure earliest_anomaly_timestamp computed robustly:
def compute_earliest_anom(df):
    if df['is_anom'].any():
        return df.loc[df['is_anom'], 'ts'].min()
    else:
        return pd.NaT

ea = (
    df_join.groupby(['cmdb_id','kpi_name'], observed=True)
    .apply(lambda d: compute_earliest_anom(d))
    .reset_index(name='earliest_anomaly_timestamp')
)

# Merge earliest timestamp into agg (to be safe)
agg = agg.drop(columns=['earliest_anomaly_timestamp']).merge(ea, on=['cmdb_id','kpi_name'], how='left')

# Compute severity metric per instructions
# up = (max_value - p95)/p95 if p95>0 else (max_value - p95)
# down = (p5 - min_value)/p5 if p5>0 else (p5 - min_value)
agg['p95'] = pd.to_numeric(agg['p95'], errors='coerce')
agg['p5']  = pd.to_numeric(agg['p5'], errors='coerce')
agg['max_value'] = pd.to_numeric(agg['max_value'], errors='coerce')
agg['min_value'] = pd.to_numeric(agg['min_value'], errors='coerce')

def compute_severity_row(row):
    # up side
    if pd.isna(row['p95']):
        up = np.nan
    else:
        up = ((row['max_value'] - row['p95']) / row['p95']) if row['p95'] > 0 else (row['max_value'] - row['p95'])
    # down side
    if pd.isna(row['p5']):
        down = np.nan
    else:
        down = ((row['p5'] - row['min_value']) / row['p5']) if row['p5'] > 0 else (row['p5'] - row['min_value'])
    # take the larger absolute positive effect; if both present take max of up and down (treat NaN as -inf)
    candidates_vals = [v for v in [up, down] if not pd.isna(v)]
    if not candidates_vals:
        return np.nan
    # severity should be the larger value (not absolute), per instruction "larger of" the two computed metrics
    return float(max(candidates_vals))

agg['severity'] = agg.apply(compute_severity_row, axis=1)

# Format earliest_anomaly_timestamp as ISO strings
agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_timestamp'].dt.tz_convert(tz).apply(lambda x: x.isoformat() if pd.notnull(x) else None)

# Keep only pairs with anomaly_count > 0
agg_anom = agg[agg['anomaly_count'] > 0].copy()

# Total number of distinct component-KPI pairs that have anomaly_count > 0
total_anom_pairs = int(agg_anom.shape[0])

# Select and order columns as requested and sort by anomaly_count desc, then severity desc
result = (
    agg_anom[['cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp','severity','p95','p5','max_value','min_value']]
    .sort_values(['anomaly_count','severity'], ascending=[False, False])
    .reset_index(drop=True)
)

top20_result = result.head(20)

# Display compact outputs: top20_result and total_anom_pairs
top20_result, total_anom_pairs
