import pandas as pd
import pytz

# reuse metric if exists, otherwise load
try:
    metric
except NameError:
    metric = pd.read_csv('metric.csv')
    metric['timestamp'] = pd.to_numeric(metric['timestamp'], errors='coerce').astype('Int64')

# ensure numeric timestamp and value
metric['timestamp'] = pd.to_numeric(metric['timestamp'], errors='coerce').astype('Int64')
metric['value'] = pd.to_numeric(metric['value'], errors='coerce')

tz = pytz.timezone('Asia/Shanghai')

# 1) compute global P95 and P5 per (cmdb_id, kpi_name) using full series
p95 = metric.groupby(['cmdb_id', 'kpi_name'], sort=False)['value'].quantile(0.95).reset_index(name='P95')
p5 = metric.groupby(['cmdb_id', 'kpi_name'], sort=False)['value'].quantile(0.05).reset_index(name='P5')
thresholds = p95.merge(p5, on=['cmdb_id', 'kpi_name'])

# 2) filter to incident window (inclusive)
start_ts = int(pd.Timestamp('2020-05-29 02:30:00', tz=tz).tz_convert(pytz.UTC).timestamp())
end_ts = int(pd.Timestamp('2020-05-29 03:00:00', tz=tz).tz_convert(pytz.UTC).timestamp())

metric_window = metric[(metric['timestamp'] >= start_ts) & (metric['timestamp'] <= end_ts)].copy()

# total rows in window
total_rows_in_window = int(metric_window.shape[0])

# If no rows in window, return empty results quickly
if metric_window.empty:
    result_top = pd.DataFrame(columns=['cmdb_id','kpi_name','count_high','earliest_high_ts','count_low','earliest_low_ts','P95','P5'])
    summary = f"total_rows_in_window: {total_rows_in_window}; total_anomaly_points: 0"
else:
    # attach thresholds to windowed rows
    metric_w = metric_window.merge(thresholds, on=['cmdb_id','kpi_name'], how='left')

    # 3) For each pair compute counts and earliest timestamps
    def summarize_group(g):
        p95v = g['P95'].iloc[0]
        p5v = g['P5'].iloc[0]
        high_mask = g['value'] >= p95v
        low_mask = g['value'] <= p5v

        count_high = int(high_mask.sum())
        earliest_high_ts = int(g.loc[high_mask, 'timestamp'].min()) if count_high > 0 else pd.NA

        count_low = int(low_mask.sum())
        earliest_low_ts = int(g.loc[low_mask, 'timestamp'].min()) if count_low > 0 else pd.NA

        return pd.Series({
            'count_high': count_high,
            'earliest_high_ts': earliest_high_ts,
            'count_low': count_low,
            'earliest_low_ts': earliest_low_ts,
            'P95': p95v,
            'P5': p5v
        })

    summary_df = metric_w.groupby(['cmdb_id','kpi_name'], sort=False).apply(summarize_group).reset_index()

    # convert earliest timestamps to timezone-aware ISO strings, keep nulls as None
    def ts_to_iso(x):
        if pd.isna(x):
            return None
        return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).isoformat()

    summary_df['earliest_high_ts'] = summary_df['earliest_high_ts'].apply(ts_to_iso)
    summary_df['earliest_low_ts'] = summary_df['earliest_low_ts'].apply(ts_to_iso)

    # compute sort key and filter out pairs that had zero rows in window (groupby already only includes present groups)
    summary_df['max_count'] = summary_df[['count_high','count_low']].max(axis=1)

    # 4) sort and limit to top 20 by max count desc
    result_top = summary_df.sort_values(['max_count','count_high','count_low'], ascending=[False,False,False]).head(20)

    # select and format columns
    result_top = result_top[['cmdb_id','kpi_name','count_high','earliest_high_ts','count_low','earliest_low_ts','P95','P5']]

    # round P95/P5 for compactness
    result_top['P95'] = result_top['P95'].round(6)
    result_top['P5'] = result_top['P5'].round(6)

    total_anomalies = int((summary_df['count_high'] + summary_df['count_low']).sum())
    summary = f"total_rows_in_window: {total_rows_in_window}; total_anomaly_points: {total_anomalies}"

# final compact outputs: top results (<=20 rows) and single-line summary
result_top, summary
