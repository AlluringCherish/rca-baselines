import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse metric if present, else load
try:
    metric
except NameError:
    metric = pd.read_csv('metric.csv')
    metric['timestamp'] = pd.to_numeric(metric['timestamp'], errors='coerce').astype('Int64')
    metric['value'] = pd.to_numeric(metric['value'], errors='coerce')

# Ensure numeric
metric['value'] = pd.to_numeric(metric['value'], errors='coerce')

# Reuse start/end window if available, else define
try:
    start_ts, end_ts
except NameError:
    start_ts = int(pd.Timestamp('2020-05-29 02:30:00', tz=tz).tz_convert(pytz.UTC).timestamp())
    end_ts = int(pd.Timestamp('2020-05-29 03:00:00', tz=tz).tz_convert(pytz.UTC).timestamp())

# Ensure thresholds (global P95/P5 per pair) exist; otherwise compute from full metric
try:
    thresholds
except NameError:
    p95 = metric.groupby(['cmdb_id','kpi_name'], sort=False)['value'].quantile(0.95).reset_index(name='P95')
    p5 = metric.groupby(['cmdb_id','kpi_name'], sort=False)['value'].quantile(0.05).reset_index(name='P5')
    thresholds = p95.merge(p5, on=['cmdb_id','kpi_name'])

# Ensure we have summary_df (per-pair counts & earliest ts). If missing, compute counts in window.
try:
    summary_df
except NameError:
    # compute metric_window first
    metric_window = metric[(metric['timestamp'] >= start_ts) & (metric['timestamp'] <= end_ts)].copy()
    # join thresholds
    metric_w = metric_window.merge(thresholds, on=['cmdb_id','kpi_name'], how='left')
    # compute counts and earliest timestamps
    def summarize_group(g):
        p95v = g['P95'].iloc[0]
        p5v = g['P5'].iloc[0]
        high_mask = g['value'] >= p95v
        low_mask = g['value'] <= p5v
        count_high = int(high_mask.sum())
        earliest_high_ts = int(g.loc[high_mask, 'timestamp'].min()) if count_high>0 else pd.NA
        count_low = int(low_mask.sum())
        earliest_low_ts = int(g.loc[low_mask, 'timestamp'].min()) if count_low>0 else pd.NA
        return pd.Series({
            'count_high': count_high,
            'earliest_high_ts': earliest_high_ts,
            'count_low': count_low,
            'earliest_low_ts': earliest_low_ts,
            'P95': p95v,
            'P5': p5v
        })
    if 'metric_w' not in globals():
        metric_window = metric[(metric['timestamp'] >= start_ts) & (metric['timestamp'] <= end_ts)].copy()
        metric_w = metric_window.merge(thresholds, on=['cmdb_id','kpi_name'], how='left')
    summary_df = metric_w.groupby(['cmdb_id','kpi_name'], sort=False).apply(summarize_group).reset_index()
    # convert earliest ts ints to ISO strings in UTC+8 where present
    def int_ts_to_iso(x):
        if pd.isna(x):
            return None
        return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).isoformat()
    summary_df['earliest_high_ts'] = summary_df['earliest_high_ts'].apply(int_ts_to_iso)
    summary_df['earliest_low_ts'] = summary_df['earliest_low_ts'].apply(int_ts_to_iso)

# Ensure metric_window exists
try:
    metric_window
except NameError:
    metric_window = metric[(metric['timestamp'] >= start_ts) & (metric['timestamp'] <= end_ts)].copy()

# 1) compute max/min in window per (cmdb_id,kpi_name)
win_stats = (
    metric_window.groupby(['cmdb_id','kpi_name'], sort=False)['value']
    .agg(min_value_in_window='min', max_value_in_window='max')
    .reset_index()
)

# Merge with summary_df and thresholds to get counts and P95/P5
per_kpi = win_stats.merge(summary_df, on=['cmdb_id','kpi_name'], how='left').merge(
    thresholds, on=['cmdb_id','kpi_name'], how='left', suffixes=('', '_th')
)

# Prefer P95/P5 from thresholds if summary_df missing them
per_kpi['P95'] = per_kpi['P95'].fillna(per_kpi['P95_th'])
per_kpi['P5'] = per_kpi['P5'].fillna(per_kpi['P5'])

# Ensure counts numeric
per_kpi['count_high'] = pd.to_numeric(per_kpi['count_high'], errors='coerce').fillna(0).astype(int)
per_kpi['count_low'] = pd.to_numeric(per_kpi['count_low'], errors='coerce').fillna(0).astype(int)

# 2) compute severities
def compute_severity(row):
    maxv = row['max_value_in_window']
    minv = row['min_value_in_window']
    p95 = row['P95']
    p5 = row['P5']
    # severity_high
    if row['count_high'] <= 0 or pd.isna(p95):
        sev_h = 0.0
    else:
        if p95 > 0:
            sev_h = (maxv - p95) / p95
        else:
            sev_h = (maxv - p95)
        if sev_h < 0:
            sev_h = 0.0
    # severity_low
    if row['count_low'] <= 0 or pd.isna(p5):
        sev_l = 0.0
    else:
        if p5 > 0:
            sev_l = (p5 - minv) / p5
        else:
            sev_l = (p5 - minv)
        if sev_l < 0:
            sev_l = 0.0
    sev = max(sev_h, sev_l, 0.0)
    return pd.Series({'severity_high': sev_h, 'severity_low': sev_l, 'kpi_severity': sev})

sev_df = per_kpi.apply(compute_severity, axis=1)
per_kpi = pd.concat([per_kpi, sev_df], axis=1)

# 3) Aggregate per cmdb_id
per_kpi['anomaly_points'] = per_kpi['count_high'] + per_kpi['count_low']

# parse earliest timestamps (strings) to datetimes for min calculation
def parse_iso(x):
    if pd.isna(x) or x is None:
        return pd.NaT
    return pd.to_datetime(x).tz_convert(tz) if pd.api.types.is_datetime64_any_dtype(x) else pd.to_datetime(str(x), utc=True).tz_convert(tz)

# Ensure earliest_high/low columns present in per_kpi (they came from summary_df)
if 'earliest_high_ts' not in per_kpi.columns:
    per_kpi['earliest_high_ts'] = None
if 'earliest_low_ts' not in per_kpi.columns:
    per_kpi['earliest_low_ts'] = None

per_kpi['earliest_high_dt'] = per_kpi['earliest_high_ts'].apply(lambda x: parse_iso(x))
per_kpi['earliest_low_dt'] = per_kpi['earliest_low_ts'].apply(lambda x: parse_iso(x))

def top_kpis_by_sev(group, top_n=5):
    s = group[['kpi_name','kpi_severity']].copy()
    s = s.sort_values('kpi_severity', ascending=False).head(top_n)
    s = s[s['kpi_severity']>0]
    return ", ".join([f"{r.kpi_name} ({r.kpi_severity:.6f})" for r in s.itertuples(index=False)])

agg = (
    per_kpi.groupby('cmdb_id', sort=False)
    .apply(lambda g: pd.Series({
        'total_anomaly_points': int(g['anomaly_points'].sum()),
        'num_kpis_with_anomaly': int((g['anomaly_points']>0).sum()),
        'earliest_anomaly_dt': pd.concat([g['earliest_high_dt'], g['earliest_low_dt']]).min(),
        'max_kpi_severity': float(g['kpi_severity'].max()) if not g['kpi_severity'].isna().all() else 0.0,
        'top_kpis_by_severity': top_kpis_by_sev(g, top_n=5)
    }))
    .reset_index()
)

# 4) component_level mapping
def comp_level(cid):
    if str(cid).startswith('db_'):
        return 'service-level'
    if str(cid).startswith('docker_'):
        return 'container-level'
    if str(cid).startswith('os_'):
        return 'node-level'
    if str(cid).startswith('redis_'):
        return 'service-level'
    return 'unknown'

agg['component_level'] = agg['cmdb_id'].apply(comp_level)

# Format earliest_anomaly_ts as ISO string (UTC+8) or None
def dt_to_iso(x):
    if pd.isna(x):
        return None
    if x.tzinfo is None:
        x = x.tz_localize(tz)
    else:
        x = x.tz_convert(tz)
    return x.isoformat()

agg['earliest_anomaly_ts'] = agg['earliest_anomaly_dt'].apply(dt_to_iso)

# Select & order columns
result = agg[['cmdb_id','component_level','max_kpi_severity','total_anomaly_points','num_kpis_with_anomaly','earliest_anomaly_ts','top_kpis_by_severity']]

# 5) sort by max_kpi_severity desc and limit to top 20
result_top20 = result.sort_values('max_kpi_severity', ascending=False).head(20).reset_index(drop=True)

# Single-line summary: number of distinct cmdb_id with at least one KPI anomaly in window
distinct_cmdb_with_anomaly = int((agg['total_anomaly_points']>0).sum())
summary_line = f"distinct_cmdb_id_with_anomaly: {distinct_cmdb_with_anomaly}"

# Compact outputs
result_top20, summary_line
