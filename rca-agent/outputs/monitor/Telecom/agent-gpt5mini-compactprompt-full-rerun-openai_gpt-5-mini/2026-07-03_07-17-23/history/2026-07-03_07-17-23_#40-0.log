import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse existing kernel variables when available; otherwise compute required tables
# metric
try:
    metric
except NameError:
    metric = pd.read_csv('metric.csv')
    metric['timestamp'] = pd.to_numeric(metric['timestamp'], errors='coerce').astype('Int64')
    metric['value'] = pd.to_numeric(metric['value'], errors='coerce')

metric['value'] = pd.to_numeric(metric['value'], errors='coerce')

# thresholds (global P95/P5) - must be computed on full series (rule 9)
try:
    thresholds
except NameError:
    p95 = metric.groupby(['cmdb_id','kpi_name'], sort=False)['value'].quantile(0.95).reset_index(name='P95')
    p5 = metric.groupby(['cmdb_id','kpi_name'], sort=False)['value'].quantile(0.05).reset_index(name='P5')
    thresholds = p95.merge(p5, on=['cmdb_id','kpi_name'])

# incident window timestamps (UTC+8 -> convert to UTC epoch)
start_ts = int(pd.Timestamp('2020-05-29 02:30:00', tz=tz).tz_convert(pytz.UTC).timestamp())
end_ts = int(pd.Timestamp('2020-05-29 03:00:00', tz=tz).tz_convert(pytz.UTC).timestamp())

# metric_window: rows within incident window
try:
    metric_window
except NameError:
    metric_window = metric[(metric['timestamp'] >= start_ts) & (metric['timestamp'] <= end_ts)].copy()

# per_kpi: ensure we have per-(cmdb_id,kpi) window stats, counts, P95/P5, severities, earliest dt
if 'per_kpi' not in globals():
    # 1) window min/max
    win_stats = (
        metric_window.groupby(['cmdb_id','kpi_name'], sort=False)['value']
        .agg(min_value_in_window='min', max_value_in_window='max')
        .reset_index()
    )

    # 2) counts and earliest breach timestamps within window, using thresholds
    metric_w = metric_window.merge(thresholds, on=['cmdb_id','kpi_name'], how='left')
    def summarize_group(g):
        p95v = g['P95'].iloc[0]
        p5v = g['P5'].iloc[0]
        high_mask = g['value'] >= p95v if not pd.isna(p95v) else pd.Series([False]*len(g), index=g.index)
        low_mask = g['value'] <= p5v if not pd.isna(p5v) else pd.Series([False]*len(g), index=g.index)
        count_high = int(high_mask.sum())
        earliest_high_ts = int(g.loc[high_mask, 'timestamp'].min()) if count_high>0 else pd.NA
        count_low = int(low_mask.sum())
        earliest_low_ts = int(g.loc[low_mask, 'timestamp'].min()) if count_low>0 else pd.NA
        return pd.Series({
            'count_high': count_high,
            'earliest_high_ts': earliest_high_ts,
            'count_low': count_low,
            'earliest_low_ts': earliest_low_ts,
            'P95': p95v,
            'P5': p5v
        })

    if metric_w.empty:
        summary_df = pd.DataFrame(columns=['cmdb_id','kpi_name','count_high','earliest_high_ts','count_low','earliest_low_ts','P95','P5'])
    else:
        summary_df = metric_w.groupby(['cmdb_id','kpi_name'], sort=False).apply(summarize_group).reset_index()

    # merge stats and summary
    per_kpi = win_stats.merge(summary_df, on=['cmdb_id','kpi_name'], how='left')
    # fill P95/P5 if missing from merge (shouldn't be)
    per_kpi = per_kpi.merge(thresholds, on=['cmdb_id','kpi_name'], how='left', suffixes=('','_th'))
    per_kpi['P95'] = per_kpi['P95'].fillna(per_kpi.get('P95_th'))
    per_kpi['P5'] = per_kpi['P5'].fillna(per_kpi.get('P5'))
    per_kpi['count_high'] = pd.to_numeric(per_kpi['count_high'], errors='coerce').fillna(0).astype(int)
    per_kpi['count_low'] = pd.to_numeric(per_kpi['count_low'], errors='coerce').fillna(0).astype(int)
    per_kpi['anomaly_points'] = per_kpi['count_high'] + per_kpi['count_low']

    # parse earliest ts to tz-aware datetimes (Asia/Shanghai)
    def int_ts_to_dt(x):
        if pd.isna(x):
            return pd.NaT
        try:
            return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz)
        except Exception:
            return pd.NaT

    per_kpi['earliest_high_dt'] = per_kpi['earliest_high_ts'].apply(int_ts_to_dt)
    per_kpi['earliest_low_dt'] = per_kpi['earliest_low_ts'].apply(int_ts_to_dt)

    # 3) compute severity_high/low and kpi_severity
    def compute_sev(row):
        maxv = row['max_value_in_window']
        minv = row['min_value_in_window']
        p95 = row['P95']
        p5 = row['P5']
        # high
        if row['count_high'] <= 0 or pd.isna(p95):
            sev_h = 0.0
        else:
            if p95 > 0:
                sev_h = (maxv - p95) / p95
            else:
                sev_h = (maxv - p95)
            sev_h = max(sev_h, 0.0)
        # low
        if row['count_low'] <= 0 or pd.isna(p5):
            sev_l = 0.0
        else:
            if p5 > 0:
                sev_l = (p5 - minv) / p5
            else:
                sev_l = (p5 - minv)
            sev_l = max(sev_l, 0.0)
        sev = max(sev_h, sev_l, 0.0)
        return pd.Series({'severity_high': sev_h, 'severity_low': sev_l, 'kpi_severity': sev})
    sev_df = per_kpi.apply(compute_sev, axis=1)
    per_kpi = pd.concat([per_kpi, sev_df], axis=1)

# Ensure result_top20 ordering exists; if not compute basic agg and ordering
if 'result_top20' not in globals():
    # aggregate to compute max_kpi_severity per cmdb_id and build result_top20
    agg_tmp = per_kpi.groupby('cmdb_id', sort=False).apply(lambda g: pd.Series({
        'max_kpi_severity': float(g['kpi_severity'].max()) if not g['kpi_severity'].isna().all() else 0.0
    })).reset_index()
    # component level map
    def comp_level(cid):
        cid = str(cid)
        if cid.startswith('db_'):
            return 'service-level'
        if cid.startswith('docker_'):
            return 'container-level'
        if cid.startswith('os_'):
            return 'node-level'
        if cid.startswith('redis_'):
            return 'service-level'
        return 'unknown'
    agg_tmp['component_level'] = agg_tmp['cmdb_id'].apply(comp_level)
    result_top20 = agg_tmp.sort_values('max_kpi_severity', ascending=False).head(20).reset_index(drop=True)

# select top 10 cmdb_id in result_top20 ordering
top_cmdbs = result_top20['cmdb_id'].head(10).tolist()

# For these cmdb_ids, pick up to top 5 KPIs by kpi_severity
sel = per_kpi[per_kpi['cmdb_id'].isin(top_cmdbs)].copy()
# Ensure we have the component_level column mapping
def comp_level(cid):
    cid = str(cid)
    if cid.startswith('db_'):
        return 'service-level'
    if cid.startswith('docker_'):
        return 'container-level'
    if cid.startswith('os_'):
        return 'node-level'
    if cid.startswith('redis_'):
        return 'service-level'
    return 'unknown'
sel['component_level'] = sel['cmdb_id'].apply(comp_level)

# earliest anomaly ts as earliest of earliest_high_dt and earliest_low_dt
sel['earliest_anomaly_dt'] = sel[['earliest_high_dt','earliest_low_dt']].min(axis=1)
# breach side: choose high if severity_high >= severity_low and severity_high>0 else low if severity_low>0 else None
def breach_side(row):
    if row['severity_high'] > 0 or row['severity_low'] > 0:
        if row['severity_high'] >= row['severity_low'] and row['severity_high']>0:
            return 'high'
        if row['severity_low'] > 0:
            return 'low'
    return None
sel['breach_side'] = sel.apply(breach_side, axis=1)

# Keep only top 5 KPIs per cmdb_id by kpi_severity (including zero severities if present, but sorted)
