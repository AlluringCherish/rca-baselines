import pandas as pd
import pytz
import numpy as np

tz = pytz.timezone('Asia/Shanghai')

# Ensure metric is loaded
try:
    metric
except NameError:
    metric = pd.read_csv('metric.csv')
    metric['timestamp'] = pd.to_numeric(metric['timestamp'], errors='coerce').astype('Int64')
    metric['value'] = pd.to_numeric(metric['value'], errors='coerce')

metric['timestamp'] = pd.to_numeric(metric['timestamp'], errors='coerce').astype('Int64')
metric['value'] = pd.to_numeric(metric['value'], errors='coerce')

# Ensure global thresholds P95/P5 computed (rule 9)
try:
    thresholds
except NameError:
    p95 = metric.groupby(['cmdb_id','kpi_name'], sort=False)['value'].quantile(0.95).reset_index(name='P95')
    p5 = metric.groupby(['cmdb_id','kpi_name'], sort=False)['value'].quantile(0.05).reset_index(name='P5')
    thresholds = p95.merge(p5, on=['cmdb_id','kpi_name'])

# incident window (UTC+8 converted to UTC epoch seconds)
start_ts = int(pd.Timestamp('2020-05-29 02:30:00', tz=tz).tz_convert(pytz.UTC).timestamp())
end_ts = int(pd.Timestamp('2020-05-29 03:00:00', tz=tz).tz_convert(pytz.UTC).timestamp())

# Pairs to analyze
pairs = [
    ('redis_003', 'instantaneous_output_kbps'),
    ('db_002', 'Physical_Read_Per_Sec'),
    ('os_022', 'Disk_await'),
]

def iso_from_ts_int(x):
    if pd.isna(x):
        return None
    return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).isoformat()

rows = []
for cmdb_id, kpi in pairs:
    # Get global thresholds
    thr = thresholds[(thresholds['cmdb_id']==cmdb_id) & (thresholds['kpi_name']==kpi)]
    if thr.empty:
        P95 = np.nan
        P5 = np.nan
    else:
        P95 = float(thr['P95'].iloc[0])
        P5 = float(thr['P5'].iloc[0])

    # Filter metric to window and pair
    dfw = metric[
        (metric['cmdb_id']==cmdb_id) &
        (metric['kpi_name']==kpi) &
        (metric['timestamp']>=start_ts) &
        (metric['timestamp']<=end_ts)
    ].copy().sort_values('timestamp')

    # Determine breach side using earlier per_kpi or fallback to window values
    breach_side = None
    # Try to use per_kpi if exists
    if 'per_kpi' in globals():
        pk = per_kpi[(per_kpi['cmdb_id']==cmdb_id) & (per_kpi['kpi_name']==kpi)]
        if not pk.empty:
            # prefer high if severity_high >= severity_low and there were high breaches
            if int(pk['count_high'].iloc[0])>0 and float(pk['severity_high'].iloc[0])>=float(pk['severity_low'].iloc[0]):
                breach_side = 'high'
            elif int(pk['count_low'].iloc[0])>0:
                breach_side = 'low'
    # Fallback: decide by checking any values in window compared to thresholds
    if breach_side is None:
        if not dfw.empty and (not np.isnan(P95)) and (dfw['value']>=P95).any():
            breach_side = 'high'
        elif not dfw.empty and (not np.isnan(P5)) and (dfw['value']<=P5).any():
            breach_side = 'low'
        else:
            # no breaches in window
            breach_side = None

    # Build breached rows according to breach_side
    if breach_side == 'high':
        breached = dfw[dfw['value'] >= P95].copy()
    elif breach_side == 'low':
        breached = dfw[dfw['value'] <= P5].copy()
    else:
        breached = dfw.iloc[0:0].copy()  # empty

    total_breach_points = int(breached.shape[0])

    # Find consecutive segments (timestamps differ by exactly 60 seconds)
    segments = []
    if not breached.empty:
        breached = breached.sort_values('timestamp').reset_index(drop=True)
        # compute difference between consecutive timestamps
        breached['ts_diff'] = breached['timestamp'].diff().fillna(0).astype('Int64')
        # start a new segment where ts_diff != 60
        seg_id = (breached['ts_diff'] != 60).cumsum()
        for sid, grp in breached.groupby(seg_id, sort=False):
            start_ts_seg = int(grp['timestamp'].iloc[0])
            end_ts_seg = int(grp['timestamp'].iloc[-1])
            length_min = int(grp.shape[0])  # each row is per-minute
            max_val = float(grp['value'].max())
            min_val = float(grp['value'].min())
            segments.append({
                'segment_start_ts': start_ts_seg,
                'segment_end_ts': end_ts_seg,
                'segment_length_minutes': length_min,
                'max_value_in_segment': max_val,
                'min_value_in_segment': min_val
            })
    # Determine earliest segment details
    if segments:
        earliest_seg = min(segments, key=lambda x: x['segment_start_ts'])
        earliest_start_iso = iso_from_ts_int(earliest_seg['segment_start_ts'])
        earliest_end_iso = iso_from_ts_int(earliest_seg['segment_end_ts'])
        earliest_len = earliest_seg['segment_length_minutes']
        earliest_max = earliest_seg['max_value_in_segment']
        earliest_min = earliest_seg['min_value_in_segment']
    else:
        earliest_start_iso = None
        earliest_end_iso = None
        earliest_len = 0
        earliest_max = None
        earliest_min = None

    rows.append({
        'cmdb_id': cmdb_id,
        'kpi_name': kpi,
        'breach_side': breach_side,
        'earliest_breach_ts': earliest_start_iso,
        'earliest_segment_length_minutes': earliest_len,
        'earliest_segment_end_ts': earliest_end_iso,
        'earliest_segment_max_value': earliest_max,
        'earliest_segment_min_value': earliest_min,
        'total_breach_points_in_window': total_breach_points
    })

summary_df_pairs = pd.DataFrame(rows, columns=[
    'cmdb_id','kpi_name','breach_side','earliest_breach_ts','earliest_segment_length_minutes',
    'earliest_segment_end_ts','earliest_segment_max_value','earliest_segment_min_value',
    'total_breach_points_in_window'
])

