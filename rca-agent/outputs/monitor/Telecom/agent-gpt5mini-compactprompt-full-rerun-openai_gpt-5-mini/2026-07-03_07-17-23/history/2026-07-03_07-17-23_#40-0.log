import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Prefer to use the full per-(cmdb_id,kpi_name) anomaly table if available
if 'summary_df' in globals():
    anomalies = summary_df.copy()
elif 'result_top' in globals():
    # fallback: use result_top but note it may be only top 20 overall
    anomalies = result_top.copy()
else:
    raise RuntimeError("No per-(cmdb_id,kpi_name) anomaly table found in kernel.")

# Ensure numeric counts
anomalies['count_high'] = pd.to_numeric(anomalies['count_high'], errors='coerce').fillna(0).astype(int)
anomalies['count_low'] = pd.to_numeric(anomalies['count_low'], errors='coerce').fillna(0).astype(int)

# Parse earliest timestamp strings back to datetimes (NaNs become NaT)
for col in ['earliest_high_ts', 'earliest_low_ts']:
    # If column already datetime, this will leave it mostly unchanged; otherwise parse strings
    anomalies[col + '_dt'] = pd.to_datetime(anomalies[col], errors='coerce')
    # Ensure timezone is Asia/Shanghai for tz-aware datetimes
    # If naive, localize to Asia/Shanghai; if tz-aware, convert to Asia/Shanghai
    def normalize_tz(x):
        if pd.isna(x):
            return pd.NaT
        if x.tzinfo is None:
            return x.tz_localize(tz)
        return x.tz_convert(tz)
    anomalies[col + '_dt'] = anomalies[col + '_dt'].apply(normalize_tz)

# Compute per-cmdb_id aggregations
anomalies['anomaly_points'] = anomalies['count_high'] + anomalies['count_low']

def top_kpis_series(df, top_n=5):
    # df has kpi_name, anomaly_points
    s = df.groupby('kpi_name', sort=False)['anomaly_points'].sum().reset_index()
    s = s.sort_values('anomaly_points', ascending=False).head(top_n)
    return ", ".join([f"{row.kpi_name} ({int(row.anomaly_points)})" for row in s.itertuples(index=False)])

agg = (
    anomalies.groupby('cmdb_id', sort=False)
    .apply(lambda g: pd.Series({
        'total_anomaly_points': int(g['anomaly_points'].sum()),
        'num_kpis_with_anomaly': int((g['anomaly_points'] > 0).sum()),
        'earliest_anomaly_ts_dt': (pd.concat([g['earliest_high_ts_dt'], g['earliest_low_ts_dt']])).min(),
        'top_kpis': top_kpis_series(g, top_n=5)
    }))
    .reset_index()
)

# Convert earliest timestamp to ISO string (UTC+8) and keep None for NaT
def dt_to_iso(x):
    if pd.isna(x):
        return None
    # ensure tz is Asia/Shanghai then isoformat
    if x.tzinfo is None:
        x = x.tz_localize(tz)
    else:
        x = x.tz_convert(tz)
    return x.isoformat()

agg['earliest_anomaly_ts'] = agg['earliest_anomaly_ts_dt'].apply(dt_to_iso)
agg = agg[['cmdb_id','total_anomaly_points','num_kpis_with_anomaly','earliest_anomaly_ts','top_kpis']]

# Sort by total_anomaly_points desc and limit to top 20
agg_sorted_top = agg.sort_values('total_anomaly_points', ascending=False).head(20).reset_index(drop=True)

# Single-line summary: number of distinct cmdb_id that had at least one KPI anomaly
num_cmdb_with_anomaly = int((agg['total_anomaly_points'] > 0).sum())
summary_line = f"distinct_cmdb_id_with_anomaly: {num_cmdb_with_anomaly}"

# Display compact result and summary
agg_sorted_top, summary_line
