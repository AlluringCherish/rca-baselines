import pandas as pd
import numpy as np
import pytz

# load CSVs (files are in current working directory)
df_metric = pd.read_csv("metric.csv")
df_trace = pd.read_csv("trace.csv")

# timezone for UTC+8
tz = pytz.timezone('Asia/Shanghai')

# helper to convert epoch seconds to timezone-aware datetime
def to_tz_datetime(s):
    return pd.to_datetime(s, unit='s', utc=True).dt.tz_convert(tz)

# --- Metrics aggregation ---
# compute aggregates per (cmdb_id, kpi_name)
grp_metric = df_metric.groupby(['cmdb_id', 'kpi_name'], as_index=False)

metrics_agg = grp_metric['value'].agg(
    count='count',
    mean_value='mean',
    median_value='median',
    p95_value=lambda x: np.percentile(x, 95)
)

# compute min/max timestamps and convert to Asia/Shanghai timezone
ts_min = grp_metric['timestamp'].min().rename('min_timestamp')
ts_max = grp_metric['timestamp'].max().rename('max_timestamp')
# merge timestamps into metrics_agg
metrics_summary = metrics_agg.merge(ts_min, on=['cmdb_id', 'kpi_name']).merge(ts_max, on=['cmdb_id', 'kpi_name'])

# convert timestamps to timezone-aware datetimes
metrics_summary['min_timestamp'] = to_tz_datetime(metrics_summary['min_timestamp'])
metrics_summary['max_timestamp'] = to_tz_datetime(metrics_summary['max_timestamp'])

# rounding numeric columns for compact display
metrics_summary['mean_value'] = metrics_summary['mean_value'].round(6)
metrics_summary['median_value'] = metrics_summary['median_value'].round(6)
metrics_summary['p95_value'] = metrics_summary['p95_value'].round(6)

# reorder columns as requested and sort by count desc, limit to top 20
metrics_summary = metrics_summary[['cmdb_id', 'kpi_name', 'count', 'min_timestamp', 'max_timestamp', 'mean_value', 'median_value', 'p95_value']]
metrics_summary = metrics_summary.sort_values('count', ascending=False).head(20)

# --- Trace aggregation ---
grp_trace = df_trace.groupby(['trace_name'], as_index=False)

traces_agg = grp_trace['value'].agg(
    count='count',
    mean_value='mean',
    median_value='median',
    p95_value=lambda x: np.percentile(x, 95)
)

ts_min_t = grp_trace['timestamp'].min().rename('min_timestamp')
ts_max_t = grp_trace['timestamp'].max().rename('max_timestamp')
traces_summary = traces_agg.merge(ts_min_t, on='trace_name').merge(ts_max_t, on='trace_name')

traces_summary['min_timestamp'] = to_tz_datetime(traces_summary['min_timestamp'])
traces_summary['max_timestamp'] = to_tz_datetime(traces_summary['max_timestamp'])

traces_summary['mean_value'] = traces_summary['mean_value'].round(6)
traces_summary['median_value'] = traces_summary['median_value'].round(6)
traces_summary['p95_value'] = traces_summary['p95_value'].round(6)

traces_summary = traces_summary[['trace_name', 'count', 'min_timestamp', 'max_timestamp', 'mean_value', 'median_value', 'p95_value']]

# If many trace_name rows, limit to top 20 by count for compactness
if traces_summary.shape[0] > 20:
    traces_summary = traces_summary.sort_values('count', ascending=False).head(20)

# Display compact results (use variable names as output)
metrics_summary, traces_summary
