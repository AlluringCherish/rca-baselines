import pandas as pd
import pytz

# Explicit timezone for UTC+8 as required (not used to convert timestamps here)
tz = pytz.timezone('Asia/Shanghai')

# Load CSVs (they are in the current working directory)
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")

# Helper to build compact summary for a dataframe
def compact_summary(df, name_col):
    total_rows = int(df.shape[0])
    unique_cmdb_ids = df['cmdb_id'].dropna().unique().tolist()
    # Ensure Python-native types for JSON serialization
    unique_cmdb_ids = [str(x) for x in unique_cmdb_ids]
    min_timestamp = int(df['timestamp'].min()) if total_rows > 0 else None
    max_timestamp = int(df['timestamp'].max()) if total_rows > 0 else None
    # Frequency table limited to top 50 names
    freq_series = df[name_col].value_counts().head(50)
    top_names = [{"name": str(idx), "count": int(cnt)} for idx, cnt in freq_series.items()]
    return {
        "total_rows": total_rows,
        "unique_cmdb_ids": unique_cmdb_ids,
        "min_timestamp": min_timestamp,
        "max_timestamp": max_timestamp,
        "top_{}_counts".format(name_col): top_names
    }

metric_summary = compact_summary(metric_df, "kpi_name")
trace_summary = compact_summary(trace_df, "trace_name")

summary = {"metric.csv": metric_summary, "trace.csv": trace_summary}

# Display the compact JSON-serializable summary
summary
