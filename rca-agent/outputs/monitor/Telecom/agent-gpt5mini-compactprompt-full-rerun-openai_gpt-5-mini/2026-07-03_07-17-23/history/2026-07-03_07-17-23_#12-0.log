import pandas as pd
import numpy as np
import pytz

# Ensure timezone (UTC+8)
tz = pytz.timezone('Asia/Shanghai')

# Verify anomalies_rows exists
try:
    anomalies_rows
except NameError:
    raise RuntimeError("anomalies_rows not found in kernel. Please run previous anomaly detection step.")

# Function to extract consecutive-60s sequences for a grouped series (by cmdb_id,kpi_name)
def extract_sequences_from_group(g):
    # g expected to have columns: timestamp, value, P95, P5 (and cmdb_id,kpi_name same for group)
    g = g.sort_values('timestamp').copy()
    if g.empty:
        return pd.DataFrame(columns=[
            'cmdb_id','kpi_name','start_timestamp','end_timestamp','length_in_points',
            'max_value_in_sequence','min_value_in_sequence','threshold_P95','threshold_P5'
        ])
    # identify sequence groups where diff != 60 starts a new sequence
    g['seq_id'] = (g['timestamp'].diff() != 60).cumsum()
    agg = g.groupby('seq_id', as_index=False).agg(
        start_timestamp=('timestamp','min'),
        end_timestamp=('timestamp','max'),
        length_in_points=('timestamp','count'),
        max_value_in_sequence=('value','max'),
        min_value_in_sequence=('value','min'),
        threshold_P95=('P95','first'),
        threshold_P5=('P5','first')
    )
    # add identifiers
    agg['cmdb_id'] = g['cmdb_id'].iat[0]
    agg['kpi_name'] = g['kpi_name'].iat[0]
    # reorder
    agg = agg[[
        'cmdb_id','kpi_name','start_timestamp','end_timestamp','length_in_points',
        'max_value_in_sequence','min_value_in_sequence','threshold_P95','threshold_P5'
    ]]
    return agg

# Helper to compute max_severity for a sequence row
def compute_sequence_severity(row):
    p95 = row['threshold_P95']
    p5 = row['threshold_P5']
    mv = row['max_value_in_sequence']
    mn = row['min_value_in_sequence']
    # determine anomaly_type: high if max_value >= P95 else low
    if pd.isna(p95) and pd.isna(p5):
        return np.nan
    # If P95 exists and max >= P95, treat as high
    if not pd.isna(p95) and mv >= p95:
        if p95 > 0:
            return (mv - p95) / p95
        else:
            return (mv - p95)
    else:
        # treat as low (use P5)
        if pd.isna(p5):
            return np.nan
        if p5 > 0:
            return (p5 - mn) / p5
        else:
            return (p5 - mn)

# Process OS components
os_anoms = anomalies_rows[anomalies_rows['cmdb_id'].str.startswith('os_')].copy()
if os_anoms.empty:
    faults_os = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','start_timestamp','end_timestamp','length_in_points',
        'max_value_in_sequence','min_value_in_sequence','threshold_P95','threshold_P5','max_severity'
    ])
else:
    faults_os = (
        os_anoms
        .groupby(['cmdb_id','kpi_name'], group_keys=False)
        .apply(extract_sequences_from_group)
        .reset_index(drop=True)
    )
    faults_os['max_severity'] = faults_os.apply(compute_sequence_severity, axis=1)

# Process Docker components
docker_anoms = anomalies_rows[anomalies_rows['cmdb_id'].str.startswith('docker_')].copy()
if docker_anoms.empty:
    faults_docker = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','start_timestamp','end_timestamp','length_in_points',
        'max_value_in_sequence','min_value_in_sequence','threshold_P95','threshold_P5','max_severity'
    ])
else:
    faults_docker = (
        docker_anoms
        .groupby(['cmdb_id','kpi_name'], group_keys=False)
        .apply(extract_sequences_from_group)
        .reset_index(drop=True)
    )
    faults_docker['max_severity'] = faults_docker.apply(compute_sequence_severity, axis=1)

# Keep faults_os and faults_docker in kernel for next steps (they are variables now)

# Combine both for aggregation per component
combined_faults = pd.concat([faults_os, faults_docker], ignore_index=True, sort=False)

# If no combined faults, prepare empty summary
if combined_faults.empty:
    component_summary = pd.DataFrame(columns=[
        'cmdb_id','total_sequences','earliest_sequence_start','max_sequence_length',
        'max_severity_over_sequences','top_3_kpis_by_sequence_count'
    ])
else:
    # aggregate per cmdb_id
    # total_sequences
    seq_counts = combined_faults.groupby('cmdb_id').size().rename('total_sequences')
    # earliest_sequence_start
    earliest_start = combined_faults.groupby('cmdb_id')['start_timestamp'].min().rename('earliest_sequence_start')
    # max_sequence_length
    max_len = combined_faults.groupby('cmdb_id')['length_in_points'].max().rename('max_sequence_length')
    # max_severity_over_sequences
    max_sev = combined_faults.groupby('cmdb_id')['max_severity'].max().rename('max_severity_over_sequences')
    # top 3 kpis by sequence count per cmdb_id
    kpi_counts = combined_faults.groupby(['cmdb_id','kpi_name']).size().rename('kpi_seq_count').reset_index()
    top_kpis = (
        kpi_counts
        .sort_values(['cmdb_id','kpi_seq_count'], ascending=[True, False])
        .groupby('cmdb_id')
        .head(3)
        .groupby('cmdb_id')['kpi_name']
        .apply(list)
        .rename('top_3_kpis_by_sequence_count')
    )
    # Combine into summary DataFrame
    component_summary = pd.concat([seq_counts, earliest_start, max_len, max_sev, top_kpis], axis=1).reset_index()
    # Fill NaN lists if any component has fewer than 3 KPI entries
    component_summary['top_3_kpis_by_sequence_count'] = component_summary['top_3_kpis_by_sequence_count'].apply(
        lambda x: x if isinstance(x, list) else []
    )
    # Sort by max_severity_over_sequences descending and take top 20
    component_summary = component_summary.sort_values('max_severity_over_sequences', ascending=False).head(20).reset_index(drop=True)

# Display compact component summary (top up to 20 rows)
component_summary
