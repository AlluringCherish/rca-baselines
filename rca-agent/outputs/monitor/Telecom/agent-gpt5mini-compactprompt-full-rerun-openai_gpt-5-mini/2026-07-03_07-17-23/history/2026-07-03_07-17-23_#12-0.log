import pandas as pd
import numpy as np
import pytz

# Ensure timezone (UTC+8) as required
tz = pytz.timezone('Asia/Shanghai')

# Reuse existing kernel variables faults_db, faults_os, faults_docker if present
for var_name in ['faults_db', 'faults_os', 'faults_docker']:
    if var_name not in globals():
        # create empty DataFrame with expected columns if missing to avoid errors
        globals()[var_name] = pd.DataFrame(columns=[
            'cmdb_id','kpi_name','start_timestamp','end_timestamp','length_in_points',
            'max_value_in_sequence','min_value_in_sequence','threshold_P95','threshold_P5'
        ])

# Severity computation function (same logic as previous steps)
def compute_sequence_severity_row(row):
    p95 = row.get('threshold_P95', np.nan)
    p5 = row.get('threshold_P5', np.nan)
    mv = row.get('max_value_in_sequence', np.nan)
    mn = row.get('min_value_in_sequence', np.nan)
    # If both thresholds missing -> NaN severity
    if pd.isna(p95) and pd.isna(p5):
        return np.nan
    # High anomaly if P95 exists and max >= P95
    if not pd.isna(p95) and (not pd.isna(mv)) and mv >= p95:
        if p95 > 0:
            return (mv - p95) / p95
        else:
            return (mv - p95)
    else:
        # Low anomaly path using P5
        if pd.isna(p5) or pd.isna(mn):
            return np.nan
        if p5 > 0:
            return (p5 - mn) / p5
        else:
            return (p5 - mn)

# Ensure each faults_* table has a 'max_severity' column computed
for df_name in ['faults_db', 'faults_os', 'faults_docker']:
    df = globals()[df_name]
    if 'max_severity' not in df.columns:
        if df.empty:
            df['max_severity'] = pd.Series(dtype='float64')
        else:
            df['max_severity'] = df.apply(compute_sequence_severity_row, axis=1)
    else:
        # still ensure no missing values in max_severity for existing rows
        if not df.empty:
            missing_mask = df['max_severity'].isna()
            if missing_mask.any():
                df.loc[missing_mask, 'max_severity'] = df[missing_mask].apply(compute_sequence_severity_row, axis=1)
    globals()[df_name] = df  # write back

# Helper to produce level aggregates
def summarize_level(df, level_name):
    if df.empty:
        return {
            "number_of_components_with_sequences": 0,
            "total_sequences_count": 0,
            "earliest_sequence_start": None,
            "max_severity_over_level": None,
            "median_severity_over_level": None,
            "top_5_components": []
        }
    # per-component aggregation
    per_comp = df.groupby('cmdb_id').agg(
        total_sequences=('cmdb_id','size'),
        earliest_sequence_start=('start_timestamp','min'),
        max_sequence_length=('length_in_points','max'),
        max_severity=('max_severity','max')
    ).reset_index()
    # Level aggregates
    number_of_components = int(per_comp['cmdb_id'].nunique())
    total_sequences = int(df.shape[0])
    earliest_start = int(df['start_timestamp'].min()) if not df['start_timestamp'].isna().all() else None
    max_sev = per_comp['max_severity'].max()
    median_sev = float(per_comp['max_severity'].median()) if not per_comp['max_severity'].isna().all() else None
    # Top 5 components by max_severity desc
    top5 = per_comp.sort_values('max_severity', ascending=False).head(5)
    top5_list = []
    for _, r in top5.iterrows():
        top5_list.append({
            "cmdb_id": str(r['cmdb_id']),
            "max_severity": (float(r['max_severity']) if not pd.isna(r['max_severity']) else None),
            "earliest_sequence_start": int(r['earliest_sequence_start']) if not pd.isna(r['earliest_sequence_start']) else None,
            "max_sequence_length": int(r['max_sequence_length']) if not pd.isna(r['max_sequence_length']) else None,
            "total_sequences": int(r['total_sequences'])
        })
    return {
        "number_of_components_with_sequences": int(number_of_components),
        "total_sequences_count": int(total_sequences),
        "earliest_sequence_start": int(earliest_start) if earliest_start is not None else None,
        "max_severity_over_level": (float(max_sev) if not pd.isna(max_sev) else None),
        "median_severity_over_level": (float(median_sev) if median_sev is not None else None),
        "top_5_components": top5_list
    }

# Build level summary dict
level_summary = {
    "db": summarize_level(faults_db, "db"),
    "os": summarize_level(faults_os, "os"),
    "docker": summarize_level(faults_docker, "docker")
}

# Keep level_summary in kernel for next steps and display it compactly
level_summary
