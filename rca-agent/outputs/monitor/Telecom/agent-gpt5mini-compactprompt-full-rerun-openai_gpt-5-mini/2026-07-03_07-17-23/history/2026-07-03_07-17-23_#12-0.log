import pandas as pd
import numpy as np
import pytz

# ensure timezone variable (UTC+8) is set as required
tz = pytz.timezone('Asia/Shanghai')

# Reuse metric_df from previous step (assumed loaded in kernel)
# Define candidate cmdb_id lists
os_ids = [f"os_{i:03d}" for i in range(1, 23)]        # os_001 .. os_022
docker_ids = [f"docker_{i:03d}" for i in range(1, 9)]  # docker_001 .. docker_008
db_ids = [f"db_{i:03d}" for i in range(1, 14)]        # db_001 .. db_013

candidate_set = set(os_ids + docker_ids + db_ids)

# Filter metric_df to only candidate cmdb_ids
filtered_metric_df = metric_df[metric_df['cmdb_id'].isin(candidate_set)].copy()

# Group and aggregate using the full available series for each group
agg_table = (
    filtered_metric_df
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        count=('value', 'count'),
        min_timestamp=('timestamp', 'min'),
        max_timestamp=('timestamp', 'max'),
        mean=('value', 'mean'),
        P95=('value', lambda s: s.quantile(0.95)),
        P90=('value', lambda s: s.quantile(0.90)),
        P50=('value', lambda s: s.quantile(0.50)),
        P5 =('value', lambda s: s.quantile(0.05)),
    )
)

# Keep agg_table in kernel for next steps (variable exists now)
# Build compact JSON-serializable summary
total_pairs = int(agg_table.shape[0])

top20_df = agg_table.sort_values('count', ascending=False).head(20)

# Convert top20 rows to JSON-serializable list of dicts with required fields and native Python types
top20_list = []
for _, row in top20_df.iterrows():
    top20_list.append({
        "cmdb_id": str(row['cmdb_id']),
        "kpi_name": str(row['kpi_name']),
