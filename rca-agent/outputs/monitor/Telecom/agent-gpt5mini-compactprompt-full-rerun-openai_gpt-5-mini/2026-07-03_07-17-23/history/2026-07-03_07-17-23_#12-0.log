    anomalies_rows
except NameError:
    raise RuntimeError("anomalies_rows not found in kernel. Please run previous anomaly detection step.")

# Filter for db_ and specified KPIs
target_kpis = ['Redo_Per_Sec','Logic_Read_Per_Sec','Physical_Read_Per_Sec']
db_anoms = anomalies_rows[
    anomalies_rows['cmdb_id'].str.startswith('db_') &
    anomalies_rows['kpi_name'].isin(target_kpis)
].copy()

# If no rows, create empty faults_db
if db_anoms.empty:
    faults_db = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','start_timestamp','end_timestamp',
        'length_in_points','earliest_anomaly_timestamp',
        'max_value_in_sequence','min_value_in_sequence',
        'threshold_P95','threshold_P5'
    ])
else:
    # Helper to extract consecutive-60s sequences per group
    def group_sequences(g):
        g = g.sort_values('timestamp').copy()
        # Identify breaks where diff != 60 (or first row)
        g['gap'] = (g['timestamp'].diff() != 60).cumsum()
        agg = g.groupby('gap', as_index=False).agg(
            start_timestamp=('timestamp','min'),
            end_timestamp=('timestamp','max'),
            length_in_points=('timestamp','count'),
            max_value_in_sequence=('value','max'),
            min_value_in_sequence=('value','min'),
            threshold_P95=('P95','first'),
            threshold_P5=('P5','first')
        )
        # add group identifiers
        agg['cmdb_id'] = g['cmdb_id'].iat[0]
        agg['kpi_name'] = g['kpi_name'].iat[0]
        agg['earliest_anomaly_timestamp'] = agg['start_timestamp']
        # Reorder columns
        return agg[[
            'cmdb_id','kpi_name','start_timestamp','end_timestamp',
            'length_in_points','earliest_anomaly_timestamp',
            'max_value_in_sequence','min_value_in_sequence',
            'threshold_P95','threshold_P5'
        ]]
    
    # Apply per (cmdb_id, kpi_name)
    faults_db = (
        db_anoms
        .groupby(['cmdb_id','kpi_name'], group_keys=False)
        .apply(group_sequences)
        .reset_index(drop=True)
    )

# Keep faults_db in kernel for next steps
# Prepare top 20 sequences sorted by earliest_anomaly_timestamp ascending
top20_sequences = faults_db.sort_values('earliest_anomaly_timestamp', ascending=True).head(20)

# Display compact result (DataFrame)
top20_sequences
