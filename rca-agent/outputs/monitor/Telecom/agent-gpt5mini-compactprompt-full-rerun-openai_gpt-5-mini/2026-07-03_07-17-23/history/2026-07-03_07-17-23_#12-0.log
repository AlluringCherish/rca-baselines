import pandas as pd
import numpy as np
import pytz
from datetime import datetime

# Ensure timezone (UTC+8)
tz = pytz.timezone('Asia/Shanghai')

# Reuse metric_df and agg_table from kernel if present, otherwise load
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

try:
    agg_table
except NameError:
    # If agg_table not present, attempt to rebuild minimally (should exist per prior steps)
    # But per instructions agg_table should be present; raise to surface the issue if not.
    raise RuntimeError("agg_table not found in kernel. Please run prior aggregation step.")

# Candidate cmdb_id lists
os_ids = [f"os_{i:03d}" for i in range(1, 23)]
docker_ids = [f"docker_{i:03d}" for i in range(1, 9)]
db_ids = [f"db_{i:03d}" for i in range(1, 14)]
candidate_set = set(os_ids + docker_ids + db_ids)

# Incident window (UTC+8) May 23, 2020 01:00 to 01:30 inclusive
start_dt = tz.localize(datetime(2020, 5, 23, 1, 0, 0))
end_dt = tz.localize(datetime(2020, 5, 23, 1, 30, 0))
start_ts = int(start_dt.timestamp())
end_ts = int(end_dt.timestamp())

# Filter metric_df for candidates and time window
incident_metrics = metric_df[
    (metric_df['cmdb_id'].isin(candidate_set)) &
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts)
].copy()

# Merge thresholds (P95, P5) from agg_table (which was computed from full series) onto incident metrics
# Ensure agg_table has the expected columns
required_threshold_cols = {'cmdb_id', 'kpi_name', 'P95', 'P5'}
if not required_threshold_cols.issubset(set(agg_table.columns)):
    raise RuntimeError("agg_table is missing required threshold columns (P95, P5).")

incident_with_thresh = incident_metrics.merge(
    agg_table[['cmdb_id', 'kpi_name', 'P95', 'P5']],
    on=['cmdb_id', 'kpi_name'],
    how='left',
    validate='m:1'  # many incident rows to one agg row
)

# Mark anomalies: high if value >= P95, low if value <= P5
# If thresholds are NaN, those rows cannot be evaluated -> treat as no-anomaly (will be dropped)
incident_with_thresh['is_high'] = incident_with_thresh['value'] >= incident_with_thresh['P95']
incident_with_thresh['is_low'] = incident_with_thresh['value'] <= incident_with_thresh['P5']

anomalies_rows = incident_with_thresh[incident_with_thresh['is_high'] | incident_with_thresh['is_low']].copy()

# Aggregate anomalies by (cmdb_id, kpi_name)
if anomalies_rows.empty:
    # Prepare empty summary structure
    anomalies_agg_df = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp',
        'max_value_in_window','min_value_in_window','threshold_P95','threshold_P5',
        'anomaly_type','max_severity'
    ])
else:
    grouped = anomalies_rows.groupby(['cmdb_id', 'kpi_name'], as_index=False)
    anomalies_agg_df = grouped.agg(
        anomaly_count=('value', 'count'),
        earliest_anomaly_timestamp=('timestamp', 'min'),
        max_value_in_window=('value', 'max'),
        min_value_in_window=('value', 'min'),
        threshold_P95=('P95', 'first'),
        threshold_P5=('P5', 'first'),
    )

    # Determine anomaly_type per instructions: 'high' if max_value >= P95 else 'low'
    anomalies_agg_df['anomaly_type'] = np.where(
        anomalies_agg_df['max_value_in_window'] >= anomalies_agg_df['threshold_P95'],
        'high',
        'low'
    )

    # Compute max_severity per rules
    def compute_severity(row):
        if row['anomaly_type'] == 'high':
            P95 = row['threshold_P95']
            mv = row['max_value_in_window']
            if pd.isna(P95):
                return np.nan
            if P95 > 0:
                return (mv - P95) / P95
            else:
                return (mv - P95)
        else:  # low
            P5 = row['threshold_P5']
            mn = row['min_value_in_window']
            if pd.isna(P5):
                return np.nan
            if P5 > 0:
                return (P5 - mn) / P5
            else:
                return (P5 - mn)

    anomalies_agg_df['max_severity'] = anomalies_agg_df.apply(compute_severity, axis=1)

# Sort by severity descending and take top 20
anomalies_agg_df_sorted = anomalies_agg_df.sort_values('max_severity', ascending=False).reset_index(drop=True)
top20 = anomalies_agg_df_sorted.head(20).copy()

# Prepare compact JSON-serializable summary list
top20_json = []
for _, r in top20.iterrows():
    top20_json.append({
        "cmdb_id": str(r['cmdb_id']),
        "kpi_name": str(r['kpi_name']),
        "anomaly_count": int(r['anomaly_count']),
        "earliest_anomaly_timestamp": int(r['earliest_anomaly_timestamp']),
        "max_value_in_window": float(r['max_value_in_window']),
        "min_value_in_window": float(r['min_value_in_window']),
        "threshold_P95": (float(r['threshold_P95']) if not pd.isna(r['threshold_P95']) else None),
        "threshold_P5": (float(r['threshold_P5']) if not pd.isna(r['threshold_P5']) else None),
        "anomaly_type": str(r['anomaly_type']),
        "max_severity": (float(r['max_severity']) if not pd.isna(r['max_severity']) else None)
    })

# Compact summary output structure
summary = {
    "incident_window_start_ts": start_ts,
    "incident_window_end_ts": end_ts,
    "incident_rows": int(incident_metrics.shape[0]),
    "anomalous_pairs_count": int(anomalies_agg_df.shape[0]),
    "top20_by_severity": top20_json
}

# Keep incident_metrics, anomalies_agg_df, anomalies_rows in kernel for next steps
summary
