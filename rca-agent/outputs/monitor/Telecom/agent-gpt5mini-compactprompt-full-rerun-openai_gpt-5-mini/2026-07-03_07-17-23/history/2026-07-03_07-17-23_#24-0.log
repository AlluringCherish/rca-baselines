import pandas as pd
import numpy as np
import pytz

# Reuse existing dataframes df_metric and df_trace if present; otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')

# Ensure types
df_metric['timestamp'] = df_metric['timestamp'].astype(int)
df_trace['timestamp'] = df_trace['timestamp'].astype(int)
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')
df_trace['value'] = pd.to_numeric(df_trace['value'], errors='coerce')

tz = pytz.timezone('Asia/Shanghai')

# Helper to convert epoch seconds (UTC) to UTC+8 formatted string
def to_local_str(ts):
    return pd.to_datetime(int(ts), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

# Incident window in UTC+8 -> convert to UTC epoch seconds
start_local = tz.localize(pd.to_datetime("2020-05-26 03:00:00"))
end_local = tz.localize(pd.to_datetime("2020-05-26 03:30:00"))
start_ts = int(start_local.tz_convert(pytz.utc).timestamp())
end_ts = int(end_local.tz_convert(pytz.utc).timestamp())

# 1) Compute global P95 and P5 thresholds for metric.csv grouped by (cmdb_id, kpi_name)
thr_metric = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .agg([
        ('p95_value', lambda x: float(np.percentile(x.dropna(), 95)) if x.dropna().size>0 else np.nan),
        ('p5_value',  lambda x: float(np.percentile(x.dropna(), 5))  if x.dropna().size>0 else np.nan),
        ('global_count', 'size')
    ])
    .reset_index()
)

# 2) Filter raw metric rows to incident window (inclusive)
metric_window = df_metric[(df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] <= end_ts)].copy()

# Merge thresholds into windowed raw rows
metric_window = metric_window.merge(thr_metric, on=['cmdb_id','kpi_name'], how='left')

# Detect anomalies: value >= p95 -> 'high'; value <= p5 -> 'low'
cond_high = metric_window['value'] >= metric_window['p95_value']
cond_low  = metric_window['value'] <= metric_window['p5_value']
metric_window['anomaly_type'] = np.select([cond_high, cond_low], ['high','low'], default=np.nan)
metric_anoms = metric_window[metric_window['anomaly_type'].notna()].copy()

# Aggregate anomaly candidates
if not metric_anoms.empty:
    metric_summary = (
        metric_anoms
        .groupby(['cmdb_id','kpi_name','anomaly_type'])
        .agg(
            anomaly_count=('value','size'),
            earliest_anomaly_timestamp=('timestamp','min'),
            max_value=('value','max'),
            min_value=('value','min'),
            p95_value=('p95_value','first'),
            p5_value=('p5_value','first')
        )
        .reset_index()
    )
    # Compute severity_score with safe division
    def compute_sev(row):
        if row['anomaly_type']=='high':
            p95 = row['p95_value']
            maxv = row['max_value']
            if pd.isna(p95) or p95 == 0:
                return np.inf if maxv>0 else np.nan
