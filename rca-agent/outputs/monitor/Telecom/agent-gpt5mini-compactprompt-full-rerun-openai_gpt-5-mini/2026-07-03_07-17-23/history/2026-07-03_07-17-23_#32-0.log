import pandas as pd
import pytz

# reuse existing dfs if present, else load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')

# ensure timezone per rules
tz = pytz.timezone('Asia/Shanghai')

# ensure timestamp numeric and tz-aware datetime column 'ts'
for df, col in [(df_metric, 'kpi_name'), (df_trace, 'trace_name')]:
    if 'timestamp' in df.columns:
        df['timestamp'] = pd.to_numeric(df['timestamp'], errors='coerce')
    if 'ts' not in df.columns:
        df['ts'] = pd.to_datetime(df['timestamp'], unit='s').dt.tz_localize(tz)

# define incident window (inclusive) in UTC+8
start = tz.localize(pd.Timestamp('2020-05-27 01:30:00'))
end   = tz.localize(pd.Timestamp('2020-05-27 02:00:00'))

# helper to build report for a dataframe
def build_report(df, id_col, name_col, value_col):
    filtered = df[(df['ts'] >= start) & (df['ts'] <= end)]
    count = int(filtered.shape[0])
    overall_min = df['ts'].min()
    overall_max = df['ts'].max()
    if count > 0:
        earliest = filtered['ts'].min().isoformat()
        latest = filtered['ts'].max().isoformat()
        sample = filtered[[ 'timestamp', 'ts', id_col, name_col, value_col]].head(10)
        summary = pd.DataFrame([{
            'count': count,
            'earliest': earliest,
            'latest': latest,
            'overall_min': overall_min.isoformat(),
            'overall_max': overall_max.isoformat()
        }])
    else:
        # no matches: only return count and overall min/max per instructions
        summary = pd.DataFrame([{
            'count': count,
            'earliest': None,
            'latest': None,
            'overall_min': overall_min.isoformat() if pd.notna(overall_min) else None,
            'overall_max': overall_max.isoformat() if pd.notna(overall_max) else None
        }])
        sample = filtered[[ 'timestamp', 'ts', id_col, name_col, value_col]].head(0)
    return summary, sample

metric_summary, metric_sample = build_report(df_metric, 'cmdb_id', 'kpi_name', 'value')
trace_summary, trace_sample = build_report(df_trace, 'cmdb_id', 'trace_name', 'value')

# return compact outputs (at most 10 rows for samples)
metric_summary, metric_sample, trace_summary, trace_sample
