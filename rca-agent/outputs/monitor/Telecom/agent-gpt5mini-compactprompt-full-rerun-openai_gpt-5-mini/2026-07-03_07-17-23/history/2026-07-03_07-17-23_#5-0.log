import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse metric_df if present; otherwise load
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')

# Ensure numeric values
metric_df['value'] = pd.to_numeric(metric_df['value'], errors='coerce')

# Candidate pairs
candidates = [
    ('db_012', 'ACS'),
    ('db_006', 'Sess_Active'),
    ('os_002', 'Disk_svctm')
]

# Ensure global thresholds (p95 and p5) are computed on the entire series BEFORE filtering window.
# Use existing 'agg' if available and contains these pairs; otherwise compute thresholds for these pairs from full metric_df.
try:
    # check agg exists and has required pairs
    _ = agg
    agg_needed = agg.set_index(['cmdb_id', 'kpi_name'])
    missing = [p for p in candidates if (p[0], p[1]) not in agg_needed.index]
    if missing:
        raise NameError("agg missing some pairs")
    thresholds = agg_needed[['p95_value', 'p5_value']].copy()
except Exception:
    # compute thresholds for all (cmdb_id,kpi_name) globally
    full_agg = metric_df.groupby(['cmdb_id', 'kpi_name']).agg(
        p95_value=('value', lambda s: s.quantile(0.95)),
        p5_value=('value', lambda s: s.quantile(0.05))
    ).reset_index().set_index(['cmdb_id', 'kpi_name'])
    thresholds = full_agg[['p95_value', 'p5_value']]

# Incident window (UTC+8) -> epoch seconds UTC for filtering
start_local = pd.Timestamp('2020-04-11 05:30:00', tz=tz)
end_local = pd.Timestamp('2020-04-11 06:00:00', tz=tz)
start_ts = int(start_local.tz_convert(pytz.UTC).timestamp())
end_ts = int(end_local.tz_convert(pytz.UTC).timestamp())

summary_rows = []
pair_tables = {}

for cmdb_id, kpi_name in candidates:
    # Global thresholds
    try:
        p95 = float(thresholds.loc[(cmdb_id, kpi_name), 'p95_value'])
        p5 = float(thresholds.loc[(cmdb_id, kpi_name), 'p5_value'])
    except Exception:
        p95 = np.nan
        p5 = np.nan

    # Filter metric rows for this pair within window
    df_pair_win = metric_df[(metric_df['cmdb_id'] == cmdb_id) & (metric_df['kpi_name'] == kpi_name) &
                             (metric_df['timestamp'] >= start_ts) & (metric_df['timestamp'] < end_ts)].copy()
    # Sort by timestamp
    df_pair_win = df_pair_win.sort_values('timestamp').reset_index(drop=True)
    # ts_local column
    df_pair_win['ts_local'] = pd.to_datetime(df_pair_win['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    # compute anomaly flags relative to global thresholds
    df_pair_win['is_high'] = df_pair_win['value'] >= p95
    df_pair_win['is_low'] = df_pair_win['value'] <= p5
    # prefer 'high' if both True
    df_pair_win['anomaly_flag'] = np.where(df_pair_win['is_high'], 'high', np.where(df_pair_win['is_low'], 'low', None))

    # earliest_timestamp_in_window
    if not df_pair_win.empty:
        earliest_in_win_ts = int(df_pair_win['timestamp'].min())
        earliest_in_win_local = pd.to_datetime(earliest_in_win_ts, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z')
    else:
        earliest_in_win_ts = None
        earliest_in_win_local = None

    # earliest_anomaly_timestamp (first minute where anomaly_flag is not None)
    df_anoms = df_pair_win[df_pair_win['anomaly_flag'].notna()].copy()
    if not df_anoms.empty:
        earliest_anom_ts = int(df_anoms['timestamp'].min())
        earliest_anom_local = pd.to_datetime(earliest_anom_ts, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z')
        anomaly_type = df_anoms.loc[df_anoms['timestamp'].idxmin(), 'anomaly_flag']
        # Identify consecutive runs of anomalies (adjacent minutes with same anomaly_flag)
        # Work on df_anoms sorted
        df_anoms = df_anoms.sort_values('timestamp').reset_index(drop=True)
        df_anoms['ts_diff'] = df_anoms['timestamp'].diff().fillna(60)
        df_anoms['type_change'] = df_anoms['anomaly_flag'] != df_anoms['anomaly_flag'].shift()
        df_anoms['new_run'] = (df_anoms['ts_diff'] != 60) | df_anoms['type_change']
        df_anoms['run_id'] = df_anoms['new_run'].cumsum()
        # find the run containing the earliest anomaly
        run_of_earliest = df_anoms.loc[df_anoms['timestamp'] == earliest_anom_ts, 'run_id'].iloc[0]
        run_records = df_anoms[df_anoms['run_id'] == run_of_earliest].copy()
        run_start_ts = int(run_records['timestamp'].min())
        run_end_ts = int(run_records['timestamp'].max())
        run_start_local = pd.to_datetime(run_start_ts, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z')
        run_end_local = pd.to_datetime(run_end_ts, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z')
        run_length = int(run_records.shape[0])  # minutes
    else:
        earliest_anom_ts = None
        earliest_anom_local = None
        anomaly_type = None
        run_start_local = None
        run_end_local = None
        run_length = 0

    # max/min in window
    if not df_pair_win.empty:
        max_in_win = float(df_pair_win['value'].max())
        min_in_win = float(df_pair_win['value'].min())
    else:
        max_in_win = np.nan
        min_in_win = np.nan

    # computed_severity
    computed_severity = np.nan
    if anomaly_type == 'high':
        if pd.notna(p95) and p95 != 0:
            computed_severity = max_in_win / p95
        else:
            computed_severity = np.nan
    elif anomaly_type == 'low':
        if pd.notna(p5) and p5 != 0:
            computed_severity = p5 / min_in_win
        else:
            computed_severity = np.nan

    # Build one-line summary row
    summary_rows.append({
        'cmdb_id': cmdb_id,
        'kpi_name': kpi_name,
        'earliest_timestamp_in_window': earliest_in_win_local,
        'earliest_anomaly_timestamp': earliest_anom_local,
        'anomaly_type': anomaly_type,
        'run_start_of_first_run': run_start_local,
        'run_length_minutes_of_first_run': run_length,
        'max_value_in_window': max_in_win,
        'min_value_in_window': min_in_win,
        'global_p95': p95,
        'global_p5': p5,
        'computed_severity': computed_severity
    })

    # Prepare per-minute rows (limit to 10). Show ts_local, timestamp, cmdb_id, kpi_name, value, p95, p5, anomaly_flag
    if not df_pair_win.empty:
        per_minute = df_pair_win[['ts_local', 'timestamp', 'cmdb_id', 'kpi_name', 'value']].copy()
        per_minute['p95'] = p95
        per_minute['p5'] = p5
        per_minute['anomaly_flag'] = df_pair_win['anomaly_flag']
        # limit to 10 rows: show rows around the first anomaly if exists, else first 10
        if earliest_anom_ts is not None:
            # find index of earliest anomaly in df_pair_win
            idx = df_pair_win.index[df_pair_win['timestamp'] == earliest_anom_ts].tolist()
            if idx:
                i = idx[0]
                start_i = max(0, i - 4)  # show up to 4 before
                per_minute_view = per_minute.iloc[start_i:start_i+10].copy()
            else:
                per_minute_view = per_minute.head(10).copy()
        else:
            per_minute_view = per_minute.head(10).copy()
    else:
        per_minute_view = pd.DataFrame(columns=['ts_local', 'timestamp', 'cmdb_id', 'kpi_name', 'value', 'p95', 'p5', 'anomaly_flag'])

    pair_tables[f"{cmdb_id}||{kpi_name}"] = per_minute_view

# Construct summary DataFrame (compact)
summary_df = pd.DataFrame(summary_rows)[[
    'cmdb_id', 'kpi_name', 'earliest_timestamp_in_window', 'earliest_anomaly_timestamp',
    'anomaly_type', 'run_start_of_first_run', 'run_length_minutes_of_first_run',
    'max_value_in_window', 'min_value_in_window', 'global_p95', 'global_p5', 'computed_severity'
]]

# Keep output compact: show summary_df and the three per-minute tables (each limited to 10 rows)
db012_rows = pair_tables.get('db_012||ACS')
db006_rows = pair_tables.get('db_006||Sess_Active')
os002_rows = pair_tables.get('os_002||Disk_svctm')

summary_df, db012_rows, db006_rows, os002_rows
