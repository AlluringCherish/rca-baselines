import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse the consecutive-run results table from kernel: result_display
# If not present, try fallback to result_runs or result_runs_sorted
try:
    runs_df = result_display.copy()
except NameError:
    try:
        runs_df = result_runs_sorted.copy()
    except NameError:
        raise RuntimeError("Consecutive-run results not found in kernel variables (result_display/result_runs_sorted).")

# Ensure run_start_timestamp is parsed as timezone-aware UTC+8 datetime
runs_df['run_start_dt'] = pd.to_datetime(runs_df['run_start_timestamp']).dt.tz_convert(tz)
runs_df['run_length_minutes'] = pd.to_numeric(runs_df['run_length_minutes'], errors='coerce').astype(int)
runs_df['severity_num'] = pd.to_numeric(runs_df['severity'], errors='coerce')

# Determine component level
def level_of(cmdb):
    if str(cmdb).startswith('os_'):
        return 'node'
    if str(cmdb).startswith('docker_'):
        return 'container'
    if str(cmdb).startswith('db_'):
        return 'service'
    return 'unknown'

runs_df['level'] = runs_df['cmdb_id'].map(level_of)

# Group by cmdb_id and aggregate required fields
grp = runs_df.groupby('cmdb_id')

agg_list = []
for cmdb, g in grp:
    level = g['level'].iloc[0]
    num_faulty_kpis = g['kpi_name'].nunique()
    earliest_fault_start_dt = g['run_start_dt'].min()
    # max severity ignoring NaN
    if g['severity_num'].dropna().empty:
        max_sev = np.nan
    else:
        max_sev = float(g['severity_num'].dropna().max())
    has_nan_severity = g['severity_num'].isna().any()
    any_full_window_sustained = (g['run_length_minutes'] == 30).any()
    # representative_kpi: choose kpi with max severity; if all NaN choose kpi with longest run_length
    if g['severity_num'].dropna().empty:
        # pick kpi with max run_length
        rep_row = g.sort_values(by='run_length_minutes', ascending=False).iloc[0]
    else:
        rep_row = g.loc[g['severity_num'].idxmax()]
    representative_kpi = rep_row['kpi_name']
    agg_list.append({
        'cmdb_id': cmdb,
        'level': level,
        'num_faulty_kpis': int(num_faulty_kpis),
        'earliest_fault_start': earliest_fault_start_dt.tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z'),
        'max_severity': max_sev,
        'has_nan_severity': bool(has_nan_severity),
        'any_full_window_sustained': bool(any_full_window_sustained),
        'representative_kpi': representative_kpi
    })

candidate_df = pd.DataFrame(agg_list)

# Sort by max_severity desc (NaN treated as -inf so they go last), then num_faulty_kpis desc
candidate_df['max_severity_sort'] = candidate_df['max_severity'].fillna(-np.inf)
candidate_df = candidate_df.sort_values(by=['max_severity_sort', 'num_faulty_kpis'], ascending=[False, False]).drop(columns=['max_severity_sort'])

# Limit to top 20 and select requested columns
candidate_top20 = candidate_df[[
    'cmdb_id', 'level', 'num_faulty_kpis', 'earliest_fault_start',
    'max_severity', 'has_nan_severity', 'any_full_window_sustained', 'representative_kpi'
]].head(20)

