import pandas as pd
import pytz
import numpy as np

# reuse existing trace_df if available; otherwise load
try:
    trace_df
except NameError:
    trace_df = pd.read_csv('trace.csv')

tz = pytz.timezone('Asia/Shanghai')

# define incident window in UTC+8 and convert to epoch seconds UTC
start_local = pd.Timestamp('2020-04-11 05:30:00', tz=tz)
end_local = pd.Timestamp('2020-04-11 06:00:00', tz=tz)
start_ts = int(start_local.tz_convert(pytz.UTC).timestamp())
end_ts = int(end_local.tz_convert(pytz.UTC).timestamp())

# ensure numeric values
trace_df['value'] = pd.to_numeric(trace_df['value'], errors='coerce')

# filter to incident window
trace_window = trace_df[(trace_df['timestamp'] >= start_ts) & (trace_df['timestamp'] < end_ts)].copy()

# target trace names
target_traces = [
    'trace.self.jdbc.duration_mean',
    'trace.self.jdbc.duration_p95',
    'trace.self.jdbc.error_rate'
]

trace_filtered = trace_window[trace_window['trace_name'].isin(target_traces)].copy()

# groupby (cmdb_id, trace_name) and compute stats
trace_jdbc_summary = trace_filtered.groupby(['cmdb_id', 'trace_name']).agg(
    count=('value', 'count'),
    earliest_ts_raw=('timestamp', 'min'),
    latest_ts_raw=('timestamp', 'max'),
    mean_value=('value', 'mean'),
    p95_value=('value', lambda s: s.quantile(0.95))
).reset_index()

# convert timestamps to UTC+8 strings and tidy numeric formatting
trace_jdbc_summary['earliest_timestamp'] = pd.to_datetime(trace_jdbc_summary['earliest_ts_raw'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S%z')
trace_jdbc_summary['latest_timestamp'] = pd.to_datetime(trace_jdbc_summary['latest_ts_raw'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S%z')
trace_jdbc_summary['mean_value'] = trace_jdbc_summary['mean_value'].round(6)
trace_jdbc_summary['p95_value'] = trace_jdbc_summary['p95_value'].round(6)

# keep rows where count>0 (groupby already ensures this), sort by p95 desc and limit top 20
trace_jdbc_summary_top20 = trace_jdbc_summary[
    ['cmdb_id', 'trace_name', 'count', 'earliest_timestamp', 'latest_timestamp', 'mean_value', 'p95_value']
].sort_values(by='p95_value', ascending=False).head(20)

# display compact result
trace_jdbc_summary_top20
