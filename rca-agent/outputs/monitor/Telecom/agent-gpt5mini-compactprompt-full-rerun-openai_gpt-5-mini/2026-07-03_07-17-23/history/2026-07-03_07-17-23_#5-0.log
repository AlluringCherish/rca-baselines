import pandas as pd
import pytz
import numpy as np

# reuse trace_window if available; otherwise recreate from trace_df
tz = pytz.timezone('Asia/Shanghai')
try:
    trace_window
except NameError:
    # recreate incident window filtering
    try:
        trace_df
    except NameError:
        trace_df = pd.read_csv('trace.csv')
    trace_df['value'] = pd.to_numeric(trace_df['value'], errors='coerce')
    start_local = pd.Timestamp('2020-04-11 05:30:00', tz=tz)
    end_local = pd.Timestamp('2020-04-11 06:00:00', tz=tz)
    start_ts = int(start_local.tz_convert(pytz.UTC).timestamp())
    end_ts = int(end_local.tz_convert(pytz.UTC).timestamp())
    trace_window = trace_df[(trace_df['timestamp'] >= start_ts) & (trace_df['timestamp'] < end_ts)].copy()

# select rows where trace_name contains 'from_' (case-sensitive)
mask = trace_window['trace_name'].str.contains('from_', na=False)
trace_from = trace_window[mask].copy()

# aggregate per (cmdb_id, trace_name)
agg_from = trace_from.groupby(['cmdb_id', 'trace_name']).agg(
    count=('value', 'count'),
    earliest_ts_raw=('timestamp', 'min'),
    latest_ts_raw=('timestamp', 'max'),
    mean_value=('value', 'mean'),
    p95_value=('value', lambda s: s.quantile(0.95))
).reset_index()

# format timestamps to UTC+8 strings and round numeric columns
agg_from['earliest_timestamp'] = pd.to_datetime(agg_from['earliest_ts_raw'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S%z')
agg_from['latest_timestamp'] = pd.to_datetime(agg_from['latest_ts_raw'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S%z')
agg_from['mean_value'] = agg_from['mean_value'].round(6)
agg_from['p95_value'] = agg_from['p95_value'].round(6)

# select requested columns, sort by p95 desc, limit to top 20
trace_from_top20 = agg_from[
    ['cmdb_id', 'trace_name', 'count', 'earliest_timestamp', 'latest_timestamp', 'mean_value', 'p95_value']
].sort_values(by='p95_value', ascending=False).head(20)

# display compact result
