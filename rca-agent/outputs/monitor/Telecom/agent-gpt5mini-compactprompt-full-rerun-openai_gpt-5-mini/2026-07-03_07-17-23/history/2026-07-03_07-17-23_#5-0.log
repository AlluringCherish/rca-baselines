import pandas as pd
import numpy as np
import pytz

# reuse existing variables: metric_allowed_df (filtered to allowed components) and agg (global thresholds)
# If they don't exist (safety), recompute from metric_df
tz = pytz.timezone('Asia/Shanghai')

try:
    metric_allowed_df
    agg
except NameError:
    # recompute allowed sets and agg if missing
    allowed_nodes = [f"os_{i:03d}" for i in range(1, 23)]
    allowed_containers = [f"docker_{i:03d}" for i in range(1, 9)]
    allowed_services = [f"db_{i:03d}" for i in range(1, 14)]
    allowed_set = set(allowed_nodes + allowed_containers + allowed_services)
    metric_allowed_df = metric_df[metric_df['cmdb_id'].isin(allowed_set)].copy()
    metric_allowed_df['value'] = pd.to_numeric(metric_allowed_df['value'], errors='coerce')
    agg = metric_allowed_df.groupby(['cmdb_id', 'kpi_name']).agg(
        count=('value', 'count'),
        earliest_timestamp_raw=('timestamp', 'min'),
        latest_timestamp_raw=('timestamp', 'max'),
        p95_value=('value', lambda s: s.quantile(0.95)),
        p5_value=('value', lambda s: s.quantile(0.05))
    ).reset_index()

# Define incident window in UTC+8 and convert to epoch seconds (timestamps in files are seconds UTC)
start_local = pd.Timestamp('2020-04-11 05:30:00', tz=tz)
end_local = pd.Timestamp('2020-04-11 06:00:00', tz=tz)
start_ts = int(start_local.tz_convert(pytz.UTC).timestamp())
end_ts = int(end_local.tz_convert(pytz.UTC).timestamp())

# Filter metric rows to the incident window
metric_window_df = metric_allowed_df[(metric_allowed_df['timestamp'] >= start_ts) & (metric_allowed_df['timestamp'] < end_ts)].copy()
metric_window_df['value'] = pd.to_numeric(metric_window_df['value'], errors='coerce')

# Merge with global thresholds (agg) which were computed on full series BEFORE filtering
thresholds = agg[['cmdb_id', 'kpi_name', 'p95_value', 'p5_value']].copy()
window_with_thresh = metric_window_df.merge(thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# Determine anomaly flags per row
window_with_thresh['is_high'] = window_with_thresh['value'] >= window_with_thresh['p95_value']
window_with_thresh['is_low'] = window_with_thresh['value'] <= window_with_thresh['p5_value']
window_with_thresh['is_anomaly'] = window_with_thresh['is_high'] | window_with_thresh['is_low']

# Aggregate per (cmdb_id, kpi_name)
grouped = window_with_thresh.groupby(['cmdb_id', 'kpi_name']).agg(
    anomaly_count=('is_anomaly', 'sum'),
    earliest_anom_ts_raw=('timestamp', lambda s: s[window_with_thresh.loc[s.index, 'is_anomaly']].min() if s.any() else np.nan),
    latest_anom_ts_raw=('timestamp', lambda s: s[window_with_thresh.loc[s.index, 'is_anomaly']].max() if s.any() else np.nan),
    p95_value=('p95_value', 'first'),
    p5_value=('p5_value', 'first'),
    max_value_in_window=('value', 'max'),
    min_value_in_window=('value', 'min')
).reset_index()

# Keep only groups with at least one anomaly point
anomaly_groups = grouped[grouped['anomaly_count'] >= 1].copy()

# Determine breach_type and severity
def compute_breach_type(row):
    # handle NaNs: if p95/p5 missing, treat as no breach
    if pd.notna(row['p95_value']) and pd.notna(row['max_value_in_window']) and row['max_value_in_window'] >= row['p95_value']:
        return 'high'
    if pd.notna(row['p5_value']) and pd.notna(row['min_value_in_window']) and row['min_value_in_window'] <= row['p5_value']:
        return 'low'
    return 'none'

def compute_severity(row):
    bt = row['breach_type']
    if bt == 'high':
        if row['p95_value'] in (0, None, np.nan):
            return np.nan
        return float(row['max_value_in_window']) / float(row['p95_value'])
    if bt == 'low':
        if row['min_value_in_window'] in (0, None, np.nan):
            return np.nan
        return float(row['p5_value']) / float(row['min_value_in_window'])
    return 0.0

anomaly_groups['breach_type'] = anomaly_groups.apply(compute_breach_type, axis=1)
anomaly_groups['severity'] = anomaly_groups.apply(compute_severity, axis=1)

# Convert earliest/latest anomaly timestamps to UTC+8 strings
anomaly_groups['earliest_anomaly_timestamp'] = pd.to_datetime(anomaly_groups['earliest_anom_ts_raw'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S%z')
anomaly_groups['latest_anomaly_timestamp'] = pd.to_datetime(anomaly_groups['latest_anom_ts_raw'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S%z')

# Select and order columns as requested
anomaly_summary = anomaly_groups[[
    'cmdb_id', 'kpi_name', 'anomaly_count',
    'earliest_anomaly_timestamp', 'latest_anomaly_timestamp',
    'p95_value', 'p5_value', 'max_value_in_window', 'min_value_in_window',
    'breach_type', 'severity'
]].copy()

# Sort by anomaly_count desc then severity desc, limit to top 20
anomaly_summary = anomaly_summary.sort_values(by=['anomaly_count', 'severity'], ascending=[False, False]).head(20)

# Display compact summary table
anomaly_summary
