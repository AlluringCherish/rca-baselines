import pandas as pd
import pytz

# reuse metric_df loaded earlier in the session
tz = pytz.timezone('Asia/Shanghai')

# build allowed component lists
allowed_nodes = [f"os_{i:03d}" for i in range(1, 23)]
allowed_containers = [f"docker_{i:03d}" for i in range(1, 9)]
allowed_services = [f"db_{i:03d}" for i in range(1, 14)]
allowed_set = set(allowed_nodes + allowed_containers + allowed_services)

# restrict to allowed cmdb_ids that actually appear in metric_df
available_allowed = sorted(list(set(metric_df['cmdb_id'].unique()) & allowed_set))

# filter metric_df to only those rows
metric_allowed_df = metric_df[metric_df['cmdb_id'].isin(available_allowed)].copy()

# ensure value is numeric
metric_allowed_df['value'] = pd.to_numeric(metric_allowed_df['value'], errors='coerce')

# groupby (cmdb_id, kpi_name) and compute required global statistics
agg = metric_allowed_df.groupby(['cmdb_id', 'kpi_name']).agg(
    count=('value', 'count'),
    earliest_timestamp_raw=('timestamp', 'min'),
    latest_timestamp_raw=('timestamp', 'max'),
    p95_value=('value', lambda s: s.quantile(0.95)),
    p5_value=('value', lambda s: s.quantile(0.05))
).reset_index()

# convert raw timestamps to UTC+8 ISO strings
agg['earliest_timestamp'] = pd.to_datetime(agg['earliest_timestamp_raw'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S%z')
agg['latest_timestamp'] = pd.to_datetime(agg['latest_timestamp_raw'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S%z')

# select and order columns as requested
result_metric_summary = agg[['cmdb_id', 'kpi_name', 'count', 'earliest_timestamp', 'latest_timestamp', 'p95_value', 'p5_value']]

# sort by p95_value descending and limit to top 20 rows for compact output
result_metric_summary = result_metric_summary.sort_values(by='p95_value', ascending=False).head(20)

# display compact table (top 20)
result_metric_summary
