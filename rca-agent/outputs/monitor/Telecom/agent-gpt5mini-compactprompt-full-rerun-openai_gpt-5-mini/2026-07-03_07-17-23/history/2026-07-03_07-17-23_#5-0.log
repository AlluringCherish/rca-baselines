import pandas as pd
import numpy as np
import pytz

# Reuse variables from previous steps: window_with_thresh, anomaly_summary, metric_window_df, agg
tz = pytz.timezone('Asia/Shanghai')

# Ensure we have the windowed data with thresholds
try:
    window_with_thresh
except NameError:
    # recreate window_with_thresh if missing
    start_local = pd.Timestamp('2020-04-11 05:30:00', tz=tz)
    end_local = pd.Timestamp('2020-04-11 06:00:00', tz=tz)
    start_ts = int(start_local.tz_convert(pytz.UTC).timestamp())
    end_ts = int(end_local.tz_convert(pytz.UTC).timestamp())
    metric_allowed_df['value'] = pd.to_numeric(metric_allowed_df['value'], errors='coerce')
    metric_window_df = metric_allowed_df[(metric_allowed_df['timestamp'] >= start_ts) & (metric_allowed_df['timestamp'] < end_ts)].copy()
    thresholds = agg[['cmdb_id', 'kpi_name', 'p95_value', 'p5_value']].copy()
    window_with_thresh = metric_window_df.merge(thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# Select top 20 pairs from anomaly_summary by anomaly_count desc then severity desc
top_pairs = anomaly_summary.sort_values(by=['anomaly_count', 'severity'], ascending=[False, False]).head(20)[['cmdb_id', 'kpi_name', 'p95_value', 'p5_value']]

rows = []
for _, pair in top_pairs.iterrows():
    cmdb = pair['cmdb_id']
    kpi = pair['kpi_name']
    p95 = pair['p95_value']
    p5 = pair['p5_value']
    dfp = window_with_thresh[(window_with_thresh['cmdb_id'] == cmdb) & (window_with_thresh['kpi_name'] == kpi)].copy()
    if dfp.empty:
        continue
    dfp = dfp.sort_values('timestamp').reset_index(drop=True)
    # Determine anomaly type per row ('high' or 'low' or None). If both, prefer 'high'.
    dfp['is_high'] = dfp['value'] >= dfp['p95_value']
    dfp['is_low'] = dfp['value'] <= dfp['p5_value']
    dfp['anomaly_type'] = np.where(dfp['is_high'], 'high', np.where(dfp['is_low'], 'low', None))
    dfp_anom = dfp[dfp['anomaly_type'].notna()].copy()
    if dfp_anom.empty:
        continue
    # Identify consecutive runs: adjacent minutes (timestamp diff == 60) AND same anomaly_type
    dfp_anom['ts_diff'] = dfp_anom['timestamp'].diff().fillna(60).astype(float)
    dfp_anom['type_change'] = (dfp_anom['anomaly_type'] != dfp_anom['anomaly_type'].shift()).fillna(False)
    dfp_anom['new_run'] = (dfp_anom['ts_diff'] != 60) | dfp_anom['type_change']
    dfp_anom['run_id'] = dfp_anom['new_run'].cumsum()
    # Aggregate runs and pick the longest run (if tie, choose one with larger severity)
    runs = dfp_anom.groupby('run_id').agg(
        breach_type=('anomaly_type', 'first'),
        run_start_ts_raw=('timestamp', 'min'),
        run_end_ts_raw=('timestamp', 'max'),
        run_length_minutes=('timestamp', 'count'),
        max_value_in_run=('value', 'max'),
        min_value_in_run=('value', 'min')
    ).reset_index(drop=True)
    if runs.empty:
        continue
    # compute severity per run
    def run_severity(row):
        if row['breach_type'] == 'high':
            if p95 in (0, None, np.nan):
                return np.nan
            return float(row['max_value_in_run']) / float(p95)
        elif row['breach_type'] == 'low':
            if row['min_value_in_run'] in (0, None, np.nan):
                return np.nan
            return float(p5) / float(row['min_value_in_run'])
        return 0.0
    runs['p95_value'] = p95
    runs['p5_value'] = p5
    runs['severity'] = runs.apply(run_severity, axis=1)
    # choose the longest run; if multiple, pick highest severity
    runs = runs.sort_values(by=['run_length_minutes', 'severity'], ascending=[False, False]).reset_index(drop=True)
    best = runs.iloc[0].to_dict()
    # format timestamps to UTC+8 strings
    best_start = pd.to_datetime(int(best['run_start_ts_raw']), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z')
    best_end = pd.to_datetime(int(best['run_end_ts_raw']), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z')
    run_length = int(best['run_length_minutes'])
    severity = float(best['severity']) if pd.notna(best['severity']) else np.nan
    significant = bool(severity >= 1.5) if pd.notna(severity) else False
    note = 'full-window sustained' if run_length == 30 else ''
    rows.append({
        'cmdb_id': cmdb,
        'kpi_name': kpi,
        'breach_type': best['breach_type'],
        'run_start_timestamp': best_start,
        'run_end_timestamp': best_end,
        'run_length_minutes': run_length,
        'max_value_in_run': best['max_value_in_run'],
        'min_value_in_run': best['min_value_in_run'],
        'p95_value': p95,
        'p5_value': p5,
        'severity': severity,
        'significant_breach': significant,
        'note': note
    })

result_runs = pd.DataFrame(rows)

# Sort results by significant_breach desc, severity desc, run_length desc and limit to top 20
result_runs_sorted = result_runs.sort_values(by=['significant_breach', 'severity', 'run_length_minutes'], ascending=[False, False, False]).head(20)

# Keep output compact: select requested columns
result_display = result_runs_sorted[[
    'cmdb_id', 'kpi_name', 'breach_type', 'run_start_timestamp', 'run_end_timestamp',
    'run_length_minutes', 'max_value_in_run', 'min_value_in_run',
    'p95_value', 'p5_value', 'severity', 'significant_breach', 'note'
]]

# Display the compact table
result_display
