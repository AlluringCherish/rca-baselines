import pandas as pd
import numpy as np
import pytz
import re

# Reuse trace_df/global_thresh_trace if available; otherwise load/compute
try:
    trace_df
except NameError:
    trace_df = pd.read_csv("trace.csv")

# Ensure correct types and timezone (Asia/Shanghai UTC+8)
trace_df['value'] = pd.to_numeric(trace_df['value'], errors='coerce')
trace_df['ts_dt'] = pd.to_datetime(trace_df['timestamp'], unit='s', utc=True).dt.tz_convert(pytz.timezone('Asia/Shanghai'))

# Compute global thresholds per group if not already available
if 'global_thresh_trace' in globals():
    global_thresh = global_thresh_trace.copy()
else:
    global_thresh = trace_df.groupby(['cmdb_id','trace_name'])['value'].agg(
        global_p95=lambda x: x.quantile(0.95),
        global_p5 =lambda x: x.quantile(0.05)
    ).reset_index()

# Select rows related to docker_007 (by cmdb_id or trace_name containing to_/from_)
pattern_to = r'\bto_docker_007\b'
pattern_from = r'\bfrom_docker_007\b'
mask_related = (
    (trace_df['cmdb_id'] == 'docker_007') |
    trace_df['trace_name'].str.contains(pattern_to, regex=True) |
    trace_df['trace_name'].str.contains(pattern_from, regex=True)
)
df_related = trace_df[mask_related].copy()

# Determine distinct groups to analyze
groups = df_related[['cmdb_id','trace_name']].drop_duplicates().reset_index(drop=True)

# Incident window
tz = pytz.timezone('Asia/Shanghai')
start = pd.Timestamp('2020-05-26 02:00:00', tz=tz)
end   = pd.Timestamp('2020-05-26 02:30:00', tz=tz)

rows = []

for _, row in groups.iterrows():
    cmdb_id = row['cmdb_id']
    trace_name = row['trace_name']
    # lookup global p95 (from full series)
    th = global_thresh[
        (global_thresh['cmdb_id'] == cmdb_id) &
        (global_thresh['trace_name'] == trace_name)
    ]
    if th.empty:
        global_p95 = np.nan
    else:
        global_p95 = float(th['global_p95'].iloc[0])

    # filter group rows to incident window
    g = trace_df[
        (trace_df['cmdb_id'] == cmdb_id) &
        (trace_df['trace_name'] == trace_name) &
        (trace_df['ts_dt'] >= start) & (trace_df['ts_dt'] <= end)
    ].copy().sort_values('ts_dt')

    count_window = int(len(g))
    if g.empty or np.isnan(global_p95):
        count_high = 0
        earliest_high = None
        high_ts_list = []
        max_in_win = None
        longest_len = 0
        longest_start = None
    else:
        g['is_high'] = g['value'] >= global_p95
        count_high = int(g['is_high'].sum())
        max_in_win = float(g['value'].max()) if not g['value'].isna().all() else None

        if count_high > 0:
            highs = g.loc[g['is_high'], 'ts_dt'].sort_values()
            # earliest high
            earliest_high = highs.iloc[0].strftime('%Y-%m-%d %H:%M:%S%z')
            # list of high timestamps (limit 10)
            high_ts_list = highs.dt.strftime('%Y-%m-%d %H:%M:%S%z').tolist()[:10]
            # compute longest consecutive-high segment (by minute)
            # convert to seconds since epoch
            secs = highs.astype('datetime64[ns]').astype('int64') // 10**9
            if len(secs) == 0:
                longest_len = 0
                longest_start = None
            else:
                max_len = 1
                cur_len = 1
                max_start_idx = 0
                cur_start_idx = 0
                for i in range(1, len(secs)):
                    if secs[i] - secs[i-1] == 60:
                        cur_len += 1
                    else:
                        if cur_len > max_len:
                            max_len = cur_len
                            max_start_idx = cur_start_idx
                        cur_len = 1
                        cur_start_idx = i
                # final check
                if cur_len > max_len:
                    max_len = cur_len
                    max_start_idx = cur_start_idx
                longest_len = int(max_len)
                longest_start = highs.iloc[max_start_idx].strftime('%Y-%m-%d %H:%M:%S%z')
        else:
            earliest_high = None
            high_ts_list = []
            longest_len = 0
            longest_start = None

    # parse peer: to_X or from_X or self
    m_to = re.search(r'\bto_([A-Za-z0-9_]+)\b', trace_name)
    m_from = re.search(r'\bfrom_([A-Za-z0-9_]+)\b', trace_name)
    if m_to:
        peer = m_to.group(1)
    elif m_from:
        peer = m_from.group(1)
    else:
        peer = 'self'

    rows.append({
        'cmdb_id': cmdb_id,
        'trace_name': trace_name,
        'peer': peer,
        'count_window': count_window,
        'count_high': count_high,
        'earliest_high_timestamp': earliest_high,
        'longest_segment_len_minutes': longest_len,
        'longest_segment_start': longest_start,
        'high_timestamps_list': high_ts_list,
        'max_value_in_window': max_in_win,
        'global_p95': global_p95
    })

# Build DataFrame and keep up to 20 rows
docker_007_trace_summary = pd.DataFrame(rows).head(20)

# Prepare message if no groups have highs
if docker_007_trace_summary['count_high'].sum() == 0:
    message = 'no highs for docker_007 in window'
else:
    message = ''

# Return compact aggregates
docker_007_trace_summary, message
