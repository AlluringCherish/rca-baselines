import pandas as pd
import numpy as np
import pytz
from datetime import datetime

# reuse existing variables: traces, grouped_traces_full, tz
try:
    traces
except NameError:
    traces = pd.read_csv('trace.csv')

try:
    grouped_traces_full
except NameError:
    raise RuntimeError("grouped_traces_full not found in kernel. Run previous grouping step first.")

tz = pytz.timezone('Asia/Shanghai')

# ensure numeric
traces['value'] = pd.to_numeric(traces['value'], errors='coerce')

# add tz-aware timestamp_utc8
traces['timestamp_utc8'] = pd.to_datetime(traces['timestamp'], unit='s').dt.tz_localize('UTC').dt.tz_convert(tz)

# incident window (inclusive)
start_dt = tz.localize(datetime(2020, 5, 24, 4, 0, 0))
end_dt = tz.localize(datetime(2020, 5, 24, 4, 30, 0))

# filter traces to time window
trace_marked = traces[(traces['timestamp_utc8'] >= start_dt) & (traces['timestamp_utc8'] <= end_dt)].copy()

# merge p95/p5 thresholds from grouped_traces_full
trace_marked = trace_marked.merge(
    grouped_traces_full[['cmdb_id', 'trace_name', 'p95', 'p5']],
    on=['cmdb_id', 'trace_name'],
    how='left'
)

# helper: detect type
trace_marked['is_duration_or_error'] = trace_marked['trace_name'].str.contains('duration') | trace_marked['trace_name'].str.contains('error_rate')
trace_marked['is_row_count'] = trace_marked['trace_name'].str.contains('row_count')

# mark anomalies according to rule
# duration/error_rate: anomaly if value >= p95
# row_count: anomaly if value <= p5
trace_marked['anomaly'] = False
# duration/error_rate
mask_de = trace_marked['is_duration_or_error'] & trace_marked['p95'].notna()
trace_marked.loc[mask_de, 'anomaly'] = trace_marked.loc[mask_de, 'value'] >= trace_marked.loc[mask_de, 'p95']
# row_count
mask_rc = trace_marked['is_row_count'] & trace_marked['p5'].notna()
trace_marked.loc[mask_rc, 'anomaly'] = trace_marked.loc[mask_rc, 'value'] <= trace_marked.loc[mask_rc, 'p5']

# compute severity ratio per row such that larger => more severe
def compute_ratio(row):
    v = row['value']
    p95 = row['p95']
    p5 = row['p5']
    if row['is_duration_or_error']:
        # ratio = value / p95 (larger is worse)
        if pd.isna(p95) or p95 == 0:
            # if p95==0: if value>0 -> severe (set inf), else set 1.0
            return np.inf if (not pd.isna(v) and v > 0) else 1.0
        return v / p95 if not pd.isna(v) else np.nan
    if row['is_row_count']:
        # ratio = p5 / value (smaller value -> larger ratio), handle zeros
        if pd.isna(p5) or p5 == 0:
            return np.inf if (not pd.isna(v) and v < p5 if not pd.isna(p5) else v == 0) else 1.0
        # avoid division by zero
        if v == 0:
            return np.inf
        return p5 / v
    return np.nan

trace_marked['severity_ratio'] = trace_marked.apply(compute_ratio, axis=1)

# keep full marked series in memory as 'trace_marked'

# isolate anomalous rows
trace_anomalous = trace_marked[trace_marked['anomaly']].copy()

# function to compute longest consecutive streak in minutes (assumes per-minute sampling)
def longest_consecutive_streak_minutes(tseries):
    if tseries.empty:
        return 0
    diffs = tseries.sort_values().diff().dt.total_seconds().fillna(9999)
    streak_id = (diffs != 60).cumsum()
    streak_lengths = streak_id.groupby(streak_id).size()
    return int(streak_lengths.max())

# aggregate anomalies by (cmdb_id, trace_name)
groups = []
if not trace_anomalous.empty:
    gb = trace_anomalous.groupby(['cmdb_id', 'trace_name'])
    for (cmdb_id, trace_name), grp in gb:
        grp_sorted = grp.sort_values('timestamp_utc8')
        anomaly_count = int(grp_sorted.shape[0])
        earliest_ts = grp_sorted['timestamp_utc8'].min()
        longest_streak = longest_consecutive_streak_minutes(grp_sorted['timestamp_utc8'])
        # max_deviation_ratio: take max of severity_ratio (we computed to have larger => more severe)
        max_dev = float(np.nanmax(grp_sorted['severity_ratio'].replace([np.inf], np.inf)))
        p95 = float(grp_sorted['p95'].iloc[0]) if pd.notna(grp_sorted['p95'].iloc[0]) else None
        p5 = float(grp_sorted['p5'].iloc[0]) if pd.notna(grp_sorted['p5'].iloc[0]) else None
        groups.append({
            'cmdb_id': cmdb_id,
            'trace_name': trace_name,
            'anomaly_count': anomaly_count,
            'earliest_anomaly_timestamp_UTC+8': earliest_ts,
            'longest_consecutive_anomaly_streak': int(longest_streak),
            'max_deviation_ratio': max_dev,
            'p95': p95,
            'p5': p5
        })

trace_aggregated = pd.DataFrame(groups)

# sort as requested and return top 20
trace_aggregated_sorted = trace_aggregated.sort_values(
    by=['longest_consecutive_anomaly_streak', 'anomaly_count'],
    ascending=[False, False]
).reset_index(drop=True)

trace_anomaly_top20 = trace_aggregated_sorted.head(20).copy()

# keep full marked series in memory: trace_marked, trace_anomalous, trace_aggregated_sorted
trace_anomaly_top20
