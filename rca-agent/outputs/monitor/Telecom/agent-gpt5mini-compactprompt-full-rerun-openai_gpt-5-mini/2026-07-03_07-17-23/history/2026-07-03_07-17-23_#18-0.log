import pandas as pd
import numpy as np
import pytz
from datetime import datetime

tz = pytz.timezone('Asia/Shanghai')

# Reuse kernel variable 'anomalous' which holds incident-window anomalous metric points
try:
    anomalous
except NameError:
    raise RuntimeError("Kernel variable 'anomalous' not found. Run metric anomaly detection earlier.")

# Ensure timestamp_utc8 exists and is tz-aware
if 'timestamp_utc8' not in anomalous.columns:
    anomalous['timestamp_utc8'] = pd.to_datetime(anomalous['timestamp'], unit='s')\
        .dt.tz_localize('UTC').dt.tz_convert(tz)

# Helper: longest consecutive streak in minutes (assumes per-minute sampling)
def longest_consecutive_streak_minutes(tseries):
    if tseries.empty:
        return 0
    diffs = tseries.sort_values().diff().dt.total_seconds().fillna(9999)
    streak_id = (diffs != 60).cumsum()
    streak_lengths = streak_id.groupby(streak_id).size()
    return int(streak_lengths.max())

# Group anomalous points by (cmdb_id, kpi_name) and compute requested aggregates + severity ratio
groups = []
gb = anomalous.groupby(['cmdb_id', 'kpi_name'])
for (cmdb_id, kpi_name), grp in gb:
    grp_sorted = grp.sort_values('timestamp_utc8')
    anomaly_count = int(grp_sorted.shape[0])
    earliest_ts = grp_sorted['timestamp_utc8'].min()
    longest_streak = longest_consecutive_streak_minutes(grp_sorted['timestamp_utc8'])
    max_value = float(grp_sorted['value'].max())
    # thresholds (global) should be present in grp
    p95 = grp_sorted['p95'].iloc[0] if 'p95' in grp_sorted.columns else np.nan
    p5  = grp_sorted['p5'].iloc[0]  if 'p5'  in grp_sorted.columns else np.nan

    # If either p95==0 or p5==0 or NaN => per instruction set ratio NaN and exclude later
    if pd.isna(p95) or pd.isna(p5) or p95 == 0 or p5 == 0:
        severity_ratio = np.nan
    else:
        # high-sided anomalies among the group's anomalous rows: value >= p95
        high_rows = grp_sorted[grp_sorted['value'] >= p95]
        ratio_high = np.nan
        if not high_rows.empty:
            # avoid division by zero (we checked p95!=0)
            ratio_high = (high_rows['value'] / p95).max()

        # low-sided anomalies: value <= p5
        low_rows = grp_sorted[grp_sorted['value'] <= p5]
        ratio_low = np.nan
        if not low_rows.empty:
            # compute p5/value and take max (larger means more severe low-side drop)
            # avoid division by zero (we checked p5!=0)
            ratio_low = (p5 / low_rows['value'].replace(0, np.nan)).max()

        # choose the larger severity measure (NaNs handled)
        severity_ratio = np.nanmax([ratio_high, ratio_low])

    groups.append({
        'cmdb_id': cmdb_id,
        'kpi_name': kpi_name,
        'anomaly_count': anomaly_count,
        'earliest_anomaly_timestamp_UTC+8': earliest_ts,
        'longest_consecutive_anomaly_streak': int(longest_streak),
        'max_value_observed_in_anomaly': max_value,
        'severity_ratio': float(severity_ratio) if not pd.isna(severity_ratio) else np.nan,
        'p95': float(p95) if not pd.isna(p95) else np.nan,
        'p5': float(p5) if not pd.isna(p5) else np.nan
    })

severity_df = pd.DataFrame(groups)

# Exclude groups with NaN severity_ratio per instruction (p95==0 or p5==0 were set to NaN)
severity_ranked = severity_df.dropna(subset=['severity_ratio']).sort_values(
    by='severity_ratio', ascending=False
).reset_index(drop=True)

# Keep full results in kernel memory as 'severity_df' and 'severity_ranked'
# Return top 10 rows as requested with selected columns
severity_top10 = severity_ranked[
    ['cmdb_id', 'kpi_name', 'anomaly_count', 'earliest_anomaly_timestamp_UTC+8',
     'longest_consecutive_anomaly_streak', 'max_value_observed_in_anomaly',
     'severity_ratio', 'p95', 'p5']
].head(10).copy()

