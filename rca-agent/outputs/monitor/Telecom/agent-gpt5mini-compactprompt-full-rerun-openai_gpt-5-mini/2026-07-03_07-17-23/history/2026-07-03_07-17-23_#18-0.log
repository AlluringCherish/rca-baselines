import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse kernel 'anomalous' which contains incident-window anomalous metric points
try:
    anomalous
except NameError:
    raise RuntimeError("Kernel variable 'anomalous' not found. Please run the metric anomaly detection step first.")

# Ensure timestamp_utc8 exists and is tz-aware
if 'timestamp_utc8' not in anomalous.columns:
    anomalous['timestamp_utc8'] = pd.to_datetime(anomalous['timestamp'], unit='s')\
        .dt.tz_localize('UTC').dt.tz_convert(tz)

# Filter anomalous points to db_013 and keep full series in memory for follow-up
db13_series = anomalous[anomalous['cmdb_id'] == 'db_013'].copy()

# If no anomalies for db_013, return empty DataFrame with requested columns
out_cols = [
    'cmdb_id', 'kpi_name', 'anomaly_count', 'earliest_anomaly_timestamp_UTC+8',
    'value_at_earliest', 'longest_consecutive_anomaly_streak',
    'max_value_observed_in_anomaly', 'severity_ratio', 'p95', 'p5'
]

if db13_series.empty:
    db13_agg = pd.DataFrame(columns=out_cols)
else:
    # Helper: longest consecutive streak (minutes) assuming per-minute sampling
    def longest_consecutive_streak_minutes(tseries):
        if tseries.empty:
            return 0
        diffs = tseries.sort_values().diff().dt.total_seconds().fillna(9999)
        streak_id = (diffs != 60).cumsum()
        streak_lengths = streak_id.groupby(streak_id).size()
        return int(streak_lengths.max())

    groups = []
    gb = db13_series.groupby('kpi_name')
    for kpi_name, grp in gb:
        grp_sorted = grp.sort_values('timestamp_utc8')
        anomaly_count = int(grp_sorted.shape[0])
        earliest_ts = grp_sorted['timestamp_utc8'].min()
        # value at earliest anomalous timestamp (if multiple at same ts, take first)
        earliest_row = grp_sorted.loc[grp_sorted['timestamp_utc8'] == earliest_ts].iloc[0]
        value_at_earliest = float(earliest_row['value'])
        longest_streak = longest_consecutive_streak_minutes(grp_sorted['timestamp_utc8'])
        max_value = float(grp_sorted['value'].max())
        # thresholds (should be present)
        p95 = grp_sorted['p95'].iloc[0] if 'p95' in grp_sorted.columns else np.nan
        p5  = grp_sorted['p5'].iloc[0]  if 'p5' in grp_sorted.columns  else np.nan

        # compute severity_ratio per rules:
        # - if p95==0 or p5==0 => severity_ratio = NaN
        if pd.isna(p95) or pd.isna(p5) or p95 == 0 or p5 == 0:
            severity_ratio = np.nan
        else:
            # high-sided anomalies among this group's anomalous rows: value >= p95
            high_rows = grp_sorted[grp_sorted['value'] >= p95]
            ratio_high = np.nan
            if not high_rows.empty:
                ratio_high = (high_rows['value'] / p95).max()

            # low-sided anomalies: value <= p5
            low_rows = grp_sorted[grp_sorted['value'] <= p5]
            ratio_low = np.nan
            if not low_rows.empty:
                min_val = low_rows['value'].min()
                # avoid division by zero; if min_val == 0 then ratio -> inf
                ratio_low = (p5 / min_val) if min_val != 0 else np.inf

            severity_ratio = np.nanmax([ratio_high, ratio_low])

        groups.append({
            'cmdb_id': 'db_013',
            'kpi_name': kpi_name,
            'anomaly_count': anomaly_count,
            'earliest_anomaly_timestamp_UTC+8': earliest_ts,
            'value_at_earliest': value_at_earliest,
            'longest_consecutive_anomaly_streak': int(longest_streak),
            'max_value_observed_in_anomaly': max_value,
            'severity_ratio': float(severity_ratio) if not pd.isna(severity_ratio) else np.nan,
            'p95': float(p95) if not pd.isna(p95) else np.nan,
            'p5': float(p5) if not pd.isna(p5) else np.nan
        })

    db13_agg = pd.DataFrame(groups)
    # limit to at most 20 rows as requested
    db13_agg = db13_agg.sort_values(
        by=['severity_ratio', 'longest_consecutive_anomaly_streak', 'anomaly_count'],
        ascending=[False, False, False]
    ).reset_index(drop=True).head(20)

# Keep full db_013 filtered series in kernel memory as 'db13_series'
# Return only the compact aggregate table for display
db13_agg
