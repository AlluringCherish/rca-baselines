import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# reuse existing 'traces' if present; otherwise load from CSV
try:
    traces
except NameError:
    traces = pd.read_csv('trace.csv')

# ensure value is numeric
traces['value'] = pd.to_numeric(traces['value'], errors='coerce')

# group by cmdb_id and trace_name using the full available series
grouped_traces = traces.groupby(['cmdb_id', 'trace_name'], as_index=False)

grouped_traces_full = grouped_traces.agg(
    count=('value', 'count'),
    min_ts=('timestamp', 'min'),
    max_ts=('timestamp', 'max'),
    p95=('value', lambda x: x.quantile(0.95)),
    p50=('value', lambda x: x.quantile(0.50)),
    p5 =('value', lambda x: x.quantile(0.05))
)

# convert min/max timestamps to timezone-aware UTC+8 datetimes
grouped_traces_full['min_timestamp_UTC+8'] = pd.to_datetime(grouped_traces_full['min_ts'], unit='s')\
    .dt.tz_localize('UTC').dt.tz_convert(tz)
grouped_traces_full['max_timestamp_UTC+8'] = pd.to_datetime(grouped_traces_full['max_ts'], unit='s')\
    .dt.tz_localize('UTC').dt.tz_convert(tz)

# select and order required columns
grouped_traces_full = grouped_traces_full[
    ['cmdb_id', 'trace_name', 'count', 'min_timestamp_UTC+8', 'max_timestamp_UTC+8', 'p95', 'p50', 'p5']
].copy()

# round percentiles for compactness
grouped_traces_full[['p95', 'p50', 'p5']] = grouped_traces_full[['p95', 'p50', 'p5']].round(6)

# keep full grouped results in kernel memory as 'grouped_traces_full'
# return only top 20 groups sorted by count
grouped_traces_top20 = grouped_traces_full.sort_values('count', ascending=False).head(20)

grouped_traces_top20
