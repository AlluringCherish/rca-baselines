import pandas as pd
import pytz
from datetime import datetime

tz = pytz.timezone('Asia/Shanghai')

# Reuse kernel variables from earlier steps:
# - filtered_series : full metrics filtered to candidate cmdb_ids and incident window, with p95/p5 and 'anomaly' flag
# - grouped_metrics_full : global per-(cmdb_id,kpi_name) thresholds (p95, p5) computed earlier

try:
    filtered_series
except NameError:
    raise RuntimeError("filtered_series not found in kernel memory. Run the metric anomaly detection step first.")

# Ensure timestamp_utc8 exists (it was created earlier); if not, create it
if 'timestamp_utc8' not in filtered_series.columns:
    filtered_series['timestamp_utc8'] = pd.to_datetime(filtered_series['timestamp'], unit='s')\
        .dt.tz_localize('UTC').dt.tz_convert(tz)

# Define keywords (case-insensitive) to match in kpi_name
keywords = [
    'network', 'Outgoing', 'Incoming', 'Send', 'Recv', 'Sent_error', 'Sent_errors',
    'tnsping', 'Sess_', 'Login', 'Conn', 'Connection', 'Row_Lock'
]
# build regex OR pattern, escape underscores for literal match where needed
import re
pattern = '|'.join([re.escape(k) for k in keywords])

# Subset filtered_series to kpi_name matches and within the incident window (defensive re-check)
start_dt = tz.localize(datetime(2020, 5, 24, 4, 0, 0))
end_dt = tz.localize(datetime(2020, 5, 24, 4, 30, 0))

metric_subset = filtered_series[
    filtered_series['kpi_name'].str.contains(pattern, case=False, na=False) &
    (filtered_series['timestamp_utc8'] >= start_dt) &
    (filtered_series['timestamp_utc8'] <= end_dt)
].copy()

# Keep this subset in memory per requirement (variable: metric_subset)

# Focus on anomalous rows within this subset
metric_anomalous_subset = metric_subset[metric_subset['anomaly']].copy()

# Helper to compute longest consecutive streak in minutes (assumes per-minute timestamps)
def longest_consecutive_streak_minutes(tseries):
    if tseries.empty:
        return 0
    diffs = tseries.sort_values().diff().dt.total_seconds().fillna(9999)
    streak_id = (diffs != 60).cumsum()
    streak_lengths = streak_id.groupby(streak_id).size()
    return int(streak_lengths.max())

# Aggregate by (cmdb_id, kpi_name)
groups = []
if not metric_anomalous_subset.empty:
    gb = metric_anomalous_subset.groupby(['cmdb_id', 'kpi_name'])
    for (cmdb_id, kpi_name), grp in gb:
        grp_sorted = grp.sort_values('timestamp_utc8')
        anomaly_count = int(grp_sorted.shape[0])
        earliest_ts = grp_sorted['timestamp_utc8'].min()
        longest_streak = longest_consecutive_streak_minutes(grp_sorted['timestamp_utc8'])
        max_anom_value = float(grp_sorted['value'].max())
        # p95/p5 should be present from grouped_metrics_full merge earlier; take first non-null
        p95 = grp_sorted['p95'].dropna().iloc[0] if grp_sorted['p95'].notna().any() else None
        p5  = grp_sorted['p5'].dropna().iloc[0]  if grp_sorted['p5'].notna().any()  else None
        groups.append({
            'cmdb_id': cmdb_id,
            'kpi_name': kpi_name,
            'anomaly_count': anomaly_count,
            'earliest_anomaly_timestamp_UTC+8': earliest_ts,
            'longest_consecutive_anomaly_streak': int(longest_streak),
            'max_anomalous_value': max_anom_value,
            'p95': p95,
            'p5': p5
        })

metric_keyword_aggregates = pd.DataFrame(groups)

# Sort and return top 20 as requested
metric_keyword_top20 = metric_keyword_aggregates.sort_values(
    by=['longest_consecutive_anomaly_streak', 'anomaly_count'],
    ascending=[False, False]
).reset_index(drop=True).head(20)

# Keep full filtered subset and anomalous subset in memory: metric_subset, metric_anomalous_subset
metric_subset.shape, metric_anomalous_subset.shape, metric_keyword_top20
