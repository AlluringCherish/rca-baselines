import pandas as pd
import pytz
from datetime import datetime, timedelta

tz = pytz.timezone('Asia/Shanghai')

# reuse existing metrics and grouped_metrics_full if present
try:
    metrics
except NameError:
    metrics = pd.read_csv('metric.csv')

# ensure grouped_metrics_full exists
try:
    grouped_metrics_full
except NameError:
    raise RuntimeError("grouped_metrics_full not found in kernel memory. Run previous grouping step first.")

# candidate cmdb ids
os_ids = [f"os_{i:03d}" for i in range(1, 23)]
docker_ids = [f"docker_{i:03d}" for i in range(1, 9)]
db_ids = [f"db_{i:03d}" for i in range(1, 14)]
candidates = set(os_ids + docker_ids + db_ids)

# ensure value numeric
metrics['value'] = pd.to_numeric(metrics['value'], errors='coerce')

# convert timestamps to tz-aware UTC+8 datetimes (from epoch UTC)
metrics_ts = pd.to_datetime(metrics['timestamp'], unit='s').dt.tz_localize('UTC').dt.tz_convert(tz)
metrics = metrics.assign(timestamp_utc8=metrics_ts)

# define incident window in UTC+8
start_dt = tz.localize(datetime(2020, 5, 24, 4, 0, 0))
end_dt = tz.localize(datetime(2020, 5, 24, 4, 30, 0))

# filter to candidate cmdb_ids and the time window (inclusive)
filtered_series = metrics[
    (metrics['cmdb_id'].isin(candidates)) &
    (metrics['timestamp_utc8'] >= start_dt) &
    (metrics['timestamp_utc8'] <= end_dt)
].copy()

# merge group's global p95 and p5 from grouped_metrics_full
# grouped_metrics_full has columns: cmdb_id, kpi_name, ..., p95, p5
merge_cols = ['cmdb_id', 'kpi_name']
filtered_series = filtered_series.merge(
    grouped_metrics_full[merge_cols + ['p95', 'p5']],
    on=merge_cols,
    how='left',
    suffixes=('', '_group')
)

# mark anomalies: value >= p95 OR value <= p5
filtered_series['anomaly'] = (
    (filtered_series['value'] >= filtered_series['p95']) |
    (filtered_series['value'] <= filtered_series['p5'])
)

# keep full filtered series in memory as variable 'filtered_series' (per requirement)

# aggregate anomalies by (cmdb_id, kpi_name)
# consider only groups that have at least one anomaly
anomalous = filtered_series[filtered_series['anomaly']].copy()

def longest_consecutive_streak_minutes(tseries):
    # tseries: sorted tz-aware datetime Series
    if tseries.empty:
        return 0
    diffs = tseries.diff().dt.total_seconds().fillna(9999)
    # new streak when diff != 60 seconds
    streak_id = (diffs != 60).cumsum()
    streak_lengths = streak_id.groupby(streak_id).size()
    return int(streak_lengths.max())

if anomalous.shape[0] == 0:
    # no anomalies found in window
    aggregated = pd.DataFrame(columns=[
        'cmdb_id', 'kpi_name', 'anomaly_count', 'earliest_anomaly_timestamp_UTC+8',
        'longest_consecutive_anomaly_streak', 'max_anomalous_value', 'p95', 'p5'
    ])
else:
    groups = []
    gb = anomalous.groupby(['cmdb_id', 'kpi_name'])
    for (cmdb_id, kpi_name), grp in gb:
        grp_sorted = grp.sort_values('timestamp_utc8')
        anomaly_count = grp_sorted.shape[0]
        earliest_ts = grp_sorted['timestamp_utc8'].min()
        longest_streak = longest_consecutive_streak_minutes(grp_sorted['timestamp_utc8'])
        max_anom_value = grp_sorted['value'].max()
        # p95 and p5 are identical for the group after merge; take first
        p95 = grp_sorted['p95'].iloc[0]
        p5 = grp_sorted['p5'].iloc[0]
        groups.append({
            'cmdb_id': cmdb_id,
            'kpi_name': kpi_name,
            'anomaly_count': int(anomaly_count),
            'earliest_anomaly_timestamp_UTC+8': earliest_ts,
            'longest_consecutive_anomaly_streak': int(longest_streak),
            'max_anomalous_value': float(max_anom_value),
            'p95': float(p95) if pd.notna(p95) else None,
            'p5': float(p5) if pd.notna(p5) else None
        })
    aggregated = pd.DataFrame(groups)

# sort by longest_consecutive_anomaly_streak desc, then anomaly_count desc
aggregated_sorted = aggregated.sort_values(
    by=['longest_consecutive_anomaly_streak', 'anomaly_count'],
    ascending=[False, False]
).reset_index(drop=True)

# format earliest timestamp column compactly (keep tz-aware)
# Limit to top 20 rows
anomaly_top20 = aggregated_sorted.head(20).copy()

# keep full results in kernel memory: filtered_series, anomalous, aggregated_sorted
filtered_series, anomalous, aggregated_sorted, anomaly_top20
