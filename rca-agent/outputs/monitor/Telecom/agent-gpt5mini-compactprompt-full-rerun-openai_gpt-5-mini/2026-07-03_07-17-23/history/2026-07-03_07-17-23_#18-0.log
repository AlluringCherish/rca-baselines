import pandas as pd
import pytz

# timezone for UTC+8
tz = pytz.timezone('Asia/Shanghai')

# Load CSV files (they are in the current working directory)
metrics = pd.read_csv('metric.csv')
traces = pd.read_csv('trace.csv')

# --- Metrics summary ---
metric_count = metrics.shape[0]

# convert epoch seconds to timezone-aware datetimes (assume epoch is UTC)
metrics_ts = pd.to_datetime(metrics['timestamp'], unit='s').dt.tz_localize('UTC').dt.tz_convert(tz)
metric_min_ts = metrics_ts.min()
metric_max_ts = metrics_ts.max()

# unique cmdb ids (as a compact Series)
metric_cmdb_unique = pd.Series(metrics['cmdb_id'].unique(), name='cmdb_id')

# top 20 kpi_name counts
metric_top_kpis = metrics['kpi_name'].value_counts().head(20)

# sample: first 5 rows with selected columns
metric_sample = metrics[['timestamp', 'cmdb_id', 'kpi_name', 'value']].head(5)

# compact summary DataFrame for metrics
metric_summary = pd.DataFrame({
    'row_count': [metric_count],
    'min_timestamp_UTC+8': [metric_min_ts],
    'max_timestamp_UTC+8': [metric_max_ts],
    'unique_cmdb_count': [metric_cmdb_unique.shape[0]]
})

# --- Traces summary ---
trace_count = traces.shape[0]

# convert epoch seconds to timezone-aware datetimes (assume epoch is UTC)
traces_ts = pd.to_datetime(traces['timestamp'], unit='s').dt.tz_localize('UTC').dt.tz_convert(tz)
trace_min_ts = traces_ts.min()
trace_max_ts = traces_ts.max()

# unique cmdb ids for traces
trace_cmdb_unique = pd.Series(traces['cmdb_id'].unique(), name='cmdb_id')

# top 20 trace_name counts
trace_top_names = traces['trace_name'].value_counts().head(20)

# sample: first 5 rows with selected columns
trace_sample = traces[['timestamp', 'cmdb_id', 'trace_name', 'value']].head(5)

# compact summary DataFrame for traces
trace_summary = pd.DataFrame({
    'row_count': [trace_count],
    'min_timestamp_UTC+8': [trace_min_ts],
    'max_timestamp_UTC+8': [trace_max_ts],
    'unique_cmdb_count': [trace_cmdb_unique.shape[0]]
})

# Display results (compact): metrics summary, unique cmdb ids, top kpis, sample;
# traces summary, unique cmdb ids, top trace names, sample
metric_summary, metric_cmdb_unique, metric_top_kpis, metric_sample, trace_summary, trace_cmdb_unique, trace_top_names, trace_sample
