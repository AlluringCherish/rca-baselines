import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# reuse existing 'metrics' if present; otherwise load from CSV
try:
    metrics
except NameError:
    metrics = pd.read_csv('metric.csv')

# build candidate cmdb_id set: os_001..os_022, docker_001..docker_008, db_001..db_013
os_ids = [f"os_{i:03d}" for i in range(1, 23)]
docker_ids = [f"docker_{i:03d}" for i in range(1, 9)]
db_ids = [f"db_{i:03d}" for i in range(1, 14)]
candidates = set(os_ids + docker_ids + db_ids)

# filter metrics to candidate cmdb_ids
metrics_candidates = metrics[metrics['cmdb_id'].isin(candidates)].copy()

# ensure value is numeric
metrics_candidates['value'] = pd.to_numeric(metrics_candidates['value'], errors='coerce')

# group by cmdb_id and kpi_name using the full available timestamps in metric.csv
grouped = metrics_candidates.groupby(['cmdb_id', 'kpi_name'], as_index=False)

agg_df = grouped.agg(
    count=('value', 'count'),
    min_ts=('timestamp', 'min'),
    max_ts=('timestamp', 'max'),
    p95=('value', lambda x: x.quantile(0.95)),
    p50=('value', lambda x: x.quantile(0.50)),
    p5 =('value', lambda x: x.quantile(0.05))
)

# convert min/max timestamps to timezone-aware UTC+8 datetimes
agg_df['min_timestamp_UTC+8'] = pd.to_datetime(agg_df['min_ts'], unit='s').dt.tz_localize('UTC').dt.tz_convert(tz)
agg_df['max_timestamp_UTC+8'] = pd.to_datetime(agg_df['max_ts'], unit='s').dt.tz_localize('UTC').dt.tz_convert(tz)

# select and order required columns
grouped_metrics_full = agg_df[
    ['cmdb_id', 'kpi_name', 'count', 'min_timestamp_UTC+8', 'max_timestamp_UTC+8', 'p95', 'p50', 'p5']
].copy()

# round percentile columns for compact display
grouped_metrics_full[['p95', 'p50', 'p5']] = grouped_metrics_full[['p95', 'p50', 'p5']].round(6)

# keep full grouped table in memory as grouped_metrics_full
# return only top 20 groups sorted by count (descending)
grouped_top20 = grouped_metrics_full.sort_values('count', ascending=False).head(20)

grouped_top20
