import pandas as pd
import numpy as np
import pytz
from datetime import datetime

# reuse existing kernel variables where possible
try:
    traces
except NameError:
    traces = pd.read_csv('trace.csv')

try:
    grouped_traces_full
except NameError:
    raise RuntimeError("grouped_traces_full not found in kernel memory. Run the previous grouping step first.")

tz = pytz.timezone('Asia/Shanghai')

# ensure numeric and timestamp_utc8 present
traces['value'] = pd.to_numeric(traces['value'], errors='coerce')
traces['timestamp_utc8'] = pd.to_datetime(traces['timestamp'], unit='s').dt.tz_localize('UTC').dt.tz_convert(tz)

# incident window (inclusive)
start_dt = tz.localize(datetime(2020, 5, 24, 4, 0, 0))
end_dt = tz.localize(datetime(2020, 5, 24, 4, 30, 0))

# filter to window
trace_marked_v2 = traces[(traces['timestamp_utc8'] >= start_dt) & (traces['timestamp_utc8'] <= end_dt)].copy()

# merge global thresholds computed earlier
trace_marked_v2 = trace_marked_v2.merge(
    grouped_traces_full[['cmdb_id', 'trace_name', 'p95', 'p5']],
    on=['cmdb_id', 'trace_name'],
    how='left'
)

# Exclude groups whose p95 == 0 or p95 is NaN
trace_marked_v2 = trace_marked_v2[trace_marked_v2['p95'].notna() & (trace_marked_v2['p95'] != 0)].copy()

# classify trace types
trace_marked_v2['is_duration_or_error'] = trace_marked_v2['trace_name'].str.contains('duration') | trace_marked_v2['trace_name'].str.contains('error_rate')
trace_marked_v2['is_row_count'] = trace_marked_v2['trace_name'].str.contains('row_count')

# mark anomalies with strict inequalities as requested
trace_marked_v2['anomaly'] = False
# duration/error_rate: value > p95
mask_de = trace_marked_v2['is_duration_or_error'] & trace_marked_v2['p95'].notna()
trace_marked_v2.loc[mask_de, 'anomaly'] = trace_marked_v2.loc[mask_de, 'value'] > trace_marked_v2.loc[mask_de, 'p95']
# row_count: value < p5 (ensure p5 present)
mask_rc = trace_marked_v2['is_row_count'] & trace_marked_v2['p5'].notna()
trace_marked_v2.loc[mask_rc, 'anomaly'] = trace_marked_v2.loc[mask_rc, 'value'] < trace_marked_v2.loc[mask_rc, 'p5']

# compute per-row ratio for severity calculations
def row_ratio(r):
    v = r['value']
    if r['is_duration_or_error']:
        # p95 is non-zero here (we excluded p95==0)
        return np.nan if pd.isna(v) else (v / r['p95'])
    if r['is_row_count']:
        return np.nan if pd.isna(v) or pd.isna(r['p5']) or r['p5'] == 0 else (v / r['p5'])
    return np.nan

trace_marked_v2['ratio'] = trace_marked_v2.apply(row_ratio, axis=1)

# keep full marked trace series in memory as 'trace_marked_v2'
trace_anomalous_v2 = trace_marked_v2[trace_marked_v2['anomaly']].copy()

# helper to compute longest consecutive streak in minutes
def longest_consecutive_streak_minutes(tseries):
    if tseries.empty:
        return 0
    diffs = tseries.sort_values().diff().dt.total_seconds().fillna(9999)
    streak_id = (diffs != 60).cumsum()
    streak_lengths = streak_id.groupby(streak_id).size()
    return int(streak_lengths.max())

# aggregate anomalies by (cmdb_id, trace_name)
groups = []
if not trace_anomalous_v2.empty:
    gb = trace_anomalous_v2.groupby(['cmdb_id', 'trace_name'])
    for (cmdb_id, trace_name), grp in gb:
        grp_sorted = grp.sort_values('timestamp_utc8')
        anomaly_count = int(grp_sorted.shape[0])
        earliest_ts = grp_sorted['timestamp_utc8'].min()
        longest_streak = longest_consecutive_streak_minutes(grp_sorted['timestamp_utc8'])
        # determine severity_metric per requested rule:
        # - duration/error_rate: max(value / p95) -> use ratio (v/p95), larger is more severe
        # - row_count: min(value / p5) -> use ratio (v/p5), smaller (<1) is more severe
        if grp_sorted['is_duration_or_error'].any():
            # consider only duration/error rows in grp_sorted
            ratios = grp_sorted.loc[grp_sorted['is_duration_or_error'], 'ratio'].dropna()
            severity_metric = float(ratios.max()) if not ratios.empty else np.nan
        elif grp_sorted['is_row_count'].any():
            ratios = grp_sorted.loc[grp_sorted['is_row_count'], 'ratio'].dropna()
            severity_metric = float(ratios.min()) if not ratios.empty else np.nan
        else:
            severity_metric = np.nan
        p95 = float(grp_sorted['p95'].iloc[0]) if pd.notna(grp_sorted['p95'].iloc[0]) else None
        p5  = float(grp_sorted['p5'].iloc[0])  if pd.notna(grp_sorted['p5'].iloc[0])  else None
        groups.append({
            'cmdb_id': cmdb_id,
            'trace_name': trace_name,
            'anomaly_count': anomaly_count,
            'earliest_anomaly_timestamp_UTC+8': earliest_ts,
            'longest_consecutive_anomaly_streak': int(longest_streak),
            'severity_metric': severity_metric,
            'p95': p95,
            'p5': p5
        })

trace_aggregated_v2 = pd.DataFrame(groups)

# sort and return top 20 as requested
trace_aggregated_v2_sorted = trace_aggregated_v2.sort_values(
    by=['longest_consecutive_anomaly_streak', 'anomaly_count'],
    ascending=[False, False]
).reset_index(drop=True)

trace_anomaly_top20_v2 = trace_aggregated_v2_sorted.head(20).copy()

# display the top-20 aggregated anomalies
trace_anomaly_top20_v2
