import pandas as pd
import pytz

# Reuse existing df_metric if present; otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
    df_metric['timestamp'] = df_metric['timestamp'].astype(int)

tz = pytz.timezone('Asia/Shanghai')

# 1) Compute global P95 and P5 for each (cmdb_id, kpi_name) using the full series (global thresholds)
thresholds_df = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(global_p95=lambda x: x.quantile(0.95), global_p5=lambda x: x.quantile(0.05))
    .reset_index()
)

# 2) Filter metric.csv to the incident window May 26, 2020 04:30:00 - 05:00:00 Asia/Shanghai
start_local = pd.Timestamp('2020-05-26 04:30:00', tz=tz)
end_local = pd.Timestamp('2020-05-26 05:00:00', tz=tz)
# Convert to UTC epoch seconds (timestamps in metric.csv are in seconds UTC)
start_ts = int(start_local.tz_convert('UTC').timestamp())
end_ts = int(end_local.tz_convert('UTC').timestamp())

incident_metric_df = df_metric[(df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] <= end_ts)].copy()

# If no rows in incident window, ensure variables exist and return empty results appropriately
if incident_metric_df.shape[0] == 0:
    top20_df = pd.DataFrame(columns=['cmdb_id','kpi_name','global_p95','global_p5','points_in_window','anomaly_count','earliest_anom_datetime_ASIA_SHANGHAI'])
    total_anomalies = 0
else:
    # Merge thresholds into incident rows to evaluate anomalies using global thresholds
    incident_with_thresh = incident_metric_df.merge(thresholds_df, on=['cmdb_id', 'kpi_name'], how='left')

    # Determine anomaly flag per row (value >= global_p95 OR value <= global_p5)
    incident_with_thresh['is_anom'] = (
        (incident_with_thresh['value'] >= incident_with_thresh['global_p95']) |
        (incident_with_thresh['value'] <= incident_with_thresh['global_p5'])
    )

    # Compute points_in_window per component-KPI
    counts = (
        incident_with_thresh
        .groupby(['cmdb_id', 'kpi_name'])
        .size()
        .rename('points_in_window')
        .reset_index()
    )

    # Compute anomaly counts and earliest anomaly timestamp (in epoch seconds)
    anom_rows = incident_with_thresh[incident_with_thresh['is_anom']]
    anom_counts = (
        anom_rows
        .groupby(['cmdb_id', 'kpi_name'])
        .agg(anomaly_count=('is_anom','sum'), earliest_anom_ts=('timestamp','min'))
        .reset_index()
    )

    # Combine counts, thresholds, and anomaly info
    result = (
        counts
        .merge(thresholds_df, on=['cmdb_id','kpi_name'], how='left')
        .merge(anom_counts, on=['cmdb_id','kpi_name'], how='left')
    )

    # Fill missing anomaly_count with 0
    result['anomaly_count'] = result['anomaly_count'].fillna(0).astype(int)

    # Convert earliest_anom_ts to Asia/Shanghai datetime (keep NaT for groups without anomalies)
    result['earliest_anom_datetime_ASIA_SHANGHAI'] = pd.to_datetime(result['earliest_anom_ts'], unit='s', utc=True).dt.tz_convert(tz)

    # Select and order requested columns
    result = result[['cmdb_id','kpi_name','global_p95','global_p5','points_in_window','anomaly_count','earliest_anom_datetime_ASIA_SHANGHAI']]

    # Rank by anomaly_count descending and take top 20
    top20_df = result.sort_values(['anomaly_count','points_in_window'], ascending=[False,False]).head(20).reset_index(drop=True)

    # Total number of metric anomalies across all component-KPIs in the window
    total_anomalies = int(anom_rows['is_anom'].sum())

# Display compact results: thresholds_df is stored in kernel, incident_metric_df stored too.
