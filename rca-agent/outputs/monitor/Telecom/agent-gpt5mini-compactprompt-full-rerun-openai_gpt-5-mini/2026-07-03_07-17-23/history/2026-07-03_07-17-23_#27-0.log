import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse existing kernel variables: thresholds_df and incident_metric_df
try:
    thresholds_df
    incident_metric_df
except NameError as e:
    raise RuntimeError("Required kernel variables thresholds_df and incident_metric_df are not available.") from e

# Ensure timestamps are integers
incident_metric_df['timestamp'] = incident_metric_df['timestamp'].astype(int)

# 1) Join thresholds to incident rows to get global_p95 and global_p5
df = incident_metric_df.merge(thresholds_df, on=['cmdb_id', 'kpi_name'], how='left')

# Mark anomalous rows
df['is_anom'] = (df['value'] >= df['global_p95']) | (df['value'] <= df['global_p5'])

# 2) Detect sampling step from incident data (use mode of timestamp diffs among unique sorted timestamps)
unique_ts = np.sort(df['timestamp'].unique())
if unique_ts.size <= 1:
    step = 60
else:
    diffs = np.diff(unique_ts)
    # If diffs contain zeros or noise, filter zeros
    diffs = diffs[diffs > 0]
    if diffs.size == 0:
        step = 60
    else:
        # choose the most common diff
        vals, counts = np.unique(diffs, return_counts=True)
        step = int(vals[np.argmax(counts)])

# 3) Build fault sequences by grouping consecutive anomalous points per (cmdb_id, kpi_name)
anom = df[df['is_anom']].copy()
if anom.shape[0] == 0:
    # No anomalies: create empty faults_df and filtered result
    faults_df = pd.DataFrame(columns=['cmdb_id','kpi_name','start_timestamp','end_timestamp',
                                      'start_datetime_ASIA_SHANGHAI','end_datetime_ASIA_SHANGHAI',
                                      'num_points','duration_seconds','max_value','min_value',
                                      'global_p95','global_p5','severity_pct'])
    filtered_faults_df = faults_df.copy()
    top20_faults_df = faults_df.head(20)
    total_filtered_count = 0
else:
    # Assign sequence ids within each cmdb+kpi based on timestamp gaps != step
    anom = anom.sort_values(['cmdb_id','kpi_name','timestamp']).copy()

    # For each group, compute diff and sequence id
    def assign_seq_ids(g):
        g = g.sort_values('timestamp').copy()
        g['ts_diff'] = g['timestamp'].diff().fillna(step)  # first row gets step to start new seq
        g['new_seq'] = (g['ts_diff'] != step)
        # The first row should start a new sequence
        g['seq_id'] = g['new_seq'].cumsum()
        return g

    anom = anom.groupby(['cmdb_id','kpi_name'], sort=False, group_keys=False).apply(assign_seq_ids)

    # Aggregate sequences
    agg = anom.groupby(['cmdb_id','kpi_name','seq_id'], sort=False).agg(
        start_timestamp=('timestamp','min'),
        end_timestamp=('timestamp','max'),
        num_points=('timestamp','size'),
        max_value=('value','max'),
        min_value=('value','min'),
        global_p95=('global_p95','first'),
        global_p5=('global_p5','first')
    ).reset_index(drop=False)

    # Compute datetimes in Asia/Shanghai
    agg['start_datetime_ASIA_SHANGHAI'] = pd.to_datetime(agg['start_timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    agg['end_datetime_ASIA_SHANGHAI'] = pd.to_datetime(agg['end_timestamp'], unit='s', utc=True).dt.tz_convert(tz)

    # duration in seconds (end - start). For single point this is 0.
    agg['duration_seconds'] = (agg['end_timestamp'] - agg['start_timestamp']).astype(int)

    # 4) Compute severity_pct per sequence
    def compute_severity(row):
        gp95 = row['global_p95']
        gp5 = row['global_p5']
        maxv = row['max_value']
        minv = row['min_value']
        # Prefer above-threshold severity if any value reaches/exceeds gp95
        if pd.notnull(gp95) and maxv >= gp95:
            denom = max(abs(gp95), 1e-9)
            return 100.0 * (maxv - gp95) / denom
        # Else, if below threshold
        if pd.notnull(gp5) and minv <= gp5:
            denom = max(abs(gp5), 1e-9)
            return 100.0 * (gp5 - minv) / denom
        return 0.0

    agg['severity_pct'] = agg.apply(compute_severity, axis=1)

    # Keep relevant columns and order them
    faults_df = agg[['cmdb_id','kpi_name','start_timestamp','end_timestamp',
                     'start_datetime_ASIA_SHANGHAI','end_datetime_ASIA_SHANGHAI',
                     'num_points','duration_seconds','max_value','min_value',
                     'global_p95','global_p5','severity_pct']].copy()

    # 5) Filter out isolated spikes: keep num_points >= 2 AND severity_pct > 50
    filtered_faults_df = faults_df[(faults_df['num_points'] >= 2) & (faults_df['severity_pct'] > 50)].copy()

    # Top 20 by severity_pct desc
    top20_faults_df = filtered_faults_df.sort_values('severity_pct', ascending=False).head(20).reset_index(drop=True)

    total_filtered_count = int(filtered_faults_df.shape[0])

# Final display: top20_faults_df (compact) and total_filtered_count
top20_faults_df, total_filtered_count
