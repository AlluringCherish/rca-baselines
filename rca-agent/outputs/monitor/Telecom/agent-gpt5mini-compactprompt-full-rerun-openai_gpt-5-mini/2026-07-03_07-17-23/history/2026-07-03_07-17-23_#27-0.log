import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse df_trace if it's already in the kernel, otherwise load
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')
    df_trace['timestamp'] = df_trace['timestamp'].astype(int)

# Ensure timestamp int
df_trace['timestamp'] = df_trace['timestamp'].astype(int)

# 1) Compute global P95 and P5 per (cmdb_id, trace_name)
thresholds_trace_df = (
    df_trace
    .groupby(['cmdb_id', 'trace_name'], sort=False)['value']
    .agg(global_p95=lambda x: x.quantile(0.95), global_p5=lambda x: x.quantile(0.05))
    .reset_index()
)

# 2) Filter trace.csv to incident window May 26, 2020 04:30:00 - 05:00:00 Asia/Shanghai
start_local = pd.Timestamp('2020-05-26 04:30:00', tz=tz)
end_local = pd.Timestamp('2020-05-26 05:00:00', tz=tz)
start_ts = int(start_local.tz_convert('UTC').timestamp())
end_ts = int(end_local.tz_convert('UTC').timestamp())

incident_trace_df = df_trace[(df_trace['timestamp'] >= start_ts) & (df_trace['timestamp'] <= end_ts)].copy()

# 3) Join thresholds and flag anomalies
incident_with_thresh = incident_trace_df.merge(thresholds_trace_df, on=['cmdb_id', 'trace_name'], how='left')
incident_with_thresh['is_anom'] = (
    (incident_with_thresh['value'] >= incident_with_thresh['global_p95']) |
    (incident_with_thresh['value'] <= incident_with_thresh['global_p5'])
)

# 4a) Aggregate by cmdb_id: anomaly_count, total_points_in_window, earliest_anom_datetime_ASIA_SHANGHAI
# total points
cmdb_counts = (
    incident_with_thresh
    .groupby('cmdb_id', sort=False)
    .agg(total_points_in_window=('timestamp','size'),
         anomaly_count=('is_anom','sum'))
    .reset_index()
)

# earliest anomaly timestamp per cmdb_id (NaN if none)
earliest_anom_ts_cmdb = (
    incident_with_thresh[incident_with_thresh['is_anom']]
    .groupby('cmdb_id', sort=False)['timestamp']
    .min()
    .reset_index()
    .rename(columns={'timestamp':'earliest_anom_ts'})
)

cmdb_agg = cmdb_counts.merge(earliest_anom_ts_cmdb, on='cmdb_id', how='left')
cmdb_agg['earliest_anom_datetime_ASIA_SHANGHAI'] = pd.to_datetime(cmdb_agg['earliest_anom_ts'], unit='s', utc=True).dt.tz_convert(tz)
cmdb_agg_top20 = cmdb_agg.sort_values('anomaly_count', ascending=False).head(20)[
    ['cmdb_id','anomaly_count','total_points_in_window','earliest_anom_datetime_ASIA_SHANGHAI']
].reset_index(drop=True)

# 4b) Aggregate by trace_name across cmdbs
trace_counts = (
    incident_with_thresh
    .groupby('trace_name', sort=False)
    .agg(total_points_in_window=('timestamp','size'),
         anomaly_count=('is_anom','sum'))
    .reset_index()
)

earliest_anom_ts_trace = (
    incident_with_thresh[incident_with_thresh['is_anom']]
    .groupby('trace_name', sort=False)['timestamp']
    .min()
    .reset_index()
    .rename(columns={'timestamp':'earliest_anom_ts'})
)

trace_agg = trace_counts.merge(earliest_anom_ts_trace, on='trace_name', how='left')
trace_agg['earliest_anom_datetime_ASIA_SHANGHAI'] = pd.to_datetime(trace_agg['earliest_anom_ts'], unit='s', utc=True).dt.tz_convert(tz)
trace_agg_top20 = trace_agg.sort_values('anomaly_count', ascending=False).head(20)[
    ['trace_name','anomaly_count','total_points_in_window','earliest_anom_datetime_ASIA_SHANGHAI']
].reset_index(drop=True)

# 4c) Total number of trace anomaly points in the window
total_trace_anomalies = int(incident_with_thresh['is_anom'].sum())

# Store thresholds_trace_df and incident_trace_df in kernel (they already are variables)
thresholds_trace_df, incident_trace_df, cmdb_agg_top20, trace_agg_top20, total_trace_anomalies
