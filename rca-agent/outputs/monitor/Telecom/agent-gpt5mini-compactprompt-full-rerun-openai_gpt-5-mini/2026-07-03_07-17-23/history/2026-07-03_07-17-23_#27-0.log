import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Load CSVs (files are in the current working directory)
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')

# Ensure timestamps are integers
df_metric['timestamp'] = df_metric['timestamp'].astype(int)
df_trace['timestamp'] = df_trace['timestamp'].astype(int)

# --- Metric aggregates ---
# (1) unique cmdb_id with counts
metric_cmdb_counts = df_metric['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count')
metric_cmdb_counts_top20 = metric_cmdb_counts.head(20)

# (2) unique kpi_name with counts (top 20)
metric_kpi_counts = df_metric['kpi_name'].value_counts().rename_axis('kpi_name').reset_index(name='count')
metric_kpi_counts_top20 = metric_kpi_counts.head(20)

# (3) overall min and max timestamp (also converted to Asia/Shanghai timezone)
metric_min_ts = int(df_metric['timestamp'].min())
metric_max_ts = int(df_metric['timestamp'].max())
metric_min_dt_sh = pd.to_datetime(metric_min_ts, unit='s', utc=True).tz_convert(tz)
metric_max_dt_sh = pd.to_datetime(metric_max_ts, unit='s', utc=True).tz_convert(tz)
metric_time_range = pd.DataFrame([{
    'min_timestamp': metric_min_ts,
    'max_timestamp': metric_max_ts,
    'min_datetime_ASIA_SHANGHAI': metric_min_dt_sh,
    'max_datetime_ASIA_SHANGHAI': metric_max_dt_sh
}])

# Compact metric summary
metric_summary = {
    'unique_cmdb_count': int(metric_cmdb_counts.shape[0]),
    'cmdb_counts_top20': metric_cmdb_counts_top20,
    'unique_kpi_count': int(metric_kpi_counts.shape[0]),
    'kpi_counts_top20': metric_kpi_counts_top20,
    'time_range': metric_time_range
}

# --- Trace aggregates ---
# (1) unique cmdb_id with counts
trace_cmdb_counts = df_trace['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count')
trace_cmdb_counts_top20 = trace_cmdb_counts.head(20)

# (2) unique trace_name with counts (top 20)
trace_name_counts = df_trace['trace_name'].value_counts().rename_axis('trace_name').reset_index(name='count')
trace_name_counts_top20 = trace_name_counts.head(20)

# (3) overall min and max timestamp (Asia/Shanghai)
trace_min_ts = int(df_trace['timestamp'].min())
trace_max_ts = int(df_trace['timestamp'].max())
trace_min_dt_sh = pd.to_datetime(trace_min_ts, unit='s', utc=True).tz_convert(tz)
trace_max_dt_sh = pd.to_datetime(trace_max_ts, unit='s', utc=True).tz_convert(tz)
trace_time_range = pd.DataFrame([{
    'min_timestamp': trace_min_ts,
    'max_timestamp': trace_max_ts,
    'min_datetime_ASIA_SHANGHAI': trace_min_dt_sh,
    'max_datetime_ASIA_SHANGHAI': trace_max_dt_sh
}])

# Compact trace summary
trace_summary = {
    'unique_cmdb_count': int(trace_cmdb_counts.shape[0]),
    'cmdb_counts_top20': trace_cmdb_counts_top20,
    'unique_trace_name_count': int(trace_name_counts.shape[0]),
    'trace_name_counts_top20': trace_name_counts_top20,
    'time_range': trace_time_range
}

# Display compact summaries (as variables for IPython)
metric_summary, trace_summary
