import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse existing kernel variables: faults_df, incident_trace_df, thresholds_trace_df
try:
    faults_df
    incident_trace_df
    thresholds_trace_df
except NameError as e:
    raise RuntimeError("Required kernel variables (faults_df, incident_trace_df, thresholds_trace_df) are not available.") from e

# Ensure start datetime column is datetime tz-aware; if not, try to parse/convert
if 'start_datetime_ASIA_SHANGHAI' in faults_df.columns:
    faults_df['start_datetime_ASIA_SHANGHAI'] = pd.to_datetime(faults_df['start_datetime_ASIA_SHANGHAI'], utc=True).dt.tz_convert(tz)
else:
    # If only start_timestamp exists, convert it
    if 'start_timestamp' in faults_df.columns:
        faults_df['start_datetime_ASIA_SHANGHAI'] = pd.to_datetime(faults_df['start_timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    else:
        raise RuntimeError("faults_df lacks both 'start_datetime_ASIA_SHANGHAI' and 'start_timestamp' columns.")

# 1) Aggregate faults_df by cmdb_id for specific prefixes
prefixes = ('os_', 'docker_', 'db_')
mask = faults_df['cmdb_id'].astype(str).str.startswith(prefixes)
comp_faults = faults_df[mask].copy()

# Aggregation
comp_fault_agg = (
    comp_faults
    .groupby('cmdb_id', sort=False)
    .agg(
        number_of_fault_sequences=('cmdb_id','size'),
        total_fault_points=('num_points','sum'),
        earliest_fault_start_datetime_ASIA_SHANGHAI=('start_datetime_ASIA_SHANGHAI','min'),
        max_severity_pct=('severity_pct','max')
    )
    .reset_index()
)

# Sort by max_severity_pct desc and keep top 20
comp_fault_agg = comp_fault_agg.sort_values('max_severity_pct', ascending=False).head(20).reset_index(drop=True)

# 2) For top-5 cmdb_id by max_severity_pct, compute trace involvement from incident_trace_df
top5_cmdbs = comp_fault_agg['cmdb_id'].head(5).tolist()

# Prepare incident_trace_df joined with thresholds to flag anomalies (recompute safe)
inc_tr = incident_trace_df.merge(thresholds_trace_df, on=['cmdb_id','trace_name'], how='left')
inc_tr['is_anom'] = (inc_tr['value'] >= inc_tr['global_p95']) | (inc_tr['value'] <= inc_tr['global_p5'])

# Aggregate trace anomalies for top5
trace_involv = (
    inc_tr[inc_tr['cmdb_id'].isin(top5_cmdbs)]
    .groupby('cmdb_id', sort=False)
    .agg(
        trace_anomaly_count=('is_anom','sum'),
        earliest_trace_anom_ts=('timestamp', lambda s: s[inc_tr.loc[s.index,'is_anom']].min() if s.size>0 else pd.NA)
    )
    .reset_index()
)

# Convert earliest timestamp to Asia/Shanghai datetime
trace_involv['earliest_trace_anom_datetime_ASIA_SHANGHAI'] = pd.to_datetime(trace_involv['earliest_trace_anom_ts'], unit='s', utc=True).dt.tz_convert(tz)
trace_involv = trace_involv[['cmdb_id','trace_anomaly_count','earliest_trace_anom_datetime_ASIA_SHANGHAI']]

# Ensure all top5 appear (fill missing with zeros/NaT)
missing = set(top5_cmdbs) - set(trace_involv['cmdb_id'])
if missing:
    for m in missing:
        trace_involv = pd.concat([trace_involv, pd.DataFrame([{
            'cmdb_id': m,
            'trace_anomaly_count': 0,
            'earliest_trace_anom_datetime_ASIA_SHANGHAI': pd.NaT
