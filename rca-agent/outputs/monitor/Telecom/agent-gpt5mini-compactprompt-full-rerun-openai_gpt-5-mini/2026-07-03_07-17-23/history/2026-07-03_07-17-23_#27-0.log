# Ensure timestamp ints
incident_metric_df['timestamp'] = incident_metric_df['timestamp'].astype(int)
incident_trace_df['timestamp'] = incident_trace_df['timestamp'].astype(int)

# Filter to os_022 for incident window rows (incident_* already filtered to window)
os_metric = incident_metric_df[incident_metric_df['cmdb_id'] == 'os_022'].copy()
os_trace = incident_trace_df[incident_trace_df['cmdb_id'] == 'os_022'].copy()

# Join global thresholds (precomputed) and flag anomalies
os_metric = os_metric.merge(thresholds_df, on=['cmdb_id','kpi_name'], how='left')
os_metric['is_anom'] = (os_metric['value'] >= os_metric['global_p95']) | (os_metric['value'] <= os_metric['global_p5'])

os_trace = os_trace.merge(thresholds_trace_df, on=['cmdb_id','trace_name'], how='left')
os_trace['is_anom'] = (os_trace['value'] >= os_trace['global_p95']) | (os_trace['value'] <= os_trace['global_p5'])

# (1) earliest metric anomaly datetime for os_022
if os_metric['is_anom'].any():
    earliest_metric_ts = int(os_metric.loc[os_metric['is_anom'], 'timestamp'].min())
    earliest_metric_anomaly_datetime_ASIA_SHANGHAI = pd.to_datetime(earliest_metric_ts, unit='s', utc=True).tz_convert(tz)
else:
    earliest_metric_anomaly_datetime_ASIA_SHANGHAI = pd.NaT

# (2) earliest trace anomaly datetime for os_022
if os_trace['is_anom'].any():
    earliest_trace_ts = int(os_trace.loc[os_trace['is_anom'], 'timestamp'].min())
    earliest_trace_anomaly_datetime_ASIA_SHANGHAI = pd.to_datetime(earliest_trace_ts, unit='s', utc=True).tz_convert(tz)
else:
    earliest_trace_anomaly_datetime_ASIA_SHANGHAI = pd.NaT

# (3) Top 5 KPIs by anomaly_count with requested columns
def earliest_anom_ts_group(g):
    anom = g.loc[g['is_anom'], 'timestamp']
    if anom.size:
        return int(anom.min())
    return np.nan

metric_grp = (
    os_metric
    .groupby('kpi_name', sort=False)
    .agg(
        points_in_window=('timestamp','size'),
        anomaly_count=('is_anom','sum'),
        earliest_anom_ts=('timestamp', lambda s: earliest_anom_ts_group(os_metric.loc[s.index])),
        max_value=('value','max'),
        min_value=('value','min'),
        global_p95=('global_p95','first'),
        global_p5=('global_p5','first')
    )
    .reset_index()
)

# Convert earliest_anom_ts to datetimes (Asia/Shanghai); NaN -> NaT
metric_grp['earliest_anom_datetime_ASIA_SHANGHAI'] = pd.to_datetime(metric_grp['earliest_anom_ts'], unit='s', utc=True).dt.tz_convert(tz)

# Select and order columns, sort by anomaly_count desc then kpi_name, take top 5
os022_evidence_df = metric_grp[
    ['kpi_name','points_in_window','anomaly_count','earliest_anom_datetime_ASIA_SHANGHAI','max_value','global_p95','global_p5']
].sort_values(['anomaly_count','kpi_name'], ascending=[False, True]).head(5).reset_index(drop=True)

# (4) Top 5 trace series by anomaly_count for os_022
def earliest_anom_ts_trace_group(g):
    anom = g.loc[g['is_anom'], 'timestamp']
    if anom.size:
        return int(anom.min())
    return np.nan

trace_grp = (
    os_trace
    .groupby('trace_name', sort=False)
    .agg(
        total_points_in_window=('timestamp','size'),
        anomaly_count=('is_anom','sum'),
        earliest_anom_ts=('timestamp', lambda s: earliest_anom_ts_trace_group(os_trace.loc[s.index]))
    )
    .reset_index()
)

trace_grp['earliest_anom_datetime_ASIA_SHANGHAI'] = pd.to_datetime(trace_grp['earliest_anom_ts'], unit='s', utc=True).dt.tz_convert(tz)

os022_trace_evidence_df = trace_grp[
    ['trace_name','total_points_in_window','anomaly_count','earliest_anom_datetime_ASIA_SHANGHAI']
].sort_values(['anomaly_count','trace_name'], ascending=[False, True]).head(5).reset_index(drop=True)

# (5) Store earliest times in a small DataFrame
os022_earliest_times = pd.DataFrame([{
    'earliest_metric_anomaly_datetime_ASIA_SHANGHAI': earliest_metric_anomaly_datetime_ASIA_SHANGHAI,
    'earliest_trace_anomaly_datetime_ASIA_SHANGHAI': earliest_trace_anomaly_datetime_ASIA_SHANGHAI
}])

# Store variables in kernel and display compact results
os022_evidence_df, os022_trace_evidence_df, os022_earliest_times
