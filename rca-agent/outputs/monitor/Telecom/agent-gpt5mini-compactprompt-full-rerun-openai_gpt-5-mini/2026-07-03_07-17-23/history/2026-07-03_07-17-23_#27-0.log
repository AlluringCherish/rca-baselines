import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse kernel variables: incident_metric_df, thresholds_df, incident_trace_df, thresholds_trace_df
try:
    incident_metric_df
    thresholds_df
    incident_trace_df
    thresholds_trace_df
except NameError as e:
    raise RuntimeError("Required kernel variables (incident_metric_df, thresholds_df, incident_trace_df, thresholds_trace_df) are not available.") from e

# Ensure timestamps are ints
incident_metric_df['timestamp'] = incident_metric_df['timestamp'].astype(int)
incident_trace_df['timestamp'] = incident_trace_df['timestamp'].astype(int)

# 1) Metric aggregation for os_022
os_metric = incident_metric_df[incident_metric_df['cmdb_id'] == 'os_022'].copy()
# Join global thresholds (precomputed) - do NOT recompute thresholds here
os_metric = os_metric.merge(thresholds_df, on=['cmdb_id','kpi_name'], how='left')

# Flag anomalies using global thresholds
os_metric['is_anom'] = (os_metric['value'] >= os_metric['global_p95']) | (os_metric['value'] <= os_metric['global_p5'])

# Aggregate per kpi_name
metric_agg = (
    os_metric
    .groupby('kpi_name', sort=False)
    .agg(
        points_in_window=('timestamp','size'),
        anomaly_count=('is_anom','sum'),
        earliest_anom_ts=('timestamp', lambda s: s[os_metric.loc[s.index,'is_anom']].min() if s.size>0 else pd.NA),
        max_value=('value','max'),
        min_value=('value','min'),
        global_p95=('global_p95','first'),
        global_p5=('global_p5','first')
    )
    .reset_index()
)

# Convert earliest anomaly timestamp to Asia/Shanghai datetime
metric_agg['earliest_anom_datetime_ASIA_SHANGHAI'] = pd.to_datetime(metric_agg['earliest_anom_ts'], unit='s', utc=True).dt.tz_convert(tz)

# Select and order columns as requested, sort by anomaly_count desc then kpi_name
os022_metric_agg = metric_agg[
    ['kpi_name','points_in_window','anomaly_count','earliest_anom_datetime_ASIA_SHANGHAI','max_value','min_value','global_p95','global_p5']
].sort_values(['anomaly_count','kpi_name'], ascending=[False, True]).reset_index(drop=True).head(20)

# 2) Trace aggregation for os_022
os_trace = incident_trace_df[incident_trace_df['cmdb_id'] == 'os_022'].copy()
os_trace = os_trace.merge(thresholds_trace_df, on=['cmdb_id','trace_name'], how='left')

# Flag anomalies using global trace thresholds
os_trace['is_anom'] = (os_trace['value'] >= os_trace['global_p95']) | (os_trace['value'] <= os_trace['global_p5'])

trace_agg = (
    os_trace
    .groupby('trace_name', sort=False)
    .agg(
        total_points_in_window=('timestamp','size'),
        anomaly_count=('is_anom','sum'),
        earliest_anom_ts=('timestamp', lambda s: s[os_trace.loc[s.index,'is_anom']].min() if s.size>0 else pd.NA)
    )
    .reset_index()
)

trace_agg['earliest_anom_datetime_ASIA_SHANGHAI'] = pd.to_datetime(trace_agg['earliest_anom_ts'], unit='s', utc=True).dt.tz_convert(tz)

os022_trace_agg = trace_agg[
    ['trace_name','total_points_in_window','anomaly_count','earliest_anom_datetime_ASIA_SHANGHAI']
].sort_values('anomaly_count', ascending=False).reset_index(drop=True).head(20)

