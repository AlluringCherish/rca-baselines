import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse existing kernel variables (they should exist from prior steps)
try:
    incident_metric_df
    thresholds_df
    incident_trace_df
    thresholds_trace_df
except NameError as e:
