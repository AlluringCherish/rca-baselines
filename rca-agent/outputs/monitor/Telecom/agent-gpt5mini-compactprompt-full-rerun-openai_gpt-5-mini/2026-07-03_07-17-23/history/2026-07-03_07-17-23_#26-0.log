import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Load CSVs (reusing variables if rerun in stateful kernel)
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')

# Helper to get time range as timezone-aware ISO strings
def time_range_iso(sr):
    if sr.empty:
        return None, None
    ts = pd.to_datetime(sr, unit='s', utc=True).dt.tz_convert(tz)
    return ts.min().isoformat(), ts.max().isoformat()

# Metric summaries
metric_total_rows = int(df_metric.shape[0])
metric_unique_cmdb = pd.Series(df_metric['cmdb_id'].unique())
metric_unique_count = int(metric_unique_cmdb.size)
metric_unique_list_display = metric_unique_cmdb.head(20).tolist()
metric_truncated = metric_unique_count > 20
metric_ts_min, metric_ts_max = time_range_iso(df_metric['timestamp'])
metric_top_kpis = df_metric['kpi_name'].value_counts().head(20).reset_index()
metric_top_kpis.columns = ['kpi_name', 'count']

# Trace summaries
trace_total_rows = int(df_trace.shape[0])
trace_unique_cmdb = pd.Series(df_trace['cmdb_id'].unique())
trace_unique_count = int(trace_unique_cmdb.size)
trace_unique_list_display = trace_unique_cmdb.head(20).tolist()
trace_truncated = trace_unique_count > 20
trace_ts_min, trace_ts_max = time_range_iso(df_trace['timestamp'])
trace_top_names = df_trace['trace_name'].value_counts().head(20).reset_index()
trace_top_names.columns = ['trace_name', 'count']

# Build a concise JSON-like text output
lines = []
lines.append("{")
lines.append('  "metric": {')
lines.append(f'    "total_rows": {metric_total_rows},')
lines.append(f'    "unique_cmdb_count": {metric_unique_count},')
lines.append(f'    "unique_cmdb_list_display (first 20)": {metric_unique_list_display}' + (", // truncated" if metric_truncated else ","))
lines.append(f'    "timestamp_min": "{metric_ts_min}",')
lines.append(f'    "timestamp_max": "{metric_ts_max}",')
lines.append('    "top_kpi_names": [')
for _, row in metric_top_kpis.iterrows():
    lines.append(f'      {{"kpi_name": "{row.kpi_name}", "count": {int(row.count)}}},')
if not metric_top_kpis.empty:
    lines[-1] = lines[-1].rstrip(',')  # remove trailing comma from last item
lines.append('    ]')
lines.append('  },')

lines.append('  "trace": {')
lines.append(f'    "total_rows": {trace_total_rows},')
lines.append(f'    "unique_cmdb_count": {trace_unique_count},')
lines.append(f'    "unique_cmdb_list_display (first 20)": {trace_unique_list_display}' + (", // truncated" if trace_truncated else ","))
lines.append(f'    "timestamp_min": "{trace_ts_min}",')
lines.append(f'    "timestamp_max": "{trace_ts_max}",')
lines.append('    "top_trace_names": [')
for _, row in trace_top_names.iterrows():
    lines.append(f'      {{"trace_name": "{row.trace_name}", "count": {int(row.count)}}},')
if not trace_top_names.empty:
    lines[-1] = lines[-1].rstrip(',')
lines.append('    ]')
lines.append('  }')
lines.append('}')

output_text = "\n".join(lines)

# Display the compact summary text and the two top-* DataFrames (compact)
output_text, metric_top_kpis, trace_top_names
