import pandas as pd
import pytz

# Reuse existing df_metric if available; otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

tz = pytz.timezone('Asia/Shanghai')

# Ensure timestamp datetime column in UTC+8
if 'dt' not in df_metric.columns:
    df_metric['dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Rule 9: compute global P95 and P5 per (cmdb_id, kpi_name) using the full series BEFORE any filtering
q = df_metric.groupby(['cmdb_id', 'kpi_name'])['value'].quantile([0.95, 0.05]).unstack(level=-1)
# columns are 0.95 and 0.05; rename for clarity
q = q.rename(columns={0.95: 'p95', 0.05: 'p5'}).reset_index()

# Merge thresholds back (so each row has its group's global p95/p5)
df_metric = df_metric.merge(q, on=['cmdb_id', 'kpi_name'], how='left')

# Define incident window (inclusive) in UTC+8
start = pd.Timestamp('2020-05-26 04:00:00', tz=tz)
end = pd.Timestamp('2020-05-26 04:30:00', tz=tz)

# Filter rows within the incident window (inclusive)
window_df = df_metric[(df_metric['dt'] >= start) & (df_metric['dt'] <= end)].copy()

# If no data in window, produce empty results gracefully
if window_df.empty:
    top20_df = pd.DataFrame(columns=[
        'cmdb_id', 'kpi_name', 'total_points', 'anomalies_high', 'anomalies_low',
        'earliest_anomaly_ts', 'max_value', 'min_value'
    ])
    top20_cmdbs = []
else:
    # Aggregate required metrics per (cmdb_id, kpi_name) present in the window
    def agg_group(g):
        total = int(g.shape[0])
        anomalies_high = int((g['value'] > g['p95']).sum())
        anomalies_low = int((g['value'] < g['p5']).sum())
        anom_mask = (g['value'] > g['p95']) | (g['value'] < g['p5'])
        if anom_mask.any():
            earliest = g.loc[anom_mask, 'dt'].min()
            # convert to ISO string in UTC+8 for compactness
            earliest_iso = earliest.isoformat()
        else:
            earliest_iso = pd.NA
        max_v = float(g['value'].max())
        min_v = float(g['value'].min())
        return pd.Series({
            'total_points': total,
            'anomalies_high': anomalies_high,
            'anomalies_low': anomalies_low,
            'earliest_anomaly_ts': earliest_iso,
            'max_value': max_v,
            'min_value': min_v,
            'anoms_total': anomalies_high + anomalies_low
        })

    agg = window_df.groupby(['cmdb_id', 'kpi_name']).apply(agg_group).reset_index()

    # Sort by total anomalies desc, then earliest anomaly timestamp asc (NaT/NA go last)
    # For sorting by earliest timestamp, convert ISO strings back to Timestamps where present
    agg['earliest_ts_for_sort'] = pd.to_datetime(agg['earliest_anomaly_ts']).dt.tz_convert(tz)
    agg_sorted = agg.sort_values(
        by=['anoms_total', 'earliest_ts_for_sort'],
        ascending=[False, True],
        na_position='last'
    )

    # Select top 20 and only requested columns
    top20_df = agg_sorted.head(20)[[
        'cmdb_id', 'kpi_name', 'total_points', 'anomalies_high', 'anomalies_low',
        'earliest_anomaly_ts', 'max_value', 'min_value'
    ]].reset_index(drop=True)

    top20_cmdbs = top20_df['cmdb_id'].unique().tolist()

# Display compact results: top20 table and list of cmdb_ids (top 20)
top20_df, top20_cmdbs
