import numpy as np
import pandas as pd
import pytz

# Reuse previously loaded variables: df_metric, window_df, top20_df, tz
# Ensure they exist
try:
    df_metric
    window_df
    top20_df
    tz
except NameError:
    df_metric = pd.read_csv('metric.csv')
    tz = pytz.timezone('Asia/Shanghai')
    df_metric['dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    # recompute thresholds if missing
    q = df_metric.groupby(['cmdb_id', 'kpi_name'])['value'].quantile([0.95, 0.05]).unstack(level=-1)
    q = q.rename(columns={0.95: 'p95', 0.05: 'p5'}).reset_index()
    df_metric = df_metric.merge(q, on=['cmdb_id', 'kpi_name'], how='left')
    start = pd.Timestamp('2020-05-26 04:00:00', tz=tz)
    end = pd.Timestamp('2020-05-26 04:30:00', tz=tz)
    window_df = df_metric[(df_metric['dt'] >= start) & (df_metric['dt'] <= end)].copy()
    # recompute top20_df as before if absent (safe fallback)
    agg = window_df.groupby(['cmdb_id','kpi_name']).size().reset_index(name='cnt').sort_values('cnt', ascending=False).head(20)
    top20_df = agg[['cmdb_id','kpi_name']].copy()

# Prepare set of (cmdb_id,kpi_name) to analyze (from previously returned top20)
pairs = set(tuple(x) for x in top20_df[['cmdb_id','kpi_name']].itertuples(index=False, name=None))

# Filter window rows to only these series
window_top = window_df[window_df.apply(lambda r: (r['cmdb_id'], r['kpi_name']) in pairs, axis=1)].copy()

# If empty, prepare empty outputs
if window_top.empty:
    faults_top20 = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','anomaly_type','fault_start_ts','fault_end_ts',
        'point_count','max_value','min_value','global_threshold_used','breach_ratio'
    ])
    fault_counts = pd.DataFrame(columns=['cmdb_id','fault_count'])
else:
    # Label each point
    window_top['label'] = np.where(window_top['value'] > window_top['p95'], 'HIGH_ANOMALY',
                                   np.where(window_top['value'] < window_top['p5'], 'LOW_ANOMALY', 'NORMAL'))

    # Assign run ids per (cmdb_id,kpi_name) considering contiguous timestamps (<=60s gap) and label changes
    def assign_runs(g):
        g = g.sort_values('dt').copy()
        g['dt_diff'] = g['dt'].diff().dt.total_seconds().fillna(9999)  # first row large to start new run
        # new run when label changed or time gap > 60 seconds
        g['run_start'] = ((g['label'] != g['label'].shift()) | (g['dt_diff'] > 60)).astype(int)
        g['run_id'] = g['run_start'].cumsum()
        return g

    window_top = window_top.groupby(['cmdb_id','kpi_name'], group_keys=False).apply(assign_runs)

    # Keep only anomaly rows (HIGH or LOW)
    anom_rows = window_top[window_top['label'].isin(['HIGH_ANOMALY','LOW_ANOMALY'])].copy()
    if anom_rows.empty:
        faults_agg = pd.DataFrame(columns=[
            'cmdb_id','kpi_name','anomaly_type','fault_start_ts','fault_end_ts',
            'point_count','max_value','min_value','global_threshold_used','breach_ratio'
        ])
    else:
        # Aggregate runs into candidate faults
        def agg_run(g):
            cmdb_id = g['cmdb_id'].iloc[0]
            kpi = g['kpi_name'].iloc[0]
            label = g['label'].iloc[0]
            anomaly_type = 'HIGH' if label == 'HIGH_ANOMALY' else 'LOW'
            start_ts = g['dt'].min()
            end_ts = g['dt'].max()
            point_count = int(g.shape[0])
            max_v = float(g['value'].max())
            min_v = float(g['value'].min())
            # thresholds (same for group)
            p95 = float(g['p95'].iloc[0])
            p5 = float(g['p5'].iloc[0])
            if anomaly_type == 'HIGH':
                thresh = p95
                if thresh == 0:
                    breach_ratio = np.inf if max_v > thresh else 0.0
                else:
                    breach_ratio = (max_v - thresh) / thresh
            else:
