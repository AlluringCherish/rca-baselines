df_r = df_metric[df_metric['cmdb_id'] == target].copy()

# If no data for redis_011, produce empty results
if df_r.empty:
    redis_summary = pd.DataFrame(columns=[
        'kpi_name','count_full','global_P95','global_P5',
        'count_window','anomalies_high','anomalies_low','earliest_anomaly_ts',
        'max_value_window','min_value_window'
    ])
    raw_instant_rows = pd.DataFrame(columns=['timestamp','value','p95','p5'])
else:
    # Rule 9: compute global thresholds using full available series BEFORE window filtering
    q = df_r.groupby('kpi_name')['value'].quantile([0.95, 0.05]).unstack(level=-1).rename(columns={0.95: 'p95', 0.05: 'p5'}).reset_index()
    # Merge thresholds into per-row df for convenience
    df_r = df_r.merge(q, on='kpi_name', how='left')

    # Define incident window (inclusive) in UTC+8
    start = pd.Timestamp('2020-05-26 04:00:00', tz=tz)
    end = pd.Timestamp('2020-05-26 04:30:00', tz=tz)

    window_r = df_r[(df_r['dt'] >= start) & (df_r['dt'] <= end)].copy()

    # Aggregate per kpi_name
    def agg_kpi(kpi, df_full, df_win):
        dfk_full = df_full[df_full['kpi_name'] == kpi]
        count_full = int(dfk_full.shape[0])
        p95 = float(dfk_full['value'].quantile(0.95)) if count_full>0 else float('nan')
        p5 = float(dfk_full['value'].quantile(0.05)) if count_full>0 else float('nan')

        dfk_win = df_win[df_win['kpi_name'] == kpi]
        count_window = int(dfk_win.shape[0])
        anomalies_high = int((dfk_win['value'] > p95).sum()) if count_window>0 else 0
        anomalies_low = int((dfk_win['value'] < p5).sum()) if count_window>0 else 0
        anom_mask = (dfk_win['value'] > p95) | (dfk_win['value'] < p5)
        if anom_mask.any():
            earliest = dfk_win.loc[anom_mask, 'dt'].min().isoformat()
        else:
            earliest = pd.NA
        max_v = float(dfk_win['value'].max()) if count_window>0 else np.nan
        min_v = float(dfk_win['value'].min()) if count_window>0 else np.nan

        return {
            'kpi_name': kpi,
            'count_full': count_full,
            'global_P95': p95,
            'global_P5': p5,
            'count_window': count_window,
            'anomalies_high': anomalies_high,
            'anomalies_low': anomalies_low,
            'earliest_anomaly_ts': earliest,
            'max_value_window': max_v,
            'min_value_window': min_v
        }

    kpis = sorted(df_r['kpi_name'].unique())
    rows = [agg_kpi(k, df_r, window_r) for k in kpis]
    redis_summary = pd.DataFrame(rows)

    # Sort by total anomalies desc, tie-breaker earliest anomaly ts asc (NA last), limit 20
    redis_summary['anoms_total'] = redis_summary['anomalies_high'] + redis_summary['anomalies_low']
    # convert earliest_anomaly_ts to datetime for sorting where present
    redis_summary['earliest_sort'] = pd.to_datetime(redis_summary['earliest_anomaly_ts']).dt.tz_convert(tz)
    redis_summary = redis_summary.sort_values(by=['anoms_total', 'earliest_sort'], ascending=[False, True], na_position='last')
    redis_summary = redis_summary.head(20).reset_index(drop=True)
    redis_summary = redis_summary[[
        'kpi_name','count_full','global_P95','global_P5',
        'count_window','anomalies_high','anomalies_low','earliest_anomaly_ts',
        'max_value_window','min_value_window'
    ]]

    # Additionally, return raw rows in the incident window for kpi 'instantaneous_input_kbps' (limit 30)
    target_kpi = 'instantaneous_input_kbps'
    raw_k = window_r[window_r['kpi_name'] == target_kpi].copy()
    if raw_k.empty:
        raw_instant_rows = pd.DataFrame(columns=['timestamp','value','p95','p5'])
    else:
        # include P95 and P5 used for that KPI (global)
        p95_val = float(q.loc[q['kpi_name']==target_kpi, 'p95'].iloc[0])
        p5_val = float(q.loc[q['kpi_name']==target_kpi, 'p5'].iloc[0])
        raw_instant_rows = raw_k.sort_values('dt')[['dt','value']].head(30).copy()
        raw_instant_rows['timestamp'] = raw_instant_rows['dt'].dt.tz_convert(tz).apply(lambda x: x.isoformat())
        raw_instant_rows = raw_instant_rows[['timestamp','value']]
        # attach p95/p5 columns
        raw_instant_rows['p95'] = p95_val
        raw_instant_rows['p5'] = p5_val

# Display compact results: summary table and raw rows for instantaneous_input_kbps
redis_summary, raw_instant_rows
