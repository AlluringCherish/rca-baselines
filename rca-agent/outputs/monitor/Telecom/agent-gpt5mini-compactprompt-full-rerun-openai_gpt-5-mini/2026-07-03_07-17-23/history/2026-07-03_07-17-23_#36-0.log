import pandas as pd
import numpy as np
import pytz

# Reuse existing kernel variables if available
try:
    df_metric
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')
    df_metric = pd.read_csv('metric.csv')
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Ensure ts exists and timezone set
if 'ts' not in df_metric.columns:
    tz = pytz.timezone('Asia/Shanghai')
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Target cmdb_id
target = 'db_010'

# 1) Compute global P95 and P5 for each kpi_name of db_010 using full series (no time filter)
df_db010_full = df_metric[df_metric['cmdb_id'] == target]
if df_db010_full.empty:
    result_db010 = pd.DataFrame([{'message': 'no metrics for db_010'}])
else:
    thresh_db010 = (
        df_db010_full
        .groupby('kpi_name')['value']
        .quantile([0.95, 0.05])
        .unstack(level=-1)
        .rename(columns={0.95: 'global_P95', 0.05: 'global_P5'})
        .reset_index()
    )
    # 2) Filter to incident window and compute window stats per kpi_name
    start_ts = pd.Timestamp('2020-05-27 05:30', tz=tz)
    end_ts   = pd.Timestamp('2020-05-27 06:00', tz=tz)
    window_db010 = df_db010_full[(df_db010_full['ts'] >= start_ts) & (df_db010_full['ts'] <= end_ts)].copy()

    # Aggregate window stats per kpi_name
    if not window_db010.empty:
        agg_win = window_db010.groupby('kpi_name').agg(
            earliest_timestamp_in_window=('ts','min'),
            data_point_count=('ts','size'),
            max_value_in_window=('value','max'),
            min_value_in_window=('value','min'),
            breach_count_high=('value', lambda s: int((s >= 0).sum()))  # placeholder, will recalc after merge
        ).reset_index()
        # We'll drop placeholder breach_count_high and recalc after merge with thresholds
        agg_win = agg_win.drop(columns=['breach_count_high'])
    else:
        # create empty frame with kpi_name from thresholds
        agg_win = pd.DataFrame(columns=['kpi_name','earliest_timestamp_in_window','data_point_count','max_value_in_window','min_value_in_window'])

    # Merge thresholds with window aggregates to ensure one row per kpi_name
    merged = thresh_db010.merge(agg_win, on='kpi_name', how='left')

    # Fill missing numeric aggregates appropriately
    merged['data_point_count'] = merged['data_point_count'].fillna(0).astype(int)
    # compute breach counts by re-evaluating against thresholds using window_db010
    # prepare a helper group for counts if window not empty
    if not window_db010.empty:
        # map kpi_name -> series values in window for counting
        counts = window_db010.groupby('kpi_name')['value'].agg(
            breach_count_high=lambda s: int((s >= s.name and False).sum())  # placeholder overwritten below
        )  # not usable; we'll compute differently
        # compute real counts using groupby.apply
        bc = window_db010.groupby('kpi_name').apply(lambda g: pd.Series({
            'breach_count_high': int((g['value'] >= g['kpi_name'].map(merged.set_index('kpi_name')['global_P95'])).sum()),
            'breach_count_low' : int((g['value'] <= g['kpi_name'].map(merged.set_index('kpi_name')['global_P5'])).sum())
        })).reset_index()
    else:
        bc = pd.DataFrame(columns=['kpi_name','breach_count_high','breach_count_low'])

    merged = merged.merge(bc, on='kpi_name', how='left')
    merged['breach_count_high'] = merged['breach_count_high'].fillna(0).astype(int)
    merged['breach_count_low']  = merged['breach_count_low'].fillna(0).astype(int)

    # For KPIs with no window rows, set earliest and max/min to NaN
    merged['earliest_timestamp_in_window'] = pd.to_datetime(merged['earliest_timestamp_in_window'])
    # format timestamps for display; leave NaT as NaN/empty
    merged['earliest_timestamp_in_window'] = merged['earliest_timestamp_in_window'].dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    merged['earliest_timestamp_in_window'] = merged['earliest_timestamp_in_window'].fillna('')

    # Fill max/min NaNs remain NaN
    # 2) compute severities
    def compute_sev_high(row):
        gp95 = row['global_P95']
        mv = row['max_value_in_window']
        if pd.isna(mv) or pd.isna(gp95) or gp95 == 0:
            return np.nan
        return mv / gp95

    def compute_sev_low(row):
        gp5 = row['global_P5']
        mn = row['min_value_in_window']
        if pd.isna(mn) or pd.isna(gp5) or mn == 0:
            return np.nan
        return gp5 / mn

    merged['severity_high'] = merged.apply(compute_sev_high, axis=1)
