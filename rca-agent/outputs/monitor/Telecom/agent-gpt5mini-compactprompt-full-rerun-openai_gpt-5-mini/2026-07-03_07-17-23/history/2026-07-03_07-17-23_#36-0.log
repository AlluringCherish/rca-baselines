import pandas as pd
import numpy as np
import pytz

# Reuse existing df_metric, df_trace, tz from kernel
# Ensure they exist; if not, load (defensive)
try:
    df_metric
    df_trace
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')
    df_metric = pd.read_csv('metric.csv')
    df_trace = pd.read_csv('trace.csv')
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Metrics: compute global P95 and P5 per (cmdb_id,kpi_name) using full series
metric_thresh = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .quantile([0.95, 0.05])
    .unstack(level=-1)
    .rename(columns={0.95: 'global_P95', 0.05: 'global_P5'})
    .reset_index()
)

# Incident window in UTC+8
start_ts = pd.Timestamp('2020-05-27 05:30', tz=tz)
end_ts   = pd.Timestamp('2020-05-27 06:00', tz=tz)

# Filter metric rows to window
metric_window = df_metric[(df_metric['ts'] >= start_ts) & (df_metric['ts'] <= end_ts)].copy()

# Merge thresholds into window rows
metric_m = metric_window.merge(metric_thresh, on=['cmdb_id','kpi_name'], how='left')

# Determine breaches using precomputed global thresholds
metric_m['is_high'] = metric_m['value'] >= metric_m['global_P95']
metric_m['is_low']  = metric_m['value'] <= metric_m['global_P5']

# Aggregate per pair for those with any breach
if not metric_m.empty:
    metric_agg = (
        metric_m
        .groupby(['cmdb_id','kpi_name'], as_index=False)
        .agg(
            global_P95 = ('global_P95','first'),
            global_P5  = ('global_P5','first'),
            breach_count_high = ('is_high','sum'),
            breach_count_low  = ('is_low','sum'),
            total_breach_count = (lambda x: None, lambda df: None)  # placeholder overwritten below
        )
    )
    # compute total_breach_count, earliest breach timestamp, max/min in window
    # We need earliest breach timestamp where either is_high or is_low
    def compute_window_stats(group):
        any_high = int(group['is_high'].sum())
        any_low = int(group['is_low'].sum())
        total = any_high + any_low
        earliest = None
        if total > 0:
            earliest_ts = group.loc[group['is_high'] | group['is_low'], 'ts'].min()
            earliest = earliest_ts.tz_convert(tz)  # ensure tz
        max_val = group['value'].max()
        min_val = group['value'].min()
        return pd.Series({
            'breach_count_high': any_high,
            'breach_count_low': any_low,
            'total_breach_count': total,
            'earliest_breach_timestamp': earliest,
            'max_value_in_window': max_val,
            'min_value_in_window': min_val
        })

    metric_stats = metric_m.groupby(['cmdb_id','kpi_name']).apply(compute_window_stats).reset_index()

    # join with thresholds
    metric_result = metric_thresh.merge(metric_stats, on=['cmdb_id','kpi_name'], how='inner')

    # compute severities with safe divisions; if no high breach -> NaN; if global_P95==0 -> NaN
    metric_result['severity_high'] = np.where(
        metric_result['breach_count_high']>0,
        np.where(metric_result['global_P95']>0, metric_result['max_value_in_window']/metric_result['global_P95'], np.nan),
        np.nan
    )
    metric_result['severity_low'] = np.where(
        metric_result['breach_count_low']>0,
        np.where(metric_result['min_value_in_window']>0, metric_result['global_P5']/metric_result['min_value_in_window'], np.nan),
        np.nan
    )

    # format earliest timestamp as string for compactness
    metric_result['earliest_breach_timestamp'] = metric_result['earliest_breach_timestamp'].dt.strftime('%Y-%m-%d %H:%M:%S %Z')

    # keep only pairs with at least one breach
    metric_result = metric_result[metric_result['total_breach_count']>0]

    # select and order columns
    metric_result = metric_result[[
        'cmdb_id','kpi_name','global_P95','global_P5',
        'breach_count_high','breach_count_low','total_breach_count',
        'earliest_breach_timestamp','max_value_in_window','min_value_in_window',
        'severity_high','severity_low'
    ]]

    # sort and limit top 20
    metric_breaches_top20 = metric_result.sort_values(['total_breach_count','earliest_breach_timestamp'], ascending=[False, True]).head(20).reset_index(drop=True)
else:
    metric_breaches_top20 = pd.DataFrame()  # empty

# 2) Traces: analogous procedure
trace_thresh = (
    df_trace
    .groupby(['cmdb_id', 'trace_name'])['value']
    .quantile([0.95, 0.05])
    .unstack(level=-1)
    .rename(columns={0.95: 'global_P95', 0.05: 'global_P5'})
    .reset_index()
)

trace_window = df_trace[(df_trace['ts'] >= start_ts) & (df_trace['ts'] <= end_ts)].copy()
trace_m = trace_window.merge(trace_thresh, on=['cmdb_id','trace_name'], how='left')
trace_m['is_high'] = trace_m['value'] >= trace_m['global_P95']
trace_m['is_low']  = trace_m['value'] <= trace_m['global_P5']

if not trace_m.empty:
    def compute_window_stats_trace(group):
        any_high = int(group['is_high'].sum())
        any_low = int(group['is_low'].sum())
        total = any_high + any_low
        earliest = None
        if total > 0:
            earliest_ts = group.loc[group['is_high'] | group['is_low'], 'ts'].min()
            earliest = earliest_ts.tz_convert(tz)
        max_val = group['value'].max()
        min_val = group['value'].min()
        return pd.Series({
            'breach_count_high': any_high,
            'breach_count_low': any_low,
            'total_breach_count': total,
            'earliest_breach_timestamp': earliest,
            'max_value_in_window': max_val,
            'min_value_in_window': min_val
        })

    trace_stats = trace_m.groupby(['cmdb_id','trace_name']).apply(compute_window_stats_trace).reset_index()
    trace_result = trace_thresh.merge(trace_stats, on=['cmdb_id','trace_name'], how='inner')

    trace_result['severity_high'] = np.where(
        trace_result['breach_count_high']>0,
        np.where(trace_result['global_P95']>0, trace_result['max_value_in_window']/trace_result['global_P95'], np.nan),
        np.nan
    )
    trace_result['severity_low'] = np.where(
        trace_result['breach_count_low']>0,
        np.where(trace_result['min_value_in_window']>0, trace_result['global_P5']/trace_result['min_value_in_window'], np.nan),
        np.nan
    )

    trace_result['earliest_breach_timestamp'] = trace_result['earliest_breach_timestamp'].dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    trace_result = trace_result[trace_result['total_breach_count']>0]
    trace_result = trace_result[[
        'cmdb_id','trace_name','global_P95','global_P5',
        'breach_count_high','breach_count_low','total_breach_count',
        'earliest_breach_timestamp','max_value_in_window','min_value_in_window',
        'severity_high','severity_low'
    ]]
    trace_breaches_top20 = trace_result.sort_values(['total_breach_count','earliest_breach_timestamp'], ascending=[False, True]).head(20).reset_index(drop=True)
else:
    trace_breaches_top20 = pd.DataFrame()

# 3) If no rows for either, return explicit indicator string(s)
if metric_breaches_top20.empty:
    metric_breaches_top20 = pd.DataFrame([{
        'message': 'No P95/P5 breaches found in metric window (May 27 2020 05:30-06:00 UTC+8).'
    }])

if trace_breaches_top20.empty:
    trace_breaches_top20 = pd.DataFrame([{
        'message': 'No P95/P5 breaches found in trace window (May 27 2020 05:30-06:00 UTC+8).'
    }])

# Display compact results (top-20 tables)
metric_breaches_top20, trace_breaches_top20
