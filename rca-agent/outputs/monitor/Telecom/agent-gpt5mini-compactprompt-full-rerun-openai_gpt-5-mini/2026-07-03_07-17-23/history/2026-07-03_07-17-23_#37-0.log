import pandas as pd
import pytz

# reuse existing metric_df if present in the kernel
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

tz = pytz.timezone('Asia/Shanghai')

# 1) Calculate global P95, P5, and total points for each (cmdb_id, kpi_name) across the full series
grouped = metric_df.groupby(['cmdb_id', 'kpi_name'])['value']
agg_full = grouped.agg(
    total_points_full_series = 'count',
    p95 = lambda x: x.quantile(0.95),
    p5  = lambda x: x.quantile(0.05)
).reset_index()

# 2) Define incident window in Asia/Shanghai and convert to epoch seconds (UTC) for filtering
start_local = pd.Timestamp('2020-05-28 00:30:00', tz=tz)
end_local   = pd.Timestamp('2020-05-28 01:00:00', tz=tz)
start_sec = int(start_local.tz_convert(pytz.utc).timestamp())
end_sec   = int(end_local.tz_convert(pytz.utc).timestamp())

window_df = metric_df[(metric_df['timestamp'] >= start_sec) & (metric_df['timestamp'] <= end_sec)].copy()

# 3) For series that have any points in the incident window, compute anomaly counts using global thresholds
if not window_df.empty:
    # attach global thresholds to window rows
    win = window_df.merge(agg_full, on=['cmdb_id','kpi_name'], how='left')
    
    def summarize_window(g):
        total_points_full_series = int(g['total_points_full_series'].iat[0])
        p95 = float(g['p95'].iat[0])
        p5  = float(g['p5'].iat[0])
        number_of_points_in_window = int(g.shape[0])
        number_of_high_anomalies = int((g['value'] >= p95).sum())
        number_of_low_anomalies  = int((g['value'] <= p5).sum())
        total_anomalies = number_of_high_anomalies + number_of_low_anomalies
        if total_anomalies > 0:
            earliest_ts = int(g.loc[(g['value'] >= p95) | (g['value'] <= p5), 'timestamp'].min())
            earliest_anom = pd.to_datetime(earliest_ts, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z%z')
        else:
            earliest_anom = None
        return pd.Series({
            'total_points_full_series': total_points_full_series,
            'p95': p95,
            'p5': p5,
            'number_of_points_in_window': number_of_points_in_window,
            'number_of_high_anomalies': number_of_high_anomalies,
            'number_of_low_anomalies': number_of_low_anomalies,
            'total_anomalies': total_anomalies,
            'earliest_anomaly_timestamp_in_window': earliest_anom
        })
    
    summary_df = win.groupby(['cmdb_id','kpi_name']).apply(summarize_window).reset_index()
else:
    # no rows in window -> empty summary_df with appropriate columns
    summary_df = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','total_points_full_series','p95','p5',
        'number_of_points_in_window','number_of_high_anomalies',
        'number_of_low_anomalies','total_anomalies','earliest_anomaly_timestamp_in_window'
    ])

# 4) Select top 20 by total_anomalies (desc). If no anomalies at all, fallback to top 20 by number_of_points_in_window.
if summary_df.shape[0] > 0:
    if summary_df['total_anomalies'].sum() == 0:
        top_df = summary_df.sort_values(by=['number_of_points_in_window','total_points_full_series'], ascending=[False, False]).head(20)
    else:
        top_df = summary_df.sort_values(by=['total_anomalies','number_of_points_in_window'], ascending=[False, False]).head(20)
else:
    # no series in window; produce top 20 series by points in full series as fallback, with zero window stats
    fallback = agg_full.sort_values(by='total_points_full_series', ascending=False).head(20).copy()
    fallback['number_of_points_in_window'] = 0
    fallback['number_of_high_anomalies'] = 0
    fallback['number_of_low_anomalies'] = 0
    fallback['total_anomalies'] = 0
    fallback['earliest_anomaly_timestamp_in_window'] = None
    fallback = fallback.rename(columns={'total_points_full_series':'total_points_full_series','p95':'p95','p5':'p5'})
    top_df = fallback[['cmdb_id','kpi_name','total_points_full_series','p95','p5',
                       'number_of_points_in_window','number_of_high_anomalies',
                       'number_of_low_anomalies','total_anomalies','earliest_anomaly_timestamp_in_window']]

# 5) Overall counts
total_distinct_series = int(agg_full.shape[0])
total_rows_in_window = int(window_df.shape[0])

# Compact result object
result = {
    'top_20_by_anomalies_or_points': top_df,
    'total_distinct_series_processed': total_distinct_series,
    'total_metric_rows_in_incident_window': total_rows_in_window,
    'incident_window_epoch_seconds_utc': {'start': start_sec, 'end': end_sec},
    'incident_window_asia_shanghai': {'start': start_local.strftime('%Y-%m-%d %H:%M:%S %Z%z'),
                                      'end': end_local.strftime('%Y-%m-%d %H:%M:%S %Z%z')}
}

# display compact result (DataFrame is limited to top 20)
result
