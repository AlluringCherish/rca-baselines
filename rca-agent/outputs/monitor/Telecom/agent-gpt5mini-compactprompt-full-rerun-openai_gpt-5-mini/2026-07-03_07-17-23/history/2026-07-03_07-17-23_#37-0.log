import pandas as pd
import pytz

# reuse metric_df if present
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

tz = pytz.timezone('Asia/Shanghai')

# 1) Compute global P95 and P5 and total points per (cmdb_id, kpi_name) from the full series
agg_full = metric_df.groupby(['cmdb_id','kpi_name'])['value'].agg(
    total_points_full_series='count',
    p95=lambda x: x.quantile(0.95),
    p5 = lambda x: x.quantile(0.05)
).reset_index()

# 2) Filter incident window (inclusive) using provided epoch seconds
start_sec = 1590597000
end_sec   = 1590598800
window_df = metric_df[(metric_df['timestamp'] >= start_sec) & (metric_df['timestamp'] <= end_sec)].copy()

# 3) Merge global thresholds into window rows and mark anomaly if value >= p95 OR value <= p5 (count each row at most once)
if not window_df.empty:
    win = window_df.merge(agg_full, on=['cmdb_id','kpi_name'], how='left')
    # boolean anomaly marker (OR), each row at most once
    win['is_anomaly'] = (win['value'] >= win['p95']) | (win['value'] <= win['p5'])
else:
    win = window_df.copy()
    win['is_anomaly'] = pd.Series(dtype=bool)

# 4) Aggregate to component (cmdb_id) level
# total_unique_anomalous_points_in_window: distinct timestamps where is_anomaly True for that cmdb_id
anom_rows = win[win['is_anomaly']].copy()
# distinct timestamps per component
unique_anom_ts = anom_rows.groupby('cmdb_id')['timestamp'].nunique().rename('total_unique_anomalous_points_in_window').reset_index()

# number_of_kpis_with_any_anomaly per component
kpi_anom = anom_rows.groupby(['cmdb_id','kpi_name']).size().reset_index(name='cnt')
num_kpis_with_anom = kpi_anom.groupby('cmdb_id')['kpi_name'].nunique().rename('number_of_kpis_with_any_anomaly').reset_index()

# total_points_in_window per component (all KPI rows)
points_in_window = win.groupby('cmdb_id').size().rename('total_points_in_window').reset_index()

# earliest anomaly timestamp per component
earliest_anom_ts = anom_rows.groupby('cmdb_id')['timestamp'].min().rename('earliest_anomaly_timestamp_epoch').reset_index()
# convert to Asia/Shanghai formatted string
if not earliest_anom_ts.empty:
    earliest_anom_ts['earliest_anomaly_timestamp_in_window'] = earliest_anom_ts['earliest_anomaly_timestamp_epoch'].apply(
        lambda t: pd.to_datetime(int(t), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z%z')
    )
else:
    earliest_anom_ts['earliest_anomaly_timestamp_in_window'] = []

# merge component-level aggregates
comp_agg = points_in_window.merge(unique_anom_ts, on='cmdb_id', how='left') \
                           .merge(num_kpis_with_anom, on='cmdb_id', how='left') \
                           .merge(earliest_anom_ts[['cmdb_id','earliest_anomaly_timestamp_in_window']], on='cmdb_id', how='left')

# fill NaNs for components with no anomalies
comp_agg['total_unique_anomalous_points_in_window'] = comp_agg['total_unique_anomalous_points_in_window'].fillna(0).astype(int)
comp_agg['number_of_kpis_with_any_anomaly'] = comp_agg['number_of_kpis_with_any_anomaly'].fillna(0).astype(int)
comp_agg['total_points_in_window'] = comp_agg['total_points_in_window'].astype(int)
comp_agg['earliest_anomaly_timestamp_in_window'] = comp_agg['earliest_anomaly_timestamp_in_window'].where(
    comp_agg['total_unique_anomalous_points_in_window']>0, None
)

# 5) Top 20 cmdb_id by total_unique_anomalous_points_in_window (desc), tie-breaker by total_points_in_window desc
top20_components = comp_agg.sort_values(
    by=['total_unique_anomalous_points_in_window','total_points_in_window'],
    ascending=[False, False]
).head(20).reset_index(drop=True)

# Overall counts
total_components_with_anomaly = int((comp_agg['total_unique_anomalous_points_in_window'] > 0).sum())
# total anomalous rows in window (each row marked anomaly counted once)
total_anomalous_rows_in_window = int(win['is_anomaly'].sum())

# Compact result object
result = {
    'top20_components_by_unique_anomalous_timestamps': top20_components[['cmdb_id',
                                                                          'total_unique_anomalous_points_in_window',
                                                                          'number_of_kpis_with_any_anomaly',
                                                                          'total_points_in_window',
                                                                          'earliest_anomaly_timestamp_in_window']],
    'total_components_with_at_least_one_anomalous_point': total_components_with_anomaly,
    'total_anomalous_rows_in_window': total_anomalous_rows_in_window,
    'incident_window_epoch_seconds_utc': {'start': start_sec, 'end': end_sec},
    'incident_window_asia_shanghai': {'start': pd.to_datetime(start_sec, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z%z'),
                                      'end': pd.to_datetime(end_sec, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z%z')}
}

