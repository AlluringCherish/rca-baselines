import pandas as pd
import numpy as np
import pytz

# reuse metric_df if present
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

tz = pytz.timezone('Asia/Shanghai')

# Incident window (epoch seconds UTC)
start_sec = 1590597000
end_sec   = 1590598800

# Filter for db_* components and kpi_name == 'Hang' (from full dataset to get all db_* with this KPI)
db_hang_all = metric_df[(metric_df['cmdb_id'].str.startswith('db_')) & (metric_df['kpi_name'] == 'Hang')].copy()

# Unique db components to report (those that have the Hang KPI at all)
db_components = pd.Series(db_hang_all['cmdb_id'].unique()).sort_values().reset_index(drop=True)

# Filter to incident window
db_hang_window = db_hang_all[(db_hang_all['timestamp'] >= start_sec) & (db_hang_all['timestamp'] <= end_sec)].copy()
db_hang_window['timestamp'] = db_hang_window['timestamp'].astype(int)

# helper for robust equality to 1 (float tolerant)
is_one = lambda s: np.isclose(s, 1.0)

# function to compute longest consecutive run (timestamps in seconds, contiguous if diff==60)
def longest_consecutive_run(sorted_ts):
    if len(sorted_ts) == 0:
        return 0
    # dedupe and sort
    ts = np.unique(sorted_ts)
    if ts.size == 0:
        return 0
    max_run = 1
    cur_run = 1
    prev = ts[0]
    for t in ts[1:]:
        if int(t) - int(prev) == 60:
            cur_run += 1
        else:
            cur_run = 1
        if cur_run > max_run:
            max_run = cur_run
        prev = t
    return int(max_run)

# Aggregate per db component
rows = []
for cmdb in db_components:
    comp_rows = db_hang_window[db_hang_window['cmdb_id'] == cmdb]
    total_points_in_window = int(comp_rows.shape[0])
    # points where Hang == 1 (use is_one)
    comp_rows['is_one'] = is_one(comp_rows['value'].values)
    ones = comp_rows[comp_rows['is_one']]
    number_of_points_where_Hang_equals_1 = int(ones.shape[0])
    if number_of_points_where_Hang_equals_1 > 0:
        earliest_ts_epoch = int(ones['timestamp'].min())
        latest_ts_epoch = int(ones['timestamp'].max())
        earliest_ts_str = pd.to_datetime(earliest_ts_epoch, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z%z')
        latest_ts_str = pd.to_datetime(latest_ts_epoch, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z%z')
        longest_run = longest_consecutive_run(ones['timestamp'].values)
    else:
        earliest_ts_epoch = None
        latest_ts_epoch = None
        earliest_ts_str = None
        latest_ts_str = None
        longest_run = 0
    rows.append({
        'cmdb_id': cmdb,
        'total_points_in_window': total_points_in_window,
        'number_of_points_where_Hang_equals_1': number_of_points_where_Hang_equals_1,
        'earliest_timestamp_in_window_where_Hang_equals_1': earliest_ts_str,
        'latest_timestamp_in_window_where_Hang_equals_1': latest_ts_str,
        'earliest_ts_epoch_for_sort': earliest_ts_epoch if earliest_ts_epoch is not None else np.nan,
        'longest_consecutive_run_length_of_Hang_equal_1_within_window': longest_run
    })

result_df = pd.DataFrame(rows)

# Sort by earliest timestamp ascending, putting None/NaN at the end
result_df = result_df.sort_values(by='earliest_ts_epoch_for_sort', ascending=True, na_position='last').reset_index(drop=True)

# Limit to top 50 rows for display
result_df_top50 = result_df[['cmdb_id',
                             'total_points_in_window',
                             'number_of_points_where_Hang_equals_1',
                             'earliest_timestamp_in_window_where_Hang_equals_1',
                             'latest_timestamp_in_window_where_Hang_equals_1',
                             'longest_consecutive_run_length_of_Hang_equal_1_within_window']].head(50)

# Overall counts
total_db_components_with_any_Hang_eq_1 = int((result_df['number_of_points_where_Hang_equals_1'] > 0).sum())
# overall earliest Hang==1 across all db_* components (epoch -> formatted)
all_earliest_epochs = result_df['earliest_ts_epoch_for_sort'].dropna().astype(int)
if not all_earliest_epochs.empty:
    overall_earliest_epoch = int(all_earliest_epochs.min())
    overall_earliest_timestamp = pd.to_datetime(overall_earliest_epoch, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z%z')
else:
    overall_earliest_epoch = None
    overall_earliest_timestamp = None

summary = {
    'total_db_components_with_Hang_eq_1_in_window': total_db_components_with_any_Hang_eq_1,
    'overall_earliest_Hang_eq_1_timestamp_across_all_db_components': overall_earliest_timestamp,
