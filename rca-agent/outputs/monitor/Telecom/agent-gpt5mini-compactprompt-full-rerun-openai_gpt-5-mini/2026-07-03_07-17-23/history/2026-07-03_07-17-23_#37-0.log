import pandas as pd
import pytz

# load data (files are in current working directory)
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")

# timezone (UTC+8)
tz = pytz.timezone('Asia/Shanghai')

# --- metric.csv summaries ---
# unique cmdb ids: count and sample (limit 20)
metric_unique_cmdb = pd.Series(metric_df['cmdb_id'].unique()[:20])
metric_unique_cmdb_count = metric_df['cmdb_id'].nunique()

# kpi_name counts (top 20)
metric_kpi_counts = metric_df['kpi_name'].value_counts().rename_axis('kpi_name').reset_index(name='count').head(20)

# file-level min/max timestamps converted to Asia/Shanghai (UTC+8)
if metric_df.shape[0] > 0:
    metric_min_ts = pd.to_datetime(metric_df['timestamp'].min(), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z%z')
    metric_max_ts = pd.to_datetime(metric_df['timestamp'].max(), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z%z')
else:
    metric_min_ts = None
    metric_max_ts = None

# up to first 5 rows (compact)
metric_head5 = metric_df.head(5)

# total record count
metric_total_records = metric_df.shape[0]

# --- trace.csv summaries ---
trace_unique_cmdb = pd.Series(trace_df['cmdb_id'].unique()[:20])
trace_unique_cmdb_count = trace_df['cmdb_id'].nunique()

trace_name_counts = trace_df['trace_name'].value_counts().rename_axis('trace_name').reset_index(name='count').head(20)

if trace_df.shape[0] > 0:
    trace_min_ts = pd.to_datetime(trace_df['timestamp'].min(), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z%z')
    trace_max_ts = pd.to_datetime(trace_df['timestamp'].max(), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z%z')
else:
    trace_min_ts = None
    trace_max_ts = None

trace_head5 = trace_df.head(5)
trace_total_records = trace_df.shape[0]

# compact summary object (small JSON-like dict). DataFrames included are already limited (top/head).
summary = {
    "metric": {
        "unique_cmdb_count": int(metric_unique_cmdb_count),
        "unique_cmdb_sample_up_to_20": metric_unique_cmdb.reset_index(drop=True),
        "kpi_name_top20_counts": metric_kpi_counts,
        "file_min_timestamp_asia_shanghai": metric_min_ts,
        "file_max_timestamp_asia_shanghai": metric_max_ts,
        "first_5_rows": metric_head5,
        "total_records": int(metric_total_records)
    },
    "trace": {
        "unique_cmdb_count": int(trace_unique_cmdb_count),
        "unique_cmdb_sample_up_to_20": trace_unique_cmdb.reset_index(drop=True),
        "trace_name_top20_counts": trace_name_counts,
        "file_min_timestamp_asia_shanghai": trace_min_ts,
        "file_max_timestamp_asia_shanghai": trace_max_ts,
        "first_5_rows": trace_head5,
        "total_records": int(trace_total_records)
    }
}

# Display the compact summary object
