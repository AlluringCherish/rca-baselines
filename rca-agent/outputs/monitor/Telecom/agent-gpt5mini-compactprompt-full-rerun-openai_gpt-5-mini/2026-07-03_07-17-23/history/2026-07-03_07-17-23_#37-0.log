import pandas as pd
import pytz

# reuse trace_df if present
try:
    trace_df
except NameError:
    trace_df = pd.read_csv("trace.csv")

tz = pytz.timezone('Asia/Shanghai')

# window (given)
start_sec = 1590597000
end_sec = 1590598800

# 1) global P95 and P5 per (cmdb_id, trace_name) using full trace.csv
agg_full_trace = trace_df.groupby(['cmdb_id','trace_name'])['value'].agg(
    total_points='count',
    p95=lambda x: x.quantile(0.95),
    p5 = lambda x: x.quantile(0.05)
).reset_index()

# 2) filter to incident window and mark anomalies
trace_window = trace_df[(trace_df['timestamp'] >= start_sec) & (trace_df['timestamp'] <= end_sec)].copy()
# attach thresholds
trace_window = trace_window.merge(agg_full_trace, on=['cmdb_id','trace_name'], how='left')

# anomaly rules: value >= p95 OR value <= p5 OR (trace_name contains 'error_rate' AND value > 0)
is_error_rate = trace_window['trace_name'].str.contains('error_rate', case=False, na=False)
trace_window['is_anomaly'] = (
    (trace_window['value'] >= trace_window['p95']) |
    (trace_window['value'] <= trace_window['p5']) |
    (is_error_rate & (trace_window['value'] > 0))
)

# 3) Aggregate anomalies by cmdb_id
anom_rows = trace_window[trace_window['is_anomaly']].copy()

# distinct anomalous timestamps per component
unique_anom_ts = anom_rows.groupby('cmdb_id')['timestamp'].nunique().rename('total_unique_anomalous_timestamps').reset_index()

# number of trace_names with any anomaly per component
trace_names_with_anom = anom_rows.groupby(['cmdb_id','trace_name']).size().reset_index(name='anom_count')
num_trace_names_with_anom = trace_names_with_anom.groupby('cmdb_id')['trace_name'].nunique().rename('number_of_trace_names_with_any_anomaly').reset_index()

# total trace rows in window per component
total_rows_comp = trace_window.groupby('cmdb_id').size().rename('total_trace_rows_in_window').reset_index()

# earliest anomalous timestamp per component
if not anom_rows.empty:
    earliest_anom = anom_rows.groupby('cmdb_id')['timestamp'].min().reset_index().rename(columns={'timestamp':'earliest_anomalous_timestamp_epoch'})
    earliest_anom['earliest_anomalous_timestamp_in_window'] = earliest_anom['earliest_anomalous_timestamp_epoch'].apply(
        lambda t: pd.to_datetime(int(t), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z%z')
    )
else:
    earliest_anom = pd.DataFrame(columns=['cmdb_id','earliest_anomalous_timestamp_epoch','earliest_anomalous_timestamp_in_window'])

# merge component-level aggregates
comp_agg = total_rows_comp.merge(unique_anom_ts, on='cmdb_id', how='left') \
                          .merge(num_trace_names_with_anom, on='cmdb_id', how='left') \
                          .merge(earliest_anom[['cmdb_id','earliest_anomalous_timestamp_in_window']], on='cmdb_id', how='left')

# fill NaNs
comp_agg['total_unique_anomalous_timestamps'] = comp_agg['total_unique_anomalous_timestamps'].fillna(0).astype(int)
comp_agg['number_of_trace_names_with_any_anomaly'] = comp_agg['number_of_trace_names_with_any_anomaly'].fillna(0).astype(int)
comp_agg['total_trace_rows_in_window'] = comp_agg['total_trace_rows_in_window'].astype(int)
comp_agg['earliest_anomalous_timestamp_in_window'] = comp_agg['earliest_anomalous_timestamp_in_window'].where(
    comp_agg['total_unique_anomalous_timestamps']>0, None
)

# 4) Top 10 cmdb_id by total_unique_anomalous_timestamps
top10_components = comp_agg.sort_values(
    by=['total_unique_anomalous_timestamps','total_trace_rows_in_window'],
    ascending=[False, False]
).head(10).reset_index(drop=True)

# For these top components, list up to 10 anomalous trace_names with counts and type
if not trace_names_with_anom.empty:
    trace_names_with_anom['type'] = trace_names_with_anom['trace_name'].apply(
        lambda s: 'error_rate' if 'error_rate' in s else ('duration' if 'duration' in s else ('row_count' if 'row_count' in s else 'other'))
    )
    # filter to top components and take top 10 trace_names per component by anom_count
    top_cmdbs = top10_components['cmdb_id'].tolist()
    top_traces_candidates = trace_names_with_anom[trace_names_with_anom['cmdb_id'].isin(top_cmdbs)].copy()
    top_traces_candidates = top_traces_candidates.sort_values(['cmdb_id','anom_count'], ascending=[True, False])
    # keep up to 10 per component
    top_traces_per_comp = top_traces_candidates.groupby('cmdb_id').head(10).reset_index(drop=True)
else:
    top_traces_per_comp = pd.DataFrame(columns=['cmdb_id','trace_name','anom_count','type'])

# 5) overall totals
total_distinct_pairs = int(agg_full_trace.shape[0])
total_trace_rows_in_window = int(trace_window.shape[0])
total_anomalous_trace_rows = int(trace_window['is_anomaly'].sum())

# Compact result
result = {
