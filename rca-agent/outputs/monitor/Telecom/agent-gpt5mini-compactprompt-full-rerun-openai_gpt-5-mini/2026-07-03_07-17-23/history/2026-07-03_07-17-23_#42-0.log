    docker_list = [f"docker_{i:03d}" for i in range(1, 9)]
    db_list = [f"db_{i:03d}" for i in range(1, 14)]
    allowed_list = set(os_list + docker_list + db_list)

# timezone and window
tz = pytz.timezone("Asia/Shanghai")
def to_local(ts_int):
    return pd.to_datetime(int(ts_int), unit="s", utc=True).tz_convert(tz).strftime("%Y-%m-%d %H:%M:%S %Z")

start_ts = 1590768000
end_ts = 1590769800

# Diagnostic computation with error capture
error_message = None
try:
    # 1) total rows
    total_trace_rows_all = int(trace_df.shape[0])

    # 2) total distinct series overall
    total_trace_series_all = int(trace_df[['cmdb_id', 'trace_name']].drop_duplicates().shape[0])

    # 3) rows where cmdb_id in allowed set
    mask_allowed = trace_df['cmdb_id'].isin(allowed_list)
    trace_allowed_df = trace_df[mask_allowed].copy()
    total_trace_rows_allowed_cmdb = int(trace_allowed_df.shape[0])

    # 4) distinct series for allowed cmdb_ids
    total_trace_series_allowed = int(trace_allowed_df[['cmdb_id', 'trace_name']].drop_duplicates().shape[0])

    # 5) per_series_nonzeroP95_count: compute global P95 per (cmdb_id, trace_name) using full allowed_trace_df
    if total_trace_series_allowed > 0:
        gp = (
            trace_allowed_df
            .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
            .quantile(0.95)
            .rename(columns={'value': 'global_p95'})
        )
        per_series_nonzeroP95_count = int((gp['global_p95'] > 0).sum())
    else:
        gp = pd.DataFrame(columns=['cmdb_id','trace_name','global_p95'])
        per_series_nonzeroP95_count = 0

    # 6) in-window rows among allowed
    in_window_mask = (trace_allowed_df['timestamp'] >= start_ts) & (trace_allowed_df['timestamp'] <= end_ts)
    in_window_rows_allowed = int(trace_allowed_df[in_window_mask].shape[0])

    # 7) anomaly_rows_strict: merge in-window rows with nonzero global_p95 series and count value > global_p95
    gp_nonzero = gp[gp['global_p95'] > 0].copy()
    if gp_nonzero.shape[0] > 0 and in_window_rows_allowed > 0:
        window_allowed_df = trace_allowed_df[in_window_mask].copy()
        merged = window_allowed_df.merge(gp_nonzero, on=['cmdb_id', 'trace_name'], how='inner')
        # count strict >
        anomalies_strict_df = merged[merged['value'] > merged['global_p95']].copy()
        anomaly_rows_strict = int(anomalies_strict_df.shape[0])
    else:
        merged = pd.DataFrame()  # empty
        anomalies_strict_df = pd.DataFrame()
        anomaly_rows_strict = 0

    # 8) sample_anomaly_rows: up to 10 earliest anomaly rows with requested fields
    sample_anomaly_rows = []
    if anomaly_rows_strict > 0:
        sample = anomalies_strict_df.sort_values('timestamp', ascending=True).head(10)
        # select and coerce native types + add local time string
        sample_sel = sample[['timestamp', 'cmdb_id', 'trace_name', 'value', 'global_p95']].copy()
        sample_sel['timestamp'] = sample_sel['timestamp'].astype(int)
        sample_sel['value'] = sample_sel['value'].astype(float)
        sample_sel['global_p95'] = sample_sel['global_p95'].astype(float)
        sample_sel['local_time'] = sample_sel['timestamp'].apply(to_local)
        sample_anomaly_rows = sample_sel.to_dict(orient='records')
    else:
        sample_anomaly_rows = []

except Exception as e:
    # On exception, set fields to safe defaults and capture error
    total_trace_rows_all = int(trace_df.shape[0]) if 'trace_df' in globals() else None
    total_trace_series_all = None
    total_trace_rows_allowed_cmdb = None
    total_trace_series_allowed = None
    per_series_nonzeroP95_count = None
    in_window_rows_allowed = None
    anomaly_rows_strict = None
    sample_anomaly_rows = []
    error_message = str(e)

# Final compact diagnostic JSON-serializable object
diagnostic = {
    "total_trace_rows_all": total_trace_rows_all,
    "total_trace_series_all": total_trace_series_all,
    "total_trace_rows_allowed_cmdb": total_trace_rows_allowed_cmdb,
    "total_trace_series_allowed": total_trace_series_allowed,
    "per_series_nonzeroP95_count": per_series_nonzeroP95_count,
    "in_window_rows_allowed": in_window_rows_allowed,
    "anomaly_rows_strict": anomaly_rows_strict,
    "sample_anomaly_rows": sample_anomaly_rows,
    "error_message": error_message
}

