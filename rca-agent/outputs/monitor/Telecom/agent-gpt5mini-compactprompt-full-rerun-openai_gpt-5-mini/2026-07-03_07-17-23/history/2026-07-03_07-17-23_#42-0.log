import pandas as pd
import numpy as np
import pytz

# reuse metric_df if present
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

# Allowed component lists (reuse if present)
try:
    allowed_list
except NameError:
    os_list = [f"os_{i:03d}" for i in range(1, 23)]
    docker_list = [f"docker_{i:03d}" for i in range(1, 9)]
    db_list = [f"db_{i:03d}" for i in range(1, 14)]
    allowed_list = set(os_list + docker_list + db_list)

# timezone (UTC+8)
tz = pytz.timezone("Asia/Shanghai")
def to_local(ts):
    if ts is None or (isinstance(ts, float) and np.isnan(ts)):
        return None
    return pd.to_datetime(int(ts), unit="s", utc=True).tz_convert(tz).strftime("%Y-%m-%d %H:%M:%S %Z")

# Incident window
start_ts = 1590768000
end_ts = 1590769800

# 1) Restrict metric to allowed components
allowed_metric_df = metric_df[metric_df['cmdb_id'].isin(allowed_list)].copy()

# 2) Compute global P95 per (cmdb_id, kpi_name) across full series (required by rule)
metric_gp = (
    allowed_metric_df
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# 3) Filter to incident window (for counting anomalies and window stats)
window_metric = allowed_metric_df[
    (allowed_metric_df['timestamp'] >= start_ts) &
    (allowed_metric_df['timestamp'] <= end_ts)
].copy()

# Merge global p95 into window rows
window_with_p95 = window_metric.merge(metric_gp, on=['cmdb_id', 'kpi_name'], how='left')

# 4) Mark metric anomaly points using value >= global_p95 (as used earlier)
window_with_p95['is_anomaly'] = window_with_p95['value'] >= window_with_p95['global_p95']

# 5) Per-series (cmdb_id,kpi_name) aggregations in-window
series_agg = (
    window_with_p95
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        window_count=('value', 'size'),
        anomaly_count=('is_anomaly', 'sum')
    )
)

# anomaly-specific aggregates (earliest anomaly timestamp and max anomaly value)
anomaly_only = window_with_p95[window_with_p95['is_anomaly']].copy()
anomaly_stats = (
    anomaly_only
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        earliest_anomaly_timestamp_raw=('timestamp', 'min'),
        max_anomaly_value=('value', 'max')
    )
)

# Build KPI-level summary by merging global p95, series_agg, anomaly_stats
kpi_summary = metric_gp.merge(series_agg, on=['cmdb_id', 'kpi_name'], how='left')
kpi_summary = kpi_summary.merge(anomaly_stats, on=['cmdb_id', 'kpi_name'], how='left')

kpi_summary['window_count'] = kpi_summary['window_count'].fillna(0).astype(int)
kpi_summary['anomaly_count'] = kpi_summary['anomaly_count'].fillna(0).astype(int)
kpi_summary['earliest_anomaly_timestamp_raw'] = kpi_summary['earliest_anomaly_timestamp_raw'].where(kpi_summary['earliest_anomaly_timestamp_raw'].notna(), None)
kpi_summary['max_anomaly_value'] = kpi_summary['max_anomaly_value'].where(kpi_summary['max_anomaly_value'].notna(), None)

# 6) breach_ratio per KPI: if no max_anomaly_value -> 0; if global_p95 == 0 -> use max_anomaly_value; else max_anomaly_value / global_p95
def breach_ratio_row(r):
    mv = r['max_anomaly_value']
    gp = r['global_p95']
    if mv is None or (isinstance(mv, float) and np.isnan(mv)):
        return 0.0
    if gp is None or (isinstance(gp, float) and np.isnan(gp)):
        return float(mv)
    try:
        if gp == 0:
            return float(mv)
        else:
            return float(mv) / float(gp)
    except Exception:
        return float(mv)

kpi_summary['breach_ratio'] = kpi_summary.apply(breach_ratio_row, axis=1)
kpi_summary['earliest_anomaly_local'] = kpi_summary['earliest_anomaly_timestamp_raw'].apply(lambda x: to_local(x) if x is not None else None)

# 7) Component-level aggregations
comp_stats = (
    kpi_summary
    .groupby('cmdb_id', as_index=False)
    .agg(
        total_kpis_scanned=('kpi_name', 'nunique'),
        num_kpis_with_anomalies=('anomaly_count', lambda s: int((s>0).sum())),
        total_metric_anomaly_points=('anomaly_count', 'sum')
    )
)

# 8) For top_kpi per component: pick KPI with maximum breach_ratio; tie-breaker use anomaly_count then max_anomaly_value
kpi_best = (
    kpi_summary
    .sort_values(['cmdb_id', 'breach_ratio', 'anomaly_count', 'max_anomaly_value'], ascending=[True, False, False, False])
    .groupby('cmdb_id', as_index=False)
    .first()
    .rename(columns={
        'kpi_name': 'top_kpi_name',
        'global_p95': 'top_kpi_global_p95',
        'max_anomaly_value': 'top_kpi_max_anomaly_value',
        'breach_ratio': 'top_kpi_breach_ratio',
        'earliest_anomaly_timestamp_raw': 'top_kpi_earliest_anomaly_timestamp_raw',
        'earliest_anomaly_local': 'top_kpi_earliest_anomaly_local'
    })
)

# 9) Combine component stats with top KPI info
comp_combined = comp_stats.merge(kpi_best[['cmdb_id','top_kpi_name','top_kpi_global_p95','top_kpi_max_anomaly_value','top_kpi_breach_ratio','top_kpi_earliest_anomaly_timestamp_raw','top_kpi_earliest_anomaly_local']], on='cmdb_id', how='left')

# Ensure types and fill NaNs
comp_combined['top_kpi_global_p95'] = comp_combined['top_kpi_global_p95'].where(comp_combined['top_kpi_global_p95'].notna(), None)
comp_combined['top_kpi_max_anomaly_value'] = comp_combined['top_kpi_max_anomaly_value'].where(comp_combined['top_kpi_max_anomaly_value'].notna(), None)
comp_combined['top_kpi_breach_ratio'] = comp_combined['top_kpi_breach_ratio'].fillna(0.0).astype(float)
comp_combined['top_kpi_earliest_anomaly_local'] = comp_combined['top_kpi_earliest_anomaly_local'].where(comp_combined['top_kpi_earliest_anomaly_local'].notna(), None)
comp_combined['top_kpi_earliest_anomaly_timestamp_raw'] = comp_combined['top_kpi_earliest_anomaly_timestamp_raw'].where(comp_combined['top_kpi_earliest_anomaly_timestamp_raw'].notna(), None)

# 10) Sort by top_kpi_breach_ratio desc, tie-breaker by total_metric_anomaly_points desc
comp_ranked = comp_combined.sort_values(['top_kpi_breach_ratio', 'total_metric_anomaly_points'], ascending=[False, False]).head(20).reset_index(drop=True)

# 11) Scalars
total_components_with_any_metric_anomaly = int((comp_combined['num_kpis_with_anomalies'] > 0).sum())
overall_total_metric_anomaly_points = int(comp_combined['total_metric_anomaly_points'].sum())

# Keep final output compact: selected columns
out_cols = [
    'cmdb_id',
    'top_kpi_name',
    'top_kpi_global_p95',
    'top_kpi_max_anomaly_value',
    'top_kpi_breach_ratio',
    'top_kpi_earliest_anomaly_timestamp_raw',
    'top_kpi_earliest_anomaly_local',
    'total_kpis_scanned',
    'num_kpis_with_anomalies',
    'total_metric_anomaly_points'
]
comp_top20 = comp_ranked[out_cols].copy()

# Ensure JSON-friendly native types
comp_top20['top_kpi_breach_ratio'] = comp_top20['top_kpi_breach_ratio'].astype(float)
comp_top20['top_kpi_global_p95'] = comp_top20['top_kpi_global_p95'].astype(object)
comp_top20['top_kpi_max_anomaly_value'] = comp_top20['top_kpi_max_anomaly_value'].astype(object)
comp_top20['top_kpi_earliest_anomaly_timestamp_raw'] = comp_top20['top_kpi_earliest_anomaly_timestamp_raw'].apply(lambda x: int(x) if x is not None else None)

totals = {
    'total_components_with_any_metric_anomaly': total_components_with_any_metric_anomaly,
    'overall_total_metric_anomaly_points': overall_total_metric_anomaly_points
}

# Display compact results (DataFrame and totals)
comp_top20, totals
