def compute_breach_ratio(row):
    gp = row['global_p95']
    mv = row['max_anomaly_value']
    if mv is None or (isinstance(mv, float) and np.isnan(mv)):
        return 0.0
    if gp is None or (isinstance(gp, float) and np.isnan(gp)):
        return float(mv)
    try:
        if gp == 0:
            return float(mv)
        else:
            return float(mv) / float(gp)
    except Exception:
        return float(mv)

kpi_summary['breach_ratio'] = kpi_summary.apply(compute_breach_ratio, axis=1)
kpi_summary['earliest_anomaly_local'] = kpi_summary['earliest_anomaly_timestamp_raw'].apply(lambda x: ts_int_to_local_str(x) if x is not None else None)
kpi_summary['anomaly_percent'] = kpi_summary.apply(lambda r: (r['anomaly_count']/r['window_count']) if r['window_count']>0 else 0.0, axis=1).round(4)

# Focus top 5 components
top_components = ['os_006', 'os_010', 'os_001', 'os_002', 'os_021']

per_component_details = {}
component_summaries = []

for comp in top_components:
    comp_kpis = kpi_summary[kpi_summary['cmdb_id'] == comp].copy()
    total_kpis_scanned = int(comp_kpis['kpi_name'].nunique())
    comp_anom = comp_kpis[comp_kpis['anomaly_count'] > 0].copy()
    num_kpis_with_anomalies = int(comp_anom.shape[0])
    total_anomaly_points = int(comp_anom['anomaly_count'].sum())
    if comp_anom['earliest_anomaly_timestamp_raw'].dropna().shape[0] > 0:
        earliest_overall_raw = int(comp_anom['earliest_anomaly_timestamp_raw'].dropna().min())
        earliest_overall_local = ts_int_to_local_str(earliest_overall_raw)
    else:
        earliest_overall_raw = None
        earliest_overall_local = None

    if num_kpis_with_anomalies > 0:
        comp_anom = comp_anom.copy()
        comp_anom = comp_anom.sort_values(['breach_ratio', 'anomaly_count'], ascending=[False, False]).head(20)
        # select and coerce types for JSON
        comp_rows = comp_anom[[
            'cmdb_id',
            'kpi_name',
            'global_p95',
            'window_count',
            'anomaly_count',
            'anomaly_percent',
            'earliest_anomaly_timestamp_raw',
            'earliest_anomaly_local',
            'max_anomaly_value',
            'breach_ratio'
        ]].to_dict(orient='records')
        # ensure native types
        for r in comp_rows:
            r['global_p95'] = float(r['global_p95']) if r['global_p95'] is not None else None
            r['window_count'] = int(r['window_count'])
            r['anomaly_count'] = int(r['anomaly_count'])
            r['anomaly_percent'] = float(r['anomaly_percent'])
            r['breach_ratio'] = float(r['breach_ratio'])
            # max_anomaly_value may be None
            if r['max_anomaly_value'] is not None:
                r['max_anomaly_value'] = float(r['max_anomaly_value'])
    else:
        comp_rows = []

    per_component_details[comp] = comp_rows
    component_summaries.append({
        'cmdb_id': comp,
        'total_kpis_scanned': total_kpis_scanned,
        'num_kpis_with_anomalies': num_kpis_with_anomalies,
        'total_anomaly_points': total_anomaly_points,
        'earliest_anomaly_local_overall': earliest_overall_local
    })

