import pandas as pd
import numpy as np
import pytz

# Reuse existing dataframes if present; otherwise load
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

# timezone
tz = pytz.timezone("Asia/Shanghai")
def ts_int_to_local_str(ts_int):
    if ts_int is None or (isinstance(ts_int, float) and np.isnan(ts_int)):
        return None
    return pd.to_datetime(int(ts_int), unit="s", utc=True).tz_convert(tz).strftime("%Y-%m-%d %H:%M:%S %Z")

# Allowed components and incident window
os_list = [f"os_{i:03d}" for i in range(1, 23)]
docker_list = [f"docker_{i:03d}" for i in range(1, 9)]
db_list = [f"db_{i:03d}" for i in range(1, 14)]
allowed_list = set(os_list + docker_list + db_list)

start_ts = 1590768000
end_ts = 1590769800

# Ensure global P95 per (cmdb_id, kpi_name) computed across full available series (only allowed components)
try:
    global_p95_df
except NameError:
    allowed_metric_df = metric_df[metric_df['cmdb_id'].isin(allowed_list)].copy()
    global_p95_df = (
        allowed_metric_df
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
        .quantile(0.95)
        .rename(columns={'value': 'global_p95'})
    )

# Build windowed data and merge with global P95
allowed_metric_df = metric_df[metric_df['cmdb_id'].isin(allowed_list)].copy()
window_df = allowed_metric_df[
    (allowed_metric_df['timestamp'] >= start_ts) &
    (allowed_metric_df['timestamp'] <= end_ts)
].copy()

window_with_p95 = window_df.merge(global_p95_df, on=['cmdb_id', 'kpi_name'], how='left')
window_with_p95['is_anomaly'] = window_with_p95['value'] >= window_with_p95['global_p95']

# KPI-level aggregates in-window
win_counts = (
    window_with_p95
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(window_count=('value', 'size'), anomaly_count=('is_anomaly', 'sum'))
)

anomaly_only = window_with_p95[window_with_p95['is_anomaly']].copy()
anomaly_agg = (
    anomaly_only
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        earliest_anomaly_timestamp_raw=('timestamp', 'min'),
        max_anomaly_value=('value', 'max')
    )
)

# KPI summary: combine global_p95, window counts, anomaly aggregates
kpi_summary = global_p95_df.merge(win_counts, on=['cmdb_id', 'kpi_name'], how='left')
kpi_summary = kpi_summary.merge(anomaly_agg, on=['cmdb_id', 'kpi_name'], how='left')

kpi_summary['window_count'] = kpi_summary['window_count'].fillna(0).astype(int)
kpi_summary['anomaly_count'] = kpi_summary['anomaly_count'].fillna(0).astype(int)
kpi_summary['earliest_anomaly_timestamp_raw'] = kpi_summary['earliest_anomaly_timestamp_raw'].where(kpi_summary['earliest_anomaly_timestamp_raw'].notna(), None)
kpi_summary['max_anomaly_value'] = kpi_summary['max_anomaly_value'].where(kpi_summary['max_anomaly_value'].notna(), None)

# breach_ratio: if global_p95 == 0 -> use max_anomaly_value; else max_anomaly_value / global_p95
def compute_breach_ratio(row):
    gp = row['global_p95']
    mv = row['max_anomaly_value']
    if mv is None or (isinstance(mv, float) and np.isnan(mv)):
        return 0.0
    if gp is None or (isinstance(gp, float) and np.isnan(gp)):
        return float(mv)
    try:
        if gp == 0:
            return float(mv)
        else:
            return float(mv) / float(gp)
    except Exception:
        return float(mv)

kpi_summary['breach_ratio'] = kpi_summary.apply(compute_breach_ratio, axis=1)

# Convert earliest local time
kpi_summary['earliest_anomaly_local'] = kpi_summary['earliest_anomaly_timestamp_raw'].apply(lambda x: ts_int_to_local_str(x) if x is not None else None)

# Focus components
top_components = ['os_006', 'os_010', 'os_001', 'os_002', 'os_021']

per_component_details = {}
summary_rows = []

for comp in top_components:
    comp_kpis = kpi_summary[kpi_summary['cmdb_id'] == comp].copy()
    total_kpis_scanned = int(comp_kpis['kpi_name'].nunique())
    # filter to KPIs that had anomaly_count > 0 in-window
    comp_anom = comp_kpis[comp_kpis['anomaly_count'] > 0].copy()
    num_kpis_with_anomalies = int((comp_anom.shape[0]))
    total_anomaly_points = int(comp_anom['anomaly_count'].sum())
    # earliest anomaly overall
    if comp_anom['earliest_anomaly_timestamp_raw'].dropna().shape[0] > 0:
        earliest_overall_raw = int(comp_anom['earliest_anomaly_timestamp_raw'].dropna().min())
        earliest_overall_local = ts_int_to_local_str(earliest_overall_raw)
    else:
        earliest_overall_raw = None
        earliest_overall_local = None

    # Prepare detail columns and sorting
    if comp_anom.shape[0] > 0:
        comp_anom['anomaly_percent'] = comp_anom.apply(lambda r: (r['anomaly_count']/r['window_count']) if r['window_count']>0 else 0.0, axis=1).round(4)
        detail_df = comp_anom[[
            'cmdb_id',
            'kpi_name',
            'global_p95',
            'window_count',
            'anomaly_count',
            'anomaly_percent',
            'earliest_anomaly_timestamp_raw',
            'earliest_anomaly_local',
            'max_anomaly_value',
            'breach_ratio'
        ]].copy()
        detail_df = detail_df.sort_values(['breach_ratio', 'anomaly_count'], ascending=[False, False]).head(20).reset_index(drop=True)
        # ensure JSON-friendly types
        detail_df['global_p95'] = detail_df['global_p95'].astype(float)
        detail_df['max_anomaly_value'] = detail_df['max_anomaly_value'].astype(object)
        detail_df['breach_ratio'] = detail_df['breach_ratio'].astype(float)
    else:
        # empty DataFrame with columns
        detail_df = pd.DataFrame(columns=[
            'cmdb_id','kpi_name','global_p95','window_count','anomaly_count','anomaly_percent',
            'earliest_anomaly_timestamp_raw','earliest_anomaly_local','max_anomaly_value','breach_ratio'
        ])

    per_component_details[comp] = detail_df

    summary_rows.append({
        'cmdb_id': comp,
        'total_kpis_scanned': total_kpis_scanned,
        'num_kpis_with_anomalies': num_kpis_with_anomalies,
        'total_anomaly_points': total_anomaly_points,
        'earliest_anomaly_local_overall': earliest_overall_local
    })

component_summaries = pd.DataFrame(summary_rows)

# Output: per_component_details (dict of DataFrames limited to top 20 each) and component_summaries (compact DataFrame)
per_component_details, component_summaries
