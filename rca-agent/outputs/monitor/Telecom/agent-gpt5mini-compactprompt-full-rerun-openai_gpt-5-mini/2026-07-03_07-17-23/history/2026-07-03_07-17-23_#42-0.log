import pandas as pd
import pytz

# reuse existing metric_df if available; otherwise load
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

tz = pytz.timezone("Asia/Shanghai")

# helper to convert int timestamp to local string
def ts_int_to_local_str(ts_int):
    if pd.isna(ts_int):
        return None
    return pd.to_datetime(int(ts_int), unit="s", utc=True).tz_convert(tz).strftime("%Y-%m-%d %H:%M:%S %Z")

# 1) allowed component sets
os_list = [f"os_{i:03d}" for i in range(1, 23)]        # os_001 .. os_022
docker_list = [f"docker_{i:03d}" for i in range(1, 9)]  # docker_001 .. docker_008
db_list = [f"db_{i:03d}" for i in range(1, 14)]        # db_001 .. db_013
allowed_list = set(os_list + docker_list + db_list)

# Filter metric_df to only allowed cmdb_ids for scanning (for threshold calculation use full series of these allowed IDs)
allowed_metric_df = metric_df[metric_df['cmdb_id'].isin(allowed_list)].copy()

# 2) Compute global P95 per (cmdb_id, kpi_name) using full available series for allowed components
global_p95_df = (
    allowed_metric_df
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# 3) Filter to incident time window (inclusive)
start_ts = 1590768000
end_ts = 1590769800
window_df = allowed_metric_df[
    (allowed_metric_df['timestamp'] >= start_ts) &
    (allowed_metric_df['timestamp'] <= end_ts)
].copy()

# 4) For each scanned component-KPI compute window_count and anomalies (value >= global_p95)
# Merge window data with global P95 so we can evaluate anomalies
window_with_p95 = window_df.merge(global_p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# mark anomalies
window_with_p95['is_anomaly'] = window_with_p95['value'] >= window_with_p95['global_p95']

# aggregate window-level stats
window_agg = (
    window_with_p95
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        window_count=('value', 'size'),
        anomaly_count=('is_anomaly', 'sum'),
        earliest_anomaly_timestamp_raw=('timestamp', lambda s: int(s[s.index[0]] ) if False else None)  # placeholder, will compute below
    )
)

# The above earliest_anomaly_timestamp_raw placeholder isn't correct; compute earliest and max for anomalies separately:
anomaly_only = window_with_p95[window_with_p95['is_anomaly']].copy()

anomaly_agg = (
    anomaly_only
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        earliest_anomaly_timestamp_raw=('timestamp', 'min'),
        max_anomaly_value=('value', 'max')
    )
)

# Merge window_agg baseline (window_count & anomaly_count) with anomaly_agg
# First compute window_count & anomaly_count properly
win_counts = (
    window_with_p95
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        window_count=('value', 'size'),
        anomaly_count=('is_anomaly', 'sum')
    )
)

summary = global_p95_df.merge(win_counts, on=['cmdb_id', 'kpi_name'], how='left')
summary = summary.merge(anomaly_agg, on=['cmdb_id', 'kpi_name'], how='left')

# Fill NaNs for series with no window data
