import pandas as pd
import numpy as np
import re
import pytz

# Reuse existing variables where possible
try:
    trace_df
except NameError:
    trace_df = pd.read_csv("trace.csv")

# Allowed components
try:
    allowed_list
except NameError:
    os_list = [f"os_{i:03d}" for i in range(1, 23)]
    docker_list = [f"docker_{i:03d}" for i in range(1, 9)]
    db_list = [f"db_{i:03d}" for i in range(1, 14)]
    allowed_list = set(os_list + docker_list + db_list)

# timezone helper (UTC+8)
tz = pytz.timezone("Asia/Shanghai")
def ts_to_local_str(ts_int):
    if ts_int is None or (isinstance(ts_int, float) and np.isnan(ts_int)):
        return None
    return pd.to_datetime(int(ts_int), unit="s", utc=True).tz_convert(tz).strftime("%Y-%m-%d %H:%M:%S %Z")

# Incident window
start_ts = 1590768000
end_ts = 1590769800

error_message = None

try:
    # 1) Restrict to allowed cmdb_ids
    allowed_trace_df = trace_df[trace_df['cmdb_id'].isin(allowed_list)].copy()

    # Compute global P95 per (cmdb_id, trace_name) using full allowed set
    gp = (
        allowed_trace_df
        .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
        .quantile(0.95)
        .rename(columns={'value': 'global_p95'})
    )

    # Exclude series with global_p95 == 0
    gp_nonzero = gp[gp['global_p95'] > 0].copy()

    # Filter to incident window
    window_df = allowed_trace_df[
        (allowed_trace_df['timestamp'] >= start_ts) &
        (allowed_trace_df['timestamp'] <= end_ts)
    ].copy()

    # Keep only series with nonzero P95 (inner merge) and mark anomalies (strict >)
    window_with_p95 = window_df.merge(gp_nonzero, on=['cmdb_id', 'trace_name'], how='inner')
    window_with_p95['is_anomaly'] = window_with_p95['value'] > window_with_p95['global_p95']

    # Precompute window_count per series (for later aggregation)
    win_counts = (
        window_with_p95
        .groupby(['cmdb_id', 'trace_name'], as_index=False)
        .agg(window_count=('value', 'size'))
    )

    # Extract anomaly rows (strict)
    anomaly_rows = window_with_p95[window_with_p95['is_anomaly']].copy()

    if anomaly_rows.shape[0] == 0:
        # No anomalies after nonzero-P95 & strict rule
        referenced_agg_top20 = pd.DataFrame(columns=[
            'referenced_component',
            'total_anomaly_points',
            'distinct_trace_series_count',
            'earliest_anomaly_timestamp_raw',
            'earliest_anomaly_local',
            'total_window_rows_referencing',
            'metric_anomaly_flag',
            'metric_total_anomaly_points'
        ])
        totals = {
            'total_referenced_components_with_trace_anomalies': 0,
            'total_trace_anomaly_points_used_in_aggregation': 0
        }
    else:
        # 2) For each anomaly row, extract referenced components (row.cmdb_id + tokens in trace_name)
        token_pattern = re.compile(r'(?:os|docker|db)_[0-9]{3}')
        def extract_refs_from_row(row):
            tokens = token_pattern.findall(str(row['trace_name']))
            refs = set(tokens)
            refs.add(row['cmdb_id'])
            return list(refs)
        anomaly_rows['referenced_components'] = anomaly_rows.apply(extract_refs_from_row, axis=1)

        # 2b) Explode anomaly rows by referenced component
        anomaly_expl = anomaly_rows[['timestamp', 'cmdb_id', 'trace_name', 'value', 'global_p95', 'referenced_components']].explode('referenced_components')
        anomaly_expl = anomaly_expl.rename(columns={'referenced_components': 'referenced_component'})

        # 3) Aggregate by referenced_component
        referenced_agg = (
            anomaly_expl
            .groupby('referenced_component', as_index=False)
            .agg(
                total_anomaly_points=('timestamp', 'size'),
                earliest_anomaly_timestamp_raw=('timestamp', 'min'),
            )
        )
        referenced_agg['earliest_anomaly_local'] = referenced_agg['earliest_anomaly_timestamp_raw'].apply(lambda x: ts_to_local_str(int(x)))

        # distinct_trace_series_count: distinct (cmdb_id, trace_name) among anomaly_expl for each referenced_component
        distinct_counts = (
            anomaly_expl
            .groupby('referenced_component')
            .apply(lambda df: df[['cmdb_id','trace_name']].drop_duplicates().shape[0])
            .reset_index(name='distinct_trace_series_count')
        )
        referenced_agg = referenced_agg.merge(distinct_counts, on='referenced_component', how='left')

        # total_window_rows_referencing: sum of window_count for series that reference the component (from window_with_p95)
        # Build mapping of series -> referenced components (from all window series)
        series_refs = window_with_p95[['cmdb_id','trace_name']].drop_duplicates().copy()
        def extract_refs_from_series(row):
            tokens = token_pattern.findall(str(row['trace_name']))
            refs = set(tokens)
            refs.add(row['cmdb_id'])
            return list(refs)
        series_refs['series_refs'] = series_refs.apply(extract_refs_from_series, axis=1)
        series_refs_expl = series_refs.explode('series_refs').rename(columns={'series_refs': 'referenced_component'})

        # Merge with win_counts to get window_count per series
        series_win = series_refs_expl.merge(win_counts, on=['cmdb_id','trace_name'], how='left')
        window_count_per_ref = (
            series_win
            .groupby('referenced_component', as_index=False)
            .agg(total_window_rows_referencing=('window_count', 'sum'))
        )
        referenced_agg = referenced_agg.merge(window_count_per_ref, on='referenced_component', how='left')
        referenced_agg['total_window_rows_referencing'] = referenced_agg['total_window_rows_referencing'].fillna(0).astype(int)

        # 4) metric_anomaly_flag and metric_total_anomaly_points from comp_agg if available, else recompute minimal metric comp aggregation
        try:
            comp_agg  # should exist from earlier metric aggregation
        except NameError:
            # Recompute component-level metric aggregation minimally
            metric_df = pd.read_csv("metric.csv")
            os_list = [f"os_{i:03d}" for i in range(1, 23)]
            docker_list = [f"docker_{i:03d}" for i in range(1, 9)]
            db_list = [f"db_{i:03d}" for i in range(1, 14)]
            allowed_list = set(os_list + docker_list + db_list)
            allowed_metric_df = metric_df[metric_df['cmdb_id'].isin(allowed_list)].copy()
            # compute global P95 per KPI series
            metric_gp = allowed_metric_df.groupby(['cmdb_id','kpi_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value':'global_p95'})
            # window
            window_metric = allowed_metric_df[(allowed_metric_df['timestamp']>=start_ts)&(allowed_metric_df['timestamp']<=end_ts)].copy()
            window_metric = window_metric.merge(metric_gp, on=['cmdb_id','kpi_name'], how='left')
            window_metric['is_anomaly'] = window_metric['value'] >= window_metric['global_p95']
            metric_kpi_counts = window_metric.groupby(['cmdb_id','kpi_name'], as_index=False).agg(anomaly_count=('is_anomaly','sum'))
            comp_agg = metric_kpi_counts.groupby('cmdb_id', as_index=False).agg(
                num_kpis_with_anomalies=('anomaly_count', lambda s: int((s>0).sum())),
                total_anomaly_points=('anomaly_count','sum')
            )

        comp_flag_map = dict(zip(comp_agg['cmdb_id'], comp_agg['num_kpis_with_anomalies']>0))
        comp_points_map = dict(zip(comp_agg['cmdb_id'], comp_agg['total_anomaly_points']))

        referenced_agg['metric_anomaly_flag'] = referenced_agg['referenced_component'].map(lambda c: bool(comp_flag_map.get(c, False)))
        referenced_agg['metric_total_anomaly_points'] = referenced_agg['referenced_component'].map(lambda c: int(comp_points_map.get(c, 0)))

        # 5) Finalize and sort top 20 by total_anomaly_points desc
        referenced_agg_top20 = referenced_agg.sort_values('total_anomaly_points', ascending=False).head(20).reset_index(drop=True)

        # totals
        total_referenced_components_with_trace_anomalies = int((referenced_agg['total_anomaly_points']>0).sum())
        total_trace_anomaly_points_used_in_aggregation = int(referenced_agg['total_anomaly_points'].sum())

        totals = {
            'total_referenced_components_with_trace_anomalies': total_referenced_components_with_trace_anomalies,
            'total_trace_anomaly_points_used_in_aggregation': total_trace_anomaly_points_used_in_aggregation
        }

    # Keep output compact: select requested columns and ensure types JSON-friendly
    out_cols = [
        'referenced_component',
        'total_anomaly_points',
        'distinct_trace_series_count',
        'earliest_anomaly_timestamp_raw',
        'earliest_anomaly_local',
        'total_window_rows_referencing',
        'metric_anomaly_flag',
        'metric_total_anomaly_points'
    ]
    # If referenced_agg_top20 is empty DataFrame, ensure columns exist
    if referenced_agg_top20.empty:
        referenced_agg_top20 = pd.DataFrame(columns=out_cols)
    else:
        referenced_agg_top20 = referenced_agg_top20[out_cols].copy()
        referenced_agg_top20['earliest_anomaly_timestamp_raw'] = referenced_agg_top20['earliest_anomaly_timestamp_raw'].astype(int)

except Exception as e:
    error_message = str(e)
    referenced_agg_top20 = pd.DataFrame(columns=[
        'referenced_component',
        'total_anomaly_points',
        'distinct_trace_series_count',
        'earliest_anomaly_timestamp_raw',
        'earliest_anomaly_local',
        'total_window_rows_referencing',
        'metric_anomaly_flag',
        'metric_total_anomaly_points'
    ])
    totals = {
        'total_referenced_components_with_trace_anomalies': 0,
        'total_trace_anomaly_points_used_in_aggregation': 0
    }

# Final compact outputs (DataFrame and totals dictionary)
referenced_agg_top20, totals, error_message
