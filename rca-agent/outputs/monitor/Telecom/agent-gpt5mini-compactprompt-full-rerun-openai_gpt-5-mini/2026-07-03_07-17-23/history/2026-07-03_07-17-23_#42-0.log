import pandas as pd
import numpy as np
import re
import pytz

# Reuse existing trace_df and metric component aggregation if present; otherwise load/compute as needed
try:
    trace_df
except NameError:
    trace_df = pd.read_csv("trace.csv")

# Allowed components
try:
    allowed_list
except NameError:
    os_list = [f"os_{i:03d}" for i in range(1, 23)]
    docker_list = [f"docker_{i:03d}" for i in range(1, 9)]
    db_list = [f"db_{i:03d}" for i in range(1, 14)]
    allowed_list = set(os_list + docker_list + db_list)

# timezone helper (UTC+8)
tz = pytz.timezone("Asia/Shanghai")
def ts_to_local_str(ts_int):
    if ts_int is None or (isinstance(ts_int, float) and np.isnan(ts_int)):
        return None
    return pd.to_datetime(int(ts_int), unit="s", utc=True).tz_convert(tz).strftime("%Y-%m-%d %H:%M:%S %Z")

# Incident window
start_ts = 1590768000
end_ts = 1590769800

# 1) Restrict trace to allowed components and compute global P95 per series using full file
allowed_trace_df = trace_df[trace_df['cmdb_id'].isin(allowed_list)].copy()
global_p95_df = (
    allowed_trace_df
    .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# 2) Exclude series with global_p95 == 0
global_p95_nonzero = global_p95_df[global_p95_df['global_p95'] > 0].copy()

# 3) Filter to incident window (inclusive)
window_df = allowed_trace_df[
    (allowed_trace_df['timestamp'] >= start_ts) &
    (allowed_trace_df['timestamp'] <= end_ts)
].copy()

# 4) Keep only series with nonzero P95 and mark anomalies (value > global_p95 strict)
window_with_p95 = window_df.merge(global_p95_nonzero, on=['cmdb_id', 'trace_name'], how='inner')
window_with_p95['is_anomaly'] = window_with_p95['value'] > window_with_p95['global_p95']

# Precompute window_count per series (for summing later)
win_counts = (
    window_with_p95
    .groupby(['cmdb_id', 'trace_name'], as_index=False)
    .agg(window_count=('value', 'size'))
)

# Extract anomaly rows
anomaly_rows = window_with_p95[window_with_p95['is_anomaly']].copy()
# If no anomalies, produce empty outputs gracefully
if anomaly_rows.shape[0] == 0:
    referenced_agg_top20 = pd.DataFrame(columns=[
        'referenced_component',
        'total_anomaly_points',
        'total_window_count',
        'earliest_anomaly_timestamp_raw',
        'earliest_anomaly_local',
        'distinct_trace_series_count',
        'metric_anomaly_flag'
    ])
    totals = {
        'total_referenced_components_with_trace_anomalies': 0,
        'total_trace_anomaly_points_used_in_aggregation': 0
    }
    referenced_agg_top20, totals
else:
    # 5) For each anomaly row, extract referenced components: row.cmdb_id plus tokens in trace_name
    token_pattern = re.compile(r'(?:os|docker|db)_[0-9]{3}')
    # create a column with list of referenced components
    def extract_refs(row):
        tokens = token_pattern.findall(str(row['trace_name']))
        refs = set(tokens)
        refs.add(row['cmdb_id'])
        return list(refs)
    anomaly_rows['referenced_components'] = anomaly_rows.apply(extract_refs, axis=1)

    # Explode anomaly rows by referenced component to count anomaly points per referenced component
    anomaly_exploded = anomaly_rows[['timestamp', 'cmdb_id', 'trace_name', 'value', 'referenced_components']].explode('referenced_components')
    anomaly_exploded = anomaly_exploded.rename(columns={'referenced_components': 'referenced_component'})

    # Aggregate anomaly metrics per referenced_component
    referenced_agg = (
        anomaly_exploded
        .groupby('referenced_component', as_index=False)
        .agg(
            total_anomaly_points=('timestamp', 'size'),
            earliest_anomaly_timestamp_raw=('timestamp', 'min')
        )
    )

    # earliest local
    referenced_agg['earliest_anomaly_local'] = referenced_agg['earliest_anomaly_timestamp_raw'].apply(lambda x: ts_to_local_str(int(x)))

    # 6) total_window_count: sum of window_count for series that reference the component.
    # Build mapping of series -> referenced components (for all series present in window_with_p95)
    def series_extract_refs(row):
        tokens = token_pattern.findall(str(row['trace_name']))
        refs = set(tokens)
        refs.add(row['cmdb_id'])
        return list(refs)
    series_refs = window_with_p95[['cmdb_id', 'trace_name']].drop_duplicates().copy()
    series_refs['series_refs'] = series_refs.apply(series_extract_refs, axis=1)
    series_refs_expl = series_refs.explode('series_refs').rename(columns={'series_refs': 'referenced_component'})

    # Merge with win_counts to get window_count per series, then sum per referenced_component
    series_win = series_refs_expl.merge(win_counts, on=['cmdb_id', 'trace_name'], how='left')
    window_count_per_ref = series_win.groupby('referenced_component', as_index=False).agg(total_window_count=('window_count', 'sum'),
                                                                                           distinct_trace_series_count=('trace_name', lambda s: s.nunique()))
    # Merge with referenced_agg
    referenced_agg = referenced_agg.merge(window_count_per_ref, on='referenced_component', how='left')

    # Fill NaNs
    referenced_agg['total_window_count'] = referenced_agg['total_window_count'].fillna(0).astype(int)
    referenced_agg['distinct_trace_series_count'] = referenced_agg['distinct_trace_series_count'].fillna(0).astype(int)

    # 7) metric_anomaly_flag: whether that component had any metric KPIs flagged anomalous earlier.
    # Try to reuse comp_agg (component-level metric aggregation). If not present, recompute minimal metric comp anomalies.
    try:
        comp_agg  # from earlier steps
    except NameError:
        # recompute minimal metric comp aggregation: num_kpis_with_anomalies per cmdb_id
        metric_df = pd.read_csv("metric.csv")
        os_list = [f"os_{i:03d}" for i in range(1, 23)]
        docker_list = [f"docker_{i:03d}" for i in range(1, 9)]
        db_list = [f"db_{i:03d}" for i in range(1, 14)]
        allowed_list = set(os_list + docker_list + db_list)
        allowed_metric_df = metric_df[metric_df['cmdb_id'].isin(allowed_list)].copy()
        # global p95 per series
        metric_gp = allowed_metric_df.groupby(['cmdb_id', 'kpi_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value':'global_p95'})
        # window
        window_metric = allowed_metric_df[(allowed_metric_df['timestamp']>=start_ts)&(allowed_metric_df['timestamp']<=end_ts)].copy()
        window_metric = window_metric.merge(metric_gp, on=['cmdb_id','kpi_name'], how='left')
        window_metric['is_anomaly'] = window_metric['value'] >= window_metric['global_p95']
        metric_kpi_counts = window_metric.groupby(['cmdb_id','kpi_name'], as_index=False).agg(anomaly_count=('is_anomaly','sum'))
        comp_agg = metric_kpi_counts.groupby('cmdb_id', as_index=False).agg(num_kpis_with_anomalies=('anomaly_count', lambda s: int((s>0).sum())))
    # build flag map
    comp_flag_map = dict(zip(comp_agg['cmdb_id'], comp_agg['num_kpis_with_anomalies']>0))
    referenced_agg['metric_anomaly_flag'] = referenced_agg['referenced_component'].map(lambda c: bool(comp_flag_map.get(c, False)))

    # 8) distinct_trace_series_count should be number of distinct (cmdb_id, trace_name) series that contributed anomalies referencing this component.
    # We computed distinct_trace_series_count earlier from series_win (which is series that reference the component) but need it specifically for series that had anomalies.
    # Compute distinct series among anomaly_exploded per referenced_component:
    distinct_series_from_anomalies = (
        anomaly_exploded
        .groupby('referenced_component')
        .apply(lambda df: df[['cmdb_id','trace_name']].drop_duplicates().shape[0])
        .reset_index(name='distinct_trace_series_count_from_anomalies')
    )
    referenced_agg = referenced_agg.merge(distinct_series_from_anomalies, left_on='referenced_component', right_on='referenced_component', how='left')
    referenced_agg['distinct_trace_series_count_from_anomalies'] = referenced_agg['distinct_trace_series_count_from_anomalies'].fillna(0).astype(int)

    # Prefer distinct_trace_series_count_from_anomalies for "distinct_trace_series_count" per instruction (series that contributed anomalies)
    referenced_agg['distinct_trace_series_count'] = referenced_agg['distinct_trace_series_count_from_anomalies']
    referenced_agg = referenced_agg.drop(columns=['distinct_trace_series_count_from_anomalies'])

    # 9) Final selection and sorting: top 20 by total_anomaly_points desc
    referenced_agg_top20 = referenced_agg.sort_values('total_anomaly_points', ascending=False).head(20).reset_index(drop=True)

    # Ensure correct types and add earliest local as string already present
    referenced_agg_top20['earliest_anomaly_timestamp_raw'] = referenced_agg_top20['earliest_anomaly_timestamp_raw'].astype(int)
    referenced_agg_top20['earliest_anomaly_local'] = referenced_agg_top20['earliest_anomaly_local'].astype(str)

    # Totals
    total_referenced_components_with_trace_anomalies = int((referenced_agg['total_anomaly_points'] > 0).sum())
    total_trace_anomaly_points_used_in_aggregation = int(referenced_agg['total_anomaly_points'].sum())

    totals = {
        'total_referenced_components_with_trace_anomalies': total_referenced_components_with_trace_anomalies,
        'total_trace_anomaly_points_used_in_aggregation': total_trace_anomaly_points_used_in_aggregation
    }

    # Keep output compact: selected columns only
    referenced_agg_top20 = referenced_agg_top20[[
        'referenced_component',
        'total_anomaly_points',
        'total_window_count',
        'earliest_anomaly_timestamp_raw',
        'earliest_anomaly_local',
        'distinct_trace_series_count',
        'metric_anomaly_flag'
    ]]

    # Display results (variable names as outputs)
    referenced_agg_top20, totals
