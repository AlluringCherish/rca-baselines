import pandas as pd
import pytz

# reuse variables where possible
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")

tz = pytz.timezone("Asia/Shanghai")

def ts_int_to_local_str(ts_int):
    if pd.isna(ts_int):
        return None
    return pd.to_datetime(int(ts_int), unit="s", utc=True).tz_convert(tz).strftime("%Y-%m-%d %H:%M:%S %Z")

# ---- metric.csv inventory ----
total_rows_metric = int(metric_df.shape[0])
cmdb_ids_metric = sorted(metric_df['cmdb_id'].dropna().unique().tolist())

kpi_counts_metric_s = metric_df['kpi_name'].value_counts().head(20)
kpi_counts_metric = {str(k): int(v) for k, v in kpi_counts_metric_s.items()}

if total_rows_metric > 0:
    min_ts_metric_int = int(metric_df['timestamp'].min())
    max_ts_metric_int = int(metric_df['timestamp'].max())
else:
    min_ts_metric_int = None
    max_ts_metric_int = None

min_ts_metric = {"raw": min_ts_metric_int, "local": ts_int_to_local_str(min_ts_metric_int)}
max_ts_metric = {"raw": max_ts_metric_int, "local": ts_int_to_local_str(max_ts_metric_int)}

top5_metric_rows = metric_df.head(5).to_dict(orient="records")

metric_summary = {
    "total_rows": total_rows_metric,
    "unique_cmdb_ids": cmdb_ids_metric,
    "top_kpi_counts": kpi_counts_metric,
    "min_timestamp": min_ts_metric,
    "max_timestamp": max_ts_metric,
    "top_5_rows": top5_metric_rows
}

# ---- trace.csv inventory ----
total_rows_trace = int(trace_df.shape[0])
cmdb_ids_trace = sorted(trace_df['cmdb_id'].dropna().unique().tolist())

trace_counts_s = trace_df['trace_name'].value_counts().head(20)
trace_counts = {str(k): int(v) for k, v in trace_counts_s.items()}

if total_rows_trace > 0:
    min_ts_trace_int = int(trace_df['timestamp'].min())
    max_ts_trace_int = int(trace_df['timestamp'].max())
else:
    min_ts_trace_int = None
    max_ts_trace_int = None

min_ts_trace = {"raw": min_ts_trace_int, "local": ts_int_to_local_str(min_ts_trace_int)}
max_ts_trace = {"raw": max_ts_trace_int, "local": ts_int_to_local_str(max_ts_trace_int)}

top5_trace_rows = trace_df.head(5).to_dict(orient="records")

trace_summary = {
    "total_rows": total_rows_trace,
    "unique_cmdb_ids": cmdb_ids_trace,
    "top_trace_counts": trace_counts,
    "min_timestamp": min_ts_trace,
    "max_timestamp": max_ts_trace,
    "top_5_rows": top5_trace_rows
}

inventory = {"metric.csv": metric_summary, "trace.csv": trace_summary}

inventory
