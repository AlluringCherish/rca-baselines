import pandas as pd
import numpy as np
import re
import pytz

# Reuse existing variables where possible; otherwise recompute pipeline
try:
    anomaly_expl
    gp_nonzero
    win_counts
    window_with_p95
except NameError:
    # load trace_df if not present
    try:
        trace_df
    except NameError:
        trace_df = pd.read_csv("trace.csv")
    # allowed components
    os_list = [f"os_{i:03d}" for i in range(1, 23)]
    docker_list = [f"docker_{i:03d}" for i in range(1, 9)]
    db_list = [f"db_{i:03d}" for i in range(1, 14)]
    allowed_list = set(os_list + docker_list + db_list)

    # timezone and window
    tz = pytz.timezone("Asia/Shanghai")
    start_ts = 1590768000
    end_ts = 1590769800

    # restrict to allowed cmdb_ids
    allowed_trace_df = trace_df[trace_df['cmdb_id'].isin(allowed_list)].copy()

    # global P95 per series
    gp = (
        allowed_trace_df
        .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
        .quantile(0.95)
        .rename(columns={'value': 'global_p95'})
    )
    gp_nonzero = gp[gp['global_p95'] > 0].copy()

    # window rows
    window_df = allowed_trace_df[(allowed_trace_df['timestamp'] >= start_ts) & (allowed_trace_df['timestamp'] <= end_ts)].copy()

    # keep only nonzero-p95 series and mark anomalies (strict >)
    window_with_p95 = window_df.merge(gp_nonzero, on=['cmdb_id', 'trace_name'], how='inner')
    window_with_p95['is_anomaly'] = window_with_p95['value'] > window_with_p95['global_p95']

    # window_count per series
    win_counts = window_with_p95.groupby(['cmdb_id', 'trace_name'], as_index=False).agg(window_count=('value', 'size'))

    # anomaly rows and exploded referenced components
    anomaly_rows = window_with_p95[window_with_p95['is_anomaly']].copy()
    token_pattern = re.compile(r'(?:os|docker|db)_[0-9]{3}')
    def extract_refs(row):
        tokens = token_pattern.findall(str(row['trace_name']))
        refs = set(tokens)
        refs.add(row['cmdb_id'])  # include row's cmdb_id per earlier aggregation logic
        return list(refs)
    anomaly_rows['referenced_components'] = anomaly_rows.apply(extract_refs, axis=1)
    anomaly_expl = anomaly_rows[['timestamp','cmdb_id','trace_name','value','global_p95','referenced_components']].explode('referenced_components')
    anomaly_expl = anomaly_expl.rename(columns={'referenced_components':'referenced_component'})

# Now focus on referenced_component == 'docker_002'
target = 'docker_002'

# Filter exploded anomalies that reference docker_002
if 'anomaly_expl' in globals() and not anomaly_expl.empty:
    expl_target = anomaly_expl[anomaly_expl['referenced_component'] == target].copy()
else:
    expl_target = pd.DataFrame(columns=['timestamp','cmdb_id','trace_name','value','global_p95','referenced_component'])

# If none, return empty list and short error message
if expl_target.shape[0] == 0:
    df_result = pd.DataFrame(columns=[
        'cmdb_id','trace_name','global_p95','window_count','anomaly_count','anomaly_percent',
        'earliest_anomaly_timestamp_raw','earliest_anomaly_local','max_anomaly_value','referenced_components'
    ])
    totals = {
        'total_series_for_docker_002': 0,
        'total_anomaly_points_for_docker_002': 0
    }
    error_message = "No anomaly rows reference 'docker_002' under nonzero-P95 strict > rule."
else:
    # Aggregate per unique (cmdb_id, trace_name)
    # Compute anomaly_count, earliest timestamp, max anomaly value
    agg = (
        expl_target
        .groupby(['cmdb_id','trace_name'], as_index=False)
        .agg(
            anomaly_count=('timestamp','size'),
            earliest_anomaly_timestamp_raw=('timestamp','min'),
            max_anomaly_value=('value','max')
        )
    )

    # Merge global_p95 and window_count
    # gp_nonzero and win_counts should be available
    agg = agg.merge(gp_nonzero, on=['cmdb_id','trace_name'], how='left')
    agg = agg.merge(win_counts, on=['cmdb_id','trace_name'], how='left')

    # compute anomaly_percent and local time string
    tz = pytz.timezone("Asia/Shanghai")
    def to_local(ts):
        return pd.to_datetime(int(ts), unit='s', utc=True).tz_convert(tz).strftime("%Y-%m-%d %H:%M:%S %Z")
    agg['window_count'] = agg['window_count'].fillna(0).astype(int)
    agg['anomaly_percent'] = agg.apply(lambda r: (r['anomaly_count']/r['window_count']) if r['window_count']>0 else 0.0, axis=1).round(4)
    agg['earliest_anomaly_local'] = agg['earliest_anomaly_timestamp_raw'].apply(lambda x: to_local(int(x)))
    # referenced_components parsed from trace_name (tokens only, per request)
    def refs_from_tracename(tn):
        return token_pattern.findall(str(tn))
    agg['referenced_components'] = agg['trace_name'].apply(refs_from_tracename)

    # select and order columns
    df_result = agg[[
        'cmdb_id','trace_name','global_p95','window_count','anomaly_count','anomaly_percent',
        'earliest_anomaly_timestamp_raw','earliest_anomaly_local','max_anomaly_value','referenced_components'
    ]].copy()

    # sort by earliest_anomaly_timestamp_raw asc then anomaly_count desc
    df_result = df_result.sort_values(['earliest_anomaly_timestamp_raw','anomaly_count'], ascending=[True, False]).head(20).reset_index(drop=True)

    # totals
    totals = {
        'total_series_for_docker_002': int(df_result.shape[0]),
        'total_anomaly_points_for_docker_002': int(df_result['anomaly_count'].sum())
    }
    error_message = None

# Display compact results: df_result (<=20 rows) and totals
df_result, totals, error_message
