import pandas as pd
import numpy as np
import pytz

# reuse existing trace_df and allowed_list if available, otherwise load/define
try:
    trace_df
except NameError:
    trace_df = pd.read_csv("trace.csv")

try:
    allowed_list
except NameError:
    os_list = [f"os_{i:03d}" for i in range(1, 23)]
    docker_list = [f"docker_{i:03d}" for i in range(1, 9)]
    db_list = [f"db_{i:03d}" for i in range(1, 14)]
    allowed_list = set(os_list + docker_list + db_list)

# timezone helper (UTC+8)
tz = pytz.timezone("Asia/Shanghai")
def ts_int_to_local_str(ts_int):
    if ts_int is None or (isinstance(ts_int, float) and np.isnan(ts_int)):
        return None
    return pd.to_datetime(int(ts_int), unit="s", utc=True).tz_convert(tz).strftime("%Y-%m-%d %H:%M:%S %Z")

# Incident window
start_ts = 1590768000
end_ts = 1590769800

# 1) Restrict trace series to allowed components
allowed_trace_df = trace_df[trace_df['cmdb_id'].isin(allowed_list)].copy()

# 2) Compute global P95 per (cmdb_id, trace_name) across full available trace.csv (for allowed components)
global_p95_df = (
    allowed_trace_df
    .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# 3) Exclude series with global_p95 == 0
global_p95_nonzero = global_p95_df[global_p95_df['global_p95'] > 0].copy()
total_trace_series_scanned_nonzeroP95 = int(global_p95_nonzero.shape[0])

# 4) Filter trace.csv to incident window (inclusive)
window_df = allowed_trace_df[
    (allowed_trace_df['timestamp'] >= start_ts) &
    (allowed_trace_df['timestamp'] <= end_ts)
].copy()

# 5) For remaining series, merge window rows with nonzero global_p95 and mark anomalies (value > global_p95 strict)
window_with_p95 = window_df.merge(global_p95_nonzero, on=['cmdb_id', 'trace_name'], how='inner')
window_with_p95['is_anomaly'] = window_with_p95['value'] > window_with_p95['global_p95']

# Compute window_count and anomaly_count per series (only series with window rows are included)
win_counts = (
    window_with_p95
    .groupby(['cmdb_id', 'trace_name'], as_index=False)
    .agg(window_count=('value', 'size'), anomaly_count=('is_anomaly', 'sum'))
)

# Compute earliest anomaly timestamp and max anomaly value per series (only where is_anomaly True)
anomaly_only = window_with_p95[window_with_p95['is_anomaly']].copy()
anomaly_agg = (
    anomaly_only
    .groupby(['cmdb_id', 'trace_name'], as_index=False)
    .agg(
        earliest_anomaly_timestamp_raw=('timestamp', 'min'),
        max_anomaly_value=('value', 'max')
    )
)

# Merge counts with anomaly aggregates; keep series that had window rows (win_counts)
series_summary = win_counts.merge(global_p95_nonzero, on=['cmdb_id', 'trace_name'], how='left')
series_summary = series_summary.merge(anomaly_agg, on=['cmdb_id', 'trace_name'], how='left')

# Fill/normalize fields
series_summary['earliest_anomaly_timestamp_raw'] = series_summary['earliest_anomaly_timestamp_raw'].where(series_summary['earliest_anomaly_timestamp_raw'].notna(), None)
series_summary['max_anomaly_value'] = series_summary['max_anomaly_value'].where(series_summary['max_anomaly_value'].notna(), None)
series_summary['anomaly_percent'] = series_summary.apply(lambda r: (r['anomaly_count']/r['window_count']) if r['window_count']>0 else 0.0, axis=1).round(4)
series_summary['earliest_anomaly_local'] = series_summary['earliest_anomaly_timestamp_raw'].apply(lambda x: ts_int_to_local_str(x) if x is not None else None)

# 6) Select requested columns and sort/limit results
out_cols = [
    'cmdb_id',
    'trace_name',
    'global_p95',
    'window_count',
    'anomaly_count',
    'anomaly_percent',
    'earliest_anomaly_timestamp_raw',
    'earliest_anomaly_local',
    'max_anomaly_value'
]
summary_df = series_summary[out_cols].copy()

# ensure types friendly for JSON (coerce floats)
summary_df['global_p95'] = summary_df['global_p95'].astype(float)
# sort by anomaly_count desc then earliest_anomaly_timestamp_raw asc (NaNs last)
summary_top20 = summary_df.sort_values(['anomaly_count', 'earliest_anomaly_timestamp_raw'], ascending=[False, True]).head(20).reset_index(drop=True)

# 7) Totals: sum anomaly_count across in-window series (only those with nonzero global_p95 and window rows)
total_trace_anomaly_count_sum_nonzeroP95 = int(summary_df['anomaly_count'].sum())

totals = {
    "total_trace_series_scanned_nonzeroP95": total_trace_series_scanned_nonzeroP95,
    "total_trace_anomaly_count_sum_nonzeroP95": total_trace_anomaly_count_sum_nonzeroP95
}

# Final compact outputs
summary_top20, totals
