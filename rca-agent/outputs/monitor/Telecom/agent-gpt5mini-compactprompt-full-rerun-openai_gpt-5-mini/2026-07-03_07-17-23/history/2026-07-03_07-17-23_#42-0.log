import pandas as pd
import numpy as np
import pytz

# reuse existing variables if available
try:
    trace_df
except NameError:
    trace_df = pd.read_csv("trace.csv")

# reuse allowed_list, tz and ts_int_to_local_str if present; otherwise define
try:
    allowed_list
except NameError:
    os_list = [f"os_{i:03d}" for i in range(1, 23)]
    docker_list = [f"docker_{i:03d}" for i in range(1, 9)]
    db_list = [f"db_{i:03d}" for i in range(1, 14)]
    allowed_list = set(os_list + docker_list + db_list)

try:
    tz
except NameError:
    tz = pytz.timezone("Asia/Shanghai")

def ts_int_to_local_str(ts_int):
    if ts_int is None or (isinstance(ts_int, float) and np.isnan(ts_int)):
        return None
    return pd.to_datetime(int(ts_int), unit="s", utc=True).tz_convert(tz).strftime("%Y-%m-%d %H:%M:%S %Z")

# Incident window
start_ts = 1590768000
end_ts = 1590769800

# 1) Restrict trace series to allowed cmdb_ids
allowed_trace_df = trace_df[trace_df['cmdb_id'].isin(allowed_list)].copy()

# 2) Compute global P95 per (cmdb_id, trace_name) across full available trace.csv (only allowed components)
global_p95_df = (
    allowed_trace_df
    .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

total_trace_series_scanned = int(global_p95_df.shape[0])

# 3) Filter trace.csv to incident window (inclusive)
window_df = allowed_trace_df[
    (allowed_trace_df['timestamp'] >= start_ts) &
    (allowed_trace_df['timestamp'] <= end_ts)
].copy()

# 4) Merge window data with global P95 and mark anomalies (value >= global_p95)
window_with_p95 = window_df.merge(global_p95_df, on=['cmdb_id', 'trace_name'], how='left')
window_with_p95['is_anomaly'] = window_with_p95['value'] >= window_with_p95['global_p95']

# Compute window_count and anomaly_count for series that appear in-window
win_counts = (
    window_with_p95
    .groupby(['cmdb_id', 'trace_name'], as_index=False)
    .agg(window_count=('value', 'size'), anomaly_count=('is_anomaly', 'sum'))
)

# Compute earliest anomaly timestamp and max anomaly value per series (only from anomaly rows)
anomaly_only = window_with_p95[window_with_p95['is_anomaly']].copy()
anomaly_agg = (
    anomaly_only
    .groupby(['cmdb_id', 'trace_name'], as_index=False)
    .agg(
        earliest_anomaly_timestamp_raw=('timestamp', 'min'),
        max_anomaly_value=('value', 'max')
    )
)

# Build per-series summary for series that have window data
series_summary = global_p95_df.merge(win_counts, on=['cmdb_id', 'trace_name'], how='inner')  # inner => only in-window series
series_summary = series_summary.merge(anomaly_agg, on=['cmdb_id', 'trace_name'], how='left')

series_summary['window_count'] = series_summary['window_count'].fillna(0).astype(int)
series_summary['anomaly_count'] = series_summary['anomaly_count'].fillna(0).astype(int)
series_summary['earliest_anomaly_timestamp_raw'] = series_summary['earliest_anomaly_timestamp_raw'].where(series_summary['earliest_anomaly_timestamp_raw'].notna(), None)
series_summary['max_anomaly_value'] = series_summary['max_anomaly_value'].where(series_summary['max_anomaly_value'].notna(), None)

# compute earliest local string and anomaly_percent
series_summary['earliest_anomaly_local'] = series_summary['earliest_anomaly_timestamp_raw'].apply(lambda x: ts_int_to_local_str(x) if x is not None else None)
series_summary['anomaly_percent'] = series_summary.apply(lambda r: (r['anomaly_count']/r['window_count']) if r['window_count']>0 else 0.0, axis=1).round(4)

# Select requested columns and ensure types are JSON-friendly
out_df = series_summary[[
    'cmdb_id',
    'trace_name',
    'global_p95',
    'window_count',
    'anomaly_count',
    'anomaly_percent',
    'earliest_anomaly_timestamp_raw',
    'earliest_anomaly_local',
    'max_anomaly_value'
]].copy()

# Convert numpy types to native Python types for cleanliness
out_df['window_count'] = out_df['window_count'].astype(int)
out_df['anomaly_count'] = out_df['anomaly_count'].astype(int)
out_df['global_p95'] = out_df['global_p95'].astype(float)
out_df['max_anomaly_value'] = out_df['max_anomaly_value'].astype(object)  # keep None where missing

# 5) Top 20 rows sorted by anomaly_count desc, then anomaly_percent desc
summary_top20 = out_df.sort_values(['anomaly_count', 'anomaly_percent'], ascending=[False, False]).head(20).reset_index(drop=True)

# Scalars
total_trace_anomaly_count_sum = int(out_df['anomaly_count'].sum())

totals = {
    "total_trace_series_scanned": total_trace_series_scanned,
    "total_trace_anomaly_count_sum": total_trace_anomaly_count_sum
}

# Final compact outputs
summary_top20, totals
