import pandas as pd
import numpy as np
import pytz

# reuse existing variables if present
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

# timezone
try:
    tz
except NameError:
    tz = pytz.timezone("Asia/Shanghai")

def ts_int_to_local_str(ts_int):
    if ts_int is None or (isinstance(ts_int, float) and np.isnan(ts_int)):
        return None
    return pd.to_datetime(int(ts_int), unit="s", utc=True).tz_convert(tz).strftime("%Y-%m-%d %H:%M:%S %Z")

# Allowed component sets
os_list = [f"os_{i:03d}" for i in range(1, 23)]
docker_list = [f"docker_{i:03d}" for i in range(1, 9)]
db_list = [f"db_{i:03d}" for i in range(1, 14)]
allowed_list = set(os_list + docker_list + db_list)

# Incident window
start_ts = 1590768000
end_ts = 1590769800

# Compute global P95 per (cmdb_id, kpi_name) across full series (only allowed components)
allowed_metric_df = metric_df[metric_df['cmdb_id'].isin(allowed_list)].copy()

global_p95_df = (
    allowed_metric_df
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# Filter to incident window (inclusive)
window_df = allowed_metric_df[
    (allowed_metric_df['timestamp'] >= start_ts) &
    (allowed_metric_df['timestamp'] <= end_ts)
].copy()

# Merge window data with global P95
window_with_p95 = window_df.merge(global_p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# Mark anomalies where value >= global_p95
window_with_p95['is_anomaly'] = window_with_p95['value'] >= window_with_p95['global_p95']

# Compute window-level counts per KPI
win_counts = (
    window_with_p95
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(window_count=('value', 'size'), anomaly_count=('is_anomaly', 'sum'))
)

# Compute anomaly-specific aggregates (earliest anomaly timestamp and max anomaly value)
anomaly_only = window_with_p95[window_with_p95['is_anomaly']].copy()
anomaly_agg = (
    anomaly_only
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        earliest_anomaly_timestamp_raw=('timestamp', 'min'),
        max_anomaly_value=('value', 'max')
    )
)

# Build KPI-level summary (include KPIs that had no window data as well)
kpi_summary = global_p95_df.merge(win_counts, on=['cmdb_id', 'kpi_name'], how='left')
kpi_summary = kpi_summary.merge(anomaly_agg, on=['cmdb_id', 'kpi_name'], how='left')

kpi_summary['window_count'] = kpi_summary['window_count'].fillna(0).astype(int)
kpi_summary['anomaly_count'] = kpi_summary['anomaly_count'].fillna(0).astype(int)
kpi_summary['earliest_anomaly_timestamp_raw'] = kpi_summary['earliest_anomaly_timestamp_raw'].where(kpi_summary['earliest_anomaly_timestamp_raw'].notna(), None)
kpi_summary['max_anomaly_value'] = kpi_summary['max_anomaly_value'].where(kpi_summary['max_anomaly_value'].notna(), None)

# Compute breach ratio per KPI: if global_p95 > 0 -> max_anomaly_value / global_p95; if global_p95 == 0 -> use max_anomaly_value; else 0
def compute_breach_ratio(row):
    gp = row['global_p95']
    mv = row['max_anomaly_value']
    if mv is None or (isinstance(mv, float) and np.isnan(mv)):
        return 0.0
    if gp is None or (isinstance(gp, float) and np.isnan(gp)):
        return float(mv)
    try:
        if gp == 0:
            return float(mv)
        else:
            return float(mv) / float(gp)
    except Exception:
        return float(mv)

kpi_summary['breach_ratio'] = kpi_summary.apply(compute_breach_ratio, axis=1)

# Component-level aggregation
comp_agg = (
    kpi_summary
    .groupby('cmdb_id', as_index=False)
    .agg(
        total_kpis_scanned=('kpi_name', 'nunique'),
        num_kpis_with_anomalies=('anomaly_count', lambda s: int((s>0).sum())),
        total_anomaly_points=('anomaly_count', 'sum'),
        earliest_anomaly_timestamp_raw=('earliest_anomaly_timestamp_raw', lambda s: (int(s.dropna().min()) if s.dropna().shape[0]>0 else None)),
        max_breach_ratio=('breach_ratio', 'max')
    )
)

# Compute pct_kpis_anomalous and earliest local string
comp_agg['pct_kpis_anomalous'] = comp_agg.apply(lambda r: (r['num_kpis_with_anomalies'] / r['total_kpis_scanned']) if r['total_kpis_scanned']>0 else 0.0, axis=1).round(4)
comp_agg['earliest_anomaly_local'] = comp_agg['earliest_anomaly_timestamp_raw'].apply(lambda x: ts_int_to_local_str(x) if x is not None else None)

# Sort by num_kpis_with_anomalies desc and limit to top 20
comp_agg_sorted = comp_agg.sort_values(['num_kpis_with_anomalies', 'total_anomaly_points'], ascending=[False, False]).head(20).reset_index(drop=True)

# Totals across all components
total_components_with_any_anomaly = int((comp_agg['num_kpis_with_anomalies'] > 0).sum())
total_anomaly_points_all_components = int(comp_agg['total_anomaly_points'].sum())

totals_components = {
    "total_components_with_any_anomaly": total_components_with_any_anomaly,
    "total_anomaly_points_all_components": total_anomaly_points_all_components
}

# Keep output compact: selected columns and reasonable ordering
component_agg_top20 = comp_agg_sorted[[
    'cmdb_id',
    'total_kpis_scanned',
    'num_kpis_with_anomalies',
    'total_anomaly_points',
    'pct_kpis_anomalous',
    'earliest_anomaly_timestamp_raw',
    'earliest_anomaly_local',
    'max_breach_ratio'
]]

component_agg_top20, totals_components
