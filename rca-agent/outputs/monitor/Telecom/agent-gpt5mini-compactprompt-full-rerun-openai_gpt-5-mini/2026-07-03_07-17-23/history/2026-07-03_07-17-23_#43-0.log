import pandas as pd
import numpy as np
import pytz

# Reuse existing data if present
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')
    metric_df['timestamp'] = pd.to_numeric(metric_df['timestamp'], errors='coerce').astype('Int64')
    metric_df['value'] = pd.to_numeric(metric_df['value'], errors='coerce')

# timezone UTC+8
tz = pytz.timezone('Asia/Shanghai')

# 1) Compute global P95 and P5 per (cmdb_id, kpi_name) using full series (must be done before window filtering)
thresholds = (
    metric_df
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(global_P95=lambda x: x.quantile(0.95),
         global_P5 =lambda x: x.quantile(0.05))
    .reset_index()
)

# 2) Filter to incident window (inclusive)
start_ts = 1590777000
end_ts   = 1590778800
window_df = metric_df[(metric_df['timestamp'] >= start_ts) & (metric_df['timestamp'] <= end_ts)].copy()

# Merge thresholds into window
w = window_df.merge(thresholds, on=['cmdb_id','kpi_name'], how='left')

# 3) Flag anomalies per row
w['is_anomaly'] = ((w['value'] >= w['global_P95']) | (w['value'] <= w['global_P5'])).fillna(False)

# If no anomalies in window at all, return message
if w['is_anomaly'].sum() == 0:
    result = "No faults (consecutive anomalous runs) found in the incident window based on global P95/P5 thresholds."
else:
    # Prepare anomaly-only rows sorted
    anom = w[w['is_anomaly']].sort_values(['cmdb_id','kpi_name','timestamp']).copy()
    # 4) Group consecutive anomalous timestamps into faults (consecutive means diff == 60 seconds)
    # For each (cmdb_id, kpi_name) compute a fault sequence id by cumsum of breaks
    anom['ts_diff'] = anom.groupby(['cmdb_id','kpi_name'])['timestamp'].diff().fillna(0)
    anom['fault_seq'] = anom.groupby(['cmdb_id','kpi_name'])['ts_diff'].apply(lambda s: (s != 60).cumsum())

    # Aggregate per fault
    agg = (
        anom
        .groupby(['cmdb_id','kpi_name','fault_seq'], as_index=False)
        .agg(
            fault_start_epoch=('timestamp','min'),
            fault_end_epoch=('timestamp','max'),
            fault_length_minutes=('timestamp', lambda s: int((s.max()-s.min())/60) + 1),
            global_P95=('global_P95','first'),
            global_P5=('global_P5','first'),
            max_value_in_fault=('value','max'),
            min_value_in_fault=('value','min')
        )
    )

    # 5) Determine anomaly_type and breach_ratio
    # flags whether fault contains high/low breaches
    agg['high_flag'] = agg['max_value_in_fault'] >= agg['global_P95']
    agg['low_flag']  = agg['min_value_in_fault'] <= agg['global_P5']

    # compute potential breach ratios (safe denom)
    eps = 1e-9
    agg['high_breach_ratio'] = (agg['max_value_in_fault'] - agg['global_P95']) / np.maximum(eps, agg['global_P95'].abs())
    agg['low_breach_ratio']  = (agg['global_P5'] - agg['min_value_in_fault']) / np.maximum(eps, agg['global_P5'].abs())

    def choose_type(row):
        hf, lf = row['high_flag'], row['low_flag']
        if hf and not lf:
            return 'high', row['high_breach_ratio']
        if lf and not hf:
            return 'low', row['low_breach_ratio']
        if hf and lf:
            # choose stronger by larger breach ratio
            if row['high_breach_ratio'] >= row['low_breach_ratio']:
                return 'high', row['high_breach_ratio']
            else:
                return 'low', row['low_breach_ratio']
        # fallback (shouldn't occur) mark as high with ratio 0
        return 'high', 0.0

    chosen = agg.apply(lambda r: pd.Series(choose_type(r)), axis=1)
    chosen.columns = ['anomaly_type','breach_ratio']
    agg = pd.concat([agg, chosen], axis=1)

    # Format timestamps to UTC+8 readable strings
    agg['fault_start_timestamp'] = pd.to_datetime(agg['fault_start_epoch'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    agg['fault_end_timestamp']   = pd.to_datetime(agg['fault_end_epoch'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')

    # 6) Compute top 10 cmdb_ids by total_anomaly_points (recompute totals)
    per_cmdb_totals = w.groupby('cmdb_id')['is_anomaly'].sum().reset_index(name='total_anomaly_points')
    top10_cmdbs = per_cmdb_totals.sort_values('total_anomaly_points', ascending=False).head(10)['cmdb_id'].tolist()

    # Keep only faults for those top10 cmdb_ids
    faults_top_cmdbs = agg[agg['cmdb_id'].isin(top10_cmdbs)].copy()

    if faults_top_cmdbs.shape[0] == 0:
        result = "No faults found for top 10 cmdb_ids by anomaly volume in the incident window."
    else:
        # 6 cont.) Sort faults by fault_length_minutes desc then breach_ratio desc
        faults_top_cmdbs = faults_top_cmdbs.sort_values(by=['fault_length_minutes','breach_ratio'], ascending=[False, False]).reset_index(drop=True)

        # 7) Prepare final compact table and round numeric fields
        final_cols = [
            'cmdb_id','kpi_name',
            'fault_start_timestamp','fault_end_timestamp','fault_length_minutes','anomaly_type',
            'global_P95','global_P5','max_value_in_fault','min_value_in_fault','breach_ratio'
        ]
        faults_top20 = faults_top_cmdbs[final_cols].copy()

        # Round numeric columns for compactness
        for c in ['global_P95','global_P5','max_value_in_fault','min_value_in_fault','breach_ratio']:
            faults_top20[c] = faults_top20[c].round(6)

        faults_top20 = faults_top20.head(20)
        result = faults_top20

# Display result (DataFrame or message)
result
