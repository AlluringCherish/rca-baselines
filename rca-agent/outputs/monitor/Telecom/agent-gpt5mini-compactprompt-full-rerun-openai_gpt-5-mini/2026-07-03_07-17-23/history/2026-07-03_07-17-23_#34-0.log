import pandas as pd
import pytz
import datetime

sh = pytz.timezone('Asia/Shanghai')

# Targets
targets = ['os_020', 'db_011', 'os_001', 'os_002', 'os_010', 'os_005']

# Rebuild runs_filtered if not available to ensure consistent types
if 'runs_filtered' not in globals():
    # load metric_df and p95_df if missing
    if 'metric_df' not in globals():
        metric_df = pd.read_csv('metric.csv')
        metric_df['timestamp'] = pd.to_numeric(metric_df['timestamp'], errors='coerce').astype('Int64')
    if 'p95_df' not in globals():
        p95_df = (
            metric_df
            .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
            .quantile(0.95)
            .rename(columns={'value': 'global_p95'})
        )
    # window
    start = sh.localize(datetime.datetime(2020, 5, 27, 2, 30, 0))
    end = sh.localize(datetime.datetime(2020, 5, 27, 3, 0, 0))
    start_ts = int(start.timestamp())
    end_ts = int(end.timestamp())

    window_df = metric_df[(metric_df['timestamp'] >= start_ts) & (metric_df['timestamp'] <= end_ts)].copy()
    window_df = window_df.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')
    window_df['global_p95'] = window_df['global_p95'].fillna(0.0).astype(float)

    anom_df = (
        window_df[window_df['value'] >= window_df['global_p95']]
        .loc[:, ['cmdb_id', 'kpi_name', 'timestamp', 'value', 'global_p95']]
        .sort_values(['cmdb_id', 'kpi_name', 'timestamp'])
        .reset_index(drop=True)
    )

    if not anom_df.empty:
        def assign_runs(g):
            g = g.copy()
            g['ts_diff'] = g['timestamp'].diff().fillna(0)
            g['run_id'] = (g['ts_diff'] > 60).cumsum()
            return g
        anom_df = anom_df.groupby(['cmdb_id', 'kpi_name'], as_index=False, group_keys=False).apply(assign_runs)

        runs = (
            anom_df
            .groupby(['cmdb_id', 'kpi_name', 'run_id'], as_index=False)
            .agg(
                run_start_timestamp=('timestamp', 'min'),
                run_end_timestamp=('timestamp', 'max'),
                num_points_in_run=('timestamp', 'count'),
                max_value_in_run=('value', 'max'),
                global_p95=('global_p95', 'first')
            )
        )

        runs['breach_severity'] = runs.apply(
            lambda r: float((r['max_value_in_run'] - r['global_p95']) / r['max_value_in_run']) if r['max_value_in_run'] > 0 else 0.0,
            axis=1
        )

        runs_filtered = runs[(runs['num_points_in_run'] >= 3) & (runs['breach_severity'] > 0.5)].copy()
    else:
        runs_filtered = pd.DataFrame(columns=['cmdb_id','kpi_name','run_id','run_start_timestamp','run_end_timestamp','num_points_in_run','max_value_in_run','global_p95','breach_severity'])

# Select runs for targets
selected = runs_filtered[runs_filtered['cmdb_id'].isin(targets)].copy()

if selected.empty:
    selected_out = pd.DataFrame(columns=['cmdb_id','kpi_name','run_start_timestamp','run_end_timestamp','num_points_in_run','max_value_in_run','global_p95'])
    summary_line = "No filtered high-severity runs found for the requested cmdb_id candidates."
else:
    # ensure integer timestamp cols for sorting and summary
    selected['run_start_ts_int'] = selected['run_start_timestamp'].astype(int)
    selected['run_end_ts_int'] = selected['run_end_timestamp'].astype(int)

    # format timestamps for display (UTC+8)
    selected['run_start_timestamp'] = selected['run_start_ts_int'].apply(
        lambda ts: pd.to_datetime(int(ts), unit='s', utc=True).tz_convert(sh).strftime('%Y-%m-%d %H:%M:%S %Z')
    )
    selected['run_end_timestamp'] = selected['run_end_ts_int'].apply(
        lambda ts: pd.to_datetime(int(ts), unit='s', utc=True).tz_convert(sh).strftime('%Y-%m-%d %H:%M:%S %Z')
    )

    # prepare output table sorted by cmdb_id then run_start_timestamp
    selected_out = (
        selected
        .loc[:, ['cmdb_id', 'kpi_name', 'run_start_timestamp', 'run_end_timestamp', 'num_points_in_run', 'max_value_in_run', 'global_p95', 'run_start_ts_int']]
        .sort_values(by=['cmdb_id', 'run_start_ts_int'])
        .drop(columns=['run_start_ts_int'])
        .head(50)
        .reset_index(drop=True)
    )

    # Build one-line summary using integer timestamps and largest abs max_value_in_run per cmdb_id
    summary_items = []
    for cm in targets:
        cm_runs = selected[selected['cmdb_id'] == cm]
        if cm_runs.empty:
            continue
        earliest_ts_int = int(cm_runs['run_start_ts_int'].min())
        earliest_str = pd.to_datetime(earliest_ts_int, unit='s', utc=True).tz_convert(sh).strftime('%Y-%m-%d %H:%M:%S %Z')
        idx = cm_runs['max_value_in_run'].abs().idxmax()
        top_kpi = cm_runs.loc[idx, 'kpi_name']
        summary_items.append(f"{cm} earliest={earliest_str}, top_kpi={top_kpi}")

    summary_line = "; ".join(summary_items) if summary_items else "No runs for the requested cmdb_id candidates."

# Return compact outputs
selected_out, summary_line
