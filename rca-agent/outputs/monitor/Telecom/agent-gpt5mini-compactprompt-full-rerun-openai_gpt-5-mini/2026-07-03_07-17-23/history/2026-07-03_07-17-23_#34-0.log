import pandas as pd
import pytz
import datetime

sh = pytz.timezone('Asia/Shanghai')

# Reuse existing trace_df, trace_p95, trace_window if present; otherwise recreate
if 'trace_df' not in globals():
    trace_df = pd.read_csv('trace.csv')
trace_df['timestamp'] = pd.to_numeric(trace_df['timestamp'], errors='coerce').astype('Int64')

if 'trace_p95' not in globals():
    trace_p95 = (
        trace_df
        .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
        .quantile(0.95)
        .rename(columns={'value': 'global_p95'})
    )

# Incident window: May 27, 2020 02:30 – 02:59 (UTC+8)
start = sh.localize(datetime.datetime(2020, 5, 27, 2, 30, 0))
end = sh.localize(datetime.datetime(2020, 5, 27, 2, 59, 0))
start_ts = int(start.timestamp())
end_ts = int(end.timestamp())

trace_window = trace_df[(trace_df['timestamp'] >= start_ts) & (trace_df['timestamp'] <= end_ts)].copy()

# Merge precomputed global P95 (computed over full series) into windowed points
trace_window = trace_window.merge(trace_p95, on=['cmdb_id', 'trace_name'], how='left')
trace_window['global_p95'] = trace_window['global_p95'].fillna(0.0).astype(float)

# Mark anomalies where value >= global_p95
trace_window['is_anom'] = (trace_window['value'] >= trace_window['global_p95']).astype(int)
trace_window['anom_ts'] = trace_window['timestamp'].where(trace_window['is_anom'] == 1, pd.NA).astype('Float64')

# Aggregate per (cmdb_id, trace_name)
agg = (
    trace_window
    .groupby(['cmdb_id', 'trace_name'], as_index=False)
    .agg(
        global_p95=('global_p95', 'first'),
        anomaly_count_in_window=('is_anom', 'sum'),
        earliest_anomaly_timestamp=('anom_ts', 'min'),
        max_value_in_window=('value', 'max')
    )
)

# Format earliest_anomaly_timestamp to UTC+8 readable string, keep NA as pd.NA
def fmt_ts(x):
    if pd.isna(x):
        return pd.NA
    return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(sh).strftime('%Y-%m-%d %H:%M:%S %Z')

agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_timestamp'].apply(fmt_ts)

# Filter rows where trace_name contains 'os_020' OR max_value_in_window > 0.0
mask = agg['trace_name'].str.contains('os_020', na=False) | (agg['max_value_in_window'] > 0.0)
filtered = agg[mask].copy()

# Sort by max_value_in_window desc, then anomaly_count_in_window desc, limit to top 30
result_top30 = (
    filtered
    .sort_values(by=['max_value_in_window', 'anomaly_count_in_window'], ascending=[False, False])
    .loc[:, ['cmdb_id', 'trace_name', 'global_p95', 'anomaly_count_in_window', 'earliest_anomaly_timestamp', 'max_value_in_window']]
    .head(30)
    .reset_index(drop=True)
)

total_matches = int(filtered.shape[0])

# Display compact outputs
result_top30, total_matches
