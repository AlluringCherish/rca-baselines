import pandas as pd
import numpy as np
import pytz
import datetime

# reuse existing metric_df loaded previously in the session
# ensure timestamp numeric
metric_df['timestamp'] = pd.to_numeric(metric_df['timestamp'], errors='coerce').astype('Int64')

sh = pytz.timezone('Asia/Shanghai')

# 1) Compute global P95 per (cmdb_id, kpi_name) using entire metric_df (global thresholds)
p95_df = (
    metric_df
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# 2) Filter metric.csv to the incident window (May 27, 2020 02:30 to 03:00 inclusive) in UTC+8
start = sh.localize(datetime.datetime(2020, 5, 27, 2, 30, 0))
end = sh.localize(datetime.datetime(2020, 5, 27, 3, 0, 0))
start_ts = int(start.timestamp())
end_ts = int(end.timestamp())

window_df = metric_df[(metric_df['timestamp'] >= start_ts) & (metric_df['timestamp'] <= end_ts)].copy()

# 3) For each (cmdb_id, kpi_name) in that window, count points with value >= global_p95,
#    record earliest timestamp of such breach and the max value observed in the window.
# Merge global p95 into window
window_df = window_df.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# mark anomalies where value >= global_p95
window_df['is_anom'] = (window_df['value'] >= window_df['global_p95']).astype('int64')
# create anom timestamp column for earliest calculation (nullable)
window_df['anom_ts'] = window_df['timestamp'].where(window_df['is_anom'] == 1, pd.NA).astype('Float64')

# aggregate per component-KPI present in window
agg = (
    window_df
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        global_p95=('global_p95', 'first'),
        anomaly_count_in_window=('is_anom', 'sum'),
        earliest_anomaly_timestamp=('anom_ts', 'min'),
        max_value_in_window=('value', 'max')
    )
)

# format earliest_anomaly_timestamp into UTC+8 readable strings, keep NA as pd.NA
def fmt_ts(x):
    if pd.isna(x):
        return pd.NA
    return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(sh).strftime('%Y-%m-%d %H:%M:%S %Z')

agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_timestamp'].apply(fmt_ts)

# ensure proper dtypes for display
agg['anomaly_count_in_window'] = agg['anomaly_count_in_window'].astype(int)
agg['global_p95'] = agg['global_p95'].astype(float)
agg['max_value_in_window'] = agg['max_value_in_window'].astype(float)

# 4) Return compact table sorted by anomaly_count_in_window desc, top 20 rows, and total anomaly points in window
result_df_top20 = (
    agg
    .sort_values(by='anomaly_count_in_window', ascending=False)
    .loc[:, ['cmdb_id', 'kpi_name', 'global_p95', 'anomaly_count_in_window', 'earliest_anomaly_timestamp', 'max_value_in_window']]
    .head(20)
    .reset_index(drop=True)
)

total_anomalies = int(agg['anomaly_count_in_window'].sum())

result_df_top20, total_anomalies
