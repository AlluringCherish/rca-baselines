import pandas as pd
import pytz
import datetime

sh = pytz.timezone('Asia/Shanghai')

# Reuse trace_df if present; otherwise load
if 'trace_df' not in globals():
    trace_df = pd.read_csv('trace.csv')

# Ensure timestamp numeric
trace_df['timestamp'] = pd.to_numeric(trace_df['timestamp'], errors='coerce').astype('Int64')

# 1) Global P95 per (cmdb_id, trace_name) using entire trace_df
trace_p95 = (
    trace_df
    .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# 2) Filter trace.csv to the incident window (May 27, 2020 02:30 to 02:59 inclusive) UTC+8
start = sh.localize(datetime.datetime(2020, 5, 27, 2, 30, 0))
end = sh.localize(datetime.datetime(2020, 5, 27, 2, 59, 0))
start_ts = int(start.timestamp())
end_ts = int(end.timestamp())

trace_window = trace_df[(trace_df['timestamp'] >= start_ts) & (trace_df['timestamp'] <= end_ts)].copy()

# 3) For each (cmdb_id, trace_name) in window, count points with value >= global_p95,
#    earliest timestamp of such breach, and max value in-window.
# Merge global p95 into window
trace_window = trace_window.merge(trace_p95, on=['cmdb_id', 'trace_name'], how='left')

# Mark anomalies
trace_window['is_anom'] = (trace_window['value'] >= trace_window['global_p95']).astype('int64')
trace_window['anom_ts'] = trace_window['timestamp'].where(trace_window['is_anom'] == 1, pd.NA).astype('Float64')

agg_trace = (
    trace_window
    .groupby(['cmdb_id', 'trace_name'], as_index=False)
    .agg(
        global_p95=('global_p95', 'first'),
        anomaly_count_in_window=('is_anom', 'sum'),
        earliest_anomaly_timestamp=('anom_ts', 'min'),
        max_value_in_window=('value', 'max')
    )
)

# Format earliest timestamp to UTC+8 readable string, keep NA as pd.NA
def fmt_ts(x):
    if pd.isna(x):
        return pd.NA
    return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(sh).strftime('%Y-%m-%d %H:%M:%S %Z')

agg_trace['earliest_anomaly_timestamp'] = agg_trace['earliest_anomaly_timestamp'].apply(fmt_ts)

# Cast numeric types
agg_trace['global_p95'] = agg_trace['global_p95'].fillna(0.0).astype(float)
agg_trace['anomaly_count_in_window'] = agg_trace['anomaly_count_in_window'].astype(int)
agg_trace['max_value_in_window'] = agg_trace['max_value_in_window'].astype(float)

# 4) Return compact table sorted by anomaly_count_in_window desc, top 20, plus total anomalies sum
result_trace_top20 = (
    agg_trace
    .sort_values(by='anomaly_count_in_window', ascending=False)
    .loc[:, ['cmdb_id', 'trace_name', 'global_p95', 'anomaly_count_in_window', 'earliest_anomaly_timestamp', 'max_value_in_window']]
    .head(20)
    .reset_index(drop=True)
)

total_trace_anomalies = int(agg_trace['anomaly_count_in_window'].sum())

result_trace_top20, total_trace_anomalies
