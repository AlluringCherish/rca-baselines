docker_id = "docker_004"
docker_df = t_df[t_df["cmdb_id"] == docker_id].copy()

# incident window (inclusive) in Asia/Shanghai
start_as = tz.localize(pd.to_datetime("2020-05-22 01:30:00"))
end_as = tz.localize(pd.to_datetime("2020-05-22 02:00:00"))

if docker_df.empty:
    # empty result with expected columns
    result_top = pd.DataFrame(columns=[
        "trace_name","p95_threshold","count_of_exceeds_in_window",
        "earliest_exceed_timestamp_ASIA_SH","max_value_in_window",
        "total_points_in_window","breach_ratio"
    ])
else:
    # 1) global P95 per (docker_004, trace_name) using full series
    p95_df = docker_df.groupby("trace_name", sort=True)["value"].quantile(0.95).reset_index().rename(columns={"value":"p95_threshold"})

    # 2) windowed rows for docker_004
    window_df = docker_df[(docker_df["dt_as"] >= start_as) & (docker_df["dt_as"] <= end_as)].copy()

    # attach p95 to window rows for exceed computation
    if not window_df.empty:
        window_df = window_df.merge(p95_df, on="trace_name", how="left")
        window_df["is_exceed"] = (window_df["value"] > window_df["p95_threshold"]).astype(int)
        window_df["dt_exceed"] = window_df.apply(lambda r: r["dt_as"] if r["is_exceed"]==1 else pd.NaT, axis=1)

        window_agg = window_df.groupby("trace_name", sort=True).agg(
            total_points_in_window = ("value","count"),
            count_of_exceeds_in_window = ("is_exceed","sum"),
            earliest_exceed_timestamp_ASIA_SH = ("dt_exceed", lambda x: x.min() if x.dropna().shape[0]>0 else pd.NaT),
            max_value_in_window = ("value","max")
        ).reset_index()
    else:
        # no window points -> create empty agg
        window_agg = pd.DataFrame(columns=["trace_name","total_points_in_window","count_of_exceeds_in_window","earliest_exceed_timestamp_ASIA_SH","max_value_in_window"])

    # merge p95 (all trace_names) with window aggregates (may be empty for some trace_names)
    summary = p95_df.merge(window_agg, on="trace_name", how="left")

    # fill missing numeric window fields with zeros/NaN as appropriate
    summary["total_points_in_window"] = summary["total_points_in_window"].fillna(0).astype(int)
    summary["count_of_exceeds_in_window"] = summary["count_of_exceeds_in_window"].fillna(0).astype(int)
    # earliest_exceed_timestamp_ASIA_SH remains NaT if none
    # max_value_in_window stays NaN if no points

    # compute breach_ratio safely
    summary["breach_ratio"] = np.where(
        (summary["p95_threshold"] > 0) & (summary["max_value_in_window"].notna()),
        (summary["max_value_in_window"] - summary["p95_threshold"]) / summary["p95_threshold"],
        np.nan
    )

    # select required columns and sort by breach_ratio descending, limit to top 20
    out_cols = ["trace_name","p95_threshold","count_of_exceeds_in_window",
                "earliest_exceed_timestamp_ASIA_SH","max_value_in_window",
                "total_points_in_window","breach_ratio"]
    result_top = summary.loc[:, out_cols].sort_values(by="breach_ratio", ascending=False).head(20).reset_index(drop=True)

# Display compact result variable
result_top
