import pandas as pd
import numpy as np
import pytz

# reuse existing m_df if present, else load
if 'm_df' not in globals():
    m_df = pd.read_csv("metric.csv")

tz = pytz.timezone("Asia/Shanghai")

# Allowed components
db_list = [f"db_{i:03d}" for i in range(1, 14)]
docker_list = [f"docker_{i:03d}" for i in range(1, 9)]
os_list = [f"os_{i:03d}" for i in range(1, 23)]
allowed = set(db_list + docker_list + os_list)

# Identify present allowed components in metric data
present_components = sorted([c for c in m_df["cmdb_id"].dropna().unique() if c in allowed])

# Prepare datetime column in Asia/Shanghai for window filtering
m_df = m_df.copy()
m_df["dt_utc"] = pd.to_datetime(m_df["timestamp"], unit="s", utc=True)
m_df["dt_as"] = m_df["dt_utc"].dt.tz_convert(tz)

# Incident window (inclusive)
start_as = tz.localize(pd.to_datetime("2020-05-22 01:30:00"))
end_as = tz.localize(pd.to_datetime("2020-05-22 02:00:00"))

# Filter metric data to only present components for processing
proc_df = m_df[m_df["cmdb_id"].isin(present_components)]

# Compute global P95 per component-kpi using full series (rule 9)
grp = proc_df.groupby(["cmdb_id", "kpi_name"], sort=True)
p95_series = grp["value"].quantile(0.95)

# For each group, evaluate the incident-window stats
rows = []
for (cmdb_id, kpi_name), p95 in p95_series.items():
    full_count = grp.size().get((cmdb_id, kpi_name), np.nan)  # not used but could be helpful
    # window rows for this group
    mask = (proc_df["cmdb_id"] == cmdb_id) & (proc_df["kpi_name"] == kpi_name) & (proc_df["dt_as"] >= start_as) & (proc_df["dt_as"] <= end_as)
    window = proc_df.loc[mask]
    total_points_in_window = int(len(window))
    if total_points_in_window:
        exceeds = window[window["value"] > p95]
        count_of_exceeds = int(len(exceeds))
        if count_of_exceeds:
            earliest_exceed_ts = exceeds["dt_as"].min()  # timezone-aware
        else:
            earliest_exceed_ts = pd.NaT
        max_value_in_window = float(window["value"].max())
    else:
        count_of_exceeds = 0
        earliest_exceed_ts = pd.NaT
        max_value_in_window = np.nan

    rows.append({
        "component": cmdb_id,
        "kpi_name": kpi_name,
        "p95_threshold": float(p95),
        "count_of_exceeds_in_window": count_of_exceeds,
        "earliest_exceed_timestamp_ASIA_SH": earliest_exceed_ts,
        "max_value_in_window": max_value_in_window,
        "total_points_in_window": total_points_in_window
    })

result_df = pd.DataFrame(rows)

# Keep only entries with any points in window or with exceeds; still sort by count descending
result_df_sorted = result_df.sort_values(by=["count_of_exceeds_in_window", "max_value_in_window"], ascending=[False, False])

# Final compact output: top 20 rows
top20_df = result_df_sorted.head(20).reset_index(drop=True)

# Ensure compact display types (no huge objects)
top20_df[["component","kpi_name","p95_threshold","count_of_exceeds_in_window",
          "earliest_exceed_timestamp_ASIA_SH","max_value_in_window","total_points_in_window"]]
