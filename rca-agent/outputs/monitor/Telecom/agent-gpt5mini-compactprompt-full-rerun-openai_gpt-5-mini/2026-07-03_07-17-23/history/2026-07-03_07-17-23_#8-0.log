import pandas as pd
import pytz
import numpy as np

# Reuse m_df if present, otherwise load
try:
    m_df
except NameError:
    m_df = pd.read_csv("metric.csv")

# Timezone
tz = pytz.timezone("Asia/Shanghai")

# Ensure datetime column in Asia/Shanghai for window filtering
m_df_dt = m_df.copy()
m_df_dt["datetime_asia_shanghai"] = pd.to_datetime(m_df_dt["timestamp"], unit="s", utc=True).dt.tz_convert(tz)

# Allowed root-cause components
db_components = [f"db_{i:03d}" for i in range(1, 14)]
docker_components = [f"docker_{i:03d}" for i in range(1, 9)]
os_components = [f"os_{i:03d}" for i in range(1, 23)]
allowed_components = set(db_components + docker_components + os_components)

# Determine which allowed components are present in metric data
present_components = sorted([c for c in m_df_dt["cmdb_id"].dropna().unique() if c in allowed_components])

# Filter metric data to only present allowed components
m_allowed = m_df_dt[m_df_dt["cmdb_id"].isin(present_components)].copy()

# 1) Compute global P95 per (component, kpi_name) using full series (no window filter)
p95_df = (
    m_allowed
    .groupby(["cmdb_id", "kpi_name"], sort=False)["value"]
    .quantile(0.95)
    .reset_index()
    .rename(columns={"value": "p95_threshold"})
)

# 2) Define incident window in Asia/Shanghai and filter rows within window
window_start = pd.Timestamp("2020-05-22 01:30:00").tz_localize(tz)
window_end = pd.Timestamp("2020-05-22 02:00:00").tz_localize(tz)
window_mask = (m_allowed["datetime_asia_shanghai"] >= window_start) & (m_allowed["datetime_asia_shanghai"] <= window_end)
window_df = m_allowed[window_mask].copy()

# Merge p95 thresholds into full metric rows (so we can compare)
m_allowed = m_allowed.merge(p95_df, on=["cmdb_id", "kpi_name"], how="left")
window_df = window_df.merge(p95_df, on=["cmdb_id", "kpi_name"], how="left")

# Aggregates in the window for all points (total points, max value)
window_all_agg = (
    window_df
    .groupby(["cmdb_id", "kpi_name"], sort=False)
    .agg(
        total_points_in_window=("value", "size"),
        max_value_in_window=("value", "max")
    )
    .reset_index()
)

# Exceeds: rows in window where value > p95_threshold
window_exceeds = window_df[window_df["value"] > window_df["p95_threshold"]].copy()

# Aggregates for exceeds: count and earliest timestamp
if not window_exceeds.empty:
    window_exceeds_agg = (
        window_exceeds
        .groupby(["cmdb_id", "kpi_name"], sort=False)
        .agg(
            count_of_exceeds_in_window=("value", "size"),
            earliest_exceed_timestamp_ASIA_SH=("datetime_asia_shanghai", "min")
        )
        .reset_index()
else:
    # empty placeholder
    window_exceeds_agg = pd.DataFrame(columns=["cmdb_id","kpi_name","count_of_exceeds_in_window","earliest_exceed_timestamp_ASIA_SH"])

# Combine p95, window_all_agg, and window_exceeds_agg
result = (
    p95_df
    .merge(window_all_agg, on=["cmdb_id", "kpi_name"], how="left")
    .merge(window_exceeds_agg, on=["cmdb_id", "kpi_name"], how="left")
)

# Fill NaNs: counts -> 0, earliest timestamps remain NaT, max_value NaN keep as NaN
result["total_points_in_window"] = result["total_points_in_window"].fillna(0).astype(int)
result["count_of_exceeds_in_window"] = result["count_of_exceeds_in_window"].fillna(0).astype(int)

# For presentation, round p95 to 6 decimals
result["p95_threshold"] = result["p95_threshold"].astype(float).round(6)

# Keep only component-KPIs that have any points in the window (total_points_in_window > 0)
result_in_window = result[result["total_points_in_window"] > 0].copy()

