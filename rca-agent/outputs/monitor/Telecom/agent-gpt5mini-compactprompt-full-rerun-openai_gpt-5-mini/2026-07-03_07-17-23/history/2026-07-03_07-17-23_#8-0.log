import pandas as pd
import numpy as np
import pytz

# Reuse existing m_df if present, else load
if 'm_df' not in globals():
    m_df = pd.read_csv("metric.csv")

# Ensure timezone and datetime columns (Asia/Shanghai, UTC+8)
tz = pytz.timezone("Asia/Shanghai")
m_df = m_df.copy()
m_df["dt_utc"] = pd.to_datetime(m_df["timestamp"], unit="s", utc=True)
m_df["dt_as"] = m_df["dt_utc"].dt.tz_convert(tz)

# Focus on docker_004
component = "docker_004"
docker_df = m_df[m_df["cmdb_id"] == component].copy()

# Incident window (inclusive) in Asia/Shanghai
start_as = tz.localize(pd.to_datetime("2020-05-22 01:30:00"))
end_as = tz.localize(pd.to_datetime("2020-05-22 02:00:00"))

if docker_df.empty:
    docker_kpi_summary_top20 = pd.DataFrame(columns=[
        "kpi_name","p95_threshold","p05_threshold","total_points_in_window",
        "count_above_p95","earliest_above_p95_timestamp_ASIA_SH","max_value_in_window",
        "count_below_p05","earliest_below_p05_timestamp_ASIA_SH","min_value_in_window",
        "breach_ratio_high"
    ])
else:
    # Compute global P95 and P05 per kpi_name using full series
    p95 = docker_df.groupby("kpi_name", sort=True)["value"].quantile(0.95).reset_index().rename(columns={"value":"p95_threshold"})
    p05 = docker_df.groupby("kpi_name", sort=True)["value"].quantile(0.05).reset_index().rename(columns={"value":"p05_threshold"})
    thresholds = p95.merge(p05, on="kpi_name", how="outer")

    # Windowed data
    window_df = docker_df[(docker_df["dt_as"] >= start_as) & (docker_df["dt_as"] <= end_as)].copy()

    if not window_df.empty:
        w = window_df.merge(thresholds, on="kpi_name", how="left")
        w["above_p95"] = (w["value"] > w["p95_threshold"]).astype(int)
        w["below_p05"] = (w["value"] < w["p05_threshold"]).astype(int)
        w["dt_above_p95"] = w.apply(lambda r: r["dt_as"] if r["above_p95"]==1 else pd.NaT, axis=1)
        w["dt_below_p05"] = w.apply(lambda r: r["dt_as"] if r["below_p05"]==1 else pd.NaT, axis=1)

        agg = w.groupby("kpi_name", sort=True).agg(
            total_points_in_window = ("value","count"),
            count_above_p95 = ("above_p95","sum"),
            earliest_above_p95_timestamp_ASIA_SH = ("dt_above_p95", lambda x: x.min() if x.dropna().shape[0]>0 else pd.NaT),
            max_value_in_window = ("value","max"),
            count_below_p05 = ("below_p05","sum"),
            earliest_below_p05_timestamp_ASIA_SH = ("dt_below_p05", lambda x: x.min() if x.dropna().shape[0]>0 else pd.NaT),
            min_value_in_window = ("value","min")
        ).reset_index()
    else:
        agg = pd.DataFrame(columns=[
            "kpi_name","total_points_in_window","count_above_p95","earliest_above_p95_timestamp_ASIA_SH",
            "max_value_in_window","count_below_p05","earliest_below_p05_timestamp_ASIA_SH","min_value_in_window"
        ])

    # Merge thresholds with window aggregates
    summary = thresholds.merge(agg, on="kpi_name", how="left")

    # Fill numeric NaNs for window metrics with zeros where appropriate
    summary["total_points_in_window"] = summary["total_points_in_window"].fillna(0).astype(int)
    summary["count_above_p95"] = summary["count_above_p95"].fillna(0).astype(int)
    summary["count_below_p05"] = summary["count_below_p05"].fillna(0).astype(int)

    # Compute breach_ratio_high safely to avoid division by zero
    summary["breach_ratio_high"] = np.nan
    mask = (summary["p95_threshold"] > 0) & (summary["max_value_in_window"].notna())
    summary.loc[mask, "breach_ratio_high"] = (
        (summary.loc[mask, "max_value_in_window"] - summary.loc[mask, "p95_threshold"])
        / summary.loc[mask, "p95_threshold"]
    )

    # Select and sort top 20 by breach_ratio_high descending
    out_cols = ["kpi_name","p95_threshold","p05_threshold","total_points_in_window",
                "count_above_p95","earliest_above_p95_timestamp_ASIA_SH","max_value_in_window",
                "count_below_p05","earliest_below_p05_timestamp_ASIA_SH","min_value_in_window",
                "breach_ratio_high"]
    docker_kpi_summary_top20 = summary.loc[:, out_cols].sort_values(by="breach_ratio_high", ascending=False).head(20).reset_index(drop=True)

# Final compact output variable
docker_kpi_summary_top20
