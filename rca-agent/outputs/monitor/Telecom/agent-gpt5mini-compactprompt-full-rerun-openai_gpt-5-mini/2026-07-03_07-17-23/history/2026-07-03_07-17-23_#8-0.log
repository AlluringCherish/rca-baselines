import pandas as pd
import numpy as np
import pytz

# reuse existing t_df if present, else load
if 't_df' not in globals():
    t_df = pd.read_csv("trace.csv")

# timezone
tz = pytz.timezone("Asia/Shanghai")

# prepare datetimes
t_df = t_df.copy()
t_df["dt_utc"] = pd.to_datetime(t_df["timestamp"], unit="s", utc=True)
t_df["dt_as"] = t_df["dt_utc"].dt.tz_convert(tz)

# incident window (inclusive) in Asia/Shanghai
start_as = tz.localize(pd.to_datetime("2020-05-22 01:30:00"))
end_as = tz.localize(pd.to_datetime("2020-05-22 02:00:00"))

# 1) compute global P95 per (cmdb_id, trace_name) using full series
p95_df = t_df.groupby(["cmdb_id", "trace_name"], sort=True)["value"].quantile(0.95).reset_index().rename(columns={"value":"p95_threshold"})

# 2) filter to incident window and attach p95 to window rows
window_df = t_df[(t_df["dt_as"] >= start_as) & (t_df["dt_as"] <= end_as)].copy()
window_merged = window_df.merge(p95_df, on=["cmdb_id","trace_name"], how="left")

# mark exceeds and dt_exceed for earliest computation
window_merged["is_exceed"] = (window_merged["value"] > window_merged["p95_threshold"]).astype(int)
window_merged["dt_exceed"] = window_merged.apply(lambda r: r["dt_as"] if r["is_exceed"]==1 else pd.NaT, axis=1)

# aggregate window stats per pair
agg = window_merged.groupby(["cmdb_id","trace_name"], sort=True).agg(
    total_points_in_window = ("value","count"),
    count_of_exceeds_in_window = ("is_exceed","sum"),
    earliest_exceed_timestamp_ASIA_SH = ("dt_exceed", lambda x: x.min() if len(x.dropna())>0 else pd.NaT),
    max_value_in_window = ("value","max")
).reset_index()

# left-join with full p95 list to ensure pairs with no window points are included
summary = p95_df.merge(agg, on=["cmdb_id","trace_name"], how="left")

# fill NaNs for counts/metrics where no window points exist
summary["total_points_in_window"] = summary["total_points_in_window"].fillna(0).astype(int)
summary["count_of_exceeds_in_window"] = summary["count_of_exceeds_in_window"].fillna(0).astype(int)
# earliest_exceed_timestamp_ASIA_SH remains NaT if none; max_value_in_window stays NaN if no points

# compute breach_ratio safely
summary["breach_ratio"] = np.where(
    (summary["p95_threshold"] > 0) & (summary["max_value_in_window"].notna()),
    (summary["max_value_in_window"] - summary["p95_threshold"]) / summary["p95_threshold"],
    np.nan
)

# select and sort top 20 by breach_ratio desc
out_cols = ["cmdb_id","trace_name","p95_threshold","count_of_exceeds_in_window",
            "earliest_exceed_timestamp_ASIA_SH","max_value_in_window","total_points_in_window","breach_ratio"]
top20_traces = summary.loc[:, out_cols].sort_values(by="breach_ratio", ascending=False).head(20).reset_index(drop=True)

top20_traces
