import pandas as pd
import numpy as np
import pytz

# Reuse existing dfs if present, otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv("metric.csv")
try:
    df_trace
except NameError:
    df_trace = pd.read_csv("trace.csv")

tz = pytz.timezone('Asia/Shanghai')

# Helper to convert epoch to localized string (or None)
def epoch_to_local_str(epoch):
    if pd.isna(epoch):
        return None
    return pd.to_datetime(int(epoch), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z')

# 1) Define candidate components: intersection of metric cmdb_ids and known lists
os_list = [f"os_{i:03d}" for i in range(1, 23)]          # os_001 .. os_022
docker_list = [f"docker_{i:03d}" for i in range(1, 9)]    # docker_001 .. docker_008
db_list = [f"db_{i:03d}" for i in range(1, 14)]          # db_001 .. db_013
possible_components = set(os_list + docker_list + db_list)

metric_cmdb_unique = set(df_metric['cmdb_id'].dropna().unique())
candidate_components = sorted(metric_cmdb_unique.intersection(possible_components))

# Keep candidate metric rows for subsequent analysis
df_metric_candidates = df_metric[df_metric['cmdb_id'].isin(candidate_components)].copy()

# 2) Metric thresholds (global) per (cmdb_id, kpi_name) BEFORE window filtering
# Compute P95 and P5 using the full series for candidate components
metric_thresholds = (
    df_metric_candidates
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .quantile([0.95, 0.05])
    .unstack(level=-1)
    .rename(columns={0.05: 'P5', 0.95: 'P95'})
    .reset_index()
)

# Ensure columns exist and sort
metric_thresholds = metric_thresholds[['cmdb_id', 'kpi_name', 'P95', 'P5']]

# Define failure window
start_ts = 1590175800
end_ts = 1590177600

# Filter metric rows to failure window (inclusive)
df_metric_window = df_metric_candidates[(df_metric_candidates['timestamp'] >= start_ts) &
                                       (df_metric_candidates['timestamp'] <= end_ts)].copy()

# Merge thresholds into windowed metric rows for anomaly detection
df_metric_window = df_metric_window.merge(metric_thresholds, on=['cmdb_id', 'kpi_name'], how='left', validate='m:1')

# Determine anomalies: high (>=P95) or low (<=P5)
df_metric_window['is_high'] = df_metric_window['value'] >= df_metric_window['P95']
df_metric_window['is_low'] = df_metric_window['value'] <= df_metric_window['P5']
df_metric_window['is_anomaly'] = df_metric_window['is_high'] | df_metric_window['is_low']

# Aggregate per (cmdb_id, kpi_name) within window
metric_agg = (
    df_metric_window
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        window_count=('value', 'size'),
        anomaly_count=('is_anomaly', 'sum'),
        earliest_anom_epoch=('timestamp', lambda s: int(s[df_metric_window.loc[s.index, 'is_anomaly']].min()) if any(df_metric_window.loc[s.index, 'is_anomaly']) else np.nan),
        mean_value_in_window=('value', 'mean'),
        max_value_in_window=('value', 'max')
    )
)

# Join thresholds into the aggregated table (for groups that might have 0 window rows, thresholds still in metric_thresholds)
metric_agg = metric_agg.merge(metric_thresholds, on=['cmdb_id', 'kpi_name'], how='left', validate='1:1')

# Convert earliest_anom_epoch to localized string
metric_agg['earliest_anomaly_ts'] = metric_agg['earliest_anom_epoch'].apply(lambda x: epoch_to_local_str(x) if not pd.isna(x) else None)
metric_agg = metric_agg.drop(columns=['earliest_anom_epoch'])

# Replace NaN anomaly_count with 0 and ensure integer types for counts
metric_agg['anomaly_count'] = metric_agg['anomaly_count'].fillna(0).astype(int)
metric_agg['window_count'] = metric_agg['window_count'].fillna(0).astype(int)

# Sort by anomaly_count desc and limit to top 20
metric_agg_top20 = metric_agg.sort_values(['anomaly_count', 'window_count'], ascending=[False, False]).head(20)

# Select and order required columns
metric_agg_top20 = metric_agg_top20[['cmdb_id', 'kpi_name', 'P95', 'P5', 'window_count', 'anomaly_count', 'earliest_anomaly_ts', 'mean_value_in_window', 'max_value_in_window']]

# 3) Trace analysis: global thresholds per trace_name across full trace.csv
trace_thresholds = (
    df_trace
    .groupby('trace_name')['value']
    .quantile([0.95, 0.05])
    .unstack(level=-1)
    .rename(columns={0.05: 'P5', 0.95: 'P95'})
    .reset_index()
)
trace_thresholds = trace_thresholds[['trace_name', 'P95', 'P5']]

# Filter trace rows to failure window
df_trace_window = df_trace[(df_trace['timestamp'] >= start_ts) & (df_trace['timestamp'] <= end_ts)].copy()

