import pandas as pd
import numpy as np
import pytz

# reuse existing variables from kernel if present
tz = pytz.timezone('Asia/Shanghai')

# Ensure global p95 per (cmdb_id, kpi_name) exists (compute if not)
if 'p95_df' not in globals():
    p95_df = (
        metric_df
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
        .quantile(0.95)
        .rename(columns={'value': 'p95'})
    )

# Define incident window in UTC+8
start_ts = int(pd.Timestamp('2020-04-11 01:30:00', tz=tz).timestamp())
end_ts = int(pd.Timestamp('2020-04-11 02:00:00', tz=tz).timestamp())

# Filter metric_df to window and to nodes starting with 'os_'
window_os = metric_df[
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts) &
    (metric_df['cmdb_id'].str.startswith('os_'))
].copy()

# If no data in window for os_ nodes, return empty DataFrame with required columns
columns = ['cmdb_id', 'faulty_kpi_count', 'earliest_breach_timestamp', 'total_breaches', 'max_severity_ratio']
if window_os.shape[0] == 0:
    node_summary_top20 = pd.DataFrame(columns=columns)
else:
    # Merge windowed data with global p95
    merged = window_os.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

    # Mark breaches
    merged['is_breach'] = merged['value'] > merged['p95']

    # Breaches dataframe
    breaches_df = merged[merged['is_breach']].copy()

    if breaches_df.shape[0] == 0:
        node_summary_top20 = pd.DataFrame(columns=columns)
    else:
        # 1) faulty_kpi_count: distinct kpi_name with at least one breach per node
        faulty_kpi_count = breaches_df.groupby('cmdb_id')['kpi_name'].nunique().rename('faulty_kpi_count')

        # 2) earliest_breach_timestamp per node
        earliest_breach = breaches_df.groupby('cmdb_id')['timestamp'].min().rename('earliest_breach_timestamp')

        # 4) total_breaches per node (total breach datapoints)
        total_breaches = breaches_df.groupby('cmdb_id').size().rename('total_breaches')

        # 3) max_severity_ratio:
        # compute per-(node,kpi) max_value_in_window from merged (window)
        per_kpi_max = (
            merged
            .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
            .max()
            .rename(columns={'value': 'max_value_in_window'})
        )
        # attach global p95
        per_kpi_max = per_kpi_max.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')
        # compute per-kpi severity_ratio, handle p95 == 0
        per_kpi_max['severity_ratio'] = per_kpi_max.apply(
            lambda r: np.inf if pd.notna(r['p95']) and r['p95'] == 0 else (r['max_value_in_window'] / r['p95'] if pd.notna(r['p95']) else np.nan),
            axis=1
        )
        # For node-level, take max severity_ratio across kpis that appear in the window
        max_severity_ratio = per_kpi_max.groupby('cmdb_id', as_index=True)['severity_ratio'].max().rename('max_severity_ratio')

        # Combine node-level aggregates
        node_summary = pd.concat([faulty_kpi_count, earliest_breach, total_breaches, max_severity_ratio], axis=1).reset_index()

        # Keep only nodes with faulty_kpi_count > 0 (they are from breaches_df so should qualify)
        node_summary = node_summary[node_summary['faulty_kpi_count'] > 0].copy()

        # Sort by max_severity_ratio desc then total_breaches desc
        node_summary_top20 = node_summary.sort_values(['max_severity_ratio', 'total_breaches'], ascending=[False, False]).head(20)

        # Select required columns and ensure column order
        node_summary_top20 = node_summary_top20[['cmdb_id', 'faulty_kpi_count', 'earliest_breach_timestamp', 'total_breaches', 'max_severity_ratio']]

        node_summary_top20 = node_summary_top20.reset_index(drop=True)
        node_summary_top20.columns = columns  # ensure exact column names

# Display the compact node-level summary (top up to 20 rows)
node_summary_top20
