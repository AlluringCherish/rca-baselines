import pandas as pd
import pytz

# set timezone to UTC+8 as required (Asia/Shanghai)
tz = pytz.timezone('Asia/Shanghai')

# Load CSV files
metric_df = pd.read_csv('metric.csv')
trace_df = pd.read_csv('trace.csv')

# --- metric.csv summary ---
metric_count = metric_df.shape[0]
metric_unique_cmdb = pd.Series(metric_df['cmdb_id'].unique(), name='cmdb_id').head(20)  # show up to 20
metric_top_kpis = (
    metric_df['kpi_name']
    .value_counts()
    .reset_index()
    .rename(columns={'index': 'kpi_name', 'kpi_name': 'count'})
    .head(20)
)
metric_min_ts = metric_df['timestamp'].min() if 'timestamp' in metric_df.columns else None
metric_max_ts = metric_df['timestamp'].max() if 'timestamp' in metric_df.columns else None
metric_summary_counts = pd.DataFrame([{
    'total_rows': metric_count,
    'unique_cmdb_count': metric_df['cmdb_id'].nunique(),
    'min_timestamp': metric_min_ts,
    'max_timestamp': metric_max_ts
}])

# --- trace.csv summary ---
trace_count = trace_df.shape[0]
trace_unique_cmdb = pd.Series(trace_df['cmdb_id'].unique(), name='cmdb_id').head(20)  # show up to 20
trace_top_traces = (
    trace_df['trace_name']
    .value_counts()
    .reset_index()
    .rename(columns={'index': 'trace_name', 'trace_name': 'count'})
    .head(20)
)
trace_min_ts = trace_df['timestamp'].min() if 'timestamp' in trace_df.columns else None
trace_max_ts = trace_df['timestamp'].max() if 'timestamp' in trace_df.columns else None
trace_summary_counts = pd.DataFrame([{
    'total_rows': trace_count,
    'unique_cmdb_count': trace_df['cmdb_id'].nunique(),
    'min_timestamp': trace_min_ts,
    'max_timestamp': trace_max_ts
}])

# Display concise summaries (variables only)
metric_summary_counts, metric_unique_cmdb, metric_top_kpis, trace_summary_counts, trace_unique_cmdb, trace_top_traces
