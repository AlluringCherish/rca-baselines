# Reuse existing metric_df and tz from the kernel
import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# 1) Compute global P95 per (cmdb_id, kpi_name) using the full metric_df
p95_df = (
    metric_df
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'p95'})
)

# 2) Define incident window in UTC+8 and convert to epoch seconds
start_ts = int(pd.Timestamp('2020-04-11 01:30:00', tz=tz).timestamp())
end_ts = int(pd.Timestamp('2020-04-11 02:00:00', tz=tz).timestamp())

# Filter metric_df to the incident window
window_df = metric_df[(metric_df['timestamp'] >= start_ts) & (metric_df['timestamp'] <= end_ts)].copy()

# If window_df is empty, return empty DataFrame with required columns
if window_df.shape[0] == 0:
    anomalies_top20 = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','count_in_window','breaches_count',
        'earliest_breach_timestamp','max_value_in_window','p95','severity_ratio'
    ])
else:
    # 3) Merge windowed data with global p95
    merged = window_df.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

    # mark breaches where value > p95 (note: p95 computed from full series)
    merged['is_breach'] = merged['value'] > merged['p95']

    # aggregates: count_in_window and max_value_in_window from merged
    counts = merged.groupby(['cmdb_id', 'kpi_name'], as_index=True)['value'].count().rename('count_in_window')
    max_vals = merged.groupby(['cmdb_id', 'kpi_name'], as_index=True)['value'].max().rename('max_value_in_window')

    # breaches_count and earliest_breach_timestamp from breached subset
    breached = merged[merged['is_breach']]
    if breached.shape[0] == 0:
        # no breaches in window
        anomalies_top20 = pd.DataFrame(columns=[
            'cmdb_id','kpi_name','count_in_window','breaches_count',
            'earliest_breach_timestamp','max_value_in_window','p95','severity_ratio'
        ])
    else:
        breaches_count = breached.groupby(['cmdb_id', 'kpi_name'], as_index=True)['is_breach'].count().rename('breaches_count')
        earliest_breach = breached.groupby(['cmdb_id', 'kpi_name'], as_index=True)['timestamp'].min().rename('earliest_breach_timestamp')

        # Combine aggregates into one DataFrame
        agg = pd.concat([counts, breaches_count, earliest_breach, max_vals], axis=1).reset_index()

        # Attach p95 by merging with p95_df
        agg = agg.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

        # 3) compute severity_ratio = max_value_in_window / p95 (as float)
        # Avoid division by zero: where p95 == 0, set severity_ratio to np.inf
        agg['severity_ratio'] = agg['max_value_in_window'] / agg['p95']
        agg.loc[agg['p95'] == 0, 'severity_ratio'] = np.inf

        # 4) Keep only rows with breaches_count > 0 (already ensured by using breached groups, but ensure)
        agg = agg[agg['breaches_count'] > 0].copy()

        # 5) Sort by breaches_count desc then severity_ratio desc and limit to top 20
        anomalies_top20 = agg.sort_values(['breaches_count', 'severity_ratio'], ascending=[False, False])[
            ['cmdb_id', 'kpi_name', 'count_in_window', 'breaches_count',
             'earliest_breach_timestamp', 'max_value_in_window', 'p95', 'severity_ratio']
        ].head(20).reset_index(drop=True)

# Display the compact aggregated anomalies (top up to 20 rows)
anomalies_top20
