        'global_p95': gp95,
        'count_of_breaches': breaches_count,
        'earliest_breach_timestamp': earliest,
        'latest_breach_timestamp': latest,
        'max_value_in_window': max_val_in_window,
        'severity_ratio': severity,
        'consecutive_run': consecutive_run
    })

