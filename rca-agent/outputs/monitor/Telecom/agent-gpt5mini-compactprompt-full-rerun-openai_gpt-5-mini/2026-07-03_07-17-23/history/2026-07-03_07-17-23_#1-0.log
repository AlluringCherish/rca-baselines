    'earliest_breach_timestamp','latest_breach_timestamp',
    'max_value_in_window','severity_ratio','consecutive_run'
]]

breaches_df = pd.concat(breach_rows_list, ignore_index=True)
breaches_df_limited = breaches_df.head(20)

# Display compact results: agg_df (2 rows) and breach rows up to 20
agg_df, breaches_df_limited
