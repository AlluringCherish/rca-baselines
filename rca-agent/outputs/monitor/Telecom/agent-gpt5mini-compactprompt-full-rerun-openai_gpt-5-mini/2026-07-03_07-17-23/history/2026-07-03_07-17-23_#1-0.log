# Reuse existing metric_df and tz from the kernel
import pandas as pd
import pytz

# ensure timezone variable exists (UTC+8)
tz = pytz.timezone('Asia/Shanghai')

# Aggregate by cmdb_id and kpi_name over the full metric_df
grp = metric_df.groupby(['cmdb_id', 'kpi_name'])
agg = grp.agg(
    count=('value', 'count'),
    min_timestamp=('timestamp', 'min'),
    max_timestamp=('timestamp', 'max'),
    p50=('value', lambda x: x.quantile(0.5)),
    p90=('value', lambda x: x.quantile(0.9)),
    p95=('value', lambda x: x.quantile(0.95))
).reset_index()

# Sort by p95 descending and take top 20
top20_agg = agg.sort_values('p95', ascending=False).head(20)[
    ['cmdb_id', 'kpi_name', 'count', 'min_timestamp', 'max_timestamp', 'p50', 'p90', 'p95']
]

top20_agg
