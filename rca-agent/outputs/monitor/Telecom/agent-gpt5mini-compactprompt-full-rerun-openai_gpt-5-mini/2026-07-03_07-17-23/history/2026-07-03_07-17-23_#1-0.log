import pandas as pd
import numpy as np
import pytz

# reuse existing variables from kernel where possible
tz = pytz.timezone('Asia/Shanghai')

# Ensure global p95 per (cmdb_id, kpi_name) exists
if 'p95_df' not in globals():
    p95_df = (
        metric_df
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
        .quantile(0.95)
        .rename(columns={'value': 'p95'})
    )

# Incident window (UTC+8)
start_ts = int(pd.Timestamp('2020-04-11 01:30:00', tz=tz).timestamp())
end_ts = int(pd.Timestamp('2020-04-11 02:00:00', tz=tz).timestamp())

# Node candidates
nodes = ['os_020', 'os_004', 'os_003', 'os_005', 'os_019', 'os_007']

# Filter metric_df to window and to candidate nodes
window_nodes = metric_df[
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts) &
    (metric_df['cmdb_id'].isin(nodes))
].copy()

# Merge with global p95
merged = window_nodes.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# Determine breaches (value > p95) only when p95 is present (NaN p95 -> not a breach)
merged['is_breach'] = merged.apply(lambda r: (r['value'] > r['p95']) if pd.notna(r['p95']) else False, axis=1)

# Breach rows
breaches = merged[merged['is_breach']].copy()

# If no breaches, return empty frame with requested columns
cols = ['cmdb_id', 'category', 'distinct_breached_kpi_count', 'total_breach_points',
        'earliest_breach_timestamp', 'max_category_severity', 'p95_zero_flag']
if breaches.shape[0] == 0:
    node_category_summary = pd.DataFrame(columns=cols)
else:
    # Compute per-(node,kpi) max_value_in_window using window data (not only breaches)
    per_kpi_max = (
        merged
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
        .max()
        .rename(columns={'value': 'max_value_in_window'})
    )
    # attach global p95
    per_kpi_max = per_kpi_max.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

    # Compute per-kpi severity and p95_zero_flag
    def compute_severity(row):
        if pd.isna(row['p95']):
            return (np.nan, False)
        if row['p95'] == 0:
            # if max_value_in_window > 0, severity is inf and flag true; else NaN and flag False
            if row['max_value_in_window'] > 0:
                return (np.inf, True)
            else:
                return (np.nan, False)
        else:
            return (float(row['max_value_in_window'] / row['p95']), False)

    sev_results = per_kpi_max.apply(lambda r: compute_severity(r), axis=1)
    per_kpi_max['severity'] = [s for s, f in sev_results]
    per_kpi_max['p95_zero_flag'] = [f for s, f in sev_results]

    # Keep only per_kpi rows that actually had at least one breach in window (focus on breached KPIs)
    breached_kpis = breaches[['cmdb_id','kpi_name']].drop_duplicates()
    per_kpi_breached = per_kpi_max.merge(breached_kpis, on=['cmdb_id','kpi_name'], how='inner')

    # Category assignment function (case-sensitive substrings as specified)
    def categorize(k):
        if ('Processor' in k) or ('CPU' in k):
            return 'CPU'
        if ('Disk' in k) or ('Disk_' in k) or ('Disk.' in k):
            return 'Disk'
        if ('network' in k) or ('Recv' in k) or ('Send' in k) or ('Incoming' in k) or ('Outgoing' in k) or ('ICMP_ping' in k):
            return 'Network'
        if ('LFSync' in k) or ('LFPara' in k) or ('DFPara' in k) or ('DB' in k) or ('lfsync' in k):
            return 'DB'
        if ('Memory' in k) or ('used_memory' in k) or ('maxmemory' in k):
            return 'Memory'
        return 'Other'

    per_kpi_breached['category'] = per_kpi_breached['kpi_name'].apply(categorize)

    # Compute category-level per-node severity: if any p95_zero_flag True -> inf and flag True; else max(severity)
    cat_sev = (
        per_kpi_breached
        .groupby(['cmdb_id','category'], as_index=False)
        .agg(
            max_category_severity_raw = ('severity', 'max'),
            any_p95_zero = ('p95_zero_flag', 'any')
        )
    )

    # If any_p95_zero True and corresponding max_value_in_window > 0 for that kpi, we should mark inf.
    # We already set severity to inf for such per_kpi entries, so max will be inf; keep as is.
    # Prepare cat_sev fields
    cat_sev['p95_zero_flag'] = cat_sev['any_p95_zero']
    # Replace numeric inf to explicit np.inf (already present); keep values
    cat_sev['max_category_severity'] = cat_sev['max_category_severity_raw']

    # Now compute breaches counts and earliest timestamps per node-category from breaches rows
    # Assign category to breach rows as well
    breaches['category'] = breaches['kpi_name'].apply(categorize)

    cat_counts = (
        breaches
        .groupby(['cmdb_id','category'], as_index=False)
        .agg(
            distinct_breached_kpi_count = ('kpi_name', lambda x: x.nunique()),
            total_breach_points = ('kpi_name', 'count'),
            earliest_breach_timestamp = ('timestamp', 'min')
        )
    )

    # Combine counts with severity
    cat_combined = cat_counts.merge(cat_sev[['cmdb_id','category','max_category_severity','p95_zero_flag']],
                                    on=['cmdb_id','category'], how='left')

    # Fill missing max_category_severity (if any) with NaN
    cat_combined['max_category_severity'] = cat_combined['max_category_severity'].replace({None: np.nan})

    # For each node, select top 3 categories sorted by distinct_breached_kpi_count desc
    def top_n_categories(df, n=3):
        return df.sort_values(['distinct_breached_kpi_count','total_breach_points'], ascending=[False, False]).head(n)

    results_list = []
    for node in nodes:
        node_df = cat_combined[cat_combined['cmdb_id'] == node]
        if node_df.shape[0] == 0:
            continue
        topcats = top_n_categories(node_df, n=3)
        results_list.append(topcats)

    if len(results_list) == 0:
        node_category_summary = pd.DataFrame(columns=cols)
    else:
        node_category_summary = pd.concat(results_list, ignore_index=True)
        # Select and order requested columns
        node_category_summary = node_category_summary[[
            'cmdb_id','category','distinct_breached_kpi_count','total_breach_points',
            'earliest_breach_timestamp','max_category_severity','p95_zero_flag'
        ]]
        # Limit to max 18 rows to satisfy requirement
        node_category_summary = node_category_summary.head(18).reset_index(drop=True)

# Display compact result
node_category_summary
