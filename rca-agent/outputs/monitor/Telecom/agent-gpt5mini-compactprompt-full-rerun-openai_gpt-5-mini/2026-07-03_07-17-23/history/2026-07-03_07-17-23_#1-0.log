import pandas as pd
import numpy as np
import pytz

# reuse existing variables from kernel: metric_df, p95_df, tz if available
tz = pytz.timezone('Asia/Shanghai')

# Ensure global p95 per (cmdb_id, kpi_name) exists
if 'p95_df' not in globals():
    p95_df = (
        metric_df
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
        .quantile(0.95)
        .rename(columns={'value': 'p95'})
    )

# Incident window (UTC+8)
start_ts = int(pd.Timestamp('2020-04-11 01:30:00', tz=tz).timestamp())
end_ts = int(pd.Timestamp('2020-04-11 02:00:00', tz=tz).timestamp())

# Filter metric rows to the window and nodes starting with 'os_'
window_df = metric_df[
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts) &
    (metric_df['cmdb_id'].str.startswith('os_'))
].copy()

# Select KPI rows where kpi_name contains any of the specified substrings (case-sensitive)
pattern = r'network|Recv|Send|ICMP_ping|Ping'
sel_df = window_df[window_df['kpi_name'].str.contains(pattern, regex=True, na=False)].copy()

# If no selected rows, return empty DataFrame with requested columns
cols = ['cmdb_id', 'kpi_name', 'breaches_count', 'earliest_breach_timestamp',
        'max_value_in_window', 'p95', 'severity_ratio', 'p95_zero_flag']
if sel_df.shape[0] == 0:
    result_top20 = pd.DataFrame(columns=cols)
else:
    # Merge with global p95 (computed on full series)
    merged = sel_df.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

    # Define is_breach: only True when p95 is not null and value > p95
    merged['is_breach'] = merged.apply(lambda r: (r['value'] > r['p95']) if pd.notna(r['p95']) else False, axis=1)

    # breaches dataframe
    breaches = merged[merged['is_breach']].copy()

    if breaches.shape[0] == 0:
        result_top20 = pd.DataFrame(columns=cols)
    else:
        # breaches_count and earliest_breach_timestamp per (node,kpi)
        breaches_count = breaches.groupby(['cmdb_id', 'kpi_name'], as_index=True).size().rename('breaches_count')
        earliest_breach = breaches.groupby(['cmdb_id', 'kpi_name'], as_index=True)['timestamp'].min().rename('earliest_breach_timestamp')

        # max_value_in_window per (node,kpi) using all window rows (not just breaches)
        max_in_window = merged.groupby(['cmdb_id', 'kpi_name'], as_index=True)['value'].max().rename('max_value_in_window')

        # p95 per (node,kpi) (from merged; same for all rows)
        p95_series = merged.groupby(['cmdb_id', 'kpi_name'], as_index=True)['p95'].first().rename('p95')

        # Combine aggregates
        agg = pd.concat([breaches_count, earliest_breach, max_in_window, p95_series], axis=1).reset_index()

        # Compute p95_zero_flag and severity_ratio
        agg['p95_zero_flag'] = agg['p95'] == 0
        # severity_ratio: handle p95==0 -> set inf if max_value_in_window>0, else NaN
        def compute_sev(row):
            if pd.isna(row['p95']):
                return np.nan
            if row['p95'] == 0:
                return np.inf if row['max_value_in_window'] > 0 else np.nan
            return float(row['max_value_in_window'] / row['p95'])
        agg['severity_ratio'] = agg.apply(compute_sev, axis=1)

        # Keep only rows with breaches_count > 0 (already from breaches grouping, but ensure)
        agg = agg[agg['breaches_count'] > 0].copy()

        # Sort by earliest_breach_timestamp asc, then severity_ratio desc
        agg_sorted = agg.sort_values(['earliest_breach_timestamp', 'severity_ratio'], ascending=[True, False])

        # Select and order requested columns, limit to top 20
        result_top20 = agg_sorted[['cmdb_id', 'kpi_name', 'breaches_count', 'earliest_breach_timestamp',
                                  'max_value_in_window', 'p95', 'severity_ratio', 'p95_zero_flag']].head(20).reset_index(drop=True)

# Display final compact result (up to 20 rows)
result_top20
