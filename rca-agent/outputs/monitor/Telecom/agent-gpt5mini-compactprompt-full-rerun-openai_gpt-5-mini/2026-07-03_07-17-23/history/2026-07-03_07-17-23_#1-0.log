import pandas as pd
import numpy as np
import pytz

# reuse variables from kernel
tz = pytz.timezone('Asia/Shanghai')

# Ensure p95_df exists (global P95 per cmdb_id,kpi_name computed on full series)
if 'p95_df' not in globals():
    p95_df = (
        metric_df
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
        .quantile(0.95)
        .rename(columns={'value': 'p95'})
    )

# Candidate nodes
candidates = ['os_020', 'os_004']

# Incident window (UTC+8)
start_ts = int(pd.Timestamp('2020-04-11 01:30:00', tz=tz).timestamp())
end_ts = int(pd.Timestamp('2020-04-11 02:00:00', tz=tz).timestamp())

# Windowed metrics for candidate nodes
window_nodes = metric_df[
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts) &
    (metric_df['cmdb_id'].isin(candidates))
].copy()

# Step 1: Find KPIs where global p95 == 0 for these nodes
p95_zero_kpis = p95_df[
    (p95_df['cmdb_id'].isin(candidates)) &
    (p95_df['p95'] == 0)
][['cmdb_id', 'kpi_name', 'p95']].copy()

# Prepare containers for summaries and raw breach rows
summary_rows = []
raw_breach_rows = []

# Iterate each KPI with p95 == 0 and check for any datapoint in window with value > 0
for _, r in p95_zero_kpis.iterrows():
    cm = r['cmdb_id']
    k = r['kpi_name']
    p95_val = r['p95']  # should be 0

    # Filter window rows for this KPI
    rows = window_nodes[(window_nodes['cmdb_id'] == cm) & (window_nodes['kpi_name'] == k)].copy()
    if rows.shape[0] == 0:
        continue

    # Breaches defined as value > 0 (per instruction)
    breaches = rows[rows['value'] > 0].copy().sort_values('timestamp')
    breaches_count = int(breaches.shape[0])
    if breaches_count == 0:
        continue  # only include KPIs that have at least one datapoint > 0 in window

    earliest = int(breaches['timestamp'].min())
    max_val = float(rows['value'].max())  # max in window (could be from non-breach if p95==0 and value==0, but breaches_count>0 ensures >0 exists)
    # p95_zero_flag is True by definition here
    summary_rows.append({
        'cmdb_id': cm,
        'kpi_name': k,
        'breaches_count': breaches_count,
        'earliest_breach_timestamp': earliest,
        'max_value_in_window': max_val,
        'p95': p95_val,
        'p95_zero_flag': True
    })

    # Step 2: capture up to 10 raw breach datapoints (timestamp, value) ordered ascending
    raw_subset = breaches[['timestamp', 'value']].head(10).copy()
    # add identifiers for clarity
    raw_subset.insert(0, 'kpi_name', k)
    raw_subset.insert(0, 'cmdb_id', cm)
    raw_breach_rows.append(raw_subset)

# Build DataFrames for output
if len(summary_rows) == 0:
    summary_df = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','breaches_count','earliest_breach_timestamp',
        'max_value_in_window','p95','p95_zero_flag'
    ])
    raw_breaches_df = pd.DataFrame(columns=['cmdb_id','kpi_name','timestamp','value'])
else:
    summary_df = pd.DataFrame(summary_rows)[[
        'cmdb_id','kpi_name','breaches_count','earliest_breach_timestamp',
        'max_value_in_window','p95','p95_zero_flag'
    ]]
    # limit summary rows to max 20 as requested
    summary_df = summary_df.head(20).reset_index(drop=True)
    if len(raw_breach_rows) > 0:
        raw_breaches_df = pd.concat(raw_breach_rows, ignore_index=True)[['cmdb_id','kpi_name','timestamp','value']]
    else:
        raw_breaches_df = pd.DataFrame(columns=['cmdb_id','kpi_name','timestamp','value'])

# Display compact results: summary_df (KPIs with p95==0 and breaches) and raw_breaches_df (up to 10 per KPI)
summary_df, raw_breaches_df
