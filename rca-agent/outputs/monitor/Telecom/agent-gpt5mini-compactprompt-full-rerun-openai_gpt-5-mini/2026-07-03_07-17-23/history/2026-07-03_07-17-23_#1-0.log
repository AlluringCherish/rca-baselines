import pandas as pd
import numpy as np
import pytz

# reuse metric_df and tz from kernel
tz = pytz.timezone('Asia/Shanghai')

cmdb = 'os_007'
kpis = ['Processor_load_1_min', 'Processor_load_5_min']

# 1) Compute global P95 for each of the two series using the full metric_df (no time filtering)
full_series = metric_df[(metric_df['cmdb_id'] == cmdb) & (metric_df['kpi_name'].isin(kpis))]
global_p95_ser = full_series.groupby('kpi_name', as_index=True)['value'].quantile(0.95).rename('global_p95')

# turn into a dict/series for lookup
global_p95 = global_p95_ser.to_dict()

# 2) Define incident window (UTC+8) and filter
start_ts = int(pd.Timestamp('2020-04-11 01:30:00', tz=tz).timestamp())
end_ts = int(pd.Timestamp('2020-04-11 02:00:00', tz=tz).timestamp())
