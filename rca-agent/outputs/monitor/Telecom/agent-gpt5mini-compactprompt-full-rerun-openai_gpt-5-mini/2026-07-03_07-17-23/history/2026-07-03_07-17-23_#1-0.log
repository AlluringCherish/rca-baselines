    # rows where value > global_p95
    breaches = series_window[series_window['value'] > gp95].sort_values('timestamp')[['timestamp','cmdb_id','kpi_name','value']]
    breach_rows_list.append(breaches)  # store even if empty
    breaches_count = int(breaches.shape[0])
    earliest = int(breaches['timestamp'].min()) if breaches_count > 0 else np.nan
    latest = int(breaches['timestamp'].max()) if breaches_count > 0 else np.nan
    max_val_in_window = float(series_window['value'].max()) if series_window.shape[0] > 0 else np.nan

    # severity ratio (handle p95 == 0)
    if pd.isna(gp95):
