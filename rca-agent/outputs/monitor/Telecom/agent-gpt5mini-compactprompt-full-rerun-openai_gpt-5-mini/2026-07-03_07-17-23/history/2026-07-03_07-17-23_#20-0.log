import pandas as pd
import numpy as np
import pytz

# reuse existing df_metric and tz if available; otherwise load/define
try:
    df_metric
except NameError:
    df_metric = pd.read_csv("metric.csv")
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

target_cmdb = "db_006"
kpis = ["AIOS","Physical_Read_Per_Sec","LFSync_Per_Sec","Redo_Per_Sec",
        "TPS_Per_Sec","Sess_Active","Login_Per_Sec","tnsping_result_time"]

# Analysis window in local tz -> convert to UTC epoch seconds
start_local = pd.Timestamp('2020-05-25 03:30:00').tz_localize(tz)
end_local   = pd.Timestamp('2020-05-25 04:00:00').tz_localize(tz)
start_ts = int(start_local.tz_convert('UTC').timestamp())
end_ts   = int(end_local.tz_convert('UTC').timestamp())

# 1) Compute global thresholds (P95 and P5) for db_006 using full series BEFORE window filtering
df_db_all = df_metric[df_metric['cmdb_id'] == target_cmdb].copy()
thresholds_db = (
    df_db_all
    .groupby('kpi_name')['value']
    .agg(global_P95=lambda x: x.quantile(0.95),
         global_P5 =lambda x: x.quantile(0.05))
    .reset_index()
)

# Ensure we have thresholds for requested KPIs (may be missing for some)
thr_map = thresholds_db.set_index('kpi_name')

# 2) Filter db_006 rows to the incident window
df_db_win = df_db_all[(df_db_all['timestamp'] >= start_ts) & (df_db_all['timestamp'] <= end_ts)].copy()

# Keep only requested KPIs
df_db_win_kpis = df_db_win[df_db_win['kpi_name'].isin(kpis)].copy()

# If multiple entries per (timestamp,kpi) take the first (data is per-minute; agg defensively)
pivot_raw = df_db_win_kpis.pivot_table(index='timestamp', columns='kpi_name', values='value', aggfunc='first')

#  create complete minute index for the window (inclusive)
minute_secs = list(range(start_ts, end_ts + 1, 60))  # step 60 seconds
ts_df = pd.DataFrame({'timestamp': minute_secs})
# merge to ensure one row per minute, then attach pivot columns
pivot_full = ts_df.merge(pivot_raw.reset_index(), on='timestamp', how='left')

# convert timestamp to local tz datetime for display and sort
pivot_full['timestamp_local'] = pd.to_datetime(pivot_full['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
pivot_full = pivot_full.sort_values('timestamp').reset_index(drop=True)

# reorder columns: timestamp_local first, then requested KPI columns in given order
display_cols = ['timestamp_local'] + kpis
for c in kpis:
    if c not in pivot_full.columns:
        pivot_full[c] = np.nan  # ensure column exists if missing

pivot_table = pivot_full.loc[:, display_cols].copy()

# Limit to max 31 rows (the window has 31 minutes)
pivot_table = pivot_table.head(31)

# 3) For each KPI, detect first breach in-window using global thresholds (P95/P5 computed historically)
breach_first = {}
for k in kpis:
    # get threshold values if available
    if k in thr_map.index:
        g95 = float(thr_map.at[k, 'global_P95'])
        g05 = float(thr_map.at[k, 'global_P5'])
    else:
        g95 = np.nan
        g05 = np.nan

    # subset in-window series for this KPI
    if k in df_db_win_kpis['kpi_name'].values:
        series_k = df_db_win_kpis[df_db_win_kpis['kpi_name'] == k].sort_values('timestamp')
        # apply breach rule: value >= P95 OR value <= P5 (only if thresholds are not NaN)
        if np.isnan(g95) and np.isnan(g05):
            first_breach = 'no breach'
        else:
            cond_ge = False if np.isnan(g95) else (series_k['value'] >= g95)
            cond_le = False if np.isnan(g05) else (series_k['value'] <= g05)
            cond = cond_ge | cond_le
            if cond.any():
                ts = int(series_k.loc[cond, 'timestamp'].iloc[0])
                ts_local = pd.to_datetime(ts, unit='s', utc=True).tz_convert(tz)
                first_breach = ts_local
            else:
                first_breach = 'no breach'
    else:
        first_breach = 'no breach'
    breach_first[k] = first_breach

# Build a concise one-line summary string for breaches
parts = []
for k in kpis:
    v = breach_first[k]
    if isinstance(v, pd.Timestamp) or (hasattr(v,'tzinfo') and pd.notna(v):
        ):
        parts.append(f"{k}:{v}")
    else:
        parts.append(f"{k}:no breach")
summary_line = " | ".join(parts)

# Final compact outputs: pivot_table (max 31 rows) and summary_line
pivot_table, summary_line
