import pandas as pd
import numpy as np
import pytz

# reuse df_metric and tz from kernel
tz = pytz.timezone('Asia/Shanghai')
if 'df_metric' not in globals():
    df_metric = pd.read_csv('metric.csv')
if 'ts' not in df_metric.columns:
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    df_metric['ts'] = pd.to_datetime(df_metric['ts']).dt.tz_convert(tz)

# Candidate nodes and KPIs
candidate_nodes = ['os_018','os_006','os_007','os_022','os_004','os_010']
candidate_kpis = ['Disk_io_util','Disk_svctm','Disk_await','CPU_iowait_time','Processor_load_1_min','Processor_load_5_min']

# Window for metrics: 2020-05-25 01:30:00 (inclusive) to 2020-05-25 02:00:00 (exclusive) UTC+8
start = tz.localize(pd.Timestamp('2020-05-25 01:30:00'))
end   = tz.localize(pd.Timestamp('2020-05-25 02:00:00'))

# Filter metric series to candidate nodes and KPIs (global - for computing thresholds)
mask_candidates = df_metric['cmdb_id'].isin(candidate_nodes) & df_metric['kpi_name'].isin(candidate_kpis)
candidates_df = df_metric[mask_candidates].copy()

# If no matching series, return empty frame with expected columns
if candidates_df.empty:
    result = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','series_total_points','p95','p5',
        'window_points_count','anomalies_count_in_window','is_full_window_fault',
        'earliest_anomaly_timestamp','latest_anomaly_timestamp'
    ])
else:
    # 1) Compute global per-series stats (series_total_points, p95, p5) BEFORE window filtering
    grp = candidates_df.groupby(['cmdb_id','kpi_name'])['value']
    series_stats = grp.agg(
        series_total_points = 'size',
        p95 = lambda s: np.nanpercentile(s.dropna(), 95),
        p5  = lambda s: np.nanpercentile(s.dropna(), 5)
    ).reset_index()

    # 2) Windowed points
    win_df = candidates_df[(candidates_df['ts'] >= start) & (candidates_df['ts'] < end)].copy()

    # Window aggregations per series
    if not win_df.empty:
        win_agg = win_df.groupby(['cmdb_id','kpi_name']).agg(
            window_points_count = ('value','size')
        ).reset_index()
    else:
        win_agg = pd.DataFrame(columns=['cmdb_id','kpi_name','window_points_count'])

    # 3) Determine anomalies in-window using global thresholds
    if not win_df.empty:
        win_with_thresh = win_df.merge(series_stats, on=['cmdb_id','kpi_name'], how='left')
        win_with_thresh['is_anom'] = (win_with_thresh['value'] >= win_with_thresh['p95']) | (win_with_thresh['value'] <= win_with_thresh['p5'])
        # aggregate anomaly counts and earliest/latest anomaly timestamps
        anom_agg = win_with_thresh[win_with_thresh['is_anom']].groupby(['cmdb_id','kpi_name']).agg(
            anomalies_count_in_window = ('is_anom','sum'),
            earliest_anomaly_timestamp = ('ts','min'),
            latest_anomaly_timestamp = ('ts','max')
        ).reset_index()
    else:
        anom_agg = pd.DataFrame(columns=['cmdb_id','kpi_name','anomalies_count_in_window','earliest_anomaly_timestamp','latest_anomaly_timestamp'])

    # 4) Compose final table
    result = series_stats.merge(win_agg, on=['cmdb_id','kpi_name'], how='left').merge(anom_agg, on=['cmdb_id','kpi_name'], how='left')

    # Fill missing window counts/anomaly counts with zeros/NaT
    result['window_points_count'] = result['window_points_count'].fillna(0).astype(int)
    result['anomalies_count_in_window'] = result['anomalies_count_in_window'].fillna(0).astype(int)
    # is_full_window_fault: True if window_points_count>0 and anomalies_count == window_points_count
    result['is_full_window_fault'] = (result['window_points_count'] > 0) & (result['anomalies_count_in_window'] == result['window_points_count'])

    # Ensure timestamp columns are datetime (may be NaT)
    if 'earliest_anomaly_timestamp' in result.columns:
        result['earliest_anomaly_timestamp'] = pd.to_datetime(result['earliest_anomaly_timestamp'])
    if 'latest_anomaly_timestamp' in result.columns:
        result['latest_anomaly_timestamp'] = pd.to_datetime(result['latest_anomaly_timestamp'])

    # Round numeric fields
    result['p95'] = result['p95'].round(4)
    result['p5']  = result['p5'].round(4)

    # Select and order columns as requested
    result = result[[
        'cmdb_id','kpi_name','series_total_points','p95','p5',
        'window_points_count','anomalies_count_in_window','is_full_window_fault',
        'earliest_anomaly_timestamp','latest_anomaly_timestamp'
    ]]

    # Keep only existing combinations (already done) and limit to 20 rows
    result = result.sort_values(by=['anomalies_count_in_window','window_points_count'], ascending=[False, False]).head(20).reset_index(drop=True)

# Display compact result
result
