import pandas as pd
import pytz

# timezone for UTC+8 as required
tz = pytz.timezone('Asia/Shanghai')

# Load CSVs (files are in current working directory)
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')

# Convert timestamp columns to timezone-aware datetimes (assume original seconds are UTC)
df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# --- Aggregates for metric.csv ---
metric_total_rows = len(df_metric)

# unique cmdb_id counts (top 20)
metric_cmdb_counts = (
    df_metric['cmdb_id']
    .value_counts()
    .reset_index()
    .rename(columns={'index': 'cmdb_id', 'cmdb_id': 'row_count'})
    .head(20)
)

# unique kpi_name counts (top 20)
metric_kpi_counts = (
    df_metric['kpi_name']
    .value_counts()
    .reset_index()
    .rename(columns={'index': 'kpi_name', 'kpi_name': 'row_count'})
    .head(20)
)

# overall min/max timestamps (numeric and tz-aware)
metric_time_range = pd.Series({
    'timestamp_min_numeric': int(df_metric['timestamp'].min()) if metric_total_rows>0 else None,
    'timestamp_max_numeric': int(df_metric['timestamp'].max()) if metric_total_rows>0 else None,
    'timestamp_min_ts': df_metric['ts'].min(),
    'timestamp_max_ts': df_metric['ts'].max()
})

# up to 10 example rows sorted by timestamp ascending (compact columns)
metric_examples = (
    df_metric.sort_values('timestamp', ascending=True)
    .loc[:, ['ts', 'cmdb_id', 'kpi_name', 'value']]
    .head(10)
    .rename(columns={'ts': 'timestamp'})
)

# number of distinct (cmdb_id, kpi_name) time series (global)
metric_distinct_series_count = df_metric.groupby(['cmdb_id', 'kpi_name']).ngroups

# --- Aggregates for trace.csv ---
trace_total_rows = len(df_trace)

# unique cmdb_id counts (top 20)
trace_cmdb_counts = (
    df_trace['cmdb_id']
    .value_counts()
    .reset_index()
    .rename(columns={'index': 'cmdb_id', 'cmdb_id': 'row_count'})
    .head(20)
)

# unique trace_name counts (top 20)
trace_trace_counts = (
    df_trace['trace_name']
    .value_counts()
    .reset_index()
    .rename(columns={'index': 'trace_name', 'trace_name': 'row_count'})
    .head(20)
)

# overall min/max timestamps for trace
trace_time_range = pd.Series({
    'timestamp_min_numeric': int(df_trace['timestamp'].min()) if trace_total_rows>0 else None,
    'timestamp_max_numeric': int(df_trace['timestamp'].max()) if trace_total_rows>0 else None,
    'timestamp_min_ts': df_trace['ts'].min(),
    'timestamp_max_ts': df_trace['ts'].max()
})

# up to 10 example rows sorted by timestamp ascending (compact columns)
trace_examples = (
    df_trace.sort_values('timestamp', ascending=True)
    .loc[:, ['ts', 'cmdb_id', 'trace_name', 'value']]
    .head(10)
    .rename(columns={'ts': 'timestamp'})
)

# Final compact output (variables shown in a concise form)
metric_total_rows, metric_cmdb_counts, metric_kpi_counts, metric_time_range, metric_examples, metric_distinct_series_count, trace_total_rows, trace_cmdb_counts, trace_trace_counts, trace_time_range, trace_examples
