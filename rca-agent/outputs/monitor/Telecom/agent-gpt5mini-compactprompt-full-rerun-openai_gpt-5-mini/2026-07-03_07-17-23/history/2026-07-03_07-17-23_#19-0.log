import pandas as pd
import pytz
import numpy as np

# reuse variables from previous steps: out_final contains series with anomalies and required fields
# ensure timezone
tz = pytz.timezone('Asia/Shanghai')

# If out_final not in memory (defensive), recreate minimal required anomaly series table from summary
if 'out_final' not in globals():
    # fallback: reconstruct from summary variable if available
    if 'summary' in globals():
        out = summary[summary['anomalies_count_in_window'] > 0].copy()
        out['p95'] = out['p95'].round(4)
        out['p5']  = out['p5'].round(4)
        out['min_value_in_window'] = out['min_value_in_window'].round(4)
        out['max_value_in_window'] = out['max_value_in_window'].round(4)
        out['breach_severity'] = out['breach_severity'].round(4)
        out_final = out.reset_index(drop=True)
    else:
        # no data available
        out_final = pd.DataFrame(columns=[
            'cmdb_id','kpi_name','series_total_points','p95','p5',
            'window_points_count','anomalies_count_in_window','earliest_anomaly_timestamp',
            'min_value_in_window','max_value_in_window','breach_severity'
        ])

# ensure correct dtypes
if 'earliest_anomaly_timestamp' in out_final.columns:
    out_final['earliest_anomaly_timestamp'] = pd.to_datetime(out_final['earliest_anomaly_timestamp'])

# classify component_type by prefix
def classify(cmdb):
    if isinstance(cmdb, str):
        if cmdb.startswith('os_'):
            return 'os'
        if cmdb.startswith('db_'):
            return 'db'
        if cmdb.startswith('docker_'):
            return 'docker'
    return 'other'

out_final['component_type'] = out_final['cmdb_id'].apply(classify)

# aggregate by cmdb_id
def top_kpis_str(df_grp):
    # sort by breach_severity desc, take up to 3
    tmp = df_grp.sort_values('breach_severity', ascending=False).head(3)
    pairs = [f"{k}:{sev:.4f}" for k, sev in zip(tmp['kpi_name'], tmp['breach_severity'])]
    return ", ".join(pairs)

if out_final.shape[0] > 0:
    agg = out_final.groupby(['cmdb_id','component_type']).agg(
        faulty_kpi_count = ('kpi_name','nunique'),
        series_total_points_sum = ('series_total_points','sum'),
        earliest_anomaly_timestamp = ('earliest_anomaly_timestamp','min'),
        max_breach_severity = ('breach_severity','max')
    ).reset_index()

    # compute top_kpis_by_severity using group apply on out_final
    topk = out_final.groupby('cmdb_id').apply(top_kpis_str).reset_index().rename(columns={0:'top_kpis_by_severity'})
    agg = agg.merge(topk, on='cmdb_id', how='left')

    # round numeric fields
    agg['series_total_points_sum'] = agg['series_total_points_sum'].astype(int)
    agg['max_breach_severity'] = agg['max_breach_severity'].round(4)

    # sort as requested
    agg = agg.sort_values(by=['faulty_kpi_count','max_breach_severity'], ascending=[False, False]).head(20).reset_index(drop=True)
else:
    agg = pd.DataFrame(columns=[
        'cmdb_id','component_type','faulty_kpi_count','series_total_points_sum',
        'earliest_anomaly_timestamp','max_breach_severity','top_kpis_by_severity'
    ])

# Final compact output
