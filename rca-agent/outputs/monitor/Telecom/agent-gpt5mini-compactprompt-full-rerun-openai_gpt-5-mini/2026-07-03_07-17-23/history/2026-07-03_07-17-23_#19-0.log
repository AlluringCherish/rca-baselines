import pandas as pd
import numpy as np
import pytz

# reuse existing df_metric (assumed loaded in kernel). Ensure timestamp tz column exists
tz = pytz.timezone('Asia/Shanghai')
if 'ts' not in df_metric.columns:
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    # ensure tz-aware in required tz
    df_metric['ts'] = pd.to_datetime(df_metric['ts']).dt.tz_convert(tz)

# 1) Global series stats: total points, P95 and P5 (computed on full series)
grp = df_metric.groupby(['cmdb_id', 'kpi_name'])['value']
series_stats = grp.agg(
    series_total_points = 'size',
    p95 = lambda s: np.nanpercentile(s.dropna(), 95),
    p5  = lambda s: np.nanpercentile(s.dropna(), 5)
).reset_index()

# 2) Filter to incident window (UTC+8): 2020-05-25 01:30:00 (inclusive) to 2020-05-25 02:00:00 (exclusive)
start = tz.localize(pd.Timestamp('2020-05-25 01:30:00'))
end   = tz.localize(pd.Timestamp('2020-05-25 02:00:00'))
df_win = df_metric[(df_metric['ts'] >= start) & (df_metric['ts'] < end)].copy()

# window-level aggregations per series
if not df_win.empty:
    win_grp = df_win.groupby(['cmdb_id', 'kpi_name'])
    win_stats = win_grp.agg(
        window_points_count = ('value', 'size'),
        earliest_ts_in_window = ('ts', 'min'),
        min_value_in_window = ('value', 'min'),
        max_value_in_window = ('value', 'max')
    ).reset_index()
else:
    # empty window -> empty dataframe with expected columns
    win_stats = pd.DataFrame(columns=['cmdb_id','kpi_name','window_points_count','earliest_ts_in_window','min_value_in_window','max_value_in_window'])

# 3) Determine anomalies in-window (value >= P95 or value <= P5) using global thresholds
# merge series_stats into df_win for per-point check
df_win2 = df_win.merge(series_stats, on=['cmdb_id','kpi_name'], how='left', suffixes=('','_series'))
# boolean anomaly per point
df_win2['is_anom'] = (df_win2['value'] >= df_win2['p95']) | (df_win2['value'] <= df_win2['p5'])

# aggregate anomaly summaries per series
if not df_win2.empty:
    anom_grp = df_win2.groupby(['cmdb_id','kpi_name'])
    anom_stats = anom_grp.agg(
        anomalies_count_in_window = ('is_anom', 'sum'),
        earliest_anomaly_timestamp = ('ts', lambda s: s[s.index.isin(df_win2[df_win2['is_anom']].index)].min() if s.size>0 else pd.NaT)
    ).reset_index()
    # The above earliest_anomaly_timestamp calculation can be simplified by computing per-group min where is_anom true:
    anom_stats = df_win2[df_win2['is_anom']].groupby(['cmdb_id','kpi_name']).agg(
        anomalies_count_in_window = ('is_anom','sum'),
        earliest_anomaly_timestamp = ('ts','min')
    ).reset_index()
else:
    anom_stats = pd.DataFrame(columns=['cmdb_id','kpi_name','anomalies_count_in_window','earliest_anomaly_timestamp'])

# 3b) Compose full summary: merge series_stats, win_stats, anom_stats
summary = series_stats.merge(win_stats, on=['cmdb_id','kpi_name'], how='left').merge(anom_stats, on=['cmdb_id','kpi_name'], how='left')

# fillna for counts with 0
summary['window_points_count'] = summary['window_points_count'].fillna(0).astype(int)
summary['anomalies_count_in_window'] = summary['anomalies_count_in_window'].fillna(0).astype(int)

# min/max in window might be NaN where no points; earliest timestamps may be NaT
# 3c) compute breach_severity per spec:
def compute_severity(row):
    p95 = row['p95']
    p5 = row['p5']
    maxv = row['max_value_in_window']
    minv = row['min_value_in_window']
    # if no window points, severity 0
    if pd.isna(maxv) and pd.isna(minv):
        return 0.0
    # check > P95 first
    if pd.notna(maxv) and pd.notna(p95) and (maxv > p95):
        if p95 == 0:
            return np.nan
        return (maxv - p95) / p95
    # else check < P5
    if pd.notna(minv) and pd.notna(p5) and (minv < p5):
        if p5 == 0:
            return np.nan
        return (p5 - minv) / p5
    return 0.0

summary['breach_severity'] = summary.apply(compute_severity, axis=1)

# 4) Filter to series with anomalies_count_in_window > 0 and prepare final compact table
out = summary[summary['anomalies_count_in_window'] > 0].copy()

# select and format columns, round numeric values to 4 decimals
out['p95'] = out['p95'].round(4)
out['p5']  = out['p5'].round(4)
out['min_value_in_window'] = out['min_value_in_window'].round(4)
out['max_value_in_window'] = out['max_value_in_window'].round(4)
out['breach_severity'] = out['breach_severity'].round(4)

final_cols = [
    'cmdb_id','kpi_name','series_total_points','p95','p5',
    'window_points_count','anomalies_count_in_window','earliest_anomaly_timestamp',
    'min_value_in_window','max_value_in_window','breach_severity'
]
out_final = out.loc[:, final_cols].sort_values(
    by=['anomalies_count_in_window','breach_severity'], ascending=[False, False]
).head(20).reset_index(drop=True)

# Display compact result
out_final
