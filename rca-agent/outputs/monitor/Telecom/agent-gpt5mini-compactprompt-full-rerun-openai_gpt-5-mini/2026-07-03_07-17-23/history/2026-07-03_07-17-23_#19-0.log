import pandas as pd
import numpy as np
import pytz

# reuse df_trace from kernel; ensure ts exists and is tz-aware Asia/Shanghai
tz = pytz.timezone('Asia/Shanghai')
if 'ts' not in df_trace.columns:
    df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    df_trace['ts'] = pd.to_datetime(df_trace['ts']).dt.tz_convert(tz)

# Define window for traces (inclusive as requested)
start = tz.localize(pd.Timestamp('2020-05-25 01:30:00'))
end   = tz.localize(pd.Timestamp('2020-05-25 02:00:00'))

# 1) Aggregates for cmdb_id == 'os_022'
os022_df = df_trace[df_trace['cmdb_id'] == 'os_022'].copy()

if not os022_df.empty:
    # global series stats (full available rows per trace_name)
    series_stats = os022_df.groupby('trace_name')['value'].agg(
        series_total_points = 'size',
        p95 = lambda s: np.nanpercentile(s.dropna(), 95),
        p5  = lambda s: np.nanpercentile(s.dropna(), 5)
    ).reset_index()

    # windowed rows for os_022 (inclusive)
    win = os022_df[(os022_df['ts'] >= start) & (os022_df['ts'] <= end)].copy()

    # window stats per trace_name
    if not win.empty:
        win_stats = win.groupby('trace_name').agg(
            window_points_count = ('value','size'),
            earliest_ts_in_window = ('ts','min'),
            min_value_in_window = ('value','min'),
            max_value_in_window = ('value','max')
        ).reset_index()
    else:
        win_stats = pd.DataFrame(columns=['trace_name','window_points_count','earliest_ts_in_window','min_value_in_window','max_value_in_window'])

    # anomalies in-window per trace_name: use global p95/p5
    if not win.empty:
        win_with_thresh = win.merge(series_stats, on='trace_name', how='left')
        win_with_thresh['is_anom'] = (win_with_thresh['value'] >= win_with_thresh['p95']) | (win_with_thresh['value'] <= win_with_thresh['p5'])
        anom_agg = win_with_thresh[win_with_thresh['is_anom']].groupby('trace_name').agg(
            anomalies_count = ('is_anom','sum'),
            earliest_anomaly_timestamp = ('ts','min')
        ).reset_index()
    else:
        anom_agg = pd.DataFrame(columns=['trace_name','anomalies_count','earliest_anomaly_timestamp'])

    # compose final os_022 summary
    os022_summary = series_stats.merge(win_stats, on='trace_name', how='left').merge(anom_agg, on='trace_name', how='left')

    # fill NaNs for counts with 0 and keep timestamps as is
    os022_summary['window_points_count'] = os022_summary['window_points_count'].fillna(0).astype(int)
    os022_summary['anomalies_count'] = os022_summary['anomalies_count'].fillna(0).astype(int)

    # compute breach_severity per spec
    def calc_sev(row):
        p95 = row['p95']; p5 = row['p5']
        maxv = row.get('max_value_in_window', np.nan)
        minv = row.get('min_value_in_window', np.nan)
        if pd.isna(maxv) and pd.isna(minv):
            return 0.0
        if pd.notna(maxv) and pd.notna(p95) and (maxv > p95):
            return (maxv - p95) / p95 if p95 != 0 else np.nan
        if pd.notna(minv) and pd.notna(p5) and (minv < p5):
            return (p5 - minv) / p5 if p5 != 0 else np.nan
        return 0.0

    os022_summary['breach_severity'] = os022_summary.apply(calc_sev, axis=1)

    # formatting and sorting
    for c in ['p95','p5','min_value_in_window','max_value_in_window','breach_severity']:
        if c in os022_summary.columns:
            os022_summary[c] = os022_summary[c].round(4)
    os022_summary = os022_summary.sort_values(by=['anomalies_count','breach_severity'], ascending=[False, False]).head(20).reset_index(drop=True)
else:
    os022_summary = pd.DataFrame(columns=[
        'trace_name','series_total_points','p95','p5','window_points_count','earliest_ts_in_window',
        'min_value_in_window','max_value_in_window','anomalies_count','earliest_anomaly_timestamp','breach_severity'
    ])

# 2) Traces across OTHER cmdb_ids where trace_name contains 'from_os_022'
mask = df_trace['trace_name'].str.contains('from_os_022', na=False) & (df_trace['cmdb_id'] != 'os_022')
remote = df_trace[mask].copy()

if not remote.empty:
    agg = remote.groupby(['cmdb_id','trace_name']).agg(
        row_count = ('value','size'),
        min_value = ('value','min'),
        max_value = ('value','max'),
        mean_value = ('value','mean')
    ).reset_index()

    # find earliest timestamp where value == max_value and where value == min_value
    tmp = agg.merge(remote, on=['cmdb_id','trace_name'], how='left')
    tmp_max_ts = tmp[tmp['value'] == tmp['max_value']].groupby(['cmdb_id','trace_name'])['ts'].min().reset_index().rename(columns={'ts':'earliest_ts_max'})
    tmp_min_ts = tmp[tmp['value'] == tmp['min_value']].groupby(['cmdb_id','trace_name'])['ts'].min().reset_index().rename(columns={'ts':'earliest_ts_min'})

    remote_summary = agg.merge(tmp_max_ts, on=['cmdb_id','trace_name'], how='left').merge(tmp_min_ts, on=['cmdb_id','trace_name'], how='left')

    # formatting
    remote_summary['min_value'] = remote_summary['min_value'].round(4)
    remote_summary['max_value'] = remote_summary['max_value'].round(4)
    remote_summary['mean_value'] = remote_summary['mean_value'].round(4)

    remote_summary = remote_summary.sort_values('row_count', ascending=False).head(20).reset_index(drop=True)
else:
    remote_summary = pd.DataFrame(columns=['cmdb_id','trace_name','row_count','min_value','max_value','mean_value','earliest_ts_max','earliest_ts_min'])

# Display compact outputs
os022_summary, remote_summary
