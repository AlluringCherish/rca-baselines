if missing:
    error_msg = "ERROR: trace.csv missing column(s): " + ", ".join(missing)
    error_msg
else:
    # 2) Restrict to cmdb_id == 'os_022' and compute global thresholds using full series (no time filter)
    df_os022_full = df_trace[df_trace['cmdb_id'] == 'os_022'].copy()
    if df_os022_full.empty:
        no_data_msg = "No rows for cmdb_id == 'os_022' in trace.csv."
        no_data_msg
    else:
        # Ensure timestamp int and create dt (UTC->Asia/Shanghai)
        df_os022_full['timestamp'] = df_os022_full['timestamp'].astype(int)
        df_os022_full['dt'] = pd.to_datetime(df_os022_full['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

        # Global thresholds per (cmdb_id, trace_name) computed from the full os_022 subset
        trace_thresh = df_os022_full.groupby(['trace_name'])['value'].agg(
            total_points_in_full_series='count',
            global_p95=lambda s: float(s.quantile(0.95)),
            global_p5=lambda s: float(s.quantile(0.05))
        ).reset_index()

        # 3) Filter rows to incident window (inclusive)
