import numpy as np
import pandas as pd

# Reuse df_metric, top20, tz from kernel
# Ensure dt exists
if 'dt' not in df_metric.columns:
    df_metric['dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

window_start = pd.Timestamp('2020-05-23T01:00:00').tz_localize(tz)
window_end = pd.Timestamp('2020-05-23T01:30:00').tz_localize(tz)

summaries = []

for row in top20.itertuples(index=False):
    cmdb = row.cmdb_id
    kpi = row.kpi_name
    p95 = row.p95
    p5 = row.p5
    points_expected = int(row.window_point_count)
    
    # 1) retrieve metric rows for that pair within window, sorted by dt
    df_pair = df_metric[
        (df_metric['cmdb_id'] == cmdb) &
        (df_metric['kpi_name'] == kpi) &
        (df_metric['dt'] >= window_start) &
        (df_metric['dt'] <= window_end)
    ].sort_values('dt').reset_index(drop=True)
    
    # 2) mark anomaly_high if value > p95 (strict), anomaly_low if value < p5 (strict)
    # handle possible NaN thresholds
    df_pair['dir'] = 0
    if pd.notnull(p95):
        df_pair.loc[df_pair['value'] > p95, 'dir'] = 1
    if pd.notnull(p5):
        df_pair.loc[df_pair['value'] < p5, 'dir'] = -1
    
    # 3) identify consecutive runs of same direction (1 or -1)
    if df_pair.empty:
        num_runs = 0
        earliest_run_start = None
        longest_run_len = 0
        max_deviation_pct = None
    else:
        # compute run change id across full series
        df_pair['dir_shift'] = df_pair['dir'].shift(fill_value=0)
        df_pair['run_change_id'] = (df_pair['dir'] != df_pair['dir_shift']).cumsum()
        
        # consider only non-zero directions
        df_runs = df_pair[df_pair['dir'] != 0].copy()
        if df_runs.empty:
            num_runs = 0
            earliest_run_start = None
            longest_run_len = 0
            max_deviation_pct = None
        else:
            run_groups = df_runs.groupby(['run_change_id', 'dir'], sort=True)
            run_records = []
            for (rid, direction), g in run_groups:
                length = len(g)
                if length >= 3:  # keep only runs with length >=3
                    start_ts = g['dt'].iloc[0]
                    end_ts = g['dt'].iloc[-1]
                    max_val = g['value'].max()
                    min_val = g['value'].min()
                    # 4) compute deviation_pct per rules
                    if direction == 1:
                        if pd.notnull(p95) and p95 > 0:
                            deviation_pct = (max_val - p95) / p95
                        else:
                            deviation_pct = None
                    else:  # direction == -1
                        if pd.notnull(p5) and p5 > 0:
                            deviation_pct = (p5 - min_val) / p5
                        else:
                            deviation_pct = None
                    run_records.append({
                        'start_ts': start_ts,
                        'end_ts': end_ts,
                        'length': length,
                        'max_value': max_val,
                        'min_value': min_val,
                        'direction': int(direction),
                        'deviation_pct': deviation_pct
                    })
            # summarize runs
            if not run_records:
                num_runs = 0
                earliest_run_start = None
                longest_run_len = 0
                max_deviation_pct = None
            else:
                runs_df = pd.DataFrame(run_records)
                num_runs = len(runs_df)
                earliest_run_start = runs_df['start_ts'].min().isoformat()
                longest_run_len = int(runs_df['length'].max())
                # max deviation across runs (ignore None)
                if runs_df['deviation_pct'].dropna().empty:
                    max_deviation_pct = None
                else:
                    max_deviation_pct = float(runs_df['deviation_pct'].dropna().max())
    
    summaries.append({
        'cmdb_id': cmdb,
        'kpi_name': kpi,
        'p95': p95,
        'p5': p5,
        'window_point_count': points_expected,
        'num_runs': num_runs,
        'earliest_run_start': earliest_run_start,
        'longest_run_len': longest_run_len,
        'max_deviation_pct': max_deviation_pct
    })

summary_df = pd.DataFrame(summaries)[
    ['cmdb_id','kpi_name','p95','p5','window_point_count','num_runs','earliest_run_start','longest_run_len','max_deviation_pct']
]

