import pandas as pd
import pytz

# Reuse df_trace and tz if available
try:
    df_trace
except NameError:
    df_trace = pd.read_csv("trace.csv")

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure dt column with timezone Asia/Shanghai (UTC+8)
if 'dt' not in df_trace.columns:
    df_trace['dt'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Compute global p95 and p5 per (cmdb_id, trace_name) using entire trace.csv
grp = df_trace.groupby(['cmdb_id', 'trace_name'])['value']
trace_p95 = grp.quantile(0.95).rename('p95')
trace_p5 = grp.quantile(0.05).rename('p5')
trace_thresholds = pd.concat([trace_p95, trace_p5], axis=1).reset_index()

# 2) Filter trace rows to the failure window (inclusive)
window_start = pd.Timestamp('2020-05-23T01:00:00').tz_localize(tz)
window_end = pd.Timestamp('2020-05-23T01:30:00').tz_localize(tz)
df_trace_win = df_trace[(df_trace['dt'] >= window_start) & (df_trace['dt'] <= window_end)].copy()

# 3) Merge window rows with global thresholds so each row has p95 and p5
df_win_thresh = pd.merge(df_trace_win, trace_thresholds, on=['cmdb_id', 'trace_name'], how='left')

# 4) Mark anomalies in the window: anomalies_high (>= p95), anomalies_low (<= p5)
df_win_thresh['is_high'] = (df_win_thresh['value'] >= df_win_thresh['p95']).astype(int)
df_win_thresh['is_low'] = (df_win_thresh['value'] <= df_win_thresh['p5']).astype(int)

# 5) Aggregate required metrics per (cmdb_id, trace_name) within the window
agg = df_win_thresh.groupby(['cmdb_id', 'trace_name']).agg(
    window_point_count=('value', 'size'),
    anomalies_high=('is_high', 'sum'),
    anomalies_low=('is_low', 'sum'),
    max_value_in_window=('value', 'max'),
    min_value_in_window=('value', 'min')
).reset_index()

# 6) Earliest anomaly timestamp per group (consider either high or low)
df_anom = df_win_thresh[(df_win_thresh['is_high'] == 1) | (df_win_thresh['is_low'] == 1)].copy()
earliest = df_anom.groupby(['cmdb_id', 'trace_name'])['dt'].min().reset_index().rename(columns={'dt': 'earliest_anomaly_ts'})

# 7) Merge aggregates with thresholds and earliest anomaly ts
result = pd.merge(trace_thresholds, agg, on=['cmdb_id', 'trace_name'], how='left')
result = pd.merge(result, earliest, on=['cmdb_id', 'trace_name'], how='left')

# Fill NaNs for groups with no window points
result['window_point_count'] = result['window_point_count'].fillna(0).astype(int)
result['anomalies_high'] = result['anomalies_high'].fillna(0).astype(int)
result['anomalies_low'] = result['anomalies_low'].fillna(0).astype(int)
result['max_value_in_window'] = result['max_value_in_window']
result['min_value_in_window'] = result['min_value_in_window']

# earliest_anomaly_ts to ISO string, keep None if missing
result['earliest_anomaly_ts'] = result['earliest_anomaly_ts'].apply(lambda x: x.isoformat() if pd.notnull(x) else None)

# total_anomalies and sorting
result['total_anomalies'] = result['anomalies_high'] + result['anomalies_low']
# for tie-break, convert earliest_anomaly_ts back to datetime with tz, NaT last
result['earliest_sort'] = pd.to_datetime(result['earliest_anomaly_ts']).dt.tz_convert(tz)
result['earliest_sort'] = result['earliest_sort'].fillna(pd.Timestamp.max.tz_localize(tz))

# Sort by total_anomalies desc, earliest_anomaly_ts asc
result_sorted = result.sort_values(by=['total_anomalies', 'earliest_sort'], ascending=[False, True])

# Select required columns in the requested order and limit to top 20
output_cols = [
    'cmdb_id', 'trace_name', 'p95', 'p5',
    'window_point_count', 'anomalies_high', 'anomalies_low',
    'earliest_anomaly_ts', 'max_value_in_window', 'min_value_in_window',
    'total_anomalies'
]
top20_traces = result_sorted[output_cols].head(20).reset_index(drop=True)

top20_traces
