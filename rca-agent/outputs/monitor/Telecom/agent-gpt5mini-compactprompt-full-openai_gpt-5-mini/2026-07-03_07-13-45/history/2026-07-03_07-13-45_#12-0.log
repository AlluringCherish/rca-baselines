metric_ts = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
trace_ts = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Summaries and limits
metric_count = int(df_metric.shape[0])
metric_cmdb_ids = list(pd.Series(df_metric['cmdb_id'].unique())[:50])
metric_kpi_names = list(pd.Series(df_metric['kpi_name'].unique())[:50])
metric_ts_min = metric_ts.min().isoformat() if not metric_ts.empty else None
metric_ts_max = metric_ts.max().isoformat() if not metric_ts.empty else None

trace_count = int(df_trace.shape[0])
trace_cmdb_ids = list(pd.Series(df_trace['cmdb_id'].unique())[:50])
trace_trace_names = list(pd.Series(df_trace['trace_name'].unique())[:50])
