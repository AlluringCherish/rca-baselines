import pandas as pd
import pytz
from datetime import datetime

# Reuse df_metric and tz if available; otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv("metric.csv")
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure timestamp dt column (timezone-aware UTC+8)
if 'dt' not in df_metric.columns:
    df_metric['dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Candidate root-cause sets
os_ids = [f"os_{i:03d}" for i in range(1, 23)]       # os_001 .. os_022
docker_ids = [f"docker_{i:03d}" for i in range(1, 9)] # docker_001 .. docker_008
db_ids = [f"db_{i:03d}" for i in range(1, 14)]       # db_001 .. db_013
allowed_cmdbs = set(os_ids + docker_ids + db_ids)

# Filter metric rows to allowed components for global threshold calculation
df_allowed = df_metric[df_metric['cmdb_id'].isin(allowed_cmdbs)].copy()

# Compute global p95 and p5 per (cmdb_id, kpi_name) across entire metric.csv
grp = df_allowed.groupby(['cmdb_id', 'kpi_name'])['value']
p95 = grp.quantile(0.95).rename('p95')
p5 = grp.quantile(0.05).rename('p5')
thresholds = pd.concat([p95, p5], axis=1).reset_index()

# Define failure window in Asia/Shanghai (UTC+8), inclusive
start = pd.Timestamp('2020-05-23T01:00:00').tz_localize(tz)
end = pd.Timestamp('2020-05-23T01:30:00').tz_localize(tz)

# Filter metric rows to window and allowed components
df_window = df_metric[
    (df_metric['dt'] >= start) &
    (df_metric['dt'] <= end) &
    (df_metric['cmdb_id'].isin(allowed_cmdbs))
].copy()

# Merge window rows with thresholds so each row knows its group's p95/p5
df_win_thresh = pd.merge(df_window, thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# Compute anomaly flags per row
df_win_thresh['is_high'] = (df_win_thresh['value'] >= df_win_thresh['p95']).astype(int)
df_win_thresh['is_low'] = (df_win_thresh['value'] <= df_win_thresh['p5']).astype(int)

# Aggregations per group within window
agg_window = df_win_thresh.groupby(['cmdb_id', 'kpi_name']).agg(
    window_point_count=('value', 'size'),
    anomalies_high=('is_high', 'sum'),
    anomalies_low=('is_low', 'sum'),
    max_value_in_window=('value', 'max'),
    min_value_in_window=('value', 'min')
).reset_index()

# Earliest anomaly timestamp per group (consider either high or low)
df_anoms = df_win_thresh[df_win_thresh['is_high'].astype(bool) | df_win_thresh['is_low'].astype(bool)]
earliest = df_anoms.groupby(['cmdb_id', 'kpi_name'])['dt'].min().reset_index().rename(columns={'dt': 'earliest_anomaly_ts'})

# Merge thresholds (to include groups even if no window points) with window aggregates and earliest timestamps
result = pd.merge(thresholds, agg_window, on=['cmdb_id', 'kpi_name'], how='left')
result = pd.merge(result, earliest, on=['cmdb_id', 'kpi_name'], how='left')

# Fill NaNs for groups with no window data
result['window_point_count'] = result['window_point_count'].fillna(0).astype(int)
result['anomalies_high'] = result['anomalies_high'].fillna(0).astype(int)
result['anomalies_low'] = result['anomalies_low'].fillna(0).astype(int)

# Compute extreme_value per instructions
def choose_extreme(row):
    if row['anomalies_high'] > 0:
        return row['max_value_in_window']
    if row['anomalies_low'] > 0:
        return row['min_value_in_window']
    return None

result['extreme_value'] = result.apply(choose_extreme, axis=1)

# Convert earliest_anomaly_ts to ISO strings (keep NaT as None)
result['earliest_anomaly_ts'] = result['earliest_anomaly_ts'].apply(lambda x: x.isoformat() if pd.notnull(x) else None)

# Total anomalies for ranking
result['total_anomalies'] = result['anomalies_high'] + result['anomalies_low']

# Sort by total_anomalies desc, tie-break earliest_anomaly_ts asc (None/NaT go last)
result['earliest_sort'] = pd.to_datetime(result['earliest_anomaly_ts']).fillna(pd.Timestamp.max.tz_localize(tz))
result_sorted = result.sort_values(by=['total_anomalies', 'earliest_sort'], ascending=[False, True])

# Select required columns and limit to top 20
output_cols = [
    'cmdb_id', 'kpi_name', 'p95', 'p5',
    'anomalies_high', 'anomalies_low', 'earliest_anomaly_ts',
    'extreme_value', 'window_point_count'
]
top20 = result_sorted[output_cols].head(20).reset_index(drop=True)

