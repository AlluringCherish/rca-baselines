import pandas as pd
import pytz

# reuse df_trace if present, else load
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')

# timezone UTC+8
tz = pytz.timezone('Asia/Shanghai')

# convert timestamp to timezone-aware datetime (UTC -> Asia/Shanghai)
df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Compute global P95 per trace_name using full series (must be before filtering)
global_p95 = (
    df_trace.groupby('trace_name')['value']
    .quantile(0.95)
    .reset_index()
    .rename(columns={'value': 'global_p95'})
)

trace_count = global_p95['trace_name'].nunique()

# 2) Filter to incident window May 22, 2020 00:30 to 01:00 (UTC+8)
start = pd.Timestamp('2020-05-22 00:30:00', tz=tz)
end = pd.Timestamp('2020-05-22 01:00:00', tz=tz)
df_window = df_trace[(df_trace['ts'] >= start) & (df_trace['ts'] <= end)].copy()

# 3) Classify metric_type
def classify_metric(tn):
    if 'error_rate' in tn:
        return 'error_rate'
    if 'duration_p95' in tn:
        return 'duration_p95'
    if 'duration_mean' in tn:
        return 'duration_mean'
    return 'other'

df_window['metric_type'] = df_window['trace_name'].apply(classify_metric)

# 6) derive involved_component by parsing trace_name
def parse_involved_component(tn):
    parts = tn.split('.')
    # expected formats: trace.from_xxx.rest..., trace.to_xxx.rest..., trace.self.xxx.rest...
    if len(parts) >= 2:
        second = parts[1]
        if second == 'self' and len(parts) >= 3:
            return f"self.{parts[2]}"
        return second
    return None

df_window['involved_component'] = df_window['trace_name'].apply(parse_involved_component)

# 4 & 5) Merge global_p95 into window, count anomalies (value > global_p95), earliest timestamp, window point count
df_window = df_window.merge(global_p95, on='trace_name', how='left')
df_window['is_anomaly'] = df_window['value'] > df_window['global_p95']

agg = (
    df_window.groupby(['trace_name', 'involved_component', 'metric_type', 'global_p95'])
    .agg(
        anomaly_count=('is_anomaly', 'sum'),
        earliest_anomaly_ts=('ts', lambda s: s[df_window.loc[s.index, 'is_anomaly']].min() if s.size>0 else pd.NaT),
        window_point_count=('value', 'count')
    )
    .reset_index()
)

# convert earliest timestamp to ISO or None
agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_ts'].apply(lambda x: x.isoformat() if pd.notnull(x) else None)
agg = agg.drop(columns=['earliest_anomaly_ts'])

#  Sort by anomaly_count desc, then window_point_count desc
result_df = agg.sort_values(['anomaly_count', 'window_point_count'], ascending=[False, False])

# keep requested columns and top 20 rows
result_df = result_df[['trace_name', 'involved_component', 'metric_type', 'global_p95',
                       'anomaly_count', 'earliest_anomaly_timestamp', 'window_point_count']].head(20)

# Final compact outputs: top table and total trace_name count
result_df, trace_count
