import pandas as pd
import numpy as np
import pytz

# reuse df_metric if present, else load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

# ensure timestamp column converted to timezone-aware Asia/Shanghai (UTC+8)
tz = pytz.timezone('Asia/Shanghai')
df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Calculate global P95 and P5 per (cmdb_id, kpi_name) using full series BEFORE filtering
thresholds = (
    df_metric.groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(global_p95=lambda x: x.quantile(0.95), global_p5=lambda x: x.quantile(0.05))
    .reset_index()
)

# total distinct pairs processed
pair_count = thresholds.shape[0]

# 2) Filter to incident window May 22, 2020 00:30 to 01:00 (UTC+8)
start = pd.Timestamp('2020-05-22 00:30:00', tz=tz)
end = pd.Timestamp('2020-05-22 01:00:00', tz=tz)
df_window = df_metric[(df_metric['ts'] >= start) & (df_metric['ts'] <= end)].copy()

# 3) Merge thresholds into window data (thresholds computed globally)
df_window = df_window.merge(thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# mark anomalies
df_window['is_high'] = df_window['value'] > df_window['global_p95']
df_window['is_low'] = df_window['value'] < df_window['global_p5']

# 4) Aggregate per pair within the window
agg = (
    df_window.groupby(['cmdb_id', 'kpi_name'])
    .apply(lambda g: pd.Series({
        'global_p95': float(g['global_p95'].iat[0]),
        'global_p5': float(g['global_p5'].iat[0]),
        'high_anomaly_count': int(g['is_high'].sum()),
        'low_anomaly_count': int(g['is_low'].sum()),
        'earliest_anomaly_timestamp': (g.loc[g['is_high'] | g['is_low'], 'ts'].min()),
        'window_point_count': int(len(g))
    }))
    .reset_index()
)

# convert earliest_anomaly_timestamp to ISO strings (compact) and handle NaT
agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_timestamp'].apply(
    lambda x: x.isoformat() if pd.notnull(x) else None
)

# compute total anomaly count and sort
agg['total_anomaly_count'] = agg['high_anomaly_count'] + agg['low_anomaly_count']
result_df = agg.sort_values(['total_anomaly_count', 'window_point_count'], ascending=[False, False])

# keep only requested columns and top 20 rows
result_df = result_df[['cmdb_id', 'kpi_name', 'global_p95', 'global_p5',
                       'high_anomaly_count', 'low_anomaly_count',
                       'earliest_anomaly_timestamp', 'window_point_count', 'total_anomaly_count']].head(20)

# Final compact outputs: top table and total pair count
