import pandas as pd
import pytz

# timezone UTC+8
tz = pytz.timezone('Asia/Shanghai')

# Load CSVs
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')

# Convert timestamp columns to timezone-aware datetimes (UTC then convert to Asia/Shanghai)
metric_ts = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
trace_ts = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Compact summaries for metric.csv
metric_summary = {
    'rows': df_metric.shape[0],
    'unique_cmdb_id': list(df_metric['cmdb_id'].unique())[:50],
    'unique_kpi_name': list(df_metric['kpi_name'].unique())[:50],
    'min_timestamp': metric_ts.min().isoformat() if not metric_ts.empty else None,
    'max_timestamp': metric_ts.max().isoformat() if not metric_ts.empty else None,
    'top5_samples': df_metric.head(5)
}

# Compact summaries for trace.csv
trace_summary = {
    'rows': df_trace.shape[0],
    'unique_cmdb_id': list(df_trace['cmdb_id'].unique())[:50],
    'unique_trace_name': list(df_trace['trace_name'].unique())[:50],
    'min_timestamp': trace_ts.min().isoformat() if not trace_ts.empty else None,
    'max_timestamp': trace_ts.max().isoformat() if not trace_ts.empty else None,
    'top5_samples': df_trace.head(5)
}

# Final small JSON-like dictionary structure
summary = {'metric_summary': metric_summary, 'trace_summary': trace_summary}

summary
