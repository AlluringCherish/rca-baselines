import pandas as pd
import numpy as np
import pytz

# reuse existing data if present
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

# timezone UTC+8
tz = pytz.timezone('Asia/Shanghai')

# ensure timestamp tz-aware column
if 'ts' not in df_metric.columns:
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Ensure global thresholds (global_p95 and global_p5) per (cmdb_id, kpi_name)
try:
    thresholds  # from earlier steps
except NameError:
    thresholds = (
        df_metric.groupby(['cmdb_id', 'kpi_name'])['value']
        .agg(global_p95=lambda x: x.quantile(0.95), global_p5=lambda x: x.quantile(0.05))
        .reset_index()
    )

# Incident window
start = pd.Timestamp('2020-05-22 00:30:00', tz=tz)
end = pd.Timestamp('2020-05-22 01:00:00', tz=tz)

# Filter window and merge thresholds
df_window = df_metric[(df_metric['ts'] >= start) & (df_metric['ts'] <= end)].copy()
df_window = df_window.merge(thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# mark anomalies
df_window['is_high'] = df_window['value'] > df_window['global_p95']
df_window['is_low'] = df_window['value'] < df_window['global_p5']

# Aggregate per pair to get counts and select top 20 pairs by total anomalies
pair_agg = (
    df_window.groupby(['cmdb_id', 'kpi_name', 'global_p95', 'global_p5'])
    .agg(high_anomaly_count=('is_high', 'sum'),
         low_anomaly_count=('is_low', 'sum'),
         window_point_count=('value', 'count'))
    .reset_index()
)
pair_agg['total_anomaly_count'] = pair_agg['high_anomaly_count'] + pair_agg['low_anomaly_count']

top_pairs = pair_agg.sort_values(['total_anomaly_count', 'window_point_count'], ascending=[False, False]).head(20)

# For each top pair, find consecutive anomaly subsequences (same anomaly type) within the window
subseqs = []
eps = 1e-9
for _, pr in top_pairs.iterrows():
    cmdb = pr['cmdb_id']
    kpi = pr['kpi_name']
    p95 = pr['global_p95']
    p5 = pr['global_p5']
    total_points = int(pr['window_point_count'])
    dfp = df_window[(df_window['cmdb_id'] == cmdb) & (df_window['kpi_name'] == kpi)].copy()
    if dfp.empty:
        continue
    # Only anomalous rows
    dfp['anomalous'] = dfp['is_high'] | dfp['is_low']
    df_anom = dfp[dfp['anomalous']].sort_values('ts').reset_index(drop=True)
    if df_anom.empty:
        continue
    # anomaly type per row
    df_anom['anomaly_type'] = np.where(df_anom['is_high'], 'high', 'low')
    # compute gap in seconds from previous anomalous point
    df_anom['gap_sec'] = df_anom['ts'].diff().dt.total_seconds().fillna(0)
    # start new group if gap > 60 or anomaly_type changed
    df_anom['new_group'] = (df_anom['gap_sec'] > 60) | (df_anom['anomaly_type'] != df_anom['anomaly_type'].shift().fillna(df_anom['anomaly_type']))
    df_anom['group_id'] = df_anom['new_group'].cumsum()
    # aggregate groups
    gagg = df_anom.groupby('group_id').agg(
        cmdb_id=('cmdb_id', 'first'),
        kpi_name=('kpi_name', 'first'),
        anomaly_type=('anomaly_type', 'first'),
        start_ts=('ts', 'min'),
        end_ts=('ts', 'max'),
        duration_points=('ts', 'count'),
        extreme_value=('value', lambda vals: float(vals.max()) if (vals.max()==vals.max() and df_anom.loc[vals.index[0],'anomaly_type']=='high') else float(vals.min()))
    ).reset_index(drop=True)
    # Above lambda attempted to choose extreme depending on type, but group doesn't easily expose type per-vals.
    # We'll recompute extreme properly per row:
    details = []
    for gid, group in df_anom.groupby('group_id'):
        atype = group['anomaly_type'].iat[0]
        start_ts = group['ts'].min()
        end_ts = group['ts'].max()
        duration_points = int(group.shape[0])
        if atype == 'high':
            extreme_value = float(group['value'].max())
            threshold_used = float(p95)
        else:
            extreme_value = float(group['value'].min())
            threshold_used = float(p5)
        breach_ratio = abs(extreme_value - threshold_used) / (abs(threshold_used) + eps)
        details.append({
            'cmdb_id': cmdb,
            'kpi_name': kpi,
            'anomaly_type': atype,
            'start_timestamp': start_ts.isoformat(),
            'end_timestamp': end_ts.isoformat(),
            'duration_minutes': duration_points,
            'extreme_value': extreme_value,
            'threshold_used': threshold_used,
            'breach_ratio': breach_ratio,
            'window_point_count': total_points
        })
    subseqs.extend(details)

# Build dataframe of subsequences and sort by breach_ratio descending, limit top 20
subseqs_df = pd.DataFrame(subseqs)
if not subseqs_df.empty:
    subseqs_df = subseqs_df.sort_values('breach_ratio', ascending=False).reset_index(drop=True)
    top_subseqs = subseqs_df.head(20)
else:
    top_subseqs = subseqs_df.copy()

# Aggregate counts of subsequences per cmdb_id (top 10)
if not subseqs_df.empty:
    subseq_counts = subseqs_df.groupby('cmdb_id').size().reset_index(name='subsequence_count').sort_values('subsequence_count', ascending=False).head(10)
else:
    subseq_counts = pd.DataFrame(columns=['cmdb_id', 'subsequence_count'])

# Display compact results: top subsequences and subsequence counts per cmdb_id
top_subseqs[['cmdb_id','kpi_name','anomaly_type','start_timestamp','end_timestamp','duration_minutes','extreme_value','threshold_used','breach_ratio','window_point_count']].head(20), subseq_counts
