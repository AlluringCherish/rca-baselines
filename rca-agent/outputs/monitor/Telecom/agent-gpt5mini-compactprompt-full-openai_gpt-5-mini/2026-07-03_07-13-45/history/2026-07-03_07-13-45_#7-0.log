    _df = _df[['trace_name','involved_component','metric_type','global_p95','anomaly_count','earliest_anomaly_timestamp','window_point_count']].head(20)
    _total = global_p95['trace_name'].nunique()

# Build plain-English summary
top_entries = []
for _, r in _df.head(10).iterrows():
    top_entries.append(
        f"{r['trace_name']} (component={r['involved_component']}, type={r['metric_type']}, "
        f"anomalies={int(r['anomaly_count'])}, earliest={r['earliest_anomaly_timestamp']}, points={int(r['window_point_count'])})"
    )

summary_text = (
    f"Processed {_total} distinct trace_name metrics. "
    f"Top trace_names by anomaly count in the incident window (May 22, 2020 00:30–01:00 UTC+8): "
    + "; ".join(top_entries) +
    ". Returned table lists up to the top 20 trace_names sorted by anomaly count."
)

summary_text
