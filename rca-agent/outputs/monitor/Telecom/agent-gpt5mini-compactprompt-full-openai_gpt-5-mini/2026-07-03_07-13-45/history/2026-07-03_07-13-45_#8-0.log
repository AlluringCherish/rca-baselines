import pandas as pd
import pytz

# reuse existing df_trace and tz if present; otherwise load and prepare
try:
    df_trace
except NameError:
    df_trace = pd.read_csv("trace.csv")
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# ensure timezone-aware timestamp column exists
if 'ts' not in df_trace.columns:
    df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    # ensure tz conversion in case it's naive
    df_trace['ts'] = pd.to_datetime(df_trace['ts']).dt.tz_localize(None)
    df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Compute global P95 and P5 per (cmdb_id, trace_name) using full series
trace_thresholds = (
    df_trace
    .groupby(['cmdb_id', 'trace_name'])['value']
    .agg(global_p95=lambda x: x.quantile(0.95), global_p5=lambda x: x.quantile(0.05))
    .reset_index()
)

# 2) Filter rows to the incident window (inclusive)
start = tz.localize(pd.to_datetime("2020-05-22 01:30:00"))
end = tz.localize(pd.to_datetime("2020-05-22 02:00:00"))
df_trace_win = df_trace[(df_trace['ts'] >= start) & (df_trace['ts'] <= end)].copy()

# Merge thresholds so each window row has its group's global thresholds
df_trace_win = df_trace_win.merge(trace_thresholds, on=['cmdb_id', 'trace_name'], how='left')

# 3) For each group in the window compute required stats
def summarize_trace_group(g):
    total_points_in_window = int(g.shape[0])
    gp95 = g['global_p95'].iloc[0]
    gp5 = g['global_p5'].iloc[0]
    ge_mask = g['value'] >= gp95
    le_mask = g['value'] <= gp5
    count_value_ge_globalP95 = int(ge_mask.sum())
    earliest_ts_ge = g.loc[ge_mask, 'ts'].min() if count_value_ge_globalP95 > 0 else pd.NaT
    count_value_le_globalP5 = int(le_mask.sum())
    earliest_ts_le = g.loc[le_mask, 'ts'].min() if count_value_le_globalP5 > 0 else pd.NaT
    max_value_in_window = g['value'].max()
    min_value_in_window = g['value'].min()
    return pd.Series({
        'total_points_in_window': total_points_in_window,
        'count_value_ge_globalP95': count_value_ge_globalP95,
        'earliest_timestamp_value_ge_globalP95': earliest_ts_ge,
        'count_value_le_globalP5': count_value_le_globalP5,
        'earliest_timestamp_value_le_globalP5': earliest_ts_le,
        'max_value_in_window': max_value_in_window,
        'min_value_in_window': min_value_in_window,
        'global_p95': gp95,
        'global_p5': gp5
    })

trace_grouped = df_trace_win.groupby(['cmdb_id', 'trace_name']).apply(summarize_trace_group).reset_index()

# Keep only groups that have at least one threshold breach
trace_grouped['total_breaches'] = trace_grouped['count_value_ge_globalP95'] + trace_grouped['count_value_le_globalP5']
trace_result = trace_grouped[trace_grouped['total_breaches'] > 0].copy()

# Sort by total breaches desc and limit to top 20
trace_result = trace_result.sort_values('total_breaches', ascending=False).head(20)

# Format earliest timestamps as ISO strings for compact display (preserve NaT as empty)
trace_result['earliest_timestamp_value_ge_globalP95'] = trace_result['earliest_timestamp_value_ge_globalP95'].apply(
    lambda x: x.isoformat() if pd.notna(x) else ""
)
trace_result['earliest_timestamp_value_le_globalP5'] = trace_result['earliest_timestamp_value_le_globalP5'].apply(
    lambda x: x.isoformat() if pd.notna(x) else ""
)

# Select and order the requested columns for compact output
trace_result_df = trace_result[
    [
        'cmdb_id',
        'trace_name',
        'total_points_in_window',
        'count_value_ge_globalP95',
        'earliest_timestamp_value_ge_globalP95',
        'count_value_le_globalP5',
        'earliest_timestamp_value_le_globalP5',
        'max_value_in_window',
        'min_value_in_window',
        'global_p95',
        'global_p5'
    ]
