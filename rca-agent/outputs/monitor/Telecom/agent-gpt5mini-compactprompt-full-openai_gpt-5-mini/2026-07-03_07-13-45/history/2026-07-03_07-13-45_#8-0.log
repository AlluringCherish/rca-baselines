import pandas as pd
import pytz

# reuse existing df_trace and tz if available
try:
    df_trace
except NameError:
    df_trace = pd.read_csv("trace.csv")

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# ensure timezone-aware timestamp column exists
if 'ts' not in df_trace.columns:
    df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    # if ts exists, ensure it's timezone-aware and matches timestamp column
    df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Compute global P95 and global P5 for each (cmdb_id, trace_name) using full series
trace_thresholds = (
    df_trace
    .groupby(['cmdb_id', 'trace_name'])['value']
    .agg(global_p95=lambda x: x.quantile(0.95), global_p5=lambda x: x.quantile(0.05))
    .reset_index()
)

# Exclude groups where global_p95 == global_p5 (constant series)
trace_thresholds = trace_thresholds[trace_thresholds['global_p95'] != trace_thresholds['global_p5']].copy()

# 2) Filter rows to the incident window (inclusive)
start = tz.localize(pd.to_datetime("2020-05-22 01:30:00"))
end = tz.localize(pd.to_datetime("2020-05-22 02:00:00"))
df_trace_win = df_trace[(df_trace['ts'] >= start) & (df_trace['ts'] <= end)].copy()

# Merge only the non-constant-group thresholds (inner join)
df_trace_win = df_trace_win.merge(trace_thresholds, on=['cmdb_id', 'trace_name'], how='inner')

# 3) For each group in the window compute required stats (strictly greater than global_p95)
def summarize_gt(g):
    total_points_in_window = int(g.shape[0])
    gp95 = g['global_p95'].iloc[0]
    gp5 = g['global_p5'].iloc[0]
    gt_mask = g['value'] > gp95  # strictly greater
    count_value_gt_globalP95 = int(gt_mask.sum())
    earliest_ts_gt = g.loc[gt_mask, 'ts'].min() if count_value_gt_globalP95 > 0 else pd.NaT
    max_value_in_window = g['value'].max()
    mean_value_in_window = g['value'].mean()
    return pd.Series({
        'total_points_in_window': total_points_in_window,
        'count_value_gt_globalP95': count_value_gt_globalP95,
        'earliest_timestamp_value_gt_globalP95': earliest_ts_gt,
        'max_value_in_window': max_value_in_window,
        'mean_value_in_window': mean_value_in_window,
        'global_p95': gp95,
        'global_p5': gp5
    })

trace_gt_grouped = df_trace_win.groupby(['cmdb_id', 'trace_name']).apply(summarize_gt).reset_index()

# Keep only groups with count_value_gt_globalP95 > 0
trace_gt_result = trace_gt_grouped[trace_gt_grouped['count_value_gt_globalP95'] > 0].copy()

# Format earliest timestamps as ISO strings for compact display
trace_gt_result['earliest_timestamp_value_gt_globalP95'] = trace_gt_result['earliest_timestamp_value_gt_globalP95'].apply(
    lambda x: x.isoformat() if pd.notna(x) else ""
)

# Sort by max_value_in_window descending and limit to top 20
trace_gt_result = trace_gt_result.sort_values('max_value_in_window', ascending=False).head(20)

# Select and order the requested columns for compact output
trace_gt_summary = trace_gt_result[
    [
        'cmdb_id',
        'trace_name',
        'total_points_in_window',
        'count_value_gt_globalP95',
        'earliest_timestamp_value_gt_globalP95',
        'max_value_in_window',
        'mean_value_in_window',
        'global_p95',
        'global_p5'
    ]
].reset_index(drop=True)

