import pandas as pd
import pytz

# load files
df_metric = pd.read_csv("metric.csv")
df_trace = pd.read_csv("trace.csv")

# convert timestamp to timezone-aware datetime in UTC+8 (Asia/Shanghai)
tz = pytz.timezone('Asia/Shanghai')
df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Metric: overall min/max timestamps
metric_global_min = df_metric['ts'].min()
metric_global_max = df_metric['ts'].max()
metric_global_range = pd.DataFrame({
    'overall_min_ts': [metric_global_min],
    'overall_max_ts': [metric_global_max]
})

# Metric: group stats
metric_grp = df_metric.groupby(['cmdb_id','kpi_name']).agg(
    count=('value','size'),
    min_ts=('ts','min'),
    max_ts=('ts','max'),
    p95=('value', lambda x: x.quantile(0.95)),
    p5=('value', lambda x: x.quantile(0.05)),
    mean_value=('value','mean')
).reset_index()

metric_summary = metric_grp.sort_values('count', ascending=False).head(50)

# Trace: overall min/max timestamps
trace_global_min = df_trace['ts'].min()
trace_global_max = df_trace['ts'].max()
trace_global_range = pd.DataFrame({
    'overall_min_ts': [trace_global_min],
    'overall_max_ts': [trace_global_max]
})

# Trace: group stats
trace_grp = df_trace.groupby(['cmdb_id','trace_name']).agg(
    count=('value','size'),
    min_ts=('ts','min'),
    max_ts=('ts','max'),
    p95=('value', lambda x: x.quantile(0.95)),
    p5=('value', lambda x: x.quantile(0.05)),
    mean_value=('value','mean')
).reset_index()

trace_summary = trace_grp.sort_values('count', ascending=False).head(50)

# Keep outputs compact: show summaries (one row per group) and global ranges
metric_summary, metric_global_range, trace_summary, trace_global_range
