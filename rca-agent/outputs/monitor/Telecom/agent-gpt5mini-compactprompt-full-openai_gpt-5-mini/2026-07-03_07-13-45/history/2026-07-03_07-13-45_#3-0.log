end_str   = '2020-04-11 03:00:00'
start_ts = tz.localize(pd.to_datetime(start_str))
end_ts   = tz.localize(pd.to_datetime(end_str))

# Helper to build compact summary and samples for a dataframe
def window_check(df, sample_cols):
    total_rows = int(df.shape[0])
    earliest = df['ts'].min()
    latest = df['ts'].max()
    # Filter inclusive
    mask = (df['ts'] >= start_ts) & (df['ts'] <= end_ts)
    df_window = df.loc[mask].copy()
    rows_in_window = int(df_window.shape[0])
