import pandas as pd
import numpy as np
import pytz

# Reuse existing df_metric if present
df_metric = globals().get('df_metric')
if df_metric is None:
    df_metric = pd.read_csv('metric.csv')

# Ensure numeric value column
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

# Ensure timezone-aware timestamp column in Asia/Shanghai (UTC+8)
tz = pytz.timezone('Asia/Shanghai')
if 'ts' not in df_metric.columns:
    df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    # ensure tz
    if df_metric['ts'].dt.tz is None:
        df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s').dt.tz_localize(tz)
    else:
        df_metric['ts'] = pd.to_datetime(df_metric['ts']).dt.tz_convert(tz)

# 1) Compute global thresholds (p95 and p5) using the full series per (cmdb_id, kpi_name)
group_cols = ['cmdb_id', 'kpi_name']
thresholds = df_metric.groupby(group_cols, sort=False)['value'].agg(
    global_p95=lambda x: float(np.nanpercentile(x.dropna().values, 95)) if x.dropna().size>0 else np.nan,
    global_p5 =lambda x: float(np.nanpercentile(x.dropna().values, 5))  if x.dropna().size>0 else np.nan
).reset_index()

# 2) Filter to incident window (inclusive) in Asia/Shanghai
start = tz.localize(pd.to_datetime('2020-04-11 02:30:00'))
end   = tz.localize(pd.to_datetime('2020-04-11 03:00:00'))
df_win = df_metric[(df_metric['ts'] >= start) & (df_metric['ts'] <= end)].copy()

# Merge thresholds into windowed data to evaluate anomalies against global thresholds
if df_win.shape[0] > 0:
    df_win = df_win.merge(thresholds, on=group_cols, how='left')
    # flags
    df_win['is_high'] = df_win['value'] >= df_win['global_p95']
    df_win['is_low']  = df_win['value'] <= df_win['global_p5']
    df_win['is_anom'] = df_win['is_high'] | df_win['is_low']
else:
    # empty dataframe with needed columns for downstream logic
    df_win = df_win.assign(global_p95=np.nan, global_p5=np.nan, is_high=False, is_low=False, is_anom=False)

# Aggregations for windowed groups
agg_win = df_win.groupby(group_cols, sort=False).agg(
    total_points_in_window=('value', 'size'),
    anomalies_high_count=('is_high', 'sum'),
    anomalies_low_count=('is_low', 'sum'),
    max_val_in_window=('value', 'max'),
    min_val_in_window=('value', 'min')
).reset_index()

# earliest anomaly timestamp per group (only among rows flagged as anomaly)
if df_win['is_anom'].any():
    earliest_anom = (df_win[df_win['is_anom']].groupby(group_cols, sort=False)['ts']
                     .min().reset_index().rename(columns={'ts':'earliest_anomaly_timestamp'}))
else:
    earliest_anom = pd.DataFrame(columns=group_cols + ['earliest_anomaly_timestamp'])

# Merge everything: start from thresholds (all combos), left-join agg_win and earliest_anom to include groups with zero window points
metric_anomaly_table = thresholds.merge(agg_win, on=group_cols, how='left').merge(earliest_anom, on=group_cols, how='left')

# Fill NaNs for groups with no window data
metric_anomaly_table['total_points_in_window'] = metric_anomaly_table['total_points_in_window'].fillna(0).astype(int)
metric_anomaly_table['anomalies_high_count'] = metric_anomaly_table['anomalies_high_count'].fillna(0).astype(int)
metric_anomaly_table['anomalies_low_count'] = metric_anomaly_table['anomalies_low_count'].fillna(0).astype(int)
# max/min remain NaN if no points in window

# Compute max_high_ratio and max_low_ratio per spec, guarding against zero denominators
def compute_high_ratio(row):
    if row['anomalies_high_count'] > 0 and pd.notnull(row['max_val_in_window']) and pd.notnull(row['global_p95']) and row['global_p95'] != 0:
        return (row['max_val_in_window'] - row['global_p95']) / row['global_p95']
    elif row['anomalies_high_count'] > 0 and row['global_p95'] == 0:
        return np.nan
    else:
        return 0.0

def compute_low_ratio(row):
    if row['anomalies_low_count'] > 0 and pd.notnull(row['min_val_in_window']) and pd.notnull(row['global_p5']) and row['global_p5'] != 0:
        return (row['global_p5'] - row['min_val_in_window']) / row['global_p5']
    elif row['anomalies_low_count'] > 0 and row['global_p5'] == 0:
        return np.nan
    else:
        return 0.0

metric_anomaly_table['max_high_ratio'] = metric_anomaly_table.apply(compute_high_ratio, axis=1)
metric_anomaly_table['max_low_ratio']  = metric_anomaly_table.apply(compute_low_ratio, axis=1)

# Format earliest_anomaly_timestamp as string in Asia/Shanghai, keep NaT as None
def fmt_ts(x):
    if pd.isnull(x):
        return None
    return pd.to_datetime(x).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z')

metric_anomaly_table['earliest_anomaly_timestamp'] = metric_anomaly_table['earliest_anomaly_timestamp'].apply(fmt_ts)

# 3) Prepare top-20 rows sorted by max(anomalies_high_count, anomalies_low_count) descending
metric_anomaly_table['max_anomaly_count'] = metric_anomaly_table[['anomalies_high_count','anomalies_low_count']].max(axis=1)
