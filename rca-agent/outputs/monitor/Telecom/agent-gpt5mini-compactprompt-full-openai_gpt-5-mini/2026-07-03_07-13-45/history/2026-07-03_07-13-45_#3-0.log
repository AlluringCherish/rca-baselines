import pandas as pd
import numpy as np
import pytz

# Load files
df_metric = pd.read_csv("metric.csv")
df_trace = pd.read_csv("trace.csv")

# Total rows
metric_total_rows = df_metric.shape[0]
trace_total_rows = df_trace.shape[0]

# Set timezone to UTC+8 (Asia/Shanghai) for timestamps
tz = pytz.timezone('Asia/Shanghai')
df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s').dt.tz_localize(tz)
df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s').dt.tz_localize(tz)

# Aggregation helper
def aggregate_df(df, group_cols, name_col):
    grp = df.groupby(group_cols, sort=False)
    agg = grp.agg(
        count=( 'value', 'size'),
        timestamp_min=('ts', 'min'),
        timestamp_max=('ts', 'max'),
        # global percentiles computed on the entire group's series
        global_p95=('value', lambda x: float(np.nanpercentile(x.values, 95)) if x.size>0 else np.nan),
        global_p5 =('value', lambda x: float(np.nanpercentile(x.values, 5)) if x.size>0 else np.nan)
    ).reset_index()
    # format timestamps compactly
    agg['timestamp_min'] = agg['timestamp_min'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
    agg['timestamp_max'] = agg['timestamp_max'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
    # sort by count desc and limit to top 50
    agg = agg.sort_values('count', ascending=False).head(50)
    # ensure column order requested
    cols = group_cols + ['count', 'timestamp_min', 'timestamp_max', 'global_p95', 'global_p5']
    return agg[cols]

# Metric aggregation by (cmdb_id, kpi_name)
metric_summary = aggregate_df(df_metric, ['cmdb_id', 'kpi_name'], 'kpi_name')

# Trace aggregation by (cmdb_id, trace_name)
trace_summary = aggregate_df(df_trace, ['cmdb_id', 'trace_name'], 'trace_name')

# Display compact results: total rows and top summaries (up to 50 rows each)
metric_total_rows, metric_summary, trace_total_rows, trace_summary
