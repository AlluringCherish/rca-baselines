import pandas as pd
import numpy as np
import pytz

# timezone (UTC+8)
tz = pytz.timezone('Asia/Shanghai')

# load CSVs
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')

# convert timestamp to timezone-aware datetime (assume epoch seconds UTC then convert to Asia/Shanghai)
for df in (df_metric, df_trace):
    df['dt'] = pd.to_datetime(df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# define window in Asia/Shanghai tz
window_start = tz.localize(pd.to_datetime("2020-04-11 02:00:00"))
window_end = tz.localize(pd.to_datetime("2020-04-11 02:30:00"))

# --- METRIC processing ---
metric_total_rows = df_metric.shape[0]
metric_unique_cmdb = pd.Series(sorted(df_metric['cmdb_id'].unique()), name='cmdb_id')
metric_unique_kpis = pd.Series(sorted(df_metric['kpi_name'].unique()), name='kpi_name')

# mark in-window
df_metric['in_window'] = (df_metric['dt'] >= window_start) & (df_metric['dt'] <= window_end)

# compute group-level aggregates: global P95 (on full series), total count, count in window, earliest & latest in-window
def agg_metric_group(g):
    values = g['value'].dropna().values
    p95 = float(np.percentile(values, 95)) if len(values) > 0 else np.nan
    total_count = len(g)
    in_window = g[g['in_window']]
    count_in_window = len(in_window)
    if count_in_window > 0:
        earliest = in_window['dt'].min()
        latest = in_window['dt'].max()
    else:
        earliest = pd.NaT
        latest = pd.NaT
    return pd.Series({
        'p95_global': p95,
        'total_count': total_count,
        'count_in_window': count_in_window,
        'earliest_in_window': earliest,
        'latest_in_window': latest
    })

metric_grouped = df_metric.groupby(['cmdb_id', 'kpi_name']).apply(agg_metric_group).reset_index()

# format earliest/latest as ISO strings while keeping NaT if absent
metric_grouped['earliest_in_window'] = metric_grouped['earliest_in_window'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
metric_grouped['latest_in_window'] = metric_grouped['latest_in_window'].dt.strftime('%Y-%m-%d %H:%M:%S%z')

# sort by count_in_window desc and take top 20
metric_summary_top20 = metric_grouped.sort_values('count_in_window', ascending=False).head(20)

# sample up to 10 metric rows inside window with requested columns (show dt as ISO)
metric_samples = df_metric[df_metric['in_window']].copy()
if not metric_samples.empty:
    metric_samples['dt_str'] = metric_samples['dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
    metric_samples = metric_samples[['dt_str', 'timestamp', 'cmdb_id', 'kpi_name', 'value']].rename(columns={'dt_str':'timestamp_dt'}).head(10)
else:
    metric_samples = metric_samples[['timestamp','cmdb_id','kpi_name','value']].head(0)

# --- TRACE processing ---
trace_total_rows = df_trace.shape[0]
trace_unique_cmdb = pd.Series(sorted(df_trace['cmdb_id'].unique()), name='cmdb_id')
trace_unique_traces = pd.Series(sorted(df_trace['trace_name'].unique()), name='trace_name')

df_trace['in_window'] = (df_trace['dt'] >= window_start) & (df_trace['dt'] <= window_end)

def agg_trace_group(g):
    values = g['value'].dropna().values
    p95 = float(np.percentile(values, 95)) if len(values) > 0 else np.nan
    total_count = len(g)
    in_window = g[g['in_window']]
    count_in_window = len(in_window)
    if count_in_window > 0:
        earliest = in_window['dt'].min()
        latest = in_window['dt'].max()
    else:
        earliest = pd.NaT
        latest = pd.NaT
    return pd.Series({
        'p95_global': p95,
        'total_count': total_count,
        'count_in_window': count_in_window,
        'earliest_in_window': earliest,
        'latest_in_window': latest
    })

trace_grouped = df_trace.groupby(['cmdb_id', 'trace_name']).apply(agg_trace_group).reset_index()
trace_grouped['earliest_in_window'] = trace_grouped['earliest_in_window'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
trace_grouped['latest_in_window'] = trace_grouped['latest_in_window'].dt.strftime('%Y-%m-%d %H:%M:%S%z')

trace_summary_top20 = trace_grouped.sort_values('count_in_window', ascending=False).head(20)

trace_samples = df_trace[df_trace['in_window']].copy()
if not trace_samples.empty:
    trace_samples['dt_str'] = trace_samples['dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
    trace_samples = trace_samples[['dt_str', 'timestamp', 'cmdb_id', 'trace_name', 'value']].rename(columns={'dt_str':'timestamp_dt'}).head(10)
else:
    trace_samples = trace_samples[['timestamp','cmdb_id','trace_name','value']].head(0)

# Compact summaries for display
metric_overview = pd.DataFrame({
    'metric_total_rows': [metric_total_rows],
    'unique_cmdb_count': [metric_unique_cmdb.shape[0]],
    'unique_kpi_count': [metric_unique_kpis.shape[0]]
})

trace_overview = pd.DataFrame({
    'trace_total_rows': [trace_total_rows],
    'unique_cmdb_count': [trace_unique_cmdb.shape[0]],
    'unique_trace_name_count': [trace_unique_traces.shape[0]]
})

# Display outputs (variables separated by commas as required)
metric_overview, metric_unique_cmdb, metric_unique_kpis, metric_summary_top20[['cmdb_id','kpi_name','p95_global','total_count','count_in_window','earliest_in_window','latest_in_window']].head(20), metric_samples, trace_overview, trace_unique_cmdb, trace_unique_traces, trace_summary_top20[['cmdb_id','trace_name','p95_global','total_count','count_in_window','earliest_in_window','latest_in_window']].head(20), trace_samples
