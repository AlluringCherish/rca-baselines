import numpy as np
import pandas as pd
import pytz

# Reuse existing df_metric, window_start, window_end, tz if present; otherwise load and prepare
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
    tz = pytz.timezone('Asia/Shanghai')
    df_metric['dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    window_start = tz.localize(pd.to_datetime("2020-04-11 02:00:00"))
    window_end = tz.localize(pd.to_datetime("2020-04-11 02:30:00"))
    df_metric['in_window'] = (df_metric['dt'] >= window_start) & (df_metric['dt'] <= window_end)

# 1) Compute global P95 and P05 and total_count per (cmdb_id, kpi_name) using full series
def compute_thresholds(g):
    vals = g['value'].dropna().values
    if len(vals) > 0:
        p95 = float(np.percentile(vals, 95))
        p05 = float(np.percentile(vals, 5))
    else:
        p95 = np.nan
        p05 = np.nan
    return pd.Series({'p95_global': p95, 'p05_global': p05, 'total_count': len(g)})

thresholds = df_metric.groupby(['cmdb_id', 'kpi_name']).apply(compute_thresholds).reset_index()

# merge thresholds back to metric rows for per-row comparison
df_metric = df_metric.merge(thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# 2) Filter metric rows to the incident window (reuse in_window if present)
df_metric_in_window = df_metric[df_metric['in_window']].copy()

# 3) Detect anomalies inside the window: value > p95_global OR value < p05_global
# Compute breach_ratio per anomalous row with safe handling for zero denominators
def row_breach_ratio(row):
    v = row['value']
    p95 = row['p95_global']
    p05 = row['p05_global']
    if pd.isna(v) or (pd.isna(p95) and pd.isna(p05)):
        return np.nan
    # above p95
    if (not pd.isna(p95)) and v > p95:
        return np.inf if p95 == 0 else v / p95
    # below p05
    if (not pd.isna(p05)) and v < p05:
        return np.inf if v == 0 else p05 / v
    return np.nan

# Identify anomalous rows
mask_anom = (df_metric_in_window['value'] > df_metric_in_window['p95_global']) | (df_metric_in_window['value'] < df_metric_in_window['p05_global'])
anomalies = df_metric_in_window[mask_anom].copy()
if not anomalies.empty:
    anomalies['breach_ratio'] = anomalies.apply(row_breach_ratio, axis=1)
else:
    anomalies['breach_ratio'] = pd.Series(dtype=float)

# 4) Aggregate per group that has at least one anomalous point in-window
if anomalies.shape[0] > 0:
    # count_in_window per group (all rows in window, not only anomalies)
    count_in_window = df_metric_in_window.groupby(['cmdb_id', 'kpi_name']).size().rename('count_in_window').reset_index()

    agg_anoms = anomalies.groupby(['cmdb_id', 'kpi_name']).agg(
        anomalous_count_in_window = ('value','size'),
        earliest_anomaly_timestamp_in_window = ('dt','min'),
        latest_anomaly_timestamp_in_window = ('dt','max'),
        max_value_in_window = ('value','max'),
        min_value_in_window = ('value','min'),
        max_breach_ratio = ('breach_ratio','max')
    ).reset_index()

    # join with thresholds (to get p95/p05 and total_count) and count_in_window
    agg_anoms = agg_anoms.merge(thresholds, on=['cmdb_id','kpi_name'], how='left')
    agg_anoms = agg_anoms.merge(count_in_window, on=['cmdb_id','kpi_name'], how='left')

    # format earliest/latest timestamps as compact strings
    agg_anoms['earliest_anomaly_timestamp_in_window'] = agg_anoms['earliest_anomaly_timestamp_in_window'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
    agg_anoms['latest_anomaly_timestamp_in_window'] = agg_anoms['latest_anomaly_timestamp_in_window'].dt.strftime('%Y-%m-%d %H:%M:%S%z')

    # reorder and select columns requested
    agg_anoms = agg_anoms[
        ['cmdb_id','kpi_name','p95_global','p05_global','total_count','count_in_window',
         'anomalous_count_in_window','earliest_anomaly_timestamp_in_window','latest_anomaly_timestamp_in_window',
         'max_value_in_window','min_value_in_window','max_breach_ratio']
    ]

    # sort by anomalous_count_in_window desc and take top 20
    anomalies_summary_top20 = agg_anoms.sort_values('anomalous_count_in_window', ascending=False).head(20).reset_index(drop=True)
else:
    # empty result frames
    anomalies_summary_top20 = pd.DataFrame(columns=['cmdb_id','kpi_name','p95_global','p05_global','total_count','count_in_window',
                                                   'anomalous_count_in_window','earliest_anomaly_timestamp_in_window','latest_anomaly_timestamp_in_window',
                                                   'max_value_in_window','min_value_in_window','max_breach_ratio'])

# 5) Up to 10 sample anomalous metric rows (timestamp, cmdb_id, kpi_name, value) across all groups
if not anomalies.empty:
    anomaly_samples = anomalies[['timestamp','cmdb_id','kpi_name','value']].head(10).reset_index(drop=True)
else:
    anomaly_samples = anomalies[['timestamp','cmdb_id','kpi_name','value']].head(0)

# Compact summary: also include how many groups had anomalies
num_groups_with_anoms = anomalies.groupby(['cmdb_id','kpi_name']).ngroups if anomalies.shape[0] > 0 else 0

# Display compact outputs
num_groups_with_anoms, anomalies_summary_top20, anomaly_samples
