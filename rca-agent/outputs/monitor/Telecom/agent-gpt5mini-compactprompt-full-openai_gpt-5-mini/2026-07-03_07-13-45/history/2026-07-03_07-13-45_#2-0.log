import pandas as pd
import numpy as np
import pytz

# Reuse anomalies DataFrame from prior steps (should contain columns: timestamp, cmdb_id, kpi_name, value, dt, breach_ratio)
# If anomalies is not present, abort with empty outputs
try:
    anomalies
except NameError:
    anomalies = pd.DataFrame(columns=['timestamp','cmdb_id','kpi_name','value','dt','breach_ratio'])

# Ensure timestamp is integer seconds and dt exists
if 'timestamp' in anomalies.columns:
    anomalies['timestamp'] = anomalies['timestamp'].astype(int)
else:
    anomalies['timestamp'] = anomalies['dt'].astype(int)

# Sort anomalies for run detection
anoms_sorted = anomalies.sort_values(['cmdb_id','kpi_name','timestamp']).copy()

# Assign run ids per (cmdb_id, kpi_name) where consecutive timestamps differ by exactly 60 seconds
def assign_run_ids(g):
    g = g.sort_values('timestamp').copy()
    # difference in seconds between adjacent rows
    diffs = g['timestamp'].diff().fillna(0).astype(int)
    # start a new run when diff != 60
    run_change = (diffs != 60).astype(int)
    # cumulative sum to produce run ids (starts at 1)
    g['run_id'] = run_change.cumsum()
    return g

if not anoms_sorted.empty:
    anoms_with_runs = anoms_sorted.groupby(['cmdb_id','kpi_name'], group_keys=False).apply(assign_run_ids).reset_index(drop=True)
else:
    anoms_with_runs = anoms_sorted.copy()

# Aggregate runs
if not anoms_with_runs.empty:
    runs = anoms_with_runs.groupby(['cmdb_id','kpi_name','run_id']).agg(
        run_start_ts = ('timestamp','first'),
        run_end_ts = ('timestamp','last'),
        run_length = ('timestamp','size'),
        anomalous_count_in_run = ('timestamp','size'),
        max_value_in_run = ('value','max'),
        min_value_in_run = ('value','min'),
        run_max_breach_ratio = ('breach_ratio','max')
    ).reset_index()
else:
    runs = pd.DataFrame(columns=['cmdb_id','kpi_name','run_id','run_start_ts','run_end_ts','run_length',
                                 'anomalous_count_in_run','max_value_in_run','min_value_in_run','run_max_breach_ratio'])

# Filter fault candidates: run_length >= 3 AND run_max_breach_ratio >= 1.2
fault_candidates = runs[(runs['run_length'] >= 3) & (runs['run_max_breach_ratio'] >= 1.2)].copy()

# Prepare output A: top 20 fault candidates sorted by run_length desc then run_max_breach_ratio desc
fault_candidates_top20 = fault_candidates.sort_values(['run_length','run_max_breach_ratio'], ascending=[False,False]) \
                                         .head(20) \
                                         .reset_index(drop=True)

# For readability, keep only requested columns in the specified order
fault_candidates_top20 = fault_candidates_top20[[
    'cmdb_id','kpi_name','run_start_ts','run_end_ts','run_length',
    'anomalous_count_in_run','max_value_in_run','min_value_in_run','run_max_breach_ratio'
]]

# Output B: aggregate count of fault candidate run_length sum per cmdb_id (top 20 cmdb_ids)
if not fault_candidates.empty:
    agg_by_cmdb = fault_candidates.groupby('cmdb_id').agg(
        fault_run_count = ('run_id','count'),
        run_length_sum = ('run_length','sum')
    ).reset_index().sort_values('run_length_sum', ascending=False).head(20).reset_index(drop=True)
else:
    agg_by_cmdb = pd.DataFrame(columns=['cmdb_id','fault_run_count','run_length_sum'])

# Output C: up to 10 sample anomalous rows that belong to the top 3 fault candidates
sample_rows_top3 = pd.DataFrame(columns=['timestamp','cmdb_id','kpi_name','value'])
if not fault_candidates_top20.empty:
    top3 = fault_candidates_top20.head(3)
    # join to get run_id: need mapping from (cmdb,kpi,run_start_ts/run_end_ts) to run_id in runs
    # Use runs df to find exact run_ids for top3 entries
    merged_top3 = top3.merge(runs, on=['cmdb_id','kpi_name','run_start_ts','run_end_ts','run_length','anomalous_count_in_run','max_value_in_run','min_value_in_run','run_max_breach_ratio'], how='left')
    # If merge fails for run_id, try matching by cmdb,kpi and start/end
    if 'run_id' not in merged_top3.columns or merged_top3['run_id'].isna().any():
        # try a safer merge using start and end
        merged_top3 = top3.merge(runs[['cmdb_id','kpi_name','run_id','run_start_ts','run_end_ts']], on=['cmdb_id','kpi_name','run_start_ts','run_end_ts'], how='left')

    # Collect anomalies for each top3 run
    frames = []
    for _, row in merged_top3.iterrows():
        if pd.isna(row.get('run_id')):
            continue
        cmdb = row['cmdb_id']
        kpi = row['kpi_name']
        rid = row['run_id']
        sel = anoms_with_runs[(anoms_with_runs['cmdb_id']==cmdb) & (anoms_with_runs['kpi_name']==kpi) & (anoms_with_runs['run_id']==rid)]
        if not sel.empty:
            frames.append(sel[['timestamp','cmdb_id','kpi_name','value']])
    if frames:
        sample_rows_top3 = pd.concat(frames, ignore_index=True).sort_values(['timestamp','cmdb_id','kpi_name']).head(10).reset_index(drop=True)

# Compact outputs
fault_candidates_top20, agg_by_cmdb, sample_rows_top3
