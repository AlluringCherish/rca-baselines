import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse the per-(cmdb_id,kpi_name) anomaly aggregates from previous step
# Expecting result_sorted to exist in the environment
try:
    src = result_sorted
except NameError:
    raise RuntimeError("Expected variable 'result_sorted' not found. Please run the anomaly aggregation step first.")

# Ensure timestamp column is datetime with UTC then converted to UTC+8
src = src.copy()
if not pd.api.types.is_datetime64tz_dtype(src['earliest_anomaly_timestamp']):
    src['earliest_anomaly_timestamp'] = pd.to_datetime(src['earliest_anomaly_timestamp'], utc=True).dt.tz_convert(tz)
else:
    src['earliest_anomaly_timestamp'] = src['earliest_anomaly_timestamp'].dt.tz_convert(tz)

# Aggregate per component (cmdb_id)
comp_agg = (
    src
    .groupby('cmdb_id', as_index=False)
    .agg(
        distinct_faulty_kpis_count = ('kpi_name', 'nunique'),
        total_anomaly_points = ('anomaly_count', 'sum'),
        earliest_anomaly_timestamp = ('earliest_anomaly_timestamp', 'min'),
        max_relative_deviation = ('max_relative_deviation', 'max')
    )
)

# Format earliest_anomaly_timestamp as timezone-aware strings for compactness
comp_agg['earliest_anomaly_timestamp'] = comp_agg['earliest_anomaly_timestamp'].dt.strftime('%Y-%m-%d %H:%M:%S%z')

# Round deviation for compact display
comp_agg['max_relative_deviation'] = comp_agg['max_relative_deviation'].round(6)

# Total distinct components with anomalies
total_distinct_components = comp_agg['cmdb_id'].nunique()

# A) All components sorted by total_anomaly_points desc (top 20)
all_components_top20 = comp_agg.sort_values('total_anomaly_points', ascending=False).head(20).reset_index(drop=True)

# B) Node-level components (cmdb_id starts with 'os_') top 20
nodes = comp_agg[comp_agg['cmdb_id'].str.startswith('os_')]
nodes_top20 = nodes.sort_values('total_anomaly_points', ascending=False).head(20).reset_index(drop=True)

# C) Container-level ('docker_') top 20 and DB/service-level ('db_') top 20
docker = comp_agg[comp_agg['cmdb_id'].str.startswith('docker_')]
docker_top20 = docker.sort_values('total_anomaly_points', ascending=False).head(20).reset_index(drop=True)

db = comp_agg[comp_agg['cmdb_id'].str.startswith('db_')]
db_top20 = db.sort_values('total_anomaly_points', ascending=False).head(20).reset_index(drop=True)

# Return compact tables and total count
all_components_top20, nodes_top20, docker_top20, db_top20, total_distinct_components
