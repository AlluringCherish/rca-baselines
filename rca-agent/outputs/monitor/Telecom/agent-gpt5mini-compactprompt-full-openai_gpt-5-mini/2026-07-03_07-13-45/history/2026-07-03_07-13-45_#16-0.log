import numpy as np
import pandas as pd
import pytz

# Reuse df_metric and tz if available; otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
tz = pytz.timezone('Asia/Shanghai')

# 1) Compute global P95 and P05 and global point count per (cmdb_id, kpi_name)
global_thresh = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(p95_value=lambda x: x.quantile(0.95),
         p05_value=lambda x: x.quantile(0.05),
         global_point_count='size')
    .reset_index()
)

# 2) Define incident window (inclusive start, exclusive end) in UTC+8, convert to epoch seconds (UTC)
start_ts = int(pd.Timestamp('2020-05-24 01:30:00', tz=tz).tz_convert('UTC').timestamp())
end_ts   = int(pd.Timestamp('2020-05-24 02:00:00', tz=tz).tz_convert('UTC').timestamp())

# 3) Filter metric series to the incident window (no thresholds recalculated here)
df_win = df_metric[(df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] < end_ts)].copy()

# 4) Join window points with global thresholds
df_join = df_win.merge(global_thresh, on=['cmdb_id', 'kpi_name'], how='left', validate='m:1')

# Drop rows where thresholds are missing (safety)
df_join = df_join.dropna(subset=['p95_value', 'p05_value'])

# 5) Detect anomalies: upper if value >= p95, lower if value <= p05
df_join['is_upper'] = df_join['value'] >= df_join['p95_value']
df_join['is_lower'] = df_join['value'] <= df_join['p05_value']
df_join['is_anom'] = df_join['is_upper'] | df_join['is_lower']

# 6) Compute relative deviation per row (safe denom to avoid division by zero)
eps = 1e-9
# For upper breaches: (value - P95)/P95  (use max(P95, eps) to avoid div zero)
df_join['rel_dev_upper'] = (df_join['value'] - df_join['p95_value']) / df_join['p95_value'].replace(0, eps)
# For lower breaches: (P05 - value)/max(P05, eps)
df_join['rel_dev_lower'] = (df_join['p05_value'] - df_join['value']) / df_join['p05_value'].replace(0, eps)
# For non-breaches, set rel dev to NaN
df_join.loc[~df_join['is_upper'], 'rel_dev_upper'] = np.nan
df_join.loc[~df_join['is_lower'], 'rel_dev_lower'] = np.nan
# Combined per-row relative deviation: choose rel_dev_upper if upper else rel_dev_lower if lower
df_join['rel_dev'] = df_join['rel_dev_upper'].fillna(df_join['rel_dev_lower'])

# 7) Aggregate per (cmdb_id, kpi_name) for those with at least one anomaly
agg = (
    df_join[df_join['is_anom']]
    .groupby(['cmdb_id', 'kpi_name'])
    .agg(
        point_count_in_window = ('timestamp', 'size'),
        anomaly_count = ('is_anom', 'sum'),
        earliest_anomaly_ts = ('timestamp', 'min'),
        all_upper = ('is_upper', 'all'),
        all_lower = ('is_lower', 'all'),
        max_rel_dev = ('rel_dev', 'max')
    )
    .reset_index()
)

# 8) Determine anomaly_type per group
def _atype(row):
    if row['all_upper'] and not row['all_lower']:
        return 'upper'
    if row['all_lower'] and not row['all_upper']:
        return 'lower'
    return 'both'

agg['anomaly_type'] = agg.apply(_atype, axis=1)

# Convert earliest_anomaly_ts to UTC+8 timestamp string for compactness
agg['earliest_anomaly_timestamp'] = pd.to_datetime(agg['earliest_anomaly_ts'], unit='s', utc=True).dt.tz_convert(tz)

# Select and order requested columns
result = agg[['cmdb_id', 'kpi_name', 'point_count_in_window', 'anomaly_count',
              'earliest_anomaly_timestamp', 'anomaly_type', 'max_rel_dev']].copy()

# Clean formatting: round max_rel_dev to 6 decimals
result['max_relative_deviation'] = result['max_rel_dev'].round(6)
result = result.drop(columns=['max_rel_dev'])

# 9) Filter only pairs with anomaly_count > 0 (should already be) and sort by anomaly_count desc
result_sorted = result.sort_values(['anomaly_count', 'max_relative_deviation'], ascending=[False, False]).reset_index(drop=True)

# 10) Top 20 rows and total number of anomalous pairs
top20_anomalies = result_sorted.head(20)
total_anomalous_pairs = result_sorted.shape[0]

# Compact display variables
top20_anomalies, total_anomalous_pairs
