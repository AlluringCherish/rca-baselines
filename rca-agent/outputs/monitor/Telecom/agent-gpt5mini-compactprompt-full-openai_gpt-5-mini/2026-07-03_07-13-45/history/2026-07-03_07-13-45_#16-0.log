import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Load CSVs
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')

# --- metric.csv summaries ---
metric_count = df_metric.shape[0]
metric_unique_cmdb = pd.Series(df_metric['cmdb_id'].unique(), name='cmdb_id')

metric_top_kpis = (
    df_metric['kpi_name']
    .value_counts()
    .head(20)
    .reset_index()
    .rename(columns={'index': 'kpi_name', 'kpi_name': 'count'})
)

metric_min_ts = df_metric['timestamp'].min()
metric_max_ts = df_metric['timestamp'].max()
metric_min_dt = pd.to_datetime(metric_min_ts, unit='s', utc=True).tz_convert(tz)
metric_max_dt = pd.to_datetime(metric_max_ts, unit='s', utc=True).tz_convert(tz)

metric_sample = df_metric.head(5).copy()
metric_sample['ts_utc8'] = pd.to_datetime(metric_sample['timestamp'], unit='s', utc=True).tz_convert(tz)
metric_sample = metric_sample[['timestamp', 'ts_utc8', 'cmdb_id', 'kpi_name', 'value']]

# --- trace.csv summaries ---
trace_count = df_trace.shape[0]
trace_unique_cmdb = pd.Series(df_trace['cmdb_id'].unique(), name='cmdb_id')

trace_top_names = (
    df_trace['trace_name']
    .value_counts()
    .head(20)
    .reset_index()
    .rename(columns={'index': 'trace_name', 'trace_name': 'count'})
)

trace_min_ts = df_trace['timestamp'].min()
trace_max_ts = df_trace['timestamp'].max()
trace_min_dt = pd.to_datetime(trace_min_ts, unit='s', utc=True).tz_convert(tz)
trace_max_dt = pd.to_datetime(trace_max_ts, unit='s', utc=True).tz_convert(tz)

trace_sample = df_trace.head(5).copy()
trace_sample['ts_utc8'] = pd.to_datetime(trace_sample['timestamp'], unit='s', utc=True).tz_convert(tz)
trace_sample = trace_sample[['timestamp', 'ts_utc8', 'cmdb_id', 'trace_name', 'value']]

# Display compact summaries (variables separated by commas for IPython output)
metric_count, metric_unique_cmdb, metric_top_kpis, metric_min_dt, metric_max_dt, metric_sample, trace_count, trace_unique_cmdb, trace_top_names, trace_min_dt, trace_max_dt, trace_sample
