import pandas as pd

# Reuse df_metric loaded previously
# Compute global P95 and point count per (cmdb_id, kpi_name)
grp = df_metric.groupby(['cmdb_id', 'kpi_name'])['value']
aggregated = grp.agg(p95_value=lambda x: x.quantile(0.95), point_count='size').reset_index()

# Format and sort
aggregated['p95_value'] = aggregated['p95_value'].round(6)
aggregated['point_count'] = aggregated['point_count'].astype(int)
