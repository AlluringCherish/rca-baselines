import pandas as pd
import pytz
from datetime import datetime

# Reuse df_metric if available, otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv("metric.csv")

# Ensure timestamp and value types
df_metric['timestamp'] = df_metric['timestamp'].astype(int)
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

# Define incident window in Asia/Shanghai (UTC+8) and convert to UTC epoch seconds
tz = pytz.timezone('Asia/Shanghai')
start_local = tz.localize(datetime(2020, 4, 11, 5, 30, 0))
end_local = tz.localize(datetime(2020, 4, 11, 6, 0, 0))
start_utc_epoch = int(start_local.astimezone(pytz.utc).timestamp())
end_utc_epoch = int(end_local.astimezone(pytz.utc).timestamp())

# Incident flag column (do not filter; used only for counting)
df_metric['incident_flag'] = ((df_metric['timestamp'] >= start_utc_epoch) & (df_metric['timestamp'] < end_utc_epoch)).astype(int)

# Group and compute aggregations (global percentiles computed on entire series per group)
grp = df_metric.groupby(['cmdb_id', 'kpi_name'])
p95 = grp['value'].quantile(0.95)
p5 = grp['value'].quantile(0.05)
total_count = grp['value'].size()
min_ts = grp['timestamp'].min()
max_ts = grp['timestamp'].max()
incident_count = grp['incident_flag'].sum()

# Combine into a single DataFrame (store full aggregated table for later)
agg_table_full = pd.DataFrame({
    'p95': p95,
    'p5': p5,
    'total_count': total_count,
    'incident_window_count': incident_count,
    'min_ts_epoch': min_ts,
    'max_ts_epoch': max_ts
}).reset_index()

# Convert epoch min/max to Asia/Shanghai localized strings for display
fmt = "%Y-%m-%d %H:%M:%S %Z"
agg_table_full['min_timestamp'] = pd.to_datetime(agg_table_full['min_ts_epoch'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime(fmt)
agg_table_full['max_timestamp'] = pd.to_datetime(agg_table_full['max_ts_epoch'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime(fmt)

# Keep columns order and round percentiles for compactness
agg_table_full['p95'] = agg_table_full['p95'].round(6)
agg_table_full['p5'] = agg_table_full['p5'].round(6)
agg_table_full = agg_table_full[['cmdb_id', 'kpi_name', 'p95', 'p5', 'total_count', 'incident_window_count', 'min_timestamp', 'max_timestamp']]

# Prepare top 20 rows sorted by descending p95 for compact display
agg_top20 = agg_table_full.sort_values('p95', ascending=False).head(20)

# Display the compact top20 result; full aggregated table is stored in `agg_table_full`
agg_top20
