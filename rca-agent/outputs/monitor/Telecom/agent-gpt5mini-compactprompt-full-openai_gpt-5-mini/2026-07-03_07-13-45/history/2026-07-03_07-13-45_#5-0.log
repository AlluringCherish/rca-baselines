import pandas as pd
import pytz
from datetime import datetime

# Reuse existing variables if present
try:
    df_metric
except NameError:
    df_metric = pd.read_csv("metric.csv")

try:
    agg_table_full
except NameError:
    # Recompute global agg_table_full if not present (must compute global p95/p5 before filtering)
    df_metric['timestamp'] = df_metric['timestamp'].astype(int)
    df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')
    grp = df_metric.groupby(['cmdb_id', 'kpi_name'])
    agg_table_full = pd.DataFrame({
        'p95': grp['value'].quantile(0.95),
        'p5': grp['value'].quantile(0.05),
    }).reset_index()

# Ensure timestamp/value types
df_metric['timestamp'] = df_metric['timestamp'].astype(int)
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

# Define incident window in Asia/Shanghai (UTC+8)
tz = pytz.timezone('Asia/Shanghai')
start_local = tz.localize(datetime(2020, 4, 11, 5, 30, 0))
end_local = tz.localize(datetime(2020, 4, 11, 6, 0, 0))
start_utc_epoch = int(start_local.astimezone(pytz.utc).timestamp())
end_utc_epoch = int(end_local.astimezone(pytz.utc).timestamp())

# Filter metric records to incident window [start, end)
df_win = df_metric[(df_metric['timestamp'] >= start_utc_epoch) & (df_metric['timestamp'] < end_utc_epoch)].copy()

# Merge global thresholds (p95/p5) from agg_table_full into windowed records
# Ensure agg_table_full has p95/p5 numeric columns
if 'p95' not in agg_table_full.columns or 'p5' not in agg_table_full.columns:
    # attempt to recover from previously computed agg_table_full structure
    grp = df_metric.groupby(['cmdb_id', 'kpi_name'])
    agg_table_full = pd.DataFrame({
        'p95': grp['value'].quantile(0.95),
        'p5': grp['value'].quantile(0.05),
    }).reset_index()

# Merge
df_win = df_win.merge(agg_table_full[['cmdb_id', 'kpi_name', 'p95', 'p5']], on=['cmdb_id', 'kpi_name'], how='left')

# Mark anomalies: value >= p95 OR value <= p5 (use global thresholds); handle missing thresholds as non-anomaly
df_win['is_anomaly'] = False
mask_has_threshold = df_win['p95'].notna() & df_win['p5'].notna()
df_win.loc[mask_has_threshold, 'is_anomaly'] = ( (df_win.loc[mask_has_threshold,'value'] >= df_win.loc[mask_has_threshold,'p95']) |
                                                (df_win.loc[mask_has_threshold,'value'] <= df_win.loc[mask_has_threshold,'p5']) )

# Aggregate anomalies by (cmdb_id, kpi_name)
agg_funcs = {
    'is_anomaly': 'sum',
    'timestamp': 'count',               # incident_window_count
    'value': ['max','min']
}
grouped = df_win.groupby(['cmdb_id','kpi_name']).agg(agg_funcs)
# flatten multiindex columns
grouped.columns = ['anomaly_count','incident_window_count','max_value_in_window','min_value_in_window']
grouped = grouped.reset_index()

# Earliest anomaly timestamp per group (if any)
anomaly_times = df_win[df_win['is_anomaly']].groupby(['cmdb_id','kpi_name'])['timestamp'].min().reset_index().rename(columns={'timestamp':'earliest_anomaly_ts_epoch'})

# Merge earliest anomaly ts and thresholds (p95/p5)
anomaly_table = grouped.merge(anomaly_times, on=['cmdb_id','kpi_name'], how='left')
anomaly_table = anomaly_table.merge(agg_table_full[['cmdb_id','kpi_name','p95','p5']], on=['cmdb_id','kpi_name'], how='left')

# Format earliest_anomaly_timestamp to Asia/Shanghai strings; keep None/NaN if no anomaly
fmt = "%Y-%m-%d %H:%M:%S %Z"
anomaly_table['earliest_anomaly_timestamp'] = pd.to_datetime(anomaly_table['earliest_anomaly_ts_epoch'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime(fmt)
# If NaT produced 'NaT' strings, replace with empty string / NA for compactness
anomaly_table.loc[anomaly_table['earliest_anomaly_ts_epoch'].isna(), 'earliest_anomaly_timestamp'] = pd.NA

# Round numeric columns for compact display
anomaly_table['p95'] = anomaly_table['p95'].round(6)
anomaly_table['p5'] = anomaly_table['p5'].round(6)
anomaly_table['max_value_in_window'] = anomaly_table['max_value_in_window'].round(6)
anomaly_table['min_value_in_window'] = anomaly_table['min_value_in_window'].round(6)

# Select and order required columns
anomaly_table = anomaly_table[['cmdb_id','kpi_name','anomaly_count','incident_window_count','earliest_anomaly_timestamp','max_value_in_window','min_value_in_window','p95','p5']]

# Sort by anomaly_count descending and keep top 20
anomaly_table = anomaly_table.sort_values('anomaly_count', ascending=False).head(20).reset_index(drop=True)

# Store as variable for later steps (already in anomaly_table)
anomaly_table
