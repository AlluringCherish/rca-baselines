import pandas as pd
import pytz
from datetime import datetime

# Reuse anomaly_table from kernel
try:
    anomaly_table
except NameError:
    raise RuntimeError("anomaly_table not found. Run previous steps to produce anomaly_table.")

tz = pytz.timezone('Asia/Shanghai')
fmt = "%Y-%m-%d %H:%M:%S %Z"

# Parse earliest_anomaly_timestamp strings back to tz-aware datetimes in Asia/Shanghai
def parse_earliest(ts_str):
    if pd.isna(ts_str):
        return pd.NaT
    # Remove trailing timezone token (e.g., " CST") to avoid ambiguous parsing, then localize to Asia/Shanghai
    base = ts_str.rsplit(' ', 1)[0]
    try:
        dt = pd.to_datetime(base, format="%Y-%m-%d %H:%M:%S")
    except Exception:
        # fallback to generic parser
        dt = pd.to_datetime(base)
    return dt.tz_localize(tz)

# Create a working copy with a parsed datetime column
work = anomaly_table.copy()
work['earliest_anom_dt'] = work['earliest_anomaly_timestamp'].apply(parse_earliest)

# Compute per-component aggregations
grouped = work.groupby('cmdb_id')

component_summary = pd.DataFrame({
    'num_kpis_with_anomaly': grouped.apply(lambda g: (g['anomaly_count'] > 0).sum()),
    'total_anomaly_points': grouped['anomaly_count'].sum(),
    'num_kpis_full_window': grouped.apply(lambda g: (g['anomaly_count'] == g['incident_window_count']).sum()),
    'earliest_anomaly_dt': grouped['earliest_anom_dt'].min(),  # min will ignore NaT
    'max_anomaly_fraction': grouped.apply(lambda g: (g['anomaly_count'] / g['incident_window_count'].replace(0, pd.NA)).fillna(0).max())
}).reset_index()

# Format earliest_anomaly_dt back to string with Asia/Shanghai tz for compact display
component_summary['earliest_anomaly_timestamp'] = component_summary['earliest_anomaly_dt'].dt.tz_convert(tz).dt.strftime(fmt)
component_summary.loc[component_summary['earliest_anomaly_dt'].isna(), 'earliest_anomaly_timestamp'] = pd.NA

# Round severity metric for compactness
