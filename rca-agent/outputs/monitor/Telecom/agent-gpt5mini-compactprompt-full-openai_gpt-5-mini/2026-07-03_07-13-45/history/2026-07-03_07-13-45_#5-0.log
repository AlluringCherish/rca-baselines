import pandas as pd
import pytz

# Reuse variable names for efficiency
metric_file = "metric.csv"
trace_file = "trace.csv"
tz_name = 'Asia/Shanghai'  # UTC+8 per requirements

# Load CSVs
df_metric = pd.read_csv(metric_file)
df_trace = pd.read_csv(trace_file)

# Helper to convert epoch seconds to Asia/Shanghai localized string
def ts_range_strings(s):
    # s is a pandas Series of epoch seconds
    if s.empty:
        return None, None
    ts_min = pd.to_datetime(s.min(), unit='s', utc=True).tz_convert(tz_name)
    ts_max = pd.to_datetime(s.max(), unit='s', utc=True).tz_convert(tz_name)
    fmt = "%Y-%m-%d %H:%M:%S %Z"
    return ts_min.strftime(fmt), ts_max.strftime(fmt)

# Metric summaries
metric_row_count = df_metric.shape[0]
metric_unique_cmdb = list(pd.Series(df_metric['cmdb_id'].unique())[:50])
metric_unique_kpi = list(pd.Series(df_metric['kpi_name'].unique())[:50])
metric_min_ts, metric_max_ts = ts_range_strings(df_metric['timestamp'])

metric_summary = pd.DataFrame({
    'row_count': [metric_row_count],
    'unique_cmdb_sample': [metric_unique_cmdb],
    'unique_kpi_sample': [metric_unique_kpi],
    'min_timestamp_ASia/Shanghai': [metric_min_ts],
    'max_timestamp_ASia/Shanghai': [metric_max_ts]
}, index=['metric.csv'])

# Trace summaries
trace_row_count = df_trace.shape[0]
trace_unique_cmdb = list(pd.Series(df_trace['cmdb_id'].unique())[:50])
trace_unique_trace = list(pd.Series(df_trace['trace_name'].unique())[:50])
trace_min_ts, trace_max_ts = ts_range_strings(df_trace['timestamp'])

trace_summary = pd.DataFrame({
    'row_count': [trace_row_count],
    'unique_cmdb_sample': [trace_unique_cmdb],
    'unique_trace_sample': [trace_unique_trace],
    'min_timestamp_ASia/Shanghai': [trace_min_ts],
    'max_timestamp_ASia/Shanghai': [trace_max_ts]
}, index=['trace.csv'])

# Display compact summaries (DataFrames are small)
metric_summary, trace_summary
