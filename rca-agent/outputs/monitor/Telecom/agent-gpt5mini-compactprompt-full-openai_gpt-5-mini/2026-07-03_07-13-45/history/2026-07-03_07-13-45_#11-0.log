import pandas as pd
import pytz

# Reuse metric and trace DataFrames loaded earlier in the kernel
# Aggregate metric.csv by (cmdb_id, kpi_name)
metric_agg_full = (
    metric
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .agg(
        count='count',
        mean='mean',
        p95=lambda s: s.quantile(0.95),
        p5=lambda s: s.quantile(0.05)
    )
)

# Round numeric precision to 6 decimals (keep count as integer)
metric_agg_full[['mean','p95','p5']] = metric_agg_full[['mean','p95','p5']].round(6)

# Top 20 by descending P95
metric_top20 = metric_agg_full.sort_values('p95', ascending=False).head(20)[
    ['cmdb_id','kpi_name','count','mean','p95','p5']
]

# Aggregate trace.csv by (cmdb_id, trace_name)
trace_agg_full = (
    trace
    .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
    .agg(
        count='count',
        mean='mean',
        p95=lambda s: s.quantile(0.95),
        p5=lambda s: s.quantile(0.05)
    )
)

# Round numeric precision to 6 decimals
trace_agg_full[['mean','p95','p5']] = trace_agg_full[['mean','p95','p5']].round(6)

# Top 20 by descending P95
trace_top20 = trace_agg_full.sort_values('p95', ascending=False).head(20)[
    ['cmdb_id','trace_name','count','mean','p95','p5']
]

# Display compact top-20 summaries for metric and trace (full aggregated tables stored in metric_agg_full and trace_agg_full)
metric_top20, trace_top20
