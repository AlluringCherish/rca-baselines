import pandas as pd
import pytz

# Reuse existing DataFrames and aggregated tables from kernel:
# metric, trace, metric_agg_full, trace_agg_full

# Define incident window in Asia/Shanghai (UTC+8)
tz = pytz.timezone('Asia/Shanghai')
start_ts = int(pd.Timestamp('2020-05-23 00:30:00', tz=tz).tz_convert('UTC').timestamp())
end_ts = int(pd.Timestamp('2020-05-23 01:00:00', tz=tz).tz_convert('UTC').timestamp())

# Helper to format epoch seconds to Shanghai timezone string
def fmt_shanghai(ts):
    return pd.to_datetime(ts, unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

# ---------- metric anomalies ----------
# Filter raw points to window
metric_window = metric[(metric['timestamp'] >= start_ts) & (metric['timestamp'] <= end_ts)].copy()

# Merge with global thresholds (metric_agg_full contains p95 and p5)
m = metric_window.merge(
    metric_agg_full[['cmdb_id','kpi_name','p95','p5']],
    on=['cmdb_id','kpi_name'],
    how='left',
    validate='m:1'
)

# Mark anomalies where value >= p95 OR value <= p5
m['is_anom'] = (m['value'] >= m['p95']) | (m['value'] <= m['p5'])

# Points per group in window
points = m.groupby(['cmdb_id','kpi_name'], as_index=False)['value'].agg(points_in_window='count')

# Anomaly counts per group
anoms_count = m.groupby(['cmdb_id','kpi_name'], as_index=False)['is_anom'].sum().rename(columns={'is_anom':'anomaly_count'})

# Max/min within window per group
minmax = m.groupby(['cmdb_id','kpi_name'], as_index=False)['value'].agg(max_value='max', min_value='min')

# For groups with anomalies, find earliest anomaly timestamp and its value
anoms_df = m[m['is_anom']].copy()
if not anoms_df.empty:
    idx_first = anoms_df.groupby(['cmdb_id','kpi_name'])['timestamp'].idxmin()
    first_vals = anoms_df.loc[idx_first, ['cmdb_id','kpi_name','timestamp','value']].rename(
        columns={'timestamp':'earliest_anomaly_timestamp','value':'first_anomaly_value'}
    ).reset_index(drop=True)
else:
    # empty structure
    first_vals = pd.DataFrame(columns=['cmdb_id','kpi_name','earliest_anomaly_timestamp','first_anomaly_value'])

# Assemble summary by joining pieces
metric_anoms = points.merge(anoms_count, on=['cmdb_id','kpi_name'], how='left')
metric_anoms = metric_anoms.merge(minmax, on=['cmdb_id','kpi_name'], how='left')
metric_anoms = metric_anoms.merge(metric_agg_full[['cmdb_id','kpi_name','p95','p5']], on=['cmdb_id','kpi_name'], how='left')
metric_anoms = metric_anoms.merge(first_vals, on=['cmdb_id','kpi_name'], how='left')

# Keep only groups with anomaly_count > 0
metric_anoms = metric_anoms[metric_anoms['anomaly_count'] > 0].copy()

# Compute earliest_anomaly_timestamp_shanghai and severity
metric_anoms['earliest_anomaly_timestamp_shanghai'] = metric_anoms['earliest_anomaly_timestamp'].apply(
    lambda x: fmt_shanghai(int(x)) if pd.notnull(x) else None
)

# Compute severity per instructions (avoid div by zero)
metric_anoms['first_anomaly_value'] = metric_anoms['first_anomaly_value'].astype(float)
metric_anoms['p95'] = metric_anoms['p95'].astype(float)
metric_anoms['p5'] = metric_anoms['p5'].astype(float)

metric_anoms['severity'] = metric_anoms.apply(
    lambda r: max(
        abs(r['first_anomaly_value'] - r['p95']) / max(abs(r['p95']), 1e-9),
        abs(r['first_anomaly_value'] - r['p5']) / max(abs(r['p5']), 1e-9)
    ), axis=1
)

# Round numeric columns to 6 decimals
for c in ['max_value','min_value','p95','p5','first_anomaly_value','severity']:
    if c in metric_anoms.columns:
        metric_anoms[c] = metric_anoms[c].round(6)

# Sort and select top 20
metric_anoms_top20 = metric_anoms.sort_values(['anomaly_count','severity'], ascending=[False,False])[
    ['cmdb_id','kpi_name','points_in_window','anomaly_count','earliest_anomaly_timestamp_shanghai',
     'first_anomaly_value','max_value','min_value','p95','p5','severity']
].head(20)

# ---------- trace anomalies ----------
# Filter raw trace points to window
trace_window = trace[(trace['timestamp'] >= start_ts) & (trace['timestamp'] <= end_ts)].copy()

# Merge with global thresholds (trace_agg_full contains p95 and p5)
t = trace_window.merge(
    trace_agg_full[['cmdb_id','trace_name','p95','p5']],
    on=['cmdb_id','trace_name'],
    how='left',
    validate='m:1'
)

t['is_anom'] = (t['value'] >= t['p95']) | (t['value'] <= t['p5'])

# Points per group in window
t_points = t.groupby(['cmdb_id','trace_name'], as_index=False)['value'].agg(points_in_window='count')

# Anomaly counts per group
t_anoms_count = t.groupby(['cmdb_id','trace_name'], as_index=False)['is_anom'].sum().rename(columns={'is_anom':'anomaly_count'})

# Max/min within window per group
t_minmax = t.groupby(['cmdb_id','trace_name'], as_index=False)['value'].agg(max_value='max', min_value='min')

# Earliest anomaly timestamp and first value
t_anoms_df = t[t['is_anom']].copy()
if not t_anoms_df.empty:
    t_idx_first = t_anoms_df.groupby(['cmdb_id','trace_name'])['timestamp'].idxmin()
    t_first_vals = t_anoms_df.loc[t_idx_first, ['cmdb_id','trace_name','timestamp','value']].rename(
        columns={'timestamp':'earliest_anomaly_timestamp','value':'first_anomaly_value'}
    ).reset_index(drop=True)
else:
    t_first_vals = pd.DataFrame(columns=['cmdb_id','trace_name','earliest_anomaly_timestamp','first_anomaly_value'])

# Assemble trace anomalies
trace_anoms = t_points.merge(t_anoms_count, on=['cmdb_id','trace_name'], how='left')
trace_anoms = trace_anoms.merge(t_minmax, on=['cmdb_id','trace_name'], how='left')
trace_anoms = trace_anoms.merge(trace_agg_full[['cmdb_id','trace_name','p95','p5']], on=['cmdb_id','trace_name'], how='left')
trace_anoms = trace_anoms.merge(t_first_vals, on=['cmdb_id','trace_name'], how='left')

# Keep only groups with anomaly_count > 0
trace_anoms = trace_anoms[trace_anoms['anomaly_count'] > 0].copy()

# Format timestamp and compute severity
trace_anoms['earliest_anomaly_timestamp_shanghai'] = trace_anoms['earliest_anomaly_timestamp'].apply(
    lambda x: fmt_shanghai(int(x)) if pd.notnull(x) else None
)

trace_anoms['first_anomaly_value'] = trace_anoms['first_anomaly_value'].astype(float)
trace_anoms['p95'] = trace_anoms['p95'].astype(float)
trace_anoms['p5'] = trace_anoms['p5'].astype(float)

trace_anoms['severity'] = trace_anoms.apply(
    lambda r: max(
        abs(r['first_anomaly_value'] - r['p95']) / max(abs(r['p95']), 1e-9),
        abs(r['first_anomaly_value'] - r['p5']) / max(abs(r['p5']), 1e-9)
    ), axis=1
)

# Round numeric columns to 6 decimals
for c in ['max_value','min_value','p95','p5','first_anomaly_value','severity']:
    if c in trace_anoms.columns:
        trace_anoms[c] = trace_anoms[c].round(6)

# Sort and select top 20
trace_anoms_top20 = trace_anoms.sort_values(['anomaly_count','severity'], ascending=[False,False])[
    ['cmdb_id','trace_name','points_in_window','anomaly_count','earliest_anomaly_timestamp_shanghai',
     'first_anomaly_value','max_value','min_value','p95','p5','severity']
].head(20)

# Store full anomaly tables in kernel variables metric_anoms and trace_anoms (already defined)
metric_anoms, metric_anoms_top20, trace_anoms, trace_anoms_top20
