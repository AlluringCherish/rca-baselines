import pandas as pd
import pytz

# Load CSVs (reusing variable names if run multiple times in the same kernel)
metric = pd.read_csv('metric.csv')
trace = pd.read_csv('trace.csv')

# Helper to convert epoch seconds to Asia/Shanghai timezone string
def to_shanghai(ts):
    return pd.to_datetime(ts, unit='s', utc=True).tz_convert(pytz.timezone('Asia/Shanghai'))

# Metric file summaries
m_count = metric.shape[0]
m_min_ts = metric['timestamp'].min()
m_max_ts = metric['timestamp'].max()
m_min_ts_sh = to_shanghai(m_min_ts)
m_max_ts_sh = to_shanghai(m_max_ts)
m_cmdb_unique = sorted(metric['cmdb_id'].dropna().unique())
m_kpis_unique = list(metric['kpi_name'].dropna().unique())
m_kpis_preview = m_kpis_unique[:50]

metric_summary = pd.DataFrame([{
    'file': 'metric.csv',
    'row_count': m_count,
    'min_timestamp_shanghai': m_min_ts_sh.strftime('%Y-%m-%d %H:%M:%S %Z'),
    'max_timestamp_shanghai': m_max_ts_sh.strftime('%Y-%m-%d %H:%M:%S %Z'),
    'unique_cmdb_count': len(m_cmdb_unique),
    'unique_cmdb_preview': ','.join(m_cmdb_unique),
    'unique_kpi_count': len(m_kpis_unique),
    'unique_kpi_preview_first_50': ','.join(m_kpis_preview)
}])

# Trace file summaries
t_count = trace.shape[0]
t_min_ts = trace['timestamp'].min()
t_max_ts = trace['timestamp'].max()
t_min_ts_sh = to_shanghai(t_min_ts)
t_max_ts_sh = to_shanghai(t_max_ts)
t_cmdb_unique = sorted(trace['cmdb_id'].dropna().unique())
t_traces_unique = list(trace['trace_name'].dropna().unique())
t_traces_preview = t_traces_unique[:50]

trace_summary = pd.DataFrame([{
    'file': 'trace.csv',
    'row_count': t_count,
    'min_timestamp_shanghai': t_min_ts_sh.strftime('%Y-%m-%d %H:%M:%S %Z'),
    'max_timestamp_shanghai': t_max_ts_sh.strftime('%Y-%m-%d %H:%M:%S %Z'),
    'unique_cmdb_count': len(t_cmdb_unique),
    'unique_cmdb_preview': ','.join(t_cmdb_unique),
    'unique_trace_count': len(t_traces_unique),
    'unique_trace_preview_first_50': ','.join(t_traces_preview)
}])

# Samples: first 3 rows each
metric_sample = metric.head(3)
trace_sample = trace.head(3)

# Display compact summaries and samples (variables separated by commas as required)
metric_summary, metric_sample, trace_summary, trace_sample
