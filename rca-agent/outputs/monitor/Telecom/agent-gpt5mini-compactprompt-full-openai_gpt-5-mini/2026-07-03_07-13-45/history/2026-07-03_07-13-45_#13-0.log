    tz = pytz.timezone('Asia/Shanghai')
    trace['timestamp_dt'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Compute global P95 and P5 per (cmdb_id, trace_name) using the full series (no time filtering)
trace_thresholds = (
    trace.groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
    .agg(global_p95=lambda s: s.quantile(0.95), global_p5=lambda s: s.quantile(0.05))
)

# 2) Filter trace rows to the incident window (inclusive)
start = pd.Timestamp('2020-05-23 01:30:00', tz=tz)
end = pd.Timestamp('2020-05-23 02:00:00', tz=tz)
trace_window = trace[(trace['timestamp_dt'] >= start) & (trace['timestamp_dt'] <= end)].copy()

# 3) Merge thresholds and mark anomalous rows
trace_window = trace_window.merge(trace_thresholds, on=['cmdb_id', 'trace_name'], how='left')
trace_window['is_anom'] = (trace_window['value'] >= trace_window['global_p95']) | (trace_window['value'] <= trace_window['global_p5'])

# Helper to compute longest consecutive anomaly length (in minutes)
def longest_consecutive_minutes(ts_series):
    if ts_series.empty:
        return 0
    s = ts_series.sort_values().reset_index(drop=True)
    diffs = s.diff().dt.total_seconds().div(60).fillna(9999)  # large gap for first
    streak_id = (diffs != 1).cumsum()
    streak_lengths = s.groupby(streak_id).size()
    return int(streak_lengths.max())

# 4) Aggregate per (cmdb_id, trace_name) for series that have anomalies in the window
grouped = trace_window.groupby(['cmdb_id', 'trace_name'], as_index=False)
agg_rows = []
for (cmdb_id, trace_name), grp in grouped:
    anom_count = int(grp['is_anom'].sum())
    if anom_count == 0:
        continue
    anom_ts = grp.loc[grp['is_anom'], 'timestamp_dt']
    earliest_anom = anom_ts.min()
    longest_consec = longest_consecutive_minutes(anom_ts)
    max_val = grp['value'].max()
    min_val = grp['value'].min()
    gp95 = float(grp['global_p95'].iloc[0])
    gp5 = float(grp['global_p5'].iloc[0])
    agg_rows.append({
        'cmdb_id': cmdb_id,
        'trace_name': trace_name,
        'anomaly_count': anom_count,
