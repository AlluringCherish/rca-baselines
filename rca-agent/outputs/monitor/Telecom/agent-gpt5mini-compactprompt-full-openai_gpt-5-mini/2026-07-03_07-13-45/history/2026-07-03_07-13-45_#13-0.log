    anom_ts = grp.loc[grp['is_anom'], 'timestamp_dt']
    earliest_anom = anom_ts.min()
    longest_consec = longest_consecutive_minutes(anom_ts)
    max_val = grp['value'].max()
    min_val = grp['value'].min()
    # thresholds: take unique values from grp (merged)
    gp95 = float(grp['global_p95'].iloc[0])
    gp5 = float(grp['global_p5'].iloc[0])
    agg_rows.append({
