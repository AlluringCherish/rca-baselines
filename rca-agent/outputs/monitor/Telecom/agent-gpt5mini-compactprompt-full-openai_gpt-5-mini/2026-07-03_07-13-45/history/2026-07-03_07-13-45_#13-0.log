import pandas as pd
import pytz

# Reuse existing metric and tz if available; otherwise load metric.csv and set tz
try:
    metric
except NameError:
    metric = pd.read_csv('metric.csv')
    tz = pytz.timezone('Asia/Shanghai')
    metric['timestamp_dt'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')
    metric['timestamp_dt'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Focus on cmdb_id == 'os_022'
os022_full = metric[metric['cmdb_id'] == 'os_022'].copy()

# 1) Compute global P95 and P5 per kpi_name using the full os_022 series (no time filtering)
thresholds_os022 = (
    os022_full.groupby('kpi_name', as_index=False)['value']
    .agg(global_p95=lambda s: s.quantile(0.95), global_p5=lambda s: s.quantile(0.05))
)

# 2) Filter rows to the incident window (inclusive)
start = pd.Timestamp('2020-05-23 01:30:00', tz=tz)
end = pd.Timestamp('2020-05-23 02:00:00', tz=tz)
os022_window = os022_full[(os022_full['timestamp_dt'] >= start) & (os022_full['timestamp_dt'] <= end)].copy()

# 3) We'll mark anomalous rows after merging thresholds into window rows
os022_window = os022_window.merge(thresholds_os022, on='kpi_name', how='left')
os022_window['is_anom'] = (os022_window['value'] >= os022_window['global_p95']) | (os022_window['value'] <= os022_window['global_p5'])

# Helper to compute longest consecutive anomaly length (in minutes)
def longest_consecutive_minutes(ts_series):
    if ts_series.empty:
        return 0
    s = ts_series.sort_values().reset_index(drop=True)
    diffs = s.diff().dt.total_seconds().div(60).fillna(9999)
    streak_id = (diffs != 1).cumsum()
    streak_lengths = s.groupby(streak_id).size()
    return int(streak_lengths.max())

# 4) For each kpi_name produce the requested aggregate. Include kpis that had no points in window.
agg_rows = []
for _, row in thresholds_os022.iterrows():
    kpi = row['kpi_name']
    gp95 = float(row['global_p95'])
    gp5 = float(row['global_p5'])
    grp = os022_window[os022_window['kpi_name'] == kpi]
    count_points = int(len(grp))
    anomaly_count = int(grp['is_anom'].sum()) if count_points > 0 else 0
    if anomaly_count > 0:
        anom_ts = grp.loc[grp['is_anom'], 'timestamp_dt']
        earliest_anom = anom_ts.min()
        earliest_anom_str = earliest_anom.strftime('%Y-%m-%d %H:%M:%S%z')
        longest_consec = longest_consecutive_minutes(anom_ts)
    else:
        earliest_anom_str = pd.NA
        longest_consec = 0
    max_val = float(grp['value'].max()) if count_points > 0 else pd.NA
    min_val = float(grp['value'].min()) if count_points > 0 else pd.NA
    agg_rows.append({
        'kpi_name': kpi,
        'count_points_in_window': count_points,
        'anomaly_count': anomaly_count,
        'earliest_anomaly_timestamp': earliest_anom_str,
        'longest_consecutive_anomaly_length': longest_consec,
        'max_value_in_window': max_val,
        'min_value_in_window': min_val,
        'global_p95': gp95,
        'global_p5': gp5
    })

os022_summary = pd.DataFrame(agg_rows)

# 5) Return all os_022 KPI aggregates (limit to 50 rows). Sort for easier inspection.
os022_summary = os022_summary.sort_values(
    by=['longest_consecutive_anomaly_length', 'anomaly_count'],
    ascending=[False, False]
).reset_index(drop=True).head(50)

# Keep output compact: selected columns only
os022_summary[[
    'kpi_name', 'count_points_in_window', 'anomaly_count', 'earliest_anomaly_timestamp',
    'longest_consecutive_anomaly_length', 'max_value_in_window', 'min_value_in_window',
    'global_p95', 'global_p5'
]]
