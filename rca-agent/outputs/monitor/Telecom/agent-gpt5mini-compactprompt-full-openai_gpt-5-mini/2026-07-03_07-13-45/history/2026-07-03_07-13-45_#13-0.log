import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Load CSVs
metric = pd.read_csv('metric.csv')
trace = pd.read_csv('trace.csv')

# Convert timestamps to timezone-aware datetimes (UTC -> Asia/Shanghai)
metric_ts = pd.to_datetime(metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
trace_ts = pd.to_datetime(trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

metric['timestamp_dt'] = metric_ts
trace['timestamp_dt'] = trace_ts

# Aggregate metric.csv by (cmdb_id, kpi_name)
metrics_agg = (
    metric.groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        count=('value', 'count'),
        earliest=('timestamp_dt', 'min'),
        latest=('timestamp_dt', 'max'),
        p95=('value', lambda s: s.quantile(0.95)),
        p5=('value', lambda s: s.quantile(0.05)),
    )
)

# Format columns and limit to top 20 (sort by count desc for compactness)
metrics_agg['earliest'] = metrics_agg['earliest'].astype(str)
metrics_agg['latest'] = metrics_agg['latest'].astype(str)
metrics_agg = metrics_agg.rename(columns={'kpi_name': 'name'})
metrics_summary = metrics_agg.sort_values('count', ascending=False).head(20)[
    ['cmdb_id', 'name', 'count', 'earliest', 'latest', 'p95', 'p5']
]

# Aggregate trace.csv by (cmdb_id, trace_name)
traces_agg = (
    trace.groupby(['cmdb_id', 'trace_name'], as_index=False)
    .agg(
        count=('value', 'count'),
        earliest=('timestamp_dt', 'min'),
        latest=('timestamp_dt', 'max'),
        p95=('value', lambda s: s.quantile(0.95)),
        p5=('value', lambda s: s.quantile(0.05)),
    )
)

traces_agg['earliest'] = traces_agg['earliest'].astype(str)
traces_agg['latest'] = traces_agg['latest'].astype(str)
traces_agg = traces_agg.rename(columns={'trace_name': 'name'})
traces_summary = traces_agg.sort_values('count', ascending=False).head(20)[
    ['cmdb_id', 'name', 'count', 'earliest', 'latest', 'p95', 'p5']
]

# Display the two compact summaries (IPython will show them)
metrics_summary, traces_summary
