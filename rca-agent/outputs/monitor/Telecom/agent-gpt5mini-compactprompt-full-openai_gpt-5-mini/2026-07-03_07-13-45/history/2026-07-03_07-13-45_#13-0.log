import pandas as pd
import numpy as np
from datetime import datetime
import pytz

# Reuse existing 'metric' and 'tz' if present; otherwise load metric.csv and timezone
try:
    metric
except NameError:
    metric = pd.read_csv('metric.csv')
    metric_ts = pd.to_datetime(metric['timestamp'], unit='s', utc=True).dt.tz_convert(pytz.timezone('Asia/Shanghai'))
    metric['timestamp_dt'] = metric_ts

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# 1) Compute global P95 and P5 per (cmdb_id, kpi_name) using the full series
thresholds = (
    metric.groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .agg(global_p95=lambda s: s.quantile(0.95), global_p5=lambda s: s.quantile(0.05))
)

