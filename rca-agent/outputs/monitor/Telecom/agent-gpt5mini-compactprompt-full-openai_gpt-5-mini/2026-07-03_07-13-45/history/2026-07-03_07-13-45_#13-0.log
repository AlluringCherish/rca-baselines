# 3) Mark anomalous rows by merging thresholds and applying condition
metric_window = metric_window.merge(thresholds, on=['cmdb_id', 'kpi_name'], how='left')
metric_window['is_anom'] = (metric_window['value'] >= metric_window['global_p95']) | (metric_window['value'] <= metric_window['global_p5'])

# Helper to compute longest consecutive anomaly length (in minutes) for a group's anomalous timestamps
def longest_consecutive_minutes(ts_series):
    if ts_series.empty:
        return 0
    s = ts_series.sort_values()
    diffs = s.diff().dt.total_seconds().div(60).fillna(9999)  # large gap for first
    # start a new streak when diff != 1
    streak_id = (diffs != 1).cumsum()
    streak_lengths = s.groupby(streak_id).size()
    return int(streak_lengths.max())

# 4) Aggregate per (cmdb_id, kpi_name)
grouped = metric_window.groupby(['cmdb_id', 'kpi_name'], as_index=False)

agg_rows = []
for (cmdb_id, kpi), grp in grouped:
