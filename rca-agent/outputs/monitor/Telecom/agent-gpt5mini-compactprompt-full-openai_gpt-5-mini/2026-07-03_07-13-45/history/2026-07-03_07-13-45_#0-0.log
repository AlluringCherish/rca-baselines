import pandas as pd
import pytz

# Reuse existing metric_df loaded previously
# Ensure timestamp column is integer
metric_df['timestamp'] = metric_df['timestamp'].astype(int)

# Time window boundaries (inclusive)
start_ts = 1586534400
end_ts = 1586536200

tz = pytz.timezone('Asia/Shanghai')

def analyze_with_quantile(q):
    # 1) global thresholds and full_count (calculated on full series BEFORE window filtering)
    group_global = (
        metric_df
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
        .agg(full_count='count', global_P95=lambda x: x.quantile(q))
    )
    # 2) filter to window
    window_df = metric_df[(metric_df['timestamp'] >= start_ts) & (metric_df['timestamp'] <= end_ts)].copy()
    # 3) window aggregates
    window_agg = (
        window_df
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)
        .agg(window_count=('value','size'), max_value_in_window=('value','max'))
    )
    # Merge global thresholds into window rows to evaluate anomalies
    merged_window = window_df.merge(group_global[['cmdb_id','kpi_name','global_P95']], on=['cmdb_id','kpi_name'], how='left')
    # anomaly rows where value >= threshold
    anomaly_rows = merged_window[merged_window['value'] >= merged_window['global_P95']]
    anomaly_agg = (
        anomaly_rows
        .groupby(['cmdb_id','kpi_name'], as_index=False)
        .agg(anomaly_count=('value','size'), earliest_anomaly_ts=('timestamp','min'))
    )
    # Combine summaries: only include pairs that appear in the window (per spec step 3)
    combined = (
        group_global
        .merge(window_agg, on=['cmdb_id','kpi_name'], how='inner')  # inner => only pairs in window
        .merge(anomaly_agg, on=['cmdb_id','kpi_name'], how='left')
    )
