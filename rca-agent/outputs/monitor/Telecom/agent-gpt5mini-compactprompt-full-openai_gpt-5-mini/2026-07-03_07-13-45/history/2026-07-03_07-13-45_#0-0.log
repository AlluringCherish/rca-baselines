import pandas as pd
import pytz

# Load data (files are in working directory)
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")

# Timezone setup (UTC+8)
tz = pytz.timezone("Asia/Shanghai")

# Helper to convert min/max timestamps to localized ISO strings
def local_time_str(ts):
    # ts may be NaN if empty; handle safely
    if pd.isna(ts):
        return None
    return pd.to_datetime(int(ts), unit="s", utc=True).tz_convert(tz).isoformat()

# Metric file summaries
metric_count = int(metric_df.shape[0])
metric_min_ts = metric_df["timestamp"].min() if "timestamp" in metric_df.columns else None
metric_max_ts = metric_df["timestamp"].max() if "timestamp" in metric_df.columns else None
metric_cmdbs = list(pd.Series(metric_df["cmdb_id"].unique()).head(20))
metric_kpis = list(pd.Series(metric_df["kpi_name"].unique()).head(50))
metric_sample = metric_df.head(5)

# Trace file summaries
trace_count = int(trace_df.shape[0])
trace_min_ts = trace_df["timestamp"].min() if "timestamp" in trace_df.columns else None
trace_max_ts = trace_df["timestamp"].max() if "timestamp" in trace_df.columns else None
trace_cmdbs = list(pd.Series(trace_df["cmdb_id"].unique()).head(20))
trace_names = list(pd.Series(trace_df["trace_name"].unique()).head(50))
trace_sample = trace_df.head(5)

# Compose compact JSON-like summary
result = {
    "metric": {
        "row_count": metric_count,
        "min_timestamp": int(metric_min_ts) if pd.notna(metric_min_ts) else None,
        "max_timestamp": int(metric_max_ts) if pd.notna(metric_max_ts) else None,
        "min_timestamp_local": local_time_str(metric_min_ts),
        "max_timestamp_local": local_time_str(metric_max_ts),
        "cmdb_ids_sample_up_to_20": metric_cmdbs,
        "kpi_names_sample_up_to_50": metric_kpis,
        "sample_first_5_rows": metric_sample,  # DataFrame (compact)
    },
    "trace": {
        "row_count": trace_count,
        "min_timestamp": int(trace_min_ts) if pd.notna(trace_min_ts) else None,
        "max_timestamp": int(trace_max_ts) if pd.notna(trace_max_ts) else None,
        "min_timestamp_local": local_time_str(trace_min_ts),
        "max_timestamp_local": local_time_str(trace_max_ts),
        "cmdb_ids_sample_up_to_20": trace_cmdbs,
        "trace_names_sample_up_to_50": trace_names,
        "sample_first_5_rows": trace_sample,  # DataFrame (compact)
    },
}

# Display the compact summary (as a single variable for IPython)
