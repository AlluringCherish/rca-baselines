# Ensure sorted as required and limit to top 20
top20_table = final.sort_values(by=['anomaly_count','earliest_anomaly_ts'], ascending=[False, True], na_position='last').head(20)

threshold_note = f"Threshold used: P{int(used_q*100)} (global quantile computed from full series before window filter). Total anomaly rows in-window: {int(top20_table['anomaly_count'].sum())}."

