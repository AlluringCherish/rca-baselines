import pandas as pd
import pytz

# Reuse variables from prior steps: trace_df, faults_df
# Ensure trace_df and metric timestamps are correct types
trace_df['timestamp'] = trace_df['timestamp'].astype(int)
tz = pytz.timezone('Asia/Shanghai')

# 1) Extract distinct faulty cmdb_ids from faults_df (recompute if faults_df absent/empty)
if 'faults_df' in globals() and not faults_df.empty:
    faulty_cmdbs = pd.Series(faults_df['cmdb_id'].unique())
else:
    # fallback: recompute faults using previous logic (use P90 as earlier); but prefer not to recompute heavy logic here
    faulty_cmdbs = pd.Series(dtype=object)

# Convert to list for isin checks
faulty_list = list(faulty_cmdbs.head(1000))  # keep all if available

# Window bounds (from previous steps)
start_ts = 1586534400
end_ts = 1586536200

# 1) Global P95 per (cmdb_id, trace_name) using full trace.csv (before window filter)
global_trace_p95 = (
    trace_df
    .groupby(['cmdb_id','trace_name'], as_index=False)['value']
    .agg(global_P95=lambda x: x.quantile(0.95))
)

# 2) Filter trace.csv to the incident window
trace_window = trace_df[(trace_df['timestamp'] >= start_ts) & (trace_df['timestamp'] <= end_ts)].copy()

# 3) Restrict to rows where cmdb_id is one of the faulty cmdb_ids
trace_window_faulty = trace_window[trace_window['cmdb_id'].isin(faulty_list)].copy()

# 4) For each (cmdb_id, trace_name) within window compute window_row_count, window_max_value, earliest_ts_of_window_max
if not trace_window_faulty.empty:
    window_agg = (
        trace_window_faulty
        .groupby(['cmdb_id','trace_name'], as_index=False)
        .agg(window_row_count=('value','size'), window_max_value=('value','max'))
    )
    # find earliest timestamp when value == window_max_value
    merged_for_ts = trace_window_faulty.merge(window_agg, on=['cmdb_id','trace_name'], how='left')
    max_rows = merged_for_ts[merged_for_ts['value'] == merged_for_ts['window_max_value']]
    earliest_ts = (
        max_rows
        .groupby(['cmdb_id','trace_name'], as_index=False)
        .agg(earliest_ts_of_window_max=('timestamp','min'))
    )
    # combine
    window_summary = window_agg.merge(earliest_ts, on=['cmdb_id','trace_name'], how='left')
else:
    window_summary = pd.DataFrame(columns=['cmdb_id','trace_name','window_row_count','window_max_value','earliest_ts_of_window_max'])

# 4 cont) merge with global P95 thresholds (computed on full series)
combined = window_summary.merge(global_trace_p95, on=['cmdb_id','trace_name'], how='left')

# compute severity_ratio and mark anomalous if window_max_value > global_P95
def compute_severity(row):
    mv = row['window_max_value']
    gp = row['global_P95']
    if pd.isna(mv) or pd.isna(gp):
        return 0.0
    if mv == 0:
        return 0.0
    return (mv - gp) / mv

if not combined.empty:
    combined['severity_ratio'] = combined.apply(compute_severity, axis=1)
    combined['is_anomalous'] = combined['window_max_value'] > combined['global_P95']
else:
    combined['severity_ratio'] = pd.Series(dtype=float)
    combined['is_anomalous'] = pd.Series(dtype=bool)

# 5) Produce compact table of anomalous trace rows (limit top 20) sorted by severity_ratio desc then earliest_ts asc
anomalies = combined[combined['is_anomalous'] == True].copy()
# convert earliest_ts to localized ISO strings
def to_local_iso(x):
    if pd.isna(x):
        return None
    return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).isoformat()

if not anomalies.empty:
    anomalies['earliest_ts_of_window_max'] = anomalies['earliest_ts_of_window_max'].apply(to_local_iso)
    anomalies_sorted = anomalies.sort_values(by=['severity_ratio','earliest_ts_of_window_max'], ascending=[False, True], na_position='last')
    top20_anomalies = anomalies_sorted[['cmdb_id','trace_name','global_P95','window_row_count','window_max_value','earliest_ts_of_window_max','severity_ratio']].head(20)
else:
    # empty DataFrame with desired columns
    top20_anomalies = pd.DataFrame(columns=['cmdb_id','trace_name','global_P95','window_row_count','window_max_value','earliest_ts_of_window_max','severity_ratio'])

# 6) Summary counts: number of distinct faulty cmdb_ids that have >=1 anomalous trace in the window, list up to 10
if not anomalies.empty:
    anomalous_components = anomalies['cmdb_id'].unique()
    anomalous_components_count = int(len(anomalous_components))
    anomalous_components_list = list(pd.Series(anomalous_components).head(10))
else:
    anomalous_components_count = 0
    anomalous_components_list = []

summary_note = (
    "Analysis: global P95 computed on full trace.csv before window filter; "
    "window restricted to 2020-04-11 00:00–00:30 (UTC+8); "
    f"restricted to {len(faulty_list)} faulty cmdb_ids from metric faults."
)

# Display compact outputs (variable names for IPython)
top20_anomalies, anomalous_components_count, anomalous_components_list, summary_note
