import pandas as pd
import pytz
from itertools import count

# Reuse metric_df from previous steps; ensure correct dtypes
metric_df['timestamp'] = metric_df['timestamp'].astype(int)
tz = pytz.timezone('Asia/Shanghai')

# Window bounds
start_ts = 1586534400
end_ts = 1586536200

# Helper to compute faults given quantile q (0.95 or 0.90)
def compute_faults(q):
    # 1) compute global threshold per pair using full series (before window filter)
    global_th = (
        metric_df
        .groupby(['cmdb_id','kpi_name'], as_index=False)['value']
        .agg(full_count='count', global_thresh=lambda x: x.quantile(q))
    )
    # 2) filter to window
    window_df = metric_df[(metric_df['timestamp'] >= start_ts) & (metric_df['timestamp'] <= end_ts)].copy()
    # Merge global threshold into window rows
    window_df = window_df.merge(global_th, on=['cmdb_id','kpi_name'], how='left')
    # We'll collect fault records in a list
    faults = []
    # Process per (cmdb_id,kpi_name)
    grp = window_df.groupby(['cmdb_id','kpi_name'], sort=False)
    for (cmdb, kpi), g in grp:
        # sort by timestamp
        g = g.sort_values('timestamp')
        thresh = float(g['global_thresh'].iloc[0]) if pd.notna(g['global_thresh'].iloc[0]) else None
        if thresh is None:
            continue
        # 1) anomalous rows: strict >
        anom = g[g['value'] > thresh].copy()
        if anom.empty:
            continue
        # 2) find consecutive anomalous runs by timestamp gaps == 60
        anom = anom.sort_values('timestamp')
        anom['ts_diff'] = anom['timestamp'].diff().fillna(60).astype(int)
        # start new run when ts_diff != 60
        anom['run_id'] = (anom['ts_diff'] != 60).cumsum()
        # 3) keep runs with length >= 3
        run_groups = anom.groupby('run_id', sort=False)
        for rid, rg in run_groups:
            duration = int(rg.shape[0])
            if duration < 3:
                continue
            max_val = float(rg['value'].max())
            # safety exclude runs where max_value_in_run <= global_thresh
            if max_val <= thresh:
                continue
            start_run_ts = int(rg['timestamp'].min())
            end_run_ts = int(rg['timestamp'].max())
            severity = (max_val - thresh) / max_val if max_val > 0 else 0.0
            faults.append({
                'cmdb_id': cmdb,
                'kpi_name': kpi,
                'fault_start_ts': start_run_ts,
                'fault_end_ts': end_run_ts,
                'duration_minutes': duration,
                'max_value_in_run': max_val,
                'global_thresh': thresh,
                'severity': severity
            })
    if not faults:
        return pd.DataFrame(columns=['cmdb_id','kpi_name','fault_start_ts','fault_end_ts','duration_minutes','max_value_in_run','global_thresh','severity'])
    faults_df = pd.DataFrame(faults)
    # Convert timestamps to localized ISO strings for display
    def to_local_iso(x):
        return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).isoformat()
    faults_df['fault_start_ts'] = faults_df['fault_start_ts'].apply(to_local_iso)
    faults_df['fault_end_ts'] = faults_df['fault_end_ts'].apply(to_local_iso)
    return faults_df

# Try P95 first
faults_p95 = compute_faults(0.95)
used_q = 0.95
if faults_p95.shape[0] == 0:
    # fallback to P90 if no runs meet criteria
    faults_p90 = compute_faults(0.90)
    faults_df = faults_p90
    used_q = 0.90
else:
    faults_df = faults_p95

# Prepare final top-20 table sorted by duration_minutes desc then severity desc
if not faults_df.empty:
    faults_df['duration_minutes'] = faults_df['duration_minutes'].astype(int)
    faults_df['severity'] = faults_df['severity'].astype(float)
    top20_faults = faults_df.sort_values(by=['duration_minutes','severity'], ascending=[False, False]).head(20)
    # Count distinct components with at least one fault
    distinct_components_with_fault = top20_faults['cmdb_id'].nunique()  # count within top20
    # But user requested count of how many distinct components have at least one fault (across all runs)
    # compute that from full faults_df
    distinct_components_all = faults_df['cmdb_id'].nunique()
else:
    top20_faults = faults_df  # empty
    distinct_components_with_fault = 0
    distinct_components_all = 0

note = f"Threshold used: P{int(used_q*100)} (global quantile computed from full series before window filter)."

# Display compact results: top20_faults (selected columns) and counts
# Ensure column names match requested: global_P95 label expected; keep name global_P95 if used_q==0.95 else global_P90
col_name = 'global_P95' if used_q==0.95 else 'global_P90'
top20_display = top20_faults.rename(columns={'global_thresh': col_name})[
    ['cmdb_id','kpi_name','fault_start_ts','fault_end_ts','duration_minutes','max_value_in_run',col_name,'severity']
]

top20_display, distinct_components_all, note
