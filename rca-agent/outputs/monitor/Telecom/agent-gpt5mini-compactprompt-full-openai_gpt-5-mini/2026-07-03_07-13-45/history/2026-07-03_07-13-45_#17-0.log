import pandas as pd
import numpy as np
import pytz

# reuse existing timezone variable if present, otherwise define
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Reuse metric_df and metric_agg from kernel state
# If they are not present, load metric.csv and recompute metric_agg (defensive)
try:
    metric_df
    metric_agg
except NameError:
    metric_df = pd.read_csv("metric.csv")
    metric_df['timestamp'] = pd.to_numeric(metric_df['timestamp'], errors='coerce').astype('Int64')
    def agg_quantiles(df, group_cols, value_col='value'):
        g = df.groupby(group_cols, observed=True)[value_col]
        agg = g.agg(
            count='count',
            min_value='min',
            p50=lambda x: x.quantile(0.5),
            p95=lambda x: x.quantile(0.95),
            max_value='max'
        ).reset_index()
        ts = df.groupby(group_cols, observed=True)['timestamp'].agg(min_timestamp='min', max_timestamp='max').reset_index()
        agg = agg.merge(ts, on=group_cols)
        return agg
    metric_agg = agg_quantiles(metric_df, ['cmdb_id', 'kpi_name'], 'value')

# 1) Define window bounds in UTC epoch seconds (convert from UTC+8 datetimes)
start_ts = int(pd.Timestamp('2020-05-24 03:00:00', tz=tz).tz_convert('UTC').timestamp())
end_ts   = int(pd.Timestamp('2020-05-24 03:30:00', tz=tz).tz_convert('UTC').timestamp())

# 1) Filter metric rows within the inclusive window
metric_window_rows = metric_df[
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts)
][['timestamp', 'cmdb_id', 'kpi_name', 'value']].copy()

# 2) Attach global p95 per (cmdb_id, kpi_name) from metric_agg (which was computed on full series)
# Ensure metric_agg has p95 column; if not, compute quantile
if 'p95' not in metric_agg.columns:
    # compute p95 from metric_agg creation fallback
    full_p95 = metric_df.groupby(['cmdb_id','kpi_name'], observed=True)['value'].quantile(0.95).reset_index().rename(columns={'value':'p95'})
    metric_agg = metric_agg.merge(full_p95, on=['cmdb_id','kpi_name'], how='left')

# Merge p95 into window rows
metric_window_with_p95 = metric_window_rows.merge(
    metric_agg[['cmdb_id','kpi_name','p95']],
    on=['cmdb_id','kpi_name'],
    how='left'
)

# 2) Identify anomaly rows where value >= group P95
# Drop rows where p95 is missing (no global group info)
metric_anomaly_rows = metric_window_with_p95.dropna(subset=['p95'])
