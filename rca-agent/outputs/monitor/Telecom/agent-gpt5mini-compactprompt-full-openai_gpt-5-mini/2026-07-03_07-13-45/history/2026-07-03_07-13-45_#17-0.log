    trace_agg = g.agg(
        count='count',
        min_value='min',
        p50=lambda x: x.quantile(0.5),
        p95=lambda x: x.quantile(0.95),
        max_value='max'
    ).reset_index()
    ts = trace_df.groupby(['cmdb_id','trace_name'], observed=True)['timestamp'].agg(min_timestamp='min', max_timestamp='max').reset_index()
