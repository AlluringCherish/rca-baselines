import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Load CSVs
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")

# Ensure timestamp numeric
metric_df['timestamp'] = pd.to_numeric(metric_df['timestamp'], errors='coerce').astype('Int64')
trace_df['timestamp'] = pd.to_numeric(trace_df['timestamp'], errors='coerce').astype('Int64')

# Overall min/max timestamps per file (as timezone-aware datetimes in UTC+8)
metric_min_ts = pd.to_datetime(metric_df['timestamp'].min(), unit='s', utc=True).tz_convert(tz)
metric_max_ts = pd.to_datetime(metric_df['timestamp'].max(), unit='s', utc=True).tz_convert(tz)
trace_min_ts = pd.to_datetime(trace_df['timestamp'].min(), unit='s', utc=True).tz_convert(tz)
trace_max_ts = pd.to_datetime(trace_df['timestamp'].max(), unit='s', utc=True).tz_convert(tz)

# Aggregation helper for quantiles
def agg_quantiles(df, group_cols, value_col='value'):
    g = df.groupby(group_cols, observed=True)[value_col]
    agg = g.agg(
        count='count',
        min_value='min',
        p50=lambda x: x.quantile(0.5),
        p95=lambda x: x.quantile(0.95),
        max_value='max'
    ).reset_index()
    # Attach min/max timestamps per group
    ts = df.groupby(group_cols, observed=True)['timestamp'].agg(min_timestamp='min', max_timestamp='max').reset_index()
    agg = agg.merge(ts, on=group_cols)
    # Convert timestamps to timezone-aware datetimes (UTC+8)
    agg['min_timestamp'] = pd.to_datetime(agg['min_timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    agg['max_timestamp'] = pd.to_datetime(agg['max_timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    return agg

# Metric aggregation by (cmdb_id, kpi_name)
metric_agg = agg_quantiles(metric_df, ['cmdb_id', 'kpi_name'], 'value')
metric_agg = metric_agg.sort_values(by='count', ascending=False).reset_index(drop=True)
metric_agg_top = metric_agg.head(50)

# Trace aggregation by (cmdb_id, trace_name)
trace_agg = agg_quantiles(trace_df, ['cmdb_id', 'trace_name'], 'value')
trace_agg = trace_agg.sort_values(by='count', ascending=False).reset_index(drop=True)
trace_agg_top = trace_agg.head(50)

# Compact timestamp ranges as single-row DataFrames for display
metric_ts_range = pd.DataFrame({
    'file': ['metric.csv'],
    'min_timestamp_UTC+8': [metric_min_ts],
    'max_timestamp_UTC+8': [metric_max_ts]
})
trace_ts_range = pd.DataFrame({
    'file': ['trace.csv'],
    'min_timestamp_UTC+8': [trace_min_ts],
    'max_timestamp_UTC+8': [trace_max_ts]
})

# Display outputs (variables only)
metric_agg_top, trace_agg_top, metric_ts_range, trace_ts_range
