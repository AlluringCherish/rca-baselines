import pandas as pd
import pytz

# timezone for UTC+8
tz = pytz.timezone('Asia/Shanghai')

# Load CSVs (files are in current working directory)
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')

# Ensure timestamp numeric
df_metric['timestamp'] = pd.to_numeric(df_metric['timestamp'], errors='coerce').astype('Int64')
df_trace['timestamp'] = pd.to_numeric(df_trace['timestamp'], errors='coerce').astype('Int64')

# Convert timestamps to timezone-aware datetimes (UTC -> convert to Asia/Shanghai)
df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Aggregation helper for metric
metric_grp = df_metric.groupby(['cmdb_id', 'kpi_name'], dropna=False)
metric_agg = metric_grp.agg(
    count=('value', 'count'),
    min_ts=('ts', 'min'),
    max_ts=('ts', 'max'),
    mean_value=('value', 'mean'),
    p95_value=('value', lambda x: x.quantile(0.95))
).reset_index()

# Format numeric columns for compactness
metric_agg['mean_value'] = metric_agg['mean_value'].round(6)
metric_agg['p95_value'] = metric_agg['p95_value'].round(6)

# Sort by count desc and limit to top 50
metric_agg_sorted = metric_agg.sort_values('count', ascending=False).head(50)

# Total row count of metric.csv
metric_total_rows = int(df_metric.shape[0])

# Aggregation helper for trace
trace_grp = df_trace.groupby(['cmdb_id', 'trace_name'], dropna=False)
trace_agg = trace_grp.agg(
    count=('value', 'count'),
    min_ts=('ts', 'min'),
    max_ts=('ts', 'max'),
    mean_value=('value', 'mean'),
    p95_value=('value', lambda x: x.quantile(0.95))
).reset_index()

# Format numeric columns for compactness
trace_agg['mean_value'] = trace_agg['mean_value'].round(6)
trace_agg['p95_value'] = trace_agg['p95_value'].round(6)

# Sort by count desc and limit to top 50
trace_agg_sorted = trace_agg.sort_values('count', ascending=False).head(50)

# Total row count of trace.csv
trace_total_rows = int(df_trace.shape[0])

# Final compact outputs: top aggregates and totals
metric_agg_sorted, metric_total_rows, trace_agg_sorted, trace_total_rows
