# Reuse existing variables: df_window, metric_agg_sorted
import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Ensure df_window exists (filtered window). If not, recreate from df_metric using same window.
# (We assume df_window exists from prior steps as per conversation.)
# 1) Attach global P95 from metric_agg_sorted to df_window
df_win_p95 = df_window.merge(
    metric_agg_sorted[['cmdb_id', 'kpi_name', 'p95_value']],
    on=['cmdb_id', 'kpi_name'],
    how='inner'
).copy()

# 1) Sort points by timestamp and mark anomalous points (value >= global p95)
df_win_p95 = df_win_p95.sort_values(['cmdb_id', 'kpi_name', 'ts'])
df_win_p95['is_anomaly'] = df_win_p95['value'] >= df_win_p95['p95_value']

# 2) Filter only anomalous points and group consecutive minutes into runs
df_anom = df_win_p95[df_win_p95['is_anomaly']].sort_values(['cmdb_id', 'kpi_name', 'ts']).copy()

def assign_runs(sub):
    # sub is sorted by ts
    diffs = sub['ts'].diff().dt.total_seconds().fillna(9999)
    # new run when diff is not exactly 60 seconds (non-consecutive minute)
    new_run = diffs != 60
    sub['run_id'] = new_run.cumsum()  # run ids start from 1 within group
    return sub

if not df_anom.empty:
    df_anom = df_anom.groupby(['cmdb_id', 'kpi_name'], group_keys=False).apply(assign_runs).reset_index(drop=True)

# 2) Aggregate runs
if df_anom.empty:
    run_agg = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','run_id','run_start_ts','run_end_ts','run_length_minutes',
        'anomaly_count','max_value_in_run','mean_value_in_run','global_p95'
    ])
else:
    run_agg = df_anom.groupby(['cmdb_id', 'kpi_name', 'run_id'], as_index=False).agg(
        run_start_ts=('ts', 'min'),
        run_end_ts=('ts', 'max'),
        anomaly_count=('value', 'count'),
        max_value_in_run=('value', 'max'),
        mean_value_in_run=('value', 'mean'),
        global_p95=('p95_value', 'first')
    )
    run_agg['run_length_minutes'] = run_agg['anomaly_count']  # 1 point per minute
    # compute breaches
    run_agg['absolute_breach'] = run_agg['max_value_in_run'] - run_agg['global_p95']
    # avoid division by zero: denom = max(|global_p95|,1e-9)
    run_agg['relative_breach'] = run_agg['absolute_breach'] / run_agg['global_p95'].abs().clip(lower=1e-9)

# 3) Exclude runs of length 1 and relative_breach <= 0.50
total_fault_runs_found = int(run_agg.shape[0])
if run_agg.empty:
    run_filtered = run_agg.copy()
else:
    run_filtered = run_agg[(run_agg['run_length_minutes'] > 1) & (run_agg['relative_breach'] > 0.5)].copy()

total_fault_runs_after_filter = int(run_filtered.shape[0])

if run_filtered.empty:
    earliest_fault_start_ts = None
else:
    earliest_fault_start_ts = run_filtered['run_start_ts'].min()

# 4) Prepare compact output table sorted by relative_breach desc then run_start_ts asc, top 20
if not run_filtered.empty:
    run_filtered['mean_value_in_run'] = run_filtered['mean_value_in_run'].round(6)
    run_filtered['max_value_in_run'] = run_filtered['max_value_in_run'].round(6)
    run_filtered['global_p95'] = run_filtered['global_p95'].round(6)
    run_filtered['absolute_breach'] = run_filtered['absolute_breach'].round(6)
    run_filtered['relative_breach'] = run_filtered['relative_breach'].round(6)
    faults_top20 = run_filtered.sort_values(['relative_breach', 'run_start_ts'], ascending=[False, True]).head(20).reset_index(drop=True)
    # select compact columns
    faults_top20 = faults_top20[[
        'cmdb_id','kpi_name','run_start_ts','run_end_ts','run_length_minutes','anomaly_count',
        'max_value_in_run','mean_value_in_run','global_p95','absolute_breach','relative_breach'
    ]]
else:
    faults_top20 = run_filtered  # empty

# Expose compact outputs; keep full intermediates in memory: df_win_p95, df_anom, run_agg, run_filtered
faults_top20, total_fault_runs_found, total_fault_runs_after_filter, earliest_fault_start_ts
