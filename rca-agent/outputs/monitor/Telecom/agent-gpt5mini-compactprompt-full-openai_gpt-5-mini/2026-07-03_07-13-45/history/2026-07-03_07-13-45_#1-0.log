import pandas as pd
import pytz

# reuse existing variables: df_metric, metric_agg_sorted
tz = pytz.timezone('Asia/Shanghai')

# 1) Define window (UTC+8) and filter df_metric
start = pd.Timestamp('2020-04-11 01:30:00').tz_localize(tz)
end = pd.Timestamp('2020-04-11 02:00:00').tz_localize(tz)  # inclusive as dataset uses
df_window = df_metric[(df_metric['ts'] >= start) & (df_metric['ts'] <= end)].copy()

# 2) Keep only (cmdb_id, kpi_name) present in metric_agg_sorted and attach global p95
keys = metric_agg_sorted[['cmdb_id', 'kpi_name', 'p95_value']].drop_duplicates()
df_window_keyed = df_window.merge(keys, on=['cmdb_id', 'kpi_name'], how='inner')

# Mark anomaly if value >= global p95 (global p95 assumed precomputed in metric_agg_sorted)
df_window_keyed['is_anomaly'] = df_window_keyed['value'] >= df_window_keyed['p95_value']

# 3) Compute per-component-KPI aggregates for those with at least one anomaly
# Aggregates from anomalous points
anomalies_df = df_window_keyed[df_window_keyed['is_anomaly']].copy()
if anomalies_df.empty:
    anomalies_agg = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','anomaly_count','earliest_anomaly_ts','latest_anomaly_ts'
    ])
else:
    anomalies_agg = anomalies_df.groupby(['cmdb_id','kpi_name'], as_index=False).agg(
        anomaly_count=('is_anomaly','sum'),
        earliest_anomaly_ts=('ts','min'),
        latest_anomaly_ts=('ts','max')
    )

# Aggregates for full window per KPI (needed for max and mean in window and carry global_p95)
window_stats = df_window_keyed.groupby(['cmdb_id','kpi_name'], as_index=False).agg(
    max_value_in_window=('value','max'),
    mean_value_in_window=('value','mean'),
    global_p95=('p95_value','first')
)

# Join anomalies_agg with window_stats, keep only KPIs that had anomalies
if anomalies_agg.empty:
    result_df = anomalies_agg  # empty
else:
    result_df = anomalies_agg.merge(window_stats, on=['cmdb_id','kpi_name'], how='left')

# Formatting: round numeric columns and keep compact column order
if not result_df.empty:
    result_df['mean_value_in_window'] = result_df['mean_value_in_window'].round(6)
    result_df['max_value_in_window'] = result_df['max_value_in_window'].round(6)
    result_df['global_p95'] = result_df['global_p95'].round(6)
    result_df = result_df[[
        'cmdb_id','kpi_name','anomaly_count','earliest_anomaly_ts','latest_anomaly_ts',
        'max_value_in_window','mean_value_in_window','global_p95'
    ]]

# 4) Top 20 by anomaly_count and two scalar totals
if result_df.empty:
    top20 = result_df.head(20)
    total_anomalous_points = 0
    total_affected_component_kpis = 0
else:
    top20 = result_df.sort_values('anomaly_count', ascending=False).head(20).reset_index(drop=True)
    total_anomalous_points = int(result_df['anomaly_count'].sum())
    total_affected_component_kpis = int((result_df['anomaly_count'] > 0).sum())

# Expose compact outputs (variables). Full intermediate tables are kept in memory:
# df_window, df_window_keyed, anomalies_df, anomalies_agg, window_stats, result_df
top20, total_anomalous_points, total_affected_component_kpis
