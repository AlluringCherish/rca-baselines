start = pd.Timestamp('2020-04-11 01:30:00').tz_localize(tz)
end = pd.Timestamp('2020-04-11 02:00:00').tz_localize(tz)

# 1) Filter metric rows for os_004 within the window
df_os004 = df_metric[(df_metric['cmdb_id'] == 'os_004') & (df_metric['ts'] >= start) & (df_metric['ts'] <= end)].copy()

# 2) Attach global P95 from metric_agg_sorted (precomputed global thresholds)
p95_map = metric_agg_sorted[['cmdb_id', 'kpi_name', 'p95_value']].drop_duplicates()
df_os004 = df_os004.merge(p95_map, on=['cmdb_id', 'kpi_name'], how='left')

# Mark anomaly only when global p95 is available; otherwise treat as non-anomalous (cannot judge)
df_os004['is_anomaly'] = False
mask_p95_present = df_os004['p95_value'].notna()
df_os004.loc[mask_p95_present, 'is_anomaly'] = df_os004.loc[mask_p95_present, 'value'] >= df_os004.loc[mask_p95_present, 'p95_value']

# 3) Per-kpi aggregates within window
if df_os004.empty:
    os004_agg = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','count','min_ts','max_ts',
        'mean_value_in_window','max_value_in_window','any_anomaly','global_p95'
    ])
else:
    grp = df_os004.groupby(['cmdb_id','kpi_name'], as_index=False)
    os004_agg = grp.agg(
        count=('value','count'),
        min_ts=('ts','min'),
        max_ts=('ts','max'),
        mean_value_in_window=('value','mean'),
        max_value_in_window=('value','max'),
        any_anomaly=('is_anomaly','any'),
        global_p95=('p95_value','first')
    )
    # Format numeric columns compactly
    os004_agg['mean_value_in_window'] = os004_agg['mean_value_in_window'].round(6)
    os004_agg['max_value_in_window'] = os004_agg['max_value_in_window'].round(6)
    os004_agg['global_p95'] = os004_agg['global_p95'].round(6)

# 4) Sort by max_value_in_window desc and limit to 50 rows
os004_agg_sorted = os004_agg.sort_values('max_value_in_window', ascending=False).head(50).reset_index(drop=True)

# 5) Scalars: number of KPIs with anomalies and list of KPI names with anomalies (up to 20)
if os004_agg_sorted.empty:
    number_of_os_004_kpis_with_anomalies = 0
    list_of_kpis_with_anomalies = []
else:
    kpis_with_anom = os004_agg_sorted[os004_agg_sorted['any_anomaly']]['kpi_name'].tolist()
    number_of_os_004_kpis_with_anomalies = len(kpis_with_anom)
    list_of_kpis_with_anomalies = kpis_with_anom[:20]

# Compact outputs (DataFrame + two scalars)
os004_agg_sorted, number_of_os_004_kpis_with_anomalies, list_of_kpis_with_anomalies
