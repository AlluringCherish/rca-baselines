import pandas as pd
import numpy as np
import pytz

# Load CSVs
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")

# Convert timestamp to timezone-aware datetime in UTC+8 (Asia/Shanghai)
tz = pytz.timezone("Asia/Shanghai")
metric_df["dt"] = pd.to_datetime(metric_df["timestamp"], unit="s", utc=True).dt.tz_convert(tz)
trace_df["dt"] = pd.to_datetime(trace_df["timestamp"], unit="s", utc=True).dt.tz_convert(tz)

# Aggregation function for value
agg_funcs = {
    "value": [
        ("count", "count"),
        ("mean", "mean"),
        ("p95", lambda x: x.quantile(0.95)),
        ("p50", "median"),
        ("p05", lambda x: x.quantile(0.05)),
        ("min", "min"),
        ("max", "max"),
    ]
}

# Aggregate metric.csv by (cmdb_id, kpi_name)
metric_grp = (
    metric_df.groupby(["cmdb_id", "kpi_name"])["value"]
    .agg(
        count="count",
        mean="mean",
        p95=lambda x: x.quantile(0.95),
        p50="median",
        p05=lambda x: x.quantile(0.05),
        min="min",
        max="max",
    )
    .reset_index()
)

# Aggregate trace.csv by (cmdb_id, trace_name)
trace_grp = (
    trace_df.groupby(["cmdb_id", "trace_name"])["value"]
    .agg(
        count="count",
        mean="mean",
        p95=lambda x: x.quantile(0.95),
        p50="median",
        p05=lambda x: x.quantile(0.05),
        min="min",
        max="max",
    )
    .reset_index()
)

# Sort by count desc and limit to top 50 rows
metric_agg_top = metric_grp.sort_values("count", ascending=False).head(50)
trace_agg_top = trace_grp.sort_values("count", ascending=False).head(50)

# Round numeric columns for compact display
num_cols = ["mean", "p95", "p50", "p05", "min", "max"]
metric_agg_top[num_cols] = metric_agg_top[num_cols].round(6)
trace_agg_top[num_cols] = trace_agg_top[num_cols].round(6)

# Unique lists: cmdb_id (union of both files), kpi_name (from metric), trace_name (from trace)
unique_cmdb = pd.Series(sorted(pd.unique(pd.concat([metric_df["cmdb_id"], trace_df["cmdb_id"]]))), name="cmdb_id")
unique_kpi = pd.Series(sorted(metric_df["kpi_name"].unique()), name="kpi_name")
unique_trace = pd.Series(sorted(trace_df["trace_name"].unique()), name="trace_name")

# Display compact results (variables returned)
metric_agg_top, trace_agg_top, unique_cmdb, unique_kpi, unique_trace
