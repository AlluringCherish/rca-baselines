import pandas as pd
import numpy as np
import pytz
from datetime import datetime

# Reuse existing variables if present, else load CSVs
try:
    metric_df
    trace_df
except NameError:
    metric_df = pd.read_csv("metric.csv")
    trace_df = pd.read_csv("trace.csv")

# Ensure timestamp->datetime in UTC+8 (Asia/Shanghai) for both dataframes (store as 'dt')
tz = pytz.timezone("Asia/Shanghai")
metric_df["dt"] = pd.to_datetime(metric_df["timestamp"], unit="s", utc=True).dt.tz_convert(tz)
trace_df["dt"] = pd.to_datetime(trace_df["timestamp"], unit="s", utc=True).dt.tz_convert(tz)

# 1) metric_global: global stats across full series (per cmdb_id, kpi_name)
metric_global = (
    metric_df.groupby(["cmdb_id", "kpi_name"])["value"]
    .agg(
        count_all="count",
        mean="mean",
        p95=lambda x: x.quantile(0.95),
        p05=lambda x: x.quantile(0.05),
        min="min",
        max="max",
    )
    .reset_index()
)

# 2) trace_global: same for traces
trace_global = (
    trace_df.groupby(["cmdb_id", "trace_name"])["value"]
    .agg(
        count_all="count",
        mean="mean",
        p95=lambda x: x.quantile(0.95),
        p05=lambda x: x.quantile(0.05),
        min="min",
        max="max",
    )
    .reset_index()
)

# 3) Filter to incident time window: May 23, 2020 03:30 to 04:00 in UTC+8 (inclusive)
start_local = tz.localize(datetime(2020, 5, 23, 3, 30, 0))
end_local = tz.localize(datetime(2020, 5, 23, 4, 0, 0))

metric_in_window = metric_df[(metric_df["dt"] >= start_local) & (metric_df["dt"] <= end_local)].copy()
trace_in_window = trace_df[(trace_df["dt"] >= start_local) & (trace_df["dt"] <= end_local)].copy()

# 4) For each (cmdb_id, kpi_name) compute count_in_window, earliest and latest timestamps in window
metric_window_groups = (
    metric_in_window.groupby(["cmdb_id", "kpi_name"])
    .agg(
        count_in_window=("value", "count"),
        earliest_timestamp_in_window=("dt", "min"),
        latest_timestamp_in_window=("dt", "max"),
    )
    .reset_index()
)

# Merge with metric_global (keep global stats) and select requested columns
metric_window_summary = (
    metric_global.merge(metric_window_groups, on=["cmdb_id", "kpi_name"], how="left")
    .fillna({"count_in_window": 0, "earliest_timestamp_in_window": pd.NaT, "latest_timestamp_in_window": pd.NaT})
)

# Keep columns in requested order and round numeric columns for compactness
metric_window_summary = metric_window_summary[
    [
        "cmdb_id",
        "kpi_name",
        "count_all",
        "mean",
        "p95",
        "p05",
        "count_in_window",
        "earliest_timestamp_in_window",
        "latest_timestamp_in_window",
    ]
]

metric_window_summary[["mean", "p95", "p05"]] = metric_window_summary[["mean", "p95", "p05"]].round(6)

# Sort by count_in_window desc and keep top 20
metric_window_summary_top20 = metric_window_summary.sort_values("count_in_window", ascending=False).head(20)

# 5) For traces: same steps
trace_window_groups = (
    trace_in_window.groupby(["cmdb_id", "trace_name"])
    .agg(
        count_in_window=("value", "count"),
        earliest_timestamp_in_window=("dt", "min"),
        latest_timestamp_in_window=("dt", "max"),
    )
    .reset_index()
)

trace_window_summary = (
    trace_global.merge(trace_window_groups, on=["cmdb_id", "trace_name"], how="left")
    .fillna({"count_in_window": 0, "earliest_timestamp_in_window": pd.NaT, "latest_timestamp_in_window": pd.NaT})
)

trace_window_summary = trace_window_summary[
    [
        "cmdb_id",
        "trace_name",
        "count_all",
        "mean",
        "p95",
        "p05",
        "count_in_window",
        "earliest_timestamp_in_window",
        "latest_timestamp_in_window",
    ]
]

trace_window_summary[["mean", "p95", "p05"]] = trace_window_summary[["mean", "p95", "p05"]].round(6)

trace_window_summary_top20 = trace_window_summary.sort_values("count_in_window", ascending=False).head(20)

# 6) Overall counts: number of groups with at least one point in window
metric_groups_in_window_count = int((metric_window_summary["count_in_window"] > 0).sum())
trace_groups_in_window_count = int((trace_window_summary["count_in_window"] > 0).sum())

# Keep full intermediate tables in variables (metric_global, trace_global, metric_in_window, trace_in_window, metric_window_summary, trace_window_summary)
# Display compact outputs: top20 summaries and the overall counts
metric_window_summary_top20, trace_window_summary_top20, metric_groups_in_window_count, trace_groups_in_window_count
