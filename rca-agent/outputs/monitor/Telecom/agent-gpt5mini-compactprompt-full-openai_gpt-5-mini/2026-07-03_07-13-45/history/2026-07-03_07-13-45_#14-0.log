import pandas as pd
import pytz
from datetime import datetime

# Reuse existing variables if available; otherwise load and compute required globals
tz = pytz.timezone("Asia/Shanghai")

try:
    metric_df
    trace_df
except NameError:
    metric_df = pd.read_csv("metric.csv")
    trace_df = pd.read_csv("trace.csv")

# Ensure dt column exists and is timezone-aware (UTC+8)
if "dt" not in metric_df.columns:
    metric_df["dt"] = pd.to_datetime(metric_df["timestamp"], unit="s", utc=True).dt.tz_convert(tz)
if "dt" not in trace_df.columns:
    trace_df["dt"] = pd.to_datetime(trace_df["timestamp"], unit="s", utc=True).dt.tz_convert(tz)

# Ensure metric_global and trace_global (global p95/p05 computed on full series) exist
try:
    metric_global
except NameError:
    metric_global = (
        metric_df.groupby(["cmdb_id", "kpi_name"])["value"]
        .agg(
            count_all="count",
            mean="mean",
            p95=lambda x: x.quantile(0.95),
            p05=lambda x: x.quantile(0.05),
            min="min",
            max="max",
        )
        .reset_index()
    )

try:
    trace_global
except NameError:
    trace_global = (
        trace_df.groupby(["cmdb_id", "trace_name"])["value"]
        .agg(
            count_all="count",
            mean="mean",
            p95=lambda x: x.quantile(0.95),
            p05=lambda x: x.quantile(0.05),
            min="min",
            max="max",
        )
        .reset_index()
    )

# Incident window (inclusive) in UTC+8
start_local = tz.localize(datetime(2020, 5, 23, 3, 30, 0))
end_local = tz.localize(datetime(2020, 5, 23, 4, 0, 0))

# Filter to window
metric_in_window = metric_df[(metric_df["dt"] >= start_local) & (metric_df["dt"] <= end_local)].copy()
trace_in_window = trace_df[(trace_df["dt"] >= start_local) & (trace_df["dt"] <= end_local)].copy()

# ---- Metrics: compute anomaly counts per group using global p95/p05 ----
# Join global thresholds onto in-window rows
metric_win_with_thresh = metric_in_window.merge(
    metric_global[["cmdb_id", "kpi_name", "p95", "p05", "count_all", "mean"]],
    on=["cmdb_id", "kpi_name"],
    how="left",
    validate="m:1",
)

# Flags and earliest anomaly timestamp column
metric_win_with_thresh["is_high"] = metric_win_with_thresh["value"] > metric_win_with_thresh["p95"]
metric_win_with_thresh["is_low"] = metric_win_with_thresh["value"] < metric_win_with_thresh["p05"]
metric_win_with_thresh["is_anom"] = metric_win_with_thresh["is_high"] | metric_win_with_thresh["is_low"]
metric_win_with_thresh["dt_anom"] = metric_win_with_thresh["dt"].where(metric_win_with_thresh["is_anom"], pd.NaT)

# Aggregate per group in-window
metric_anom_agg = (
    metric_win_with_thresh.groupby(["cmdb_id", "kpi_name"])
    .agg(
        count_in_window=("value", "count"),
        anom_high=("is_high", "sum"),
        anom_low=("is_low", "sum"),
        earliest_anom_timestamp=("dt_anom", "min"),
    )
    .reset_index()
)

# Merge with global stats to form final summary (keep requested columns)
metric_anom_summary = (
    metric_global[["cmdb_id", "kpi_name", "count_all", "mean", "p95", "p05"]]
    .merge(metric_anom_agg, on=["cmdb_id", "kpi_name"], how="left")
    .fillna({"count_in_window": 0, "anom_high": 0, "anom_low": 0, "earliest_anom_timestamp": pd.NaT})
)

# Ensure integer counts
metric_anom_summary["count_in_window"] = metric_anom_summary["count_in_window"].astype(int)
metric_anom_summary["anom_high"] = metric_anom_summary["anom_high"].astype(int)
metric_anom_summary["anom_low"] = metric_anom_summary["anom_low"].astype(int)

# Round numeric thresholds/mean for compact display
metric_anom_summary[["mean", "p95", "p05"]] = metric_anom_summary[["mean", "p95", "p05"]].round(6)

# Add total anomalies column for sorting
metric_anom_summary["total_anom"] = metric_anom_summary["anom_high"] + metric_anom_summary["anom_low"]

# Select groups that had at least one point in window (as required)
metric_anom_with_points = metric_anom_summary[metric_anom_summary["count_in_window"] > 0].copy()

# Top 20 by total anomalies desc
metric_anom_top20 = metric_anom_with_points.sort_values(["total_anom", "count_in_window"], ascending=[False, False]).head(20)

# Keep only requested output columns (compact)
metric_anom_top20 = metric_anom_top20[
    ["cmdb_id", "kpi_name", "count_all", "mean", "p95", "p05", "count_in_window", "anom_high", "anom_low", "earliest_anom_timestamp"]
]

# ---- Traces: same process ----
trace_win_with_thresh = trace_in_window.merge(
    trace_global[["cmdb_id", "trace_name", "p95", "p05", "count_all", "mean"]],
    on=["cmdb_id", "trace_name"],
    how="left",
    validate="m:1",
)

trace_win_with_thresh["is_high"] = trace_win_with_thresh["value"] > trace_win_with_thresh["p95"]
trace_win_with_thresh["is_low"] = trace_win_with_thresh["value"] < trace_win_with_thresh["p05"]
trace_win_with_thresh["is_anom"] = trace_win_with_thresh["is_high"] | trace_win_with_thresh["is_low"]
trace_win_with_thresh["dt_anom"] = trace_win_with_thresh["dt"].where(trace_win_with_thresh["is_anom"], pd.NaT)

trace_anom_agg = (
    trace_win_with_thresh.groupby(["cmdb_id", "trace_name"])
    .agg(
        count_in_window=("value", "count"),
        anom_high=("is_high", "sum"),
        anom_low=("is_low", "sum"),
        earliest_anom_timestamp=("dt_anom", "min"),
    )
    .reset_index()
)

trace_anom_summary = (
    trace_global[["cmdb_id", "trace_name", "count_all", "mean", "p95", "p05"]]
    .merge(trace_anom_agg, on=["cmdb_id", "trace_name"], how="left")
    .fillna({"count_in_window": 0, "anom_high": 0, "anom_low": 0, "earliest_anom_timestamp": pd.NaT})
)

trace_anom_summary["count_in_window"] = trace_anom_summary["count_in_window"].astype(int)
trace_anom_summary["anom_high"] = trace_anom_summary["anom_high"].astype(int)
trace_anom_summary["anom_low"] = trace_anom_summary["anom_low"].astype(int)
trace_anom_summary[["mean", "p95", "p05"]] = trace_anom_summary[["mean", "p95", "p05"]].round(6)
trace_anom_summary["total_anom"] = trace_anom_summary["anom_high"] + trace_anom_summary["anom_low"]

trace_anom_with_points = trace_anom_summary[trace_anom_summary["count_in_window"] > 0].copy()
trace_anom_top20 = trace_anom_with_points.sort_values(["total_anom", "count_in_window"], ascending=[False, False]).head(20)

trace_anom_top20 = trace_anom_top20[
    ["cmdb_id", "trace_name", "count_all", "mean", "p95", "p05", "count_in_window", "anom_high", "anom_low", "earliest_anom_timestamp"]
]

# Scalars: number of groups with any anomaly (anom_high+anom_low > 0)
metric_groups_with_anom_count = int((metric_anom_with_points["anom_high"] + metric_anom_with_points["anom_low"] > 0).sum())
trace_groups_with_anom_count = int((trace_anom_with_points["anom_high"] + trace_anom_with_points["anom_low"] > 0).sum())

# Store full intermediate tables in kernel variables for later steps
metric_anom_summary_full = metric_anom_summary
trace_anom_summary_full = trace_anom_summary

# Compact outputs (top20 tables and two scalars)
metric_anom_top20, trace_anom_top20, metric_groups_with_anom_count, trace_groups_with_anom_count
