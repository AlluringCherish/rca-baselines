        .agg(count_in_window=("value", "count"),
             earliest_timestamp_in_window=("dt", "min"),
             latest_timestamp_in_window=("dt", "max"))
        .reset_index()
    )

    metric_summary = metric_global.merge(metric_window_groups, on=["cmdb_id", "kpi_name"], how="left").fillna({"count_in_window":0})
