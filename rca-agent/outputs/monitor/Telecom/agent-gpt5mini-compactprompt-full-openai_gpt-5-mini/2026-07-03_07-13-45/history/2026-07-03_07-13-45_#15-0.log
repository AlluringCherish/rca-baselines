2026-07-03 07:15:26,959 | DEBUG | Raw Code:
import pandas as pd
import pytz
import numpy as np

# Reuse df_metric and tz if present; otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure numeric and correct dtypes
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')
df_metric['timestamp'] = pd.to_numeric(df_metric['timestamp'], errors='coerce').astype('Int64')

# 1) Compute global quantiles (P5, P50, P90, P95) per (cmdb_id, kpi_name) using full series
quantiles = df_metric.groupby(['cmdb_id', 'kpi_name'])['value'].quantile([0.05, 0.5, 0.9, 0.95]).unstack(level=-1)
quantiles = quantiles.rename(columns={0.05: 'global_P5', 0.5: 'global_P50', 0.9: 'global_P90', 0.95: 'global_P95'}).reset_index()

# 2) Filter to incident window: May 23, 2020 04:30:00 to 05:00:00 UTC+8
start_ts = int(pd.Timestamp('2020-05-23 04:30:00', tz=tz).astimezone(pytz.UTC).timestamp())
end_ts = int(pd.Timestamp('2020-05-23 05:00:00', tz=tz).astimezone(pytz.UTC).timestamp())
df_window = df_metric[(df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] <= end_ts)].copy()

# 3) Join global thresholds into windowed data
df_win_with_q = df_window.merge(quantiles, on=['cmdb_id', 'kpi_name'], how='left')

# Define anomaly condition using P95/P5
df_win_with_q['is_anomaly'] = False
mask_valid = df_win_with_q['value'].notna() & df_win_with_q['global_P95'].notna() & df_win_with_q['global_P5'].notna()
df_win_with_q.loc[mask_valid, 'is_anomaly'] = (
    (df_win_with_q.loc[mask_valid, 'value'] >= df_win_with_q.loc[mask_valid, 'global_P95']) |
    (df_win_with_q.loc[mask_valid, 'value'] <= df_win_with_q.loc[mask_valid, 'global_P5'])
)

# Aggregations per (cmdb_id, kpi_name)
grp = df_win_with_q.groupby(['cmdb_id', 'kpi_name'])
agg_pairs = grp.agg(
    total_points_in_window = ('value', 'count'),
    max_value_in_window = ('value', 'max'),
    min_value_in_window = ('value', 'min'),
    anomaly_count = ('is_anomaly', 'sum')
).reset_index()

# earliest_anomaly_timestamp per pair
earliest = df_win_with_q[df_win_with_q['is_anomaly']].groupby(['cmdb_id','kpi_name'])['timestamp'].min().reset_index().rename(columns={'timestamp':'earliest_anomaly_timestamp'})
# Merge earliest timestamps
agg_pairs = agg_pairs.merge(quantiles[['cmdb_id','kpi_name','global_P95','global_P5']], on=['cmdb_id','kpi_name'], how='left')
agg_pairs = agg_pairs.merge(earliest, on=['cmdb_id','kpi_name'], how='left')

# Ensure numeric types and compact columns; convert earliest timestamp to nullable Int64
agg_pairs['earliest_anomaly_timestamp'] = agg_pairs['earliest_anomaly_timestamp'].astype('Int64')

# 4A) Top 20 pairs sorted by anomaly_count descending
top20_pairs = agg_pairs.sort_values(by=['anomaly_count','total_points_in_window'], ascending=[False, False]) \
                      [['cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp','total_points_in_window','max_value_in_window','min_value_in_window','global_P95','global_P5']].head(20)

# 4B) Per-component summary for components starting with db_, docker_, os_
# Sum anomaly_count per cmdb_id and earliest among its KPIs
components_mask = agg_pairs['cmdb_id'].str.startswith(('db_','docker_','os_'))
comp_agg = agg_pairs[components_mask].groupby('cmdb_id').agg(
    total_anomaly_count = ('anomaly_count','sum'),
    earliest_anomaly_timestamp = ('earliest_anomaly_timestamp','min')
).reset_index()
comp_agg['earliest_anomaly_timestamp'] = comp_agg['earliest_anomaly_timestamp'].astype('Int64')
comp_top20 = comp_agg.sort_values(by=['total_anomaly_count','earliest_anomaly_timestamp'], ascending=[False, True]).head(20)

# 5) If no anomalies found in top results (i.e., total anomaly_count == 0 across window), compute relaxed P90 rule
total_anomalies = int(agg_pairs['anomaly_count'].sum())
relaxed_top20_pairs = None
relaxed_comp_top20 = None
if total_anomalies == 0:
    # relaxed rule: value >= global_P90
    df_win_with_q['is_anomaly_relaxed'] = False
    mask_valid_r = df_win_with_q['value'].notna() & df_win_with_q['global_P90'].notna()
    df_win_with_q.loc[mask_valid_r, 'is_anomaly_relaxed'] = (df_win_with_q.loc[mask_valid_r, 'value'] >= df_win_with_q.loc[mask_valid_r, 'global_P90'])
    grp_r = df_win_with_q.groupby(['cmdb_id','kpi_name'])
    agg_pairs_r = grp_r.agg(
        total_points_in_window = ('value','count'),
        max_value_in_window = ('value','max'),
        min_value_in_window = ('value','min'),
        anomaly_count = ('is_anomaly_relaxed','sum')
    ).reset_index()
    earliest_r = df_win_with_q[df_win_with_q['is_anomaly_relaxed']].groupby(['cmdb_id','kpi_name'])['timestamp'].min().reset_index().rename(columns={'timestamp':'earliest_anomaly_timestamp'})
    agg_pairs_r = agg_pairs_r.merge(quantiles[['cmdb_id','kpi_name','global_P90','global_P5']], on=['cmdb_id','kpi_name'], how='left')
    agg_pairs_r = agg_pairs_r.merge(earliest_r, on=['cmdb_id','kpi_name'], how='left')
    agg_pairs_r['earliest_anomaly_timestamp'] = agg_pairs_r['earliest_anomaly_timestamp'].astype('Int64')
    relaxed_top20_pairs = agg_pairs_r.sort_values(by=['anomaly_count','total_points_in_window'], ascending=[False, False]) \
                                     [['cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp','total_points_in_window','max_value_in_window','min_value_in_window','global_P90','global_P5']].head(20)
    # component summary for relaxed
    comp_r_mask = agg_pairs_r['cmdb_id'].str.startswith(('db_','docker_','os_'))
    comp_agg_r = agg_pairs_r[comp_r_mask].groupby('cmdb_id').agg(
        total_anomaly_count = ('anomaly_count','sum'),
        earliest_anomaly_timestamp = ('earliest_anomaly_timestamp','min')
    ).reset_index()
    comp_agg_r['earliest_anomaly_timestamp'] = comp_agg_r['earliest_anomaly_timestamp'].astype('Int64')
    relaxed_comp_top20 = comp_agg_r.sort_values(by=['total_anomaly_count','earliest_anomaly_timestamp'], ascending=[False, True]).head(20)

# Final compact outputs (variables to display)
top20_pairs, comp_top20, total_anomalies, relaxed_top20_pairs, relaxed_comp_top20
