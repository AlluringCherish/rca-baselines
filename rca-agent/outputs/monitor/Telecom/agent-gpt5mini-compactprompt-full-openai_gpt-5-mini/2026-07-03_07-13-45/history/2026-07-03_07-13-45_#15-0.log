import pandas as pd
import pytz

# timezone UTC+8
tz = pytz.timezone('Asia/Shanghai')

# Load files (they are in current working directory)
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')

# Ensure numeric 'value'
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')
df_trace['value'] = pd.to_numeric(df_trace['value'], errors='coerce')

# Helper to format timestamp range in UTC+8
def ts_range(df, col='timestamp'):
    if df.empty:
        return {"min": None, "max": None}
    mins = pd.to_datetime(df[col].min(), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z')
    maxs = pd.to_datetime(df[col].max(), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z')
    return {"min": mins, "max": maxs}

# Metric summary
metric_total_rows = len(df_metric)
metric_time_range = ts_range(df_metric, 'timestamp')
metric_unique_cmdb = sorted(df_metric['cmdb_id'].dropna().unique().tolist())

# Top 20 kpi_name by count
metric_top_kpis_counts = df_metric.groupby('kpi_name').size().rename('count').sort_values(ascending=False).head(20)
# Build DataFrame with quantiles for these top KPIs (global across all rows)
metric_top_kpis = (
    metric_top_kpis_counts.reset_index()
    .rename(columns={'index':'kpi_name'})
)
quant_rows = []
for kpi in metric_top_kpis['kpi_name']:
    series = df_metric.loc[df_metric['kpi_name'] == kpi, 'value'].dropna()
    if series.empty:
        p50 = p90 = p95 = None
    else:
        qs = series.quantile([0.5, 0.9, 0.95]).to_dict()
        p50 = float(qs.get(0.5))
        p90 = float(qs.get(0.9))
        p95 = float(qs.get(0.95))
    quant_rows.append((kpi, int(metric_top_kpis_counts.loc[kpi]), p50, p90, p95))
metric_top_kpis_stats = pd.DataFrame(quant_rows, columns=['kpi_name','count','p50','p90','p95']).head(20)

# Trace summary
trace_total_rows = len(df_trace)
trace_time_range = ts_range(df_trace, 'timestamp')
trace_unique_cmdb = sorted(df_trace['cmdb_id'].dropna().unique().tolist())

# Top 20 trace_name by count
trace_top_names_counts = df_trace.groupby('trace_name').size().rename('count').sort_values(ascending=False).head(20)
trace_top_names = trace_top_names_counts.reset_index().rename(columns={'index':'trace_name'})
quant_rows = []
for tname in trace_top_names['trace_name']:
    series = df_trace.loc[df_trace['trace_name'] == tname, 'value'].dropna()
    if series.empty:
        p50 = p90 = p95 = None
    else:
        qs = series.quantile([0.5, 0.9, 0.95]).to_dict()
        p50 = float(qs.get(0.5))
        p90 = float(qs.get(0.9))
        p95 = float(qs.get(0.95))
    quant_rows.append((tname, int(trace_top_names_counts.loc[tname]), p50, p90, p95))
trace_top_stats = pd.DataFrame(quant_rows, columns=['trace_name','count','p50','p90','p95']).head(20)

# Assemble compact JSON/dict-like summary
summary = {
    "metric": {
        "total_rows": int(metric_total_rows),
        "time_range_UTC+8": metric_time_range,
        "unique_cmdb_id": metric_unique_cmdb,
        "top_kpi_stats": metric_top_kpis_stats  # DataFrame (max 20 rows) with kpi_name, count, p50, p90, p95
    },
    "trace": {
        "total_rows": int(trace_total_rows),
        "time_range_UTC+8": trace_time_range,
        "unique_cmdb_id": trace_unique_cmdb,
        "top_trace_stats": trace_top_stats  # DataFrame (max 20 rows) with trace_name, count, p50, p90, p95
    }
}

# Display the compact summary variable (per instructions, use variable name)
summary
