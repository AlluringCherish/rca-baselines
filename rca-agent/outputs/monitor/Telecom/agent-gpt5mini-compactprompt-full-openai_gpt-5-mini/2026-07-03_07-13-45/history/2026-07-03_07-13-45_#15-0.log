import pandas as pd
import pytz
import numpy as np

# Reuse df_trace and tz if present; otherwise load
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure dtypes
df_trace['value'] = pd.to_numeric(df_trace['value'], errors='coerce')
df_trace['timestamp'] = pd.to_numeric(df_trace['timestamp'], errors='coerce').astype('Int64')

# 1) Compute global quantiles per (cmdb_id, trace_name) on full series (P5, P50, P90, P95)
q = df_trace.groupby(['cmdb_id','trace_name'])['value'].quantile([0.05,0.5,0.9,0.95]).unstack(level=-1)
q = q.rename(columns={0.05:'global_P5', 0.5:'global_P50', 0.9:'global_P90', 0.95:'global_P95'}).reset_index()

# 2) Filter to incident window: May 23, 2020 04:30:00 to 05:00:00 UTC+8
start_ts = int(pd.Timestamp('2020-05-23 04:30:00', tz=tz).astimezone(pytz.UTC).timestamp())
end_ts   = int(pd.Timestamp('2020-05-23 05:00:00', tz=tz).astimezone(pytz.UTC).timestamp())
df_win = df_trace[(df_trace['timestamp'] >= start_ts) & (df_trace['timestamp'] <= end_ts)].copy()

# 3) Join global quantiles into windowed data (thresholds computed on full series as required)
dfw = df_win.merge(q, on=['cmdb_id','trace_name'], how='left')

# Determine anomalies using P95/P5 rule
dfw['is_anomaly'] = False
mask_valid = dfw['value'].notna() & dfw['global_P95'].notna() & dfw['global_P5'].notna()
dfw.loc[mask_valid, 'is_anomaly'] = (
    (dfw.loc[mask_valid, 'value'] >= dfw.loc[mask_valid, 'global_P95']) |
    (dfw.loc[mask_valid, 'value'] <= dfw.loc[mask_valid, 'global_P5'])
)

# Aggregations per (cmdb_id, trace_name)
grp = dfw.groupby(['cmdb_id','trace_name'])
agg_pairs_trace = grp.agg(
    total_points_in_window = ('value','count'),
    anomaly_count = ('is_anomaly','sum'),
    max_value_in_window = ('value','max'),
    min_value_in_window = ('value','min')
).reset_index()

# earliest anomaly timestamp per pair
earliest = dfw[dfw['is_anomaly']].groupby(['cmdb_id','trace_name'])['timestamp'].min().reset_index().rename(columns={'timestamp':'earliest_anomaly_timestamp'})
agg_pairs_trace = agg_pairs_trace.merge(q[['cmdb_id','trace_name','global_P95','global_P5']], on=['cmdb_id','trace_name'], how='left')
agg_pairs_trace = agg_pairs_trace.merge(earliest, on=['cmdb_id','trace_name'], how='left')
agg_pairs_trace['earliest_anomaly_timestamp'] = agg_pairs_trace['earliest_anomaly_timestamp'].astype('Int64')

# 4A) Top 20 (cmdb_id, trace_name) by anomaly_count desc
top20_pairs_trace = agg_pairs_trace.sort_values(by=['anomaly_count','total_points_in_window'], ascending=[False,False]) \
    [['cmdb_id','trace_name','anomaly_count','earliest_anomaly_timestamp','total_points_in_window','max_value_in_window','min_value_in_window','global_P95','global_P5']].head(20)

# 4B) Per-component summary for cmdb_ids present in trace.csv
comp_agg_trace = agg_pairs_trace.groupby('cmdb_id').agg(
    total_anomaly_count = ('anomaly_count','sum'),
    earliest_anomaly_timestamp = ('earliest_anomaly_timestamp','min')
).reset_index()
comp_agg_trace['earliest_anomaly_timestamp'] = comp_agg_trace['earliest_anomaly_timestamp'].astype('Int64')
comp_top20_trace = comp_agg_trace.sort_values(by=['total_anomaly_count','earliest_anomaly_timestamp'], ascending=[False,True]).head(20)

# 5) If no anomalies found, perform relaxed P90 test
total_anomalies_trace = int(agg_pairs_trace['anomaly_count'].sum())
relaxed_top20_pairs_trace = None
relaxed_comp_top20_trace = None

if total_anomalies_trace == 0:
    # relaxed: value >= global_P90
    dfw['is_anomaly_relaxed'] = False
    mask_valid_r = dfw['value'].notna() & dfw['global_P90'].notna()
    dfw.loc[mask_valid_r, 'is_anomaly_relaxed'] = (dfw.loc[mask_valid_r, 'value'] >= dfw.loc[mask_valid_r, 'global_P90'])
    grp_r = dfw.groupby(['cmdb_id','trace_name'])
    agg_pairs_r = grp_r.agg(
        total_points_in_window = ('value','count'),
        anomaly_count = ('is_anomaly_relaxed','sum'),
        max_value_in_window = ('value','max'),
        min_value_in_window = ('value','min')
    ).reset_index()
    earliest_r = dfw[dfw['is_anomaly_relaxed']].groupby(['cmdb_id','trace_name'])['timestamp'].min().reset_index().rename(columns={'timestamp':'earliest_anomaly_timestamp'})
    agg_pairs_r = agg_pairs_r.merge(q[['cmdb_id','trace_name','global_P90','global_P5']], on=['cmdb_id','trace_name'], how='left')
    agg_pairs_r = agg_pairs_r.merge(earliest_r, on=['cmdb_id','trace_name'], how='left')
    agg_pairs_r['earliest_anomaly_timestamp'] = agg_pairs_r['earliest_anomaly_timestamp'].astype('Int64')
    relaxed_top20_pairs_trace = agg_pairs_r.sort_values(by=['anomaly_count','total_points_in_window'], ascending=[False,False]) \
        [['cmdb_id','trace_name','anomaly_count','earliest_anomaly_timestamp','total_points_in_window','max_value_in_window','min_value_in_window','global_P90','global_P5']].head(20)
    # component summary for relaxed
    comp_r = agg_pairs_r.groupby('cmdb_id').agg(
        total_anomaly_count = ('anomaly_count','sum'),
        earliest_anomaly_timestamp = ('earliest_anomaly_timestamp','min')
    ).reset_index()
    comp_r['earliest_anomaly_timestamp'] = comp_r['earliest_anomaly_timestamp'].astype('Int64')
    relaxed_comp_top20_trace = comp_r.sort_values(by=['total_anomaly_count','earliest_anomaly_timestamp'], ascending=[False,True]).head(20)

# Final compact outputs (variables to display)
top20_pairs_trace, comp_top20_trace, total_anomalies_trace, relaxed_top20_pairs_trace, relaxed_comp_top20_trace
