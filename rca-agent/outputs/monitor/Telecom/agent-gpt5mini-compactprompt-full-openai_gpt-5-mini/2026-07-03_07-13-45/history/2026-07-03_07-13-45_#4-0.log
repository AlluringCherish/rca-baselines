import pandas as pd
import pytz

# Load CSVs
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')

# Timezone setup (UTC+8)
tz = pytz.timezone('Asia/Shanghai')

# Convert timestamps to timezone-aware datetimes (assume epoch seconds in UTC, then convert to Asia/Shanghai)
df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Metric summaries
metric_count = df_metric.shape[0]
metric_unique_cmdb = pd.Series(sorted(df_metric['cmdb_id'].unique()), name='cmdb_id').head(20)
metric_top_kpis = df_metric['kpi_name'].value_counts().rename_axis('kpi_name').reset_index(name='count').head(20)
metric_ts_min = df_metric['ts'].min()
metric_ts_max = df_metric['ts'].max()

# Trace summaries
trace_count = df_trace.shape[0]
trace_unique_cmdb = pd.Series(sorted(df_trace['cmdb_id'].unique()), name='cmdb_id').head(20)
trace_top_names = df_trace['trace_name'].value_counts().rename_axis('trace_name').reset_index(name='count').head(20)
trace_ts_min = df_trace['ts'].min()
trace_ts_max = df_trace['ts'].max()

# Display compact summaries (IPython will render these variables)
metric_count, metric_unique_cmdb, metric_top_kpis, metric_ts_min, metric_ts_max, trace_count, trace_unique_cmdb, trace_top_names, trace_ts_min, trace_ts_max
