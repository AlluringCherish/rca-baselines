# Compute global P95 per (cmdb_id, trace_name) using entire trace dataframe (reuse df_trace and tz)
p95_trace_df = df_trace.groupby(['cmdb_id', 'trace_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value': 'global_P95'})

# Define incident window in Asia/Shanghai (UTC+8)
start = pd.Timestamp('2020-04-11 04:30:00', tz=tz)
end = pd.Timestamp('2020-04-11 05:00:00', tz=tz)

# Filter trace rows to the window
df_trace_window = df_trace[(df_trace['ts'] >= start) & (df_trace['ts'] <= end)].copy()

# Merge global P95 into windowed rows
df_trace_window = df_trace_window.merge(p95_trace_df, on=['cmdb_id', 'trace_name'], how='left')

# Flag rows above global P95 (strictly greater)
df_trace_window['above'] = df_trace_window['value'] > df_trace_window['global_P95']

# Aggregations per (cmdb_id, trace_name) present in the window
grouped_trace = df_trace_window.groupby(['cmdb_id', 'trace_name'], as_index=False)
agg_trace = grouped_trace.agg(
    count_points_in_window=('value', 'size'),
    count_points_above_P95=('above', 'sum'),
    max_value_in_window=('value', 'max')
)

# Earliest timestamp above P95 (if any)
earliest_trace_above = df_trace_window[df_trace_window['above']].groupby(['cmdb_id', 'trace_name'], as_index=False)['ts'].min().rename(columns={'ts': 'earliest_timestamp_above_P95'})

# Join earliest timestamps and global P95
trace_report = agg_trace.merge(earliest_trace_above, on=['cmdb_id', 'trace_name'], how='left').merge(p95_trace_df, on=['cmdb_id', 'trace_name'], how='left')

# Sort by count_points_above_P95 desc, then count_points_in_window desc
trace_report_sorted = trace_report.sort_values(['count_points_above_P95', 'count_points_in_window'], ascending=[False, False])

# Compact output: select and order columns, limit to top 20
trace_report_top20 = trace_report_sorted[['cmdb_id', 'trace_name', 'global_P95', 'count_points_in_window', 'count_points_above_P95', 'earliest_timestamp_above_P95', 'max_value_in_window']].head(20)

# Additional summaries
num_distinct_trace_with_anomalies = (trace_report['count_points_above_P95'] > 0).sum()
total_trace_rows_in_window = df_trace_window.shape[0]

# Display compact results (IPython will render these variables)
trace_report_top20, num_distinct_trace_with_anomalies, total_trace_rows_in_window
