# Compute global P95 per (cmdb_id, kpi_name) using entire metric dataframe (reuse df_metric and tz)
p95_df = df_metric.groupby(['cmdb_id', 'kpi_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value': 'global_P95'})

# Define incident window in Asia/Shanghai (UTC+8)
start = pd.Timestamp('2020-04-11 04:30:00', tz=tz)
end = pd.Timestamp('2020-04-11 05:00:00', tz=tz)

# Filter metric rows to the window
df_window = df_metric[(df_metric['ts'] >= start) & (df_metric['ts'] <= end)].copy()

# Merge global P95 into windowed rows
df_window = df_window.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# Flag rows above global P95 (strictly greater = "above")
df_window['above'] = df_window['value'] > df_window['global_P95']

# Aggregations per (cmdb_id, kpi_name) present in the window
grouped = df_window.groupby(['cmdb_id', 'kpi_name'], as_index=False)
agg = grouped.agg(
    count_points_in_window=('value', 'size'),
    count_points_above_P95=('above', 'sum'),
    max_value_in_window=('value', 'max')
)

# Earliest timestamp above P95 (if any)
earliest_above = df_window[df_window['above']].groupby(['cmdb_id', 'kpi_name'], as_index=False)['ts'].min().rename(columns={'ts': 'earliest_timestamp_above_P95'})

# Join earliest timestamps and global P95
report = agg.merge(earliest_above, on=['cmdb_id', 'kpi_name'], how='left').merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# Sort by severity (count_points_above_P95 desc) and keep top 20
report_sorted = report.sort_values(['count_points_above_P95', 'count_points_in_window'], ascending=[False, False])

# Compact output: select and order columns, limit to top 20
report_top20 = report_sorted[['cmdb_id', 'kpi_name', 'global_P95', 'count_points_in_window', 'count_points_above_P95', 'earliest_timestamp_above_P95', 'max_value_in_window']].head(20)

# Additional summaries
num_distinct_with_anomalies = (report['count_points_above_P95'] > 0).sum()
total_rows_in_window = df_window.shape[0]

# Display compact results (as required by the environment)
report_top20, num_distinct_with_anomalies, total_rows_in_window
