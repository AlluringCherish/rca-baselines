report_docker = agg_docker.merge(earliest_above_docker, on=['cmdb_id', 'kpi_name'], how='left').merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# Sort by count_points_above_P95 descending, then by count_points_in_window desc
report_docker_sorted = report_docker.sort_values(['count_points_above_P95', 'count_points_in_window'], ascending=[False, False])

# Compact top 20 selection
report_docker_top20 = report_docker_sorted[['cmdb_id', 'kpi_name', 'global_P95', 'count_points_in_window', 'count_points_above_P95', 'earliest_timestamp_above_P95', 'max_value_in_window']].head(20)

# Additional summaries
num_kpis_with_anomalies_docker = (report_docker['count_points_above_P95'] > 0).sum()
total_rows_docker_window = df_docker_window.shape[0]

# Display compact results
report_docker_top20, int(num_kpis_with_anomalies_docker), int(total_rows_docker_window)
