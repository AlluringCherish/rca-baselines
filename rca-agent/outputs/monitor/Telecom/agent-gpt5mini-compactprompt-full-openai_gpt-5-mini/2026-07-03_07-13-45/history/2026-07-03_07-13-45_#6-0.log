import pandas as pd
import numpy as np
import pytz

# Reuse existing variables if present; otherwise load minimally
tz = pytz.timezone('Asia/Shanghai')
try:
    metric
except NameError:
    metric = pd.read_csv("metric.csv")
    metric['ts_utc'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)
    metric['ts_local'] = metric['ts_utc'].dt.tz_convert(tz)

try:
    trace
except NameError:
    trace = pd.read_csv("trace.csv")
    trace['ts_utc'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True)
    trace['ts_local'] = trace['ts_utc'].dt.tz_convert(tz)

# Ensure global P95 tables exist (computed on full series)
if 'metric_p95' not in globals():
    metric_p95 = metric.groupby(['cmdb_id','kpi_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value':'p95_value'})
if 'trace_p95' not in globals():
    trace_p95 = trace.groupby(['cmdb_id','trace_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value':'p95_value'})

# Incident window
window_start = tz.localize(pd.Timestamp('2020-05-22 00:00:00'))
window_end   = tz.localize(pd.Timestamp('2020-05-22 00:30:00'))

metric_window = metric[(metric['ts_local'] >= window_start) & (metric['ts_local'] <= window_end)].copy()
trace_window  = trace[(trace['ts_local']  >= window_start) & (trace['ts_local']  <= window_end)].copy()

def find_consecutive_runs(window_df, p95_df, key_cols, value_col='value', ts_col='ts_local'):
    # Merge p95
    merged = window_df.merge(p95_df, on=key_cols, how='left')
    # Only consider rows with a defined p95 (otherwise cannot compare)
    merged = merged[~merged['p95_value'].isna()].copy()
    if merged.empty:
        return pd.DataFrame(), 0  # no runs at all

    # Determine breach boolean
    merged['is_breach'] = merged[value_col] > merged['p95_value']

    # Keep only breach rows for run detection
    breaches = merged[merged['is_breach']].copy()
    if breaches.empty:
        return pd.DataFrame(), 0

    # Sort for run detection
    breaches = breaches.sort_values(key_cols + [ts_col]).reset_index(drop=True)

    # For each series, compute time difference to previous row in minutes
    def assign_run_ids(df):
        # df is per-series subset already sorted
        df = df.copy()
        df['prev_ts'] = df[ts_col].shift(1)
        # compute gap in minutes; for first row, mark as new run
        df['gap_min'] = ((df[ts_col] - df['prev_ts']).dt.total_seconds() / 60).fillna(np.inf)
        # New run if gap_min != 1
        df['new_run'] = (df['gap_min'] != 1.0).astype(int)
        df['run_id'] = df['new_run'].cumsum()
        return df

    grouped = []
    for keys, group in breaches.groupby(key_cols, sort=False):
        g = assign_run_ids(group)
        # attach series keys back
        grouped.append(g)
    breaches_runs = pd.concat(grouped, ignore_index=True)

    # Now aggregate per series & run_id
    agg_cols = key_cols + ['run_id']
    runs = breaches_runs.groupby(agg_cols, sort=False).agg(
        run_start_timestamp = (ts_col, 'min'),
        run_end_timestamp   = (ts_col, 'max'),
        run_length_minutes  = (ts_col, 'count'),
        max_value_in_run    = (value_col, 'max'),
        p95_value           = ('p95_value', 'first')
    ).reset_index()

    # Compute ratio (handle p95==0)
    runs['max_over_p95_ratio'] = np.where(
        runs['p95_value'] == 0,
        np.where(runs['max_value_in_run'] > 0, np.inf, 0.0),
        runs['max_value_in_run'] / runs['p95_value']
    )

    # Format timestamps as strings (keep timezone info)
    runs['run_start_timestamp'] = runs['run_start_timestamp'].astype(str)
    runs['run_end_timestamp'] = runs['run_end_timestamp'].astype(str)

    # Total runs found
    total_runs = runs.shape[0]

    return runs, total_runs

# 1) Metric runs
metric_runs_all, metric_total_runs = find_consecutive_runs(metric_window, metric_p95, ['cmdb_id','kpi_name'])
if metric_runs_all.empty:
    metric_runs_kept = pd.DataFrame()
    metric_kept_count = 0
    metric_component_counts = pd.DataFrame(columns=['component','kept_runs_count'])
else:
    # Keep runs where run_length_minutes >=2 OR max_over_p95_ratio >=1.5
    metric_runs_kept = metric_runs_all[
        (metric_runs_all['run_length_minutes'] >= 2) | (metric_runs_all['max_over_p95_ratio'] >= 1.5)
    ].copy().reset_index(drop=True)

    metric_kept_count = metric_runs_kept.shape[0]
    # component level extraction
    metric_runs_kept['component'] = metric_runs_kept['cmdb_id'].apply(lambda s: s.split('_')[0] if isinstance(s,str) and '_' in s else s)
    metric_component_counts = metric_runs_kept.groupby('component', sort=False).size().reset_index(name='kept_runs_count').sort_values('kept_runs_count', ascending=False)

    # Sort by severity
    metric_runs_kept = metric_runs_kept.sort_values('max_over_p95_ratio', ascending=False).reset_index(drop=True)

# Limit top20 for display and select columns
if not metric_runs_kept.empty:
    metric_runs_top20 = metric_runs_kept[['cmdb_id','kpi_name','run_start_timestamp','run_end_timestamp','run_length_minutes','max_value_in_run','p95_value','max_over_p95_ratio']].head(20)
else:
    metric_runs_top20 = pd.DataFrame()  # empty

# 2) Trace runs
trace_runs_all, trace_total_runs = find_consecutive_runs(trace_window, trace_p95, ['cmdb_id','trace_name'])
if trace_runs_all.empty:
    trace_runs_kept = pd.DataFrame()
    trace_kept_count = 0
    trace_component_counts = pd.DataFrame(columns=['component','kept_runs_count'])
else:
    trace_runs_kept = trace_runs_all[
        (trace_runs_all['run_length_minutes'] >= 2) | (trace_runs_all['max_over_p95_ratio'] >= 1.5)
    ].copy().reset_index(drop=True)

    trace_kept_count = trace_runs_kept.shape[0]
    trace_runs_kept['component'] = trace_runs_kept['cmdb_id'].apply(lambda s: s.split('_')[0] if isinstance(s,str) and '_' in s else s)
    trace_component_counts = trace_runs_kept.groupby('component', sort=False).size().reset_index(name='kept_runs_count').sort_values('kept_runs_count', ascending=False)

    trace_runs_kept = trace_runs_kept.sort_values('max_over_p95_ratio', ascending=False).reset_index(drop=True)

if not trace_runs_kept.empty:
    trace_runs_top20 = trace_runs_kept[['cmdb_id','trace_name','run_start_timestamp','run_end_timestamp','run_length_minutes','max_value_in_run','p95_value','max_over_p95_ratio']].head(20)
else:
    trace_runs_top20 = pd.DataFrame()

# Compact summary DataFrames
metric_summary_df = pd.DataFrame([{
    'total_runs_found_in_window': int(metric_total_runs),
    'runs_kept_after_filter': int(metric_kept_count)
}])

trace_summary_df = pd.DataFrame([{
    'total_runs_found_in_window': int(trace_total_runs),
    'runs_kept_after_filter': int(trace_kept_count)
}])

# Limit component counts to top 20 for readability
metric_component_counts_top = metric_component_counts.head(20)
trace_component_counts_top = trace_component_counts.head(20)

# Final displayed variables (compact): metric_runs_top20 (or message), metric_summary_df, metric_component_counts_top,
#                                        trace_runs_top20 (or message), trace_summary_df, trace_component_counts_top

# If empty results, replace with explicit message strings to satisfy requirement
if metric_runs_top20.empty:
    metric_display = "No metric runs meet the keep criteria in the window."
else:
    metric_display = metric_runs_top20

if trace_runs_top20.empty:
    trace_display = "No trace runs meet the keep criteria in the window."
else:
    trace_display = trace_runs_top20

metric_display, metric_summary_df, metric_component_counts_top, trace_display, trace_summary_df, trace_component_counts_top
