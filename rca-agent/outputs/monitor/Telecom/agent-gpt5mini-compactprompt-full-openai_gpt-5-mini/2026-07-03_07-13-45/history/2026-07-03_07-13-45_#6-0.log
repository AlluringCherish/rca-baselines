import pandas as pd
import pytz

# Read CSVs
metric = pd.read_csv("metric.csv")
trace = pd.read_csv("trace.csv")

# Convert timestamps to timezone-aware datetimes in Asia/Shanghai (UTC+8)
tz = pytz.timezone('Asia/Shanghai')
metric['ts_utc'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)
metric['ts_local'] = metric['ts_utc'].dt.tz_convert(tz)
trace['ts_utc'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True)
trace['ts_local'] = trace['ts_utc'].dt.tz_convert(tz)

# 1) Rows and min/max timestamp (both raw int and localized)
metric_rows = pd.DataFrame([{
    'file': 'metric.csv',
    'rows': len(metric),
    'min_timestamp': int(metric['timestamp'].min()) if not metric.empty else None,
    'min_ts_local': metric['ts_local'].min() if not metric.empty else None,
    'max_timestamp': int(metric['timestamp'].max()) if not metric.empty else None,
    'max_ts_local': metric['ts_local'].max() if not metric.empty else None
}])

trace_rows = pd.DataFrame([{
    'file': 'trace.csv',
    'rows': len(trace),
    'min_timestamp': int(trace['timestamp'].min()) if not trace.empty else None,
    'min_ts_local': trace['ts_local'].min() if not trace.empty else None,
    'max_timestamp': int(trace['timestamp'].max()) if not trace.empty else None,
    'max_ts_local': trace['ts_local'].max() if not trace.empty else None
}])

# 2) metric.csv distinct cmdb_id values; kpi_name counts (top20); global P95 per (cmdb_id,kpi_name)
metric_cmdb_list = pd.DataFrame({'cmdb_id': sorted(metric['cmdb_id'].unique())})
metric_kpi_counts = metric.groupby('kpi_name').size().reset_index(name='count').sort_values('count', ascending=False).head(20)

# Compute global P95 per (cmdb_id, kpi_name) using entire series BEFORE any filtering
metric_p95 = metric.groupby(['cmdb_id', 'kpi_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value':'p95_value'})
metric_p95_top20 = metric_p95.sort_values('p95_value', ascending=False).head(20)

# 3) trace.csv distinct cmdb_id values; trace_name counts (top20); global P95 per (cmdb_id, trace_name)
trace_cmdb_list = pd.DataFrame({'cmdb_id': sorted(trace['cmdb_id'].unique())})
trace_name_counts = trace.groupby('trace_name').size().reset_index(name='count').sort_values('count', ascending=False).head(20)

trace_p95 = trace.groupby(['cmdb_id', 'trace_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value':'p95_value'})
trace_p95_top20 = trace_p95.sort_values('p95_value', ascending=False).head(20)

# 4) Incident window counts (May 22, 2020, 00:00 to 00:30) in UTC+8
window_start = tz.localize(pd.Timestamp('2020-05-22 00:00:00'))
window_end   = tz.localize(pd.Timestamp('2020-05-22 00:30:00'))

metric_window = metric[(metric['ts_local'] >= window_start) & (metric['ts_local'] <= window_end)]
trace_window  = trace[(trace['ts_local']  >= window_start) & (trace['ts_local']  <= window_end)]

metric_window_summary = pd.DataFrame([{
    'file': 'metric.csv',
    'points_in_window': int(metric_window.shape[0]),
    'earliest_in_window': metric_window['ts_local'].min() if not metric_window.empty else None,
    'latest_in_window': metric_window['ts_local'].max() if not metric_window.empty else None
}])

trace_window_summary = pd.DataFrame([{
    'file': 'trace.csv',
    'points_in_window': int(trace_window.shape[0]),
    'earliest_in_window': trace_window['ts_local'].min() if not trace_window.empty else None,
    'latest_in_window': trace_window['ts_local'].max() if not trace_window.empty else None
}])

# Keep outputs compact: limit tables to <=20 rows and selected columns
metric_rows, trace_rows, metric_cmdb_list, metric_kpi_counts, metric_p95_top20[['cmdb_id','kpi_name','p95_value']], trace_cmdb_list, trace_name_counts, trace_p95_top20[['cmdb_id','trace_name','p95_value']], metric_window_summary, trace_window_summary
