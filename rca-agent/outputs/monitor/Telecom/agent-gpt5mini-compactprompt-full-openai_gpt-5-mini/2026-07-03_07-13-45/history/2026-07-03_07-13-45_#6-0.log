import numpy as np
import pandas as pd
import pytz

# Reuse existing variables: metric, trace, metric_p95, trace_p95, metric_window, trace_window, tz
# If any are missing (e.g., fresh kernel), recompute minimal needed items:
try:
    _ = metric_window
except NameError:
    tz = pytz.timezone('Asia/Shanghai')
    metric['ts_utc'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)
    metric['ts_local'] = metric['ts_utc'].dt.tz_convert(tz)
    trace['ts_utc'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True)
    trace['ts_local'] = trace['ts_utc'].dt.tz_convert(tz)
    window_start = tz.localize(pd.Timestamp('2020-05-22 00:00:00'))
    window_end   = tz.localize(pd.Timestamp('2020-05-22 00:30:00'))
    metric_window = metric[(metric['ts_local'] >= window_start) & (metric['ts_local'] <= window_end)]
    trace_window  = trace[(trace['ts_local']  >= window_start) & (trace['ts_local']  <= window_end)]

# Ensure p95 tables exist; recompute if missing
if 'metric_p95' not in globals():
    metric_p95 = metric.groupby(['cmdb_id','kpi_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value':'p95_value'})
if 'trace_p95' not in globals():
    trace_p95 = trace.groupby(['cmdb_id','trace_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value':'p95_value'})

# Helper to aggregate anomalies for a windowed dataframe merged with p95
def detect_anomalies(window_df, p95_df, key_cols, value_col='value', ts_col='ts_local', name_cols=None):
    # Merge global p95 into windowed points
    merged = window_df.merge(p95_df, on=key_cols, how='left')
    # Filter breaches where value > p95_value (must have non-null p95_value)
    breaches = merged[(merged[value_col] > merged['p95_value']) & (~merged['p95_value'].isna())].copy()
    if breaches.empty:
        return None, 0
    # Aggregate per series
    agg = breaches.groupby(key_cols).agg(
        anomaly_count = (value_col, 'size'),
        earliest_anomaly_timestamp = (ts_col, 'min'),
        latest_anomaly_timestamp   = (ts_col, 'max'),
        max_value_in_window        = (value_col, 'max'),
        p95_value                  = ('p95_value', 'first')
    ).reset_index()
    # Compute ratio safely
    agg['max_over_p95_ratio'] = np.where(
        agg['p95_value'] == 0,
        np.where(agg['max_value_in_window'] > 0, np.inf, 0.0),
        agg['max_value_in_window'] / agg['p95_value']
    )
    # Format timestamps as strings (keep timezone info)
    agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_timestamp'].astype(str)
    agg['latest_anomaly_timestamp']   = agg['latest_anomaly_timestamp'].astype(str)
    # Order columns
    out_cols = key_cols + ['p95_value','anomaly_count','earliest_anomaly_timestamp','latest_anomaly_timestamp','max_value_in_window','max_over_p95_ratio']
    agg = agg[out_cols]
    # Sort by severity ratio desc and limit to top 20
    agg = agg.sort_values('max_over_p95_ratio', ascending=False).reset_index(drop=True)
    top20 = agg.head(20)
    series_count = agg.shape[0]
    return top20, series_count

# 1) metric.csv anomalies within window
metric_anomalies_top, metric_anomaly_series_count = detect_anomalies(
    metric_window, metric_p95, key_cols=['cmdb_id','kpi_name']
)

# 2) trace.csv anomalies within window
trace_anomalies_top, trace_anomaly_series_count = detect_anomalies(
    trace_window, trace_p95, key_cols=['cmdb_id','trace_name']
)

# Prepare compact outputs: either DataFrame (top20) or explicit statement
if metric_anomalies_top is None:
    metric_result = "No >P95 anomalies detected in metric.csv during the window."
else:
    metric_result = metric_anomalies_top

if trace_anomalies_top is None:
    trace_result = "No >P95 anomalies detected in trace.csv during the window."
else:
    trace_result = trace_anomalies_top

# Final displayed variables (compact): metric_result, metric_anomaly_series_count, trace_result, trace_anomaly_series_count
metric_result, metric_anomaly_series_count, trace_result, trace_anomaly_series_count
