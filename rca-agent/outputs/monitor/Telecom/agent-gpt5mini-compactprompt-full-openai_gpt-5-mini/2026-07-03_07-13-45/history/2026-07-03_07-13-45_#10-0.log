import pandas as pd
import numpy as np
import pytz

# Reuse existing kernel variables if available: df_trace, trace_groups
# Defensive loading if missing
try:
    df_trace
except NameError:
    df_trace = pd.read_csv("trace.csv")
    df_trace['value'] = pd.to_numeric(df_trace['value'], errors='coerce')

try:
    trace_groups
except NameError:
    # Recreate trace_groups if absent (should contain global p95 and p5 per group)
    trace_groups = (
        df_trace
        .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
        .agg(p95=lambda x: x.quantile(0.95), p5=lambda x: x.quantile(0.05))
    )

# Ensure value numeric
df_trace['value'] = pd.to_numeric(df_trace['value'], errors='coerce')

# Ensure timezone-aware timestamp column in Asia/Shanghai (UTC+8)
tz = pytz.timezone('Asia/Shanghai')
if 'ts' not in df_trace.columns:
    df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    # ensure tz-aware and converted
    if df_trace['ts'].dt.tz is None:
        df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    else:
        df_trace['ts'] = df_trace['ts'].dt.tz_convert(tz)

# Define incident window in UTC+8
start = tz.localize(pd.to_datetime('2020-05-23 00:00:00'))
end = tz.localize(pd.to_datetime('2020-05-23 00:30:00'))

# Filter trace rows inside the window (inclusive)
df_window_trace = df_trace[(df_trace['ts'] >= start) & (df_trace['ts'] <= end)].copy()

# Merge global thresholds (p95, p5) from trace_groups into window rows
tg = trace_groups.copy()
if not {'cmdb_id','trace_name','p95','p5'}.issubset(tg.columns):
    raise ValueError("trace_groups must contain cmdb_id, trace_name, p95, p5")

df_window_trace = df_window_trace.merge(tg[['cmdb_id','trace_name','p95','p5']], on=['cmdb_id','trace_name'], how='left')

# Drop rows without thresholds or without value
df_window_trace = df_window_trace.dropna(subset=['p95','p5','value'])

# Mark anomalies using provided thresholds (do NOT recalc)
anomaly_mask = (df_window_trace['value'] >= df_window_trace['p95']) | (df_window_trace['value'] <= df_window_trace['p5'])
trace_anomalies_full = df_window_trace[anomaly_mask].copy()   # store full anomaly rows in kernel variable

# Aggregate anomalies by (cmdb_id, trace_name)
if not trace_anomalies_full.empty:
    agg = (
        trace_anomalies_full
        .groupby(['cmdb_id','trace_name'], as_index=False)
        .agg(
            anomaly_count=('value','size'),
            earliest_anomaly_timestamp=('ts','min'),
            max_value_in_window=('value','max'),
            min_value_in_window=('value','min'),
            p95=('p95','first'),
            p5=('p5','first')
        )
    )

    # Determine breach type
    agg['breach_type'] = np.where(agg['max_value_in_window'] >= agg['p95'], 'high',
                                 np.where(agg['min_value_in_window'] <= agg['p5'], 'low', 'none'))

    # zero threshold flag
    agg['zero_threshold'] = (agg['p95'] == 0) | (agg['p5'] == 0)

    # severity calculation with NaN when zero-threshold
    def compute_sev(r):
        if r['zero_threshold']:
            return np.nan
        if r['breach_type'] == 'high':
            return r['max_value_in_window'] / r['p95'] if r['p95'] != 0 else np.nan
        if r['breach_type'] == 'low':
            return r['p5'] / r['min_value_in_window'] if r['min_value_in_window'] != 0 else np.nan
        return np.nan

    agg['severity'] = agg.apply(compute_sev, axis=1)

    # Format earliest timestamp string in UTC+8
    agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_timestamp'].dt.strftime('%Y-%m-%d %H:%M:%S %Z')

    # Select required columns and sort
    result = agg[['cmdb_id','trace_name','anomaly_count','earliest_anomaly_timestamp',
                  'max_value_in_window','min_value_in_window','severity','zero_threshold']]

    result = result.sort_values(['anomaly_count','severity'], ascending=[False, False]).reset_index(drop=True)
else:
    # empty result
    result = pd.DataFrame(columns=['cmdb_id','trace_name','anomaly_count','earliest_anomaly_timestamp',
                                   'max_value_in_window','min_value_in_window','severity','zero_threshold'])

# Compact top 20 table
aggregated_top20 = result.head(20)

# Unique cmdb_ids appearing in trace anomalies (compact)
unique_cmdbs = trace_anomalies_full['cmdb_id'].unique() if not trace_anomalies_full.empty else np.array([])

# Top-10 summary of anomaly counts per cmdb_id
if not trace_anomalies_full.empty:
    top10_by_cmdb = (
        trace_anomalies_full
        .groupby('cmdb_id', as_index=False)
        .size()
        .rename(columns={'size':'trace_anomaly_count'})
        .sort_values('trace_anomaly_count', ascending=False)
        .head(10)
        .reset_index(drop=True)
    )
else:
    top10_by_cmdb = pd.DataFrame(columns=['cmdb_id','trace_anomaly_count'])

# Return only compact aggregated table, unique cmdb_ids, and top-10 summary
aggregated_top20, unique_cmdbs, top10_by_cmdb
