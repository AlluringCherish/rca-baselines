import pandas as pd
import numpy as np
import pytz

# Reuse existing kernel variables: metric_anomalies_full, metric_groups
# Defensive checks
try:
    metric_anomalies_full
except NameError:
    raise NameError("metric_anomalies_full not found in kernel. Run anomaly detection step first.")

try:
    metric_groups
except NameError:
    raise NameError("metric_groups not found in kernel. It must contain p95 and p5 per group.")

# Ensure timezone UTC+8 and ts column exists
tz = pytz.timezone('Asia/Shanghai')
if 'ts' not in metric_anomalies_full.columns:
    metric_anomalies_full['ts'] = pd.to_datetime(metric_anomalies_full['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    # ensure tz-aware and in Asia/Shanghai
    if metric_anomalies_full['ts'].dt.tz is None:
        metric_anomalies_full['ts'] = pd.to_datetime(metric_anomalies_full['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    else:
        metric_anomalies_full['ts'] = metric_anomalies_full['ts'].dt.tz_convert(tz)

# Work on a copy
df = metric_anomalies_full.copy()

# Ensure metrics groups thresholds available for merge
mg = metric_groups.copy()
if not {'cmdb_id','kpi_name','p95','p5'}.issubset(mg.columns):
    raise ValueError("metric_groups must include cmdb_id, kpi_name, p95, p5")

# Merge thresholds into anomaly rows if not already present
if 'p95' not in df.columns or 'p5' not in df.columns:
    df = df.merge(mg[['cmdb_id','kpi_name','p95','p5']], on=['cmdb_id','kpi_name'], how='left')

# Sort for grouping
df = df.sort_values(['cmdb_id','kpi_name','ts']).reset_index(drop=True)

# Identify consecutive runs: within each (cmdb_id,kpi_name), a new run starts when time difference != 60 seconds
def assign_run_ids(g):
    g = g.sort_values('ts').copy()
    diffs = g['ts'].diff().dt.total_seconds().fillna(np.nan)
    # continuation if diff == 60, else new run
    new_run = (diffs != 60).astype(int)  # first row will be 1 (new run)
    run_id = new_run.cumsum() - 1  # make run ids start from 0
    g['run_id'] = run_id.values
    return g

df_runs = df.groupby(['cmdb_id','kpi_name'], group_keys=False).apply(assign_run_ids).reset_index(drop=True)

# Aggregate per run
agg = (
    df_runs
    .groupby(['cmdb_id','kpi_name','run_id'], as_index=False)
    .agg(
        start_ts=('ts','min'),
        end_ts=('ts','max'),
        samples=('value','size'),
        max_value_in_run=('value','max'),
        min_value_in_run=('value','min'),
        p95=('p95','first'),
        p5=('p5','first')
    )
)

# Compute additional fields
# duration_minutes defined as samples (per instruction)
agg['duration_minutes'] = agg['samples']

# Determine breach_type
agg['breach_type'] = np.where(agg['max_value_in_run'] >= agg['p95'], 'high',
                             np.where(agg['min_value_in_run'] <= agg['p5'], 'low', 'none'))

# zero_threshold_flag: True if p95==0 or p5==0 (either threshold zero)
agg['zero_threshold_flag'] = (agg['p95'] == 0) | (agg['p5'] == 0)

# Compute severity with null when zero_threshold_flag True
def compute_severity(row):
    if row['zero_threshold_flag']:
        return np.nan
    if row['breach_type'] == 'high':
        # avoid division by zero already handled
        return row['max_value_in_run'] / row['p95'] if row['p95'] != 0 else np.nan
    elif row['breach_type'] == 'low':
        return row['p5'] / row['min_value_in_run'] if row['min_value_in_run'] != 0 else np.nan
    else:
        return np.nan

agg['severity'] = agg.apply(compute_severity, axis=1)

# keep_flag: samples >=3 AND severity not null AND severity > 1.5
agg['keep_flag'] = (agg['samples'] >= 3) & (~agg['severity'].isna()) & (agg['severity'] > 1.5)

# Format timestamps as strings in UTC+8
agg['start_timestamp'] = agg['start_ts'].dt.strftime('%Y-%m-%d %H:%M:%S %Z')
agg['end_timestamp'] = agg['end_ts'].dt.strftime('%Y-%m-%d %H:%M:%S %Z')

# Build the final faults table and store full runs in metric_faults_full
metric_faults_full = agg.copy()

# Prepare compact result table sorted by duration_minutes desc then severity desc
result_cols = ['cmdb_id','kpi_name','start_timestamp','end_timestamp','duration_minutes',
               'breach_type','severity','max_value_in_run','min_value_in_run','samples','zero_threshold_flag','keep_flag']

compact = metric_faults_full[result_cols].sort_values(['duration_minutes','severity'], ascending=[False, False]).reset_index(drop=True)

aggregated_top20 = compact.head(20)

# Totals and top 10 cmdb_id by kept-run count
total_runs = int(metric_faults_full.shape[0])
kept_runs_count = int(metric_faults_full['keep_flag'].sum())

top10_kept_by_cmdb = (
    metric_faults_full[metric_faults_full['keep_flag']]
    .groupby('cmdb_id', as_index=False)
    .size()
    .rename(columns={'size':'kept_run_count'})
    .sort_values('kept_run_count', ascending=False)
    .head(10)
)

# Return compact outputs (store full runs in metric_faults_full variable)
aggregated_top20, total_runs, kept_runs_count, top10_kept_by_cmdb
