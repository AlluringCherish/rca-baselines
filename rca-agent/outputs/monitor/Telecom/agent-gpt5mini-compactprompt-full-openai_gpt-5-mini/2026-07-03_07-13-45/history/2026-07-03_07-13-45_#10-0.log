import pandas as pd
import pytz

# load data (files are in current working directory)
metric_file = "metric.csv"
trace_file = "trace.csv"

# Read CSVs
df_metric = pd.read_csv(metric_file)
df_trace = pd.read_csv(trace_file)

# Ensure numeric values
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')
df_trace['value'] = pd.to_numeric(df_trace['value'], errors='coerce')

# Convert timestamp to timezone-aware datetime in Asia/Shanghai (UTC+8) for completeness (not required for aggregates)
tz = pytz.timezone('Asia/Shanghai')
df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Summaries for metric.csv
metric_unique = df_metric['cmdb_id'].unique()           # unique cmdb_id values
metric_rows = df_metric.shape[0]                        # total number of metric rows

# Group by (cmdb_id, kpi_name) and compute count, global P95 and P5
metric_groups = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .agg(count='size',
         p95=lambda x: x.quantile(0.95),
         p5=lambda x: x.quantile(0.05))
)

metric_groups_top20 = metric_groups.sort_values('count', ascending=False).head(20)[
    ['cmdb_id', 'kpi_name', 'count', 'p95', 'p5']
]

# Summaries for trace.csv
trace_unique = df_trace['cmdb_id'].unique()
trace_rows = df_trace.shape[0]

trace_groups = (
    df_trace
    .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
    .agg(count='size',
         p95=lambda x: x.quantile(0.95),
         p5=lambda x: x.quantile(0.05))
)

trace_groups_top20 = trace_groups.sort_values('count', ascending=False).head(20)[
    ['cmdb_id', 'trace_name', 'count', 'p95', 'p5']
]

# Display compact outputs (variables). The full grouped tables are stored in metric_groups and trace_groups.
metric_unique, metric_rows, metric_groups_top20, trace_unique, trace_rows, trace_groups_top20
