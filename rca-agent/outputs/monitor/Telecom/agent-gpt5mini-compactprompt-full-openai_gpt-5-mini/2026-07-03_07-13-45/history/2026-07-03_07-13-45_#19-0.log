import pandas as pd
import pytz

# ensure timezone variable
tz = pytz.timezone('Asia/Shanghai')

# metric is assumed loaded in kernel from previous step
# 1) compute global P95 per (cmdb_id, kpi_name) using the full series (BEFORE filtering)
metric_p95 = metric.groupby(['cmdb_id', 'kpi_name'])['value'].quantile(0.95).reset_index(name='global_p95')

# 2) convert timestamps to UTC+8 aware datetimes and filter to the failure window
metric['ts'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
start = pd.Timestamp('2020-05-25 01:30:00', tz=tz)
end = pd.Timestamp('2020-05-25 02:00:00', tz=tz)
metric_window = metric[(metric['ts'] >= start) & (metric['ts'] <= end)].copy()

# 3) attach global_p95 to windowed rows (left join)
metric_window = metric_window.merge(metric_p95, on=['cmdb_id', 'kpi_name'], how='left')

# 4) mark anomalies where value >= global_p95
metric_window['is_anom'] = metric_window['value'] >= metric_window['global_p95']

# 5) aggregate per (cmdb_id, kpi_name) within the window
group_stats = metric_window.groupby(['cmdb_id', 'kpi_name'], as_index=False).agg(
    anomaly_count=('is_anom', 'sum'),
    max_value_in_window=('value', 'max')
)

# earliest anomaly timestamp (NaT if no anomaly in window)
earliest_anom = metric_window[metric_window['is_anom']].groupby(['cmdb_id', 'kpi_name'], as_index=False)['ts'].min().rename(columns={'ts':'earliest_anomaly_timestamp'})

# combine stats and earliest timestamps, then add global_p95
result = group_stats.merge(earliest_anom, on=['cmdb_id','kpi_name'], how='left')
result = result.merge(metric_p95, on=['cmdb_id','kpi_name'], how='left')

# sort by descending anomaly_count and keep top 20
top20_df = result.sort_values(by='anomaly_count', ascending=False).head(20)

# Keep output compact: show the top table plus shapes of stored variables for later use
top20_df[['cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp','max_value_in_window','global_p95']], metric_window.shape, metric_p95.shape
