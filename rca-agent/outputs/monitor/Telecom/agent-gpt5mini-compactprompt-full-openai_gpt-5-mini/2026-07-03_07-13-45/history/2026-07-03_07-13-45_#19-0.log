import pandas as pd
import pytz
import numpy as np

# reuse existing trace DataFrame and timezone
tz = pytz.timezone('Asia/Shanghai')

# 1) compute global P95 per (cmdb_id, trace_name) using the full trace series (before filtering)
trace_p95 = trace.groupby(['cmdb_id', 'trace_name'])['value'].quantile(0.95).reset_index(name='global_p95')

# 2) convert timestamps to UTC+8 aware datetimes and filter to the failure window (inclusive)
if 'ts' not in trace.columns:
    trace['ts'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
start = pd.Timestamp('2020-05-25 01:30:00', tz=tz)
end = pd.Timestamp('2020-05-25 01:59:00', tz=tz)
trace_window = trace[(trace['ts'] >= start) & (trace['ts'] <= end)].copy()

# 3) attach global_p95 to windowed rows
trace_window = trace_window.merge(trace_p95, on=['cmdb_id', 'trace_name'], how='left')

# 4) mark anomalies where value >= global_p95
trace_window['is_anom'] = trace_window['value'] >= trace_window['global_p95']

# 5) aggregate per (cmdb_id, trace_name) within window
anomaly_count = trace_window.groupby(['cmdb_id','trace_name'], as_index=False)['is_anom'].sum().rename(columns={'is_anom':'anomaly_count'})
max_value = trace_window.groupby(['cmdb_id','trace_name'], as_index=False)['value'].max().rename(columns={'value':'max_value_in_window'})

# earliest anomaly timestamp (NaT if none)
earliest_anom = trace_window[trace_window['is_anom']].groupby(['cmdb_id','trace_name'], as_index=False)['ts'].min().rename(columns={'ts':'earliest_anomaly_timestamp'})

# combine aggregates and include global_p95
trace_anomalies = anomaly_count.merge(earliest_anom, on=['cmdb_id','trace_name'], how='left')
trace_anomalies = trace_anomalies.merge(max_value, on=['cmdb_id','trace_name'], how='left')
trace_anomalies = trace_anomalies.merge(trace_p95, on=['cmdb_id','trace_name'], how='left')

# sort by anomaly_count desc and keep top 20
trace_anomalies = trace_anomalies.sort_values(by='anomaly_count', ascending=False).reset_index(drop=True)

# compact output: shapes and top 20 rows with requested columns
trace_p95.shape, trace_window.shape, trace_anomalies[['cmdb_id','trace_name','anomaly_count','earliest_anomaly_timestamp','max_value_in_window','global_p95']].head(20)
