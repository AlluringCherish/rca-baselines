import numpy as np
import pandas as pd
import pytz

# reuse timezone
tz = pytz.timezone('Asia/Shanghai')

# metric_window and metric_p95 are assumed present in kernel
# 1) filter anomaly rows (value >= global_p95)
anomaly_rows = metric_window[metric_window['is_anom']].copy()

# quick aggregates needed
max_vals = metric_window.groupby(['cmdb_id','kpi_name'])['value'].max()
anom_counts = anomaly_rows.groupby(['cmdb_id','kpi_name']).size()

# prepare list of candidate summaries
records = []
if not anomaly_rows.empty:
    # iterate groups of anomaly rows to compute consecutive runs
    for (cmdb, kpi), g in anomaly_rows.groupby(['cmdb_id','kpi_name']):
        g = g.sort_values('ts')
        # compute time diffs in seconds between consecutive anomaly points
        diffs = g['ts'].diff().dt.total_seconds().fillna(0)
        # a new run starts when diff != 60 (one minute)
        run_id = (diffs != 60).cumsum()
        run_sizes = g.groupby(run_id).size()
        max_run_len = int(run_sizes.max())
        # earliest start timestamp of the longest run
        longest_run_idx = run_sizes.idxmax()
        earliest_run_start = g.groupby(run_id)['ts'].first().loc[longest_run_idx]
        anomaly_count = int(len(g))
        max_value_in_window = float(max_vals.loc[(cmdb,kpi)])
        # fetch global_p95
        gp95_row = metric_p95[(metric_p95['cmdb_id']==cmdb) & (metric_p95['kpi_name']==kpi)]
        global_p95 = float(gp95_row['global_p95'].values[0]) if not gp95_row.empty else np.nan
        # breach_ratio handling for global_p95 == 0
        if global_p95 == 0:
            breach_ratio = 0.0 if max_value_in_window == 0 else np.inf
        else:
            breach_ratio = (max_value_in_window - global_p95) / global_p95
        records.append({
            'cmdb_id': cmdb,
            'kpi_name': kpi,
            'anomaly_count': anomaly_count,
            'max_consecutive_run_length': max_run_len,
            'earliest_run_start_timestamp': earliest_run_start,
            'max_value_in_window': max_value_in_window,
            'global_p95': global_p95,
            'breach_ratio': breach_ratio
        })

# create DataFrame and sort as requested
fault_candidates = pd.DataFrame(records)
if not fault_candidates.empty:
    fault_candidates = fault_candidates.sort_values(
        by=['max_consecutive_run_length','breach_ratio'],
        ascending=[False, False]
    ).reset_index(drop=True)

# keep output compact: top 20 rows
fault_candidates.head(20), fault_candidates.shape
