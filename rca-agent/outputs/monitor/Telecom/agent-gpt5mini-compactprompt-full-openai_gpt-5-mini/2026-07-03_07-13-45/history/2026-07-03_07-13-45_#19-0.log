import pandas as pd
import pytz

# timezone UTC+8
tz = pytz.timezone('Asia/Shanghai')

# Load CSVs
metric = pd.read_csv('metric.csv')
trace = pd.read_csv('trace.csv')

# Helper to compute earliest/latest in UTC+8 from epoch seconds
def ts_min_max(df, ts_col='timestamp'):
    ts = pd.to_datetime(df[ts_col], unit='s', utc=True).dt.tz_convert(tz)
    return ts.min(), ts.max()

# Metric summaries
metric_total = metric.shape[0]
metric_earliest, metric_latest = ts_min_max(metric, 'timestamp')
metric_cmdb_top = metric['cmdb_id'].value_counts().head(20).reset_index().rename(columns={'index':'cmdb_id','cmdb_id':'count'})
metric_kpi_top = metric['kpi_name'].value_counts().head(20).reset_index().rename(columns={'index':'kpi_name','kpi_name':'count'})
metric_summary = pd.DataFrame({
    'total_rows': [metric_total],
    'earliest_UTC+8': [metric_earliest],
    'latest_UTC+8': [metric_latest]
})

# Trace summaries
trace_total = trace.shape[0]
trace_earliest, trace_latest = ts_min_max(trace, 'timestamp')
trace_cmdb_top = trace['cmdb_id'].value_counts().head(20).reset_index().rename(columns={'index':'cmdb_id','cmdb_id':'count'})
trace_name_top = trace['trace_name'].value_counts().head(20).reset_index().rename(columns={'index':'trace_name','trace_name':'count'})
trace_summary = pd.DataFrame({
    'total_rows': [trace_total],
    'earliest_UTC+8': [trace_earliest],
    'latest_UTC+8': [trace_latest]
})

# Display compact summaries (up to 20 rows for top lists)
metric_summary, metric_cmdb_top, metric_kpi_top, trace_summary, trace_cmdb_top, trace_name_top
