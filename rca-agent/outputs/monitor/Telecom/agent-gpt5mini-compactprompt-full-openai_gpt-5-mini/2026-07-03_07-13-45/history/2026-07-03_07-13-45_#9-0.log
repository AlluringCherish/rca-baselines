            'severity_ratio': float(r['severity_ratio']) if r['severity_ratio'] is not None else None
        })

# sort by ascending seq_start_ts and limit to first 20
sequences = sorted(sequences, key=lambda x: x['seq_start_ts'])
sequences = sequences[:20]

