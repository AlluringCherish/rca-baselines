pairs = []
if 'summary_result' in globals() and isinstance(summary_result, dict) and summary_result.get('top_breaches'):
    pairs = [(r['cmdb_id'], r['kpi_name']) for r in summary_result['top_breaches']][:20]
elif 'top_records' in globals() and isinstance(top_records, list) and top_records:
    pairs = [(r['cmdb_id'], r['kpi_name']) for r in top_records][:20]
else:
    # fallback: compute top pairs by count_exceed_p95 from window vs global p95
    # compute p95_all if not present
    tmp = p95_all.copy()
    df_win_tmp = df_win.merge(tmp, on=['cmdb_id','kpi_name'], how='left')
    if not df_win_tmp.empty:
        df_win_tmp['exceed'] = df_win_tmp['value'] > df_win_tmp['p95_value']
        agg_fallback = df_win_tmp.groupby(['cmdb_id','kpi_name'], dropna=False).agg(
            count_exceed_p95 = ('exceed','sum'),
        ).reset_index()
        agg_fallback = agg_fallback.sort_values('count_exceed_p95', ascending=False).head(20)
        pairs = list(zip(agg_fallback['cmdb_id'], agg_fallback['kpi_name']))
    else:
        pairs = []

# Process each pair: compute global p95 (guarantee computed before filtering), extract window rows, find consecutive exceed sequences
sequences = []
for cmdb_id, kpi_name in pairs:
    # global p95 (from p95_all)
    row = p95_all[(p95_all['cmdb_id']==cmdb_id)&(p95_all['kpi_name']==kpi_name)]
    if not row.empty:
        p95_value = float(row['p95_value'].iloc[0])
    else:
        # compute directly as fallback
        series_all = df_metric[(df_metric['cmdb_id']==cmdb_id)&(df_metric['kpi_name']==kpi_name)]['value']
        if series_all.empty:
            continue
        p95_value = float(series_all.quantile(0.95))
    # extract window rows for this pair
    df_pair_win = df_win[(df_win['cmdb_id']==cmdb_id)&(df_win['kpi_name']==kpi_name)].copy()
    if df_pair_win.empty:
        continue
    # identify exceed rows
    df_pair_win = df_pair_win.sort_values('timestamp')
    df_pair_win['exceed'] = df_pair_win['value'] > p95_value
    df_ex = df_pair_win[df_pair_win['exceed']].copy()
    if df_ex.empty:
        continue
    # compute diffs between consecutive exceed timestamps
    df_ex = df_ex.sort_values('timestamp').reset_index(drop=True)
    df_ex['ts_diff'] = df_ex['timestamp'].diff().fillna(0).astype('int64')
    # start new sequence when diff > 60 seconds
    df_ex['new_seq'] = (df_ex['ts_diff'] > 60).astype(int)
    df_ex['seq_id'] = df_ex['new_seq'].cumsum()
    # aggregate sequences
    seq_agg = df_ex.groupby('seq_id').agg(
        cmdb_id = ('cmdb_id','first'),
        kpi_name = ('kpi_name','first'),
        seq_start_ts = ('timestamp','min'),
        seq_end_ts = ('timestamp','max'),
        length = ('timestamp','size'),
        max_value_in_seq = ('value','max')
    ).reset_index(drop=True)
    # filter by length >= 2
    seq_agg = seq_agg[seq_agg['length'] >= 2].copy()
    if seq_agg.empty:
        continue
    # compute severity_ratio and p95_value fill
    seq_agg['p95_value'] = p95_value
    def _sev(row):
        if row['p95_value'] is None or row['p95_value'] == 0:
            return None
        return float(row['max_value_in_seq'])/float(row['p95_value'])
    seq_agg['severity_ratio'] = seq_agg.apply(_sev, axis=1)
    # ensure types and collect
    for _, r in seq_agg.iterrows():
        sequences.append({
            'cmdb_id': r['cmdb_id'],
            'kpi_name': r['kpi_name'],
            'seq_start_ts': int(r['seq_start_ts']),
            'seq_end_ts': int(r['seq_end_ts']),
            'length': int(r['length']),
