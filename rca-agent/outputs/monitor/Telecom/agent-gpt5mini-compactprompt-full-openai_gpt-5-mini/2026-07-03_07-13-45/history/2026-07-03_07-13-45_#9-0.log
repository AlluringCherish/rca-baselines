import pandas as pd
import pytz
import numpy as np

# reuse existing df_metric if available, else load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

# Ensure types
df_metric['timestamp'] = df_metric['timestamp'].astype('int64')
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

# Timezone
tz = pytz.timezone('Asia/Shanghai')

# 1) Compute global P95 per (cmdb_id, kpi_name) using all rows (global threshold BEFORE window filter)
grp = df_metric.groupby(['cmdb_id', 'kpi_name'], dropna=False)['value']
p95_df = grp.quantile(0.95).reset_index().rename(columns={'value': 'p95_value'})

# 2) Convert timestamps to UTC+8 datetimes and filter to incident window
df_metric['_dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
start = pd.Timestamp('2020-05-22 02:00:00', tz=tz)
end = pd.Timestamp('2020-05-22 02:30:00', tz=tz)
mask_window = (df_metric['_dt'] >= start) & (df_metric['_dt'] <= end)
df_window = df_metric[mask_window].copy()

# 3) For each pair present in window compute required aggregates, joined with global p95
if not df_window.empty:
    # join p95 to window rows
    df_window = df_window.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')
    # flag exceedances
    df_window['exceed'] = df_window['value'] > df_window['p95_value']
    # aggregate per pair
    agg = df_window.groupby(['cmdb_id', 'kpi_name'], dropna=False).agg(
        count_window = ('value', 'size'),
        count_exceed_p95 = ('exceed', 'sum'),
        earliest_exceed_ts = (lambda x: 'timestamp', lambda s: int(s[df_window.loc[s.index,'exceed']].min()) if s[df_window.loc[s.index,'exceed']].any() else np.nan),  # placeholder overwritten below
        max_value_window = ('value', 'max'),
        p95_value = ('p95_value', 'first')
    ).reset_index()
    # The above earliest_exceed_ts construction is awkward in agg; compute separately
    earliest = (
        df_window[df_window['exceed']]
        .groupby(['cmdb_id','kpi_name'], dropna=False)['timestamp']
        .min()
        .reset_index()
        .rename(columns={'timestamp':'earliest_exceed_ts'})
    )
    agg = agg.drop(columns=['earliest_exceed_ts'])
    agg = agg.merge(earliest, on=['cmdb_id','kpi_name'], how='left')
    # replace NaN earliest with None and convert dtypes
    agg['earliest_exceed_ts'] = agg['earliest_exceed_ts'].where(pd.notnull(agg['earliest_exceed_ts']), None)
    agg['count_exceed_p95'] = agg['count_exceed_p95'].astype(int)
    agg['count_window'] = agg['count_window'].astype(int)
else:
    # empty window
    agg = pd.DataFrame(columns=['cmdb_id','kpi_name','count_window','count_exceed_p95','max_value_window','p95_value','earliest_exceed_ts'])

# Ensure total counts
total_component_kpis = int(df_metric.groupby(['cmdb_id','kpi_name']).ngroups)
component_kpis_in_window = int(agg.shape[0])

# 4) Prepare top_breaches sorted by count_exceed_p95 desc, limit 20
if not agg.empty:
    top = agg.sort_values(['count_exceed_p95','count_window','max_value_window'], ascending=[False, False, False]).head(20).copy()
    # normalize types for JSON serializable output
    def to_py(val):
        if pd.isna(val):
            return None
        if isinstance(val, (np.integer,)):
            return int(val)
        if isinstance(val, (np.floating,)):
            return float(val)
        return val
    top_records = []
    for _, row in top.iterrows():
        top_records.append({
            'cmdb_id': row['cmdb_id'],
            'kpi_name': row['kpi_name'],
            'count_window': int(row['count_window']),
            'count_exceed_p95': int(row['count_exceed_p95']),
            'earliest_exceed_ts': int(row['earliest_exceed_ts']) if row['earliest_exceed_ts'] is not None else None,
            'max_value_window': to_py(row['max_value_window']),
            'p95_value': to_py(row['p95_value'])
        })
else:
    top_records = []

