import pandas as pd
import pytz

# reuse variable names across runs
tz = pytz.timezone('Asia/Shanghai')

# Load CSVs
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')

# Ensure timestamp is integer type
df_metric['timestamp'] = df_metric['timestamp'].astype('int64')
df_trace['timestamp'] = df_trace['timestamp'].astype('int64')

# (Use timezone in analysis steps by creating datetime columns in UTC+8)
df_metric['_dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
df_trace['_dt'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Distinct cmdb_id values per file
metric_cmdb_ids = df_metric['cmdb_id'].dropna().unique().tolist()
trace_cmdb_ids = df_trace['cmdb_id'].dropna().unique().tolist()

# 2) metric.csv: unique kpi_name count and top 20 by count
metric_unique_kpi_count = int(df_metric['kpi_name'].nunique(dropna=True))
metric_top_kpis_df = (
    df_metric.groupby('kpi_name', dropna=False)
    .size()
    .reset_index(name='count')
    .sort_values('count', ascending=False)
    .head(20)
)
metric_top_kpis = metric_top_kpis_df.to_dict(orient='records')

# 3) trace.csv: unique trace_name count and top 20 by count
trace_unique_trace_count = int(df_trace['trace_name'].nunique(dropna=True))
trace_top_traces_df = (
    df_trace.groupby('trace_name', dropna=False)
    .size()
    .reset_index(name='count')
    .sort_values('count', ascending=False)
    .head(20)
)
trace_top_traces = trace_top_traces_df.to_dict(orient='records')

# 4) min and max timestamps (as integers) per file
metric_min_ts = int(df_metric['timestamp'].min()) if not df_metric.empty else None
metric_max_ts = int(df_metric['timestamp'].max()) if not df_metric.empty else None
trace_min_ts = int(df_trace['timestamp'].min()) if not df_trace.empty else None
trace_max_ts = int(df_trace['timestamp'].max()) if not df_trace.empty else None

# Build JSON-serializable result
result = {
    'metric_cmdb_ids': metric_cmdb_ids,
    'trace_cmdb_ids': trace_cmdb_ids,
    'metric': {
        'unique_kpi_count': metric_unique_kpi_count,
        'top_kpis': metric_top_kpis,  # up to 20 rows
        'min_timestamp': metric_min_ts,
        'max_timestamp': metric_max_ts
    },
    'trace': {
        'unique_trace_count': trace_unique_trace_count,
        'top_traces': trace_top_traces,  # up to 20 rows
        'min_timestamp': trace_min_ts,
        'max_timestamp': trace_max_ts
    }
}

