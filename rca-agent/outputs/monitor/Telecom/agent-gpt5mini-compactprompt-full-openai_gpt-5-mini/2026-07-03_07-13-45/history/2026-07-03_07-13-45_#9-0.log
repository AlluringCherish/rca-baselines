import pandas as pd
import numpy as np
import pytz

# reuse df_metric if present, else load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

# Ensure types
df_metric['timestamp'] = df_metric['timestamp'].astype('int64')
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

# Timezone (UTC+8)
tz = pytz.timezone('Asia/Shanghai')

# 1) Global P95 per (cmdb_id, kpi_name) using all rows (compute BEFORE window filtering)
p95_series = df_metric.groupby(['cmdb_id','kpi_name'], dropna=False)['value'].quantile(0.95)
p95_df = p95_series.reset_index().rename(columns={'value':'p95_value'})

# 2) Convert timestamps to UTC+8 datetimes and filter to incident window (inclusive)
df_metric['_dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
start = pd.Timestamp('2020-05-22 02:00:00', tz=tz)
end = pd.Timestamp('2020-05-22 02:30:00', tz=tz)
mask_window = (df_metric['_dt'] >= start) & (df_metric['_dt'] <= end)
df_window = df_metric[mask_window].copy()

# 3) For pairs present in window compute aggregates, joined with global p95
if not df_window.empty:
    # merge p95 to window rows
    df_window = df_window.merge(p95_df, on=['cmdb_id','kpi_name'], how='left')
    # flag exceedances
    df_window['exceed'] = df_window['value'] > df_window['p95_value']
    # basic aggregates
    agg_basic = df_window.groupby(['cmdb_id','kpi_name'], dropna=False).agg(
        count_window = ('value','size'),
        count_exceed_p95 = ('exceed','sum'),
        max_value_window = ('value','max'),
        p95_value = ('p95_value','first')
    ).reset_index()
    # earliest exceed timestamp (if any)
    earliest = (
        df_window[df_window['exceed']]
        .groupby(['cmdb_id','kpi_name'], dropna=False)['timestamp']
        .min()
        .reset_index()
        .rename(columns={'timestamp':'earliest_exceed_ts'})
    )
    agg = agg_basic.merge(earliest, on=['cmdb_id','kpi_name'], how='left')
    # normalize types and fill None where appropriate
    agg['earliest_exceed_ts'] = agg['earliest_exceed_ts'].where(pd.notnull(agg['earliest_exceed_ts']), None)
    agg['count_exceed_p95'] = agg['count_exceed_p95'].astype(int)
    agg['count_window'] = agg['count_window'].astype(int)
else:
    agg = pd.DataFrame(columns=['cmdb_id','kpi_name','count_window','count_exceed_p95','max_value_window','p95_value','earliest_exceed_ts'])

# 4) Prepare summary JSON-serializable dict
total_component_kpis = int(df_metric.groupby(['cmdb_id','kpi_name']).ngroups)
component_kpis_in_window = int(agg.shape[0])

# top_breaches sorted by count_exceed_p95 desc, then count_window, then max_value_window
if not agg.empty:
    top = agg.sort_values(['count_exceed_p95','count_window','max_value_window'], ascending=[False,False,False]).head(20)
    top_records = []
    for _, r in top.iterrows():
        top_records.append({
            'cmdb_id': r['cmdb_id'],
            'kpi_name': r['kpi_name'],
            'count_window': int(r['count_window']),
            'count_exceed_p95': int(r['count_exceed_p95']),
            'earliest_exceed_ts': int(r['earliest_exceed_ts']) if r['earliest_exceed_ts'] is not None else None,
            'max_value_window': (float(r['max_value_window']) if pd.notnull(r['max_value_window']) else None),
            'p95_value': (float(r['p95_value']) if pd.notnull(r['p95_value']) else None)
        })
else:
    top_records = []

summary_result = {
    'total_component_kpis': total_component_kpis,
    'component_kpis_in_window': component_kpis_in_window,
    'top_breaches': top_records  # up to 20 records
}

