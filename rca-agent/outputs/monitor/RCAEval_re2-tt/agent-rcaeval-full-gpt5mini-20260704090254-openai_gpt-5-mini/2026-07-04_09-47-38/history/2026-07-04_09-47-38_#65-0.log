import pandas as pd

# Load CSVs
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')
df_log = pd.read_csv('log.csv')
df_error = pd.read_csv('error_logs.csv')

# Parse timestamps as UTC datetime
for df in (df_metric, df_trace, df_log, df_error):
    df['timestamp'] = pd.to_datetime(df['timestamp'], unit='s', utc=True)

# Ensure numeric 'value' columns where applicable
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')
df_trace['value'] = pd.to_numeric(df_trace['value'], errors='coerce')
df_log['value'] = pd.to_numeric(df_log['value'], errors='coerce')

# 1) metric.csv summaries
metric_cmdb_uniques = pd.Series(df_metric['cmdb_id'].unique()).head(50)
metric_kpi_uniques = pd.Series(df_metric['kpi_name'].unique()).head(50)

metric_summary = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'], dropna=False)['value']
    .agg(count='count', mean='mean', p95=lambda x: x.quantile(0.95))
    .reset_index()
)
# Format and sort by count desc, limit to top 20
metric_summary['mean'] = metric_summary['mean'].round(6)
metric_summary['p95'] = metric_summary['p95'].round(6)
metric_summary_top20 = metric_summary.sort_values('count', ascending=False).head(20)

# 2) trace.csv summaries
trace_cmdb_uniques = pd.Series(df_trace['cmdb_id'].unique()).head(50)
trace_name_uniques = pd.Series(df_trace['trace_name'].unique()).head(50)

trace_summary = (
    df_trace
    .groupby(['cmdb_id', 'trace_name'], dropna=False)['value']
    .agg(count='count', mean='mean', p95=lambda x: x.quantile(0.95))
    .reset_index()
)
trace_summary['mean'] = trace_summary['mean'].round(6)
trace_summary['p95'] = trace_summary['p95'].round(6)
trace_summary_top20 = trace_summary.sort_values('count', ascending=False).head(20)

# 3) log.csv summaries
log_cmdb_uniques = pd.Series(df_log['cmdb_id'].unique()).head(50)
log_name_uniques = pd.Series(df_log['log_name'].unique()).head(50)

log_summary = (
    df_log
    .groupby(['cmdb_id', 'log_name'], dropna=False)['value']
    .agg(count='count', mean='mean', p95=lambda x: x.quantile(0.95))
    .reset_index()
)
log_summary['mean'] = log_summary['mean'].round(6)
log_summary['p95'] = log_summary['p95'].round(6)
log_summary_top20 = log_summary.sort_values('count', ascending=False).head(20)

# 4) error_logs.csv summaries
error_cmdb_uniques = pd.Series(df_error['cmdb_id'].unique()).head(50)

error_counts_by_cmdb = (
    df_error
    .groupby('cmdb_id', dropna=False)
    .size()
    .reset_index(name='count')
    .sort_values('count', ascending=False)
)

# Top up to 10 distinct message samples overall with counts; truncate long messages to 200 chars
def truncate_msg(s, n=200):
    s = str(s)
    return (s[:n] + '...') if len(s) > n else s

msg_counts = (
    df_error['message']
    .astype(str)
    .value_counts()
    .reset_index()
    .rename(columns={'index': 'message', 'message': 'count'})
)
msg_counts['message_trunc'] = msg_counts['message'].apply(lambda s: truncate_msg(s, 200))
error_top10_messages = msg_counts[['message_trunc', 'count']].head(10)

# Compact display variables (do not print full tables)
metric_cmdb_uniques, metric_kpi_uniques, metric_summary_top20, \
trace_cmdb_uniques, trace_name_uniques, trace_summary_top20, \
log_cmdb_uniques, log_name_uniques, log_summary_top20, \
error_cmdb_uniques, error_counts_by_cmdb.head(20), error_top10_messages
