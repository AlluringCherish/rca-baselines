trace_name_list_df['trace_names'] = trace_name_list_df['trace_name'].apply(lambda arr: ','.join(arr[:50]) if len(arr)>0 else '')
trace_name_list_df = trace_name_list_df[['cmdb_id','trace_names']]

if not trace_candidates_df.empty:
