import pandas as pd
import numpy as np

# load files (they are in current working directory)
df_metric = pd.read_csv("metric.csv")
df_trace = pd.read_csv("trace.csv")
df_log = pd.read_csv("log.csv")
df_err = pd.read_csv("error_logs.csv")

# parse timestamps as UTC datetimes (reuse variable names)
df_metric['timestamp'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)
df_trace['timestamp'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True)
df_log['timestamp'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True)
df_err['timestamp'] = pd.to_datetime(df_err['timestamp'], unit='s', utc=True)

# incident window (UTC)
start = pd.to_datetime("2024-01-24 16:47:39", utc=True)
end = pd.to_datetime("2024-01-24 17:17:39", utc=True)

# helper to compute summaries for metric/trace/log
def summarize_kpi(df, id_col, kpi_col):
    # compute global p95 and total_count per group using full series (rule 9)
    agg = df.groupby([id_col, kpi_col])['value'].agg(
        global_p95=lambda s: float(np.nan) if s.empty else float(s.quantile(0.95)),
        total_count='count'
    ).reset_index()
    # compute counts and earliest/latest within window
    mask = (df['timestamp'] >= start) & (df['timestamp'] <= end)
    df_win = df[mask]
    win_agg = df_win.groupby([id_col, kpi_col])['timestamp'].agg(
        count_in_window='count',
        earliest_ts_in_window='min',
        latest_ts_in_window='max'
    ).reset_index()
    # merge, fill missing window info with NA/0
    merged = agg.merge(win_agg, on=[id_col, kpi_col], how='left')
    merged['count_in_window'] = merged['count_in_window'].fillna(0).astype(int)
    # mark absent timestamps as NA (use pd.NaT)
    merged['earliest_ts_in_window'] = merged['earliest_ts_in_window'].where(merged['count_in_window']>0, pd.NaT)
    merged['latest_ts_in_window'] = merged['latest_ts_in_window'].where(merged['count_in_window']>0, pd.NaT)
    # rename columns to required output names
    merged = merged.rename(columns={
        id_col: 'component',
        kpi_col: 'kpi_name'
    })[['component', 'kpi_name', 'global_p95', 'total_count', 'count_in_window', 'earliest_ts_in_window', 'latest_ts_in_window']]
    # sort by count_in_window desc and limit to top 50
    merged = merged.sort_values(by='count_in_window', ascending=False).head(50).reset_index(drop=True)
    return merged

# summaries
metric_summary = summarize_kpi(df_metric, 'cmdb_id', 'kpi_name')
trace_summary = summarize_kpi(df_trace, 'cmdb_id', 'trace_name')
log_summary = summarize_kpi(df_log, 'cmdb_id', 'log_name')

# error_logs summary: total_count per cmdb_id, count_in_window, sample up to 5 messages within window
err_total = df_err.groupby('cmdb_id').size().reset_index(name='total_count')
mask_err = (df_err['timestamp'] >= start) & (df_err['timestamp'] <= end)
df_err_win = df_err[mask_err]
err_win_count = df_err_win.groupby('cmdb_id').size().reset_index(name='count_in_window')

# sample messages up to 5 per component within window
def sample_msgs(group):
    return list(group['message'].head(5))

err_msgs = df_err_win.groupby('cmdb_id').apply(sample_msgs).reset_index(name='sample_messages')
# merge summaries
error_logs_summary = err_total.merge(err_win_count, on='cmdb_id', how='left').merge(err_msgs, on='cmdb_id', how='left')
error_logs_summary['count_in_window'] = error_logs_summary['count_in_window'].fillna(0).astype(int)
error_logs_summary['sample_messages'] = error_logs_summary['sample_messages'].where(error_logs_summary['count_in_window']>0, None)
error_logs_summary = error_logs_summary.rename(columns={'cmdb_id':'component'})
# sort and limit top 50
error_logs_summary = error_logs_summary.sort_values(by='count_in_window', ascending=False).head(50).reset_index(drop=True)

# final outputs (compact)
metric_summary, trace_summary, log_summary, error_logs_summary
