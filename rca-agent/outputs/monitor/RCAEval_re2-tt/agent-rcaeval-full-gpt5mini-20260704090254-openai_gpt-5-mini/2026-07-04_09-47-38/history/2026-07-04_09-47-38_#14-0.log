import pandas as pd

# Reuse df_trace from previous state
try:
    df_trace
except NameError:
    df_trace = pd.read_csv("trace.csv")

# Ensure timestamp_dt exists (UTC)
if "timestamp_dt" not in df_trace.columns:
    df_trace["timestamp_dt"] = pd.to_datetime(df_trace["timestamp"], unit="s", utc=True)

# Incident window (UTC)
inc_start = pd.to_datetime("2024-02-24 03:45:54", utc=True)
inc_end = pd.to_datetime("2024-02-24 04:15:54", utc=True)

targets = ["ts-auth-service","ts-order-service","ts-route-service"]

# Compute global P95 per (cmdb_id, trace_name) using full series (required before any filtering)
grp_all = df_trace.groupby(["cmdb_id","trace_name"], dropna=False)["value"].agg(
    total_count="size",
    P95=lambda x: x.quantile(0.95)
).reset_index()

# Filter incident-window rows and join P95 to compute anomalies within window
df_inc = df_trace[(df_trace["timestamp_dt"] >= inc_start) & (df_trace["timestamp_dt"] <= inc_end)].copy()
# merge P95 and total_count onto incident rows
df_inc = df_inc.merge(grp_all[["cmdb_id","trace_name","P95"]], on=["cmdb_id","trace_name"], how="left")

# Compute per-pair incident-window anomaly counts and earliest above-P95 timestamp
pair_inc_stats = (
    df_inc.assign(is_above=lambda d: d["value"] > d["P95"])
    .groupby(["cmdb_id","trace_name"], dropna=False)
    .agg(
        incident_count=("value","size"),
        count_above_p95=("is_above","sum"),
        earliest_timestamp_above_p95=("timestamp", lambda s: int(s[d_inc_idx := s.index][(df_inc.loc[d_inc_idx,"is_above"])].min()) if (df_inc.loc[d_inc_idx,"is_above"].any()) else pd.NA)
    )  # we'll fix earliest computation below in a safer way
    .reset_index()
)

# The lambda used above is awkward due to grouping index handling; recompute earliest properly:
def compute_earliest_above(group):
    mask = group["value"] > group["P95"]
    if mask.any():
        return int(group.loc[mask, "timestamp"].min())
    else:
        return pd.NA

pair_inc_stats = (
    df_inc.groupby(["cmdb_id","trace_name"], dropna=False)
    .agg(
        incident_count=("value","size"),
        count_above_p95=("value", lambda v: int((v > v.name and 0) ) )  # placeholder to keep structure
    )
    .reset_index()
)

# Instead, build pair_inc_stats from scratch more clearly:
pairs = grp_all[["cmdb_id","trace_name","P95","total_count"]].copy()

# For each pair, compute incident stats using df_inc slice
inc_rows = []
for _, r in pairs.iterrows():
    cmdb = r["cmdb_id"]
    tname = r["trace_name"]
    p95 = r["P95"]
    total_count = int(r["total_count"])
    rows_inc = df_inc[(df_inc["cmdb_id"] == cmdb) & (df_inc["trace_name"] == tname)]
    incident_count = int(len(rows_inc))
    if incident_count == 0:
        count_above = 0
        earliest_above = pd.NA
    else:
        above_mask = rows_inc["value"] > p95
        count_above = int(above_mask.sum())
        earliest_above = int(rows_inc.loc[above_mask, "timestamp"].min()) if count_above>0 else pd.NA
    inc_rows.append({
        "cmdb_id": cmdb,
        "trace_name": tname,
        "total_count": total_count,
        "P95": p95,
        "incident_count": incident_count,
        "count_above_p95": count_above,
        "earliest_timestamp_above_p95": earliest_above
    })

df_pair_inc = pd.DataFrame(inc_rows)

# Now for each target, focus on trace_name containing 'to_ts-<target>' and aggregate producers with anomalies
summary_rows = []
for target in targets:
    substring = f"to_ts-{target}"
    # select pairs whose trace_name contains the substring
    df_target_pairs = df_pair_inc[df_pair_inc["trace_name"].str.contains(substring, na=False)].copy()
    # keep only pairs that had anomalies in window (count_above_p95>0)
    df_target_anom_pairs = df_target_pairs[df_target_pairs["count_above_p95"] > 0].copy()
    if df_target_anom_pairs.empty:
        num_producers = 0
        earliest_among_all = pd.NA
        top_producers_list = []
    else:
        # producer cmdb_id is the cmdb_id column
        # For each producer, get earliest timestamp across its trace_names (there may be multiple trace metrics)
        prod_earliest = (
            df_target_anom_pairs.groupby("cmdb_id", as_index=False)
            .agg(earliest_timestamp_above_p95=("earliest_timestamp_above_p95","min"))
        )
        # sort by earliest timestamp ascending
        prod_earliest_sorted = prod_earliest.sort_values("earliest_timestamp_above_p95")
        num_producers = int(prod_earliest_sorted["cmdb_id"].nunique())
        earliest_among_all = int(prod_earliest_sorted["earliest_timestamp_above_p95"].min())
        # format top producers as "cmdb_id:timestamp" and limit to 10
        prod_earliest_sorted["producer_with_ts"] = prod_earliest_sorted["cmdb_id"].astype(str) + ":" + prod_earliest_sorted["earliest_timestamp_above_p95"].astype(int).astype(str)
        top_producers_list = prod_earliest_sorted["producer_with_ts"].head(10).tolist()
    summary_rows.append({
        "target_service": target,
        "num_producer_cmdbs_with_anomaly": num_producers,
        "earliest_timestamp_above_p95_among_producers": earliest_among_all,
        "top_producers": top_producers_list
    })

df_summary = pd.DataFrame(summary_rows)

# Display compact result
df_summary
