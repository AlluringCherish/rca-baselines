import pandas as pd

# Reuse existing metric_df loaded in kernel.
# 1) Compute global P95 per (cmdb_id, kpi_name) using entire series
comp_kpi_thresholds = (
    metric_df
    .groupby(['cmdb_id', 'kpi_name'], dropna=False)['value']
    .quantile(0.95)
    .reset_index()
    .rename(columns={'value': 'p95_threshold'})
)

# 2) Filter metric_df to the incident window (inclusive) using timestamp_dt (UTC)
start_ts = pd.to_datetime('2024-01-22 19:22:25', utc=True)
end_ts   = pd.to_datetime('2024-01-22 19:52:25', utc=True)
metric_window = metric_df[(metric_df['timestamp_dt'] >= start_ts) & (metric_df['timestamp_dt'] <= end_ts)].copy()

# 3) For each (cmdb_id, kpi_name) in metric_window compute the requested aggregates
# Merge windowed data with thresholds so each row knows its global P95
mw_with_thresh = metric_window.merge(comp_kpi_thresholds, on=['cmdb_id', 'kpi_name'], how='left')

# Mark exceedances (value > global P95)
mw_with_thresh['exceed'] = mw_with_thresh['value'] > mw_with_thresh['p95_threshold']

# Group and aggregate
grp = mw_with_thresh.groupby(['cmdb_id', 'kpi_name'], dropna=False)

agg = grp.agg(
    count_in_window = ('value', 'size'),
    count_exceed    = ('exceed', 'sum'),
    earliest_exceed_ts_dt = (lambda df: df.loc[df['exceed'], 'timestamp_dt'].min() ),
    max_value       = ('value', 'max'),
).reset_index()

# The custom aggregation returned a column with name 2 (because of lambda usage),
# fix by recomputing earliest_exceed_ts properly to ensure robust behavior:
# recompute earliest_exceed_ts using groupby apply to avoid ambiguous names
earliest_exceed = (
    mw_with_thresh.loc[mw_with_thresh['exceed']]
    .groupby(['cmdb_id','kpi_name'])['timestamp_dt']
    .min()
    .reset_index()
    .rename(columns={'timestamp_dt':'earliest_exceed_ts_dt'})
)

# Merge earliest_exceed into agg (will be NaT where no exceed)
agg = agg.drop(columns=['earliest_exceed_ts_dt'], errors='ignore').merge(
    earliest_exceed, on=['cmdb_id','kpi_name'], how='left'
)

# Compute exceed_ratio
agg['exceed_ratio'] = agg['count_exceed'] / agg['count_in_window']

# Format earliest_exceed_ts as ISO UTC strings, None if no exceed
agg['earliest_exceed_ts'] = agg['earliest_exceed_ts_dt'].apply(
    lambda dt: dt.isoformat() if pd.notnull(dt) else None
)

# Select and rename final columns requested
final_cols = ['cmdb_id', 'kpi_name', 'count_in_window', 'count_exceed', 
              'earliest_exceed_ts', 'max_value', 'exceed_ratio']
agg_final = agg[final_cols].copy()

# 4) Compact table sorted by count_exceed descending (max 20 rows)
agg_display = agg_final.sort_values(by='count_exceed', ascending=False).head(20)

# Total count of distinct cmdb_ids that have at least one exceedance, and the list (max 50)
exceeding_pairs = agg_final[agg_final['count_exceed'] > 0]
exceed_cmdb_ids = exceeding_pairs['cmdb_id'].dropna().unique()
total_exceed_cmdb_count = int(len(exceed_cmdb_ids))
# Keep deterministic order (sorted) and limit to 50
exceed_cmdb_list = pd.Series(sorted(exceed_cmdb_ids)[:50], name='cmdb_id')

# Keep full tables in kernel variables (comp_kpi_thresholds, metric_window) as requested
# For compact output, return only agg_display (<=20 rows), total_exceed_cmdb_count, exceed_cmdb_list,
# and shapes of the full tables to confirm they are stored.
comp_kpi_thresholds_shape = comp_kpi_thresholds.shape
metric_window_shape = metric_window.shape

# Final output variables (kernel will display them; kept compact)
agg_display, total_exceed_cmdb_count, exceed_cmdb_list, comp_kpi_thresholds_shape, metric_window_shape
