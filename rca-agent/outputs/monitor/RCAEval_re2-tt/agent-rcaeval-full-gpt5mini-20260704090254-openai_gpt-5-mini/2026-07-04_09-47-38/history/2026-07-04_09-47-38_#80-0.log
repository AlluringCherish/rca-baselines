    'cmdb_id','log_name','count_in_window','earliest_ts_in_window','latest_ts_in_window',
    'count_above_global_p95_in_window','max_value_in_window',
    'count_below_global_p5_in_window','min_value_in_window','global_p95','global_p5'
]
