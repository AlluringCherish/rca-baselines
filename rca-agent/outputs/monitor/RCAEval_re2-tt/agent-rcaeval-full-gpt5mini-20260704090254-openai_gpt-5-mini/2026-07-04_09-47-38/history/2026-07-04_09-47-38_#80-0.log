        latest_ts_in_window=('timestamp','max'),
        count_above_global_p95_in_window=('above_global_p95','sum'),
        max_value_in_window=('value','max'),
        count_below_global_p5_in_window=('below_global_p5','sum'),
        min_value_in_window=('value','min'),
