def top_examples(df, key_col, val_col, n_items=3, max_vals=6):
    examples = []
    for cm in df[key_col].unique()[:n_items]:
        vals = df[df[key_col]==cm][val_col].unique()[:max_vals].tolist()
        examples.append(f"{cm}: {', '.join(vals)}")
    return "; ".join(examples)

