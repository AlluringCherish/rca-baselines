import pandas as pd
import numpy as np

# Reuse existing 'metric' DataFrame if present, otherwise load
try:
    metric
except NameError:
    metric = pd.read_csv("metric.csv", low_memory=False)

# Ensure numeric value and datetime_utc column (UTC)
metric['value'] = pd.to_numeric(metric['value'], errors='coerce')
if 'datetime_utc' not in metric.columns:
    metric['datetime_utc'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)

# Define target groups and KPIs
groups_kpis = {
    'ts-travel-service': ['workload','mem','socket','latency-50','latency-90','error'],
    'ts-auth-service':   ['cpu','socket','diskio','latency-50']
}

# Build a DataFrame of the groups we care about for filtering
target_rows = metric[metric['cmdb_id'].isin(groups_kpis.keys()) & metric['kpi_name'].notna()].copy()
# Keep only rows whose kpi_name is in our listed KPIs per cmdb_id
mask = target_rows.apply(lambda r: r['kpi_name'] in groups_kpis.get(r['cmdb_id'], []), axis=1)
target_rows = target_rows[mask]

# Rule 9: compute global p95 and p5 (and global_count) over full available series BEFORE time filtering
thr = (
    target_rows
    .groupby(['cmdb_id','kpi_name'])['value']
    .agg(global_count='count',
         p95=lambda x: x.quantile(0.95),
         p5=lambda x: x.quantile(0.05))
    .reset_index()
)

# Incident window (UTC) inclusive
start = pd.to_datetime("2024-01-24 09:34:39", utc=True)
end = pd.to_datetime("2024-01-24 10:04:39", utc=True)

# Filter metric rows to the incident window and the target groups/kpis
window_df = metric[
    (metric['datetime_utc'] >= start) &
    (metric['datetime_utc'] <= end) &
    (metric['cmdb_id'].isin(groups_kpis.keys())) &
    (metric['kpi_name'].notna())
].copy()
# Keep only requested KPIs per cmdb_id
window_df = window_df[window_df.apply(lambda r: r['kpi_name'] in groups_kpis.get(r['cmdb_id'], []), axis=1)]

# Merge thresholds into windowed rows
window_with_thr = window_df.merge(thr, on=['cmdb_id','kpi_name'], how='left')

# Function to analyze anomaly sequences for a group's anomaly timestamps (sorted)
def analyze_sequences(ts_series):
    # ts_series: pd.Series of datetime64[ns, UTC] sorted ascending
    if ts_series.empty:
        return 0, 0, None, []
    # compute diffs
    diffs = ts_series.diff()
    # A new sequence starts where diff != 60s or diff is NaT (first)
    is_new_seq = (diffs != pd.Timedelta(seconds=60))
    # Assign sequence ids
    seq_id = is_new_seq.cumsum().fillna(0).astype(int)
    # Group by seq_id to get lengths
    lengths = ts_series.groupby(seq_id).size().tolist()
    num_sequences = len(lengths)
    longest = int(max(lengths)) if lengths else 0
    # earliest sequence start is the start timestamp of the first sequence (smallest seq_id)
    first_seq_start = ts_series.groupby(seq_id).first().iloc[0] if num_sequences>0 else None
    # Return number of sequences, longest length (in minutes == number of timestamps), earliest start, and full ts list for sampling
    return num_sequences, longest, first_seq_start, ts_series.tolist()

# Prepare summary rows for each requested (cmdb_id, kpi_name) pair
rows = []
for cmdb, kpis in groups_kpis.items():
    for kpi in kpis:
        # Get global thresholds row
        thr_row = thr[(thr['cmdb_id']==cmdb)&(thr['kpi_name']==kpi)]
        if thr_row.empty:
            global_count = 0
            p95 = np.nan
            p5 = np.nan
        else:
            global_count = int(thr_row['global_count'].iloc[0])
            p95 = float(thr_row['p95'].iloc[0])
            p5 = float(thr_row['p5'].iloc[0])

        # Windowed rows for this group
        w = window_with_thr[(window_with_thr['cmdb_id']==cmdb)&(window_with_thr['kpi_name']==kpi)].copy()
        if w.empty:
            total_anoms = 0
            num_sequences = 0
            longest_seq = 0
            earliest_seq_start = None
            sample_list = ""
        else:
            # Identify anomalies where value >= p95 OR value <= p5
            # If p95/p5 are NaN (no global data), treat as no anomalies
            if np.isnan(p95) or np.isnan(p5):
                anom = w.iloc[0:0]
            else:
                anom = w[(w['value'] >= p95) | (w['value'] <= p5)].copy()
            total_anoms = int(len(anom))
            if total_anoms == 0:
                num_sequences = 0
                longest_seq = 0
                earliest_seq_start = None
                sample_list = ""
            else:
                # sort anomaly timestamps ascending
                anom = anom.sort_values('datetime_utc')
                ts_series = anom['datetime_utc'].reset_index(drop=True)
                num_sequences, longest_seq, earliest_seq_start, ts_list = analyze_sequences(ts_series)
                earliest_seq_start_iso = earliest_seq_start.isoformat() if earliest_seq_start is not None else None
                # sample up to 5 anomaly pairs (timestamp ISO, value)
                sample_pairs = []
                for _, r in anom.head(5).iterrows():
                    sample_pairs.append(f"({r['datetime_utc'].isoformat()}, {r['value']})")
                sample_list = "; ".join(sample_pairs)
                earliest_seq_start = earliest_seq_start_iso

        rows.append({
            'cmdb_id': cmdb,
            'kpi_name': kpi,
            'global_count': global_count,
            'p95': p95,
            'p5': p5,
            'total_anomalies_in_window': total_anoms,
            'num_consecutive_sequences': num_sequences,
            'longest_sequence_length_minutes': longest_seq,
            'earliest_sequence_start_utc': earliest_seq_start,
            'sample_anomalies': sample_list
        })

# Build result DataFrame, sort by total_anomalies_in_window desc, then cmdb_id, limit to these groups only
summary_df = pd.DataFrame(rows)
summary_df = summary_df.sort_values(by=['total_anomalies_in_window','cmdb_id'], ascending=[False, True]).reset_index(drop=True)

# Keep columns order compact and as requested
summary_df = summary_df[[
    'cmdb_id','kpi_name','global_count','p95','p5',
    'total_anomalies_in_window','num_consecutive_sequences',
    'longest_sequence_length_minutes','earliest_sequence_start_utc','sample_anomalies'
]]

# Display the compact summary table
summary_df
