import pandas as pd

# Reuse existing 'metric' if present, otherwise load
try:
    metric
except NameError:
    metric = pd.read_csv("metric.csv", low_memory=False)

# Ensure numeric value and datetime_utc column (UTC)
metric['value'] = pd.to_numeric(metric['value'], errors='coerce')
if 'datetime_utc' not in metric.columns:
    metric['datetime_utc'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)

# Candidate services
candidates = ['ts-auth-service','ts-order-service','ts-route-service','ts-train-service','ts-travel-service']

# Rule 9: compute global thresholds (p95 and p5) over the full series for these components BEFORE time filtering
thr = (
    metric[metric['cmdb_id'].isin(candidates)]
    .groupby(['cmdb_id','kpi_name'])['value']
    .agg(global_count='count',
         p95=lambda x: x.quantile(0.95),
         p5=lambda x: x.quantile(0.05))
    .reset_index()
)

# Incident window (UTC) inclusive
start = pd.to_datetime("2024-01-24 09:34:39", utc=True)
end = pd.to_datetime("2024-01-24 10:04:39", utc=True)

# Filter metric rows to the five services and the incident window
window_df = metric[
    metric['cmdb_id'].isin(candidates) &
    (metric['datetime_utc'] >= start) &
    (metric['datetime_utc'] <= end)
].copy()

# Merge global thresholds into the windowed rows
wnd = window_df.merge(thr, on=['cmdb_id','kpi_name'], how='left')

# Identify anomaly rows: value >= p95 OR value <= p5
mask_anom = (wnd['value'] >= wnd['p95']) | (wnd['value'] <= wnd['p5'])
anom = wnd[mask_anom].copy()

# Prepare result table for groups with anomalies in window
if anom.empty:
    # empty result with required columns
    result_df = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','global_count','p95','p5',
        'anomaly_count_in_window','first_anomaly_timestamp_utc',
        'max_value_in_window','min_value_in_window','example_anomalies'
    ])
else:
    g = anom.groupby(['cmdb_id','kpi_name'])
    agg_basic = g.agg(
        anomaly_count_in_window = ('value','count'),
        first_anomaly_timestamp_utc = ('datetime_utc','min'),
        max_value_in_window = ('value','max'),
        min_value_in_window = ('value','min')
    ).reset_index()
    # convert first anomaly timestamp to ISO string with timezone
    agg_basic['first_anomaly_timestamp_utc'] = agg_basic['first_anomaly_timestamp_utc'].apply(lambda t: t.isoformat())

    # assemble up to 3 example anomaly rows per group as a small list-like string
    examples = (
        g.apply(lambda df: "; ".join(
            f"({row['datetime_utc'].isoformat()}, {row['value']})"
            for _, row in df.sort_values('datetime_utc').head(3).iterrows()
        ))
        .reset_index()
        .rename(columns={0: 'example_anomalies'})
    )

    # merge with examples and with global thresholds
    result_df = (
        agg_basic.merge(examples, on=['cmdb_id','kpi_name'], how='left')
                  .merge(thr[['cmdb_id','kpi_name','global_count','p95','p5']], on=['cmdb_id','kpi_name'], how='left')
    )

    # reorder columns as requested
    result_df = result_df[[
        'cmdb_id','kpi_name','global_count','p95','p5',
        'anomaly_count_in_window','first_anomaly_timestamp_utc',
        'max_value_in_window','min_value_in_window','example_anomalies'
    ]]

    # sort by anomaly_count_in_window desc then by cmdb_id and limit to 50 rows
    result_df = result_df.sort_values(by=['anomaly_count_in_window','cmdb_id'], ascending=[False, True]).head(50).reset_index(drop=True)

# Display compact result (per IPython rules)
result_df
