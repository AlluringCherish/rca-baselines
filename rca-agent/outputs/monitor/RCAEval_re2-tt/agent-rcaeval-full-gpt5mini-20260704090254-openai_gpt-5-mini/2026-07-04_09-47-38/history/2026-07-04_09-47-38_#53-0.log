import pandas as pd

# Load CSVs
metric = pd.read_csv("metric.csv", low_memory=False)
trace = pd.read_csv("trace.csv", low_memory=False)
logdf = pd.read_csv("log.csv", low_memory=False)
error_logs = pd.read_csv("error_logs.csv", low_memory=False)

# Parse timestamps to UTC datetimes (keep original timestamp column too)
for df in (metric, trace, logdf, error_logs):
    if 'timestamp' in df.columns:
        df['datetime_utc'] = pd.to_datetime(df['timestamp'], unit='s', utc=True)

# 1) For each file, unique cmdb_id values (as list), limited to top 50 for compactness
metric_cmdbs = sorted(metric['cmdb_id'].dropna().unique().tolist())[:50]
trace_cmdbs = sorted(trace['cmdb_id'].dropna().unique().tolist())[:50]
log_cmdbs = sorted(logdf['cmdb_id'].dropna().unique().tolist())[:50]
error_logs_cmdbs = sorted(error_logs['cmdb_id'].dropna().unique().tolist())[:50]

# 2) metric.csv: unique kpi_name values with counts (top 50)
metric_kpi_counts = metric['kpi_name'].value_counts().head(50).rename_axis('kpi_name').reset_index(name='count')

# 3) trace.csv: unique trace_name values with counts
trace_name_counts = trace['trace_name'].value_counts().head(50).rename_axis('trace_name').reset_index(name='count')

# 4) log.csv: unique log_name values with counts
log_name_counts = logdf['log_name'].value_counts().head(50).rename_axis('log_name').reset_index(name='count')

# 5) error_logs.csv: total row count and top 5 rows (all columns)
error_count = error_logs.shape[0]
error_top5 = error_logs.head(5)

# Display compact overview (variables separated by commas per IPython rules)
metric_cmdbs, metric_kpi_counts, trace_cmdbs, trace_name_counts, log_cmdbs, log_name_counts, error_count, error_top5
