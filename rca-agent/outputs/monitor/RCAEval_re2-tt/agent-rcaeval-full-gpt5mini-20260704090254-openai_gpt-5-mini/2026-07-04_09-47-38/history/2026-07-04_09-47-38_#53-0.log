import pandas as pd

# Reuse existing 'trace' if present, otherwise load
try:
    trace
except NameError:
    trace = pd.read_csv("trace.csv", low_memory=False)

# Ensure numeric value and datetime_utc column (UTC)
trace['value'] = pd.to_numeric(trace['value'], errors='coerce')
if 'datetime_utc' not in trace.columns:
    trace['datetime_utc'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True)

# Incident window (UTC) inclusive
start = pd.to_datetime("2024-01-24 09:34:39", utc=True)
end = pd.to_datetime("2024-01-24 10:04:39", utc=True)

# Filter to window
trace_window = trace[(trace['datetime_utc'] >= start) & (trace['datetime_utc'] <= end)].copy()

# Keep only rows where trace_name contains 'ts-travel-service' OR 'ts-auth-service'
mask = trace_window['trace_name'].str.contains('ts-travel-service|ts-auth-service', na=False)
trace_sel = trace_window[mask].copy()

# Group by trace_name and compute aggregates
if trace_sel.empty:
    agg = pd.DataFrame(columns=['trace_name','count','earliest_timestamp_utc','mean_value','max_value','min_value'])
    unique_trace_names = []
else:
    g = trace_sel.groupby('trace_name')
    agg = g.agg(
        count = ('value','count'),
        earliest_timestamp_utc = ('datetime_utc','min'),
        mean_value = ('value','mean'),
