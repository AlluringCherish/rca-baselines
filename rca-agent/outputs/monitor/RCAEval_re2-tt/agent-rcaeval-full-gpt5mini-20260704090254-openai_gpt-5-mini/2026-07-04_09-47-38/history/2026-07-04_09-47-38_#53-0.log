import pandas as pd
import numpy as np

# Reuse existing variables if present, otherwise load files
try:
    logdf
except NameError:
    logdf = pd.read_csv("log.csv", low_memory=False)

try:
    error_logs
except NameError:
    error_logs = pd.read_csv("error_logs.csv", low_memory=False)

# Ensure numeric 'value' in logdf
logdf['value'] = pd.to_numeric(logdf['value'], errors='coerce')

# Parse timestamps to UTC datetimes (create/overwrite datetime_utc)
logdf['datetime_utc'] = pd.to_datetime(logdf['timestamp'], unit='s', utc=True)
error_logs['datetime_utc'] = pd.to_datetime(error_logs['timestamp'], unit='s', utc=True)

# Incident window (UTC) inclusive
start = pd.to_datetime("2024-01-24 09:34:39", utc=True)
end = pd.to_datetime("2024-01-24 10:04:39", utc=True)

# Target cmdb_ids
targets = ['ts-travel-service','ts-auth-service']

# Filter log rows to window and targets
logs_window = logdf[
    (logdf['datetime_utc'] >= start) &
    (logdf['datetime_utc'] <= end) &
    (logdf['cmdb_id'].isin(targets))
].copy()

# Group by (cmdb_id, log_name) and compute aggregates
if logs_window.empty:
    grouped_logs = pd.DataFrame(columns=['cmdb_id','log_name','row_count','sum_of_value','earliest_timestamp_utc','latest_timestamp_utc'])
else:
    grouped = (
        logs_window
        .groupby(['cmdb_id','log_name'])['value']
        .agg(row_count = 'count',
             sum_of_value = 'sum')
        .reset_index()
    )
    # compute earliest and latest timestamps per group
    times = (
        logs_window
        .groupby(['cmdb_id','log_name'])['datetime_utc']
        .agg(earliest = 'min', latest = 'max')
        .reset_index()
    )
    grouped_logs = grouped.merge(times, on=['cmdb_id','log_name'], how='left')
    # convert times to ISO strings
    grouped_logs['earliest_timestamp_utc'] = grouped_logs['earliest'].apply(lambda t: t.isoformat() if pd.notna(t) else None)
    grouped_logs['latest_timestamp_utc'] = grouped_logs['latest'].apply(lambda t: t.isoformat() if pd.notna(t) else None)
    grouped_logs = grouped_logs[['cmdb_id','log_name','row_count','sum_of_value','earliest_timestamp_utc','latest_timestamp_utc']]
    # sort by row_count desc then cmdb_id and limit to 10 rows
    grouped_logs = grouped_logs.sort_values(by=['row_count','cmdb_id'], ascending=[False, True]).head(10).reset_index(drop=True)

# Prepare raw log rows for these two cmdb_ids in the window, top 20 ordered by timestamp ascending
if logs_window.empty:
    raw_logs_top20 = pd.DataFrame(columns=['timestamp','datetime_utc_iso','cmdb_id','log_name','value'])
else:
    raw_logs = logs_window.sort_values('datetime_utc', ascending=True).copy()
    raw_logs['datetime_utc_iso'] = raw_logs['datetime_utc'].apply(lambda t: t.isoformat())
    raw_logs_top20 = raw_logs[['timestamp','datetime_utc_iso','cmdb_id','log_name','value']].head(20).reset_index(drop=True)

# Filter error_logs to window and targets
errors_window = error_logs[
    (error_logs['datetime_utc'] >= start) &
    (error_logs['datetime_utc'] <= end) &
    (error_logs['cmdb_id'].isin(targets))
].copy()

error_count = int(errors_window.shape[0])
if errors_window.empty:
    error_top10 = pd.DataFrame(columns=['timestamp','datetime_utc_iso','cmdb_id','message'])
else:
    errors_window['datetime_utc_iso'] = errors_window['datetime_utc'].apply(lambda t: t.isoformat())
    error_top10 = errors_window[['timestamp','datetime_utc_iso','cmdb_id','message']].head(10).reset_index(drop=True)

# Return compact outputs: grouped table (<=10 rows), raw logs top 20, error count, and error top10
grouped_logs, raw_logs_top20, error_count, error_top10
