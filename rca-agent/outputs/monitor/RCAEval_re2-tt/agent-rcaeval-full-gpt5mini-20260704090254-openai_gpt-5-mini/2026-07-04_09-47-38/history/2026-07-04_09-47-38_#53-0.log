# Reuse existing 'metric' DataFrame loaded earlier.
import pandas as pd
# Ensure 'value' is numeric
metric['value'] = pd.to_numeric(metric['value'], errors='coerce')

# Candidate services
candidates = ['ts-auth-service','ts-order-service','ts-route-service','ts-train-service','ts-travel-service']

# Filter rows to only the five candidate services
sel = metric[metric['cmdb_id'].isin(candidates)].copy()

# Ensure we have the timestamp parsed (should exist from prior steps), but keep as-is per rules
if 'datetime_utc' not in sel.columns and 'timestamp' in sel.columns:
    sel['datetime_utc'] = pd.to_datetime(sel['timestamp'], unit='s', utc=True)

# Group and compute global aggregates over the full available series
grp = sel.groupby(['cmdb_id', 'kpi_name'])['value']
agg_df = grp.agg(
    count='count',
    p95=lambda x: x.quantile(0.95),
    p50=lambda x: x.quantile(0.50),
    mean='mean',
    max='max'
).reset_index()

# Sort by count descending then cmdb_id and limit to 100 rows
agg_df = agg_df.sort_values(by=['count', 'cmdb_id'], ascending=[False, True]).head(100)

# Unique kpi_name values observed for these five services
unique_kpis = sorted(sel['kpi_name'].dropna().unique().tolist())

# Display compact results (per IPython rules, use variable names)
agg_df, unique_kpis
