# Reuse existing df_metric loaded earlier. Define target components.
components = ["ts-auth-service","ts-order-service","ts-route-service","ts-train-service","ts-travel-service"]

# Ensure df_metric is present
try:
    df_metric
except NameError:
    import pandas as pd
    df_metric = pd.read_csv("metric.csv")

import pandas as pd
import numpy as np

# Filter rows to the five components
df_five = df_metric[df_metric['cmdb_id'].isin(components)].copy()

# Compute per (cmdb_id, kpi_name) aggregates: count, min_timestamp, max_timestamp, p95_value
grouped = df_five.groupby(['cmdb_id', 'kpi_name'], sort=True)['value']

agg_df = grouped.agg(
    count='count',
    min_timestamp=('timestamp', 'min'),
    max_timestamp=('timestamp', 'max'),
    p95_value=(lambda s: np.nan)  # placeholder, will compute below
).reset_index()

# Compute p95 per group correctly (using the group's full series)
p95_series = grouped.quantile(0.95).reset_index(name='p95_value')
# Merge p95 into agg_df
agg_df = agg_df.merge(p95_series, on=['cmdb_id','kpi_name'], how='left')

# Ensure integer timestamps
agg_df['min_timestamp'] = agg_df['min_timestamp'].astype('Int64')
agg_df['max_timestamp'] = agg_df['max_timestamp'].astype('Int64')

# Sort by cmdb_id then kpi_name and limit to top 50 rows
agg_df = agg_df.sort_values(['cmdb_id','kpi_name']).reset_index(drop=True)
group_summary = agg_df[['cmdb_id','kpi_name','count','min_timestamp','max_timestamp','p95_value']].head(50)

# Build a short list of available kpi_name values per each of the five components (one line per component)
rows = []
for c in components:
    kpis = sorted(df_metric.loc[df_metric['cmdb_id']==c, 'kpi_name'].dropna().unique())
    # keep the list short: join up to 20 names into a comma-separated string
    kpi_sample = ", ".join(kpis[:20]) if len(kpis)>0 else ""
    rows.append({'cmdb_id': c, 'kpi_names_sample': kpi_sample, 'kpi_count': len(kpis)})

kpi_per_component = pd.DataFrame(rows)

# Display the two compact outputs (per rule, return variables rather than printing)
group_summary, kpi_per_component
