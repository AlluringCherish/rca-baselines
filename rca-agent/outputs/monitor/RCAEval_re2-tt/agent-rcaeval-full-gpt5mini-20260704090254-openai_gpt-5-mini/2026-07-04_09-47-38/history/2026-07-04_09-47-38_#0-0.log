import pandas as pd
import numpy as np

# reuse existing df_metric and group_summary if present; otherwise load/compute
try:
    df_metric
except NameError:
    df_metric = pd.read_csv("metric.csv")

# ensure global p95 per (cmdb_id,kpi_name) exists as group_summary (computed on full metric series)
try:
    group_summary
except NameError:
    # compute global p95 per rule 9 for the five components
    components = ["ts-auth-service","ts-order-service","ts-route-service","ts-train-service","ts-travel-service"]
    df_five_all = df_metric[df_metric['cmdb_id'].isin(components)].copy()
    group_summary = (
        df_five_all
        .groupby(['cmdb_id','kpi_name'], as_index=False, sort=True)
        .agg(count=('value','count'),
             min_timestamp=('timestamp','min'),
             max_timestamp=('timestamp','max'),
             p95_value=('value', lambda s: float(s.quantile(0.95))))
    )

# Define components and incident window (UTC)
components = ["ts-auth-service","ts-order-service","ts-route-service","ts-train-service","ts-travel-service"]
start_ts = pd.Timestamp("2024-01-22 09:53:25", tz="UTC")
end_ts   = pd.Timestamp("2024-01-22 10:23:25", tz="UTC")

# Ensure timestamp datetime column in UTC for filtering (rule 10)
if 'ts_utc' not in df_metric.columns:
    df_metric['ts_utc'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)

# Filter rows to components and incident window (inclusive)
df_window = df_metric[
    df_metric['cmdb_id'].isin(components) &
    (df_metric['ts_utc'] >= start_ts) &
    (df_metric['ts_utc'] <= end_ts)
].copy()

# Merge global p95_value from group_summary (thresholds computed before window filtering)
p95_map = group_summary[['cmdb_id','kpi_name','p95_value']].drop_duplicates()
df_window = df_window.merge(p95_map, on=['cmdb_id','kpi_name'], how='left')

# Mark anomalies where value >= global p95_value (handle missing p95 as no anomaly)
df_window['is_anomaly'] = False
mask_p95_valid = df_window['p95_value'].notna()
df_window.loc[mask_p95_valid, 'is_anomaly'] = df_window.loc[mask_p95_valid, 'value'] >= df_window.loc[mask_p95_valid, 'p95_value']

# Group within window to compute required metrics
agg_window = (
    df_window
    .groupby(['cmdb_id','kpi_name'], as_index=False, sort=False)
    .agg(
        count_in_window = ('value','count'),
        anomaly_count = ('is_anomaly','sum'),
        earliest_anomaly_timestamp = (['timestamp','is_anomaly'], lambda grp: int(grp['timestamp'][grp['is_anomaly']].min()) if grp['is_anomaly'].any() else pd.NA),
        max_value_in_window = ('value','max'),
        p95_value = ('p95_value','first')
    )
)

# The custom aggregation with list of columns might not work in older pandas; handle robustly if needed
if agg_window.empty and not df_window.empty:
    # fallback: perform groupby manually
    rows = []
    for (cmdb,kpi), g in df_window.groupby(['cmdb_id','kpi_name'], sort=False):
        cnt = int(g['value'].count())
        an_cnt = int(g['is_anomaly'].sum())
        earliest = int(g.loc[g['is_anomaly'], 'timestamp'].min()) if an_cnt>0 else pd.NA
        maxv = float(g['value'].max())
        p95v = float(g['p95_value'].iloc[0]) if pd.notna(g['p95_value'].iloc[0]) else np.nan
        rows.append((cmdb,kpi,cnt,an_cnt,earliest,maxv,p95v))
    agg_window = pd.DataFrame(rows, columns=['cmdb_id','kpi_name','count_in_window','anomaly_count','earliest_anomaly_timestamp','max_value_in_window','p95_value'])

# Compute ratio = max_value_in_window / p95_value (if p95_value>0 else None)
def compute_ratio(row):
    p95 = row['p95_value']
    maxv = row['max_value_in_window']
    if pd.isna(p95) or p95 == 0:
        return pd.NA
    return float(maxv) / float(p95)

agg_window['ratio'] = agg_window.apply(compute_ratio, axis=1)

# Normalize earliest_anomaly_timestamp to Int64 with NA for None
agg_window['earliest_anomaly_timestamp'] = agg_window['earliest_anomaly_timestamp'].astype('Int64')

# Sort by ratio desc then anomaly_count desc; ensure NA ratios sort last
agg_window_sorted = agg_window.sort_values(by=['ratio','anomaly_count'], ascending=[False, False]).reset_index(drop=True)

# Limit to top 20 rows for display
top20_by_ratio = agg_window_sorted.head(20)[
    ['cmdb_id','kpi_name','count_in_window','anomaly_count','earliest_anomaly_timestamp','max_value_in_window','p95_value','ratio']
]

# Separate short list of all groups with anomaly_count>0 (limit 20)
anomalies_only = agg_window_sorted[agg_window_sorted['anomaly_count']>0][
    ['cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp']
].head(20).reset_index(drop=True)

# Final compact outputs
top20_by_ratio, anomalies_only
