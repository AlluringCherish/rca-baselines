import pandas as pd
import re
import numpy as np

# Reuse df_trace if present; otherwise load and parse timestamps as UTC
try:
    df_trace
except NameError:
    df_trace = pd.read_csv("trace.csv")
df_trace['timestamp'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True)

# Candidate referenced services
candidates = ['ts-auth-service','ts-order-service','ts-route-service','ts-train-service','ts-travel-service']

# 1 & 2) Select trace rows where name contains 'to_ts-' or 'from_ts-' AND contains 'row_count' or 'duration'
mask_to_from = df_trace['trace_name'].str.contains(r'\b(?:to_ts|from_ts)-', regex=True, na=False)
mask_metric = df_trace['trace_name'].str.contains(r'(row_count|duration_mean|duration_p95)', regex=True, na=False)
df_tf = df_trace[mask_to_from & mask_metric].copy()

# Extract referenced_service token after to_ts- or from_ts- up to next dot (.)
df_tf['referenced_service'] = df_tf['trace_name'].str.extract(r'(?:to_ts-|from_ts-)([^.]+)', expand=False)

# Keep only rows where referenced_service matches one of the five candidates
df_tf = df_tf[df_tf['referenced_service'].isin(candidates)].copy()

# Count number of distinct (cmdb_id, trace_name) series examined
distinct_series_examined = int(df_tf[['cmdb_id', 'trace_name']].drop_duplicates().shape[0])

# 2) Compute global P95 and P05 per (cmdb_id, trace_name) using the full series (before time filtering).
# We compute thresholds for the selected series using all rows from df_trace that match those series.
selected_keys = df_tf[['cmdb_id', 'trace_name']].drop_duplicates()
thresholds = (
    df_trace
    .merge(selected_keys, on=['cmdb_id', 'trace_name'], how='inner')
    .groupby(['cmdb_id', 'trace_name'], observed=True)['value']
    .agg(p95=lambda x: x.quantile(0.95), p05=lambda x: x.quantile(0.05))
    .reset_index()
)

# 3) Filter the selected rows to the incident window (inclusive)
start = pd.Timestamp("2024-01-23 12:24:34", tz="UTC")
end = pd.Timestamp("2024-01-23 12:54:34", tz="UTC")
df_window = df_tf[(df_tf['timestamp'] >= start) & (df_tf['timestamp'] <= end)].copy()

# 4) Join thresholds and flag anomalies where value >= p95 or value <= p05 (only where thresholds exist)
df_window = df_window.merge(thresholds, on=['cmdb_id', 'trace_name'], how='left')
df_window['is_anomaly'] = False
valid = df_window['p95'].notna() & df_window['p05'].notna()
df_window.loc[valid, 'is_anomaly'] = (
    (df_window.loc[valid, 'value'] >= df_window.loc[valid, 'p95']) |
    (df_window.loc[valid, 'value'] <= df_window.loc[valid, 'p05'])
)

# Helper to determine metric_type
def metric_type_from_name(name):
    if 'row_count' in name:
        return 'row_count'
    if 'duration_p95' in name:
        return 'duration_p95'
    if 'duration_mean' in name:
        return 'duration_mean'
    # fallback
    return 'duration'

df_window['metric_type'] = df_window['trace_name'].apply(metric_type_from_name)

# 5) Aggregate anomalies by (cmdb_id, trace_name)
agg = (
    df_window
    .groupby(['cmdb_id', 'trace_name', 'referenced_service', 'metric_type'], observed=True)
    .apply(lambda g: pd.Series({
        'sample_count_in_window': int(len(g)),
        'anomaly_count': int(g['is_anomaly'].sum()),
        'earliest_anomaly_timestamp_utc': (g.loc[g['is_anomaly'], 'timestamp'].min() if g['is_anomaly'].any() else pd.NaT),
        'max_value_in_window': (g['value'].max() if len(g) > 0 else np.nan),
        'min_value_in_window': (g['value'].min() if len(g) > 0 else np.nan)
    }))
    .reset_index()
)

# Attach p95/p05 (already computed)
agg = agg.merge(thresholds, on=['cmdb_id', 'trace_name'], how='left')

# 5 continued) Compute severity per rules
def compute_severity(row):
    p95 = row['p95']
    p05 = row['p05']
    maxv = row['max_value_in_window']
    minv = row['min_value_in_window']
    mtype = row['metric_type']
    # ensure numeric and not NaN
    if pd.isna(p95) or pd.isna(p05):
        return 0.0
    denom = max(1.0, float(p95))
    if mtype == 'row_count':
        if not pd.isna(minv) and minv < p05:
            return float((p95 - minv) / denom)
        return 0.0
    else:  # duration_mean or duration_p95 treated as 'duration'
        if not pd.isna(maxv) and maxv > p95:
            return float((maxv - p95) / denom)
        return 0.0

agg['severity'] = agg.apply(compute_severity, axis=1)

# Round numeric columns for compactness
agg['p95'] = agg['p95'].round(6)
agg['p05'] = agg['p05'].round(6)
agg['max_value_in_window'] = agg['max_value_in_window'].astype(float)
agg['min_value_in_window'] = agg['min_value_in_window'].astype(float)
agg['severity'] = agg['severity'].round(6)

# 6) Filter to anomaly_count > 0, sort by severity desc then anomaly_count desc, limit top 20
result = (
    agg[agg['anomaly_count'] > 0]
    .sort_values(['severity', 'anomaly_count'], ascending=[False, False])
    .loc[:, ['cmdb_id', 'trace_name', 'referenced_service', 'metric_type',
             'sample_count_in_window', 'anomaly_count', 'earliest_anomaly_timestamp_utc',
             'max_value_in_window', 'min_value_in_window', 'p95', 'p05', 'severity']]
    .head(20)
    .reset_index(drop=True)
)

# Counts: number of series examined and number with anomalies
series_examined_count = distinct_series_examined
series_with_anomalies_count = int(agg[agg['anomaly_count'] > 0][['cmdb_id','trace_name']].drop_duplicates().shape[0])

# Display compact outputs
result, series_examined_count, series_with_anomalies_count
