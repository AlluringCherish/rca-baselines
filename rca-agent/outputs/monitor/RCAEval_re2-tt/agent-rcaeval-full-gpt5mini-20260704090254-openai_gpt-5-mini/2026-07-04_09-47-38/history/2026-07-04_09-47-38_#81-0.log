df_final['total_log_anomaly_points'] = df_final['total_log_anomaly_points'].fillna(0).astype(int)
df_final['total_incoming_trace_anomaly_points'] = df_final['total_incoming_trace_anomaly_points'].fillna(0).astype(int)

