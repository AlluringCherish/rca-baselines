import pandas as pd
import numpy as np

# reuse existing metric_df, global_p95, df_window if present; otherwise load/compute
if "metric_df" not in globals():
    metric_df = pd.read_csv("metric.csv")
    metric_df["timestamp"] = pd.to_datetime(metric_df["timestamp"], unit="s", utc=True)
else:
    if not pd.api.types.is_datetime64_any_dtype(metric_df["timestamp"]):
        metric_df["timestamp"] = pd.to_datetime(metric_df["timestamp"], unit="s", utc=True)
    else:
        if metric_df["timestamp"].dt.tz is None:
            metric_df["timestamp"] = metric_df["timestamp"].dt.tz_localize("UTC")

# compute global_p95 if not present
if "global_p95" not in globals():
    global_p95 = (
        metric_df
        .groupby(["cmdb_id", "kpi_name"], as_index=False)["value"]
        .quantile(0.95)
        .rename(columns={"value": "global_p95"})
    )

# incident window
start = pd.to_datetime("2024-02-20 15:31:23", utc=True)
end = pd.to_datetime("2024-02-20 16:01:23", utc=True)

# prepare windowed dataframe for all component-kpi pairs present in global_p95
df_window = metric_df[(metric_df["timestamp"] >= start) & (metric_df["timestamp"] <= end)].copy()
df_window = df_window.sort_values(["cmdb_id", "kpi_name", "timestamp"])

results = []
# iterate over existing component-kpi pairs
for _, row in global_p95.iterrows():
    comp = row["cmdb_id"]
    kpi = row["kpi_name"]
    p95 = row["global_p95"]

    grp = df_window[(df_window["cmdb_id"] == comp) & (df_window["kpi_name"] == kpi)].sort_values("timestamp")
    rows_in_window = len(grp)
    if rows_in_window == 0:
        rows_exceeding = 0
        earliest_anom = None
        max_val = None
        breach_ratio = None
        num_runs = 0
        longest_run = 0
        start_longest = None
    else:
        vals = grp["value"].to_numpy()
        mask = vals > p95
        rows_exceeding = int(np.sum(mask))
        if rows_exceeding > 0:
            earliest_ts = grp.loc[mask, "timestamp"].min()
            earliest_anom = earliest_ts.strftime("%Y-%m-%dT%H:%M:%SZ")
        else:
            earliest_anom = None
        max_val = float(np.nanmax(vals))
        if p95 == 0 or pd.isna(p95):
            breach_ratio = None
        else:
            breach_ratio = float((max_val - p95) / p95)

        # compute consecutive anomaly runs
        arr = mask.astype(int)
        padded = np.r_[0, arr, 0]
        diff = np.diff(padded)
        starts = np.where(diff == 1)[0]  # positions in arr where runs start
        ends = np.where(diff == -1)[0]   # positions in arr where runs end (exclusive)
        lengths = ends - starts
        if len(lengths) == 0:
            num_runs = 0
            longest_run = 0
            start_longest = None
        else:
            num_runs = int(len(lengths))
            longest_run = int(np.max(lengths))
            idx_of_longest = int(np.argmax(lengths))
            start_idx = starts[idx_of_longest]
            # obtain timestamp at start_idx in grp
            start_ts = grp["timestamp"].iloc[start_idx]
            start_longest = start_ts.strftime("%Y-%m-%dT%H:%M:%SZ")

    results.append({
        "component": comp,
        "kpi_name": kpi,
        "global_p95": float(p95) if not pd.isna(p95) else None,
        "rows_in_window": int(rows_in_window),
        "rows_exceeding_p95": int(rows_exceeding),
        "earliest_anomaly_timestamp_in_window": earliest_anom,
        "max_value_in_window": max_val,
        "breach_ratio": breach_ratio,
        "number_of_consecutive_anomaly_runs": int(num_runs),
        "longest_run_length": int(longest_run),
        "start_timestamp_of_longest_run": start_longest
    })

res_df = pd.DataFrame(results)

# sort by longest_run_length desc then breach_ratio desc (NaNs last)
res_df["breach_ratio_sort"] = res_df["breach_ratio"].fillna(-np.inf)
res_df = res_df.sort_values(by=["longest_run_length", "breach_ratio_sort"], ascending=[False, False]).drop(columns=["breach_ratio_sort"])

# limit to top 50 rows and display selected columns compactly
output_df = res_df[
    ["component", "kpi_name", "global_p95", "rows_in_window", "rows_exceeding_p95",
     "earliest_anomaly_timestamp_in_window", "max_value_in_window", "breach_ratio",
     "number_of_consecutive_anomaly_runs", "longest_run_length", "start_timestamp_of_longest_run"]
].head(50)

