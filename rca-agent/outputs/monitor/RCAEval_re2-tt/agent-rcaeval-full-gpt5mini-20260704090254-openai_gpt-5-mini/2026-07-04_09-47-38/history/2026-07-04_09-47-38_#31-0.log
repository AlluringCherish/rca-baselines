import pandas as pd
import numpy as np

# reuse log_df if available, otherwise load and parse timestamp as UTC
if "log_df" not in globals():
    log_df = pd.read_csv("log.csv")
    log_df["timestamp"] = pd.to_datetime(log_df["timestamp"], unit="s", utc=True)
else:
    if not pd.api.types.is_datetime64_any_dtype(log_df["timestamp"]):
        log_df["timestamp"] = pd.to_datetime(log_df["timestamp"], unit="s", utc=True)
    else:
        if log_df["timestamp"].dt.tz is None:
            log_df["timestamp"] = log_df["timestamp"].dt.tz_localize("UTC")

# target components
targets = ["ts-travel-service", "ts-order-service"]

# 1) compute global P95 per component-log_name using full series (before filtering)
global_p95_df = (
    log_df
    .groupby(["cmdb_id", "log_name"], as_index=False)["value"]
    .quantile(0.95)
    .rename(columns={"value": "global_p95"})
)

# keep only target components that exist
global_p95_df = global_p95_df[global_p95_df["cmdb_id"].isin(targets)].copy()

# incident window
start = pd.to_datetime("2024-02-20 15:31:23", utc=True)
end = pd.to_datetime("2024-02-20 16:01:23", utc=True)

# windowed logs for targets
window_df = log_df[
    (log_df["cmdb_id"].isin(targets)) &
    (log_df["timestamp"] >= start) &
    (log_df["timestamp"] <= end)
].copy()

# merge windowed data with global p95
merged = window_df.merge(global_p95_df, on=["cmdb_id", "log_name"], how="left")

# mark anomalies: value > global_p95
merged["is_anom"] = merged["value"] > merged["global_p95"]

# aggregate metrics from windowed merged data
rows_in_window = merged.groupby(["cmdb_id", "log_name"], as_index=True)["value"].size().rename("rows_in_window")
rows_exceeding = merged.groupby(["cmdb_id", "log_name"], as_index=True)["is_anom"].sum().rename("rows_exceeding_p95")
max_value = merged.groupby(["cmdb_id", "log_name"], as_index=True)["value"].max().rename("max_value_in_window")
earliest_anom = (
    merged[merged["is_anom"]]
    .groupby(["cmdb_id", "log_name"], as_index=True)["timestamp"]
    .min()
    .rename("earliest_anomaly_timestamp_in_window")
)

# assemble results by starting from global_p95_df (to include combos that may have zero rows in window)
combos = global_p95_df.set_index(["cmdb_id", "log_name"])
res = combos.join(rows_in_window).join(rows_exceeding).join(earliest_anom).join(max_value)

# fill defaults for missing window groups
res["rows_in_window"] = res["rows_in_window"].fillna(0).astype(int)
res["rows_exceeding_p95"] = res["rows_exceeding_p95"].fillna(0).astype(int)
res["earliest_anomaly_timestamp_in_window"] = res["earliest_anomaly_timestamp_in_window"].dt.strftime("%Y-%m-%dT%H:%M:%SZ")
res["earliest_anomaly_timestamp_in_window"] = res["earliest_anomaly_timestamp_in_window"].where(res["rows_exceeding_p95"]>0, None)
res["max_value_in_window"] = res["max_value_in_window"].where(res["rows_in_window"]>0, None)

# breach_ratio calculation: (max - global_p95)/global_p95, handle zero/NaN global_p95
def compute_breach(row):
    g = row["global_p95"]
    m = row["max_value_in_window"]
    if pd.isna(g) or g == 0 or pd.isna(m):
        return None
    return float((m - g) / g)

res["breach_ratio"] = res.apply(compute_breach, axis=1)

# reset index and rename cmdb_id -> component
res = res.reset_index().rename(columns={"cmdb_id": "component"})

# select and order columns
output_df = res[[
    "component", "log_name", "global_p95", "rows_in_window", "rows_exceeding_p95",
    "earliest_anomaly_timestamp_in_window", "max_value_in_window", "breach_ratio"
]]

# sort by rows_exceeding_p95 desc then breach_ratio desc, limit to 20 rows
output_df = output_df.sort_values(by=["rows_exceeding_p95", "breach_ratio"], ascending=[False, False]).head(20)

# display compact result
output_df
