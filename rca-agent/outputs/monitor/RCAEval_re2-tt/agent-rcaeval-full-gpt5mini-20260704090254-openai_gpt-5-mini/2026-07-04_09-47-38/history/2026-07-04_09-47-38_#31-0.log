import pandas as pd

# reuse metric_df if available, otherwise load and parse timestamp as UTC
if "metric_df" not in globals():
    metric_df = pd.read_csv("metric.csv")
    metric_df["timestamp"] = pd.to_datetime(metric_df["timestamp"], unit="s", utc=True)
else:
    # ensure timestamp is datetime tz-aware
    if not pd.api.types.is_datetime64_any_dtype(metric_df["timestamp"]):
        metric_df["timestamp"] = pd.to_datetime(metric_df["timestamp"], unit="s", utc=True)
    else:
        # ensure tz-aware UTC
        if metric_df["timestamp"].dt.tz is None:
            metric_df["timestamp"] = metric_df["timestamp"].dt.tz_localize("UTC")

# Candidate components
candidates = ["ts-auth-service", "ts-order-service", "ts-route-service", "ts-train-service", "ts-travel-service"]

# 1) Identify which candidates appear in metric.csv
unique_cmdb = metric_df["cmdb_id"].unique()
appearing = [c for c in candidates if c in unique_cmdb]

# 2) Compute global P95 for each component-kpi using full series (global thresholds before filtering)
global_p95 = (
    metric_df
    .groupby(["cmdb_id", "kpi_name"], as_index=False)["value"]
    .quantile(0.95)
    .rename(columns={"value": "global_p95"})
)

# keep only appearing components
global_p95 = global_p95[global_p95["cmdb_id"].isin(appearing)]

# 3) Filter to incident window
start = pd.to_datetime("2024-02-20 15:31:23", utc=True)
end = pd.to_datetime("2024-02-20 16:01:23", utc=True)
df_window = metric_df[
    (metric_df["timestamp"] >= start)
    & (metric_df["timestamp"] <= end)
    & (metric_df["cmdb_id"].isin(appearing))
].copy()

# rows in window per component-kpi
rows_in_window = (
    df_window.groupby(["cmdb_id", "kpi_name"], as_index=False).size().rename(columns={"size": "rows_in_window"})
)

# join global_p95 into window to evaluate exceedances
window_with_p95 = df_window.merge(global_p95, on=["cmdb_id", "kpi_name"], how="left")

# anomalies: value > global_p95
anomaly_mask = window_with_p95["value"] > window_with_p95["global_p95"]
anomalies = (
    window_with_p95[anomaly_mask]
    .groupby(["cmdb_id", "kpi_name"], as_index=False)
    .agg(rows_exceeding_p95=("value", "size"), earliest_anomaly_timestamp_in_window=("timestamp", "min"))
)

# assemble final table
result = (
    global_p95
    .merge(rows_in_window, on=["cmdb_id", "kpi_name"], how="left")
    .merge(anomalies, on=["cmdb_id", "kpi_name"], how="left")
)

# fill defaults and format earliest timestamp as ISO UTC or null
result["rows_in_window"] = result["rows_in_window"].fillna(0).astype(int)
result["rows_exceeding_p95"] = result["rows_exceeding_p95"].fillna(0).astype(int)
result["earliest_anomaly_timestamp_in_window"] = result["earliest_anomaly_timestamp_in_window"].dt.strftime("%Y-%m-%dT%H:%M:%SZ")
result["earliest_anomaly_timestamp_in_window"] = result["earliest_anomaly_timestamp_in_window"].where(result["rows_exceeding_p95"]>0, None)

# final columns and rename cmdb_id -> component
result_df = result.rename(columns={"cmdb_id": "component"})[
    ["component", "kpi_name", "global_p95", "rows_in_window", "rows_exceeding_p95", "earliest_anomaly_timestamp_in_window"]
]

# keep it compact and limit to existing rows (max 100)
result_df = result_df.sort_values(by=["rows_exceeding_p95", "rows_in_window"], ascending=False).head(100)

appearing, result_df
