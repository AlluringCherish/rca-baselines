import pandas as pd
import numpy as np

# reuse trace_df if available, otherwise load and parse timestamp as UTC
if "trace_df" not in globals():
    trace_df = pd.read_csv("trace.csv")
    trace_df["timestamp"] = pd.to_datetime(trace_df["timestamp"], unit="s", utc=True)
else:
    if not pd.api.types.is_datetime64_any_dtype(trace_df["timestamp"]):
        trace_df["timestamp"] = pd.to_datetime(trace_df["timestamp"], unit="s", utc=True)
    else:
        if trace_df["timestamp"].dt.tz is None:
            trace_df["timestamp"] = trace_df["timestamp"].dt.tz_localize("UTC")

# candidate services
candidates = ["ts-auth-service", "ts-order-service", "ts-route-service", "ts-train-service", "ts-travel-service"]

# 1) select trace entries that reference any candidate service (match substring)
pattern = "|".join(candidates)
selected_traces_df = trace_df[trace_df["trace_name"].str.contains(pattern, na=False)].copy()

# derive feature_type from trace_name (last token after dot)
selected_traces_df["feature_type"] = selected_traces_df["trace_name"].str.split(".").str[-1]

# 2) compute global P95 for each trace_name using full available series
global_p95_df = (
    selected_traces_df
    .groupby("trace_name", as_index=False)["value"]
    .quantile(0.95)
    .rename(columns={"value": "global_p95"})
)

# compute global P05 for trace_names where feature_type == 'row_count' (used for row_count anomaly detection)
p05_df = (
    selected_traces_df[selected_traces_df["feature_type"] == "row_count"]
    .groupby("trace_name", as_index=False)["value"]
    .quantile(0.05)
    .rename(columns={"value": "global_p05"})
)

# merge p05 into global_p95_df (will be NaN for non-row_count features)
global_p95_df = global_p95_df.merge(p05_df, on="trace_name", how="left")

# 3) filter to incident window
start = pd.to_datetime("2024-02-20 15:31:23", utc=True)
end = pd.to_datetime("2024-02-20 16:01:23", utc=True)
window_df = selected_traces_df[(selected_traces_df["timestamp"] >= start) & (selected_traces_df["timestamp"] <= end)].copy()
window_df = window_df.sort_values(["trace_name", "timestamp"])

# prepare per-trace_name metrics
results = []
trace_names = global_p95_df["trace_name"].unique()

for tn in trace_names:
    grow = global_p95_df[global_p95_df["trace_name"] == tn].iloc[0]
    g95 = float(grow["global_p95"]) if not pd.isna(grow["global_p95"]) else None
    g05 = float(grow["global_p05"]) if ("global_p05" in grow and not pd.isna(grow["global_p05"])) else None

    grp = window_df[window_df["trace_name"] == tn].sort_values("timestamp")
    rows_in_window = int(len(grp))
    if rows_in_window == 0:
        rows_exceeding = 0
        earliest_anom = None
        max_val = None
        breach_ratio = None
    else:
        vals = grp["value"].to_numpy()
        feature = grp["feature_type"].iloc[0]

        if feature == "row_count":
            # anomaly if value <= global_p05 (if available); else treat no anomalies
            if g05 is None:
                mask = np.zeros_like(vals, dtype=bool)
            else:
                mask = vals <= g05
        else:
            # duration_mean, duration_p95, error_rate: anomaly if value > global_p95
            if g95 is None:
                mask = np.zeros_like(vals, dtype=bool)
            else:
                mask = vals > g95

        rows_exceeding = int(np.sum(mask))
        earliest_anom = grp.loc[mask, "timestamp"].min() if rows_exceeding > 0 else None
        earliest_anom = earliest_anom.strftime("%Y-%m-%dT%H:%M:%SZ") if earliest_anom is not None else None

        max_val = float(np.nanmax(vals))

        if g95 in (0, None) or pd.isna(g95):
            breach_ratio = None
        else:
            breach_ratio = float((max_val - g95) / g95)

    # assemble row
    results.append({
        "trace_name": tn,
        "feature_type": tn.split(".")[-1],
        "global_p95": g95,
        "rows_in_window": rows_in_window,
        "rows_exceeding_p95": rows_exceeding,
        "earliest_anomaly_timestamp_in_window": earliest_anom,
        "max_value_in_window": max_val,
        "breach_ratio": breach_ratio
    })

res_df = pd.DataFrame(results)

# 4) sort by rows_exceeding_p95 desc then breach_ratio desc, limit top 20
# ensure breach_ratio NaNs sort last
res_df["breach_sort"] = res_df["breach_ratio"].fillna(-np.inf)
res_df = res_df.sort_values(by=["rows_exceeding_p95", "breach_sort"], ascending=[False, False]).drop(columns=["breach_sort"])

output_df = res_df[
    ["trace_name", "feature_type", "global_p95", "rows_in_window", "rows_exceeding_p95",
     "earliest_anomaly_timestamp_in_window", "max_value_in_window", "breach_ratio"]
].head(20)

# display compact result
output_df
