import pandas as pd
import numpy as np

# reuse metric_df and global_p95 if present; otherwise load/compute
if "metric_df" not in globals():
    metric_df = pd.read_csv("metric.csv")
    metric_df["timestamp"] = pd.to_datetime(metric_df["timestamp"], unit="s", utc=True)
else:
    if not pd.api.types.is_datetime64_any_dtype(metric_df["timestamp"]):
        metric_df["timestamp"] = pd.to_datetime(metric_df["timestamp"], unit="s", utc=True)
    else:
        if metric_df["timestamp"].dt.tz is None:
            metric_df["timestamp"] = metric_df["timestamp"].dt.tz_localize("UTC")

if "global_p95" not in globals():
    global_p95 = (
        metric_df
        .groupby(["cmdb_id", "kpi_name"], as_index=False)["value"]
        .quantile(0.95)
        .rename(columns={"value": "global_p95"})
    )

# target component and incident window
component = "ts-order-service"
start = pd.to_datetime("2024-02-20 15:31:23", utc=True)
end = pd.to_datetime("2024-02-20 16:01:23", utc=True)

# get global p95s for this component
gp = global_p95[global_p95["cmdb_id"] == component].copy()
kpis = gp["kpi_name"].unique().tolist()

# windowed data for the component
comp_window = metric_df[
    (metric_df["cmdb_id"] == component)
    & (metric_df["timestamp"] >= start)
    & (metric_df["timestamp"] <= end)
].sort_values(["kpi_name", "timestamp"]).copy()

results = []
for kpi in kpis:
    row = gp[gp["kpi_name"] == kpi].iloc[0]
    p95 = float(row["global_p95"]) if not pd.isna(row["global_p95"]) else None

    grp = comp_window[comp_window["kpi_name"] == kpi].sort_values("timestamp")
    rows_in_window = len(grp)
    if rows_in_window == 0:
        rows_exceeding = 0
        earliest_anom = None
        max_val = None
        breach_ratio = None
        longest_run = 0
        start_longest = None
    else:
        vals = grp["value"].to_numpy()
        # anomaly condition: value > global_p95 (per instructions)
        if p95 is None:
            mask = np.zeros_like(vals, dtype=bool)
        else:
            mask = vals > p95

        rows_exceeding = int(np.sum(mask))
        earliest_anom_ts = grp.loc[mask, "timestamp"].min() if rows_exceeding > 0 else None
        earliest_anom = earliest_anom_ts.strftime("%Y-%m-%dT%H:%M:%SZ") if earliest_anom_ts is not None and not pd.isna(earliest_anom_ts) else None

        max_val = float(np.nanmax(vals))

        if p95 in (0, None) or pd.isna(p95):
            breach_ratio = None
        else:
            breach_ratio = float((max_val - p95) / p95)

        # consecutive anomaly runs (consecutive rows where mask True)
        arr = mask.astype(int)
        padded = np.r_[0, arr, 0]
        diff = np.diff(padded)
        starts = np.where(diff == 1)[0]
        ends = np.where(diff == -1)[0]
        lengths = ends - starts
        if len(lengths) == 0:
            longest_run = 0
            start_longest = None
        else:
            longest_run = int(np.max(lengths))
            idx_of_longest = int(np.argmax(lengths))
            start_idx = starts[idx_of_longest]
            start_ts = grp["timestamp"].iloc[start_idx]
            start_longest = start_ts.strftime("%Y-%m-%dT%H:%M:%SZ")

    results.append({
        "kpi_name": kpi,
        "global_p95": p95,
        "rows_in_window": int(rows_in_window),
        "rows_exceeding_p95": int(rows_exceeding),
        "earliest_anomaly_timestamp_in_window": earliest_anom,
        "max_value_in_window": max_val,
        "breach_ratio": breach_ratio,
        "longest_run_length": int(longest_run),
        "start_timestamp_of_longest_run": start_longest
    })

res_df = pd.DataFrame(results)

# sort by breach_ratio desc (None last) then longest_run_length desc
res_df["breach_sort"] = res_df["breach_ratio"].fillna(-np.inf)
res_df = res_df.sort_values(by=["breach_sort", "longest_run_length"], ascending=[False, False]).drop(columns=["breach_sort"])

# final compact output (all KPIs for ts-order-service)
output_df = res_df[
    ["kpi_name", "global_p95", "rows_in_window", "rows_exceeding_p95",
     "earliest_anomaly_timestamp_in_window", "max_value_in_window", "breach_ratio",
     "longest_run_length", "start_timestamp_of_longest_run"]
]

