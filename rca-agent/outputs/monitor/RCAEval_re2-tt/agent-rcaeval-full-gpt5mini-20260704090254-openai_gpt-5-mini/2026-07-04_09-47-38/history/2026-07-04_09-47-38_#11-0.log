import pandas as pd

# Reuse existing metric_df from previous run
# 1) Compute global P95 and total global count per (cmdb_id, kpi_name) using full series
metric_global = (
    metric_df
    .groupby(['cmdb_id', 'kpi_name'], dropna=False)['value']
    .agg(global_p95=lambda s: s.quantile(0.95), total_count_global='count')
