import pandas as pd
import numpy as np

# Reuse existing 'metric' if present, otherwise load
try:
    metric
except NameError:
    metric = pd.read_csv("metric.csv")
    metric['timestamp'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)
    # normalize kpi_name column if necessary
    if 'kpi_name' not in metric.columns and 'kpi' in metric.columns:
        metric = metric.rename(columns={'kpi': 'kpi_name'})
    # add kpi_name if missing but present under other name (defensive)
    if 'kpi_name' not in metric.columns and 'kpi' in metric.columns:
        metric['kpi_name'] = metric['kpi']

# Ensure timestamp is parsed and kpi_name exists
metric['timestamp'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)
if 'kpi_name' not in metric.columns and 'kpi' in metric.columns:
    metric = metric.rename(columns={'kpi': 'kpi_name'})

# Target services
services = ["ts-auth-service","ts-order-service","ts-route-service","ts-train-service","ts-travel-service"]

# Compute global P95 per (cmdb_id, kpi_name) using the full series (no time filter)
metric_filtered_services = metric[metric['cmdb_id'].isin(services)].copy()
global_p95_df = metric_filtered_services.groupby(['cmdb_id', 'kpi_name'], as_index=False)['value'].quantile(0.95)
global_p95_df = global_p95_df.rename(columns={'value': 'global_p95'})

# Total number of groups examined for these five services
total_groups = global_p95_df.shape[0]

# Define incident window (UTC) using pd.to_datetime(..., unit='s', utc=True)
start = pd.to_datetime('2024-01-25 16:45:00', utc=True)
end = pd.to_datetime('2024-01-25 17:15:00', utc=True)

# Filter metric to services and to the incident window
window_df = metric_filtered_services[
    (metric_filtered_services['timestamp'] >= start) &
    (metric_filtered_services['timestamp'] <= end)
].copy()

# If no data in window, produce empty results with counts zero
if window_df.empty:
    final_df = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','count_in_window','count_anomalies_in_window',
        'earliest_anomaly_timestamp','max_value_in_window','global_p95'
    ])
else:
    # Merge global_p95 into windowed data so we can evaluate anomalies
    window_with_p95 = window_df.merge(global_p95_df, on=['cmdb_id','kpi_name'], how='left')

    # Flag anomalies where value >= global_p95
    window_with_p95['is_anomaly'] = window_with_p95['value'] >= window_with_p95['global_p95']

    # Aggregate per group
    agg = window_with_p95.groupby(['cmdb_id','kpi_name'], as_index=False).agg(
        count_in_window = ('value','count'),
        count_anomalies_in_window = ('is_anomaly','sum'),
        # earliest anomaly timestamp (min of timestamps where is_anomaly True)
        earliest_anomaly_timestamp = (lambda df: df.loc[df['is_anomaly'],'timestamp'].min()),
        max_value_in_window = ('value','max'),
        global_p95 = ('global_p95','first')
    )

    # The custom aggregate for earliest_anomaly_timestamp produced a column with name 0 due to lambda; fix by recomputing properly
    # Recompute earliest anomaly timestamp more explicitly
    earliest = window_with_p95[window_with_p95['is_anomaly']].groupby(['cmdb_id','kpi_name'], as_index=False)['timestamp'].min()
    earliest = earliest.rename(columns={'timestamp':'earliest_anomaly_timestamp'})
    agg = agg.drop(columns=['earliest_anomaly_timestamp'])
    agg = agg.merge(earliest, on=['cmdb_id','kpi_name'], how='left')

    # Convert earliest_anomaly_timestamp to integer seconds or null
    agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_timestamp'].dt.tz_convert('UTC')
    # Convert to integer seconds
    agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_timestamp'].view('int64') // 10**9
    # For groups with no anomaly, the merge produced NaN; keep as NaN (will show as NaN)
    agg.loc[agg['count_anomalies_in_window']==0, 'earliest_anomaly_timestamp'] = np.nan

    # Ensure integer counts
    agg['count_in_window'] = agg['count_in_window'].astype(int)
    agg['count_anomalies_in_window'] = agg['count_anomalies_in_window'].astype(int)

    # Select and order columns as requested
    final_df = agg[[
        'cmdb_id','kpi_name','count_in_window','count_anomalies_in_window',
        'earliest_anomaly_timestamp','max_value_in_window','global_p95'
    ]].copy()

# Sort by count_anomalies_in_window desc then global_p95 desc and limit to 20
final_df = final_df.sort_values(by=['count_anomalies_in_window','global_p95'], ascending=[False, False]).head(20).reset_index(drop=True)

# Display compact results: final_df and total_groups
final_df, total_groups
