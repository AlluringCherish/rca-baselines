import pandas as pd

# Load CSVs
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")
log_df = pd.read_csv("log.csv")
error_logs_df = pd.read_csv("error_logs.csv")

# Ensure timestamp ints and also parse datetimes in UTC
for df in (metric_df, trace_df, log_df, error_logs_df):
    # ensure integer timestamps (some CSVs may have floats)
    df['timestamp'] = df['timestamp'].astype(int)
    df['ts_dt'] = pd.to_datetime(df['timestamp'], unit='s', utc=True)

# 1) File-level min/max timestamps (as integers)
file_coverage = pd.DataFrame([
    {"file": "metric.csv", "min_ts": int(metric_df['timestamp'].min()), "max_ts": int(metric_df['timestamp'].max())},
    {"file": "trace.csv",  "min_ts": int(trace_df['timestamp'].min()),  "max_ts": int(trace_df['timestamp'].max())},
    {"file": "log.csv",    "min_ts": int(log_df['timestamp'].min()),    "max_ts": int(log_df['timestamp'].max())},
    {"file": "error_logs.csv", "min_ts": int(error_logs_df['timestamp'].min()), "max_ts": int(error_logs_df['timestamp'].max())},
])

# 2) Unique component list across all files (compact)
unique_cmdb = sorted(set(metric_df['cmdb_id'].unique()).union(
                     set(trace_df['cmdb_id'].unique()),
                     set(log_df['cmdb_id'].unique()),
                     set(error_logs_df['cmdb_id'].unique())))
# Keep it compact (it should be short already); show as list
unique_cmdb_list = unique_cmdb

# Helper to create summaries
def summary_from_group(df, group_cols, value_col):
    g = df.groupby(group_cols)[value_col].agg(
        count='count',
        p95=lambda x: x.quantile(0.95),
        p50=lambda x: x.quantile(0.5),
        mean='mean'
    ).reset_index()
    # round numeric columns for compactness
    for c in ['p95', 'p50', 'mean']:
        g[c] = g[c].round(6)
    g = g.sort_values('count', ascending=False).reset_index(drop=True)
    return g

# 3) Metrics summary: group by (cmdb_id, kpi_name)
metric_summary = summary_from_group(metric_df, ['cmdb_id', 'kpi_name'], 'value').head(20)

# 4) Trace summary: group by (cmdb_id, trace_name)
trace_summary = summary_from_group(trace_df, ['cmdb_id', 'trace_name'], 'value').head(20)

# 5) Log summary: group by (cmdb_id, log_name)
log_summary = summary_from_group(log_df, ['cmdb_id', 'log_name'], 'value').head(20)

# Display compact results (variables)
metric_summary, trace_summary, log_summary, file_coverage, unique_cmdb_list
