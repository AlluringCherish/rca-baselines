import pandas as pd

# Reuse existing variables: trace_summary, candidates, trace_window
# Ensure trace_summary exists; if not, rebuild minimal summary from trace_window
try:
    trace_summary
except NameError:
    # Build the same trace_summary as before (compact per-trace_name aggregation)
    service_pattern = re.compile(r"(ts-[a-z0-9\-]+-service)")
    def extract_services(name):
        if pd.isna(name):
            return []
        found = service_pattern.findall(str(name))
        return list(dict.fromkeys(found))
    agg = (
        trace_window
        .groupby('trace_name', dropna=False)
        .agg(
            window_count=('trace_name','count'),
            emitters_list=('cmdb_id', lambda s: sorted(pd.Series(s).dropna().unique().tolist())),
            earliest_ts=('timestamp','min')
        )
        .reset_index()
    )
    agg['involved_services'] = agg['trace_name'].apply(extract_services)
    agg['involved_candidates'] = agg['involved_services'].apply(lambda lst: sorted(list(set(lst) & candidates)))
    trace_summary = agg[agg['involved_candidates'].map(len) > 0].rename(columns={'emitters_list':'emitters'})

# Helper to compute intersections per row
def intersect_emitters_emitters(row):
    emitters = row['emitters'] if isinstance(row['emitters'], (list, tuple)) else []
    involved = row['involved_services'] if isinstance(row['involved_services'], (list, tuple)) else []
    emitters_intersection = sorted(list(set(emitters) & candidates))
    involved_candidates = sorted(list(set(involved) & candidates))
    return pd.Series({
        'emitters_intersection': emitters_intersection,
        'involved_candidates': involved_candidates
    })

# Apply intersections
intersections = trace_summary.apply(intersect_emitters_emitters, axis=1)
trace_enriched = pd.concat([trace_summary.reset_index(drop=True), intersections], axis=1)

# Condition: at least one emitter is in candidates AND involved_candidates contains at least one candidate different from the emitter(s)
def qualifies(row):
    e = set(row['emitters_intersection'])
    i = set(row['involved_candidates'])
    return (len(e) > 0) and (len(i) > 0) and (len(i - e) > 0)

trace_enriched['qualifies'] = trace_enriched.apply(qualifies, axis=1)

# Filter matches and select requested columns, sort by window_count desc, limit 50
