        # ensure column order as requested
        [['cmdb_id', 'trace_name', 'count', 'earliest_timestamp', 'min_value', 'mean_value', 'max_value']]
    )
    no_matching_traces = ""

# Return compact results
trace_aggregates, no_matching_traces
