    trace['timestamp'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True)

# Ensure timestamp is parsed (idempotent)
trace['timestamp'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True)

# Candidate services
candidates = [
    "ts-auth-service",
    "ts-order-service",
    "ts-route-service",
    "ts-train-service",
    "ts-travel-service"
]

# Compute global P95 for each (cmdb_id, trace_name) using the full available series
trace_p95 = (
    trace
    .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# Incident window (UTC)
start = pd.to_datetime("2024-01-24 01:15:03", utc=True)
end = pd.to_datetime("2024-01-24 01:45:03", utc=True)

# Filter to window
trace_win = trace[(trace['timestamp'] >= start) & (trace['timestamp'] <= end)].copy()

# Build regex to match from_ts-<service> or to_ts-<service>
escaped = [re.escape(s) for s in candidates]
pattern = r"(from_ts-(?:{}))|(to_ts-(?:{}))".format("|".join(escaped), "|".join(escaped))

mask = trace_win['trace_name'].str.contains(pattern, regex=True, na=False)
trace_win_cand = trace_win[mask].copy()

# Merge with global p95
trace_win_cand = trace_win_cand.merge(trace_p95, on=['cmdb_id', 'trace_name'], how='left')

# Aggregate required metrics per (cmdb_id, trace_name)
rows = []
grp = trace_win_cand.groupby(['cmdb_id', 'trace_name'], sort=False)
for (cmdb_id, trace_name), g in grp:
    total_points = int(len(g))
    p95 = g['global_p95'].iloc[0] if 'global_p95' in g.columns else float('nan')
    mean_val = float(g['value'].mean())
    if pd.isna(p95):
        high_count = 0
        first_high_ts = None
