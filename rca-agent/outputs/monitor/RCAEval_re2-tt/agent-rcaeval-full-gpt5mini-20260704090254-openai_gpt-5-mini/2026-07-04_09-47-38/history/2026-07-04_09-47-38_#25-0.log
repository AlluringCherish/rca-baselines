import pandas as pd
import re

# Reuse existing 'trace' if available; otherwise load and parse timestamps
try:
    trace
except NameError:
    trace = pd.read_csv("trace.csv")
    trace['timestamp'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True)

# Candidate services
candidates = [
    "ts-auth-service",
    "ts-order-service",
    "ts-route-service",
    "ts-train-service",
    "ts-travel-service"
]

# 1) Compute global P95 for each (cmdb_id, trace_name) using the full series
trace_p95 = (
    trace
    .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'p95'})
)

# 2) Filter trace rows to the incident window (UTC)
start = pd.to_datetime("2024-01-24 01:15:03", utc=True)
end = pd.to_datetime("2024-01-24 01:45:03", utc=True)
trace_win = trace[(trace['timestamp'] >= start) & (trace['timestamp'] <= end)].copy()

# 3) Select trace rows whose trace_name mentions candidate services via from_ts-<service> or to_ts-<service>
# Build regex to match either "from_ts-<service>" or "to_ts-<service>" for any candidate
escaped = [re.escape(s) for s in candidates]
pattern = r"(from_ts-(?:{}))|(to_ts-(?:{}))".format("|".join(escaped), "|".join(escaped))
mask = trace_win['trace_name'].str.contains(pattern, regex=True, na=False)
trace_win_cand = trace_win[mask].copy()

# 4) Merge with global p95 so each in-window row carries its group's p95
trace_win_cand = trace_win_cand.merge(trace_p95, on=['cmdb_id', 'trace_name'], how='left')

# 5) For each (cmdb_id, trace_name) compute required metrics:
# (a) total points in-window
# (b) global P95
# (c) number of in-window values >= global P95
# (d) earliest timestamp in-window where value >= global P95 (UTC ISO) if any
# (e) mean value in-window

grp = trace_win_cand.groupby(['cmdb_id', 'trace_name'], sort=False)

rows = []
for (cmdb_id, trace_name), g in grp:
    total_points = len(g)
    p95 = g['p95'].iloc[0]  # global p95
    # count breaches >= p95 (treat NaN p95 as no breach)
    if pd.isna(p95):
        high_count = 0
        first_high_ts = None
    else:
        high_mask = g['value'] >= p95
        high_count = int(high_mask.sum())
        if high_count > 0:
            first_high_ts = g.loc[high_mask, 'timestamp'].min().isoformat()
        else:
            first_high_ts = None
