import pandas as pd
import numpy as np

# Reuse existing metric_df (assumed loaded and timestamp parsed). Ensure timestamp is datetime UTC.
metric_df['timestamp'] = pd.to_datetime(metric_df['timestamp'], unit=None, utc=True)

# 1) Calculate global P95 per (cmdb_id, kpi_name) across the entire metric series (do NOT filter first)
global_p95 = (
    metric_df
    .groupby(['cmdb_id', 'kpi_name'], dropna=False)['value']
    .quantile(0.95)
    .reset_index(name='global_p95')
)

# 2) Define incident window (UTC) and filter metric_df to that window (inclusive)
start = pd.to_datetime("2024-01-24 18:55:46", utc=True)
end = pd.to_datetime("2024-01-24 19:25:46", utc=True)
window_df = metric_df[(metric_df['timestamp'] >= start) & (metric_df['timestamp'] <= end)].copy()

# 3) Compute window-level aggregates per (cmdb_id, kpi_name)
window_stats = (
    window_df
    .groupby(['cmdb_id', 'kpi_name'], dropna=False)
    .agg(total_points_in_window=('value', 'size'),
         max_value_in_window=('value', 'max'))
    .reset_index()
)

# 4) Determine exceedances by merging window rows with global_p95 and finding value > global_p95
merged_window = pd.merge(window_df, global_p95, on=['cmdb_id', 'kpi_name'], how='left')

# Mark exceedances (strictly greater than global P95)
exceed_df = merged_window[merged_window['value'] > merged_window['global_p95']].copy()

