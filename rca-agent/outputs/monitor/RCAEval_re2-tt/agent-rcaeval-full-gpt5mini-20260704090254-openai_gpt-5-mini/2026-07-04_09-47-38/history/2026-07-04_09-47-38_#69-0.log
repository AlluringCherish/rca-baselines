import pandas as pd

# File to KPI column mapping
files_info = {
    "metric.csv": "kpi_name",
    "trace.csv": "trace_name",
    "log.csv": "log_name",
    "error_logs.csv": "message",
}

# Load files, parse timestamps, and collect summaries
summaries = {}
for fname, kpi_col in files_info.items():
    # read csv
    df = pd.read_csv(fname)
    # parse timestamp to UTC datetime (Unix seconds)
    df["timestamp"] = pd.to_datetime(df["timestamp"], unit="s", utc=True)
    # basic summary fields
    number_of_rows = int(len(df))
    min_timestamp = df["timestamp"].min().isoformat() if number_of_rows > 0 else None
    max_timestamp = df["timestamp"].max().isoformat() if number_of_rows > 0 else None
    unique_cmdb_ids = sorted(df["cmdb_id"].dropna().unique().tolist())
    # top 20 values and their counts for the KPI column
    if kpi_col in df.columns:
        top20_counts = df[kpi_col].value_counts(dropna=False).head(20).reset_index()
        top20_counts.columns = [kpi_col, "count"]
    else:
        # fallback empty DataFrame if KPI column missing
        top20_counts = pd.DataFrame(columns=[kpi_col, "count"])
    # Build compact summary dictionary for this file
    summaries[fname] = {
        "number_of_rows": number_of_rows,
        "min_timestamp": min_timestamp,
        "max_timestamp": max_timestamp,
        "unique_cmdb_ids": unique_cmdb_ids,
        # keep top20 as a small DataFrame for compact display
        "top20": top20_counts
    }

# Display summaries (variable output). This will show the dictionary keys and the compact top20 DataFrames.
summaries
