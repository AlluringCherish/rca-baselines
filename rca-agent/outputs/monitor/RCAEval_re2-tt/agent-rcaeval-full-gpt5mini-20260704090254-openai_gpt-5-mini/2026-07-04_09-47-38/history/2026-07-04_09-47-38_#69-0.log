import pandas as pd

# Load metric.csv and parse timestamp to UTC datetime
df_metric = pd.read_csv("metric.csv")
df_metric["timestamp"] = pd.to_datetime(df_metric["timestamp"], unit="s", utc=True)

# Candidate components
candidates = ["ts-auth-service","ts-order-service","ts-route-service","ts-train-service","ts-travel-service"]

# Restrict to candidate components
df_cand = df_metric[df_metric["cmdb_id"].isin(candidates)].copy()

# If no matching rows, produce empty result
if df_cand.shape[0] == 0:
    result_df = pd.DataFrame(columns=[
        "cmdb_id","kpi_name","global_p95","global_p90","global_p5",
        "total_points_in_window","points_above_global_P95",
        "earliest_timestamp_above_P95","max_value_in_window"
    ])
else:
    # Compute global percentiles per (cmdb_id, kpi_name) using the entire series for that pair
    global_stats = (
        df_cand
        .groupby(["cmdb_id", "kpi_name"])["value"]
        .agg(global_p95=lambda x: x.quantile(0.95),
             global_p90=lambda x: x.quantile(0.90),
             global_p5 = lambda x: x.quantile(0.05))
        .reset_index()
    )

    # Define incident window (UTC)
    window_start = pd.to_datetime("2024-01-23 07:53:37", utc=True)
    window_end   = pd.to_datetime("2024-01-23 08:23:37", utc=True)

    # Filter candidate data to the incident window
    df_window = df_cand[(df_cand["timestamp"] >= window_start) & (df_cand["timestamp"] <= window_end)].copy()

    # Merge global stats into windowed rows to allow per-row comparison to global P95
    df_win_merged = df_window.merge(global_stats, on=["cmdb_id","kpi_name"], how="left")

    # Aggregations in window
    total_points = df_win_merged.groupby(["cmdb_id","kpi_name"]).size().rename("total_points_in_window")
    max_value = df_win_merged.groupby(["cmdb_id","kpi_name"])["value"].max().rename("max_value_in_window")

    # Points above global P95 (strict >)
    above_p95_mask = df_win_merged["value"] > df_win_merged["global_p95"]
    points_above = df_win_merged[above_p95_mask].groupby(["cmdb_id","kpi_name"]).size().rename("points_above_global_P95")
    earliest_above = (
        df_win_merged[above_p95_mask]
        .groupby(["cmdb_id","kpi_name"])["timestamp"]
        .min()
        .rename("earliest_timestamp_above_P95")
    )

    # Combine into a single DataFrame indexed by (cmdb_id, kpi_name)
    result = global_stats.set_index(["cmdb_id","kpi_name"]).join(total_points).join(points_above).join(earliest_above).join(max_value)

