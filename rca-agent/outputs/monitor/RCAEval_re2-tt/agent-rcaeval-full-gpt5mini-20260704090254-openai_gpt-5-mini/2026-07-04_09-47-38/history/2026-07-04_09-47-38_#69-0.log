import pandas as pd

# Load trace.csv and parse timestamp to UTC datetime (reuse variable name if present)
df_trace = pd.read_csv("trace.csv")
df_trace["timestamp"] = pd.to_datetime(df_trace["timestamp"], unit="s", utc=True)

# Tokens to match in trace_name
tokens = ["ts-auth-service","ts-order-service","ts-route-service","ts-train-service","ts-travel-service"]

# Find trace_name values that mention any of the tokens
mask_name = df_trace["trace_name"].apply(lambda x: any(tok in x for tok in tokens))
matching_trace_names = sorted(df_trace.loc[mask_name, "trace_name"].dropna().unique().tolist())

# If none match, return empty DataFrame with the required columns
cols = [
    "trace_name","global_p95","global_p90","global_p5",
    "total_points_in_window","points_above_global_P95",
    "earliest_timestamp_above_P95","max_value_in_window"
]
if len(matching_trace_names) == 0:
    result_df = pd.DataFrame(columns=cols)
else:
    # 1) Compute global percentiles per trace_name using the entire series (no window filtering)
    global_stats = (
        df_trace[df_trace["trace_name"].isin(matching_trace_names)]
        .groupby("trace_name")["value"]
        .agg(
            global_p95=lambda x: x.quantile(0.95),
            global_p90=lambda x: x.quantile(0.90),
            global_p5 = lambda x: x.quantile(0.05)
        )
        .reset_index()
    )

    # Incident window (UTC)
    window_start = pd.to_datetime("2024-01-23 07:53:37", utc=True)
    window_end   = pd.to_datetime("2024-01-23 08:23:37", utc=True)

    # 2) Filter rows to the incident window and restrict to matching trace_names
    df_window = df_trace[
        (df_trace["timestamp"] >= window_start) &
        (df_trace["timestamp"] <= window_end) &
        (df_trace["trace_name"].isin(matching_trace_names))
    ].copy()

    # Merge global stats into windowed rows to compare per-row against global P95
    df_win_merged = df_window.merge(global_stats, on="trace_name", how="left")

    # Aggregations in window
    total_points = df_win_merged.groupby("trace_name").size().rename("total_points_in_window")
    max_value = df_win_merged.groupby("trace_name")["value"].max().rename("max_value_in_window")

    # Points above global P95 (strict >)
    above_mask = df_win_merged["value"] > df_win_merged["global_p95"]
    points_above = df_win_merged[above_mask].groupby("trace_name").size().rename("points_above_global_P95")
    earliest_above = df_win_merged[above_mask].groupby("trace_name")["timestamp"].min().rename("earliest_timestamp_above_P95")

    # Combine results
    result = (
        global_stats.set_index("trace_name")
        .join(total_points)
        .join(points_above)
        .join(earliest_above)
        .join(max_value)
    )

    # Fill missing values and format columns
    result["total_points_in_window"] = result["total_points_in_window"].fillna(0).astype(int)
    result["points_above_global_P95"] = result["points_above_global_P95"].fillna(0).astype(int)
    result["earliest_timestamp_above_P95"] = result["earliest_timestamp_above_P95"].dt.tz_convert("UTC").apply(lambda x: x.isoformat() if pd.notnull(x) else None)
    result["max_value_in_window"] = result["max_value_in_window"]

    # Round numeric percentiles/max for compact display
    result["global_p95"] = result["global_p95"].round(6)
    result["global_p90"] = result["global_p90"].round(6)
    result["global_p5"]  = result["global_p5"].round(6)
    result["max_value_in_window"] = result["max_value_in_window"].round(6)

    result_df = result.reset_index()[cols]

    # Sort by points_above_global_P95 desc, then max_value_in_window desc
    result_df = result_df.sort_values(by=["points_above_global_P95","max_value_in_window"], ascending=[False, False])

# Display compact table (top 20 rows)
result_df.head(20)
