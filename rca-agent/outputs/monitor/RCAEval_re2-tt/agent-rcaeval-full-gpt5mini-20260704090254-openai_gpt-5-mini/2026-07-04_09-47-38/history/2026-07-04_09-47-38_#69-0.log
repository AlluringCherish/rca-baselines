import pandas as pd

# Load log.csv and parse timestamp to UTC datetime
df_log = pd.read_csv("log.csv")
df_log["timestamp"] = pd.to_datetime(df_log["timestamp"], unit="s", utc=True)

# Candidate services
candidates = ["ts-order-service","ts-travel-service","ts-train-service","ts-route-service","ts-auth-service"]

# Restrict to candidate services
df_cand = df_log[df_log["cmdb_id"].isin(candidates)].copy()

# Prepare output columns
cols = [
    "cmdb_id","log_name","global_p95","global_p90","global_p5",
    "total_points_in_window","points_above_global_P95",
    "earliest_timestamp_above_P95","max_value_in_window"
]

# If no matching rows, produce empty DataFrame with required columns
if df_cand.shape[0] == 0:
    result_df = pd.DataFrame(columns=cols)
else:
    # 1) Compute global percentiles per (cmdb_id, log_name) using full series (before filtering by window)
    global_stats = (
        df_cand
        .groupby(["cmdb_id","log_name"])["value"]
        .agg(
            global_p95=lambda x: x.quantile(0.95),
            global_p90=lambda x: x.quantile(0.90),
            global_p5 = lambda x: x.quantile(0.05)
        )
        .reset_index()
    )

    # Incident window (UTC)
    window_start = pd.to_datetime("2024-01-23 07:53:37", utc=True)
    window_end   = pd.to_datetime("2024-01-23 08:23:37", utc=True)

    # 2) Filter rows to the incident window
    df_window = df_cand[(df_cand["timestamp"] >= window_start) & (df_cand["timestamp"] <= window_end)].copy()

    # Merge global stats into windowed rows for comparison
    df_win_merged = df_window.merge(global_stats, on=["cmdb_id","log_name"], how="left")

    # Aggregations in window
    total_points = df_win_merged.groupby(["cmdb_id","log_name"]).size().rename("total_points_in_window")
    max_value = df_win_merged.groupby(["cmdb_id","log_name"])["value"].max().rename("max_value_in_window")

    # Points above global P95 (strict >)
    above_mask = df_win_merged["value"] > df_win_merged["global_p95"]
    points_above = df_win_merged[above_mask].groupby(["cmdb_id","log_name"]).size().rename("points_above_global_P95")
    earliest_above = df_win_merged[above_mask].groupby(["cmdb_id","log_name"])["timestamp"].min().rename("earliest_timestamp_above_P95")

    # Combine results
    result = (
        global_stats.set_index(["cmdb_id","log_name"])
        .join(total_points)
        .join(points_above)
        .join(earliest_above)
        .join(max_value)
    )

    # Fill missing values and format
    result["total_points_in_window"] = result["total_points_in_window"].fillna(0).astype(int)
    result["points_above_global_P95"] = result["points_above_global_P95"].fillna(0).astype(int)
    # Format earliest timestamp or None
    result["earliest_timestamp_above_P95"] = result["earliest_timestamp_above_P95"].dt.tz_convert("UTC").apply(lambda x: x.isoformat() if pd.notnull(x) else None)
    result["max_value_in_window"] = result["max_value_in_window"]

    # Round numeric percentiles/max for compact display
    result["global_p95"] = result["global_p95"].round(6)
    result["global_p90"] = result["global_p90"].round(6)
    result["global_p5"]  = result["global_p5"].round(6)
    result["max_value_in_window"] = result["max_value_in_window"].round(6)

    result_df = result.reset_index()[cols]

    # Sort rows by points_above_global_P95 desc, then max_value_in_window desc
    result_df = result_df.sort_values(by=["points_above_global_P95","max_value_in_window"], ascending=[False, False])

# Display compact table (top 20 rows)
result_df.head(20)
