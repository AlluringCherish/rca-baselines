import pandas as pd
import numpy as np

# Reuse or reload log data to ensure correct parsing
log = pd.read_csv("log.csv")

# Parse timestamps and ensure numeric values
log['ts'] = pd.to_datetime(log['timestamp'], unit='s', utc=True)
log['value'] = pd.to_numeric(log['value'], errors='coerce')

# Components of interest
components = [
    "ts-auth-service",
    "ts-order-service",
    "ts-route-service",
    "ts-train-service",
    "ts-travel-service"
]

# Subset to components of interest (thresholds computed on full series of these components)
log_sub = log[log['cmdb_id'].isin(components)].copy()

# 1) Compute global P95 and P05 and total points using the full series (per pair)
full_stats = (
    log_sub
    .groupby(['cmdb_id', 'log_name'], dropna=False)['value']
    .agg(
        total_points_full_series='count',
        p95_threshold=lambda x: x.quantile(0.95),
        p05_threshold=lambda x: x.quantile(0.05)
    )
    .reset_index()
)

# 2) Filter to incident window (UTC)
start = pd.to_datetime("2024-01-25 15:53:22", utc=True)
end = pd.to_datetime("2024-01-25 16:23:22", utc=True)
log_window = log_sub[(log_sub['ts'] >= start) & (log_sub['ts'] <= end)].copy()

# 3) Window-level basic stats per pair
window_stats = (
    log_window
    .groupby(['cmdb_id', 'log_name'], dropna=False)
    .agg(
        points_in_window=('value', 'count'),
        earliest_ts_in_window=('ts', 'min'),
        latest_ts_in_window=('ts', 'max'),
        max_in_window=('value', 'max')
    )
    .reset_index()
)

# Attach thresholds to in-window rows for anomaly detection
window_with_thresh = pd.merge(
    log_window,
    full_stats,
    on=['cmdb_id', 'log_name'],
    how='left'
)

# Flags for anomalies using global thresholds
window_with_thresh['is_high'] = window_with_thresh['value'] >= window_with_thresh['p95_threshold']
window_with_thresh['is_low'] = window_with_thresh['value'] <= window_with_thresh['p05_threshold']

# High anomaly counts and earliest high timestamp
if not window_with_thresh.empty:
    high_rows = window_with_thresh[window_with_thresh['is_high']]
    high_counts = high_rows.groupby(['cmdb_id', 'log_name'])['is_high'].sum().reset_index(name='anomalies_high_count')
    earliest_high = high_rows.groupby(['cmdb_id', 'log_name'])['ts'].min().reset_index(name='earliest_high_ts')

    low_rows = window_with_thresh[window_with_thresh['is_low']]
    low_counts = low_rows.groupby(['cmdb_id', 'log_name'])['is_low'].sum().reset_index(name='anomalies_low_count')
    earliest_low = low_rows.groupby(['cmdb_id', 'log_name'])['ts'].min().reset_index(name='earliest_low_ts')
else:
    high_counts = pd.DataFrame(columns=['cmdb_id','log_name','anomalies_high_count'])
    earliest_high = pd.DataFrame(columns=['cmdb_id','log_name','earliest_high_ts'])
    low_counts = pd.DataFrame(columns=['cmdb_id','log_name','anomalies_low_count'])
    earliest_low = pd.DataFrame(columns=['cmdb_id','log_name','earliest_low_ts'])

# Merge everything: full thresholds, window stats, anomaly summaries
result = full_stats.merge(window_stats, on=['cmdb_id','log_name'], how='left')
result = result.merge(high_counts, on=['cmdb_id','log_name'], how='left')
result = result.merge(earliest_high, on=['cmdb_id','log_name'], how='left')
result = result.merge(low_counts, on=['cmdb_id','log_name'], how='left')
result = result.merge(earliest_low, on=['cmdb_id','log_name'], how='left')

# Fill missing window-derived values
result['points_in_window'] = result['points_in_window'].fillna(0).astype(int)
result['earliest_ts_in_window'] = pd.to_datetime(result['earliest_ts_in_window'])
result['latest_ts_in_window'] = pd.to_datetime(result['latest_ts_in_window'])
result['max_in_window'] = pd.to_numeric(result['max_in_window'], errors='coerce')

result['anomalies_high_count'] = result['anomalies_high_count'].fillna(0).astype(int)
result['anomalies_low_count'] = result['anomalies_low_count'].fillna(0).astype(int)

# severity_high = max_in_window / p95_threshold (or NaN if p95_threshold == 0 or max_in_window NaN)
result['severity_high'] = result['max_in_window'] / result['p95_threshold']
result.loc[result['p95_threshold'] == 0, 'severity_high'] = np.nan

# Reorder and format columns as requested
cols = [
    'cmdb_id',
    'log_name',
    'p95_threshold',
    'p05_threshold',
    'total_points_full_series',
    'points_in_window',
    'earliest_ts_in_window',
    'latest_ts_in_window',
    'anomalies_high_count',
    'earliest_high_ts',
    'max_in_window',
    'severity_high',
    'anomalies_low_count',
    'earliest_low_ts'
]
result_df = result[cols].sort_values(by=['anomalies_high_count', 'severity_high'], ascending=[False, False])

# Round numeric thresholds and severity for compactness
result_df['p95_threshold'] = result_df['p95_threshold'].round(6)
result_df['p05_threshold'] = result_df['p05_threshold'].round(6)
result_df['max_in_window'] = result_df['max_in_window'].round(6)
result_df['severity_high'] = result_df['severity_high'].round(6)

# Return top 20 rows sorted by anomalies_high_count desc then severity_high desc
result_df.head(20)
