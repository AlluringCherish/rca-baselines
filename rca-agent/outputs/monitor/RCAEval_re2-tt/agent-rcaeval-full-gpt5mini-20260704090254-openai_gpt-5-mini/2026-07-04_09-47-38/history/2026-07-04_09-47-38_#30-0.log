import pandas as pd
import numpy as np

# Load metric data (reuse if exists in kernel to ensure fresh parsing)
metric = pd.read_csv("metric.csv")

# Parse timestamps and ensure numeric values
metric['ts'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)
metric['value'] = pd.to_numeric(metric['value'], errors='coerce')

# Components of interest
components = [
    "ts-auth-service",
    "ts-order-service",
    "ts-route-service",
    "ts-train-service",
    "ts-travel-service"
]

# Subset to only these components for processing (but global thresholds use full series of these components)
metric_sub = metric[metric['cmdb_id'].isin(components)].copy()

# 1) Global P95 and total points for each (cmdb_id, kpi_name) pair using full available series (before any window filtering)
full_stats = (
    metric_sub
    .groupby(['cmdb_id', 'kpi_name'], dropna=False)['value']
    .agg(
        total_points_full_series='count',
        p95_threshold=lambda x: x.quantile(0.95)
    )
    .reset_index()
)

# 2) Filter to incident window (UTC)
start = pd.to_datetime("2024-01-25 15:53:22", utc=True)
end = pd.to_datetime("2024-01-25 16:23:22", utc=True)

metric_window = metric_sub[(metric_sub['ts'] >= start) & (metric_sub['ts'] <= end)].copy()

window_stats = (
    metric_window
    .groupby(['cmdb_id', 'kpi_name'], dropna=False)
    .agg(
        points_in_window=('value', 'count'),
        earliest_ts_in_window=('ts', 'min'),
        latest_ts_in_window=('ts', 'max'),
        mean_in_window=('value', 'mean'),
        max_in_window=('value', 'max')
    )
    .reset_index()
)

# Merge full and window stats. Keep only pairs present in full_stats (i.e., those components' KPI pairs)
result = pd.merge(full_stats, window_stats, on=['cmdb_id', 'kpi_name'], how='left')

# Fill missing window counts with 0 (no points in window). Keep NaT for earliest/latest if no points.
result['points_in_window'] = result['points_in_window'].fillna(0).astype(int)
# Round numeric metrics for compactness
result['p95_threshold'] = result['p95_threshold'].round(6)
result['mean_in_window'] = result['mean_in_window'].round(6)
result['max_in_window'] = result['max_in_window'].round(6)

# Reorder columns as requested
cols = [
    'cmdb_id',
