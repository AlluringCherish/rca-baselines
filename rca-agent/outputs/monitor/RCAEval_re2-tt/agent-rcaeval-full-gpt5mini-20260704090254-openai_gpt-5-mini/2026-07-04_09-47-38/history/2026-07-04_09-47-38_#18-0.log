import pandas as pd

# Load CSVs (files are in working directory)
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")
log_df = pd.read_csv("log.csv")
error_df = pd.read_csv("error_logs.csv")

# Helper to build overview (counts, min/max ts ints and datetimes)
def build_overview(df, ts_col="timestamp"):
    rows = int(df.shape[0])
    if rows == 0:
        return pd.DataFrame([{
            "rows": 0,
            "min_timestamp": None,
            "max_timestamp": None,
            "min_timestamp_dt_utc": None,
            "max_timestamp_dt_utc": None
        }])
    min_ts = int(df[ts_col].min())
    max_ts = int(df[ts_col].max())
    min_dt = pd.to_datetime(min_ts, unit="s", utc=True)
    max_dt = pd.to_datetime(max_ts, unit="s", utc=True)
    return pd.DataFrame([{
        "rows": rows,
        "min_timestamp": min_ts,
        "max_timestamp": max_ts,
        "min_timestamp_dt_utc": min_dt,
        "max_timestamp_dt_utc": max_dt
    }])

# Metric summaries
metric_overview = build_overview(metric_df, "timestamp")
metric_cmdb_counts = (
    metric_df["cmdb_id"]
    .value_counts()
    .rename_axis("cmdb_id")
    .reset_index(name="count")
    .head(20)
)
metric_kpi_counts = (
    metric_df["kpi_name"]
    .value_counts()
    .rename_axis("kpi_name")
    .reset_index(name="count")
    .head(20)
)
metric_pair_counts = (
    metric_df.groupby(["cmdb_id", "kpi_name"])
    .size()
    .reset_index(name="count")
    .sort_values("count", ascending=False)
    .head(20)
)

# Trace summaries
trace_overview = build_overview(trace_df, "timestamp")
trace_cmdb_counts = (
    trace_df["cmdb_id"]
    .value_counts()
    .rename_axis("cmdb_id")
    .reset_index(name="count")
    .head(20)
)
trace_kpi_counts = (
    trace_df["trace_name"]
    .value_counts()
    .rename_axis("trace_name")
    .reset_index(name="count")
    .head(20)
)

# Log summaries
log_overview = build_overview(log_df, "timestamp")
log_cmdb_counts = (
    log_df["cmdb_id"]
    .value_counts()
    .rename_axis("cmdb_id")
    .reset_index(name="count")
    .head(20)
)
log_kpi_counts = (
    log_df["log_name"]
    .value_counts()
    .rename_axis("log_name")
    .reset_index(name="count")
    .head(20)
)

# Error logs summaries
error_overview = build_overview(error_df, "timestamp")
error_cmdb_counts = (
    error_df["cmdb_id"]
    .value_counts()
    .rename_axis("cmdb_id")
    .reset_index(name="count")
    .head(20)
)

# Compact results (JSON-friendly text tables via DataFrames)
metric_overview, metric_cmdb_counts, metric_kpi_counts, metric_pair_counts, trace_overview, trace_cmdb_counts, trace_kpi_counts, log_overview, log_cmdb_counts, log_kpi_counts, error_overview, error_cmdb_counts
