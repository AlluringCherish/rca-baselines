import pandas as pd
import numpy as np

# Reuse metric_df from kernel if present
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

# Components of interest
components = [
    "ts-auth-service",
    "ts-order-service",
    "ts-route-service",
    "ts-train-service",
    "ts-travel-service",
]

# Ensure numeric value column
metric_df["value"] = pd.to_numeric(metric_df["value"], errors="coerce")

# Create datetime column in UTC as required (keep original integer timestamp too)
metric_df["ts_dt"] = pd.to_datetime(metric_df["timestamp"], unit="s", utc=True)

# 1) Compute global P95 for each component–KPI using the full series (before filtering)
full_sel = metric_df[metric_df["cmdb_id"].isin(components)].copy()
p95_series = (
    full_sel
    .groupby(["cmdb_id", "kpi_name"])["value"]
    .quantile(0.95)
    .rename("global_p95")
    .reset_index()
)

# 2) Filter metric.csv to the incident window (timestamps inclusive)
start_ts = 1705934225
end_ts = 1705936025
start_dt = pd.to_datetime(start_ts, unit="s", utc=True)
end_dt = pd.to_datetime(end_ts, unit="s", utc=True)

window_df = full_sel[(full_sel["ts_dt"] >= start_dt) & (full_sel["ts_dt"] <= end_dt)].copy()

# 3) For each component–KPI, within the incident window compute required metrics
# Aggregate total points and max value in window
agg_window = (
    window_df
    .groupby(["cmdb_id", "kpi_name"])
    .agg(
        total_points_in_window=("value", "count"),
        max_value_in_window=("value", "max")
    )
    .reset_index()
)

# Join global_p95
agg = agg_window.merge(p95_series, left_on=["cmdb_id", "kpi_name"], right_on=["cmdb_id", "kpi_name"], how="left")

# Determine anomaly rows (value >= global_p95) within window and compute anomaly_count and earliest_anomaly_timestamp
# Merge per-row global_p95 to window_df to identify anomaly rows
window_with_p95 = window_df.merge(p95_series, on=["cmdb_id", "kpi_name"], how="left")
# Mark anomalies (value >= global_p95) — handle NaN p95 by marking False
window_with_p95["is_anomaly"] = np.where(window_with_p95["global_p95"].notna() & (window_with_p95["value"] >= window_with_p95["global_p95"]), True, False)

anomaly_agg = (
    window_with_p95[window_with_p95["is_anomaly"]]
    .groupby(["cmdb_id", "kpi_name"])
    .agg(
        anomaly_count=("is_anomaly", "sum"),
        earliest_anomaly_timestamp=("timestamp", "min")
    )
    .reset_index()
)

# Combine with agg (which has total_points and max and global_p95)
result = agg.merge(anomaly_agg, on=["cmdb_id", "kpi_name"], how="left")

# Fill NaNs for combos that had window rows but no anomalies (anomaly_count NaN -> 0), but we'll filter those out later
result["anomaly_count"] = result["anomaly_count"].fillna(0).astype(int)
# earliest_anomaly_timestamp keep as int or NaN
result["earliest_anomaly_timestamp"] = result["earliest_anomaly_timestamp"].astype("Int64")

# Compute severity_ratio = max_value_in_window / global_p95 (if global_p95 > 0)
def compute_severity(row):
    p95 = row["global_p95"]
    mx = row["max_value_in_window"]
    if pd.isna(p95) or p95 == 0 or pd.isna(mx):
        return np.nan
    return mx / p95

result["severity_ratio"] = result.apply(compute_severity, axis=1)

# 4) Keep only rows with anomaly_count > 0
result_nonzero = result[result["anomaly_count"] > 0].copy()

# 5) Sort by severity_ratio descending and limit to top 20 rows
result_nonzero = result_nonzero.sort_values("severity_ratio", ascending=False).head(20)

# Select and rename columns as requested, round numeric fields for compactness
out_cols = [
    "cmdb_id", "kpi_name", "total_points_in_window", "anomaly_count",
    "earliest_anomaly_timestamp", "max_value_in_window", "global_p95", "severity_ratio"
]
final_df = result_nonzero[out_cols].rename(columns={"cmdb_id": "component"})

# Round numeric columns for readability
final_df["max_value_in_window"] = final_df["max_value_in_window"].round(6)
final_df["global_p95"] = final_df["global_p95"].round(6)
final_df["severity_ratio"] = final_df["severity_ratio"].round(6)

# Display compact result (top up to 20 rows)
final_df.reset_index(drop=True)
