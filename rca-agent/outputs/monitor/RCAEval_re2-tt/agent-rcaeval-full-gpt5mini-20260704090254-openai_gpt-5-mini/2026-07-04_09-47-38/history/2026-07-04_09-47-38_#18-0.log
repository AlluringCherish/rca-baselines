import pandas as pd
import numpy as np
import re

# Reuse trace_df if available, else load
try:
    trace_df
except NameError:
    trace_df = pd.read_csv("trace.csv")

# Ensure numeric value and parse timestamps to UTC datetimes (keep raw timestamp ints)
trace_df["value"] = pd.to_numeric(trace_df["value"], errors="coerce")
trace_df["ts_dt"] = pd.to_datetime(trace_df["timestamp"], unit="s", utc=True)

# Services of interest (substring match)
services = [
    "ts-auth-service",
    "ts-order-service",
    "ts-route-service",
    "ts-train-service",
    "ts-travel-service",
]

# Build regex for substring match (escape service names)
pattern = "|".join(re.escape(s) for s in services)

# 1) Identify trace_name rows that reference any of these services (match substrings in trace_name)
selected_trace_rows = trace_df[trace_df["trace_name"].str.contains(pattern, na=False)]

# 2) Compute global P95 per trace_name using the full series (do NOT filter by window)
global_p95_all = (
    trace_df
    .groupby("trace_name")["value"]
    .quantile(0.95)
    .rename("global_p95")
    .reset_index()
)

# Keep only trace_names that reference the services
selected_trace_names = (
    global_p95_all[global_p95_all["trace_name"].str.contains(pattern, na=False)].copy()
)

# 3) Filter trace.csv to the incident window (inclusive)
start_ts = 1705934225
end_ts = 1705936025
start_dt = pd.to_datetime(start_ts, unit="s", utc=True)
end_dt = pd.to_datetime(end_ts, unit="s", utc=True)

window_rows = selected_trace_rows[(selected_trace_rows["ts_dt"] >= start_dt) & (selected_trace_rows["ts_dt"] <= end_dt)].copy()

# 4) For each selected trace_name and cmdb_id produce required summary
# Aggregate total points and max value in window per trace_name + cmdb_id
agg_window = (
    window_rows
    .groupby(["trace_name", "cmdb_id"])
    .agg(
        total_points_in_window=("value", "count"),
        max_value_in_window=("value", "max")
    )
    .reset_index()
)

# Join global_p95 (per trace_name)
agg = agg_window.merge(selected_trace_names, on="trace_name", how="left")

# Mark anomalies per row by merging global_p95 into window_rows
window_with_p95 = window_rows.merge(selected_trace_names, on="trace_name", how="left")
window_with_p95["is_anomaly"] = np.where(window_with_p95["global_p95"].notna() & (window_with_p95["value"] >= window_with_p95["global_p95"]), True, False)

# Compute anomaly_count and earliest_anomaly_timestamp per trace_name + cmdb_id
anomaly_agg = (
    window_with_p95[window_with_p95["is_anomaly"]]
    .groupby(["trace_name", "cmdb_id"])
    .agg(
        anomaly_count=("is_anomaly", "sum"),
        earliest_anomaly_timestamp=("timestamp", "min")
    )
    .reset_index()
)

# Combine aggregates
result = agg.merge(anomaly_agg, on=["trace_name", "cmdb_id"], how="left")

# Fill NaNs for anomaly_count as 0, keep earliest timestamp as Int64 NA if none
result["anomaly_count"] = result["anomaly_count"].fillna(0).astype(int)
result["earliest_anomaly_timestamp"] = result["earliest_anomaly_timestamp"].astype("Int64")

# Compute severity_ratio = max_value_in_window / global_p95 (null if global_p95 == 0 or NaN)
def severity(row):
    p95 = row["global_p95"]
    mx = row["max_value_in_window"]
    if pd.isna(p95) or p95 == 0 or pd.isna(mx):
        return np.nan
    return mx / p95

result["severity_ratio"] = result.apply(severity, axis=1)

# 5) Filter to anomaly_count > 0, sort by severity_ratio desc, limit top 20
out = result[result["anomaly_count"] > 0].copy()
out = out.sort_values("severity_ratio", ascending=False).head(20)

# Select and format columns requested
final_cols = [
    "trace_name", "cmdb_id", "global_p95",
    "total_points_in_window", "anomaly_count",
    "earliest_anomaly_timestamp", "max_value_in_window", "severity_ratio"
]
final_df = out[final_cols].rename(columns={"cmdb_id": "cmdb_id"})

# Round numeric columns for compact display
final_df["global_p95"] = final_df["global_p95"].round(6)
final_df["max_value_in_window"] = final_df["max_value_in_window"].round(6)
final_df["severity_ratio"] = final_df["severity_ratio"].round(6)

# Final compact output (top up to 20 rows)
final_df.reset_index(drop=True)
