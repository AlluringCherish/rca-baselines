import pandas as pd
import numpy as np

# Reuse metric_df from kernel if present
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

# Ensure numeric and datetime columns exist
metric_df["value"] = pd.to_numeric(metric_df["value"], errors="coerce")
if "ts_dt" not in metric_df.columns:
    metric_df["ts_dt"] = pd.to_datetime(metric_df["timestamp"], unit="s", utc=True)

# Parameters
component = "ts-order-service"
kpi = "diskio"
start_ts = 1705934225
end_ts = 1705936025
start_dt = pd.to_datetime(start_ts, unit="s", utc=True)
end_dt = pd.to_datetime(end_ts, unit="s", utc=True)

# 1) Compute global P95 for the full series of this component-KPI (before filtering)
full_series = metric_df[(metric_df["cmdb_id"] == component) & (metric_df["kpi_name"] == kpi)]["value"]
global_p95 = float(full_series.quantile(0.95)) if not full_series.empty else np.nan

# 2) Filter rows within the incident window for the requested component-KPI
window_df_full = metric_df[
    (metric_df["cmdb_id"] == component)
    & (metric_df["kpi_name"] == kpi)
    & (metric_df["ts_dt"] >= start_dt)
    & (metric_df["ts_dt"] <= end_dt)
].copy()

# 3) Prepare compact result table sorted by timestamp ascending, limit to 25 rows
result_table = window_df_full[["timestamp", "value"]].sort_values("timestamp", ascending=True).head(25).reset_index(drop=True)

# 4) Summary: number of rows returned (in window) and count of values >= global_P95 (use full window count)
num_rows_in_window = int(window_df_full.shape[0])
anomaly_count = int((window_df_full["value"] >= global_p95).sum()) if not np.isnan(global_p95) else 0

summary = (
    f"Component={component}, KPI={kpi} | rows_in_window={num_rows_in_window} | "
    f"count_values>=global_P95({global_p95:.6f}) = {anomaly_count}"
)

# Display compact table and summary
result_table, summary
