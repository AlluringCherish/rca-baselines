import pandas as pd
import numpy as np

# Reuse log_df from kernel if present, otherwise load
try:
    log_df
except NameError:
    log_df = pd.read_csv("log.csv")

# Ensure numeric 'value' and parse timestamps (UTC)
log_df["value"] = pd.to_numeric(log_df["value"], errors="coerce")
log_df["ts_dt"] = pd.to_datetime(log_df["timestamp"], unit="s", utc=True)

# Parameters
components = ["ts-travel-service", "ts-train-service", "ts-order-service", "ts-route-service", "ts-auth-service"]
start_ts = 1705934225
end_ts = 1705936025
start_dt = pd.to_datetime(start_ts, unit="s", utc=True)
end_dt = pd.to_datetime(end_ts, unit="s", utc=True)

# Filter to window and selected components
window_logs = log_df[
    (log_df["ts_dt"] >= start_dt) & (log_df["ts_dt"] <= end_dt) & (log_df["cmdb_id"].isin(components))
].copy()

# Per-group aggregates: total_rows, sum_value, max_value
group_agg = (
    window_logs
    .groupby(["cmdb_id", "log_name"], dropna=False)["value"]
    .agg(total_rows="count", sum_value="sum", max_value="max")
    .reset_index()
)

# earliest_timestamp_with_value_gt_0: compute from rows where value > 0
positive_rows = window_logs[window_logs["value"] > 0]
earliest_pos = (
    positive_rows
    .groupby(["cmdb_id", "log_name"], dropna=False)["timestamp"]
    .min()
    .reset_index()
    .rename(columns={"timestamp": "earliest_timestamp_with_value_gt_0"})
)

# Merge earliest timestamp into group_agg
group_agg = group_agg.merge(earliest_pos, on=["cmdb_id", "log_name"], how="left")

# Keep only groups where sum_value > 0 OR max_value > 0
filtered_groups = group_agg[(group_agg["sum_value"].fillna(0) > 0) | (group_agg["max_value"].fillna(0) > 0)].copy()

# Sort by sum_value descending and limit to top 20
filtered_groups = filtered_groups.sort_values("sum_value", ascending=False).head(20)

# Make earliest timestamp Int64 nullable for compact display
filtered_groups["earliest_timestamp_with_value_gt_0"] = filtered_groups["earliest_timestamp_with_value_gt_0"].astype("Int64")

# Per-component summary: total log rows in window for each of the five components
per_component_summary = (
    window_logs
    .groupby("cmdb_id")
    .size()
    .reindex(components, fill_value=0)
    .rename("total_log_rows_in_window")
    .reset_index()
)

# Compact outputs
filtered_groups, per_component_summary
