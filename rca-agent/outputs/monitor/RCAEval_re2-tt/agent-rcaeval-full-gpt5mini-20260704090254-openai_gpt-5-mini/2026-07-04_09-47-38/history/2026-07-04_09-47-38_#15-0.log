    trace_df = pd.read_csv("trace.csv", low_memory=False)
try:
    log_df
except NameError:
    log_df = pd.read_csv("log.csv", low_memory=False)

# Ensure numeric types and UTC datetime columns
trace_df['value'] = pd.to_numeric(trace_df.get('value'), errors='coerce')
trace_df['timestamp'] = pd.to_numeric(trace_df.get('timestamp'), errors='coerce').astype('Int64')
trace_df['timestamp_dt'] = pd.to_datetime(trace_df['timestamp'].astype('int64'), unit='s', utc=True)

log_df['value'] = pd.to_numeric(log_df.get('value'), errors='coerce')
log_df['timestamp'] = pd.to_numeric(log_df.get('timestamp'), errors='coerce').astype('Int64')
log_df['timestamp_dt'] = pd.to_datetime(log_df['timestamp'].astype('int64'), unit='s', utc=True)

# Define incident window (UTC)
start_dt = pd.to_datetime("2024-01-23 03:30:08", utc=True)
end_dt   = pd.to_datetime("2024-01-23 04:00:08", utc=True)

# --- Part 1: trace analysis ---

# Compute global P95 per trace_name using the full series (do NOT filter by window)
trace_p95 = trace_df.groupby('trace_name', dropna=False)['value'].quantile(0.95).reset_index(name='global_p95')
trace_counts = trace_df.groupby('trace_name', dropna=False)['value'].count().reset_index(name='total_count')
trace_stats = trace_p95.merge(trace_counts, on='trace_name', how='left')

# Filter trace rows to the incident window
trace_window = trace_df[(trace_df['timestamp_dt'] >= start_dt) & (trace_df['timestamp_dt'] <= end_dt)].copy()

# Selection criteria: trace_name contains any token and any service substring
tokens = ['from_ts-','to_ts-','root']
services = ['auth','order','route','preserve','security','travel']

# Build boolean mask for trace_name filtering
def contains_any(s, lst):
    return any(tok in s for tok in lst)

trace_window['trace_name_str'] = trace_window['trace_name'].astype(str)
mask_token = trace_window['trace_name_str'].apply(lambda s: contains_any(s, tokens))
mask_service = trace_window['trace_name_str'].apply(lambda s: contains_any(s, services))
trace_window_sel = trace_window[mask_token & mask_service].copy()

# Merge global_p95 into window rows (global p95 computed from full series)
trace_window_sel = trace_window_sel.merge(trace_stats[['trace_name','global_p95','total_count']],
                                          left_on='trace_name', right_on='trace_name', how='left')

# Compute anomaly flag (value >= global_p95). For global_p95 <= 0, anomalies are still counted only if >= gp but ratio will be None later.
trace_window_sel['is_anomaly'] = trace_window_sel['value'] >= trace_window_sel['global_p95']

# Aggregate per unique trace_name (and include cmdb_id for context — take the most common cmdb_id per trace_name in window)
# Determine representative cmdb_id per trace_name by mode in window selection
rep_cmdb = trace_window_sel.groupby('trace_name')['cmdb_id'] \
            .agg(lambda s: s.mode().iloc[0] if not s.mode().empty else s.iloc[0]).reset_index(name='cmdb_id')

# Window aggregates
window_aggs = trace_window_sel.groupby('trace_name', dropna=False).agg(
    window_count = ('value','count'),
    anomaly_count = ('is_anomaly','sum'),
    earliest_anom_ts = ('timestamp', lambda s: int(s[s >= 0][s.index[trace_window_sel.loc[s.index,'is_anomaly']].tolist()].min()) if any(trace_window_sel.loc[s.index,'is_anomaly']) else None),
    max_value_in_window = ('value','max')
).reset_index()

# The above lambda for earliest_anom_ts is complex; instead compute earliest per trace_name from anomaly rows safely:
anoms = trace_window_sel[trace_window_sel['is_anomaly']].copy()
if not anoms.empty:
    earliest_anom = anoms.groupby('trace_name', dropna=False).agg(earliest_anom_ts=('timestamp','min'),
                                                                 earliest_anom_val=('value','first')).reset_index()
    # ensure earliest_anom_val corresponds to the earliest timestamp's value
    earliest_vals = anoms.sort_values(['trace_name','timestamp']).groupby('trace_name', dropna=False).first().reset_index()[['trace_name','value']]
    earliest_vals = earliest_vals.rename(columns={'value':'earliest_anom_val'})
    earliest_anom = earliest_anom.drop(columns=['earliest_anom_val']).merge(earliest_vals, on='trace_name', how='left')
else:
    earliest_anom = pd.DataFrame(columns=['trace_name','earliest_anom_ts','earliest_anom_val'])

# Merge aggregates with earliest anomalies and rep cmdb and global p95
trace_result = window_aggs.merge(earliest_anom, on='trace_name', how='left') \
                          .merge(trace_stats[['trace_name','global_p95','total_count']], on='trace_name', how='left') \
                          .merge(rep_cmdb, on='trace_name', how='left')

# Compute max_over_p95_ratio when global_p95 > 0 and max_value_in_window not null
def ratio_row(r):
    gp = r['global_p95']
    mv = r['max_value_in_window']
    if pd.isna(gp) or gp <= 0 or pd.isna(mv):
        return None
    return float(mv) / float(gp)

trace_result['max_over_p95_ratio'] = trace_result.apply(ratio_row, axis=1)

# Rename columns to match requested output and format earliest timestamp as integer or None
trace_result = trace_result.rename(columns={
    'cmdb_id':'cmdb_id',
    'trace_name':'trace_name',
    'window_count':'window_count',
    'anomaly_count':'anomaly_count',
    'earliest_anom_ts':'earliest_anomaly_ts',
    'value':'earliest_anomaly_value',
    'max_value_in_window':'max_value_in_window',
    'global_p95':'global_p95',
    'total_count':'total_count'
})

# Replace NaN earliest_anomaly_ts/val with None and cast timestamps to int
if 'earliest_anom_ts' in trace_result.columns:
    trace_result['earliest_anom_ts'] = trace_result['earliest_anom_ts'].where(trace_result['earliest_anom_ts'].notna(), None)

# Use the earliest_anom_ts and earliest_anom_val columns from earliest_anom merge
if 'earliest_anom_ts' in trace_result.columns:
    trace_result = trace_result.rename(columns={'earliest_anom_ts':'earliest_anomaly_ts'})
if 'earliest_anom_val' in trace_result.columns:
    trace_result = trace_result.rename(columns={'earliest_anom_val':'earliest_anomaly_value'})

# Select and order final columns
trace_final_cols = ['cmdb_id','trace_name','global_p95','total_count','window_count','anomaly_count',
                    'earliest_anomaly_ts','earliest_anomaly_value','max_value_in_window','max_over_p95_ratio']
trace_result = trace_result[trace_final_cols]

# Sort by ratio descending and limit to top 30
trace_result_top = trace_result.sort_values('max_over_p95_ratio', key=lambda s: s.fillna(-np.inf), ascending=False).head(30).reset_index(drop=True)

# --- Part 2: log analysis ---

# Filter logs to incident window and to specified cmdb_ids
log_candidates = ["ts-auth-service","ts-order-service","ts-route-service"]
log_window = log_df[(log_df['timestamp_dt'] >= start_dt) & (log_df['timestamp_dt'] <= end_dt) & (log_df['cmdb_id'].isin(log_candidates))].copy()

if log_window.empty:
    log_result = pd.DataFrame({
        'message': ["No log rows in the incident window for the specified services."]
    })
else:
    # Aggregate per cmdb_id and log_name
    log_aggs = log_window.groupby(['cmdb_id','log_name'], dropna=False).agg(
