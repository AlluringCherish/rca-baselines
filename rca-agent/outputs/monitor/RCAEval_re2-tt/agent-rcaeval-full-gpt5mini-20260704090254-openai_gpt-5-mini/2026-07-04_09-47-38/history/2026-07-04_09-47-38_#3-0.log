import re
import pandas as pd

# Ensure source table exists
assert "df_trace_window_labeled" in globals(), "df_trace_window_labeled not found in kernel"

# Candidate services (reuse if available)
candidates = ['ts-auth-service','ts-order-service','ts-route-service','ts-train-service','ts-travel-service']

# Build regex to find "to_ts-<candidate>" followed by a dot (or end)
pattern = re.compile(r"to_ts-(" + "|".join(re.escape(c) for c in candidates) + r")(?=\.|$)")

# Filter rows where trace_name matches pattern
mask = df_trace_window_labeled["trace_name"].astype(str).str.contains(pattern)
trace_calls_to_candidates = df_trace_window_labeled[mask].copy()  # store full filtered subset in kernel

# Extract target candidate name from trace_name
trace_calls_to_candidates["target_candidate"] = trace_calls_to_candidates["trace_name"].str.extract(r"to_ts-(" + "|".join(re.escape(c) for c in candidates) + r")(?=\.|$)", expand=False)

# Caller is existing cmdb_id
trace_calls_to_candidates["caller_cmdb_id"] = trace_calls_to_candidates["cmdb_id"]

# Group and aggregate
group_cols = ["caller_cmdb_id", "target_candidate", "trace_name"]
agg_basic = trace_calls_to_candidates.groupby(group_cols, as_index=False).agg(
    count_points=("value", "size"),
    count_anom_high=("anom_high", "sum"),
    max_value_in_window=("value", "max"),
    count_anom_low=("anom_low", "sum"),
    min_value_in_window=("value", "min"),
)

# Earliest anomaly timestamps
earliest_high = (
    trace_calls_to_candidates[trace_calls_to_candidates["anom_high"] == 1]
    .groupby(group_cols, as_index=False)["timestamp_dt"]
    .min()
    .rename(columns={"timestamp_dt": "earliest_anom_high_ts"})
)
earliest_low = (
    trace_calls_to_candidates[trace_calls_to_candidates["anom_low"] == 1]
    .groupby(group_cols, as_index=False)["timestamp_dt"]
    .min()
    .rename(columns={"timestamp_dt": "earliest_anom_low_ts"})
)

# Merge earliest timestamps
agg = agg_basic.merge(earliest_high, on=group_cols, how="left").merge(earliest_low, on=group_cols, how="left")

# Keep only groups with any anomalies
agg_anom = agg[(agg["count_anom_high"] + agg["count_anom_low"]) > 0].copy()

# Sort by count_anom_high desc, then earliest_anom_high_ts asc (NaT placed after by filling with large timestamp for sorting)
agg_anom["earliest_anom_high_ts_sort"] = agg_anom["earliest_anom_high_ts"].fillna(pd.Timestamp.max.tz_localize("UTC"))
agg_anom_sorted = agg_anom.sort_values(by=["count_anom_high", "earliest_anom_high_ts_sort"], ascending=[False, True])

# Select and limit columns for output
trace_calls_top20 = agg_anom_sorted.loc[:, [
    "caller_cmdb_id", "target_candidate", "trace_name",
    "count_points", "count_anom_high", "earliest_anom_high_ts", "max_value_in_window",
    "count_anom_low", "earliest_anom_low_ts", "min_value_in_window"
]].head(20).rename(columns={"caller_cmdb_id":"caller_cmdb_id"})

# Clean helper sort column from memory view
trace_calls_top20, trace_calls_to_candidates.shape
