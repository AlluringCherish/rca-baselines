# Reuse existing df_trace variable from kernel
import pandas as pd
import numpy as np

# Ensure timestamp_dt exists (parse if missing)
if "timestamp_dt" not in df_trace.columns and "timestamp" in df_trace.columns:
    df_trace["timestamp_dt"] = pd.to_datetime(df_trace["timestamp"], unit="s", utc=True)

# 1) Global aggregations across full trace series grouped by (cmdb_id, trace_name)
trace_agg_basic = (
    df_trace
    .groupby(["cmdb_id", "trace_name"], as_index=False)
    .agg(
        count=("value", "size"),
        value_mean=("value", "mean"),
        value_min=("value", "min"),
        value_max=("value", "max"),
        value_std=("value", "std"),
    )
)

# Quantiles (global)
q95 = df_trace.groupby(["cmdb_id", "trace_name"])["value"].quantile(0.95).reset_index(name="P95")
q90 = df_trace.groupby(["cmdb_id", "trace_name"])["value"].quantile(0.90).reset_index(name="P90")
q05 = df_trace.groupby(["cmdb_id", "trace_name"])["value"].quantile(0.05).reset_index(name="P5")

# Merge into full aggregated table
trace_agg_full = trace_agg_basic.merge(q95, on=["cmdb_id", "trace_name"], how="left") \
                                .merge(q90, on=["cmdb_id", "trace_name"], how="left") \
                                .merge(q05, on=["cmdb_id", "trace_name"], how="left")

# Keep trace_agg_full in kernel for later use (required)

# 2) Filter trace points to incident window
start_ts = pd.to_datetime("2024-01-22 10:56:05", utc=True)
end_ts   = pd.to_datetime("2024-01-22 11:26:05", utc=True)

df_trace_window = df_trace[(df_trace["timestamp_dt"] >= start_ts) & (df_trace["timestamp_dt"] <= end_ts)].copy()

# 3) Join each point with its group's thresholds (P95, P5)
thresholds = trace_agg_full[["cmdb_id", "trace_name", "P95", "P5"]]
df_trace_window_labeled = df_trace_window.merge(thresholds, on=["cmdb_id", "trace_name"], how="left")

# 4) Label anomalies using global thresholds
df_trace_window_labeled["anom_high"] = np.where(
    df_trace_window_labeled["P95"].notna() & (df_trace_window_labeled["value"] >= df_trace_window_labeled["P95"]),
    1, 0
)
df_trace_window_labeled["anom_low"] = np.where(
    df_trace_window_labeled["P5"].notna() & (df_trace_window_labeled["value"] <= df_trace_window_labeled["P5"]),
    1, 0
)

# 5) Aggregate per (cmdb_id, trace_name) within the window
agg_basic = (
    df_trace_window_labeled
    .groupby(["cmdb_id", "trace_name"], as_index=False)
    .agg(
        count_points=("value", "size"),
        count_anom_high=("anom_high", "sum"),
        max_value_in_window=("value", "max"),
        count_anom_low=("anom_low", "sum"),
        min_value_in_window=("value", "min"),
    )
)

# Earliest anomaly timestamps
earliest_high = (
    df_trace_window_labeled[df_trace_window_labeled["anom_high"] == 1]
    .groupby(["cmdb_id", "trace_name"], as_index=False)["timestamp_dt"]
    .min()
    .rename(columns={"timestamp_dt": "earliest_anom_high_ts"})
)
earliest_low = (
    df_trace_window_labeled[df_trace_window_labeled["anom_low"] == 1]
    .groupby(["cmdb_id", "trace_name"], as_index=False)["timestamp_dt"]
    .min()
    .rename(columns={"timestamp_dt": "earliest_anom_low_ts"})
)

# Merge earliest timestamps into aggregated table
agg = agg_basic.merge(earliest_high, on=["cmdb_id", "trace_name"], how="left").merge(earliest_low, on=["cmdb_id", "trace_name"], how="left")

# Attach global P95 and P5 for severity calculations
agg = agg.merge(thresholds, on=["cmdb_id", "trace_name"], how="left")

# Compute severity metrics safely
agg["severity_high"] = np.where((agg["P95"] > 0) & agg["P95"].notna(), agg["max_value_in_window"] / agg["P95"], np.nan)
agg["severity_low"]  = np.where((agg["min_value_in_window"] > 0) & agg["min_value_in_window"].notna(), agg["P5"] / agg["min_value_in_window"], np.nan)

# Compute sorting key
agg["severity_max"] = agg[["severity_high", "severity_low"]].max(axis=1, skipna=True)

# Filter groups with any anomalies
agg_anomalous = agg[(agg["count_anom_high"] + agg["count_anom_low"]) > 0].copy()

# Prepare top-20 summary sorted by descending severity_max
if agg_anomalous.shape[0] == 0:
    anomaly_group_count = 0
    trace_top20 = agg_anomalous.head(20).loc[:, ["cmdb_id","trace_name","count_points","count_anom_high","earliest_anom_high_ts","max_value_in_window","severity_high","count_anom_low","earliest_anom_low_ts","min_value_in_window","severity_low"]]
else:
    anomaly_group_count = agg_anomalous.shape[0]
    trace_top20 = (
        agg_anomalous
        .sort_values("severity_max", ascending=False)
        .loc[:, ["cmdb_id","trace_name","count_points","count_anom_high","earliest_anom_high_ts","max_value_in_window","severity_high","count_anom_low","earliest_anom_low_ts","min_value_in_window","severity_low"]]
        .head(20)
    )

# Keep full per-point labeled table in kernel variable: df_trace_window_labeled
# Keep full aggregated thresholds in kernel variable: trace_agg_full

# Display compact results: number of anomalous groups and the top-20 summary
anomaly_group_count, trace_top20
