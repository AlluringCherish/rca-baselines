import pandas as pd
import numpy as np

# Candidate components
candidates = ['ts-auth-service','ts-order-service','ts-route-service','ts-train-service','ts-travel-service']

# Reuse existing per-point labeled tables: df_metric_window_labeled, df_trace_window_labeled
# Ensure they exist
assert "df_metric_window_labeled" in globals(), "df_metric_window_labeled not found in kernel"
assert "df_trace_window_labeled" in globals(), "df_trace_window_labeled not found in kernel"

# 1) Filter per-point tables to candidate components and store
metric_candidates_window = df_metric_window_labeled[df_metric_window_labeled["cmdb_id"].isin(candidates)].copy()
trace_candidates_window  = df_trace_window_labeled[df_trace_window_labeled["cmdb_id"].isin(candidates)].copy()

# Helper to compute group summaries (metrics)
def summarize_anomalies(df_points, group_cols, value_col="value"):
    # Basic aggregates
    agg_basic = (
        df_points
        .groupby(group_cols, as_index=False)
        .agg(
            count_points=(value_col, "size"),
            count_anom_high=("anom_high", "sum"),
            max_value_in_window=(value_col, "max"),
            count_anom_low=("anom_low", "sum"),
            min_value_in_window=(value_col, "min"),
        )
    )
    # Earliest anomaly timestamps
    earliest_high = (
        df_points[df_points["anom_high"] == 1]
        .groupby(group_cols, as_index=False)["timestamp_dt"]
        .min()
        .rename(columns={"timestamp_dt": "earliest_anom_high_ts"})
    )
    earliest_low = (
        df_points[df_points["anom_low"] == 1]
        .groupby(group_cols, as_index=False)["timestamp_dt"]
        .min()
        .rename(columns={"timestamp_dt": "earliest_anom_low_ts"})
    )
    # Merge
    agg = agg_basic.merge(earliest_high, on=group_cols, how="left").merge(earliest_low, on=group_cols, how="left")
    # Bring global thresholds if available in points (P95, P5) else NaN
    if "P95" in df_points.columns and "P5" in df_points.columns:
        thresholds = df_points.groupby(group_cols, as_index=False).agg(P95=("P95","first"), P5=("P5","first"))
    else:
        # fallback: try to use precomputed global agg variables if exist
        thresholds = None
    if thresholds is not None:
        agg = agg.merge(thresholds, on=group_cols, how="left")
    else:
        agg["P95"] = np.nan
        agg["P5"] = np.nan
    # Severities (safe)
    agg["severity_high"] = np.where((agg["P95"] > 0) & agg["P95"].notna(), agg["max_value_in_window"] / agg["P95"], np.nan)
    agg["severity_low"]  = np.where((agg["min_value_in_window"] > 0) & agg["min_value_in_window"].notna(), agg["P5"] / agg["min_value_in_window"], np.nan)
    agg["severity_max"] = agg[["severity_high","severity_low"]].max(axis=1, skipna=True)
    return agg

# 2) Metric-anomaly summary for candidates
metric_summary_all = summarize_anomalies(metric_candidates_window, ["cmdb_id","kpi_name"], value_col="value")
metric_summary_anom = metric_summary_all[(metric_summary_all["count_anom_high"] + metric_summary_all["count_anom_low"]) > 0].copy()
metric_summary_top20 = (
    metric_summary_anom
    .sort_values("severity_max", ascending=False)
    .loc[:, ["cmdb_id","kpi_name","count_points","count_anom_high","earliest_anom_high_ts","max_value_in_window","severity_high","count_anom_low","earliest_anom_low_ts","min_value_in_window","severity_low"]]
    .head(20)
)

# 3) Trace-anomaly summary for candidates
trace_summary_all = summarize_anomalies(trace_candidates_window, ["cmdb_id","trace_name"], value_col="value")
trace_summary_anom = trace_summary_all[(trace_summary_all["count_anom_high"] + trace_summary_all["count_anom_low"]) > 0].copy()
trace_summary_top20 = (
    trace_summary_anom
    .sort_values("severity_max", ascending=False)
    .loc[:, ["cmdb_id","trace_name","count_points","count_anom_high","earliest_anom_high_ts","max_value_in_window","severity_high","count_anom_low","earliest_anom_low_ts","min_value_in_window","severity_low"]]
    .head(20)
)

# 4) Per-component rollup for the five candidates
# For metrics: total anomaly counts and earliest anomaly ts
if metric_summary_anom.shape[0] > 0:
    metric_summary_anom["total_group_anoms"] = metric_summary_anom["count_anom_high"] + metric_summary_anom["count_anom_low"]
    # earliest per group any-anom ts (min of earliest high/low)
    metric_summary_anom["earliest_any_anom_ts"] = metric_summary_anom[["earliest_anom_high_ts","earliest_anom_low_ts"]].min(axis=1)
    metric_rollup = (
        metric_summary_anom
        .groupby("cmdb_id", as_index=False)
        .agg(
            total_metric_anomaly_count=("total_group_anoms", "sum"),
            earliest_metric_anom_ts=("earliest_any_anom_ts", "min"),
        )
    )
else:
    metric_rollup = pd.DataFrame({"cmdb_id": candidates, "total_metric_anomaly_count": [0]*len(candidates), "earliest_metric_anom_ts":[pd.NaT]*len(candidates)})

# For traces: similar
if trace_summary_anom.shape[0] > 0:
    trace_summary_anom["total_group_anoms"] = trace_summary_anom["count_anom_high"] + trace_summary_anom["count_anom_low"]
    trace_summary_anom["earliest_any_anom_ts"] = trace_summary_anom[["earliest_anom_high_ts","earliest_anom_low_ts"]].min(axis=1)
    trace_rollup = (
        trace_summary_anom
        .groupby("cmdb_id", as_index=False)
        .agg(
            total_trace_anomaly_count=("total_group_anoms", "sum"),
            earliest_trace_anom_ts=("earliest_any_anom_ts", "min"),
        )
    )
else:
    trace_rollup = pd.DataFrame({"cmdb_id": candidates, "total_trace_anomaly_count": [0]*len(candidates), "earliest_trace_anom_ts":[pd.NaT]*len(candidates)})

# Merge metric and trace rollups to get final per-component rollup (one row per candidate)
rollup = pd.DataFrame({"cmdb_id": candidates}).merge(metric_rollup, on="cmdb_id", how="left").merge(trace_rollup, on="cmdb_id", how="left")
# Fill NaNs for counts with 0
rollup["total_metric_anomaly_count"] = rollup["total_metric_anomaly_count"].fillna(0).astype(int)
rollup["total_trace_anomaly_count"] = rollup["total_trace_anomaly_count"].fillna(0).astype(int)

