import pandas as pd
import numpy as np

# Candidate services
candidates = ['ts-auth-service','ts-order-service','ts-route-service','ts-train-service','ts-travel-service']

# Ensure source table exists and timestamp parsed
assert "df_trace_window_labeled" in globals(), "df_trace_window_labeled not found in kernel"
if "timestamp_dt" not in df_trace_window_labeled.columns and "timestamp" in df_trace_window_labeled.columns:
    df_trace_window_labeled["timestamp_dt"] = pd.to_datetime(df_trace_window_labeled["timestamp"], unit="s", utc=True)

# 1) Filter per-point trace table to candidate services and store in kernel variable
trace_candidates_window = df_trace_window_labeled[df_trace_window_labeled["cmdb_id"].isin(candidates)].copy()

# 2) Add direction_hint based on trace_name
def direction_hint(name):
    if "to_ts-" in name:
        return "to"
    if "from_ts-" in name or "from_root" in name:
        return "from"
    return "other"

trace_candidates_window["direction_hint"] = trace_candidates_window["trace_name"].astype(str).apply(direction_hint)

# 3) Aggregate per (cmdb_id, trace_name)
group_cols = ["cmdb_id", "trace_name", "direction_hint"]
agg_basic = trace_candidates_window.groupby(group_cols, as_index=False).agg(
    count_points=("value", "size"),
    count_anom_high=("anom_high", "sum"),
    max_value_in_window=("value", "max"),
    count_anom_low=("anom_low", "sum"),
    min_value_in_window=("value", "min"),
)

# Earliest anomaly timestamps
earliest_high = (
    trace_candidates_window[trace_candidates_window["anom_high"] == 1]
    .groupby(group_cols, as_index=False)["timestamp_dt"]
    .min()
    .rename(columns={"timestamp_dt": "earliest_anom_high_ts"})
)
earliest_low = (
    trace_candidates_window[trace_candidates_window["anom_low"] == 1]
    .groupby(group_cols, as_index=False)["timestamp_dt"]
    .min()
    .rename(columns={"timestamp_dt": "earliest_anom_low_ts"})
)

# Merge earliest timestamps into aggregated table
agg = agg_basic.merge(earliest_high, on=group_cols, how="left").merge(earliest_low, on=group_cols, how="left")

# 4) Prepare compact sorted summary: sort by cmdb_id then count_points desc, limit 50
agg_sorted = agg.sort_values(by=["cmdb_id", "count_points"], ascending=[True, False])
trace_agg_top50 = agg_sorted.loc[:, [
    "cmdb_id", "trace_name", "direction_hint",
    "count_points", "count_anom_high", "earliest_anom_high_ts", "max_value_in_window",
    "count_anom_low", "earliest_anom_low_ts", "min_value_in_window"
]].head(50)

# Return only the aggregated top-50 summary (trace_candidates_window is stored in kernel)
trace_agg_top50
