import pandas as pd

# Load CSVs
df_metric = pd.read_csv("metric.csv")
df_trace = pd.read_csv("trace.csv")
df_log = pd.read_csv("log.csv")
df_err = pd.read_csv("error_logs.csv")

# Parse timestamps to UTC datetimes (Unix seconds -> UTC)
for df in (df_metric, df_trace, df_log, df_err):
    if "timestamp" in df.columns:
        df["timestamp_dt"] = pd.to_datetime(df["timestamp"], unit="s", utc=True)

# ---------------------
# 1) metric.csv summary
# ---------------------
metric_row_count = df_metric.shape[0]

# unique cmdb_id with counts
metric_cmdb_counts = df_metric["cmdb_id"].value_counts().rename_axis("cmdb_id").reset_index(name="count")

# unique kpi_name with counts (compute top 50 but display top 20)
metric_kpi_counts_50 = df_metric["kpi_name"].value_counts().head(50).rename_axis("kpi_name").reset_index(name="count")
metric_kpi_counts_head20 = metric_kpi_counts_50.head(20)

# group by (cmdb_id, kpi_name) with stats and earliest/latest timestamps
metric_group = (
    df_metric
    .groupby(["cmdb_id", "kpi_name"], as_index=False)
    .agg(
        count=("value", "size"),
        value_mean=("value", "mean"),
        value_min=("value", "min"),
        value_max=("value", "max"),
        value_std=("value", "std"),
        earliest_ts=("timestamp_dt", "min"),
        latest_ts=("timestamp_dt", "max"),
    )
    .sort_values("count", ascending=False)
)
metric_group_top20 = metric_group.head(20)

# ---------------------
# 2) trace.csv summary
# ---------------------
trace_row_count = df_trace.shape[0]
trace_cmdb_counts = df_trace["cmdb_id"].value_counts().rename_axis("cmdb_id").reset_index(name="count")
trace_name_counts = df_trace["trace_name"].value_counts().rename_axis("trace_name").reset_index(name="count").head(20)

trace_group = (
    df_trace
    .groupby(["cmdb_id", "trace_name"], as_index=False)
    .agg(
        count=("value", "size"),
        value_mean=("value", "mean"),
        value_min=("value", "min"),
        value_max=("value", "max"),
        value_std=("value", "std"),
        earliest_ts=("timestamp_dt", "min"),
        latest_ts=("timestamp_dt", "max"),
    )
    .sort_values("count", ascending=False)
)
trace_group_top20 = trace_group.head(20)

# ---------------------
# 3) log.csv summary
# ---------------------
log_row_count = df_log.shape[0]
log_cmdb_counts = df_log["cmdb_id"].value_counts().rename_axis("cmdb_id").reset_index(name="count")
log_name_counts = df_log["log_name"].value_counts().rename_axis("log_name").reset_index(name="count").head(20)

log_group = (
    df_log
    .groupby(["cmdb_id", "log_name"], as_index=False)
    .agg(
        count=("value", "size"),
        value_mean=("value", "mean"),
        value_min=("value", "min"),
        value_max=("value", "max"),
        value_std=("value", "std"),
        earliest_ts=("timestamp_dt", "min"),
        latest_ts=("timestamp_dt", "max"),
    )
    .sort_values("count", ascending=False)
)
log_group_top20 = log_group.head(20)

# ---------------------
# 4) error_logs.csv summary
# ---------------------
err_row_count = df_err.shape[0]
err_cmdb_counts = df_err["cmdb_id"].value_counts().rename_axis("cmdb_id").reset_index(name="count")

# earliest 5 and latest 5 rows by timestamp, with timestamp_dt, cmdb_id, and first 200 chars of message
if "message" in df_err.columns:
    df_err["message_snippet"] = df_err["message"].astype(str).str.slice(0, 200)
else:
    df_err["message_snippet"] = ""

err_sorted_asc = df_err.sort_values("timestamp_dt", ascending=True)[["timestamp_dt", "cmdb_id", "message_snippet"]].head(5)
err_sorted_desc = df_err.sort_values("timestamp_dt", ascending=False)[["timestamp_dt", "cmdb_id", "message_snippet"]].head(5)

# ---------------------
# Compact summaries to display (limit sizes)
# ---------------------
metric_summary_overview = pd.DataFrame({
    "metric_total_rows": [metric_row_count],
    "metric_unique_cmdb_count": [metric_cmdb_counts.shape[0]],
    "metric_unique_kpi_count": [metric_kpi_counts_50.shape[0]],
})

trace_summary_overview = pd.DataFrame({
    "trace_total_rows": [trace_row_count],
    "trace_unique_cmdb_count": [trace_cmdb_counts.shape[0]],
    "trace_unique_name_count": [trace_name_counts.shape[0]],
})

log_summary_overview = pd.DataFrame({
    "log_total_rows": [log_row_count],
    "log_unique_cmdb_count": [log_cmdb_counts.shape[0]],
    "log_unique_name_count": [log_name_counts.shape[0]],
})

error_summary_overview = pd.DataFrame({
    "error_total_rows": [err_row_count],
    "error_unique_cmdb_count": [err_cmdb_counts.shape[0]],
})

# Final displayed variables (compact)
metric_summary_overview, metric_cmdb_counts, metric_kpi_counts_head20, metric_group_top20, \
trace_summary_overview, trace_cmdb_counts, trace_name_counts, trace_group_top20, \
log_summary_overview, log_cmdb_counts, log_name_counts, log_group_top20, \
error_summary_overview, err_cmdb_counts, err_sorted_asc, err_sorted_desc
