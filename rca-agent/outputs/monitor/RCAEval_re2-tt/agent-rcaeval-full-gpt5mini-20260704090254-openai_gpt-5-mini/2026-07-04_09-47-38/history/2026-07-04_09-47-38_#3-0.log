# Reuse existing variables: df_metric, metric_agg_full
import pandas as pd
import numpy as np

# Ensure timestamp_dt exists and is parsed as UTC datetime
if "timestamp_dt" not in df_metric.columns and "timestamp" in df_metric.columns:
    df_metric["timestamp_dt"] = pd.to_datetime(df_metric["timestamp"], unit="s", utc=True)

# Incident window (UTC)
start_ts = pd.to_datetime("2024-01-22 10:56:05", utc=True)
end_ts   = pd.to_datetime("2024-01-22 11:26:05", utc=True)

# Filter metric points within the incident window
df_metric_window = df_metric[(df_metric["timestamp_dt"] >= start_ts) & (df_metric["timestamp_dt"] <= end_ts)].copy()

# Join global thresholds (metric_agg_full contains P95 and P5 computed globally)
thresholds = metric_agg_full[["cmdb_id", "kpi_name", "P95", "P5"]]
df_metric_window_labeled = df_metric_window.merge(thresholds, on=["cmdb_id", "kpi_name"], how="left")

# Label anomalies using global thresholds
df_metric_window_labeled["anom_high"] = np.where(
    df_metric_window_labeled["P95"].notna() & (df_metric_window_labeled["value"] >= df_metric_window_labeled["P95"]),
    1, 0
)
df_metric_window_labeled["anom_low"] = np.where(
    df_metric_window_labeled["P5"].notna() & (df_metric_window_labeled["value"] <= df_metric_window_labeled["P5"]),
    1, 0
)

# Aggregate per (cmdb_id, kpi_name) within the window
agg_basic = (
    df_metric_window_labeled
    .groupby(["cmdb_id", "kpi_name"], as_index=False)
    .agg(
        count_points=("value", "size"),
        count_anom_high=("anom_high", "sum"),
        max_value_in_window=("value", "max"),
        count_anom_low=("anom_low", "sum"),
        min_value_in_window=("value", "min"),
    )
)

# Earliest anomaly timestamps (high / low)
earliest_high = (
    df_metric_window_labeled[df_metric_window_labeled["anom_high"] == 1]
    .groupby(["cmdb_id", "kpi_name"], as_index=False)["timestamp_dt"]
    .min()
    .rename(columns={"timestamp_dt": "earliest_anom_high_ts"})
)
earliest_low = (
    df_metric_window_labeled[df_metric_window_labeled["anom_low"] == 1]
    .groupby(["cmdb_id", "kpi_name"], as_index=False)["timestamp_dt"]
    .min()
    .rename(columns={"timestamp_dt": "earliest_anom_low_ts"})
)

# Merge earliest timestamps into aggregated table
agg = agg_basic.merge(earliest_high, on=["cmdb_id", "kpi_name"], how="left").merge(earliest_low, on=["cmdb_id", "kpi_name"], how="left")

# Attach global P95 and P5 for severity calculations
agg = agg.merge(thresholds, on=["cmdb_id", "kpi_name"], how="left")

# Compute severity metrics
def safe_div(numer, denom):
    return np.where((denom > 0) & pd.notna(denom), numer / denom, np.nan)

agg["severity_high"] = safe_div(agg["max_value_in_window"], agg["P95"])
agg["severity_low"]  = safe_div(agg["P5"], agg["min_value_in_window"])

# Compute a sorting key = max(severity_high, severity_low)
agg["severity_max"] = agg[["severity_high", "severity_low"]].max(axis=1, skipna=True)

# Filter groups that have any anomalies and sort by severity_max desc
agg_anomalous = agg[(agg["count_anom_high"] + agg["count_anom_low"]) > 0].copy()

# If no anomalous groups, prepare empty summary accordingly
if agg_anomalous.shape[0] == 0:
    anomaly_group_count = 0
    agg_top20 = agg_anomalous.head(20).loc[:, ["cmdb_id","kpi_name","count_points","count_anom_high","earliest_anom_high_ts","max_value_in_window","severity_high","count_anom_low","earliest_anom_low_ts","min_value_in_window","severity_low"]]
else:
    anomaly_group_count = agg_anomalous.shape[0]
    agg_top20 = (
        agg_anomalous
        .sort_values("severity_max", ascending=False)
        .loc[:, ["cmdb_id","kpi_name","count_points","count_anom_high","earliest_anom_high_ts","max_value_in_window","severity_high","count_anom_low","earliest_anom_low_ts","min_value_in_window","severity_low"]]
        .head(20)
    )

# Keep full per-point labeled table in kernel variable: df_metric_window_labeled
# Return compact results: number of anomalous groups and top-20 summary
anomaly_group_count, agg_top20
