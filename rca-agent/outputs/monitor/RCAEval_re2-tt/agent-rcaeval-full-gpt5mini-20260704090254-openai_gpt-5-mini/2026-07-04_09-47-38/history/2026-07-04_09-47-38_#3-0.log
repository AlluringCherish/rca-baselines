import numpy as np
import pandas as pd

# Reuse df_metric_window_labeled from kernel
assert "df_metric_window_labeled" in globals(), "df_metric_window_labeled not found in kernel"

# Target service and KPIs
service = "ts-order-service"
kpi_list = ['latency-90','latency-50','cpu','workload','socket','diskio','error','mem']

# Filter to service and KPIs within the incident window (df_metric_window_labeled is already window-filtered)
df_order = df_metric_window_labeled[
    (df_metric_window_labeled["cmdb_id"] == service) &
    (df_metric_window_labeled["kpi_name"].isin(kpi_list))
].copy()

# Ensure P95/P5 exist; if anom flags not present, compute them (they should exist)
if "anom_high" not in df_order.columns or "anom_low" not in df_order.columns:
    df_order["anom_high"] = np.where(df_order["P95"].notna() & (df_order["value"] >= df_order["P95"]), 1, 0)
    df_order["anom_low"]  = np.where(df_order["P5"].notna() & (df_order["value"] <= df_order["P5"]), 1, 0)

# Select only anomalous points (value >= P95 OR value <= P5)
mask_anom = (df_order["P95"].notna() & (df_order["value"] >= df_order["P95"])) | (df_order["P5"].notna() & (df_order["value"] <= df_order["P5"]))
order_metric_anoms_window = df_order[mask_anom].copy()  # store full filtered per-point set in kernel

# Determine anomaly_type for each anomalous point
order_metric_anoms_window["anomaly_type"] = np.where(
    order_metric_anoms_window["P95"].notna() & (order_metric_anoms_window["value"] >= order_metric_anoms_window["P95"]),
    "high",
    "low"
)

# Prepare the ordered compact per-point table (limit to top 50 by timestamp ascending)
order_anom_points_head50 = (
    order_metric_anoms_window
    .sort_values("timestamp_dt", ascending=True)
    .loc[:, ["timestamp_dt", "cmdb_id", "kpi_name", "value", "P95", "P5", "anomaly_type"]]
    .head(50)
)

# Tiny per-KPI summary for ts-order-service (within window)
def earliest_ts_or_nat(s):
    if s.empty:
        return pd.NaT
    return s.min()

summary_rows = []
for kpi in kpi_list:
    df_k = df_order[df_order["kpi_name"] == kpi]
    if df_k.empty:
        summary_rows.append({
            "kpi_name": kpi,
            "count_points_in_window": 0,
            "count_anom_high": 0,
            "count_anom_low": 0,
            "earliest_anom_high_ts": pd.NaT,
            "earliest_anom_low_ts": pd.NaT,
            "max_value_in_window": np.nan
        })
        continue
    count_points = df_k.shape[0]
    mask_high = df_k["P95"].notna() & (df_k["value"] >= df_k["P95"])
    mask_low  = df_k["P5"].notna() & (df_k["value"] <= df_k["P5"])
    count_high = int(mask_high.sum())
    count_low = int(mask_low.sum())
    earliest_high_ts = df_k.loc[mask_high, "timestamp_dt"].min() if count_high>0 else pd.NaT
    earliest_low_ts  = df_k.loc[mask_low,  "timestamp_dt"].min() if count_low>0 else pd.NaT
    max_value = df_k["value"].max()
    summary_rows.append({
        "kpi_name": kpi,
        "count_points_in_window": count_points,
        "count_anom_high": count_high,
        "count_anom_low": count_low,
        "earliest_anom_high_ts": earliest_high_ts,
        "earliest_anom_low_ts": earliest_low_ts,
        "max_value_in_window": max_value
    })

order_kpi_summary = pd.DataFrame(summary_rows)

# Final displayed variables (compact): the per-point head (<=50), the per-kpi summary, and the stored full set
order_anom_points_head50, order_kpi_summary, order_metric_anoms_window.shape
