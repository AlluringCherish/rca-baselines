# Reuse df_metric already loaded in the kernel.
import pandas as pd
# Ensure timestamp parsed (should exist from prior steps); if not, parse now.
if "timestamp_dt" not in df_metric.columns and "timestamp" in df_metric.columns:
    df_metric["timestamp_dt"] = pd.to_datetime(df_metric["timestamp"], unit="s", utc=True)

# 1) Compute basic aggregates per (cmdb_id, kpi_name)
metric_agg_basic = (
    df_metric
    .groupby(["cmdb_id", "kpi_name"], as_index=False)
    .agg(
        count=("value", "size"),
        value_mean=("value", "mean"),
        value_min=("value", "min"),
        value_max=("value", "max"),
        value_std=("value", "std"),
    )
)

# 2) Compute quantiles (global across the full series)
q95 = df_metric.groupby(["cmdb_id", "kpi_name"])["value"].quantile(0.95).reset_index(name="P95")
q90 = df_metric.groupby(["cmdb_id", "kpi_name"])["value"].quantile(0.90).reset_index(name="P90")
q05 = df_metric.groupby(["cmdb_id", "kpi_name"])["value"].quantile(0.05).reset_index(name="P5")

# 3) Merge quantiles into the main aggregated table
metric_agg_full = (
    metric_agg_basic
    .merge(q95, on=["cmdb_id", "kpi_name"], how="left")
    .merge(q90, on=["cmdb_id", "kpi_name"], how="left")
    .merge(q05, on=["cmdb_id", "kpi_name"], how="left")
)

# Keep the full aggregated table in the kernel for later use (variable: metric_agg_full)
# 4) Prepare compact summary: total number of distinct groups and top 20 by P95 desc
metric_agg_count = metric_agg_full.shape[0]

metric_agg_top20 = (
    metric_agg_full
    .sort_values("P95", ascending=False)
    .loc[:, ["cmdb_id", "kpi_name", "count", "value_mean", "value_min", "value_max", "value_std", "P95", "P90", "P5"]]
    .head(20)
)

# Display compact results (as variables, per rules)
metric_agg_count, metric_agg_top20
