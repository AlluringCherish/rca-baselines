import re
import pandas as pd
import numpy as np

# Ensure source exists
assert "df_trace_window_labeled" in globals(), "df_trace_window_labeled not found in kernel"

# Candidate services
candidates = ['ts-auth-service','ts-order-service','ts-route-service','ts-train-service','ts-travel-service']

# Regex to extract target after 'to_ts-'
pattern = r"to_ts-(" + "|".join(re.escape(c) for c in candidates) + r")(?=\.|$)"

# Filter rows where cmdb_id == 'root' and trace_name contains to_ts-<candidate>
mask_root = (df_trace_window_labeled["cmdb_id"] == "root")
df_root = df_trace_window_labeled[mask_root].copy()
df_root["target_candidate"] = df_root["trace_name"].astype(str).str.extract(pattern, expand=False)

# Keep only rows with a matched target
root_to_candidates_traces = df_root[df_root["target_candidate"].notna()].copy()  # stored in kernel

# If empty, produce empty aggregated result
if root_to_candidates_traces.empty:
    root_to_candidates_agg_top20 = root_to_candidates_traces.head(20)
else:
    # Ensure anomaly flags exist
    if "anom_high" not in root_to_candidates_traces.columns:
        root_to_candidates_traces["anom_high"] = np.where(root_to_candidates_traces["P95"].notna() & (root_to_candidates_traces["value"] >= root_to_candidates_traces["P95"]), 1, 0)
    if "anom_low" not in root_to_candidates_traces.columns:
        root_to_candidates_traces["anom_low"]  = np.where(root_to_candidates_traces["P5"].notna() & (root_to_candidates_traces["value"] <= root_to_candidates_traces["P5"]), 1, 0)

    group_cols = ["trace_name", "target_candidate"]

    agg_basic = root_to_candidates_traces.groupby(group_cols, as_index=False).agg(
        count_points=("value", "size"),
        count_anom_high=("anom_high", "sum"),
        max_value_in_window=("value", "max"),
        count_anom_low=("anom_low", "sum"),
        min_value_in_window=("value", "min"),
        P95=("P95", "first"),
    )

    # Earliest anomaly timestamps
    earliest_high = (
        root_to_candidates_traces[root_to_candidates_traces["anom_high"] == 1]
        .groupby(group_cols, as_index=False)["timestamp_dt"]
        .min()
        .rename(columns={"timestamp_dt": "earliest_anom_high_ts"})
    )
    earliest_low = (
        root_to_candidates_traces[root_to_candidates_traces["anom_low"] == 1]
        .groupby(group_cols, as_index=False)["timestamp_dt"]
        .min()
        .rename(columns={"timestamp_dt": "earliest_anom_low_ts"})
    )

    agg = agg_basic.merge(earliest_high, on=group_cols, how="left").merge(earliest_low, on=group_cols, how="left")

    # Compute severity_high = max_value_in_window / P95 (if P95>0)
    agg["severity_high"] = np.where((agg["P95"] > 0) & agg["P95"].notna(), agg["max_value_in_window"] / agg["P95"], np.nan)

