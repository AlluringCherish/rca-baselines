import pandas as pd
import numpy as np

# Reuse existing df_log if available; otherwise load
if "df_log" not in globals():
    df_log = pd.read_csv("log.csv")

# Parse timestamp to UTC datetime if not already
if "timestamp_dt" not in df_log.columns and "timestamp" in df_log.columns:
    df_log["timestamp_dt"] = pd.to_datetime(df_log["timestamp"], unit="s", utc=True)

# 1) Global aggregations across full log series grouped by (cmdb_id, log_name)
log_agg_basic = (
    df_log
    .groupby(["cmdb_id", "log_name"], as_index=False)
    .agg(
        count=("value", "size"),
        value_mean=("value", "mean"),
        value_min=("value", "min"),
        value_max=("value", "max"),
        value_std=("value", "std"),
    )
)

# Quantiles (global, computed before any window filtering)
q95 = df_log.groupby(["cmdb_id", "log_name"])["value"].quantile(0.95).reset_index(name="P95")
q90 = df_log.groupby(["cmdb_id", "log_name"])["value"].quantile(0.90).reset_index(name="P90")
q05 = df_log.groupby(["cmdb_id", "log_name"])["value"].quantile(0.05).reset_index(name="P5")

# Merge quantiles into full aggregated table
log_agg_full = log_agg_basic.merge(q95, on=["cmdb_id", "log_name"], how="left") \
                            .merge(q90, on=["cmdb_id", "log_name"], how="left") \
                            .merge(q05, on=["cmdb_id", "log_name"], how="left")

# Keep log_agg_full in kernel

# 2) Filter log points to incident window (UTC)
start_ts = pd.to_datetime("2024-01-22 10:56:05", utc=True)
end_ts   = pd.to_datetime("2024-01-22 11:26:05", utc=True)

df_log_window = df_log[(df_log["timestamp_dt"] >= start_ts) & (df_log["timestamp_dt"] <= end_ts)].copy()

# 3) Join each point with its group's global thresholds
thresholds = log_agg_full[["cmdb_id", "log_name", "P95", "P5"]]
df_log_window_labeled = df_log_window.merge(thresholds, on=["cmdb_id", "log_name"], how="left")

# 4) Label anomalies using global thresholds
df_log_window_labeled["anom_high"] = np.where(df_log_window_labeled["P95"].notna() & (df_log_window_labeled["value"] >= df_log_window_labeled["P95"]), 1, 0)
df_log_window_labeled["anom_low"]  = np.where(df_log_window_labeled["P5"].notna()  & (df_log_window_labeled["value"] <= df_log_window_labeled["P5"]), 1, 0)

# 5) Filter to candidate components and store full per-point labeled table
candidates = ['ts-auth-service','ts-order-service','ts-route-service','ts-train-service','ts-travel-service']
log_candidates_window = df_log_window_labeled[df_log_window_labeled["cmdb_id"].isin(candidates)].copy()

# 6) Aggregate per (cmdb_id, log_name) within the window
group_cols = ["cmdb_id", "log_name"]
agg_basic = (
    log_candidates_window
    .groupby(group_cols, as_index=False)
    .agg(
        count_points=("value", "size"),
        count_anom_high=("anom_high", "sum"),
        max_value_in_window=("value", "max"),
        count_anom_low=("anom_low", "sum"),
        min_value_in_window=("value", "min"),
    )
)

# Earliest anomaly timestamps
earliest_high = (
    log_candidates_window[log_candidates_window["anom_high"] == 1]
    .groupby(group_cols, as_index=False)["timestamp_dt"]
    .min()
    .rename(columns={"timestamp_dt": "earliest_anom_high_ts"})
)
earliest_low = (
    log_candidates_window[log_candidates_window["anom_low"] == 1]
    .groupby(group_cols, as_index=False)["timestamp_dt"]
    .min()
    .rename(columns={"timestamp_dt": "earliest_anom_low_ts"})
)

# Merge earliest timestamps
agg = agg_basic.merge(earliest_high, on=group_cols, how="left").merge(earliest_low, on=group_cols, how="left")

# Keep only rows where any anomalies exist
