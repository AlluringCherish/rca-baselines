    agg_anom = agg[(agg["count_anom_high"] + agg["count_anom_low"]) > 0].copy()

    # Sort by earliest_anom_high_ts ascending (put NaT at the end)
    agg_anom["earliest_anom_high_ts_sort"] = agg_anom["earliest_anom_high_ts"].fillna(pd.Timestamp.max.tz_localize("UTC"))
    agg_sorted = agg_anom.sort_values(by=["earliest_anom_high_ts_sort", "count_anom_high"], ascending=[True, False])

    # Select and limit to top 20 rows
    root_to_candidates_agg_top20 = agg_sorted.loc[:, [
        "trace_name", "target_candidate",
        "count_points", "count_anom_high", "earliest_anom_high_ts", "max_value_in_window",
        "count_anom_low", "earliest_anom_low_ts", "min_value_in_window", "severity_high"
    ]].head(20)

