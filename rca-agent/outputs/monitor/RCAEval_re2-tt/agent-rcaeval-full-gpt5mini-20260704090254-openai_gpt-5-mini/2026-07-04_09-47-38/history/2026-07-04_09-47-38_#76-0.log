        'min_value': float(agg['min_value']),
        'max_value': float(agg['max_value']),
        'mean_value': float(agg['mean_value'])
    }])
else:
    aggregate_summary = pd.DataFrame([{
        'count_in_window': 0,
        'min_timestamp': pd.NA,
        'max_timestamp': pd.NA,
        'min_value': pd.NA,
        'max_value': pd.NA,
        'mean_value': pd.NA
    }])

