        'max_value_in_window': float(g['value'].max()) if g['value'].count()>0 else pd.NA,
        'mean_value_in_window': float(g['value'].mean()) if g['value'].count()>0 else pd.NA
    })
).reset_index()

# Now ensure every (cmdb_id,kpi_name) present in metric_agg_global is represented (fill zeros/NA where absent in window)
