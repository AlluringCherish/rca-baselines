# 1) Aggregate summary
if not ts_travel_mem_window.empty:
    agg = ts_travel_mem_window.agg(
        count_in_window = ('value','count'),
        min_timestamp = ('timestamp','min'),
        max_timestamp = ('timestamp','max'),
        min_value = ('value','min'),
        max_value = ('value','max'),
        mean_value = ('value','mean')
    )
    # Ensure types and put into a one-row DataFrame for compact display
    aggregate_summary = pd.DataFrame([{
        'count_in_window': int(agg['count_in_window']),
        'min_timestamp': int(agg['min_timestamp']),
