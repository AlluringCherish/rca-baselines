    # s is Series of timestamps where corresponding boolean mask is True
    if len(s) == 0:
        return pd.NA
    return int(s.min())

grouped = win_with_p95.groupby(['cmdb_id','kpi_name'])

agg_win = grouped.agg(
    count_in_window = ('value', 'count'),
    n_anomaly_ge_p95 = (lambda df: (df['value'] >= df['p95']).sum()),
    earliest_anom_ts = (lambda df: (
        int(df.loc[df['value'] >= df['p95'], 'timestamp'].min())
        if (df['value'] >= df['p95']).any() else pd.NA
    )),
    max_value_in_window = ('value', 'max'),
