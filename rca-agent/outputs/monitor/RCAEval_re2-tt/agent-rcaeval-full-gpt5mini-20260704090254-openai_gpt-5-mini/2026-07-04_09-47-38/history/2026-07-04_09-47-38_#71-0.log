import pandas as pd

# Reuse existing `log` if available; otherwise load
try:
    log
except NameError:
    log = pd.read_csv("log.csv")

# Ensure types and timestamps
log['timestamp'] = pd.to_numeric(log['timestamp'], errors='coerce').astype('Int64')
log['value'] = pd.to_numeric(log['value'], errors='coerce')
log['ts'] = pd.to_datetime(log['timestamp'], unit='s', utc=True)

# Candidate services and incident window (UTC)
candidates = ["ts-order-service", "ts-travel-service", "ts-preserve-service", "ts-seat-service", "ts-admin-travel-service", "ts-auth-service", "ts-route-service"]
start = pd.Timestamp("2024-01-24 18:29:59", tz='UTC')
end   = pd.Timestamp("2024-01-24 18:59:59", tz='UTC')

# Filter rows to window and candidates
log_window = log[log['cmdb_id'].isin(candidates) & (log['ts'] >= start) & (log['ts'] <= end)].copy()

# Total number of nonzero log records across these services in the window
total_nonzero_log_records = int((log_window['value'] > 0).sum())

# If no rows, return empty structure
if log_window.empty:
    out = {"table": [], "total_nonzero_log_records": total_nonzero_log_records}
else:
    # Compute per-group aggregates
    grp = log_window.groupby(['cmdb_id', 'log_name'], as_index=False)

    agg = grp.agg(
        total_points_in_window = ('value', 'size'),
        count_nonzero_points = (lambda df: (df['value'] > 0).sum(),),
        sum_value = ('value', 'sum'),
        max_value = ('value', 'max'),
    )

    # The above custom agg for count_nonzero_points produced a column with a tuple key; normalize:
    # If column name is a tuple, rename appropriately
    if isinstance(agg.columns[3], tuple):
        # find the column that contains 'count_nonzero_points' name within tuple
        cols = list(agg.columns)
        for i, c in enumerate(cols):
            if isinstance(c, tuple) and c[0] == '':
                cols[i] = 'count_nonzero_points'
        agg.columns = cols

    # Compute earliest timestamp of nonzero per group
    nonzero = log_window[log_window['value'] > 0]
    if not nonzero.empty:
        earliest = nonzero.groupby(['cmdb_id', 'log_name'], as_index=False)['timestamp'].min().rename(columns={'timestamp':'earliest_timestamp_of_nonzero'})
    else:
        earliest = pd.DataFrame(columns=['cmdb_id','log_name','earliest_timestamp_of_nonzero'])

    summary = agg.merge(earliest, on=['cmdb_id','log_name'], how='left')

    # Ensure correct dtypes and convert NA to None-friendly types
    summary['sum_value'] = pd.to_numeric(summary['sum_value'], errors='coerce')
    summary['max_value'] = pd.to_numeric(summary['max_value'], errors='coerce')
    summary['earliest_timestamp_of_nonzero'] = summary['earliest_timestamp_of_nonzero'].where(summary['earliest_timestamp_of_nonzero'].notna(), None)

    # Sort by count_nonzero_points desc then sum_value desc
    summary_sorted = summary.sort_values(by=['count_nonzero_points','sum_value'], ascending=[False, False])

    # Limit to top 20 rows
    top = summary_sorted.head(20).copy()

    # Prepare JSON-serializable table records
    table_records = []
    for _, r in top.iterrows():
        rec = {
            "cmdb_id": str(r['cmdb_id']),
            "log_name": str(r['log_name']),
            "total_points_in_window": int(r['total_points_in_window']),
            "count_nonzero_points": int(r['count_nonzero_points']),
            "sum_value": (float(r['sum_value']) if pd.notna(r['sum_value']) else None),
            "max_value": (float(r['max_value']) if pd.notna(r['max_value']) else None),
            "earliest_timestamp_of_nonzero_point": (int(r['earliest_timestamp_of_nonzero']) if r['earliest_timestamp_of_nonzero'] is not None else None)
        }
        table_records.append(rec)

    out = {
        "table": table_records,
        "total_nonzero_log_records": total_nonzero_log_records
    }

