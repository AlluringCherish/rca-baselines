import pandas as pd
import numpy as np
import re

# Reuse df_trace if available; otherwise load
try:
    df_trace
except NameError:
    df_trace = pd.read_csv("trace.csv")

# Ensure timestamp parsed as UTC datetimes
if not pd.api.types.is_datetime64_any_dtype(df_trace['timestamp']):
    df_trace['timestamp'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True)

# Ensure numeric values
df_trace['value'] = pd.to_numeric(df_trace['value'], errors='coerce')

# Incident window (UTC)
start_ts = pd.Timestamp('2024-01-22 17:06:32', tz='UTC')
end_ts = pd.Timestamp('2024-01-22 17:36:32', tz='UTC')

# Compute global_p95 per (cmdb_id, trace_name) from the full trace series (no window filtering)
thr_trace_full = (
    df_trace
    .dropna(subset=['cmdb_id', 'trace_name', 'value'])
    .groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
    .agg(global_p95=lambda s: s.quantile(0.95))
)

# Filter trace rows to incident window
trace_win = df_trace[(df_trace['timestamp'] >= start_ts) & (df_trace['timestamp'] <= end_ts)].copy()

# Merge global p95 into windowed rows
trace_win = trace_win.merge(thr_trace_full, on=['cmdb_id', 'trace_name'], how='left')

# Mark high_anomaly if value >= global_p95 (handle missing thresholds conservatively as False)
trace_win['high_anomaly'] = False
mask_valid = trace_win['global_p95'].notna()
trace_win.loc[mask_valid, 'high_anomaly'] = trace_win.loc[mask_valid, 'value'] >= trace_win.loc[mask_valid, 'global_p95']

# Parse trace_name to extract direction and peer_service
# direction: 'from' if contains 'from_<svc>', 'to' if contains 'to_<svc>', else 'other'
# peer_service: extracted <svc> part after from_ or to_, stopping at the next dot (.)
trace_win['direction'] = 'other'
trace_win.loc[trace_win['trace_name'].str.contains(r'\bfrom_', na=False), 'direction'] = 'from'
trace_win.loc[trace_win['trace_name'].str.contains(r'\bto_', na=False), 'direction'] = 'to'

# Extract peer_service using regex
trace_win['peer_service'] = trace_win['trace_name'].str.extract(r'\bfrom_([^.\s]+)', expand=False)
# fill where to_ pattern
to_peers = trace_win['trace_name'].str.extract(r'\bto_([^.\s]+)', expand=False)
trace_win['peer_service'] = trace_win['peer_service'].fillna(to_peers)

# Normalize empty/NaN peer to None
trace_win['peer_service'] = trace_win['peer_service'].where(trace_win['peer_service'].notna(), None)

# Aggregate per cmdb_id, direction, peer_service, trace_name
agg = (
    trace_win
    .groupby(['cmdb_id', 'direction', 'peer_service', 'trace_name'], dropna=False, as_index=False)
    .agg(
        count_in_window=('value', 'count'),
        anomalies_high_count=('high_anomaly', lambda s: int(s.sum())),
        earliest_high_timestamp=('timestamp', lambda s: s[s.index[s.index.isin(s.index)][0]] if False else pd.NaT),  # placeholder, will compute below
        max_value_in_window=('value', 'max'),
    )
)

# Compute earliest_high_timestamp properly: for groups with high anomalies, find min timestamp where high_anomaly True
# We'll build a helper df of high rows then merge
high_rows = trace_win[trace_win['high_anomaly']].copy()
if not high_rows.empty:
    earliest_high = (
        high_rows
        .groupby(['cmdb_id', 'direction', 'peer_service', 'trace_name'], dropna=False, as_index=False)
        .agg(earliest_high_timestamp=('timestamp', 'min'),
             anomalies_high_count_actual=('high_anomaly', 'sum'))
    )
    # Merge earliest timestamps into agg
    agg = agg.merge(earliest_high[['cmdb_id','direction','peer_service','trace_name','earliest_high_timestamp','anomalies_high_count_actual']],
                    on=['cmdb_id','direction','peer_service','trace_name'],
                    how='left')
    # Replace anomalies_high_count with actual sum (should match) and set earliest
    agg['anomalies_high_count'] = agg['anomalies_high_count_actual'].fillna(0).astype(int)
    agg.drop(columns=['anomalies_high_count_actual'], inplace=True)
    agg['earliest_high_timestamp'] = agg['earliest_high_timestamp']
else:
    # no high rows, set anomalies_high_count to 0 and earliest NaT
    agg['earliest_high_timestamp'] = pd.NaT
    agg['anomalies_high_count'] = 0

# Merge global_p95 into agg for display (from thr_trace_full)
agg = agg.merge(thr_trace_full.rename(columns={'trace_name':'trace_name'}), on=['cmdb_id','trace_name'], how='left')

# Keep only rows where anomalies_high_count > 0
agg_pos = agg[agg['anomalies_high_count'] > 0].copy()

# Convert earliest_high_timestamp to ISO string (UTC) for display, keeping dtype in variable if needed
agg_pos['earliest_high_timestamp'] = pd.to_datetime(agg_pos['earliest_high_timestamp'], utc=True)
agg_pos['earliest_high_timestamp_str'] = agg_pos['earliest_high_timestamp'].dt.tz_convert('UTC').astype(str)

# Select and order columns as requested
main_table = agg_pos[['cmdb_id','direction','peer_service','trace_name',
                     'count_in_window','anomalies_high_count','earliest_high_timestamp_str',
                     'max_value_in_window','global_p95']].copy()
main_table = main_table.rename(columns={'earliest_high_timestamp_str':'earliest_high_timestamp'})

# Sort by anomalies_high_count desc then max_value_in_window desc and limit to top 50
main_table = main_table.sort_values(['anomalies_high_count','max_value_in_window'], ascending=[False, False]).head(50).reset_index(drop=True)

# Prepare per-candidate summary for given services
candidates = ['ts-auth-service', 'ts-order-service', 'ts-route-service', 'ts-train-service', 'ts-travel-service']

summary_rows = []
for comp in candidates:
    comp_rows = trace_win[trace_win['cmdb_id'] == comp].copy()
    # compute total anomalies in window for this cmdb_id
    total_trace_anomalies = int(comp_rows['high_anomaly'].sum())
    # earliest anomaly timestamp across this cmdb_id
    if total_trace_anomalies > 0:
        earliest_ts = comp_rows.loc[comp_rows['high_anomaly'], 'timestamp'].min()
        earliest_ts_str = pd.to_datetime(earliest_ts, utc=True).tz_convert('UTC').isoformat()
    else:
        earliest_ts_str = None
    # peer services with anomalies: group by peer_service and count high_anomaly
    peers = (
        comp_rows[comp_rows['high_anomaly']]
        .groupby('peer_service', dropna=False)['high_anomaly']
        .sum()
        .reset_index()
        .rename(columns={'high_anomaly':'anomaly_count'})
    )
    if peers.shape[0] > 0:
        peers = peers.sort_values('anomaly_count', ascending=False)
        # format top 5 as "peer (count)" and handle None as 'other'
        peers['peer_label'] = peers['peer_service'].fillna('other').astype(str) + ' (' + peers['anomaly_count'].astype(int).astype(str) + ')'
        top_peers_list = peers['peer_label'].head(5).tolist()
    else:
        top_peers_list = []
    peers_str = ', '.join(top_peers_list) if top_peers_list else None
    summary_rows.append({
        'cmdb_id': comp,
        'total_trace_anomalies_in_window': total_trace_anomalies,
        'earliest_trace_anomaly_timestamp': earliest_ts_str,
        'list_of_peer_services_with_anomalies': peers_str
    })

candidate_summary = pd.DataFrame(summary_rows)

# Display compact outputs: main_table (<=50 rows) and candidate_summary (5 rows)
main_table, candidate_summary
