import pandas as pd

# filenames
files = {
    "metric.csv": {"name_col": "kpi_name"},
    "trace.csv": {"name_col": "trace_name"},
    "log.csv": {"name_col": "log_name"},
    "error_logs.csv": {"name_col": "message"},
}

rows = []
for fname, meta in files.items():
    # load CSV
    df = pd.read_csv(fname)
    # parse timestamp to UTC datetimes
    df['timestamp'] = pd.to_datetime(df['timestamp'], unit='s', utc=True)
    # basic aggregates
    row_count = int(df.shape[0])
    min_ts = df['timestamp'].min()
    max_ts = df['timestamp'].max()
    unique_cmdb_ids = sorted(df['cmdb_id'].dropna().unique())[:50]  # limit to 50
    # name/count summaries
    name_col = meta['name_col']
    if name_col in df.columns:
        name_counts = df[name_col].fillna("<NA>").value_counts()
        # For metric/trace/log: provide up to 50 name:count strings
        if fname != "error_logs.csv":
            top_pairs = [f"{n} : {int(c)}" for n, c in name_counts.items()[:50]]
        else:
            # For error_logs: return top 20 distinct message samples (with counts), truncate messages for compactness
            top = name_counts.items()[:20]
            def truncate_msg(s, l=200):
                s = str(s)
                return s if len(s) <= l else s[:l]+"...[truncated]"
            top_pairs = [f"{truncate_msg(n)} : {int(c)}" for n, c in top]
    else:
        top_pairs = []
    rows.append({
        "file_name": fname,
        "row_count": row_count,
        "min_timestamp_utc": min_ts,
        "max_timestamp_utc": max_ts,
        "unique_cmdb_ids": unique_cmdb_ids,
        "unique_metric_names_with_counts_or_top_messages": top_pairs
    })

summary_df = pd.DataFrame(rows)

# Keep final output compact
summary_df[[
    "file_name",
    "row_count",
    "min_timestamp_utc",
    "max_timestamp_utc",
    "unique_cmdb_ids",
    "unique_metric_names_with_counts_or_top_messages"
]]
