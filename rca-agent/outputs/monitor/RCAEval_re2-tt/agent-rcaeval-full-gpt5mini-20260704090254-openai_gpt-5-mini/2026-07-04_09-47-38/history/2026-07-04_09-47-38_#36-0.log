def get_p95(df, match_col, cmdb, name_sub):
    try:
        row = df[(df['cmdb_id']==cmdb) & (df[match_col].str.contains(name_sub, na=False))]
        if not row.empty:
            return float(row.iloc[0]['p95_value'])
    except Exception:
        pass
    return None

