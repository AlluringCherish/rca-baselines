import pandas as pd

# Reuse trace_df if present; otherwise load
try:
    trace_df
except NameError:
    trace_df = pd.read_csv("trace.csv")

# Ensure timestamp parsed as UTC datetimes
trace_df['timestamp'] = pd.to_datetime(trace_df['timestamp'], unit='s', utc=True)

# Candidate services and filter conditions
services = [
    "ts-auth-service",
    "ts-order-service",
    "ts-route-service",
    "ts-train-service",
    "ts-travel-service",
]
service_pattern = "|".join(services)  # regex OR

# Keep trace rows that mention any candidate service (to_, from_, or direct) AND are latency/error indicators
indicator_keywords = ['duration', 'error_rate', 'row_count']
indicator_pattern = "|".join(indicator_keywords)

mask_service = trace_df['trace_name'].str.contains(service_pattern, na=False)
mask_indicator = trace_df['trace_name'].str.contains(indicator_pattern, na=False)
df_filtered = trace_df[mask_service & mask_indicator].copy()

# 1) Compute global P95 for each distinct trace_name in this filtered set using the full series for that trace_name
trace_names_of_interest = df_filtered['trace_name'].unique().tolist()

global_p95 = (
    trace_df[trace_df['trace_name'].isin(trace_names_of_interest)]
    .groupby('trace_name', as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# 2) Filter to incident window (inclusive)
start = pd.Timestamp("2024-01-23 04:57:52", tz='UTC')
end = pd.Timestamp("2024-01-23 05:27:52", tz='UTC')

df_window = trace_df[
    (trace_df['timestamp'] >= start) &
    (trace_df['timestamp'] <= end) &
    (trace_df['trace_name'].isin(trace_names_of_interest))
].copy()

# Attach global_p95 for anomaly detection
df_window = df_window.merge(global_p95, on='trace_name', how='left')

# Mark anomalies where value > global_p95
df_window['is_anom'] = df_window['value'] > df_window['global_p95']

# Aggregates within window per trace_name
window_counts = (
    df_window
    .groupby('trace_name', as_index=False)
    .agg(
        total_points_in_window=('value', 'count'),
        anomaly_count_in_window=('is_anom', 'sum'),
        max_value_in_window=('value', 'max')
    )
)

# Earliest anomaly timestamp per trace_name
earliest_anom = (
    df_window[df_window['is_anom']]
    .groupby('trace_name', as_index=False)['timestamp']
    .min()
    .rename(columns={'timestamp': 'earliest_anomaly_timestamp_utc'})
)

# Combine global_p95 with window aggregates
result = global_p95.merge(window_counts, on='trace_name', how='left')
result = result.merge(earliest_anom, on='trace_name', how='left')

# Fill missing numeric aggregates with zeros (no points in window)
result['total_points_in_window'] = result['total_points_in_window'].fillna(0).astype(int)
result['anomaly_count_in_window'] = result['anomaly_count_in_window'].fillna(0).astype(int)

# Sort by anomaly_count desc then max_value desc
result_sorted = result.sort_values(
    by=['anomaly_count_in_window', 'max_value_in_window'],
    ascending=[False, False]
).reset_index(drop=True)

# Select requested columns and limit to top 20
final_table = result_sorted[[
    'trace_name',
    'global_p95',
    'total_points_in_window',
    'anomaly_count_in_window',
    'earliest_anomaly_timestamp_utc',
    'max_value_in_window'
]].head(20)

