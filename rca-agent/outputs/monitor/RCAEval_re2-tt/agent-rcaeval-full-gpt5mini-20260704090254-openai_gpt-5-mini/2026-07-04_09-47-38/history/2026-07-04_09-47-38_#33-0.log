import pandas as pd

# Reuse existing metric_df from kernel state
services = [
    "ts-auth-service",
    "ts-order-service",
    "ts-route-service",
    "ts-train-service",
    "ts-travel-service",
]

# 1) Select candidate-service rows and compute global P95 per (cmdb_id, kpi_name)
df_candidates = metric_df[metric_df['cmdb_id'].isin(services)].copy()

global_p95 = (
    df_candidates
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# 2) Filter by incident window (UTC inclusive)
start = pd.Timestamp("2024-01-23 04:57:52", tz='UTC')
end = pd.Timestamp("2024-01-23 05:27:52", tz='UTC')

df_window = df_candidates[(df_candidates['timestamp'] >= start) & (df_candidates['timestamp'] <= end)].copy()

# Attach global_p95 to window rows for anomaly detection
df_window = df_window.merge(global_p95, on=['cmdb_id', 'kpi_name'], how='left')

# Mark anomalies where value > global_p95
df_window['is_anom'] = df_window['value'] > df_window['global_p95']

# Aggregates within window per pair
window_counts = (
    df_window
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        total_points_in_window=('value', 'count'),
        anomaly_count_in_window=('is_anom', 'sum'),
        max_value_in_window=('value', 'max')
    )
)

# Earliest anomaly timestamp per pair (if any)
earliest_anom = (
    df_window[df_window['is_anom']]
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['timestamp']
    .min()
    .rename(columns={'timestamp': 'earliest_anomaly_timestamp_utc'})
)

# Combine global_p95 with window aggregates, ensuring pairs with no window data are kept
result = global_p95.merge(window_counts, on=['cmdb_id', 'kpi_name'], how='left')
result = result.merge(earliest_anom, on=['cmdb_id', 'kpi_name'], how='left')

# Fill missing numeric aggregates with zeros (no points in window)
result['total_points_in_window'] = result['total_points_in_window'].fillna(0).astype(int)
