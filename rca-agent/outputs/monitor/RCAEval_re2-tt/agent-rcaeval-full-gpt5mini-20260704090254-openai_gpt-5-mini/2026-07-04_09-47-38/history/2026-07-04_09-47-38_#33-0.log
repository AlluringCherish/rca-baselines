import pandas as pd

# Reuse or load log_df, ensure timestamp parsed as UTC datetimes
try:
    log_df
except NameError:
    log_df = pd.read_csv("log.csv")
log_df['timestamp'] = pd.to_datetime(log_df['timestamp'], unit='s', utc=True)

# Candidate services
services = [
    "ts-auth-service",
    "ts-order-service",
    "ts-route-service",
    "ts-train-service",
    "ts-travel-service",
]

# Restrict to candidate services for global P95 computation
log_candidates = log_df[log_df['cmdb_id'].isin(services)].copy()

# 1) Compute global P95 per (cmdb_id, log_name) using full available series for those services
global_p95 = (
    log_candidates
    .groupby(['cmdb_id', 'log_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# 2) Filter to incident window (inclusive)
start = pd.Timestamp("2024-01-23 04:57:52", tz='UTC')
end = pd.Timestamp("2024-01-23 05:27:52", tz='UTC')

log_window = log_candidates[
    (log_candidates['timestamp'] >= start) &
    (log_candidates['timestamp'] <= end)
].copy()

# Attach global_p95 for anomaly detection
log_window = log_window.merge(global_p95, on=['cmdb_id', 'log_name'], how='left')

# Mark anomalies where value > global_p95
log_window['is_anom'] = log_window['value'] > log_window['global_p95']

# Aggregates within window per (cmdb_id, log_name)
window_agg = (
    log_window
    .groupby(['cmdb_id', 'log_name'], as_index=False)
    .agg(
        total_points_in_window=('value', 'count'),
        anomaly_count_in_window=('is_anom', 'sum'),
        max_value_in_window=('value', 'max')
    )
)

# Earliest anomaly timestamp per pair
earliest_anom = (
    log_window[log_window['is_anom']]
    .groupby(['cmdb_id', 'log_name'], as_index=False)['timestamp']
    .min()
    .rename(columns={'timestamp': 'earliest_anomaly_timestamp_utc'})
)

# Combine global_p95 with window aggregates; keep all pairs seen in global_p95
result = global_p95.merge(window_agg, on=['cmdb_id', 'log_name'], how='left')
result = result.merge(earliest_anom, on=['cmdb_id', 'log_name'], how='left')

# Fill missing numeric aggregates with zeros (no points in window)
result['total_points_in_window'] = result['total_points_in_window'].fillna(0).astype(int)
result['anomaly_count_in_window'] = result['anomaly_count_in_window'].fillna(0).astype(int)

# Sort by anomaly_count desc then max_value desc
result_sorted = result.sort_values(
    by=['anomaly_count_in_window', 'max_value_in_window'],
    ascending=[False, False]
).reset_index(drop=True)

# Select requested columns and limit to top 20 rows
final_table = result_sorted[[
    'cmdb_id',
    'log_name',
    'global_p95',
    'total_points_in_window',
    'anomaly_count_in_window',
    'earliest_anomaly_timestamp_utc',
    'max_value_in_window'
]].head(20)

final_table
