import re
import pandas as pd
import numpy as np

# Reuse existing variables: trace_candidates_incident, trace_candidates_agg
# (they were created in previous steps)

# 1) Extract rows whose trace_name contains 'to_ts-' or 'from_ts-'
mask_to_from = trace_candidates_incident['trace_name'].str.contains(r'\b(?:to_ts-|from_ts-)', regex=True)
parsed_trace_refs = trace_candidates_incident[mask_to_from].copy()

# 1b) Parse referenced service name using regex
# capture the token after to_ts- or from_ts- (letters, digits, hyphens)
parsed_trace_refs['referenced_service'] = parsed_trace_refs['trace_name'].str.extract(r'(?:to_ts-|from_ts-)([a-z0-9\-]+)', flags=re.IGNORECASE, expand=False)

# 2) Keep only parsed referenced services that are in the candidate list
candidates = ['ts-auth-service', 'ts-order-service', 'ts-route-service', 'ts-train-service', 'ts-travel-service']
parsed_trace_refs = parsed_trace_refs[parsed_trace_refs['referenced_service'].isin(candidates)].copy()

# Ensure referenced_service values are normalized (lowercase)
parsed_trace_refs['referenced_service'] = parsed_trace_refs['referenced_service'].str.lower()

# Prepare lookup of global thresholds from trace_candidates_agg (computed on full series)
agg_lookup = trace_candidates_agg.set_index(['cmdb_id','trace_name'])

# Helper to determine low-is-bad (success metrics)
def is_low_is_bad_trace(name):
    return ('success' in str(name).lower())

# 3) For each (caller_cmdb_id, referenced_service, trace_name) compute required stats
grouped = parsed_trace_refs.groupby(['cmdb_id','referenced_service','trace_name'])

rows = []
for (caller, callee, tname), g in grouped:
    incident_count = int(g.shape[0])
    # lookup global thresholds using caller cmdb_id and trace_name (global aggregates are per caller's trace series)
    try:
        global_P95 = float(agg_lookup.loc[(caller, tname), 'P95'])
        global_P05 = float(agg_lookup.loc[(caller, tname), 'P05'])
    except Exception:
        # fallback: compute from full-series subset if missing
        sfull = trace_candidates_agg[
            (trace_candidates_agg['cmdb_id']==caller) &
            (trace_candidates_agg['trace_name']==tname)
        ]
        if not sfull.empty:
            global_P95 = float(sfull['P95'].iloc[0])
            global_P05 = float(sfull['P05'].iloc[0])
        else:
            # if still missing, compute from full trace_candidates (rare)
            sfullvals = trace_candidates[(trace_candidates['cmdb_id']==caller)&(trace_candidates['trace_name']==tname)]['value'] if 'trace_candidates' in globals() else pd.Series([])
            global_P95 = float(sfullvals.quantile(0.95)) if len(sfullvals) else np.nan
            global_P05 = float(sfullvals.quantile(0.05)) if len(sfullvals) else np.nan

    low_is_bad = is_low_is_bad_trace(tname)
    if low_is_bad:
        anomaly_mask = g['value'] < global_P05
        threshold_used = global_P05
    else:
        # higher is worse (including error_rate)
        anomaly_mask = g['value'] > global_P95
        threshold_used = global_P95

    anomaly_count = int(anomaly_mask.sum())
    earliest_anom_ts = pd.NaT
    if anomaly_count > 0:
        earliest_anom_ts = g.loc[anomaly_mask, 'timestamp'].min()
    incident_max_value = float(g['value'].max())

    rows.append({
        'caller_cmdb_id': caller,
        'referenced_service': callee,
        'trace_name': tname,
        'incident_count': incident_count,
        'anomaly_count': anomaly_count,
        'earliest_anomaly_timestamp': pd.to_datetime(earliest_anom_ts).tz_convert('UTC') if pd.notnull(earliest_anom_ts) else pd.NaT,
        'threshold_used': threshold_used,
        'incident_max_value': round(incident_max_value, 6)
    })

paired_summary = pd.DataFrame(rows)

# Format earliest_anomaly_timestamp to ISO strings (or None)
paired_summary['earliest_anomaly_timestamp'] = paired_summary['earliest_anomaly_timestamp'].apply(
    lambda x: x.isoformat() if pd.notnull(x) else None
)

# Sort by anomaly_count desc then earliest_anomaly_timestamp asc, limit 50
paired_summary_top50 = paired_summary.sort_values(['anomaly_count','earliest_anomaly_timestamp'], ascending=[False, True]).head(50)

# 4) Aggregated caller->callee table: sum anomaly_count and earliest anomaly timestamp per pair
if not paired_summary.empty:
    # Convert earliest_anomaly_timestamp back to datetime for aggregation where not None
    tmp = paired_summary.copy()
    tmp['earliest_ts_dt'] = pd.to_datetime(tmp['earliest_anomaly_timestamp']).dt.tz_convert('UTC', errors='coerce')
    agg = tmp.groupby(['caller_cmdb_id','referenced_service']).agg(
        total_anomaly_count = ('anomaly_count','sum'),
        earliest_anomaly_timestamp = ('earliest_ts_dt','min')
    ).reset_index()
    # Format timestamp ISO or None
    agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_timestamp'].apply(lambda x: x.isoformat() if pd.notnull(x) else None)
    caller_callee_agg = agg.sort_values(['total_anomaly_count','earliest_anomaly_timestamp'], ascending=[False, True])
else:
    caller_callee_agg = pd.DataFrame(columns=['caller_cmdb_id','referenced_service','total_anomaly_count','earliest_anomaly_timestamp'])

caller_callee_agg_top20 = caller_callee_agg.head(20)

# Final compact outputs
paired_summary_top50, caller_callee_agg_top20
