    threshold = row['p95']
    
    anomalies = metric_df_filtered[(metric_df_filtered['cmdb_id'] == component) & (metric_df_filtered['kpi_name'] == kpi) & (metric_df_filtered['value'] > threshold)]
    
    if not anomalies.empty:
        anomaly_results.append({
