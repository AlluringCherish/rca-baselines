    lines = []
    for _, r in df.iterrows():
        lines.append(f"{r['cmdb_id']} | {r['kpi_name']} | count={int(r['count'])} | min={r['min']:.6g} p50={r['p50']:.6g} mean={r['mean']:.6g} p95={r['p95']:.6g} max={r['max']:.6g}")
    return lines

