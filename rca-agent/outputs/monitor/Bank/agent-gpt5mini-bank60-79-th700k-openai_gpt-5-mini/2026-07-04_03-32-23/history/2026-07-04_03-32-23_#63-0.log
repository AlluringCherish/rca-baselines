import pandas as pd
import numpy as np
import pytz

# Reuse timezone
tz = pytz.timezone('Asia/Shanghai')

# Components of interest
components_of_interest = ["MG01","MG02","Tomcat01","Tomcat03","Tomcat04"]

# Ensure required kernel variables exist; otherwise load/compute fallbacks
try:
    window_metric
except NameError:
    # load and filter as in previous steps (incident window assumed already known)
    metric_df = pd.read_csv('metric.csv')
    metric_df['ts'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    # use same incident window as earlier: March 10, 2021 14:00 — 14:30 (UTC+8)
    start_local = tz.localize(pd.Timestamp("2021-03-10 14:00:00"))
    end_local   = tz.localize(pd.Timestamp("2021-03-10 14:30:00"))
    window_metric = metric_df[(metric_df['ts'] >= start_local) & (metric_df['ts'] <= end_local) & (metric_df['cmdb_id'].isin(components_of_interest))].copy()

# Ensure metric_thresholds exists (global p95s)
if 'metric_thresholds' not in globals():
    full_metric_df = pd.read_csv('metric.csv')
    # compute global p95 per (component,kpi_name)
    grp = full_metric_df.groupby(['cmdb_id','kpi_name'])['value']
    metric_thresholds = grp.agg(count='count', p95_value=lambda x: np.percentile(x.dropna().astype(float),95) if x.dropna().size>0 else np.nan).reset_index()
    metric_thresholds = metric_thresholds.rename(columns={'cmdb_id':'component'})

# Prepare working window dataframe (filtered to requested components)
wm = window_metric.copy()
# ensure ts column exists and is tz-aware
if 'ts' not in wm.columns:
    wm['ts'] = pd.to_datetime(wm['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    # ensure tz
    wm['ts'] = pd.to_datetime(wm['ts']).dt.tz_convert(tz)

wm = wm[wm['cmdb_id'].isin(components_of_interest)].copy()
# numeric value
wm['value_num'] = pd.to_numeric(wm['value'], errors='coerce')

# Merge with global thresholds (metric_thresholds)
mt = metric_thresholds[['component','kpi_name','p95_value']].copy()
merged = pd.merge(wm, mt, left_on=['cmdb_id','kpi_name'], right_on=['component','kpi_name'], how='left')

# Mark anomalies: value >= p95_value (require p95_value not NaN)
merged['is_anom'] = False
mask_valid = merged['p95_value'].notna() & merged['value_num'].notna()
merged.loc[mask_valid, 'is_anom'] = merged.loc[mask_valid, 'value_num'] >= merged.loc[mask_valid, 'p95_value']

# Identify consecutive anomalous runs per (cmdb_id, kpi_name)
runs = []
group_cols = ['cmdb_id','kpi_name']
for (comp, kpi), g in merged.groupby(group_cols):
    g = g.sort_values('ts').reset_index(drop=True)
    if g.empty:
        continue
    # compute segment id whenever is_anom changes
    change = (g['is_anom'] != g['is_anom'].shift(fill_value=False))
    seg_id = change.cumsum()
    g['seg_id'] = seg_id
    # keep only segments where is_anom True
    anom_segs = g[g['is_anom']].groupby('seg_id')
    for seg, seg_df in anom_segs:
        run_length = int(seg_df.shape[0])
        if run_length < 2:
            continue  # keep only runs length >=2
        run_start = seg_df['ts'].iloc[0]
        run_end = seg_df['ts'].iloc[-1]
        max_val = seg_df['value_num'].max()
        p95 = seg_df['p95_value'].iloc[0]
        # compute ratio treating p95==0 as inf (per instructions)
        if pd.isna(p95):
            ratio = np.nan
        else:
            try:
                if p95 == 0:
                    ratio = np.inf
                else:
                    ratio = max_val / float(p95)
            except Exception:
                ratio = np.inf
        runs.append({
            'component': comp,
            'kpi_name': kpi,
            'run_start_timestamp': run_start,
            'run_end_timestamp': run_end,
            'run_length': run_length,
            'max_value_in_run': max_val,
            'p95_value': p95,
            'max_over_p95': ratio
        })

# Create DataFrame of runs
if runs:
    metric_faults = pd.DataFrame(runs)
else:
    metric_faults = pd.DataFrame(columns=[
        'component','kpi_name','run_start_timestamp','run_end_timestamp',
        'run_length','max_value_in_run','p95_value','max_over_p95'
    ])

# Filter to significant breaches: max_over_p95 > 1.5
# Handle infinite ratios: inf > 1.5 is True
metric_faults['max_over_p95_numeric'] = pd.to_numeric(metric_faults['max_over_p95'], errors='coerce')
significant = metric_faults[metric_faults['max_over_p95_numeric'] > 1.5].copy()

# Round numeric columns and format timestamps
for c in ['max_value_in_run','p95_value','max_over_p95_numeric']:
    if c in significant.columns:
        significant[c] = pd.to_numeric(significant[c], errors='coerce').round(6)

# Rename ratio column for display, preserve inf if present
significant = significant.rename(columns={'max_over_p95_numeric':'max_over_p95'})

# Sort by max_over_p95 desc then run_length desc
significant = significant.sort_values(by=['max_over_p95','run_length'], ascending=[False, False])

# Keep requested columns and up to top 20 rows for compact display
metric_faults = metric_faults.copy()  # store full results in kernel variable as requested
metric_faults_top = significant[['component','kpi_name','run_start_timestamp','run_end_timestamp','run_length','max_value_in_run','p95_value','max_over_p95']].head(20)

# Ensure timestamps are tz-aware strings for compactness
metric_faults_top['run_start_timestamp'] = pd.to_datetime(metric_faults_top['run_start_timestamp']).dt.tz_convert(tz)
metric_faults_top['run_end_timestamp'] = pd.to_datetime(metric_faults_top['run_end_timestamp']).dt.tz_convert(tz)

# Final compact result variable to display
metric_faults_top
