    metric_counts = metric_counts.rename(columns={'timestamp_dt':'timestamp'})
    # Example metric KPI (highest ratio) per (timestamp, counterpart)
    def mk_example_metric(df):
        row = df.sort_values('ratio', ascending=False).iloc[0]
        ratio = row['ratio']
