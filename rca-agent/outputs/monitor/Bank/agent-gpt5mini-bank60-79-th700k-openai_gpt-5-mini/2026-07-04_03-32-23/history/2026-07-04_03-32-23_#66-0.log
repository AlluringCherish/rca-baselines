# p95 == 0 and value > 0 => inf
zero_p95_mask = (detailed_metrics_2202['p95'] == 0) & (detailed_metrics_2202['value'] > 0)
detailed_metrics_2202.loc[zero_p95_mask, 'ratio'] = np.inf

