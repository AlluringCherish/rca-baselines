import pandas as pd
import numpy as np
import pytz

# Reuse existing variables if present, otherwise raise informative error
try:
    anoms_all
except NameError:
    raise NameError("anoms_all not found in kernel. Please run the previous anomaly computation steps first.")

# Ensure timezone and window vars exist (recreate if needed)
try:
    tz_sh
    start_local
    end_local
except NameError:
    tz_sh = pytz.timezone('Asia/Shanghai')
    start_local = pd.Timestamp('2021-03-06 02:00:00', tz=tz_sh)
    end_local = pd.Timestamp('2021-03-06 02:30:00', tz=tz_sh)

# Work on groups that have any anomalies
anoms_candidates = anoms_all[(anoms_all['high_count'] > 0) | (anoms_all['low_count'] > 0)].copy()

# Ensure earliest timestamps are timezone-aware pandas Timestamps (they should be already)
# Filter to those whose earliest_high_timestamp OR earliest_low_timestamp lies inside the incident window
def in_window(ts):
    if pd.isna(ts):
        return False
    return (ts >= start_local) and (ts <= end_local)

anoms_candidates['earliest_high_in_window'] = anoms_candidates['earliest_high_timestamp'].apply(lambda x: in_window(x))
anoms_candidates['earliest_low_in_window']  = anoms_candidates['earliest_low_timestamp'].apply(lambda x: in_window(x))

anoms_filtered = anoms_candidates[(anoms_candidates['earliest_high_in_window']) | (anoms_candidates['earliest_low_in_window'])].copy()

# Compute severity = max(max_high_ratio (or 0), max_low_ratio (or 0))
anoms_filtered['max_high_ratio_f'] = anoms_filtered['max_high_ratio'].fillna(0).replace([np.inf, -np.inf], np.inf)
anoms_filtered['max_low_ratio_f']  = anoms_filtered['max_low_ratio'].fillna(0).replace([np.inf, -np.inf], np.inf)
anoms_filtered['severity'] = anoms_filtered[['max_high_ratio_f','max_low_ratio_f']].max(axis=1)

# Sort by severity desc and take top 20
severity_top20 = anoms_filtered.sort_values(by='severity', ascending=False).head(20).copy()

# Select and order requested columns
severity_top20 = severity_top20[[
    'file_type','cmdb_id','kpi_name','p95','p05','count_in_window',
    'high_count','low_count','earliest_high_timestamp','earliest_low_timestamp',
    'max_high_ratio','max_low_ratio','severity'
]].reset_index(drop=True)

# Compact count summary: number_of_severe_groups per cmdb_id among the top-20 severity list
severe_counts = severity_top20.groupby('cmdb_id', as_index=False).size().reset_index()
severe_counts.columns = ['cmdb_id', 'number_of_severe_groups']
severe_counts = severe_counts[severe_counts['number_of_severe_groups']>0].sort_values(by='number_of_severe_groups', ascending=False).reset_index(drop=True)

# Keep full results stored in kernel variables for later steps
severity_all_full = anoms_filtered.copy()   # full filtered set with severity
severity_top20_full = severity_top20.copy() # displayed top20 (also stored)
severe_counts_full = severe_counts.copy()

# Final compact outputs (display)
severity_top20_full, severe_counts_full
