                    'anomaly_points_in_window': int(t0['anomalies_count_in_window']),
                    'severity_or_note': note
                })

    # ---------- LOG ----------
    log_rows_comp = log[log['cmdb_id'] == comp].copy()
    if not log_rows_comp.empty:
