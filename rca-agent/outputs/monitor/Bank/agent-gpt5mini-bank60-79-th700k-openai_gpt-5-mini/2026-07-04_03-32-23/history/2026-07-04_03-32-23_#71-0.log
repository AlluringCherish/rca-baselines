import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')
component = 'Tomcat01'
components = ['IG01','apache01','Mysql01','Tomcat01','Tomcat02']
start = pd.Timestamp('2021-03-06 03:30', tz=tz)
end = pd.Timestamp('2021-03-06 04:00', tz=tz)
err_start = pd.Timestamp('2021-03-06 03:25', tz=tz)
err_end = pd.Timestamp('2021-03-06 04:05', tz=tz)

# Ensure dt cols are present and in Asia/Shanghai tz (reuse existing dfs in kernel)
for df in (metric, trace, log, error_logs):
    if 'dt' not in df.columns:
        df['dt'] = pd.to_datetime(df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    else:
        df['dt'] = pd.to_datetime(df['dt']).dt.tz_convert(tz)

# -------------------------
# 1) Tomcat01 metric anomalies using global P90/P10 (full-series thresholds)
# -------------------------
metric_tomcat = metric[metric['cmdb_id'] == component].copy()
if metric_tomcat.empty:
    metric_table = pd.DataFrame(columns=[
        'kpi_name','group_count','global_p90','global_p10',
        'anomalies_count_in_window','earliest_anomaly_timestamp','latest_anomaly_timestamp',
        'min_value_in_window','max_value_in_window'
    ])
else:
    # Compute global P90/P10 per KPI using full series (rule #9)
    metric_thresh_t = (
        metric_tomcat
        .groupby('kpi_name', as_index=False)
        .agg(
            group_count=('value','count'),
            global_p90=('value', lambda x: float(x.quantile(0.90))),
            global_p10=('value', lambda x: float(x.quantile(0.10)))
        )
    )

    # Filter to incident window and mark anomalies by P90/P10 rule
    metric_win = metric_tomcat[(metric_tomcat['dt'] >= start) & (metric_tomcat['dt'] <= end)].copy()
    if metric_win.empty:
        metric_table = pd.DataFrame(columns=[
            'kpi_name','group_count','global_p90','global_p10',
            'anomalies_count_in_window','earliest_anomaly_timestamp','latest_anomaly_timestamp',
            'min_value_in_window','max_value_in_window'
        ])
    else:
        metric_win = metric_win.merge(metric_thresh_t, on='kpi_name', how='left')
        metric_win['is_anomaly'] = (metric_win['value'] >= metric_win['global_p90']) | (metric_win['value'] <= metric_win['global_p10'])
        metric_anoms = metric_win[metric_win['is_anomaly']].copy()
        if metric_anoms.empty:
            metric_table = pd.DataFrame(columns=[
                'kpi_name','group_count','global_p90','global_p10',
                'anomalies_count_in_window','earliest_anomaly_timestamp','latest_anomaly_timestamp',
                'min_value_in_window','max_value_in_window'
            ])
        else:
            metric_table = (
                metric_anoms
                .groupby(['kpi_name','group_count','global_p90','global_p10'], as_index=False)
                .agg(
                    anomalies_count_in_window=('value','count'),
                    earliest_anomaly_timestamp=('dt','min'),
                    latest_anomaly_timestamp=('dt','max'),
                    min_value_in_window=('value','min'),
                    max_value_in_window=('value','max')
                )
                .reset_index(drop=True)
                .sort_values('earliest_anomaly_timestamp')
                .loc[:, ['kpi_name','group_count','global_p90','global_p10',
                         'anomalies_count_in_window','earliest_anomaly_timestamp','latest_anomaly_timestamp',
                         'min_value_in_window','max_value_in_window']]
                .head(20)
            )

# -------------------------
# 2) Tomcat01 downstream trace anomalies (global P90/P10 per trace group)
# -------------------------
# We interpret downstream as rows where role == 'to' and peer == Tomcat01 OR role == 'from' where cmdb_id is caller and downstream is cmdb_id? 
# For consistent downstream detection: treat 'to_<Peer>' -> downstream is peer; 'from_<Peer>' -> downstream is cmdb_id (the receiver).
def extract_role_peer(name):
    if pd.isna(name): 
        return (None, None)
    s = str(name)
    # match to_X or from_X, allow optional punctuation
    import re
    m = re.search(r'\b(to|from)(?:<_)?_?([A-Za-z0-9]+)\b', s)
    if m:
        return m.group(1), m.group(2)
    return (None, None)

trace['__role__'] = trace['trace_name'].apply(lambda x: extract_role_peer(x)[0])
trace['__peer__'] = trace['trace_name'].apply(lambda x: extract_role_peer(x)[1])

# Build groups where either the trace references Tomcat01 as peer (to_Tomcat01) OR the cmdb_id is some caller and downstream is Tomcat01 (role/from)
# Approach: compute global thresholds for all trace groups that may reference Tomcat01 as peer or have Tomcat01 as cmdb_id
# Collect trace groups where peer==Tomcat01 or cmdb_id==some caller with role 'from_' pointing to ??? We'll simply consider rows where downstream computed equals Tomcat01.
def downstream_comp(row):
    role = row['__role__']
    peer = row['__peer__']
    if role == 'to' and peer == component:
        return component
    if role == 'from' and row['cmdb_id'] != component:
        # 'from_X' typically indicates trace originated from X to current cmdb_id (current cmdb_id is downstream)
        if row['cmdb_id'] == component:
            return component
        # else if trace is labeled like 'from_IG01' on Tomcat01 entries, then cmdb_id is Tomcat01; handled above
    # Also if cmdb_id == component and role == 'from' then downstream is component
    if role == 'from' and row['cmdb_id'] == component:
        return component
    return None

# Create a helper column downstream_target for all rows
trace['downstream_target'] = trace.apply(downstream_comp, axis=1)

# Now select groups where either downstream_target == Tomcat01 OR trace_name contains 'to_Tomcat01' etc.
trace_groups_of_interest = trace[(trace['downstream_target'] == component) | 
                                (trace['__peer__'] == component) |
                                ((trace['cmdb_id'] != component) & (trace['__peer__'] == component))].copy()

# If empty handle
if trace_groups_of_interest.empty:
    trace_down_table = pd.DataFrame(columns=[
        'trace_name','peer_component','group_count','global_p90','global_p10',
        'anomalies_count_in_window','earliest_anomaly_timestamp','latest_anomaly_timestamp',
        'min_value_in_window','max_value_in_window'
    ])
else:
    # Compute global P90/P10 for these groups across full trace series (no time filter)
    groups = trace_groups_of_interest[['cmdb_id','trace_name']].drop_duplicates()
    trace_full_groups = trace.merge(groups, on=['cmdb_id','trace_name'], how='inner')
    trace_thresh = (
        trace_full_groups
        .groupby(['cmdb_id','trace_name'], as_index=False)
        .agg(
            group_count=('value','count'),
            global_p90=('value', lambda x: float(x.quantile(0.90)) if x.count()>0 else np.nan),
            global_p10=('value', lambda x: float(x.quantile(0.10)) if x.count()>0 else np.nan)
        )
    )
    # Filter original trace to incident window for these groups and mark anomalies
    trace_win = trace.merge(groups, on=['cmdb_id','trace_name'], how='inner')
    trace_win = trace_win[(trace_win['dt'] >= start) & (trace_win['dt'] <= end)].copy()
    trace_win = trace_win.merge(trace_thresh, on=['cmdb_id','trace_name'], how='left')
    trace_win['is_anomaly'] = (trace_win['value'] >= trace_win['global_p90']) | (trace_win['value'] <= trace_win['global_p10'])
    trace_anoms = trace_win[trace_win['is_anomaly']].copy()
    if trace_anoms.empty:
        trace_down_table = pd.DataFrame(columns=[
            'trace_name','peer_component','group_count','global_p90','global_p10',
            'anomalies_count_in_window','earliest_anomaly_timestamp','latest_anomaly_timestamp',
            'min_value_in_window','max_value_in_window'
        ])
    else:
        # Determine peer component (caller) for each anomalous row:
        # If trace_name contains 'to_<peer>' then peer is the source cmdb_id; if 'from_<peer>' then peer is the peer token.
        def peer_of_row(r):
            role = r['__role']
            peer = r['__peer']
            if role == 'to' and peer == component:
                # called as: <caller>.trace.to_Tomcat01 -> caller is r['cmdb_id']
                return r['cmdb_id']
            if role == 'from' and r['cmdb_id'] == component:
                # trace.from_X on Tomcat01 means caller is X (peer token)
                return peer
            # fallback: if peer token exists and equals component, caller is cmdb_id
            if peer == component:
                return r['cmdb_id']
            return None

        trace_anoms['peer_component'] = trace_anoms.apply(peer_of_row, axis=1)
        # Aggregate per trace_name + peer_component
        trace_down_table = (
            trace_anoms
            .groupby(['trace_name','peer_component','group_count','global_p90','global_p10'], as_index=False)
            .agg(
                anomalies_count_in_window=('value','count'),
                earliest_anomaly_timestamp=('dt','min'),
                latest_anomaly_timestamp=('dt','max'),
                min_value_in_window=('value','min'),
                max_value_in_window=('value','max')
            )
            .reset_index(drop=True)
            .sort_values('earliest_anomaly_timestamp')
            .loc[:, ['trace_name','peer_component','group_count','global_p90','global_p10',
                     'anomalies_count_in_window','earliest_anomaly_timestamp','latest_anomaly_timestamp',
                     'min_value_in_window','max_value_in_window']]
            .head(20)
        )

# -------------------------
# 3) Tomcat01 logs & error_logs
# -------------------------
# (a) log.csv summary for Tomcat01 in window
log_tomcat_win = log[(log['cmdb_id'] == component) & (log['dt'] >= start) & (log['dt'] <= end)].copy()
if log_tomcat_win.empty:
    log_table = pd.DataFrame(columns=['log_name','count','earliest_timestamp','latest_timestamp','median_value','p90_value'])
else:
    log_table = (
        log_tomcat_win
        .groupby('log_name', as_index=False)
        .agg(
            count=('value','count'),
            earliest_timestamp=('dt','min'),
            latest_timestamp=('dt','max'),
            median_value=('value','median'),
            p90_value=('value', lambda x: float(x.quantile(0.90)))
        )
        .sort_values('count', ascending=False)
        .head(20)
    )

# (b) error_logs earliest 10 rows for Tomcat01 in extended interval
err_tomcat_range = error_logs[(error_logs['cmdb_id'] == component) & (error_logs['dt'] >= err_start) & (error_logs['dt'] <= err_end)].copy()
if err_tomcat_range.empty:
    err_earliest10 = pd.DataFrame(columns=['dt','cmdb_id','message'])
else:
    err_earliest10 = err_tomcat_range.sort_values('dt', ascending=True).head(10)[['dt','cmdb_id','message']]

# -------------------------
# Determine earliest Tomcat01 anomalous timestamp and whether consecutive fault run exists
# -------------------------
# Collect earliest timestamps from metric_table and trace_down_table (and logs if they show anomalies)
earliest_times = []
# from metric_table
if not metric_table.empty:
    earliest_times.append(metric_table['earliest_anomaly_timestamp'].min())
# from trace_down_table
if not trace_down_table.empty:
    earliest_times.append(trace_down_table['earliest_anomaly_timestamp'].min())
# from logs use earliest_timestamp if any anomaly-like signals (we treat presence as anomaly)
if not log_table.empty:
    earliest_times.append(log_table['earliest_timestamp'].min())
# from error logs
if not err_earliest10.empty:
    earliest_times.append(err_earliest10['dt'].min())

if earliest_times:
    earliest_overall = min([t for t in earliest_times if pd.notna(t)])
else:
    earliest_overall = pd.NaT

# Check consecutive fault run existence in metric anomalies or trace anomalies:
# We'll inspect metric anomalous rows for Tomcat01 in-window and check if any run of consecutive minutes length >=2 exists.
consecutive_run_found = False

# metric_anomalous rows raw (not aggregated)
metric_raw_anoms = None
if metric_tomcat is not None and not metric_tomcat.empty:
    # reuse metric_win and metric_thresh_t if present
    try:
        metric_win  # exists above
    except NameError:
        metric_win = metric_tomcat.merge(metric_thresh_t, on='kpi_name', how='left')
        metric_win = metric_win[(metric_win['dt'] >= start) & (metric_win['dt'] <= end)].copy()
        metric_win['is_anomaly'] = (metric_win['value'] >= metric_win['global_p90']) | (metric_win['value'] <= metric_win['global_p10'])
    metric_raw_anoms = metric_win[metric_win.get('is_anomaly', False)].copy()
    if not metric_raw_anoms.empty:
        # check per kpi for consecutive minute runs
        metric_raw_anoms = metric_raw_anoms.sort_values('dt')
        metric_raw_anoms['epoch'] = metric_raw_anoms['dt'].astype('int64') // 10**9
        metric_raw_anoms['diff'] = metric_raw_anoms.groupby('kpi_name')['epoch'].diff().fillna(0).astype(int)
        metric_raw_anoms['run_id'] = (metric_raw_anoms['diff'] != 60).cumsum()
        runs = metric_raw_anoms.groupby(['kpi_name','run_id']).size().reset_index(name='run_len')
        if any(runs['run_len'] >= 2):
            consecutive_run_found = True

# also check trace_anoms raw rows where Tomcat01 is downstream for consecutive minutes
if not consecutive_run_found and not trace_anoms.empty:
    ta = trace_anoms.copy()
    # filter rows where peer indicates Tomcat01 downstream as derived earlier
    # downstream detection reused: downstream target computed earlier in trace_win step; recompute for safety
    ta['epoch'] = ta['dt'].astype('int64') // 10**9
    ta['diff'] = ta.groupby(['trace_name'])['epoch'].diff().fillna(0).astype(int)
    ta['run_id'] = (ta['diff'] != 60).cumsum()
    runs_t = ta.groupby(['trace_name','run_id']).size().reset_index(name='run_len')
    if any(runs_t['run_len'] >= 2):
        consecutive_run_found = True

consecutive_flag = 'yes' if consecutive_run_found else 'no'

# Build one-line computed output string
if pd.notna(earliest_overall) and earliest_overall is not pd.NaT:
    earliest_str = pd.to_datetime(earliest_overall).strftime('%Y-%m-%d %H:%M %Z')
    summary_str = f"Tomcat01 earliest anomaly at {earliest_str}; consecutive fault run present: {consecutive_flag}"
else:
    summary_str = f"No Tomcat01 anomalies found in window; consecutive fault run present: {consecutive_flag}"

# Final compact display variables
metric_table, trace_down_table, log_table, err_earliest10, summary_str
