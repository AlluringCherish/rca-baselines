    cmdbs = sorted(sub['cmdb_id'].dropna().unique())[:sample_limit]
    return {
        'file_name': file_name,
        'count_rows_in_range': count,
        'min_timestamp_in_range': min_ts,
        'max_timestamp_in_range': max_ts,
        'sample_cmdb_ids_in_range': cmdbs
    }

