# Helper severity computation (consistent with earlier)
def severity_val(v, p95, p5):
    if pd.isna(v):
        return None
    if (not pd.isna(p95)) and (v >= p95):
        if p95 == 0:
            return float('inf')
        return float(v / p95)
    if (not pd.isna(p5)) and (v <= p5):
        if v == 0:
            return float('inf') if p5 == 0 else float(p5 / 1e-12)
        return float(p5 / v)
    return None

