trace_cmdb_counts = trace_df['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count')
trace_name_counts = trace_df['trace_name'].value_counts().rename_axis('trace_name').reset_index(name='count').head(50)
