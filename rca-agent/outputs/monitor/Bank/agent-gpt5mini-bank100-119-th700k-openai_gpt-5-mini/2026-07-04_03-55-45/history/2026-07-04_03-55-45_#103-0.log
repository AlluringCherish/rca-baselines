    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

# Candidate components
candidates = [
    "apache01","apache02","Tomcat01","Tomcat02","Tomcat04","Tomcat03",
    "MG01","MG02","IG01","IG02","Mysql01","Mysql02","Redis01","Redis02"
]

# Ensure numeric values
metric_df["value"] = pd.to_numeric(metric_df["value"], errors="coerce")

# Filter rows for candidate components (for global thresholds calculation)
mask_candidates = metric_df["cmdb_id"].isin(candidates)
metric_candidates_df = metric_df[mask_candidates].copy()

# Compute global thresholds per (cmdb_id, kpi_name): count_full_series, p95_value, p5_value
count_df = (
    metric_candidates_df
    .groupby(["cmdb_id","kpi_name"], as_index=False)
    .size()
    .reset_index()
    .rename(columns={0: "count_full_series"})
)

p95_df = (
    metric_candidates_df
    .groupby(["cmdb_id","kpi_name"])["value"]
    .apply(lambda x: float(np.nanpercentile(x.dropna(), 95)) if x.dropna().size>0 else np.nan)
    .reset_index(name="p95_value")
)

p5_df = (
    metric_candidates_df
    .groupby(["cmdb_id","kpi_name"])["value"]
    .apply(lambda x: float(np.nanpercentile(x.dropna(), 5)) if x.dropna().size>0 else np.nan)
    .reset_index(name="p5_value")
)

threshold_table = count_df.merge(p95_df, on=["cmdb_id","kpi_name"], how="left").merge(p5_df, on=["cmdb_id","kpi_name"], how="left")
# Keep expected column order
threshold_table = threshold_table[["cmdb_id","kpi_name","count_full_series","p95_value","p5_value"]]

# Cache threshold_table in kernel variable (already set)

# Incident window: March 25, 2021 00:00 to 00:30 (UTC+8)
tz = pytz.timezone('Asia/Shanghai')
start_dt = tz.localize(datetime(2021,3,25,0,0,0))
end_dt   = tz.localize(datetime(2021,3,25,0,30,0))
start_ts = int(start_dt.timestamp())
end_ts   = int(end_dt.timestamp())

incident_metric_df = metric_df[
    (metric_df["cmdb_id"].isin(candidates)) &
    (metric_df["timestamp"] >= start_ts) &
    (metric_df["timestamp"] <= end_ts)
].copy()

# Cache incident_metric_df in kernel variable

# If no data in window, prepare empty result
if incident_metric_df.shape[0] == 0:
    result_display = pd.DataFrame(columns=[
        "cmdb_id","kpi_name","count_full_series","p95_value","p5_value",
        "count_exceed_p95","earliest_exceed_ts","max_value_in_window",
        "count_below_p5","earliest_below_ts","min_value_in_window"
    ])
    num_groups_examined = 0
else:
    # Merge thresholds into incident rows
    merged = incident_metric_df.merge(threshold_table, on=["cmdb_id","kpi_name"], how="left")
    # Aggregate per group using global thresholds
    def agg_group(g):
        p95 = g["p95_value"].iloc[0]
        p5  = g["p5_value"].iloc[0]
        # Exceeds p95
        if pd.isna(p95):
            count_exceed = 0
            earliest_exceed = np.nan
        else:
            exceed_mask = g["value"] >= p95
            count_exceed = int(exceed_mask.sum())
            earliest_exceed = int(g.loc[exceed_mask, "timestamp"].min()) if exceed_mask.any() else np.nan
        # Below p5
        if pd.isna(p5):
            count_below = 0
            earliest_below = np.nan
        else:
            below_mask = g["value"] <= p5
            count_below = int(below_mask.sum())
            earliest_below = int(g.loc[below_mask, "timestamp"].min()) if below_mask.any() else np.nan
        max_val = float(g["value"].max()) if g["value"].notna().any() else np.nan
        min_val = float(g["value"].min()) if g["value"].notna().any() else np.nan
        return pd.Series({
            "count_exceed_p95": count_exceed,
            "earliest_exceed_ts": earliest_exceed,
            "max_value_in_window": max_val,
            "count_below_p5": count_below,
            "earliest_below_ts": earliest_below,
            "min_value_in_window": min_val
        })
    agg_window = merged.groupby(["cmdb_id","kpi_name"]).apply(agg_group).reset_index()

