import pandas as pd
import numpy as np
from datetime import datetime
import pytz

# reuse cached metric_df from previous steps
# ensure metric_df exists
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

# Candidate components list (root-cause components)
candidates = [
    "apache01","apache02","Tomcat01","Tomcat02","Tomcat04","Tomcat03",
    "MG01","MG02","IG01","IG02","Mysql01","Mysql02","Redis01","Redis02"
]

# Ensure value is numeric
metric_df["value"] = pd.to_numeric(metric_df["value"], errors="coerce")

# 1) Compute global thresholds (count, p95, p5) for every (cmdb_id,kpi_name) where cmdb_id in candidates
mask_candidates = metric_df["cmdb_id"].isin(candidates)
metric_candidates_df = metric_df[mask_candidates]

# Group by full series (global thresholds must be computed on entire series prior to any time filtering)
grouped = metric_candidates_df.groupby(["cmdb_id", "kpi_name"], as_index=False)["value"]

def safe_pctl(x, q):
    arr = x.dropna().values
    if arr.size == 0:
        return np.nan
    return float(np.nanpercentile(arr, q))

threshold_table = grouped.agg(
    count_full_series = ("value", "count")
).merge(
    metric_candidates_df.groupby(["cmdb_id","kpi_name"])["value"].apply(lambda x: float(np.nanpercentile(x.dropna(),95)) if x.dropna().size>0 else np.nan).reset_index(name="p95_value"),
    on=["cmdb_id","kpi_name"]
).merge(
    metric_candidates_df.groupby(["cmdb_id","kpi_name"])["value"].apply(lambda x: float(np.nanpercentile(x.dropna(),5)) if x.dropna().size>0 else np.nan).reset_index(name="p5_value"),
    on=["cmdb_id","kpi_name"]
)

# Cache threshold_table in kernel variable (as required)
threshold_table = threshold_table[["cmdb_id","kpi_name","count_full_series","p95_value","p5_value"]]

# 2) Filter metric.csv to incident window March 25, 2021 00:00 to 00:30 (UTC+8) and keep only candidate components
tz = pytz.timezone('Asia/Shanghai')
start_dt = tz.localize(datetime(2021,3,25,0,0,0))
end_dt   = tz.localize(datetime(2021,3,25,0,30,0))
start_ts = int(start_dt.timestamp())
end_ts   = int(end_dt.timestamp())

incident_metric_df = metric_df[
    (metric_df["cmdb_id"].isin(candidates)) &
    (metric_df["timestamp"] >= start_ts) &
    (metric_df["timestamp"] <= end_ts)
].copy()

# Cache incident_metric_df in kernel variable (as required)

# 3) For each (cmdb_id,kpi_name) present in the incident window compute anomaly aggregates using global thresholds
if incident_metric_df.shape[0] == 0:
    # no data in window: produce empty result table with proper columns
    result_df = pd.DataFrame(columns=[
        "cmdb_id","kpi_name","count_full_series","p95_value","p5_value",
        "count_exceed_p95","earliest_exceed_ts","max_value_in_window",
        "count_below_p5","earliest_below_ts","min_value_in_window"
    ])
else:
    # Merge per-row threshold values into incident window rows
    merged = incident_metric_df.merge(threshold_table, on=["cmdb_id","kpi_name"], how="left")
    # Compute per-group aggregates
    def agg_group(df):
        p95 = df["p95_value"].iloc[0]
        p5  = df["p5_value"].iloc[0]
        # count_exceed_p95: value >= p95 (handle NaN p95 -> treat as none)
        if pd.isna(p95):
            count_exceed = 0
            earliest_exceed = np.nan
        else:
            exceed_mask = df["value"] >= p95
            count_exceed = int(exceed_mask.sum())
            earliest_exceed = int(df.loc[exceed_mask, "timestamp"].min()) if exceed_mask.any() else np.nan
        # count_below_p5: value <= p5
        if pd.isna(p5):
            count_below = 0
            earliest_below = np.nan
        else:
            below_mask = df["value"] <= p5
            count_below = int(below_mask.sum())
            earliest_below = int(df.loc[below_mask, "timestamp"].min()) if below_mask.any() else np.nan
        return pd.Series({
            "count_exceed_p95": count_exceed,
            "earliest_exceed_ts": earliest_exceed,
            "max_value_in_window": float(df["value"].max()) if df["value"].notna().any() else np.nan,
            "count_below_p5": count_below,
            "earliest_below_ts": earliest_below,
            "min_value_in_window": float(df["value"].min()) if df["value"].notna().any() else np.nan
        })
    agg_window = merged.groupby(["cmdb_id","kpi_name"], as_index=False).apply(agg_group).reset_index(drop=True)
    # Prepare final table by joining with threshold_table to include count_full_series, p95, p5
    # Note: only keep groups that appear in the window (per instruction)
    window_groups = merged.groupby(["cmdb_id","kpi_name"], as_index=False).size().reset_index()[["cmdb_id","kpi_name"]]
    result_df = window_groups.merge(threshold_table, on=["cmdb_id","kpi_name"], how="left").merge(agg_window, on=["cmdb_id","kpi_name"], how="left")
    # Reorder columns as required
    result_df = result_df[[
        "cmdb_id","kpi_name","count_full_series","p95_value","p5_value",
        "count_exceed_p95","earliest_exceed_ts","max_value_in_window",
        "count_below_p5","earliest_below_ts","min_value_in_window"
    ]]

# 4) Sort by (count_exceed_p95 + count_below_p5) descending and keep top 20
if not result_df.empty:
    result_df["severity_score"] = result_df["count_exceed_p95"].fillna(0).astype(int) + result_df["count_below_p5"].fillna(0).astype(int)
    result_df = result_df.sort_values("severity_score", ascending=False).reset_index(drop=True)
    result_display = result_df.head(20).drop(columns=["severity_score"])
else:
    result_display = result_df.copy()

# 5) total number of distinct (cmdb_id,kpi_name) groups examined (i.e., those in the incident window)
num_groups_examined = int(result_df.shape[0])

# Final compact outputs: threshold_table (cached), incident_metric_df (cached), result_display (top20), num_groups_examined
threshold_table.shape, incident_metric_df.shape, result_display.head(20), num_groups_examined
