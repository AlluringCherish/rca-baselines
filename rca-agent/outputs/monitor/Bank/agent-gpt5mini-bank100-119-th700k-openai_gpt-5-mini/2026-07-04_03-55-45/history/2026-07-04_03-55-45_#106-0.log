    end_ts = int(tz.localize(datetime(2021, 3, 25, 17, 30, 0)).timestamp())

# 1) log.csv: compute global P95 and total_count per (cmdb_id, log_name)
log_global = (
    df_log
    .groupby(['cmdb_id', 'log_name'])['value']
    .agg(total_count='size', global_p95=lambda s: float(s.quantile(0.95)))
    .reset_index()
)

# 2) filter log rows to incident window (inclusive)
df_log_window = df_log[(df_log['timestamp'] >= start_ts) & (df_log['timestamp'] <= end_ts)].copy()

# 3) merge global thresholds into window rows
df_log_window = df_log_window.merge(log_global, on=['cmdb_id', 'log_name'], how='left')

# 4) window aggregates
log_window_agg = (
    df_log_window
    .groupby(['cmdb_id', 'log_name'])
    .agg(
        window_count=('value', 'size'),
        max_value_in_window=('value', 'max')
