log_anoms = df_log_window[df_log_window['value'] > df_log_window['global_p95']].copy()
log_anom_agg = (
    log_anoms
    .groupby(['cmdb_id', 'log_name'])
    .agg(
        anomaly_count=('value', 'size'),
        earliest_anomaly_timestamp=('timestamp', 'min')
    )
    .reset_index()
)

# 6) merge results
log_merged = (
    log_window_agg
    .merge(log_global, on=['cmdb_id', 'log_name'], how='left')
    .merge(log_anom_agg, on=['cmdb_id', 'log_name'], how='left')
)

# 7) tidy up types and fill NAs
