import pandas as pd
import pytz
from datetime import datetime

# reuse df_metric if present, else load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

# Ensure types
df_metric['timestamp'] = pd.to_numeric(df_metric['timestamp'], errors='coerce').astype('Int64')
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

# Timezone (UTC+8) per rule
tz = pytz.timezone('Asia/Shanghai')

# Filter to apache components first (we compute global P95 using all rows for these pairs)
apache_df = df_metric[df_metric['cmdb_id'].isin(['apache01', 'apache02'])].copy()

# 1) Global stats (total_count and global P95) computed on full series for each (cmdb_id, kpi_name)
apache_global = (
    apache_df
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(total_count='size', global_p95=lambda s: float(s.quantile(0.95)))
    .reset_index()
)

# 2) Define apache error-log interval (given epochs) using tz for clarity (no conversion of series)
start_dt = tz.localize(datetime(2021, 3, 25, 0, 0))  # placeholder to satisfy tz variable usage
# Use the specified epoch interval directly:
start_ts = 1616664122
end_ts = 1616664367

# 3) Filter apache metric rows to the interval (inclusive)
apache_window = apache_df[(apache_df['timestamp'] >= start_ts) & (apache_df['timestamp'] <= end_ts)].copy()

# 4) Merge global thresholds into window rows
apache_window = apache_window.merge(apache_global, on=['cmdb_id', 'kpi_name'], how='left')

# 5) Window-level aggregates
window_agg = (
    apache_window
    .groupby(['cmdb_id', 'kpi_name'])
    .agg(
        window_count=('value', 'size'),
        max_value_in_window=('value', 'max')
    )
    .reset_index()
)

# 6) Anomaly detection within window (value > global_p95)
anoms = apache_window[apache_window['value'] > apache_window['global_p95']].copy()
anomaly_agg = (
    anoms
    .groupby(['cmdb_id', 'kpi_name'])
    .agg(
        anomaly_count=('value', 'size'),
        earliest_anomaly_timestamp=('timestamp', 'min')
    )
    .reset_index()
)

# 7) Merge results: window_agg + apache_global + anomaly_agg
apache_merged = (
    window_agg
    .merge(apache_global, on=['cmdb_id', 'kpi_name'], how='left')
    .merge(anomaly_agg, on=['cmdb_id', 'kpi_name'], how='left')
)

# 8) Fill NA for anomaly_count and set types
apache_merged['anomaly_count'] = apache_merged['anomaly_count'].fillna(0).astype(int)
apache_merged['earliest_anomaly_timestamp'] = apache_merged['earliest_anomaly_timestamp'].astype('Int64')

# 9) Select required columns, sort and limit to top 20
apache_result = (
    apache_merged[
        ['cmdb_id', 'kpi_name', 'total_count', 'window_count', 'anomaly_count', 'earliest_anomaly_timestamp', 'max_value_in_window', 'global_p95']
    ]
    .sort_values(['anomaly_count', 'max_value_in_window'], ascending=[False, False])
    .head(20)
    .reset_index(drop=True)
)

