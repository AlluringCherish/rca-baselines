import pandas as pd
import pytz
from datetime import datetime

# reuse df_trace if present, else load
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')

# Ensure timestamp and value columns are numeric
df_trace['timestamp'] = pd.to_numeric(df_trace['timestamp'], errors='coerce').astype('Int64')
df_trace['value'] = pd.to_numeric(df_trace['value'], errors='coerce')

# 1) Calculate global P95 and total_count per (cmdb_id, trace_name) using the entire series
global_stats = (
    df_trace
    .groupby(['cmdb_id', 'trace_name'])['value']
    .agg(total_count='size', global_p95=lambda s: float(s.quantile(0.95)))
    .reset_index()
)

# 2) Define the incident window in UTC+8 (Asia/Shanghai)
tz = pytz.timezone('Asia/Shanghai')
start_dt = tz.localize(datetime(2021, 3, 25, 17, 0, 0))
end_dt = tz.localize(datetime(2021, 3, 25, 17, 30, 0))
start_ts = int(start_dt.timestamp())
end_ts = int(end_dt.timestamp())

# 3) Filter trace rows to the window (inclusive)
df_window = df_trace[(df_trace['timestamp'] >= start_ts) & (df_trace['timestamp'] <= end_ts)].copy()

# 4) Attach global_p95 to window rows to identify anomalies (value > global_p95)
df_window = df_window.merge(global_stats, on=['cmdb_id', 'trace_name'], how='left')

# 5) Compute window-level aggregates for pairs present in the window
window_agg = (
    df_window
    .groupby(['cmdb_id', 'trace_name'])
    .agg(
        window_count=('value', 'size'),
        max_value_in_window=('value', 'max')
    )
    .reset_index()
)

# 6) Compute anomaly counts and earliest anomaly timestamp per pair in the window
anoms = df_window[df_window['value'] > df_window['global_p95']].copy()
anomaly_agg = (
    anoms
    .groupby(['cmdb_id', 'trace_name'])
    .agg(
        anomaly_count=('value', 'size'),
        earliest_anomaly_timestamp=('timestamp', 'min')
    )
    .reset_index()
)

# 7) Merge: window_agg + global_stats + anomaly_agg
merged = (
    window_agg
    .merge(global_stats, on=['cmdb_id', 'trace_name'], how='left')
    .merge(anomaly_agg, on=['cmdb_id', 'trace_name'], how='left')
)

# 8) Fill NaNs for pairs with no anomalies
merged['anomaly_count'] = merged['anomaly_count'].fillna(0).astype(int)
merged['earliest_anomaly_timestamp'] = merged['earliest_anomaly_timestamp'].astype('Int64')

# 9) Select required columns and order by anomaly_count desc, limit to top 20
result = (
    merged[['cmdb_id', 'trace_name', 'total_count', 'window_count', 'anomaly_count', 'earliest_anomaly_timestamp', 'max_value_in_window', 'global_p95']]
    .sort_values(['anomaly_count', 'max_value_in_window'], ascending=[False, False])
    .head(20)
    .reset_index(drop=True)
)

