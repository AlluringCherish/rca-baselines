import pandas as pd
import pytz

# reuse existing DataFrames if present, else load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')

# Ensure numeric types
df_metric['timestamp'] = pd.to_numeric(df_metric['timestamp'], errors='coerce').astype('Int64')
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

df_trace['timestamp'] = pd.to_numeric(df_trace['timestamp'], errors='coerce').astype('Int64')
df_trace['value'] = pd.to_numeric(df_trace['value'], errors='coerce')

# Define apache error-log interval (given epochs)
start_ts = 1616664122
end_ts = 1616664367

# ---------------------
# 1) Metrics: compute global P95 per (cmdb_id, kpi_name) using full series
metric_global = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(total_count='size', global_p95=lambda s: float(s.quantile(0.95)))
    .reset_index()
)

# Filter metric rows to the interval (inclusive)
metric_window = df_metric[(df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] <= end_ts)].copy()

# Merge global thresholds into window rows
metric_window = metric_window.merge(metric_global, on=['cmdb_id', 'kpi_name'], how='left')

# Compute window aggregates
metric_window_agg = (
    metric_window
    .groupby(['cmdb_id', 'kpi_name'])
    .agg(
        window_count=('value', 'size'),
        max_value_in_window=('value', 'max')
    )
    .reset_index()
)

# Compute anomalies within window (value > global_p95)
metric_anoms = metric_window[metric_window['value'] > metric_window['global_p95']].copy()
metric_anom_agg = (
    metric_anoms
    .groupby(['cmdb_id', 'kpi_name'])
    .agg(
        anomaly_count=('value', 'size'),
        earliest_anomaly_timestamp=('timestamp', 'min')
    )
    .reset_index()
)

# Merge full stats
metric_merged = (
    metric_window_agg
    .merge(metric_global, on=['cmdb_id', 'kpi_name'], how='left')
    .merge(metric_anom_agg, on=['cmdb_id', 'kpi_name'], how='left')
)

# Fill missing anomaly counts and ensure types
metric_merged['anomaly_count'] = metric_merged['anomaly_count'].fillna(0).astype(int)
metric_merged['earliest_anomaly_timestamp'] = metric_merged['earliest_anomaly_timestamp'].astype('Int64')

# Select and order columns, sort by anomaly_count desc then max_value_in_window desc, limit 20
result_metric = (
    metric_merged[
        ['cmdb_id', 'kpi_name', 'total_count', 'window_count', 'anomaly_count', 'earliest_anomaly_timestamp', 'max_value_in_window', 'global_p95']
    ]
    .sort_values(['anomaly_count', 'max_value_in_window'], ascending=[False, False])
    .head(20)
    .reset_index(drop=True)
)

# ---------------------
# 2) Traces: compute global P95 per (cmdb_id, trace_name) using full series
trace_global = (
    df_trace
    .groupby(['cmdb_id', 'trace_name'])['value']
    .agg(total_count='size', global_p95=lambda s: float(s.quantile(0.95)))
    .reset_index()
)

# Filter trace rows to the interval
trace_window = df_trace[(df_trace['timestamp'] >= start_ts) & (df_trace['timestamp'] <= end_ts)].copy()

# Merge global thresholds into window rows
trace_window = trace_window.merge(trace_global, on=['cmdb_id', 'trace_name'], how='left')

# Compute window aggregates
trace_window_agg = (
    trace_window
    .groupby(['cmdb_id', 'trace_name'])
    .agg(
        window_count=('value', 'size'),
        max_value_in_window=('value', 'max')
    )
    .reset_index()
)

# Compute anomalies within window (value > global_p95)
trace_anoms = trace_window[trace_window['value'] > trace_window['global_p95']].copy()
trace_anom_agg = (
    trace_anoms
    .groupby(['cmdb_id', 'trace_name'])
    .agg(
        anomaly_count=('value', 'size'),
        earliest_anomaly_timestamp=('timestamp', 'min')
    )
    .reset_index()
)

# Merge full stats
trace_merged = (
    trace_window_agg
    .merge(trace_global, on=['cmdb_id', 'trace_name'], how='left')
    .merge(trace_anom_agg, on=['cmdb_id', 'trace_name'], how='left')
)

# Fill missing anomaly counts and ensure types
trace_merged['anomaly_count'] = trace_merged['anomaly_count'].fillna(0).astype(int)
trace_merged['earliest_anomaly_timestamp'] = trace_merged['earliest_anomaly_timestamp'].astype('Int64')

# Select and order columns, sort by anomaly_count desc then max_value_in_window desc, limit 20
result_trace = (
    trace_merged[
        ['cmdb_id', 'trace_name', 'total_count', 'window_count', 'anomaly_count', 'earliest_anomaly_timestamp', 'max_value_in_window', 'global_p95']
    ]
    .sort_values(['anomaly_count', 'max_value_in_window'], ascending=[False, False])
    .head(20)
    .reset_index(drop=True)
)

# Compact results (DataFrames limited to top 20)
result_metric, result_trace
