metric_max_ts = int(df_metric['timestamp'].max()) if not df_metric['timestamp'].isna().all() else None

# 2) trace.csv summary
trace_pairs = (
    df_trace.groupby(['cmdb_id', 'trace_name'])
    .size()
    .reset_index(name='count')
    .sort_values('count', ascending=False)
)
