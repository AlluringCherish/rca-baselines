if not df_trace_at_ts.empty:
    df_trace_at_ts['ts_local'] = pd.to_datetime(df_trace_at_ts['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# compute count of rows per cmdb_id (within this filtered slice)
