import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Ensure trace_df is loaded and dt exists
try:
    trace_df
except NameError:
    trace_df = pd.read_csv('trace.csv')

# Ensure dt column is timezone-aware Asia/Shanghai
if 'dt' in trace_df.columns:
    trace_df['dt'] = pd.to_datetime(trace_df['dt'])
    if trace_df['dt'].dt.tz is None:
        if 'timestamp' in trace_df.columns:
            trace_df['dt'] = pd.to_datetime(trace_df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
        else:
            trace_df['dt'] = trace_df['dt'].dt.tz_localize('UTC').dt.tz_convert(tz)
    else:
        trace_df['dt'] = trace_df['dt'].dt.tz_convert(tz)
else:
    trace_df['dt'] = pd.to_datetime(trace_df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Selection criteria
components = ['IG01','Tomcat04','Tomcat03','Tomcat02','Tomcat01']
name_pattern = r'trace\.self|to_Tomcat|to_Tomcat04'

# 2) Compute full-series global P95 per (cmdb_id, trace_name) BEFORE filtering
trace_global_p95 = trace_df.groupby(['cmdb_id','trace_name'], as_index=False).agg(
    global_p95 = ('value', lambda s: float(s.quantile(0.95)))
)

# Filter groups by component and trace_name pattern using full-series groups
selected_groups = trace_global_p95[
    trace_global_p95['cmdb_id'].isin(components) &
    trace_global_p95['trace_name'].str.contains(name_pattern, regex=True, na=False)
].copy()

# Window boundaries (inclusive) in UTC+8
start_local = tz.localize(pd.to_datetime('2021-03-23 01:30:00'))
end_local = tz.localize(pd.to_datetime('2021-03-23 02:00:00'))

# Prepare windowed trace rows for the selected components/names
window_mask = (
    (trace_df['dt'] >= start_local) & (trace_df['dt'] <= end_local) &
    trace_df['cmdb_id'].isin(components) &
    trace_df['trace_name'].str.contains(name_pattern, regex=True, na=False)
)
trace_window = trace_df[window_mask].copy()

# For windowed data, merge with global p95 for comparison
trace_window = trace_window.merge(trace_global_p95, on=['cmdb_id','trace_name'], how='left')

# Flag anomalies in window where value > global_p95
trace_window['is_anom'] = trace_window['value'] > trace_window['global_p95']

# Aggregates from windowed data per group
win_agg = trace_window.groupby(['cmdb_id','trace_name'], as_index=False).agg(
    count_points_in_window = ('value','count'),
    anomaly_count = ('is_anom','sum'),
    max_value_in_window = ('value','max'),
    earliest_anom_dt = ('dt', lambda s: s[trace_window.loc[s.index, 'is_anom']].min() if any(trace_window.loc[s.index, 'is_anom']) else pd.NaT),
    # earliest_anom_val computed separately for correctness
)

# Compute earliest_anomaly_value properly
if not trace_window.empty:
    earliest_vals = trace_window[trace_window['is_anom']].sort_values(['cmdb_id','trace_name','dt']).groupby(['cmdb_id','trace_name'], as_index=False).first()[['cmdb_id','trace_name','dt','value']]
    earliest_vals = earliest_vals.rename(columns={'dt':'earliest_anom_dt','value':'earliest_anom_val'})
else:
    earliest_vals = pd.DataFrame(columns=['cmdb_id','trace_name','earliest_anom_dt','earliest_anom_val'])

# Merge earliest values into win_agg
if not win_agg.empty:
    win_agg = win_agg.merge(earliest_vals, on=['cmdb_id','trace_name'], how='left')
else:
    # create empty with expected columns
    win_agg = pd.DataFrame(columns=['cmdb_id','trace_name','count_points_in_window','anomaly_count','max_value_in_window','earliest_anom_dt','earliest_anom_val'])

# Now combine with selected_groups to ensure groups with zero window rows are included
result = selected_groups.merge(win_agg, on=['cmdb_id','trace_name'], how='left')

# Fill NaNs for counts and numeric fields
result['count_points_in_window'] = result['count_points_in_window'].fillna(0).astype(int)
result['anomaly_count'] = result['anomaly_count'].fillna(0).astype(int)
result['max_value_in_window'] = result['max_value_in_window'].where(~result['max_value_in_window'].isna(), None)
result['earliest_anom_dt'] = pd.to_datetime(result['earliest_anom_dt'])
result['earliest_anom_val'] = result['earliest_anom_val'].where(~result['earliest_anom_val'].isna(), None)

# Format earliest_anomaly_time to readable string or None
def fmt_dt(x):
    if pd.isna(x):
        return None
    # ensure timezone
    ts = pd.to_datetime(x)
    if ts.tz is None:
        ts = ts.tz_localize('UTC').tz_convert(tz)
    else:
        ts = ts.tz_convert(tz)
    return ts.strftime('%Y-%m-%d %H:%M:%S %Z')

result['earliest_anomaly_time'] = result['earliest_anom_dt'].apply(fmt_dt)
result['earliest_anomaly_value'] = result['earliest_anom_val']

# Keep only requested columns and rename global_p95
out = result[['cmdb_id','trace_name','count_points_in_window','global_p95','anomaly_count','earliest_anomaly_time','earliest_anomaly_value','max_value_in_window']].copy()
out = out.rename(columns={'global_p95':'global_p95'})

# Sorting: anomaly_count>0 first (True), ordered by earliest_anomaly_time ascending (None last), then others
out['has_anom'] = out['anomaly_count'] > 0
# For sorting earliest times convert to datetime (NaT for None)
out['_earliest_dt'] = pd.to_datetime(out['earliest_anomaly_time']).dt.tz_localize(None, ambiguous='NaT', nonexistent='NaT')
out = out.sort_values(by=['has_anom','_earliest_dt'], ascending=[False, True])

# Drop helper cols and limit to 30 rows, keep compact
out = out.drop(columns=['has_anom','_earliest_dt']).head(30)

# Display the compact result
out
