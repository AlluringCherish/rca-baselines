    metric_anomalies.groupby(['cmdb_id','kpi_name']).agg(
        anomaly_count = ('value','count'),
        earliest_timestamp = ('timestamp','min'),
        latest_timestamp = ('timestamp','max'),
        min_value = ('value','min'),
        max_value = ('value','max'),
        p95 = ('p95','first'),
        p5  = ('p5','first')
    ).reset_index()
)
group_agg['severity_ratio'] = np.where(group_agg['p95']>0, group_agg['max_value'] / group_agg['p95'], np.nan)

# Select top 20 groups by severity_ratio (NaNs at the end)
top20_groups = (
    group_agg.assign(_isnull = group_agg['severity_ratio'].isnull())
    .sort_values(['_isnull','severity_ratio'], ascending=[True, False])
    .drop(columns=['_isnull'])
    .head(20)[['cmdb_id','kpi_name','severity_ratio']]
)

# 2) Restrict metric_anomalies to these top 20 groups and sort by timestamp
filtered = metric_anomalies.merge(top20_groups[['cmdb_id','kpi_name']], on=['cmdb_id','kpi_name'], how='inner')
