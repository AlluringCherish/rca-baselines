    filtered.groupby(['cmdb_id','kpi_name','segment_id'])
    .agg(
        start_timestamp = ('timestamp','min'),
        end_timestamp   = ('timestamp','max'),
        length_in_minutes = ('timestamp','count'),
        min_value = ('value','min'),
        max_value = ('value','max'),
        p95 = ('p95','first')
    )
    .reset_index()
)

# compute severity_ratio (null if p95 <= 0)
faults['severity_ratio'] = np.where(faults['p95']>0, faults['max_value'] / faults['p95'], np.nan)

# 4) Filter out isolated single-point spikes unless severity_ratio >= 2.0
