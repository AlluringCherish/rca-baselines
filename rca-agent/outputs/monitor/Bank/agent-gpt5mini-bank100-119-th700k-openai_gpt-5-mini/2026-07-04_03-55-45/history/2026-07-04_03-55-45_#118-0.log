import numpy as np
import pandas as pd
import pytz

# ensure required variables exist in kernel: metric_anomalies, agg_sorted
# Reuse tz object per rules (not converting timestamps)
tz = pytz.timezone('Asia/Shanghai')

# 1) select top 20 groups by severity_ratio from previous aggregation (agg_sorted)
top20_groups = agg_sorted[['cmdb_id','kpi_name','severity_ratio']].head(20).copy()

# 2) restrict metric_anomalies to these top 20 groups and sort
filtered = metric_anomalies.merge(top20_groups[['cmdb_id','kpi_name']], on=['cmdb_id','kpi_name'], how='inner')
filtered = filtered.sort_values(['cmdb_id','kpi_name','timestamp']).copy()

# 2b) identify consecutive anomaly segments within each group: gap > 60s starts new segment
filtered['ts_diff'] = filtered.groupby(['cmdb_id','kpi_name'])['timestamp'].diff().fillna(0)
filtered['segment_id'] = filtered.groupby(['cmdb_id','kpi_name'])['ts_diff'].apply(lambda x: x.gt(60).cumsum())

# 3) aggregate per fault segment
faults = (
    filtered.groupby(['cmdb_id','kpi_name','segment_id'])
    .agg(
        start_timestamp = ('timestamp','min'),
        end_timestamp   = ('timestamp','max'),
        length_in_minutes = ('timestamp','count'),
        min_value = ('value','min'),
        max_value = ('value','max'),
        p95 = ('p95','first')
    )
    .reset_index(drop=False)
)

# compute severity_ratio (null if p95 == 0)
faults['severity_ratio'] = np.where(faults['p95']>0, faults['max_value'] / faults['p95'], np.nan)

# 4) filter out isolated single-point spikes unless severity_ratio >= 2.0
faults_filtered = faults[~((faults['length_in_minutes']==1) & (faults['severity_ratio'] < 2.0))].copy()

# 5) store full fault segments table for later correlation
metric_faults = faults_filtered.copy()

# prepare final top-20 display sorted by severity_ratio desc, NaNs at the end
faults_display = (
    metric_faults.assign(_isnull = metric_faults['severity_ratio'].isnull())
    .sort_values(['_isnull','severity_ratio'], ascending=[True, False])
    .drop(columns=['_isnull','segment_id'], errors='ignore')  # drop internals if present
)

# select requested columns and limit to top 20
result = faults_display[[
    'cmdb_id','kpi_name','start_timestamp','end_timestamp','length_in_minutes',
    'min_value','max_value','p95','severity_ratio'
]].head(20)

# Return the stored full faults table shape and the compact top-20 result
metric_faults.shape, result
