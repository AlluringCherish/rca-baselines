import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse existing kernel variables: metric_anomalies, trace_anomalies, trace_anomalies_filtered
# 1) Filter metric_anomalies for MG01 and Tomcat04, sort by consecutive_flag (True first) then severity_ratio desc
components = ["MG01", "Tomcat04"]
metric_evidence = (
    metric_anomalies[metric_anomalies['cmdb_id'].isin(components)]
    .copy()
)
# Ensure severity_ratio exists (should from prior step); if missing, compute defensively
if 'severity_ratio' not in metric_evidence.columns:
    import numpy as np
    metric_evidence['severity_ratio'] = np.where(
        metric_evidence['global_p95'] == 0,
        np.where(metric_evidence['max_value_in_window'] == 0, pd.NA, float('inf')),
        metric_evidence['max_value_in_window'] / metric_evidence['global_p95']
    )

metric_evidence = metric_evidence.sort_values(
    by=['consecutive_flag', 'severity_ratio'],
    ascending=[False, False]
)[[
    'cmdb_id', 'kpi_name', 'global_p95', 'points_in_window', 'count_anomalies',
    'earliest_anomaly_timestamp', 'max_value_in_window', 'severity_ratio', 'consecutive_flag'
]].reset_index(drop=True).head(20)

# 2) Per-component earliest metric anomaly time and number of kpis with consecutive_flag=True
metric_earliest = (
    metric_anomalies[metric_anomalies['cmdb_id'].isin(components)]
    .groupby('cmdb_id', as_index=False)
    .agg(
        earliest_metric_anomaly_timestamp=('earliest_anomaly_timestamp', 'min'),
        num_faulty_kpis=('consecutive_flag', 'sum')
    )
)
# ensure integer type for count
metric_earliest['num_faulty_kpis'] = metric_earliest['num_faulty_kpis'].astype(int)

# 3) From trace_anomalies_filtered, return rows that involve MG01 and Tomcat04 based on trace_name patterns
# Use trace_anomalies_filtered if available; otherwise fall back to trace_anomalies
ta = trace_anomalies_filtered if 'trace_anomalies_filtered' in globals() else trace_anomalies

pattern_keywords = ['Tomcat04', 'MG01', 'to_MG01', 'from_Tomcat04']
mask_comp = ta['cmdb_id'].isin(components)
mask_name = ta['trace_name'].astype(str).apply(lambda s: any(k in s for k in pattern_keywords))
trace_evidence = ta[mask_comp & mask_name].copy()

# Compute severity_ratio & ensure it exists
if 'severity_ratio' not in trace_evidence.columns:
    import numpy as np
    trace_evidence['severity_ratio'] = np.where(
        trace_evidence['global_p95'] == 0,
        np.where(trace_evidence['max_value_in_window'] == 0, pd.NA, float('inf')),
        trace_evidence['max_value_in_window'] / trace_evidence['global_p95']
    )

trace_evidence = trace_evidence.sort_values(
    by=['count_anomalies', 'severity_ratio'],
    ascending=[False, False]
)[[
    'cmdb_id', 'trace_name', 'global_p95', 'points_in_window', 'count_anomalies',
    'earliest_anomaly_timestamp', 'max_value_in_window', 'severity_ratio'
]].reset_index(drop=True).head(20)

# 4) Earliest trace anomaly timestamp among these returned trace rows per cmdb_id
trace_earliest = (
    trace_evidence.groupby('cmdb_id', as_index=False)
    .agg(earliest_trace_anomaly_timestamp=('earliest_anomaly_timestamp', 'min'))
)

# Counts: number of metric_anomalies rows for MG01 and Tomcat04, and number of matching trace_anomalies rows for MG01 and Tomcat04
metric_counts = pd.DataFrame({
    'cmdb_id': components,
    'metric_anomalies_rows': [int(metric_anomalies[metric_anomalies['cmdb_id'] == c].shape[0]) for c in components]
})

trace_counts = pd.DataFrame({
    'cmdb_id': components,
    'matching_trace_anomalies_rows': [int(ta[(ta['cmdb_id'] == c) & (ta['trace_name'].astype(str).apply(lambda s: any(k in s for k in pattern_keywords)))].shape[0]) for c in components]
})

# Compact outputs (each variable is concise / limited rows)
metric_evidence, metric_earliest, trace_evidence, trace_earliest, metric_counts, trace_counts
