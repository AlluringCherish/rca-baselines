import pandas as pd
import numpy as np
import pytz
from pathlib import Path

tz = pytz.timezone('Asia/Shanghai')
start = pd.to_datetime('2021-03-25 18:00:00').tz_localize(tz)
end = pd.to_datetime('2021-03-25 18:30:00').tz_localize(tz)
targets = ['MG01', 'MG02']

# Reuse existing log_df and error_df if present, otherwise load
if 'log_df' not in globals():
    log_path = Path("log.csv")
    log_df = pd.read_csv(log_path) if log_path.exists() else pd.DataFrame(columns=["timestamp","cmdb_id","log_name","value"])
if 'error_df' not in globals():
    err_path = Path("error_logs.csv")
    error_df = pd.read_csv(err_path) if err_path.exists() else pd.DataFrame(columns=["timestamp","cmdb_id","message"])

# Ensure dt columns (timezone-aware Asia/Shanghai)
for df in (log_df, error_df):
    if 'timestamp' in df.columns and not df.empty:
        df['dt'] = pd.to_datetime(df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    else:
        df['dt'] = pd.Series(dtype='datetime64[ns]')

# 1) Global group summaries for log.csv restricted to MG01 and MG02
log_mg = log_df[log_df['cmdb_id'].isin(targets)]
if log_mg.empty:
    log_mg_summary = pd.DataFrame(columns=['cmdb_id','log_name','count','p50','p95','min','max'])
else:
    grp = log_mg.groupby(['cmdb_id','log_name'])['value']
    log_mg_summary = grp.agg(
        count='count',
        p50=lambda s: float(s.quantile(0.5)),
        p95=lambda s: float(s.quantile(0.95)),
        min='min',
        max='max'
    ).reset_index()

# store in kernel variable
log_mg_summary = log_mg_summary

# 2) Filter log.csv to the incident window and targets
log_mg_window = log_df[
    (log_df['cmdb_id'].isin(targets)) &
    (log_df['dt'] >= start) & (log_df['dt'] <= end)
].copy()

# Selection condition: log_name contains keywords OR value > 0
keyword_mask = log_mg_window['log_name'].astype(str).str.contains(r'error|gc|row_count|gc_pause', case=False, na=False)
value_mask = pd.to_numeric(log_mg_window['value'], errors='coerce').fillna(0) > 0
selected_mask = keyword_mask | value_mask

log_mg_window_selected = log_mg_window[selected_mask].sort_values('dt', ascending=True)

# Limit to at most 50 rows and include columns timestamp, cmdb_id, log_name, value
log_mg_window_selected = log_mg_window_selected[['timestamp','cmdb_id','log_name','value']].head(50)

# Store full filtered table in kernel variable
log_mg_window = log_mg_window

# 3) From error_logs.csv, filter by cmdb_id and window
error_logs_mg = error_df[
    (error_df['cmdb_id'].isin(targets)) &
    (error_df['dt'] >= start) & (error_df['dt'] <= end)
].copy()

# Summary: count, earliest, latest, examples up to 5 rows (timestamp, cmdb_id, message)
if error_logs_mg.empty:
    error_logs_mg_summary = pd.DataFrame([{
        'rows_count': 0,
        'earliest_dt': pd.NaT,
        'latest_dt': pd.NaT
    }])
    error_logs_mg_examples = pd.DataFrame(columns=['timestamp','cmdb_id','message'])
else:
    rows_count = int(error_logs_mg.shape[0])
    earliest_dt = error_logs_mg['dt'].min()
    latest_dt = error_logs_mg['dt'].max()
    error_logs_mg_summary = pd.DataFrame([{
        'rows_count': rows_count,
        'earliest_dt': earliest_dt,
        'latest_dt': latest_dt
    }])
    # examples limited to 5, show original timestamp (seconds), cmdb_id, message
    error_logs_mg_examples = error_logs_mg[['timestamp','cmdb_id','message']].sort_values('timestamp').head(5)

# Keep full filtered error logs in kernel variable as requested
error_logs_mg = error_logs_mg

# Final compact outputs (limited): log_mg_summary (top 50), log_mg_window_selected (<=50 rows), error_logs_mg_summary, error_logs_mg_examples (<=5)
log_mg_summary.head(50), log_mg_window_selected, error_logs_mg_summary, error_logs_mg_examples.head(5)
