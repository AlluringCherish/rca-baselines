import pandas as pd
import numpy as np
import pytz

# reuse existing variables when possible
tz = pytz.timezone('Asia/Shanghai')

try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv', low_memory=False)

# Ensure timestamp_dt exists and is Asia/Shanghai tz-aware
if 'timestamp_dt' not in metric_df.columns:
    metric_df['timestamp_dt'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    def _to_shanghai(ts):
        if pd.isna(ts):
            return pd.NaT
        if isinstance(ts, pd.Timestamp):
            if ts.tzinfo is None:
                return ts.tz_localize(tz)
            else:
                return ts.tz_convert(tz)
        return pd.to_datetime(ts, unit='s', utc=True).tz_convert(tz)
    metric_df['timestamp_dt'] = metric_df['timestamp_dt'].apply(_to_shanghai)

# Candidate components
candidates = ['Mysql01','Mysql02','MG01','MG02','Tomcat01','Tomcat02','Tomcat03','Tomcat04',
              'IG01','IG02','Redis01','Redis02','apache01','apache02']

# 1) Compute global stats per (cmdb_id, kpi_name) using full series (for candidate components)
mdf = metric_df[metric_df['cmdb_id'].isin(candidates)].copy()

global_stats = (
    mdf
    .groupby(['cmdb_id','kpi_name'], dropna=False)['value']
    .agg(total_points='count', global_p95=lambda x: x.quantile(0.95))
    .reset_index()
)

# 2) Filter to incident window (inclusive)
start = pd.Timestamp('2021-03-25 20:00:00', tz=tz)
end = pd.Timestamp('2021-03-25 20:30:00', tz=tz)
window = mdf[(mdf['timestamp_dt'] >= start) & (mdf['timestamp_dt'] <= end)].copy()

# Merge global thresholds into window rows
w = window.merge(global_stats, on=['cmdb_id','kpi_name'], how='left', validate='m:1')

# mark exceedances (strict > global_p95)
w['exceed_flag'] = w['value'] > w['global_p95']

# 3) Per (cmdb_id,kpi_name) window-level stats
grp_window = (
    w
    .groupby(['cmdb_id','kpi_name'], dropna=False)
    .agg(
        points_in_window=('value','size'),
        exceed_count_window=('exceed_flag','sum'),
        first_exceed_timestamp=('timestamp_dt', lambda s: s[w.loc[s.index,'exceed_flag']].min() if len(s)>0 else pd.NaT),
        max_value_in_window=('value','max')
    )
    .reset_index()
)

# Merge with global_stats to ensure all kpi groups included (kpis with no window rows will be absent in grp_window)
group_all = global_stats.merge(grp_window, on=['cmdb_id','kpi_name'], how='left')

# Fill NaNs for groups without window rows
group_all['points_in_window'] = group_all['points_in_window'].fillna(0).astype(int)
group_all['exceed_count_window'] = group_all['exceed_count_window'].fillna(0).astype(int)
group_all['max_value_in_window'] = group_all['max_value_in_window']  # keep NaN if absent
# Ensure first_exceed_timestamp tz-aware or NaT
group_all['first_exceed_timestamp'] = pd.to_datetime(group_all['first_exceed_timestamp']).dt.tz_convert(tz, ambiguous='NaT', nonexistent='NaT')

# 4) Compute per-(component,kpi) ratio where exceed_count_window > 0 and global_p95 != 0
def compute_kpi_ratio(row):
    if row['exceed_count_window'] <= 0:
        return np.nan
    gp95 = row['global_p95']
    maxv = row['max_value_in_window']
    if pd.isna(gp95) or gp95 == 0 or pd.isna(maxv):
        return np.nan
    return (maxv - gp95) / gp95

group_all['kpi_over_p95_ratio'] = group_all.apply(compute_kpi_ratio, axis=1)

# 5) Aggregate per-component
# earliest_exceed_timestamp per component
comp_earliest = (
    group_all[group_all['exceed_count_window'] > 0]
    .groupby('cmdb_id', dropna=False)
    .agg(earliest_exceed_timestamp=('first_exceed_timestamp','min'))
    .reset_index()
)

# distinct_kpis_with_exceed
comp_distinct = (
    group_all[group_all['exceed_count_window'] > 0]
    .groupby('cmdb_id', dropna=False)
    .agg(distinct_kpis_with_exceed=('kpi_name','nunique'),
         total_exceed_points=('exceed_count_window','sum'))
    .reset_index()
)

# max_over_p95_ratio and top_kpi_by_ratio per component (ignore NaN ratios)
kpi_ratios = group_all[['cmdb_id','kpi_name','kpi_over_p95_ratio']].copy()
kpi_ratios_nonan = kpi_ratios[~kpi_ratios['kpi_over_p95_ratio'].isna()].copy()

if not kpi_ratios_nonan.empty:
    idx = kpi_ratios_nonan.groupby('cmdb_id')['kpi_over_p95_ratio'].idxmax()
    comp_max_ratio = kpi_ratios_nonan.loc[idx].rename(columns={'kpi_over_p95_ratio':'max_over_p95_ratio','kpi_name':'top_kpi_by_ratio'})[['cmdb_id','top_kpi_by_ratio','max_over_p95_ratio']].reset_index(drop=True)
else:
    comp_max_ratio = pd.DataFrame(columns=['cmdb_id','top_kpi_by_ratio','max_over_p95_ratio'])

# Combine per-component results, ensure all candidates present
comp_df = pd.DataFrame({'cmdb_id': candidates})
comp_df = comp_df.merge(comp_earliest, on='cmdb_id', how='left')
comp_df = comp_df.merge(comp_distinct, on='cmdb_id', how='left')
comp_df = comp_df.merge(comp_max_ratio, on='cmdb_id', how='left')

comp_df['distinct_kpis_with_exceed'] = comp_df['distinct_kpis_with_exceed'].fillna(0).astype(int)
comp_df['total_exceed_points'] = comp_df['total_exceed_points'].fillna(0).astype(int)
# max_over_p95_ratio stays NaN if no valid KPI ratios; top_kpi_by_ratio NaN -> set to None for clarity
comp_df['top_kpi_by_ratio'] = comp_df['top_kpi_by_ratio'].where(comp_df['top_kpi_by_ratio'].notna(), None)

# Sort: earliest_exceed_timestamp ascending (NaT last), tie-breaker max_over_p95_ratio descending
# For sorting by max_over_p95_ratio desc while keeping NaT last, we use na_position='last' for timestamps,
# and for ratio we fill NaN with -inf so they sort last when descending tie-breaker is applied.
comp_df_for_sort = comp_df.copy()
comp_df_for_sort['ratio_for_sort'] = comp_df_for_sort['max_over_p95_ratio'].fillna(-np.inf)
comp_df_sorted = comp_df_for_sort.sort_values(by=['earliest_exceed_timestamp','ratio_for_sort'], ascending=[True, False], na_position='last')

# Final select columns and limit to 20 rows
comp_timeline_summary = comp_df_sorted[['cmdb_id','earliest_exceed_timestamp','distinct_kpis_with_exceed','total_exceed_points','max_over_p95_ratio','top_kpi_by_ratio']].head(20)

comp_timeline_summary
