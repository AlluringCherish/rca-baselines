import pandas as pd
import pytz
tz = pytz.timezone('Asia/Shanghai')

# Reuse trace_df from kernel
# 1) Compute global P95, P05, full_count per (cmdb_id, trace_name)
trace_thresholds = (
    trace_df
    .groupby(['cmdb_id','trace_name'], sort=True)['value']
    .agg(
        full_count = 'count',
        P95 = lambda s: float(s.quantile(0.95)),
        P05 = lambda s: float(s.quantile(0.05))
    )
    .reset_index()
)

# 2) Filter trace rows to the incident window (inclusive)
start_ts = 1616680800
end_ts   = 1616682600
trace_window = trace_df[(trace_df['timestamp'] >= start_ts) & (trace_df['timestamp'] <= end_ts)].copy()

# 3) Merge thresholds into window rows and flag anomalies
trace_window = trace_window.merge(trace_thresholds, on=['cmdb_id','trace_name'], how='left')
trace_window['high_flag'] = trace_window['value'] >= trace_window['P95']
trace_window['low_flag']  = trace_window['value'] <= trace_window['P05']

# Helper to convert integer ts to ISO in Asia/Shanghai
def ts_to_iso(val):
    if pd.isna(val):
        return None
    return pd.to_datetime(int(val), unit='s', utc=True).tz_convert(tz).isoformat()

# Aggregations within window per series
window_stats = (
    trace_window
    .groupby(['cmdb_id','trace_name'], sort=True)
    .agg(
        window_count = ('value','count'),
        # high stats
        high_anomaly_count = (lambda x: (x >= x.name) , 'count')  # placeholder won't be used
    )
    .reset_index()
)

# Instead compute high/low using groupby on flags
high_stats = (
    trace_window[trace_window['high_flag']]
    .groupby(['cmdb_id','trace_name'], sort=True)
    .agg(
        high_anomaly_count = ('value','count'),
        high_first_ts = ('timestamp','min'),
        high_max = ('value','max')
    )
    .reset_index()
)

low_stats = (
    trace_window[trace_window['low_flag']]
    .groupby(['cmdb_id','trace_name'], sort=True)
    .agg(
        low_anomaly_count = ('value','count'),
        low_first_ts = ('timestamp','min'),
        low_min = ('value','min')
    )
    .reset_index()
)

# window counts, max/min in window
