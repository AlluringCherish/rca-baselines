import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Load CSV files
metric_df = pd.read_csv('metric.csv')
trace_df = pd.read_csv('trace.csv')
log_df = pd.read_csv('log.csv')
error_df = pd.read_csv('error_logs.csv')

# Helper to convert epoch seconds to UTC+8 localized ISO strings (handles NaN)
def epoch_to_tz_iso(epoch_series):
    if epoch_series.dropna().empty:
        return None
    # convert to datetime (assume epoch is UTC), then convert to Asia/Shanghai
    dt = pd.to_datetime(epoch_series, unit='s', utc=True).dt.tz_convert(tz)
    # return min and max as ISO strings
    return dt.min().isoformat(), dt.max().isoformat()

# Generic summarizer
def summarize_file(df, name_col=None, sample_col_name='name'):
    total_rows = len(df)
    min_max = epoch_to_tz_iso(df['timestamp']) if 'timestamp' in df.columns else (None, None)
    unique_cmdb_counts = df['cmdb_id'].value_counts().reset_index().rename(columns={'index':'cmdb_id','cmdb_id':'count'})
    cmdb_top = unique_cmdb_counts.head(50)  # top 50 cmdb ids by frequency
    unique_name_counts = None
    if name_col and name_col in df.columns:
        unique_name_counts = df[name_col].value_counts().reset_index().rename(columns={'index':sample_col_name, name_col:'count'})
        name_top = unique_name_counts.head(50)
    else:
        name_top = pd.DataFrame(columns=[sample_col_name, 'count'])
    summary = pd.DataFrame([{
        'total_rows': total_rows,
        'min_timestamp_UTC+8': min_max[0],
        'max_timestamp_UTC+8': min_max[1],
        'unique_cmdb_count': df['cmdb_id'].nunique() if 'cmdb_id' in df.columns else 0,
        'unique_names_count': unique_name_counts.shape[0] if unique_name_counts is not None else 0
    }])
    return summary, cmdb_top, name_top

# Summaries for each file
metric_summary, metric_cmdb_top, metric_kpi_top = summarize_file(metric_df, name_col='kpi_name', sample_col_name='kpi_name')
trace_summary, trace_cmdb_top, trace_trace_top = summarize_file(trace_df, name_col='trace_name', sample_col_name='trace_name')
log_summary, log_cmdb_top, log_logname_top = summarize_file(log_df, name_col='log_name', sample_col_name='log_name')
error_summary, error_cmdb_top, error_msg_top = summarize_file(error_df, name_col='message', sample_col_name='message')

# Keep outputs compact: show only top 50 rows where applicable and selected columns
metric_kpi_top = metric_kpi_top[['kpi_name','count']].head(50)
trace_trace_top = trace_trace_top[['trace_name','count']].head(50)
log_logname_top = log_logname_top[['log_name','count']].head(50)
error_msg_top = error_msg_top[['message','count']].head(50)

# Display the summaries and top lists (as compact tables)
metric_summary, metric_cmdb_top.head(50), metric_kpi_top, \
trace_summary, trace_cmdb_top.head(50), trace_trace_top, \
log_summary, log_cmdb_top.head(50), log_logname_top, \
error_summary, error_cmdb_top.head(50), error_msg_top
