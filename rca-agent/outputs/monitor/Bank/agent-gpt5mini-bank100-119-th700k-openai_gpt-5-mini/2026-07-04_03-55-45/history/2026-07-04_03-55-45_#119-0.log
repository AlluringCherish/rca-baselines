error_group = (
    error_window
    .groupby('cmdb_id', as_index=False)
    .agg(
        count=('timestamp', 'size'),
        earliest_ts=('dt', 'min'),
        latest_ts=('dt', 'max')
    )
    .sort_values('count', ascending=False)
    .head(10)
    .reset_index(drop=True)
)

# Format timestamps to ISO strings for compact display
error_group['earliest_ts'] = error_group['earliest_ts'].dt.tz_convert(tz).dt.isoformat()
error_group['latest_ts'] = error_group['latest_ts'].dt.tz_convert(tz).dt.isoformat()
