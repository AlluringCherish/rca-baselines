import pandas as pd
import pytz, datetime

# Reuse existing df_log and tz if available
try:
    df_log
except NameError:
    df_log = pd.read_csv('log.csv')

tz = pytz.timezone('Asia/Shanghai')

# Components of interest
components = ['apache01','apache02','Tomcat01','Tomcat02','Tomcat03','Tomcat04']

# 1) Compute global P95 for log.row_count per cmdb_id using full log.csv (thresholds before any filtering)
df_log['value'] = pd.to_numeric(df_log['value'], errors='coerce')
rowcount_full = df_log[df_log['log_name'] == 'log.row_count'].copy()
global_p95 = (
    rowcount_full
    .groupby('cmdb_id', as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_P95'})
)

# Ensure all target components are present in the p95 table (include missing with NaN)
p95_target = pd.DataFrame({'cmdb_id': components}).merge(global_p95, on='cmdb_id', how='left')

# 2) Define inclusive incident window and filter log rows to the window
start_local = tz.localize(datetime.datetime(2021, 3, 23, 18, 0, 0))
end_local = tz.localize(datetime.datetime(2021, 3, 23, 18, 30, 0))
start_ts = int(start_local.astimezone(pytz.UTC).timestamp())
end_ts = int(end_local.astimezone(pytz.UTC).timestamp())

df_log_window = df_log[(df_log['timestamp'] >= start_ts) & (df_log['timestamp'] <= end_ts)].copy()

# Focus on log.row_count rows for the selected components in the window
window_rowcount = df_log_window[(df_log_window['log_name'] == 'log.row_count') & (df_log_window['cmdb_id'].isin(components))].copy()

# Merge global P95 into window rows to evaluate crossing
window_rowcount = window_rowcount.merge(p95_target, on='cmdb_id', how='right', suffixes=('', '_p95'))

# 3) Aggregate per component: earliest timestamp where value >= global_P95, max and sum within window
def earliest_crossing(group):
    gp = group['global_P95'].iloc[0]
    if pd.isna(gp):
        return None
    # select rows where value >= gp; note if gp==0, condition applies accordingly
    mask = group['value'] >= gp
    if mask.any():
        ts = int(group.loc[mask, 'timestamp'].min())
        return pd.to_datetime(ts, unit='s', utc=True).tz_convert(tz).strftime("%Y-%m-%d %H:%M:%S %Z")
    else:
        return None

agg = (
    window_rowcount
    .groupby('cmdb_id', as_index=True)
    .agg(
        max_log_row_count_within_window=('value', 'max'),
        sum_log_row_count_within_window=('value', 'sum')
    )
)

# Ensure all components present in agg (include those with no rows in window)
agg = p95_target.set_index('cmdb_id').join(agg)

# Compute earliest crossing per component
earliest_list = {}
for cmdb in components:
    grp = window_rowcount[window_rowcount['cmdb_id'] == cmdb]
    if grp.empty:
        earliest = None
    else:
        earliest = earliest_crossing(grp)
    earliest_list[cmdb] = earliest

# Apply earliest list to agg
agg['earliest_timestamp_in_window_where_log.row_count>=global_P95'] = pd.Series(earliest_list)

# Reorder and rename columns per request
result_table = agg.reset_index()[[
    'cmdb_id',
    'global_P95',
    'earliest_timestamp_in_window_where_log.row_count>=global_P95',
    'max_log_row_count_within_window',
    'sum_log_row_count_within_window'
]]

# Format numeric columns: keep as-is (compact)
# 4) Compute single earliest timestamp among these components where any crossed its P95
valid_earlies = result_table['earliest_timestamp_in_window_where_log.row_count>=global_P95'].dropna().tolist()
if valid_earlies:
    # parse strings back to datetimes for min
    parsed = pd.to_datetime(pd.Series(valid_earlies)).dt.tz_localize(None)  # already localized strings parse as tz-aware in pandas; normalize by removing tz for min
    # To avoid timezone naivety issues, parse with utc then convert
    parsed = pd.to_datetime(pd.Series(valid_earlies)).dt.tz_convert(tz)
    earliest_crossing_any = parsed.min().strftime("%Y-%m-%d %H:%M:%S %Z")
else:
    earliest_crossing_any = None

# Keep outputs compact: show the six-row result_table and earliest_crossing_any
result_table, earliest_crossing_any
