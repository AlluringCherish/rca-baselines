def fmt_num(v):
    try:
        if pd.isna(v):
            return "<NA>"
        v = float(v)
        if abs(v - round(v)) < 1e-9:
            return str(int(round(v)))
        if abs(v) >= 1e6:
            return f"{v:,.0f}"
        return f"{v:.6g}"
    except Exception:
        return str(v)

