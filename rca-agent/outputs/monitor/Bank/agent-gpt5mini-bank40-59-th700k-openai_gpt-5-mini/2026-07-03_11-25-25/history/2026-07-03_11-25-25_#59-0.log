import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Load files (they are expected to be in the working directory)
metric = pd.read_csv('metric.csv')
trace = pd.read_csv('trace.csv')
log = pd.read_csv('log.csv')
error_logs = pd.read_csv('error_logs.csv')

# Ensure timestamp numeric
for df in (metric, trace, log, error_logs):
    if 'timestamp' in df.columns:
        df['timestamp'] = pd.to_numeric(df['timestamp'], errors='coerce').astype('Int64')

# Helper to convert epoch seconds to Asia/Shanghai localized string (compact)
def epoch_to_shanghai_str(s):
    if pd.isna(s):
        return pd.NA
    return pd.to_datetime(int(s), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

# 1) metric.csv aggregation
if not metric.empty:
    metric_grp = metric.groupby(['cmdb_id', 'kpi_name'], as_index=False).agg(
        count_points = ('value', 'count'),
        min_timestamp = ('timestamp', 'min'),
        max_timestamp = ('timestamp', 'max'),
        p50 = ('value', lambda x: float(np.percentile(x.dropna(), 50)) if x.dropna().size>0 else np.nan),
        p95 = ('value', lambda x: float(np.percentile(x.dropna(), 95)) if x.dropna().size>0 else np.nan),
        max_value = ('value', 'max')
    )
    metric_grp['min_timestamp'] = metric_grp['min_timestamp'].apply(lambda x: epoch_to_shanghai_str(x) if pd.notna(x) else pd.NA)
    metric_grp['max_timestamp'] = metric_grp['max_timestamp'].apply(lambda x: epoch_to_shanghai_str(x) if pd.notna(x) else pd.NA)
    metric_summary = metric_grp.sort_values(['count_points','cmdb_id','kpi_name'], ascending=[False, True, True]).head(50)
else:
    metric_summary = pd.DataFrame(columns=['cmdb_id','kpi_name','count_points','min_timestamp','max_timestamp','p50','p95','max_value'])

# 2) trace.csv aggregation
if not trace.empty:
    trace_grp = trace.groupby(['cmdb_id', 'trace_name'], as_index=False).agg(
        count_points = ('value', 'count'),
        min_timestamp = ('timestamp', 'min'),
        max_timestamp = ('timestamp', 'max'),
        p50 = ('value', lambda x: float(np.percentile(x.dropna(), 50)) if x.dropna().size>0 else np.nan),
        p95 = ('value', lambda x: float(np.percentile(x.dropna(), 95)) if x.dropna().size>0 else np.nan),
        max_value = ('value', 'max')
    )
    trace_grp['min_timestamp'] = trace_grp['min_timestamp'].apply(lambda x: epoch_to_shanghai_str(x) if pd.notna(x) else pd.NA)
    trace_grp['max_timestamp'] = trace_grp['max_timestamp'].apply(lambda x: epoch_to_shanghai_str(x) if pd.notna(x) else pd.NA)
    trace_summary = trace_grp.sort_values(['count_points','cmdb_id','trace_name'], ascending=[False, True, True]).head(50)
else:
    trace_summary = pd.DataFrame(columns=['cmdb_id','trace_name','count_points','min_timestamp','max_timestamp','p50','p95','max_value'])

# 3) log.csv aggregation
if not log.empty:
    log_grp = log.groupby(['cmdb_id', 'log_name'], as_index=False).agg(
        count_points = ('value', 'count'),
        min_timestamp = ('timestamp', 'min'),
        max_timestamp = ('timestamp', 'max'),
        p50 = ('value', lambda x: float(np.percentile(x.dropna(), 50)) if x.dropna().size>0 else np.nan),
        p95 = ('value', lambda x: float(np.percentile(x.dropna(), 95)) if x.dropna().size>0 else np.nan),
        max_value = ('value', 'max')
    )
    log_grp['min_timestamp'] = log_grp['min_timestamp'].apply(lambda x: epoch_to_shanghai_str(x) if pd.notna(x) else pd.NA)
    log_grp['max_timestamp'] = log_grp['max_timestamp'].apply(lambda x: epoch_to_shanghai_str(x) if pd.notna(x) else pd.NA)
    log_summary = log_grp.sort_values(['count_points','cmdb_id','log_name'], ascending=[False, True, True]).head(50)
else:
    log_summary = pd.DataFrame(columns=['cmdb_id','log_name','count_points','min_timestamp','max_timestamp','p50','p95','max_value'])

# 4) error_logs.csv summary: total row count, min_timestamp, max_timestamp, top 20 rows (timestamp, cmdb_id, message)
if not error_logs.empty:
    total_error_rows = len(error_logs)
    min_err_ts = int(error_logs['timestamp'].min())
    max_err_ts = int(error_logs['timestamp'].max())
    error_info = pd.DataFrame([{
        'total_rows': total_error_rows,
        'min_timestamp': epoch_to_shanghai_str(min_err_ts),
        'max_timestamp': epoch_to_shanghai_str(max_err_ts)
    }])
    error_top20 = error_logs.sort_values('timestamp', ascending=True)[['timestamp','cmdb_id','message']].head(20).copy()
    error_top20['timestamp'] = error_top20['timestamp'].apply(lambda x: epoch_to_shanghai_str(x) if pd.notna(x) else pd.NA)
else:
    error_info = pd.DataFrame([{'total_rows': 0, 'min_timestamp': pd.NA, 'max_timestamp': pd.NA}])
    error_top20 = pd.DataFrame(columns=['timestamp','cmdb_id','message'])

# Overall min and max timestamp across all files
all_ts = pd.Series(dtype='Int64')
for df in (metric, trace, log, error_logs):
    if not df.empty and 'timestamp' in df.columns:
        all_ts = all_ts.append(df['timestamp'].dropna().astype('Int64'), ignore_index=True)
if not all_ts.empty:
    overall_min = int(all_ts.min())
    overall_max = int(all_ts.max())
    overall_range = pd.DataFrame([{
        'overall_min_timestamp': epoch_to_shanghai_str(overall_min),
        'overall_max_timestamp': epoch_to_shanghai_str(overall_max)
    }])
else:
    overall_range = pd.DataFrame([{'overall_min_timestamp': pd.NA, 'overall_max_timestamp': pd.NA}])

# Keep outputs compact as requested: top 50 for groupings, top 20 for error logs, single-row summaries for counts and overall range
metric_summary, trace_summary, log_summary, error_info, error_top20, overall_range
