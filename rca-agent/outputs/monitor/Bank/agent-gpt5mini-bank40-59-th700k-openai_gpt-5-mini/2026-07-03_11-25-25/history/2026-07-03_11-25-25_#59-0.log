def fmt_num(x):
    try:
        if pd.isna(x):
            return "<NA>"
        # format large ints without scientific notation, floats with 3 sig figs
        if float(x).is_integer():
            return str(int(float(x)))
        val = float(x)
        if abs(val) >= 1e6:
            return f"{val:,.0f}"
        if abs(val) >= 1:
            return f"{val:.3f}"
        return f"{val:.6f}"
    except Exception:
