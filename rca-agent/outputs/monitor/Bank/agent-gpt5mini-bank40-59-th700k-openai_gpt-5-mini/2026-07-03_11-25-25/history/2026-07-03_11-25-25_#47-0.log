import pandas as pd
import numpy as np
import pytz

# Reuse existing df_metric if present; otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv("metric.csv")

# Ensure timezone-aware ts_dt in Asia/Shanghai (UTC+8)
tz = pytz.timezone('Asia/Shanghai')
if 'ts_dt' not in df_metric.columns or df_metric['ts_dt'].isnull().all():
    df_metric['ts_dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Compute global p95 per component-KPI using the full available series (no time filtering)
p95_df = df_metric.groupby(['cmdb_id', 'kpi_name'])['value'] \
    .quantile(0.95).reset_index().rename(columns={'value': 'p95_value'})

# 2) Filter metric.csv to the time window March 4, 2021 21:00 to 21:30 (UTC+8)
start = pd.Timestamp('2021-03-04 21:00:00', tz=tz)
end = pd.Timestamp('2021-03-04 21:30:00', tz=tz)
mask_window = (df_metric['ts_dt'] >= start) & (df_metric['ts_dt'] <= end)
df_win = df_metric.loc[mask_window].copy()

# 3) For groups with any rows in the window, mark anomalies where value >= group's global p95
# Merge global p95 into windowed rows
df_win = df_win.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# Mark anomaly: value >= p95_value (if p95_value is NaN, treat as no threshold => anomaly=False)
df_win['is_anomaly'] = False
mask_has_p95 = df_win['p95_value'].notna()
df_win.loc[mask_has_p95, 'is_anomaly'] = df_win.loc[mask_has_p95, 'value'] >= df_win.loc[mask_has_p95, 'p95_value']

# 4) Aggregate per component-KPI (only groups with number_of_rows_in_window > 0)
grp = df_win.groupby(['cmdb_id', 'kpi_name'])
agg = grp.agg(
    number_of_rows_in_window = ('value', 'count'),
    number_of_anomalies = ('is_anomaly', 'sum'),
    earliest_anomaly_ts = (lambda d: d.loc[d['is_anomaly'], 'ts_dt'].min() if d['is_anomaly'].any() else pd.NaT),
    p95_value = ('p95_value', 'first'),
    max_value_in_window = ('value', 'max')
).reset_index()

# The custom earliest_anomaly_ts aggregation above may not work in all pandas versions;
# ensure correctness by computing earliest_anomaly_ts separately if needed:
if agg['earliest_anomaly_ts'].isna().all():
    # recompute via groupby apply (safe fallback)
    def earliest_anom(sub):
        an = sub.loc[sub['is_anomaly'], 'ts_dt']
        return an.min() if not an.empty else pd.NaT
    earliest = df_win.groupby(['cmdb_id','kpi_name']).apply(earliest_anom).reset_index().rename(columns={0:'earliest_anomaly_ts'})
    agg = agg.drop(columns=['earliest_anomaly_ts']).merge(earliest, on=['cmdb_id','kpi_name'], how='left')

# 5) Compute max_excess_ratio = (max_value_in_window - p95_value)/p95_value (use NaN if p95_value==0 or NaN)
agg['max_excess_ratio'] = np.where(
    (agg['p95_value'].isna()) | (agg['p95_value'] == 0),
    np.nan,
    (agg['max_value_in_window'] - agg['p95_value']) / agg['p95_value']
)

# Format earliest_anomaly_ts as string in Asia/Shanghai or null
agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_ts'].apply(
    lambda x: x.isoformat() if pd.notna(x) else None
)
agg = agg.drop(columns=['earliest_anomaly_ts'])

# Round numeric columns for compactness
agg['p95_value'] = agg['p95_value'].round(6)
agg['max_value_in_window'] = agg['max_value_in_window'].round(6)
agg['max_excess_ratio'] = agg['max_excess_ratio'].round(6)

# Keep only groups with number_of_rows_in_window > 0 (df_win already ensures groups present)
result_df_all = agg.copy()

# Sort by number_of_anomalies desc then max_excess_ratio desc, limit to top 20
result_df_top20 = result_df_all.sort_values(['number_of_anomalies', 'max_excess_ratio'], ascending=[False, False]).head(20).reset_index(drop=True)

# Total groups with anomaly (number_of_anomalies > 0)
total_groups_with_anomaly = int((result_df_all['number_of_anomalies'] > 0).sum())

# Compact display variables returned for inspection
result_df_top20, total_groups_with_anomaly
