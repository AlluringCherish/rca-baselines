for r in log_top5:
    cmdb,name,cnt,p50,p95,te,tl = r
    summary_lines.append(f"    • {cmdb} | {short(name)} | count={int(cnt)} | p50={float(p50):.3f} p95={float(p95):.3f} | {te} → {tl}")

# error logs
