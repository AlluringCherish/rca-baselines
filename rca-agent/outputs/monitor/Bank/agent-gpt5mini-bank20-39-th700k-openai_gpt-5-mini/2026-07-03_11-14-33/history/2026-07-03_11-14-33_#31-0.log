# Analyze trace.csv for candidate components for high/low anomalies using full-series thresholds.
import pandas as pd
import pytz

# Reuse existing trace DataFrame and timezone if available
try:
    trace
except NameError:
    trace = pd.read_csv('trace.csv')
tz = pytz.timezone('Asia/Shanghai')

# Candidate components
candidates = ['MG02', 'Mysql01', 'Tomcat03', 'apache02', 'apache01']

# 1) Compute global p95 and p5 per (cmdb_id, trace_name) using full series
pctl = trace.groupby(['cmdb_id', 'trace_name'], dropna=False)['value'].agg(
    p95=lambda x: x.quantile(0.95),
    p5=lambda x: x.quantile(0.05)
).reset_index()

# 2) Filter trace to the inclusive window [1615516200, 1615518000] and to candidate components
win_start_ts = 1615516200
win_end_ts = 1615518000
trace_win = trace[
    (trace['timestamp'] >= win_start_ts) &
    (trace['timestamp'] <= win_end_ts) &
    (trace['cmdb_id'].isin(candidates))
].copy()

# If no points in window for candidates, return empty results with summary
if trace_win.empty:
    result_df = pd.DataFrame(columns=[
        'cmdb_id','trace_name','count_in_window','anomalies_count_high','earliest_anomaly_ts_high',
        'max_value_in_window','p95','severity_high','anomalies_count_low','earliest_anomaly_ts_low',
        'p5','severity_low'
    ])
    summary_line = "0 distinct trace series had anomalies among the candidate components in the window. Components with anomalies: []"
    result_df, summary_line
else:
    # 3) Join windowed points with p95/p5
    trace_win = trace_win.merge(pctl, on=['cmdb_id', 'trace_name'], how='left')

    # mark high/low anomaly flags
    trace_win['is_high'] = trace_win['value'] >= trace_win['p95']
    trace_win['is_low'] = trace_win['value'] <= trace_win['p5']

    # 3/4) Aggregate per (cmdb_id, trace_name)
    grp = trace_win.groupby(['cmdb_id', 'trace_name'], dropna=False)

    agg = grp.agg(
        count_in_window = ('timestamp', 'size'),
        max_value_in_window = ('value', 'max'),
        min_value_in_window = ('value', 'min'),
        anomalies_count_high = ('is_high', 'sum'),
        anomalies_count_low = ('is_low', 'sum'),
        earliest_anomaly_ts_high = (lambda d: d.loc[d['is_high'], 'timestamp'].min() if d['is_high'].any() else pd.NA),
        earliest_anomaly_ts_low = (lambda d: d.loc[d['is_low'], 'timestamp'].min() if d['is_low'].any() else pd.NA),
        p95 = ('p95', 'first'),
        p5 = ('p5', 'first')
    ).reset_index()

    # The custom lambdas used above inside agg may not work in older pandas; handle earliest anomaly timestamps explicitly:
    # Recompute earliest timestamps robustly if needed
    if agg['earliest_anomaly_ts_high'].dtype == object:
        # recompute using group-specific filtering
        e_high = trace_win[trace_win['is_high']].groupby(['cmdb_id','trace_name'])['timestamp'].min().reset_index(name='earliest_anomaly_ts_high')
        e_low = trace_win[trace_win['is_low']].groupby(['cmdb_id','trace_name'])['timestamp'].min().reset_index(name='earliest_anomaly_ts_low')
        agg = agg.drop(columns=['earliest_anomaly_ts_high','earliest_anomaly_ts_low'])
        agg = agg.merge(e_high, on=['cmdb_id','trace_name'], how='left')
        agg = agg.merge(e_low, on=['cmdb_id','trace_name'], how='left')

    # ensure numeric types
    agg['anomalies_count_high'] = agg['anomalies_count_high'].astype(int)
    agg['anomalies_count_low'] = agg['anomalies_count_low'].astype(int)
    agg['count_in_window'] = agg['count_in_window'].astype(int)

    # 4) Compute severities
    def compute_sev_high(row):
        p95v = row['p95']
        if pd.isna(p95v) or p95v == 0:
            return pd.NA
        return row['max_value_in_window'] / p95v

    def compute_sev_low(row):
        p5v = row['p5']
        if pd.isna(p5v) or p5v == 0:
            return pd.NA
        minv = row['min_value_in_window']
        # guard divide by zero or NaN
        if pd.isna(minv) or minv == 0:
            return pd.NA
        return p5v / minv

    # rename min_value column in agg to min_value_in_window
    if 'min_value_in_window' not in agg.columns and 'min_value_in_window' in agg.columns:
        pass
    # ensure column exists
    if 'min_value_in_window' not in agg.columns:
        # if previous agg used 'min_value_in_window' name, ensure it's present; else create from trace_win grouping
