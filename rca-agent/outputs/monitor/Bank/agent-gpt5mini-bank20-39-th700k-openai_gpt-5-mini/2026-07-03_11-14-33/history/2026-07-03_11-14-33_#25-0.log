if 'ts' not in metric_df.columns:
    metric_df['ts'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    metric_df['ts'] = pd.to_datetime(metric_df['ts']).dt.tz_convert(tz)

if 'ts' not in trace_df.columns:
