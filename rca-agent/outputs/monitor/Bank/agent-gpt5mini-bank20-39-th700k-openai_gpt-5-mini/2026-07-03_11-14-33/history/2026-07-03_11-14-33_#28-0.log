        lambda t: pd.to_datetime(int(t), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
    )

# Normalize numeric columns
anomalies_agg['threshold_used'] = pd.to_numeric(anomalies_agg['threshold_used'], errors='coerce')
