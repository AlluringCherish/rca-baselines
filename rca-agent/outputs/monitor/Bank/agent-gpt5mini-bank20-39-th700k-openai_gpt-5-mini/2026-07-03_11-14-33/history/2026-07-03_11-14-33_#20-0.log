import pandas as pd
import pytz

# Reuse metric_df if available, else load
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')

tz = pytz.timezone('Asia/Shanghai')  # UTC+8 as required

# Parameters / filters
cmdb_target = 'IG01'
substr_patterns = ['JVM','JVM-Memory','JVM-Threads','OSLinux-CPU','MEMORY']
# Build regex for case-sensitive matching (as-is)
regex_pat = '(' + '|'.join(substr_patterns) + ')'

start_ts = 1615274640
end_ts   = 1615274760

# Filter rows for IG01 and matching kpi_name, then time window
ig_df = metric_df[
    (metric_df['cmdb_id'] == cmdb_target) &
    (metric_df['kpi_name'].str.contains(regex_pat, regex=True, na=False)) &
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts)
].copy()

# Select requested columns and sort
ig_rows = ig_df[['timestamp','cmdb_id','kpi_name','value']].sort_values('timestamp', ascending=True).head(50).reset_index(drop=True)

# Aggregate per kpi_name: min(value), max(value), and timestamp of max within the small window
if not ig_df.empty:
    agg_min = ig_df.groupby('kpi_name', as_index=False)['value'].min().rename(columns={'value':'min_value'})
    agg_max = ig_df.groupby('kpi_name', as_index=False)['value'].max().rename(columns={'value':'max_value'})
    # timestamp of max: locate idxmax per group
    idx_max = ig_df.groupby('kpi_name')['value'].idxmax().dropna().astype(int)
    ts_of_max = ig_df.loc[idx_max, ['kpi_name','timestamp']].set_index('kpi_name')
    agg = agg_min.merge(agg_max, on='kpi_name').merge(ts_of_max, left_on='kpi_name', right_index=True).reset_index(drop=True)
    agg = agg[['kpi_name','min_value','max_value','timestamp']].rename(columns={'timestamp':'ts_of_max'})
else:
    agg = pd.DataFrame(columns=['kpi_name','min_value','max_value','ts_of_max'])

# Display compact results: the filtered rows (<=50) and the aggregate per kpi_name
ig_rows, agg
