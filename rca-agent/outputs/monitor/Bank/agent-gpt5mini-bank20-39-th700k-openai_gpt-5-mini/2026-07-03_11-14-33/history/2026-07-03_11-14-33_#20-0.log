error_df = pd.read_csv('error_logs.csv')

# --- metric.csv aggregates ---
metric_total = metric_df.shape[0]
metric_cmdb_counts = metric_df['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count')
metric_kpi_counts = metric_df['kpi_name'].value_counts().rename_axis('kpi_name').reset_index(name='count').head(20)
metric_min_ts = metric_df['timestamp'].min() if metric_total>0 else None
metric_max_ts = metric_df['timestamp'].max() if metric_total>0 else None

# --- trace.csv aggregates ---
trace_total = trace_df.shape[0]
trace_cmdb_counts = trace_df['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count')
trace_name_counts = trace_df['trace_name'].value_counts().rename_axis('trace_name').reset_index(name='count').head(20)
trace_min_ts = trace_df['timestamp'].min() if trace_total>0 else None
trace_max_ts = trace_df['timestamp'].max() if trace_total>0 else None

# --- log.csv aggregates ---
log_total = log_df.shape[0]
log_cmdb_counts = log_df['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count')
log_name_counts = log_df['log_name'].value_counts().rename_axis('log_name').reset_index(name='count').head(20)
