import pandas as pd
import numpy as np
import pytz

# Reuse trace_df and tz if present
try:
    trace_df
except NameError:
    trace_df = pd.read_csv('trace.csv')
tz = pytz.timezone('Asia/Shanghai')

# Parameters
source_cmdbs = ['IG01','IG02','MG01','Tomcat01','Tomcat02','Tomcat03','Tomcat04','apache01','apache02']
start_ts = 1615273200
end_ts   = 1615275000

# 1) Restrict trace rows to the specified components and trace_name patterns 'trace.to_*' or 'trace.from_*'
pattern_mask = trace_df['trace_name'].str.contains(r'^trace\.(to|from)_', regex=True, na=False)
df_tr = trace_df[trace_df['cmdb_id'].isin(source_cmdbs) & pattern_mask].copy()

# 2) Compute global P95 and total count per (cmdb_id, trace_name) using full series (before window filtering)
global_stats = (
    df_tr
    .groupby(['cmdb_id','trace_name'], as_index=False)['value']
    .agg(count_total='count', p95_global=lambda x: x.quantile(0.95))
)

# 3) Filter to the incident window and compute windowed stats
window_df = df_tr[(df_tr['timestamp'] >= start_ts) & (df_tr['timestamp'] <= end_ts)].copy()

if not window_df.empty:
    # attach p95 to window rows
    window_df = window_df.merge(global_stats[['cmdb_id','trace_name','p95_global']],
                                on=['cmdb_id','trace_name'], how='left')
    window_df['exceed'] = (window_df['value'] > window_df['p95_global']).astype(int)
    window_df['ts_if_exceed'] = window_df['timestamp'].where(window_df['exceed']==1, np.nan)

    window_agg = (
        window_df
        .groupby(['cmdb_id','trace_name'], as_index=False)
        .agg(
            count_in_window=('value','count'),
            count_exceeding_in_window=('exceed','sum'),
            earliest_exceed_ts=('ts_if_exceed','min')
        )
    )
else:
    window_agg = pd.DataFrame(columns=['cmdb_id','trace_name','count_in_window','count_exceeding_in_window','earliest_exceed_ts'])

# 4) Combine global stats with window aggregates
combined = global_stats.merge(window_agg, on=['cmdb_id','trace_name'], how='left')
combined['count_in_window'] = combined['count_in_window'].fillna(0).astype(int)
combined['count_exceeding_in_window'] = combined['count_exceeding_in_window'].fillna(0).astype(int)
combined['earliest_exceed_ts'] = combined['earliest_exceed_ts'].astype('Int64')

# 5) Extract direction and target_component from trace_name (e.g., trace.to_Tomcat01....)
def parse_direction_target(name):
    # remove leading 'trace.' then take first segment before '.'
    if not isinstance(name, str):
        return pd.Series([None, None])
    core = name.split('.',1)[1] if '.' in name else name
    seg = core.split('.',1)[0]
    if seg.startswith('to_'):
        return pd.Series(['to', seg.split('_',1)[1]])
    if seg.startswith('from_'):
        return pd.Series(['from', seg.split('_',1)[1]])
    return pd.Series([None, None])

parsed = combined['trace_name'].apply(parse_direction_target)
combined[['direction','target_component']] = parsed

# 6) Prepare final table with requested columns and sorting
final_tbl = combined.rename(columns={'cmdb_id':'source_cmdb_id'})[
    ['source_cmdb_id','direction','target_component','trace_name','count_total','p95_global','count_in_window','count_exceeding_in_window','earliest_exceed_ts']
]

top50 = final_tbl.sort_values(['count_exceeding_in_window','count_in_window'], ascending=[False,False]).head(50)

# 7) Additionally return rows where count_exceeding_in_window > 0 and trace_name contains 'self.duration' or 'duration_p95'
mask_focus = (final_tbl['count_exceeding_in_window'] > 0) & (
    final_tbl['trace_name'].str.contains('self.duration', na=False) |
    final_tbl['trace_name'].str.contains('duration_p95', na=False)
)
focus_rows = final_tbl[mask_focus].sort_values(['count_exceeding_in_window','count_in_window'], ascending=[False,False]).head(20)

# Compact outputs
top50, focus_rows, final_tbl.shape[0]
