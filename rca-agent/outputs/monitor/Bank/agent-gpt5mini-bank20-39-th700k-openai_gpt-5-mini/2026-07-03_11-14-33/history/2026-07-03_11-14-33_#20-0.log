# Candidate components and their common peers
candidates = ['IG01','IG02','MG01']
peers = ['MG02','Tomcat01','Tomcat02','Tomcat03','Tomcat04','apache01','apache02']
target_components = list(dict.fromkeys(candidates + peers))  # preserve order, unique

# Filter trace rows to target components
df_t = trace_df[trace_df['cmdb_id'].isin(target_components)].copy()

# 1) Compute global P95 and total count per (cmdb_id, trace_name) using full series
global_stats_trace = (
    df_t
    .groupby(['cmdb_id','trace_name'], as_index=False)['value']
    .agg(count_total='count', p95_global=lambda x: x.quantile(0.95))
)

# 2) Convert incident window (UTC+8) to epoch timestamps and filter window
start_dt = tz.localize(datetime(2021,3,9,15,0,0))
end_dt   = tz.localize(datetime(2021,3,9,15,30,0))
start_ts = int(start_dt.timestamp())
end_ts   = int(end_dt.timestamp())

window_trace = df_t[(df_t['timestamp'] >= start_ts) & (df_t['timestamp'] <= end_ts)].copy()

if not window_trace.empty:
    # attach global p95 to window rows
    window_trace = window_trace.merge(global_stats_trace[['cmdb_id','trace_name','p95_global']],
                                      on=['cmdb_id','trace_name'], how='left')
    window_trace['exceed'] = (window_trace['value'] > window_trace['p95_global']).astype(int)
    window_trace['ts_if_exceed'] = window_trace['timestamp'].where(window_trace['exceed']==1, np.nan)

    window_agg = (
        window_trace
        .groupby(['cmdb_id','trace_name'], as_index=False)
        .agg(
            count_in_window=('value','count'),
            count_exceeding_in_window=('exceed','sum'),
            earliest_exceed_ts=('ts_if_exceed','min')
        )
    )
else:
    window_agg = pd.DataFrame(columns=['cmdb_id','trace_name','count_in_window','count_exceeding_in_window','earliest_exceed_ts'])

# 3) Combine global stats with window aggregates
combined_trace = global_stats_trace.merge(window_agg, on=['cmdb_id','trace_name'], how='left')

# Fill NaNs for counts with 0
combined_trace['count_in_window'] = combined_trace['count_in_window'].fillna(0).astype(int)
combined_trace['count_exceeding_in_window'] = combined_trace['count_exceeding_in_window'].fillna(0).astype(int)
