import pandas as pd
import numpy as np
import pytz
from datetime import datetime

# Reuse metric_df loaded earlier
tz = pytz.timezone('Asia/Shanghai')

# List of components to consider
components = ['apache01','apache02','Tomcat01','Tomcat02','Tomcat03','Tomcat04',
              'MG01','MG02','IG01','IG02','Mysql01','Mysql02','Redis01','Redis02']

# Filter metric rows to only these components (for scanning)
df_comp = metric_df[metric_df['cmdb_id'].isin(components)].copy()

# 1) Compute global P95 and total count per component-kpi using entire series (must be done BEFORE window filtering)
global_stats = (
    df_comp
    .groupby(['cmdb_id','kpi_name'], as_index=False)['value']
    .agg(count_total='count', p95_global=lambda x: x.quantile(0.95))
)

# 2) Convert incident window (UTC+8) to epoch timestamps
start_dt = tz.localize(datetime(2021,3,9,15,0,0))
end_dt   = tz.localize(datetime(2021,3,9,15,30,0))
start_ts = int(start_dt.timestamp())
end_ts   = int(end_dt.timestamp())

# Filter rows to the time window (inclusive)
window_df = df_comp[(df_comp['timestamp'] >= start_ts) & (df_comp['timestamp'] <= end_ts)].copy()

# Merge with global p95 so each row knows its group's threshold
if not window_df.empty:
    window_df = window_df.merge(global_stats[['cmdb_id','kpi_name','p95_global']],
                                on=['cmdb_id','kpi_name'], how='left')
    window_df['exceed'] = (window_df['value'] > window_df['p95_global']).astype(int)
    window_df['ts_if_exceed'] = window_df['timestamp'].where(window_df['exceed']==1, np.nan)

    window_agg = (
        window_df
        .groupby(['cmdb_id','kpi_name'], as_index=False)
        .agg(
            count_in_window=('value','count'),
            count_exceeding_in_window=('exceed','sum'),
            earliest_exceed_ts=('ts_if_exceed','min')
        )
    )
else:
    # empty window
    window_agg = pd.DataFrame(columns=['cmdb_id','kpi_name','count_in_window','count_exceeding_in_window','earliest_exceed_ts'])

# 3) Combine global stats with window aggregates (ensure all scanned pairs present)
combined = global_stats.merge(window_agg, on=['cmdb_id','kpi_name'], how='left')

# Fill NaNs for counts with 0, keep earliest_exceed_ts as NaN where none
combined['count_in_window'] = combined['count_in_window'].fillna(0).astype(int)
combined['count_exceeding_in_window'] = combined['count_exceeding_in_window'].fillna(0).astype(int)
# earliest_exceed_ts keep as float (NaN if none); convert to Int64 (nullable) for compact display
combined['earliest_exceed_ts'] = combined['earliest_exceed_ts'].astype('Int64')

# Select and rename columns as requested
result_df = combined[['cmdb_id','kpi_name','count_total','p95_global','count_in_window','count_exceeding_in_window','earliest_exceed_ts']]

# 4) Return top 20 rows sorted by count_exceeding_global_P95_in_window desc
top20 = result_df.sort_values(['count_exceeding_in_window','count_in_window'], ascending=[False,False]).head(20)

# Total distinct component-kpi pairs scanned
total_pairs = result_df.shape[0]

# Display compact outputs
top20, total_pairs, start_ts, end_ts
