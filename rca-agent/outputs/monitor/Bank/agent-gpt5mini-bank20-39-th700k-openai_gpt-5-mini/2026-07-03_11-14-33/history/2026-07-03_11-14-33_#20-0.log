error_cmdb_counts = error_df['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count')
error_sample = error_df.sort_values('timestamp')[['timestamp','cmdb_id','message']].head(10)
error_min_ts = error_df['timestamp'].min() if error_total>0 else None
error_max_ts = error_df['timestamp'].max() if error_total>0 else None

# Display compact summaries (variables only, per instructions)
