import pandas as pd
import numpy as np
import pytz

# Reuse existing DataFrames if present (log_df, error_df)
try:
    log_df
except NameError:
    log_df = pd.read_csv('log.csv')
try:
    error_df
except NameError:
    error_df = pd.read_csv('error_logs.csv')

tz = pytz.timezone('Asia/Shanghai')

# Incident window provided
start_ts = 1615273200
end_ts   = 1615275000

# Part A — log.csv (focused scan)
target_cmdbs = ['IG01','IG02','MG01','Tomcat01','Tomcat02','Tomcat03','Tomcat04','apache01','apache02']

# Filter to the target components first (global thresholds are computed on these series only)
logs_filt = log_df[log_df['cmdb_id'].isin(target_cmdbs)].copy()

# 2) Compute global P95 and total count per (cmdb_id, log_name) using full available series (no windowing)
global_logs = (
    logs_filt
    .groupby(['cmdb_id','log_name'], as_index=False)['value']
    .agg(count_total='count', p95_global=lambda x: x.quantile(0.95))
)

# 3) Filter to incident window and compute windowed stats
window_logs = logs_filt[(logs_filt['timestamp'] >= start_ts) & (logs_filt['timestamp'] <= end_ts)].copy()

if not window_logs.empty:
    # Attach global p95 to window rows
    window_logs = window_logs.merge(global_logs[['cmdb_id','log_name','p95_global']],
                                    on=['cmdb_id','log_name'], how='left')
    window_logs['exceed'] = (window_logs['value'] > window_logs['p95_global']).astype(int)
    window_logs['ts_if_exceed'] = window_logs['timestamp'].where(window_logs['exceed']==1, np.nan)

    window_agg = (
        window_logs
        .groupby(['cmdb_id','log_name'], as_index=False)
        .agg(
            count_in_window=('value','count'),
            count_exceeding_in_window=('exceed','sum'),
            earliest_exceed_ts=('ts_if_exceed','min')
        )
    )
else:
    window_agg = pd.DataFrame(columns=['cmdb_id','log_name','count_in_window','count_exceeding_in_window','earliest_exceed_ts'])

# 4) Combine global and window aggregates
combined_logs = global_logs.merge(window_agg, on=['cmdb_id','log_name'], how='left')
combined_logs['count_in_window'] = combined_logs['count_in_window'].fillna(0).astype(int)
combined_logs['count_exceeding_in_window'] = combined_logs['count_exceeding_in_window'].fillna(0).astype(int)
combined_logs['earliest_exceed_ts'] = combined_logs['earliest_exceed_ts'].astype('Int64')

# Select requested columns and sort by count_exceeding desc, then count_in_window desc
top20_logs = combined_logs[['cmdb_id','log_name','count_total','p95_global','count_in_window','count_exceeding_in_window','earliest_exceed_ts']].sort_values(
    ['count_exceeding_in_window','count_in_window'], ascending=[False,False]
).head(20)

# 5) Full time-window series for log.error_count for Tomcat01-04 and apache01-02 (limit up to 100 rows)
servers_error_series = ['Tomcat01','Tomcat02','Tomcat03','Tomcat04','apache01','apache02']
error_count_series = log_df[
    (log_df['cmdb_id'].isin(servers_error_series)) &
    (log_df['log_name']=='log.error_count') &
    (log_df['timestamp'] >= start_ts) & (log_df['timestamp'] <= end_ts)
][['timestamp','cmdb_id','value']].sort_values('timestamp').head(100).reset_index(drop=True)

# Part B — error_logs.csv (message scan)
# 1) Rows within the incident window, up to 20 rows sorted by timestamp asc
error_rows_window = error_df[
    (error_df['timestamp'] >= start_ts) & (error_df['timestamp'] <= end_ts)
][['timestamp','cmdb_id','message']].sort_values('timestamp').head(20).reset_index(drop=True)

# 2) Counts of error_logs per cmdb_id within the window (compact list)
error_counts_window = error_df[
    (error_df['timestamp'] >= start_ts) & (error_df['timestamp'] <= end_ts)
].groupby('cmdb_id', as_index=False).size().rename(columns={'size':'count'}).sort_values('count', ascending=False)

# Display compact outputs (variables only)
top20_logs, error_count_series, error_rows_window, error_counts_window, start_ts, end_ts
