import pandas as pd
import numpy as np
import pytz

# Reuse cached variables: anomalies_df_full, thresholds_df
# Ensure they exist
try:
    anomalies_df_full
    thresholds_df
except NameError as e:
    raise

# Merge anomalies with full thresholds to get p95 and p5 per group (thresholds_df contains p95 and p5)
anom = anomalies_df_full.merge(
    thresholds_df[['cmdb_id','kpi_name','p95','p5']],
    on=['cmdb_id','kpi_name'],
    how='left'
)

# Aggregate per (cmdb_id, kpi_name)
grp = anom.groupby(['cmdb_id','kpi_name'])

agg = grp.agg(
    anomaly_count = ('value','count'),
    earliest_anomaly = ('timestamp_dt','min'),
    max_value = ('value','max'),
    min_value = ('value','min'),
    max_value_high = (lambda df: df.loc[df['threshold_type']=='high','value'].max()),
    min_value_low  = (lambda df: df.loc[df['threshold_type']=='low','value'].min()),
    p95 = ('p95','first'),
    p5  = ('p5','first')
).reset_index()

# The lambdas above won't work directly in agg for named columns in older pandas; compute high/low separately
# Recompute high/low safely:
highs = anom[anom['threshold_type']=='high'].groupby(['cmdb_id','kpi_name'])['value'].max().rename('max_value_high')
lows  = anom[anom['threshold_type']=='low'].groupby(['cmdb_id','kpi_name'])['value'].min().rename('min_value_low')

agg = grp.agg(
    anomaly_count = ('value','count'),
    earliest_anomaly = ('timestamp_dt','min'),
    max_value = ('value','max'),
    min_value = ('value','min'),
    p95 = ('p95','first'),
    p5  = ('p5','first')
).reset_index()

agg = agg.merge(highs.reset_index(), on=['cmdb_id','kpi_name'], how='left')
agg = agg.merge(lows.reset_index(), on=['cmdb_id','kpi_name'], how='left')

# Compute breach ratios
def compute_breach_row(r):
    # high breach
    bh = np.nan
    bl = np.nan
    zero_flag = False
    chosen_type = None
    chosen_threshold = np.nan

    # high case
    if not pd.isna(r['max_value_high']):
        if r['p95'] == 0 or pd.isna(r['p95']):
            bh = abs(r['max_value_high'])
        else:
            bh = (r['max_value_high'] - r['p95']) / abs(r['p95'])
    # low case
    if not pd.isna(r['min_value_low']):
        if r['p5'] == 0 or pd.isna(r['p5']):
            bl = abs(r['min_value_low'])
        else:
            bl = (r['p5'] - r['min_value_low']) / abs(r['p5'])

    # Replace negative or NaN with -inf to ignore
    bh_val = bh if (not pd.isna(bh)) else -np.inf
    bl_val = bl if (not pd.isna(bl)) else -np.inf

    if bh_val >= bl_val:
        breach_ratio = bh_val if bh_val != -np.inf else 0.0
        chosen_type = 'high'
        chosen_threshold = r['p95']
    else:
        breach_ratio = bl_val if bl_val != -np.inf else 0.0
        chosen_type = 'low'
        chosen_threshold = r['p5']

    zero_flag = (chosen_threshold == 0) or pd.isna(chosen_threshold) and (breach_ratio != 0)
    # ensure finite
    if not np.isfinite(breach_ratio):
        breach_ratio = 0.0

    return pd.Series({
        'threshold_type': chosen_type,
        'threshold_value': chosen_threshold,
        'breach_ratio': breach_ratio,
        'zero_threshold_flag': bool(zero_flag)
    })

breach_cols = agg.apply(compute_breach_row, axis=1)
faults_by_kpi = pd.concat([agg, breach_cols], axis=1)

# Keep and format required columns
faults_by_kpi = faults_by_kpi.assign(
    earliest_anomaly = pd.to_datetime(faults_by_kpi['earliest_anomaly'])
)

faults_by_kpi = faults_by_kpi[[
    'cmdb_id','kpi_name','anomaly_count','earliest_anomaly',
    'max_value','threshold_value','breach_ratio','zero_threshold_flag'
]]

# Sort by breach_ratio desc and limit top 20 for display
faults_by_kpi_display = faults_by_kpi.sort_values('breach_ratio', ascending=False).head(20)

# 2) Per-cmdb_id summary
# For each component, sum anomaly_count, find top kpi by breach, top breach ratio, earliest anomaly among its KPIs
comp_grp = faults_by_kpi.groupby('cmdb_id')

def top_kpi_info(df):
    # df is subset for a component
    top = df.sort_values('breach_ratio', ascending=False).iloc[0]
    return pd.Series({
        'top_kpi_by_breach': top['kpi_name'],
        'top_breach_ratio': top['breach_ratio'],
        'earliest_anomaly': df['earliest_anomaly'].min()
    })

comp_agg = comp_grp['anomaly_count'].sum().reset_index().rename(columns={'anomaly_count':'total_anomaly_points'})
comp_top = faults_by_kpi.groupby('cmdb_id').apply(top_kpi_info).reset_index()

faults_by_component = comp_agg.merge(comp_top, on='cmdb_id')
faults_by_component = faults_by_component.sort_values('total_anomaly_points', ascending=False).head(20)

# Final compact outputs (stored full tables in variables faults_by_kpi and faults_by_component)
# Display only the compact top-20 KPI-level and top-20 component-level tables
faults_by_kpi_display, faults_by_component
