import pandas as pd
import pytz
import numpy as np

# reuse metric_df and tz_sh from kernel if available; otherwise redefine
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')
    metric_df['value'] = pd.to_numeric(metric_df['value'], errors='coerce')
    tz_sh = pytz.timezone('Asia/Shanghai')
    metric_df['datetime'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True).dt.tz_convert(tz_sh)

# Ensure datetime column and numeric value
metric_df['value'] = pd.to_numeric(metric_df['value'], errors='coerce')
if 'datetime' not in metric_df.columns:
    tz_sh = pytz.timezone('Asia/Shanghai')
    metric_df['datetime'] = pd.to_datetime(metric_df['timestamp'], unit='s', utc=True).dt.tz_convert(tz_sh)
else:
    tz_sh = pytz.timezone('Asia/Shanghai')

# Incident window (inclusive) in UTC+8
start = pd.Timestamp('2021-03-06 23:30:00', tz=tz_sh)
end = pd.Timestamp('2021-03-06 23:59:00', tz=tz_sh)

# Precompute global thresholds for each (cmdb_id, kpi_name) for P95 and P90 using full series
thresholds_p95 = metric_df.groupby(['cmdb_id', 'kpi_name'])['value'].quantile(0.95).reset_index().rename(columns={'value':'global_threshold'})
thresholds_p95['quantile'] = 0.95

thresholds_p90 = metric_df.groupby(['cmdb_id', 'kpi_name'])['value'].quantile(0.90).reset_index().rename(columns={'value':'global_threshold'})
thresholds_p90['quantile'] = 0.90

# Filter metric to incident window (store full window table)
window_df = metric_df[(metric_df['datetime'] >= start) & (metric_df['datetime'] <= end)].copy()

# Function to compute anomaly summary given thresholds df
def compute_anomalies(thresholds_df):
    # Merge thresholds into window data
    merged = window_df.merge(thresholds_df, on=['cmdb_id','kpi_name'], how='left')
    # Mark anomaly when value >= global_threshold (higher-is-worse)
    merged['is_anom'] = merged['value'] >= merged['global_threshold']
    # Aggregate per group
    agg = merged.groupby(['cmdb_id','kpi_name']).agg(
        total_window_points = ('value','count'),
        anomaly_count = ('is_anom','sum'),
        earliest_anomaly_ts = (lambda d: merged.loc[d.index][merged.loc[d.index,'is_anom']==True,'datetime'].min() if True else pd.NaT),
        max_value_in_window = ('value','max'),
        global_threshold = ('global_threshold','first')
    ).reset_index()
    # The above earliest_anomaly_ts lambda is a placeholder; compute properly:
    # Compute earliest_anomaly_ts by group
    ea = merged[merged['is_anom']].groupby(['cmdb_id','kpi_name'])['datetime'].min().reset_index().rename(columns={'datetime':'earliest_anomaly_ts'})
    agg = agg.drop(columns=['earliest_anomaly_ts'])
    agg = agg.merge(ea, on=['cmdb_id','kpi_name'], how='left')
    # pct_over: handle zero or NaN threshold
    agg['pct_over'] = np.where(
        (agg['global_threshold'].isna()) | (agg['global_threshold']==0),
        np.nan,
        100.0*(agg['max_value_in_window'] - agg['global_threshold'])/agg['global_threshold']
    )
    # Keep types tidy
    agg['earliest_anomaly_ts'] = pd.to_datetime(agg['earliest_anomaly_ts'])
    return merged, agg

# First try with P95
merged_p95, agg_p95 = compute_anomalies(thresholds_p95)
# Filter to groups that actually appear in window (total_window_points>0)
agg_p95 = agg_p95[agg_p95['total_window_points']>0].copy()
# Keep only groups with anomaly_count>0
agg_p95_anom = agg_p95[agg_p95['anomaly_count']>0].copy()

threshold_used = 'P95'
result_df = agg_p95_anom

# If no anomalies found, relax to P90
if result_df.shape[0] == 0:
    merged_p90, agg_p90 = compute_anomalies(thresholds_p90)
    agg_p90 = agg_p90[agg_p90['total_window_points']>0].copy()
    agg_p90_anom = agg_p90[agg_p90['anomaly_count']>0].copy()
    threshold_used = 'P90'
    result_df = agg_p90_anom
    # Also keep merged/agg variables
    merged_used = merged_p90
    agg_used = agg_p90
else:
    merged_used = merged_p95
    agg_used = agg_p95

# Prepare final compact table: sort by anomaly_count desc, limit top 20, format columns
if result_df.shape[0] > 0:
    final = result_df.copy()
    final = final.sort_values(['anomaly_count','max_value_in_window'], ascending=[False, False])
    # Format earliest_anomaly_ts to timezone-aware string in UTC+8 (if not NaT)
    final['earliest_anomaly_ts'] = final['earliest_anomaly_ts'].dt.tz_convert(tz_sh)
    # Select and order columns
    final_table = final[['cmdb_id','kpi_name','total_window_points','anomaly_count','earliest_anomaly_ts','max_value_in_window','global_threshold','pct_over']].head(20)
else:
    # empty DataFrame with desired columns
    final_table = pd.DataFrame(columns=['cmdb_id','kpi_name','total_window_points','anomaly_count','earliest_anomaly_ts','max_value_in_window','global_threshold','pct_over'])

# Summary line
num_distinct = final_table.shape[0]
summary_line = f"{num_distinct} distinct (cmdb_id, kpi_name) anomalies found using {threshold_used} threshold."

# Return compact table and summary
final_table, summary_line
