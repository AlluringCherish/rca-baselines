    ser = pd.to_datetime(anomalies['earliest_anomaly_ts'])
    try:
        ser = ser.dt.tz_convert(tz_sh)
    except Exception:
        # likely naive timestamps -> localize then convert
        ser = ser.dt.tz_localize(tz_sh)
    anomalies['earliest_anomaly_ts'] = ser

