    series_with_anomaly = ('kpi_name', 'nunique'),
    total_anomalies = ('anomalies_count', 'sum'),
    earliest_anomaly_timestamp = ('earliest_anomaly_timestamp', 'min'),
    max_breach_ratio = ('max_breach_ratio', 'max')
)

