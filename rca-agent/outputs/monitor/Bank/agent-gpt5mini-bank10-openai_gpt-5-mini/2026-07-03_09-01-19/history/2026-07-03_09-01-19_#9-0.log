import pandas as pd
import numpy as np
import pytz

# Reuse kernel variables: metric_anomalies, metric_thresholds, metric_window, component_anomaly_summary_top10
tz = pytz.timezone('Asia/Shanghai')

# Ensure needed variables exist
ma = metric_anomalies.copy()
mt = metric_thresholds.copy()
mw = metric_window.copy()
top_components = component_anomaly_summary_top10['cmdb_id'].tolist()

# Normalize numeric severity and parse earliest timestamps for accurate computations
ma['_severity'] = pd.to_numeric(ma['severity_ratio'], errors='coerce')
ma['_earliest_dt'] = pd.to_datetime(ma['earliest_anomaly_timestamp'], errors='coerce', utc=True).dt.tz_convert(tz)

# Compute max_value per (cmdb_id,kpi_name) from metric_window (required)
max_vals = mw.groupby(['cmdb_id','kpi_name'], dropna=False)['value'].max().reset_index().rename(columns={'value':'max_value'})

# Prepare p95 from metric_thresholds (already global)
p95_df = mt.rename(columns={'kpi_name':'kpi_name','p95':'p95'})

# Merge ma (which has anomaly stats) with p95 and max_value to ensure values present
ma_enriched = (
    ma
    .merge(p95_df, on=['cmdb_id','kpi_name'], how='left')
    .merge(max_vals, on=['cmdb_id','kpi_name'], how='left')
)

# Focus on top components and only KPIs with anomaly_count > 0 (they are the relevant anomalies)
ma_topcomps = ma_enriched[(ma_enriched['cmdb_id'].isin(top_components)) & (ma_enriched['anomaly_count'] > 0)].copy()

# For ordering: treat missing severity as very small so they appear last
ma_topcomps['_severity_for_sort'] = ma_topcomps['_severity'].fillna(-9999999)

# For each component, select up to top 5 KPI rows ordered by severity_ratio desc then anomaly_count desc
kpi_rows = []
component_rows = []
for comp in top_components:
    comp_df = ma_topcomps[ma_topcomps['cmdb_id']==comp].copy()
    if comp_df.shape[0]==0:
        continue
    comp_df_sorted = comp_df.sort_values(by=['_severity_for_sort','anomaly_count'], ascending=[False, False])
    topk = comp_df_sorted.head(5).copy()
    # Format earliest timestamp strings (keep existing string if present, else NA)
    topk['earliest_anomaly_timestamp'] = topk['earliest_anomaly_timestamp'].where(topk['earliest_anomaly_timestamp'].notna(), pd.NA)
    # Select requested columns and ensure ordering
    topk_out = topk[['cmdb_id','kpi_name','anomaly_count','total_points','earliest_anomaly_timestamp','severity_ratio','p95','max_value']].copy()
    kpi_rows.append(topk_out)
    # Component-level summary: earliest anomaly timestamp and KPI that produced max severity
    comp_earliest_dt = comp_df['_earliest_dt'].min()
    comp_earliest_str = pd.to_datetime(comp_earliest_dt).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z') if pd.notna(comp_earliest_dt) else pd.NA
    # KPI producing max severity: use original severity (not fill) and pick first if tie
    comp_max_idx = comp_df.sort_values(by=['_severity_for_sort','anomaly_count'], ascending=[False, False]).head(1).index[0]
    comp_max_kpi = comp_df.loc[comp_max_idx, 'kpi_name']
    comp_max_sev = comp_df.loc[comp_max_idx, '_severity']
    component_rows.append({
        'cmdb_id': comp,
        'component_earliest_anomaly_timestamp': comp_earliest_str,
        'kpi_with_max_severity': comp_max_kpi,
        'component_max_severity_ratio': comp_max_sev
    })

# Concatenate KPI rows into single DataFrame (limit total rows to at most 50)
if kpi_rows:
    kpi_report_df = pd.concat(kpi_rows, ignore_index=True)
    kpi_report_df = kpi_report_df.head(50)
else:
    kpi_report_df = pd.DataFrame(columns=['cmdb_id','kpi_name','anomaly_count','total_points','earliest_anomaly_timestamp','severity_ratio','p95','max_value'])

component_kpi_summary = pd.DataFrame(component_rows)

# Compute the earliest anomaly timestamp among all top-10 components
if component_kpi_summary['component_earliest_anomaly_timestamp'].dropna().empty:
    global_earliest_ts = pd.NA
else:
    # parse timestamps back to datetime to compute min
    all_dt = pd.to_datetime(component_kpi_summary['component_earliest_anomaly_timestamp'], utc=True).dt.tz_convert(tz)
    global_earliest_ts = pd.to_datetime(all_dt.min()).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z')

# Store results in kernel variables requested by the user
component_kpi_report = kpi_report_df
component_level_summary = component_kpi_summary
earliest_among_top10_components = global_earliest_ts

# Return compact results (variables) for Controller consumption
component_kpi_report, component_level_summary, earliest_among_top10_components
