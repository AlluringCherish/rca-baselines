import pandas as pd
import numpy as np
import pytz

# Reuse existing kernel variables: metric_anomalies, metric_thresholds, metric_window, component_anomaly_summary_top10
tz = pytz.timezone('Asia/Shanghai')

# 1) component list in order from component_anomaly_summary_top10
comp_list = component_anomaly_summary_top10['cmdb_id'].tolist()

# 2) KPI rows for these components from metric_anomalies
ma = metric_anomalies.copy()
ma_sub = ma[ma['cmdb_id'].isin(comp_list)].copy()

# 3) Join p95 from metric_thresholds (ensure column names align) and compute max_value from metric_window
# Ensure metric_thresholds has expected columns
mt = metric_thresholds.copy()

# Compute max_value per (cmdb_id,kpi_name) in metric_window
mw = metric_window.copy()
group_max = mw.groupby(['cmdb_id','kpi_name'], dropna=False)['value'].max().reset_index().rename(columns={'value':'max_value'})

# Merge p95 and max_value into KPI rows
comp_kpi = (
    ma_sub
    .merge(mt, how='left', on=['cmdb_id','kpi_name'])
    .merge(group_max, how='left', on=['cmdb_id','kpi_name'])
)

# 4) Compute severity_ratio = max_value / p95 (null if p95 <= 0 or missing)
def compute_severity(row):
    p95 = row.get('p95')
    maxv = row.get('max_value')
    try:
        if pd.isna(p95) or p95 == 0:
            return pd.NA
        return float(maxv) / float(p95)
    except Exception:
        return pd.NA

comp_kpi['severity_ratio_computed'] = comp_kpi.apply(compute_severity, axis=1)

# Use anomaly_count and total_points from metric_anomalies (ensure numeric)
comp_kpi['anomaly_count'] = pd.to_numeric(comp_kpi['anomaly_count'], errors='coerce').fillna(0).astype(int)
comp_kpi['total_points'] = pd.to_numeric(comp_kpi['total_points'], errors='coerce').fillna(0).astype(int)

# 5) Sort KPI rows per component by severity_ratio (desc, treat <NA> as smallest) then anomaly_count (desc)
# For sorting, replace NA with -inf so they go to the end when sorting descending
comp_kpi['_severity_sort'] = comp_kpi['severity_ratio_computed'].apply(lambda x: -np.inf if pd.isna(x) else x)
comp_kpi_sorted = comp_kpi.sort_values(by=['cmdb_id','_severity_sort','anomaly_count'], ascending=[True, False, False])

# For each component, take up to top 5 KPI rows in the original component order
rows = []
for comp in comp_list:
    sub = comp_kpi_sorted[comp_kpi_sorted['cmdb_id'] == comp].copy()
    if sub.shape[0] == 0:
        continue
    topk = sub.head(5)
    rows.append(topk)

if rows:
    component_kpi_severity = pd.concat(rows, ignore_index=True)
else:
    component_kpi_severity = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','anomaly_count','total_points','earliest_anomaly_timestamp',
        'severity_ratio_computed','p95','max_value'
    ])

# 6) Limit total returned rows to at most 50
component_kpi_severity = component_kpi_severity.head(50).copy()

# Select and rename final columns as requested
component_kpi_severity = component_kpi_severity[[
    'cmdb_id',
    'kpi_name',
    'anomaly_count',
    'total_points',
    'earliest_anomaly_timestamp',
    'severity_ratio_computed',
    'p95',
    'max_value'
]].rename(columns={'severity_ratio_computed':'severity_ratio'})

# Keep output compact: display the table (CSV-like rows)
component_kpi_severity
