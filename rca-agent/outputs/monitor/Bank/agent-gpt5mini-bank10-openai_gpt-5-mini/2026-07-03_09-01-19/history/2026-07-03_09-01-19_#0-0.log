            kpi_short = (kpi[:100] + '...') if isinstance(kpi, str) and len(kpi) > 100 else str(kpi)
            kpi_lines.append(f"- {kpi_short} | p95={p95:.6g} | anomalies={ac} | {est_str}–{let_str} | max={maxv:.6g} | severity={sev_str}")

    lines = [
