    'unique_cmdb_top20': trace_top_cmdb,
    'unique_trace_name_top20': trace_name_counts,
    'min_timestamp_unix_and_local': (trace_min, trace_min_local),
    'max_timestamp_unix_and_local': (trace_max, trace_max_local),
