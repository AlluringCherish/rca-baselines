import pandas as pd
import numpy as np
import pytz

# reuse existing df_metric and tz if present; otherwise load/define
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

tz = pytz.timezone('Asia/Shanghai')

# Ensure numeric columns
df_metric['timestamp'] = pd.to_numeric(df_metric['timestamp'], errors='coerce')
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

# Target KPIs and allowed components
kpis = ['app.sr','app.rr','app.mrt','app.cnt']
allowed = ['apache01','apache02','Tomcat01','Tomcat02','Tomcat03','Tomcat04',
           'MG01','MG02','IG01','IG02','Mysql01','Mysql02','Redis01','Redis02']

