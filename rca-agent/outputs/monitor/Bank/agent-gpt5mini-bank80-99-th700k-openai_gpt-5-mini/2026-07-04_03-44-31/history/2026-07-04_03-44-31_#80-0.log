# Function to evaluate breaches per source
def evaluate_breaches(window_df, thr_df, source_name):
    df = window_df.merge(thr_df, on=['cmdb_id','kpi'], how='left')
    if df.empty:
        return pd.DataFrame(columns=['cmdb_id','kpi','source','timestamp','value','P95','P5','is_high','is_low','breach_ratio'])
    df['value'] = pd.to_numeric(df['value'], errors='coerce')
    df = df.dropna(subset=['value'])
