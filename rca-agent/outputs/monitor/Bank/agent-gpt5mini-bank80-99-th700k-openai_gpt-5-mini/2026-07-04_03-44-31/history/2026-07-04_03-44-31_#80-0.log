    if ts is None:
        return 'null'
    return datetime.fromtimestamp(int(ts), tz).strftime('%Y-%m-%d %H:%M:%S%z')

def short(s, n=80):
    s = str(s)
    return s if len(s)<=n else s[:n-3]+'...'

# Counts
