    # max breach ratio per component (ignore NaN)
    max_ratio_per_comp = all_breaches.groupby('cmdb_id')['breach_ratio'].max().rename('max_breach_ratio_across_sources_in_window')

    # Find earliest breach row per component (if multiple, pick highest breach_ratio among earliest timestamp rows)
    earliest_rows = []
    for comp, sub in all_breaches.groupby('cmdb_id'):
        # minimal timestamp
        min_ts = int(sub['timestamp'].min())
        # filter rows at min_ts
        earliest_sub = sub[sub['timestamp'] == min_ts].copy()
        # pick row with max breach_ratio among them
