except NameError:
    start_ts = 1615271400
    end_ts = 1615273200

# Ensure thresholds for each source are available (compute fallback if necessary)
def get_metric_thresholds():
    if 'metric_thr' in globals():
        return metric_thr[['cmdb_id','kpi','P95','P5']].copy()
    if 'thresholds_df' in globals():
        df = thresholds_df.copy()
        # thresholds_df uses kpi_name column
        if 'kpi_name' in df.columns:
            return df.rename(columns={'kpi_name':'kpi'})[['cmdb_id','kpi','P95','P5']].copy()
    # fallback compute
    m = metric_df.copy()
    m = m.dropna(subset=['value'])
    q = m.groupby(['cmdb_id','kpi_name'])['value'].quantile([0.95,0.05]).unstack(level=-1).rename(columns={0.95:'P95',0.05:'P5'})
    return q.reset_index().rename(columns={'kpi_name':'kpi'})[['cmdb_id','kpi','P95','P5']]

def get_trace_thresholds():
    if 'trace_thresholds' in globals():
        df = trace_thresholds.copy()
        if 'trace_name' in df.columns:
            return df.rename(columns={'trace_name':'kpi'})[['cmdb_id','kpi','P95','P5']].copy()
    # fallback compute
    t = trace_df.copy()
    t = t.dropna(subset=['value'])
    q = t.groupby(['cmdb_id','trace_name'])['value'].quantile([0.95,0.05]).unstack(level=-1).rename(columns={0.95:'P95',0.05:'P5'})
    return q.reset_index().rename(columns={'trace_name':'kpi'})[['cmdb_id','kpi','P95','P5']]

def get_log_thresholds():
    if 'thresholds_log_df' in globals():
        df = thresholds_log_df.copy()
        if 'log_name' in df.columns:
            return df.rename(columns={'log_name':'kpi'})[['cmdb_id','kpi','P95','P5']].copy()
    if 'thresholds_log_top50' in globals():
        df = thresholds_log_top50.copy()
        if 'log_name' in df.columns:
            return df.rename(columns={'log_name':'kpi'})[['cmdb_id','kpi','P95','P5']].copy()
    # fallback compute
    l = log_df.copy()
    l = l.dropna(subset=['value'])
    q = l.groupby(['cmdb_id','log_name'])['value'].quantile([0.95,0.05]).unstack(level=-1).rename(columns={0.95:'P95',0.05:'P5'})
    return q.reset_index().rename(columns={'log_name':'kpi'})[['cmdb_id','kpi','P95','P5']]

metric_thr_df = get_metric_thresholds()
trace_thr_df  = get_trace_thresholds()
log_thr_df    = get_log_thresholds()

# Build windowed dataframes and normalize KPI column to 'kpi'
metric_window = metric_df[(metric_df['timestamp'] >= int(start_ts)) & (metric_df['timestamp'] <= int(end_ts))].copy()
trace_window  = trace_df[(trace_df['timestamp']  >= int(start_ts)) & (trace_df['timestamp']  <= int(end_ts))].copy()
log_window    = log_df[(log_df['timestamp']    >= int(start_ts)) & (log_df['timestamp']    <= int(end_ts))].copy()

metric_window = metric_window.rename(columns={'kpi_name':'kpi'})[['timestamp','cmdb_id','kpi','value']]
trace_window  = trace_window.rename(columns={'trace_name':'kpi'})[['timestamp','cmdb_id','kpi','value']]
log_window    = log_window.rename(columns={'log_name':'kpi'})[['timestamp','cmdb_id','kpi','value']]

# Helper to compute per-row breach flags and breach_ratio safely
def evaluate_breaches(window_df, thr_df, source_name):
    # Merge thresholds
    df = window_df.merge(thr_df, on=['cmdb_id','kpi'], how='left')
    if df.empty:
        return pd.DataFrame(columns=[
            'cmdb_id','kpi','source','timestamp','value','P95','P5','is_high','is_low','is_breach','breach_ratio'
        ])
    # Ensure numeric
    df['value'] = pd.to_numeric(df['value'], errors='coerce')
    # compute flags
    df['is_high'] = df['value'] >= df['P95']
    df['is_low']  = df['value'] <= df['P5']
    df['is_breach'] = df['is_high'] | df['is_low']
    # compute breach_ratio safely (for high breaches; for low breaches ratio could be negative; requirement uses (value-P95)/P95)
    def safe_ratio(row):
        P95 = row['P95']
        val = row['value']
        if pd.isna(P95) or P95 == 0:
            return float('inf') if val > 0 else 0.0
        else:
            return (val - P95) / P95
    df['breach_ratio'] = df.apply(lambda r: safe_ratio(r) if r['is_breach'] else np.nan, axis=1)
    df['source'] = source_name
    return df[df['is_breach']].copy()

# Evaluate breaches per source for components of interest
metric_breached_rows = evaluate_breaches(metric_window[metric_window['cmdb_id'].isin(components)], metric_thr_df, 'metric')
trace_breached_rows  = evaluate_breaches(trace_window[trace_window['cmdb_id'].isin(components)], trace_thr_df,  'trace')
log_breached_rows    = evaluate_breaches(log_window[log_window['cmdb_id'].isin(components)], log_thr_df,    'log')

