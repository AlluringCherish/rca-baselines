            'earliest_breach_source': earliest_row['source'],
            'earliest_breach_kpi': earliest_row['kpi'],
            'value_at_earliest_breach': float(earliest_row['value']),
            'global_P95_for_that_kpi': earliest_row['P95'],
            'breach_type': 'high' if earliest_row['is_high'] else 'low',
            'max_breach_ratio_across_sources_in_window': max_ratio if np.isfinite(max_ratio) else float('inf'),
            'count_distinct_sources_with_breaches_in_window': distinct_sources,
            'total_breach_points_in_window': total_breaches
        })

per_component_summary = pd.DataFrame(rows)

# Sort as requested: earliest_breach_ts ascending (None last) then max_breach_ratio desc
per_component_summary['earliest_sort'] = per_component_summary['earliest_breach_ts'].apply(lambda x: x if x is not None else 10**18)
per_component_summary = per_component_summary.sort_values(by=['earliest_sort','max_breach_ratio_across_sources_in_window'],
                                                        ascending=[True, False]).drop(columns=['earliest_sort']).reset_index(drop=True)

# Earliest overall breach and which component/source it belongs to
filled = per_component_summary[per_component_summary['earliest_breach_ts'].notna()]
if not filled.empty:
    earliest_row = filled.iloc[0]
    earliest_overall = {
        'earliest_breach_ts': int(earliest_row['earliest_breach_ts']),
        'component': earliest_row['cmdb_id'],
        'source': earliest_row['earliest_breach_source'],
        'kpi': earliest_row['earliest_breach_kpi']
    }
else:
    earliest_overall = None

# Final compact outputs (one row per component)
per_component_summary, earliest_overall
