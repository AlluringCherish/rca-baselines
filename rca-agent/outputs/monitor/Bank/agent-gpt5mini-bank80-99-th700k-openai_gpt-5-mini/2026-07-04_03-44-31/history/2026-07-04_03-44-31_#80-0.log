import pandas as pd
import numpy as np
import pytz

# Reuse cached dataframes where available
# metric_df, trace_df, log_df, start_ts, end_ts, and threshold tables may exist from prior steps.

# Components to summarize: prefer cached component_set_used or comp_set, else use provided list
