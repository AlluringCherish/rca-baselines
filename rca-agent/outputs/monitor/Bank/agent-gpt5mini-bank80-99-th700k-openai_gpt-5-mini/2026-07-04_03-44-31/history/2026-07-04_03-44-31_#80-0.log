import pandas as pd
import numpy as np
import pytz

# Reuse cached dataframes if present; otherwise load
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')
try:
    trace_df
except NameError:
    trace_df = pd.read_csv('trace.csv')
try:
    log_df
except NameError:
    log_df = pd.read_csv('log.csv')

# Reuse incident window timestamps
try:
    start_ts, end_ts
except NameError:
    start_ts = 1615271400
    end_ts = 1615273200

# Component list requested
components = ["IG01","IG02","Tomcat03","Tomcat04","Mysql02"]

# Ensure numeric types
metric_df['timestamp'] = metric_df['timestamp'].astype(int)
trace_df['timestamp'] = trace_df['timestamp'].astype(int)
log_df['timestamp'] = log_df['timestamp'].astype(int)
metric_df['value'] = pd.to_numeric(metric_df['value'], errors='coerce')
trace_df['value'] = pd.to_numeric(trace_df['value'], errors='coerce')
log_df['value'] = pd.to_numeric(log_df['value'], errors='coerce')

# Helper to compute or reuse thresholds for a source
def get_metric_thresholds():
    if 'thresholds_df' in globals():
        thr = thresholds_df.copy()
        # thresholds_df uses columns cmdb_id,kpi_name,P95,P5,...
        return thr[['cmdb_id','kpi_name','P95','P5']].rename(columns={'kpi_name':'kpi'})
    # compute on full series
    m = metric_df.dropna(subset=['value'])
    q = m.groupby(['cmdb_id','kpi_name'])['value'].quantile([0.95,0.05]).unstack(level=-1).rename(columns={0.95:'P95',0.05:'P5'})
    thr = q.reset_index()[['cmdb_id','kpi_name','P95','P5']].rename(columns={'kpi_name':'kpi'})
    return thr

def get_trace_thresholds():
    if 'trace_thresholds' in globals():
        thr = trace_thresholds.copy()
        return thr[['cmdb_id','trace_name','P95','P5']].rename(columns={'trace_name':'kpi'})
    t = trace_df.dropna(subset=['value'])
    q = t.groupby(['cmdb_id','trace_name'])['value'].quantile([0.95,0.05]).unstack(level=-1).rename(columns={0.95:'P95',0.05:'P5'})
    thr = q.reset_index()[['cmdb_id','trace_name','P95','P5']].rename(columns={'trace_name':'kpi'})
    return thr

def get_log_thresholds():
    if 'thresholds_log_df' in globals():
        thr = thresholds_log_df.copy()
        return thr[['cmdb_id','log_name','P95','P5']].rename(columns={'log_name':'kpi'})
    l = log_df.dropna(subset=['value'])
    q = l.groupby(['cmdb_id','log_name'])['value'].quantile([0.95,0.05]).unstack(level=-1).rename(columns={0.95:'P95',0.05:'P5'})
    thr = q.reset_index()[['cmdb_id','log_name','P95','P5']].rename(columns={'log_name':'kpi'})
    return thr

metric_thr = get_metric_thresholds()
trace_thr  = get_trace_thresholds()
log_thr    = get_log_thresholds()

# Prepare windowed data for each source and normalize kpi column name
metric_window = metric_df[(metric_df['timestamp'] >= int(start_ts)) & (metric_df['timestamp'] <= int(end_ts))].copy()
metric_window = metric_window.rename(columns={'kpi_name':'kpi'})[['timestamp','cmdb_id','kpi','value']]

trace_window = trace_df[(trace_df['timestamp'] >= int(start_ts)) & (trace_df['timestamp'] <= int(end_ts))].copy()
trace_window = trace_window.rename(columns={'trace_name':'kpi'})[['timestamp','cmdb_id','kpi','value']]

log_window = log_df[(log_df['timestamp'] >= int(start_ts)) & (log_df['timestamp'] <= int(end_ts))].copy()
log_window = log_window.rename(columns={'log_name':'kpi'})[['timestamp','cmdb_id','kpi','value']]

# Function to extract breaches per source for the specified components
def extract_breaches(window_df, thr_df, source_name):
    # restrict to requested components
    thr_sub = thr_df[thr_df['cmdb_id'].isin(components)].copy()
    # join window rows with thresholds
    merged = window_df.merge(thr_sub, on=['cmdb_id','kpi'], how='left')
    # Keep only rows for our components
    merged = merged[merged['cmdb_id'].isin(components)].copy()
    if merged.empty:
        return pd.DataFrame(columns=[
            'cmdb_id','kpi','source','timestamp','value','P95','P5','breach_type'
        ])
    # Determine breach conditions, handling NaNs safely
    merged['is_high'] = merged.apply(lambda r: False if pd.isna(r['P95']) else (r['value'] >= r['P95']), axis=1)
    merged['is_low']  = merged.apply(lambda r: False if pd.isna(r['P5'])  else (r['value'] <= r['P5']), axis=1)
    merged['is_breach'] = merged['is_high'] | merged['is_low']
    breaches = merged[merged['is_breach']].copy()
    if breaches.empty:
        return pd.DataFrame(columns=[
            'cmdb_id','kpi','source','timestamp','value','P95','P5','breach_type'
        ])
    # Determine breach_type per row (high preferred if both)
    breaches['breach_type'] = breaches.apply(lambda r: 'high' if r['is_high'] else 'low', axis=1)
    breaches['source'] = source_name
    return breaches[['cmdb_id','kpi','source','timestamp','value','P95','P5','breach_type']]

# Extract breaches from each source
metric_breaches = extract_breaches(metric_window, metric_thr, 'metric')
trace_breaches  = extract_breaches(trace_window, trace_thr, 'trace')
log_breaches    = extract_breaches(log_window, log_thr, 'log')

# Combine breaches
all_breaches = pd.concat([metric_breaches, trace_breaches, log_breaches], ignore_index=True)
# If no breaches at all, create empty summary rows with nulls per component
component_rows = []
for comp in components:
    comp_b = all_breaches[all_breaches['cmdb_id'] == comp].copy()
    if comp_b.empty:
        # no breaches for this component
        component_rows.append({
            'cmdb_id': comp,
            'earliest_breach_ts': None,
            'earliest_breach_source': None,
            'earliest_breach_kpi': None,
            'value_at_earliest_breach': None,
            'global_P95_for_that_kpi': None,
            'global_P5_for_that_kpi': None,
            'breach_type': None,
            'count_breaches_in_window_for_that_kpi': 0
        })
        continue
    # For each (kpi,source) compute earliest breach ts and count breaches for that KPI/source
    grouped = comp_b.groupby(['source','kpi'])
    per_kpi = grouped.agg(
        earliest_breach_ts = ('timestamp','min'),
        count_breaches = ('timestamp','count')
    ).reset_index()
    # Merge to get value at earliest breach and thresholds and breach_type
    # For each row find the value and breach_type at the earliest timestamp (if multiple rows same ts pick first)
    details = []
    for _, r in per_kpi.iterrows():
        src = r['source']
        kpi = r['kpi']
        e_ts = int(r['earliest_breach_ts'])
        count_b = int(r['count_breaches'])
        # find corresponding row in comp_b
        row_candidates = comp_b[(comp_b['source']==src) & (comp_b['kpi']==kpi) & (comp_b['timestamp']==e_ts)].sort_values('value', ascending=False)
        first_row = row_candidates.iloc[0]
        val = float(first_row['value'])
        P95 = first_row['P95']
        P5  = first_row['P5']
        btype = first_row['breach_type']
        # compute breach_ratio safely
        if pd.isna(P95) or P95 == 0:
            breach_ratio = float('inf') if val > 0 else 0.0
        else:
            breach_ratio = (val - P95) / P95
        details.append({
            'source': src,
            'kpi': kpi,
            'earliest_breach_ts': e_ts,
            'value_at_earliest_breach': val,
            'P95': P95,
            'P5': P5,
            'breach_type': btype,
            'count_breaches': count_b,
            'breach_ratio': breach_ratio
        })
    # Choose the KPI/source with the minimum earliest_breach_ts; if multiple, pick the one with larger breach_ratio
    det_df = pd.DataFrame(details)
    det_df = det_df.sort_values(by=['earliest_breach_ts','breach_ratio'], ascending=[True, False]).reset_index(drop=True)
    chosen = det_df.iloc[0]
    component_rows.append({
        'cmdb_id': comp,
        'earliest_breach_ts': int(chosen['earliest_breach_ts']),
        'earliest_breach_source': chosen['source'],
        'earliest_breach_kpi': chosen['kpi'],
        'value_at_earliest_breach': float(chosen['value_at_earliest_breach']),
        'global_P95_for_that_kpi': chosen['P95'],
        'global_P5_for_that_kpi': chosen['P5'],
        'breach_type': chosen['breach_type'],
        'count_breaches_in_window_for_that_kpi': int(chosen['count_breaches'])
