import pandas as pd
import numpy as np
import re
import pytz

# Reuse existing kernel variable 'fault_runs'
if 'fault_runs' not in globals():
    raise RuntimeError("Kernel variable 'fault_runs' not found. Please run prior steps.")

# Ensure run_start_ts is datetime with Asia/Shanghai tz
tz = pytz.timezone('Asia/Shanghai')
if not pd.api.types.is_datetime64_any_dtype(fault_runs['run_start_ts']):
    fault_runs['run_start_ts'] = pd.to_datetime(fault_runs['run_start_ts'])
# If tz-naive, localize to Asia/Shanghai (most are already tz-aware)
if fault_runs['run_start_ts'].dt.tz is None:
    fault_runs['run_start_ts'] = fault_runs['run_start_ts'].dt.tz_localize(tz)
else:
    fault_runs['run_start_ts'] = fault_runs['run_start_ts'].dt.tz_convert(tz)

# Filter trace runs
trace_runs = fault_runs[fault_runs['series_type'] == 'trace'].copy()

# Parse kpi_name to extract to_/from_/self components
# Extract downstream from 'trace.to_<COMP>.' pattern
trace_runs['parsed_to'] = trace_runs['kpi_name'].str.extract(r'trace\.to_([^\.]+)\.', expand=False)
# Extract upstream from 'trace.from_<COMP>.' pattern (not used for downstream but stored)
trace_runs['parsed_from'] = trace_runs['kpi_name'].str.extract(r'trace\.from_([^\.]+)\.', expand=False)
# Detect self traces
trace_runs['is_self'] = trace_runs['kpi_name'].str.startswith('trace.self.')

# Compute effective downstream_component: prefer parsed_to, else if self use cmdb_id, else NaN
trace_runs['downstream_component'] = np.where(
    trace_runs['parsed_to'].notna(),
    trace_runs['parsed_to'],
    np.where(trace_runs['is_self'], trace_runs['cmdb_id'], np.nan)
)

# Keep only runs that have an effective downstream_component
trace_runs_with_down = trace_runs[trace_runs['downstream_component'].notna()].copy()

# Aggregate by downstream_component
def sample_series(names_series, n=3):
    # take up to n unique names as a semicolon-separated string
    uniq = pd.unique(names_series)
    return "; ".join(uniq[:n])

trace_downstream_agg = (
    trace_runs_with_down
    .groupby('downstream_component')
    .agg(
        trace_run_count = ('kpi_name','size'),
        earliest_trace_run_start = ('run_start_ts','min'),
        max_trace_run_severity = ('run_max_severity','max'),
        sample_trace_series = ('kpi_name', lambda s: sample_series(s, 3))
    )
    .reset_index()
)

# Sort as required: earliest_trace_run_start asc, then max_trace_run_severity desc
trace_downstream_agg = trace_downstream_agg.sort_values(
    by=['earliest_trace_run_start','max_trace_run_severity'],
    ascending=[True, False]
).reset_index(drop=True)

# Compact top-20 for return
trace_downstream_agg_top20 = trace_downstream_agg.head(20)[
    ['downstream_component','trace_run_count','earliest_trace_run_start','max_trace_run_severity','sample_trace_series']
]

# Overall earliest trace run_start_ts among all trace runs (regardless of downstream presence)
overall_earliest = trace_runs['run_start_ts'].min()

# Number of distinct downstream components identified
downstream_count = int(trace_downstream_agg['downstream_component'].nunique())

# Store full aggregated result in kernel variable 'trace_downstream_agg' (already assigned)
trace_downstream_agg_top20, overall_earliest, downstream_count
