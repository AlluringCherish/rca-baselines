import pandas as pd
import numpy as np
import pytz

# Reuse existing DataFrames from kernel: metric_df, trace_df, log_df
# Ensure timezone variable
tz = pytz.timezone('Asia/Shanghai')
start = pd.Timestamp('2021-03-10 00:00:00', tz=tz)
end = pd.Timestamp('2021-03-10 00:30:00', tz=tz)

# Helper to compute global P95 and P5 per group (uses entire series BEFORE filtering)
def compute_global_quantiles(df, group_cols, value_col='value'):
    g = df.groupby(group_cols)[value_col]
    p95 = g.quantile(0.95).rename('global_P95')
    p5 = g.quantile(0.05).rename('global_P5')
    q = pd.concat([p95, p5], axis=1).reset_index()
    return q

# Helper to compute windowed stats joined with global quantiles
def compute_window_stats(df, group_cols, global_q):
    # Filter df to window first
    df_win = df[(df['ts'] >= start) & (df['ts'] <= end)].copy()
    # Merge only groups that have values in global_q (global_q contains all series)
    base = global_q.copy()
    # If there are rows in window, compute per-group stats from those rows
    if not df_win.empty:
        # join window rows with their group's global thresholds
        w = df_win.merge(global_q, on=group_cols, how='inner')
        # group and aggregate
        def agg_fn(g):
            gp95 = g['global_P95'].iloc[0]
            gp5 = g['global_P5'].iloc[0]
            pts = len(g)
            highs = (g['value'] >= gp95).sum()
            lows = (g['value'] <= gp5).sum()
            earliest_high = g.loc[g['value'] >= gp95, 'ts'].min() if highs > 0 else pd.NaT
            earliest_low = g.loc[g['value'] <= gp5, 'ts'].min() if lows > 0 else pd.NaT
            return pd.Series({
                'points_in_window': pts,
                'anomalies_high_count': int(highs),
                'earliest_high_ts': earliest_high,
                'max_value_in_window': g['value'].max(),
                'anomalies_low_count': int(lows),
                'earliest_low_ts': earliest_low,
                'min_value_in_window': g['value'].min()
            })
        grp = w.groupby(group_cols).apply(agg_fn).reset_index()
    else:
        # empty window: create empty dataframe with proper columns
        grp = pd.DataFrame(columns=group_cols + [
            'points_in_window','anomalies_high_count','earliest_high_ts','max_value_in_window',
            'anomalies_low_count','earliest_low_ts','min_value_in_window'
        ])
    # Merge base global thresholds with group window stats (left join on group_cols)
    merged = base.merge(grp, on=group_cols, how='left')
    # Fill missing numeric counts with 0 and keep min/max as NaN where absent
    merged['points_in_window'] = merged['points_in_window'].fillna(0).astype(int)
    merged['anomalies_high_count'] = merged['anomalies_high_count'].fillna(0).astype(int)
    merged['anomalies_low_count'] = merged['anomalies_low_count'].fillna(0).astype(int)
    # earliest timestamps may be NaT; keep as is
    # Compute severity metrics
    merged['severity_high'] = np.where(merged['global_P95'] > 0, merged['max_value_in_window'] / merged['global_P95'], np.nan)
    merged['severity_low'] = np.where(merged['min_value_in_window'] > 0, merged['global_P5'] / merged['min_value_in_window'], np.nan)
    return merged

# Process metric.csv: group by (cmdb_id, kpi_name)
metric_globals = compute_global_quantiles(metric_df, ['cmdb_id','kpi_name'])
metric_window_stats = compute_window_stats(metric_df, ['cmdb_id','kpi_name'], metric_globals)
# rename kpi_name retained

# Process trace.csv: group by (cmdb_id, trace_name)
trace_globals = compute_global_quantiles(trace_df, ['cmdb_id','trace_name'])
trace_window_stats = compute_window_stats(trace_df, ['cmdb_id','trace_name'], trace_globals)
# For uniformity, rename trace_name -> kpi_name column
trace_window_stats = trace_window_stats.rename(columns={'trace_name':'kpi_name'})

# Process log.csv: group by (cmdb_id, log_name)
log_globals = compute_global_quantiles(log_df, ['cmdb_id','log_name'])
log_window_stats = compute_window_stats(log_df, ['cmdb_id','log_name'], log_globals)
log_window_stats = log_window_stats.rename(columns={'log_name':'kpi_name'})

# Build unified summary table with required columns
def build_summary(df_stats, series_type_label):
    df = df_stats.copy()
    df['series_type'] = series_type_label
    # Select/ensure columns in required order:
    cols = ['series_type','cmdb_id','kpi_name','global_P95','global_P5',
            'points_in_window','anomalies_high_count','earliest_high_ts','max_value_in_window',
            'severity_high','anomalies_low_count','earliest_low_ts','min_value_in_window','severity_low']
    # Some dfs may not have kpi_name column name correct; ensure it exists
    if 'kpi_name' not in df.columns:
        # attempt to find the name column among possible names
        for c in ['kpi_name','trace_name','log_name']:
            if c in df.columns:
                df = df.rename(columns={c:'kpi_name'})
                break
    # keep only these columns (if missing, add NaN)
    for c in cols:
        if c not in df.columns:
            df[c] = np.nan
    return df[cols]

metric_summary = build_summary(metric_window_stats, 'metric')
trace_summary = build_summary(trace_window_stats, 'trace')
log_summary = build_summary(log_window_stats, 'log')

# Combine summaries
combined = pd.concat([metric_summary, trace_summary, log_summary], ignore_index=True)

# Compute sorting keys: total anomalies and peak severity
combined['total_anomalies'] = combined['anomalies_high_count'] + combined['anomalies_low_count']
combined['peak_severity'] = combined[['severity_high','severity_low']].max(axis=1, skipna=True).fillna(0)

# Final selection and sorting
final_cols = ['series_type','cmdb_id','kpi_name','global_P95','global_P5',
              'points_in_window','anomalies_high_count','earliest_high_ts','max_value_in_window',
