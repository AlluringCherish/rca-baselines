    ['series_type','kpi_name','points_in_window','global_P95','global_P5',
     'severity_high','severity_low','anomalies_high_count','anomalies_low_count','peak_severity']
].sort_values(by='peak_severity', ascending=False).head(20).drop(columns=['peak_severity'])

# 2) Fault runs for Tomcat01 from fault_runs
tomcat01_runs = fault_runs[fault_runs['cmdb_id'] == 'Tomcat01'].copy()

# Ensure run_start_ts is datetime with tz
if not pd.api.types.is_datetime64_any_dtype(tomcat01_runs['run_start_ts']):
    tomcat01_runs['run_start_ts'] = pd.to_datetime(tomcat01_runs['run_start_ts']).dt.tz_localize(tz, ambiguous='NaT', nonexistent='NaT')

if not pd.api.types.is_datetime64_any_dtype(tomcat01_runs['run_end_ts']):
    tomcat01_runs['run_end_ts'] = pd.to_datetime(tomcat01_runs['run_end_ts']).dt.tz_localize(tz, ambiguous='NaT', nonexistent='NaT')

tomcat01_runs = tomcat01_runs[
    ['series_type','kpi_name','anomaly_side','run_start_ts','run_end_ts','run_length',
     'run_max_severity','run_max_value','run_min_value','series_global_P95','series_global_P5']
].sort_values(by=['run_start_ts','run_max_severity'], ascending=[True, False]).head(20)

# 3) Log aggregates for Tomcat01 in-window from log_df
logs_win = log_df[
    (log_df['cmdb_id'] == 'Tomcat01') &
    (log_df['ts'] >= start) & (log_df['ts'] <= end)
].copy()

if not logs_win.empty:
    # points, sum, max
    agg_counts = logs_win.groupby('log_name').agg(
        points_in_window = ('value','count'),
        sum_value = ('value','sum'),
        max_value = ('value','max')
    ).reset_index()
    # earliest timestamp where value>0
    positive = logs_win[logs_win['value'] > 0].groupby('log_name').agg(
        earliest_pos_ts = ('ts','min')
    ).reset_index()
    tomcat01_logs = agg_counts.merge(positive, on='log_name', how='left')
else:
    tomcat01_logs = pd.DataFrame(columns=['log_name','points_in_window','sum_value','max_value','earliest_pos_ts'])

tomcat01_logs = tomcat01_logs.head(20)

# 4) Trace summary for Tomcat01 in-window using precomputed global thresholds (trace_globals)
# Prepare global thresholds for Tomcat01
trace_globals_tomcat = trace_globals[trace_globals['cmdb_id']=='Tomcat01'].copy() if 'trace_globals' in globals() else pd.DataFrame(columns=['cmdb_id','trace_name','global_P95','global_P5'])

# Windowed trace series for Tomcat01
traces_win = trace_df[
    (trace_df['cmdb_id'] == 'Tomcat01') &
    (trace_df['ts'] >= start) & (trace_df['ts'] <= end)
].copy()

if not traces_win.empty:
    # Merge with global thresholds (ensures thresholds computed globally are used)
    traces_win = traces_win.merge(trace_globals_tomcat, on=['cmdb_id','trace_name'], how='left')
    # points and max per trace_name
    agg = traces_win.groupby('trace_name').agg(
        points_in_window = ('value','count'),
        max_value_in_window = ('value','max')
    ).reset_index()
    # earliest timestamp where value >= global_P95
    # Need rows where value >= global_P95 (global_P95 might be NaN if missing)
    traces_win['is_ge_p95'] = traces_win['value'] >= traces_win['global_P95']
    earliest_p95 = traces_win[traces_win['is_ge_p95']].groupby('trace_name').agg(
        earliest_ts_where_ge_p95 = ('ts','min')
    ).reset_index()
    # Bring global thresholds into result
    trace_params = trace_globals_tomcat[['trace_name','global_P95','global_P5']].drop_duplicates()
    tomcat01_traces = agg.merge(earliest_p95, on='trace_name', how='left').merge(trace_params, on='trace_name', how='left')
    tomcat01_traces = tomcat01_traces.sort_values(by='earliest_ts_where_ge_p95', na_position='last').head(20)
else:
