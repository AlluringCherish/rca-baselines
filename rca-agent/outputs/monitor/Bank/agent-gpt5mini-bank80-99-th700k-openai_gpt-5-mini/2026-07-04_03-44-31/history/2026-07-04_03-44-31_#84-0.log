import pandas as pd
import numpy as np
import pytz

# Ensure candidate_df exists
if 'candidate_df' not in globals():
    raise RuntimeError("candidate_df not found in kernel. Please run previous steps to produce candidate_df.")

# Ensure timestamp columns are datetime (they should be), enforce timezone Asia/Shanghai
tz = pytz.timezone('Asia/Shanghai')
for col in ['earliest_high_ts','earliest_low_ts']:
    if col in candidate_df.columns and not pd.api.types.is_datetime64_any_dtype(candidate_df[col]):
        candidate_df[col] = pd.to_datetime(candidate_df[col], utc=True).dt.tz_convert(tz)

# Per-series earliest anomaly timestamp (min of earliest_high_ts and earliest_low_ts, ignore NaT)
candidate_df['series_earliest_ts'] = candidate_df[['earliest_high_ts','earliest_low_ts']].min(axis=1, skipna=True)

# Per-series peak severity
candidate_df['series_peak_severity'] = candidate_df[['severity_high','severity_low']].max(axis=1, skipna=True)

# Aggregate by cmdb_id
component_candidates = candidate_df.groupby('cmdb_id').agg(
    num_candidate_series = ('kpi_name','size'),
    earliest_anomaly_ts = ('series_earliest_ts','min'),
    max_severity = ('series_peak_severity','max'),
    total_anomalies_high = ('anomalies_high_count','sum'),
    total_anomalies_low  = ('anomalies_low_count','sum')
).reset_index()

# Exclude components with missing earliest_anomaly_ts
component_candidates = component_candidates.dropna(subset=['earliest_anomaly_ts'])

# Sort by earliest_anomaly_ts asc, then max_severity desc
component_candidates = component_candidates.sort_values(by=['earliest_anomaly_ts','max_severity'], ascending=[True, False]).reset_index(drop=True)

# Keep full aggregated result in kernel variable as required
# Return compact top-20 and total count of components in this aggregated candidate set
component_candidates_top20 = component_candidates[['cmdb_id','num_candidate_series','earliest_anomaly_ts','max_severity','total_anomalies_high','total_anomalies_low']].head(20)
component_candidates_count = int(component_candidates.shape[0])

component_candidates_top20, component_candidates_count
