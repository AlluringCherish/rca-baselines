import pandas as pd
import numpy as np
import pytz

# Reuse variables from kernel
tz = pytz.timezone('Asia/Shanghai')
start = pd.Timestamp('2021-03-10 00:00:00', tz=tz)
end = pd.Timestamp('2021-03-10 00:30:00', tz=tz)

# 1) Candidate series summary for Tomcat01 from candidate_df
