        run_len = len(g)
        run_max = float(g['value'].max())
        run_min = float(g['value'].min())
        run_max_sev = (gp5 / run_min) if (pd.notna(gp5) and run_min != 0) else np.nan
        runs_records.append({
            'series_type': series_type,
            'cmdb_id': cmdb,
            'kpi_name': kpi_name,
            'anomaly_side': 'low',
            'run_start_ts': run_start,
            'run_end_ts': run_end,
            'run_length': int(run_len),
            'run_max_value': run_max,
            'run_min_value': run_min,
            'run_max_severity': float(run_max_sev) if pd.notna(run_max_sev) else np.nan,
            'series_global_P95': float(gp95) if pd.notna(gp95) else np.nan,
            'series_global_P5': float(gp5) if pd.notna(gp5) else np.nan
        })

# Create DataFrame of runs
fault_runs = pd.DataFrame.from_records(runs_records)

# Ensure timestamp columns are tz-aware datetimes
if not fault_runs.empty:
    fault_runs['run_start_ts'] = pd.to_datetime(fault_runs['run_start_ts'])
    fault_runs['run_end_ts'] = pd.to_datetime(fault_runs['run_end_ts'])

# Sorting: run_start_ts ascending then run_max_severity descending
if not fault_runs.empty:
