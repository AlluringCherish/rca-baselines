import pandas as pd
import numpy as np
import pytz

# Reuse existing variables from kernel
tz = pytz.timezone('Asia/Shanghai')
start = pd.Timestamp('2021-03-10 00:00:00', tz=tz)
end = pd.Timestamp('2021-03-10 00:30:00', tz=tz)

# Ensure required variables exist
for v in ('candidate_df','component_candidates_top20','metric_df','trace_df','log_df'):
    if v not in globals():
        raise RuntimeError(f"Required variable '{v}' not found in kernel.")

# Select top 8 components by the order from component_candidates_top20.head(8)
top8_cmdbs = component_candidates_top20.head(8)['cmdb_id'].tolist()

# Retrieve candidate series for these components
top_candidates = candidate_df[candidate_df['cmdb_id'].isin(top8_cmdbs)].copy()

# Helper to find contiguous runs (length >=2) in a DataFrame of points with tz-aware 'ts' sorted asc
def find_contiguous_runs(df_points):
    if df_points.empty:
        return []
    dfp = df_points.sort_values('ts').reset_index(drop=True).copy()
    diff = dfp['ts'].diff()
    # Start of run when diff != 1 minute or first row
    new_run = (diff != pd.Timedelta(minutes=1))
    group_id = new_run.cumsum()
    dfp['group_id'] = group_id
    runs = []
    for gid, g in dfp.groupby('group_id'):
        if len(g) >= 2:
            runs.append(g)
    return runs

runs_records = []

# Iterate over each candidate series row
for _, s in top_candidates.iterrows():
    series_type = s['series_type']
    cmdb = s['cmdb_id']
    kpi_name = s['kpi_name']
    gp95 = s.get('global_P95', np.nan)
    gp5 = s.get('global_P5', np.nan)
    # Choose source dataframe and name column
    if series_type == 'metric':
        src_df = metric_df
        name_col = 'kpi_name'
    elif series_type == 'trace':
        src_df = trace_df
        name_col = 'trace_name'
    elif series_type == 'log':
        src_df = log_df
        name_col = 'log_name'
    else:
        continue  # unknown type

    # Filter original timeseries to window, cmdb_id and name
    series_ts = src_df[
        (src_df['ts'] >= start) & (src_df['ts'] <= end) &
        (src_df['cmdb_id'] == cmdb) & (src_df[name_col] == kpi_name)
    ].sort_values('ts').copy()

    if series_ts.empty:
        continue

    # Mark anomalies using global thresholds
    series_ts['anomaly_high'] = series_ts['value'] >= gp95
    series_ts['anomaly_low'] = series_ts['value'] <= gp5

    # High-side runs
    high_points = series_ts[series_ts['anomaly_high']][['ts','value']].copy()
    high_runs = find_contiguous_runs(high_points)
    for g in high_runs:
        run_start = g['ts'].iloc[0]
        run_end = g['ts'].iloc[-1]
        run_len = len(g)
        run_max = float(g['value'].max())
        run_min = float(g['value'].min())
        run_max_sev = (run_max / gp95) if (pd.notna(gp95) and gp95 != 0) else np.nan
        runs_records.append({
            'series_type': series_type,
            'cmdb_id': cmdb,
            'kpi_name': kpi_name,
            'anomaly_side': 'high',
            'run_start_ts': run_start,
            'run_end_ts': run_end,
            'run_length': int(run_len),
            'run_max_value': run_max,
            'run_min_value': run_min,
            'run_max_severity': float(run_max_sev) if pd.notna(run_max_sev) else np.nan,
            'series_global_P95': float(gp95) if pd.notna(gp95) else np.nan,
            'series_global_P5': float(gp5) if pd.notna(gp5) else np.nan
        })

    # Low-side runs
    low_points = series_ts[series_ts['anomaly_low']][['ts','value']].copy()
    low_runs = find_contiguous_runs(low_points)
    for g in low_runs:
        run_start = g['ts'].iloc[0]
