import pandas as pd
import numpy as np
import pytz

# Reuse anomalies DataFrame from kernel
try:
    anomalies
except NameError:
    raise NameError("anomalies DataFrame not found in kernel. Run anomaly detection step first.")

# Ensure datetime tz handling (UTC+8)
tz = pytz.timezone('Asia/Shanghai')
for col in ['exceed_earliest_ts','drop_earliest_ts']:
    if col in anomalies.columns:
        anomalies[col] = pd.to_datetime(anomalies[col], errors='coerce')
        # localize or convert to Asia/Shanghai consistently
        if not anomalies[col].dropna().empty:
            sample = anomalies[col].dropna().iloc[0]
            if sample.tzinfo is None:
                anomalies[col] = anomalies[col].dt.tz_localize(tz)
            else:
                anomalies[col] = anomalies[col].dt.tz_convert(tz)

# Define directional anomalies
spike_mask = (anomalies['exceed_count'] > 0) & (anomalies['drop_count'] == 0)
drop_mask = (anomalies['drop_count'] > 0) & (anomalies['exceed_count'] == 0)
directional_mask = spike_mask | drop_mask

directional_anomalies = anomalies[directional_mask].copy()  # saved in kernel as requested

# Compute fractions
directional_anomalies['exceed_fraction'] = directional_anomalies['exceed_count'] / directional_anomalies['count_in_window']
directional_anomalies['drop_fraction'] = directional_anomalies['drop_count'] / directional_anomalies['count_in_window']

# 1) overall_counts: single-row summary with total_directional_groups and counts_by_type mapping
N_spike = int(spike_mask.sum())
N_drop = int(drop_mask.sum())
total_directional = int(directional_mask.sum())
counts_by_type_str = f"spike:{N_spike}, drop:{N_drop}"
overall_counts = pd.DataFrame([{
    'total_directional_groups': total_directional,
    'counts_by_type': counts_by_type_str,
    'spike_count': N_spike,
    'drop_count': N_drop
}])

# 2) per_component_summary
grp = directional_anomalies.groupby('cmdb_id')

per_component_summary = grp.agg(
    directional_group_count=('kpi_name','nunique'),
    spike_count=('exceed_count', lambda s: ((s>0) & (directional_anomalies.loc[s.index,'drop_count']==0)).sum()),
    drop_count=('drop_count', lambda s: ((s>0) & (directional_anomalies.loc[s.index,'exceed_count']==0)).sum()),
).reset_index()

# earliest directional ts: min of exceed_earliest_ts or drop_earliest_ts among directional groups
def earliest_directional_ts(sub):
    times = pd.to_datetime(pd.concat([sub['exceed_earliest_ts'], sub['drop_earliest_ts']]), errors='coerce')
    times = times.dropna()
    return times.min() if not times.empty else pd.NaT

per_component_summary['earliest_directional_ts'] = grp.apply(earliest_directional_ts).values

# Sort and limit top 20
per_component_summary = per_component_summary.sort_values(
    ['directional_group_count','spike_count','drop_count'], ascending=[False, False, False]
).reset_index(drop=True)
per_component_summary_top20 = per_component_summary.head(20).copy()

# 3) top_directional_groups: sort by severity (max fraction) desc then count_in_window desc
directional_anomalies['severity'] = directional_anomalies[['exceed_fraction','drop_fraction']].max(axis=1)
top_directional_groups = directional_anomalies.sort_values(['severity','count_in_window'], ascending=[False, False])

# Select and round requested columns
top_directional_groups = top_directional_groups[[
    'cmdb_id','kpi_name','count_in_window','p95','p5',
    'exceed_count','exceed_earliest_ts','drop_count','drop_earliest_ts',
    'exceed_fraction','drop_fraction','max_value_in_window','min_value_in_window'
]].copy()

top_directional_groups[['p95','p5','exceed_fraction','drop_fraction','max_value_in_window','min_value_in_window']] = \
    top_directional_groups[['p95','p5','exceed_fraction','drop_fraction','max_value_in_window','min_value_in_window']].round(6)

top_directional_groups_top20 = top_directional_groups.head(20).reset_index(drop=True)

# Save directional_anomalies in kernel (already assigned)
directional_anomalies = directional_anomalies  # ensure variable name exists

# Final compact outputs
overall_counts, per_component_summary_top20, top_directional_groups_top20
