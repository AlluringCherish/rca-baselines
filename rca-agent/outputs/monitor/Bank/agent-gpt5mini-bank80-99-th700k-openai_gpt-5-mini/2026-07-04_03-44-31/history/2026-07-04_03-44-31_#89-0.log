import pandas as pd
import pytz

# Reuse anomalies variable from kernel
try:
    anomalies
except NameError:
    raise NameError("anomalies DataFrame not found in kernel. Run anomaly detection step first.")

tz = pytz.timezone('Asia/Shanghai')

# Work on a copy
an = anomalies.copy()

# Ensure datetime columns are proper datetimes (NaT when missing) and in UTC+8
an['exceed_earliest_ts'] = pd.to_datetime(an['exceed_earliest_ts'], errors='coerce')
an['drop_earliest_ts'] = pd.to_datetime(an['drop_earliest_ts'], errors='coerce')

# If datetimes are tz-naive but represent UTC+8 already, attempt to localize; otherwise keep tz-aware.
# We will convert tz-aware datetimes to Asia/Shanghai for consistency.
def ensure_tz(dt_series):
    # If any non-null timezone-aware entries exist, convert them; else leave as is (they may be tz-aware already)
    if dt_series.dropna().apply(lambda x: x.tzinfo is not None).any():
        return dt_series.dt.tz_convert(tz)
    else:
        # treat as timezone-naive timestamps that already represent UTC+8: localize to Asia/Shanghai
        return dt_series.dt.tz_localize(tz, ambiguous='NaT', nonexistent='NaT')

an['exceed_earliest_ts'] = ensure_tz(an['exceed_earliest_ts'])
an['drop_earliest_ts'] = ensure_tz(an['drop_earliest_ts'])

# Compute per-component aggregates
group = an.groupby('cmdb_id')

component_candidates = pd.DataFrame({
    'cmdb_id': group.size().index
}).set_index('cmdb_id')

# total distinct KPI groups with window (each row in anomalies is a group with window rows)
component_candidates['total_groups_with_window'] = group['kpi_name'].nunique()

# groups with exceed_only, drop_only, both
component_candidates['groups_with_exceed_only'] = group.apply(lambda g: ((g['exceed_count']>0) & (g['drop_count']==0)).sum())
component_candidates['groups_with_drop_only'] = group.apply(lambda g: ((g['drop_count']>0) & (g['exceed_count']==0)).sum())
component_candidates['groups_with_both'] = group.apply(lambda g: ((g['exceed_count']>0) & (g['drop_count']>0)).sum())

# earliest exceed/drop timestamps per component (NULL if none)
def min_ts(series):
    s = series.dropna()
    return s.min() if not s.empty else pd.NaT

component_candidates['earliest_exceed_ts'] = group['exceed_earliest_ts'].apply(min_ts)
component_candidates['earliest_drop_ts'] = group['drop_earliest_ts'].apply(min_ts)

# max_exceed_fraction and max_drop_fraction
component_candidates['max_exceed_fraction'] = group.apply(lambda g: (g['exceed_count'] / g['count_in_window']).replace([pd.NA, pd.NaN, float('inf')], 0).max())
component_candidates['max_drop_fraction'] = group.apply(lambda g: (g['drop_count'] / g['count_in_window']).replace([pd.NA, pd.NaN, float('inf')], 0).max())

# Reset index to column
component_candidates = component_candidates.reset_index()

# Ensure earliest timestamps are timezone-aware Asia/Shanghai where present
component_candidates['earliest_exceed_ts'] = pd.to_datetime(component_candidates['earliest_exceed_ts'], errors='coerce')
component_candidates['earliest_drop_ts'] = pd.to_datetime(component_candidates['earliest_drop_ts'], errors='coerce')

# Sorting as requested: by (groups_with_exceed_only + groups_with_drop_only) desc, then groups_with_both, then total_groups_with_window
component_candidates['tot_exceed_drop_only'] = component_candidates['groups_with_exceed_only'] + component_candidates['groups_with_drop_only']
component_candidates = component_candidates.sort_values(
    ['tot_exceed_drop_only', 'groups_with_both', 'total_groups_with_window'],
    ascending=[False, False, False]
).reset_index(drop=True)

# Limit to top 20 components for display
component_candidates_top20 = component_candidates.head(20).copy()

# Clean up display: round fraction columns to 3 decimals
component_candidates_top20['max_exceed_fraction'] = component_candidates_top20['max_exceed_fraction'].round(3)
component_candidates_top20['max_drop_fraction'] = component_candidates_top20['max_drop_fraction'].round(3)

# Prepare top 3 components and their up-to-5 KPI groups that contributed anomalies
top3_components = component_candidates_top20['cmdb_id'].head(3).tolist()

top_components_kpis = {}
for comp in top3_components:
    comp_rows = an[(an['cmdb_id']==comp) & ((an['exceed_count']>0) | (an['drop_count']>0))].copy()
    # Order by severity: max(exceed_count, drop_count) desc then count_in_window desc
    comp_rows['severity'] = comp_rows[['exceed_count','drop_count']].max(axis=1)
    comp_rows = comp_rows.sort_values(['severity','count_in_window'], ascending=[False, False])
    comp_rows_display = comp_rows[['cmdb_id','kpi_name','count_in_window','exceed_count','exceed_earliest_ts',
                                  'drop_count','drop_earliest_ts','max_value_in_window','min_value_in_window']].head(5).copy()
    # Round numeric extremes for compactness
    comp_rows_display[['max_value_in_window','min_value_in_window']] = comp_rows_display[['max_value_in_window','min_value_in_window']].round(6)
    top_components_kpis[comp] = comp_rows_display

# Save variables in kernel as requested
component_candidates = component_candidates  # full table (kept in kernel)
top_components_kpis = top_components_kpis    # dict of small DataFrames for top 3 components

# Return compact outputs: top 20 component candidates and the KPI lists for top 3 components
component_candidates_top20, top_components_kpis
