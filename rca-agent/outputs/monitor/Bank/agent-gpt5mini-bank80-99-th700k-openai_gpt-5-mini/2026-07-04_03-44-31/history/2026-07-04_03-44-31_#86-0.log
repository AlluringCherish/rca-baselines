import pandas as pd
import numpy as np
import pytz

# reuse existing variables where possible: trace, tz, start_epoch, end_epoch
# ensure timezone variable
tz = pytz.timezone('Asia/Shanghai')

# Ensure required variables exist; if not, recreate incident window
from datetime import datetime
if 'start_epoch' not in globals() or 'end_epoch' not in globals() or 'tz' not in globals():
    tz = pytz.timezone('Asia/Shanghai')
    start_local = tz.localize(datetime(2021,3,10,8,30,0))
    end_local = tz.localize(datetime(2021,3,10,9,0,0))
    start_epoch = int(start_local.astimezone(pytz.UTC).timestamp())
    end_epoch = int(end_local.astimezone(pytz.UTC).timestamp())

# Top candidate components
top_components = ['Mysql02','Mysql01','MG02','IG01','MG01','Tomcat01','Tomcat03','IG02','Tomcat02','Redis01']

# Filter trace to allowed components
trace_allowed = trace[trace['cmdb_id'].isin(top_components)].copy()

# Ensure numeric values
trace_allowed['value'] = pd.to_numeric(trace_allowed['value'], errors='coerce')

# Compute global P95 and P5 per (cmdb_id, trace_name) using full available series (rule 9)
global_trace_thresh = trace_allowed.groupby(['cmdb_id','trace_name'])['value'].agg(
    count_global='count',
    p95=lambda s: s.quantile(0.95),
    p5 = lambda s: s.quantile(0.05)
).reset_index()

# Filter trace rows to incident window (inclusive)
trace_window = trace_allowed[(trace_allowed['timestamp'] >= start_epoch) & (trace_allowed['timestamp'] <= end_epoch)].copy()

# Merge global thresholds into window rows
trace_window = trace_window.merge(global_trace_thresh, on=['cmdb_id','trace_name'], how='left')

# Flags and earliest timestamps for breaches
trace_window['gt_p95'] = trace_window['value'] > trace_window['p95']
trace_window['lt_p5'] = trace_window['value'] < trace_window['p5']

# Aggregate per (cmdb_id, trace_name)
def earliest_epoch_or_na(series):
    if series.dropna().empty:
        return pd.NA
    return int(series.min())

agg = trace_window.groupby(['cmdb_id','trace_name'], sort=False).agg(
    points_inside = ('value','count'),
    count_gt_p95 = ('gt_p95','sum'),
    earliest_gt_epoch = ('timestamp', lambda s: earliest_epoch_or_na(s[ trace_window.loc[s.index, 'gt_p95'] ] ) if s.size>0 else pd.NA),
    count_lt_p5 = ('lt_p5','sum'),
    earliest_lt_epoch = ('timestamp', lambda s: earliest_epoch_or_na(s[ trace_window.loc[s.index, 'lt_p5'] ] ) if s.size>0 else pd.NA),
    max_inside = ('value','max'),
    min_inside = ('value','min')
).reset_index()

# Note: The lambda above uses indices to pick gt/lt rows. For robustness, recalc earliest epochs separately:
# Recompute earliest_gt_epoch and earliest_lt_epoch correctly
if not trace_window.empty:
    earliest_gt = (trace_window[trace_window['gt_p95']]
                   .groupby(['cmdb_id','trace_name'])['timestamp']
                   .min()
                   .rename('earliest_gt_epoch'))
    earliest_lt = (trace_window[trace_window['lt_p5']]
                   .groupby(['cmdb_id','trace_name'])['timestamp']
                   .min()
                   .rename('earliest_lt_epoch'))
    agg = agg.set_index(['cmdb_id','trace_name'])
    agg = agg.join(earliest_gt).join(earliest_lt)
    agg = agg.reset_index()

# Convert earliest epochs to local ISO strings
def epoch_to_local_iso(val):
    if pd.isna(val):
        return pd.NA
    try:
        return pd.to_datetime(int(val), unit='s', utc=True).tz_convert(tz).isoformat()
    except Exception:
        return pd.NA

agg['earliest_gt_local'] = agg['earliest_gt_epoch'].apply(epoch_to_local_iso)
agg['earliest_lt_local'] = agg['earliest_lt_epoch'].apply(epoch_to_local_iso)

# Compute total anomalies for ranking
agg['total_anomalies'] = agg['count_gt_p95'].astype(int) + agg['count_lt_p5'].astype(int)

# For sorting by earliest anomaly time asc, compute earliest anomaly epoch (min of gt/lt epochs)
def min_epoch_or_large(row):
    e1 = row['earliest_gt_epoch']
    e2 = row['earliest_lt_epoch']
    if pd.isna(e1) and pd.isna(e2):
        return np.iinfo(np.int64).max
    vals = [v for v in (e1,e2) if pd.notna(v)]
    return int(min(vals)) if vals else np.iinfo(np.int64).max

agg['earliest_anom_epoch_for_sort'] = agg.apply(min_epoch_or_large, axis=1)

# Sort by total_anomalies desc, then earliest anomaly asc
agg_sorted = agg.sort_values(['total_anomalies','earliest_anom_epoch_for_sort'], ascending=[False, True]).reset_index(drop=True)

# Keep only requested aggregate columns (component, trace_name, points_inside, count_gt_p95, earliest_gt_local, count_lt_p5, earliest_lt_local, max_inside, min_inside)
display_cols = [
    'cmdb_id','trace_name','points_inside',
    'count_gt_p95','earliest_gt_local',
    'count_lt_p5','earliest_lt_local',
    'max_inside','min_inside'
]
trace_top20 = agg_sorted[display_cols].head(20)

# Store full anomaly table in kernel variable as requested
trace_anomalies = agg_sorted.copy()

# Display compact result and size of full anomalies table
trace_top20, trace_anomalies.shape
