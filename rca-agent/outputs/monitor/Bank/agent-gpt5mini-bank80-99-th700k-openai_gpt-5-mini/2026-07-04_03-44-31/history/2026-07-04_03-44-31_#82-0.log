import numpy as np
import pandas as pd
import pytz

# Reuse existing df_metric if present; otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

# Ensure numeric values
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

# Timezone for UTC+8
tz = pytz.timezone('Asia/Shanghai')

# Incident window in Asia/Shanghai (inclusive)
start_local = tz.localize(pd.Timestamp('2021-03-09 19:30:00'))
end_local   = tz.localize(pd.Timestamp('2021-03-09 20:00:00'))
start_utc_ts = int(start_local.astimezone(pytz.utc).timestamp())
end_utc_ts   = int(end_local.astimezone(pytz.utc).timestamp())

# 1) List distinct kpi_name for Tomcat02 from full metric.csv
tomcat_id = 'Tomcat02'
tomcat_kpis = pd.Series(sorted(df_metric[df_metric['cmdb_id'] == tomcat_id]['kpi_name'].dropna().unique()),
                        name='kpi_name')

# Helper to compute global quantile per group BEFORE filtering
def compute_global_quantile(df, q, group_cols, value_col='value', out_name=None):
    if out_name is None:
        out_name = f'p{int(q)}_value'
    agg = df.groupby(group_cols)[value_col].agg(
        **{out_name: (lambda x, q=q: float(np.nanpercentile(x.dropna(), q)) if x.dropna().size>0 else np.nan)}
    ).reset_index()
    return agg

# 2) Compute global P95 per (cmdb_id,kpi_name) using full series
p95_thresholds = compute_global_quantile(df_metric, 95, ['cmdb_id','kpi_name'], out_name='p95_value')

# Merge thresholds into full metric rows (not filtered)
dfm = df_metric.merge(p95_thresholds, on=['cmdb_id','kpi_name'], how='left')

# 3) Filter to incident window and Tomcat02 rows
df_win = dfm[(dfm['cmdb_id'] == tomcat_id) & (dfm['timestamp'] >= start_utc_ts) & (dfm['timestamp'] <= end_utc_ts)].copy()

# Helper to compute longest consecutive-minute run length
def longest_consecutive_minute_run(ts_array):
    if len(ts_array) == 0:
        return 0
    ts = np.sort(np.unique(ts_array.astype(np.int64)))
    if ts.size == 1:
        return 1
    run_len = 1
    runs = []
    for d in np.diff(ts):
        if d == 60:
            run_len += 1
        else:
            runs.append(run_len)
            run_len = 1
    runs.append(run_len)
    return int(np.max(runs))

# 4) For each Tomcat02 kpi_name that has at least one value >= p95_value in window, compute metrics
def build_tomcat_summary(df_window, thresholds_df, threshold_col='p95_value'):
    if df_window.empty:
        return pd.DataFrame()
    # Mask anomaly rows (value >= threshold and threshold not null)
    mask = (~df_window[threshold_col].isna()) & (df_window['value'] >= df_window[threshold_col])
    anom_rows = df_window[mask].copy()
    if anom_rows.empty:
        return pd.DataFrame()
    # count_anom and first/last_anom_ts from anom_rows
    grp_count = anom_rows.groupby(['cmdb_id','kpi_name'])['value'].count().rename('count_anom')
    grp_first = anom_rows.groupby(['cmdb_id','kpi_name'])['timestamp'].min().rename('first_anom_ts')
    grp_last = anom_rows.groupby(['cmdb_id','kpi_name'])['timestamp'].max().rename('last_anom_ts')
    # max_value_in_window computed from all window rows for the group (not limited to anomaly rows)
    grp_max_window = df_window.groupby(['cmdb_id','kpi_name'])['value'].max().rename('max_value_in_window')
    # Compose summary
    summary = pd.concat([grp_count, grp_first, grp_last, grp_max_window], axis=1).reset_index()
    # attach threshold value
    summary = summary.merge(thresholds_df[['cmdb_id','kpi_name', threshold_col]], on=['cmdb_id','kpi_name'], how='left')
    # Compute severity_ratio with special rules
    def compute_ratio(row):
        p = row[threshold_col]
        mx = row['max_value_in_window']
        if pd.isna(p):
            return np.nan
        if p == 0:
            if mx > 0:
                return np.inf
            else:
                return 1.0
        return float(mx / p)
    summary['severity_ratio'] = summary.apply(compute_ratio, axis=1)
    # Compute longest consecutive anomaly run per group using anomaly timestamps
    runs = []
    grouped_anom = anom_rows.groupby(['cmdb_id','kpi_name'])['timestamp']
    for cmdb, kpi in summary[['cmdb_id','kpi_name']].itertuples(index=False):
        try:
            arr = grouped_anom.get_group((cmdb, kpi)).values
        except Exception:
            arr = anom_rows[(anom_rows['cmdb_id']==cmdb) & (anom_rows['kpi_name']==kpi)]['timestamp'].values
        runs.append(longest_consecutive_minute_run(arr))
    summary['longest_consecutive_anom_run'] = runs
    # Format timestamps to UTC+8 strings
    for col in ['first_anom_ts','last_anom_ts']:
        summary[col] = pd.to_datetime(summary[col], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    # Round numeric columns
    summary[threshold_col] = summary[threshold_col].round(6)
    summary['max_value_in_window'] = summary['max_value_in_window'].round(6)
    # Significant breach flag (severity_ratio >= 1.5)
    summary['significant_breach'] = summary['severity_ratio'].apply(lambda x: True if (pd.notna(x) and x >= 1.5) else False)
    # Select and order required columns
    out_col = 'p95_value' if threshold_col == 'p95_value' else 'p90_value'
    summary = summary.rename(columns={threshold_col: out_col})
    summary = summary[['cmdb_id','kpi_name', out_col, 'count_anom', 'first_anom_ts', 'last_anom_ts',
                       'max_value_in_window','severity_ratio','longest_consecutive_anom_run','significant_breach']]
    return summary

summary_p95 = build_tomcat_summary(df_win, p95_thresholds, 'p95_value')

used_threshold = 'p95'
final_summary = summary_p95.copy()

# 5) If no groups breach P95, repeat using P90
if final_summary.empty:
    # compute global P90 thresholds (must be computed BEFORE filtering)
    p90_thresholds = compute_global_quantile(df_metric, 90, ['cmdb_id','kpi_name'], out_name='p90_value')
    # merge p90 into df_win
    df_win = df_win.merge(p90_thresholds, on=['cmdb_id','kpi_name'], how='left')
    # build summary using p90
    summary_p90 = build_tomcat_summary(df_win, p90_thresholds, 'p90_value')
    final_summary = summary_p90.copy()
    used_threshold = 'p90'

# Limit to top 20 by severity_ratio desc
if final_summary.empty:
    tomcat_result = final_summary  # empty
    significant_count = 0
    earliest_first_anom_ts = None
else:
    tomcat_result = final_summary.sort_values(by='severity_ratio', ascending=False).head(20).reset_index(drop=True)
    significant_count = int(tomcat_result['significant_breach'].sum())
    # earliest first_anom_ts among all Tomcat02 groups (convert back to timestamp for min)
    # find minimal original timestamp (we need to parse strings back)
    first_ts_series = pd.to_datetime(tomcat_result['first_anom_ts']).dt.tz_convert(tz)
    # earliest as formatted string
    if not first_ts_series.empty:
        earliest_first_anom_ts = first_ts_series.min().strftime('%Y-%m-%d %H:%M:%S %Z')
    else:
        earliest_first_anom_ts = None

# Final displayed outputs (compact)
tomcat_kpis, tomcat_result, significant_count, earliest_first_anom_ts, used_threshold
