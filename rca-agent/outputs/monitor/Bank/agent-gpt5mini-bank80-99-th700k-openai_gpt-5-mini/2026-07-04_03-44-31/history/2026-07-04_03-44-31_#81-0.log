    .groupby(['cmdb_id', 'trace_name'])
    .size()
    .reset_index(name='count')
    .sort_values('count', ascending=False)
)
trace_pairs_top20 = trace_pairs.head(20)

trace_summary_counts = pd.DataFrame({
    'distinct_cmdb_id': [trace_df['cmdb_id'].nunique()],
    'distinct_trace_name': [trace_df['trace_name'].nunique()],
    'total_records': [len(trace_df)]
})

# --- log.csv aggregates ---
