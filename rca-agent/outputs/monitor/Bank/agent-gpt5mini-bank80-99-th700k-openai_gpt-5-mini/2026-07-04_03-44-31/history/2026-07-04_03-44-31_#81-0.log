import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Load CSV files (they are in current working directory per task)
metric_df = pd.read_csv('metric.csv')
trace_df = pd.read_csv('trace.csv')
log_df = pd.read_csv('log.csv')
error_df = pd.read_csv('error_logs.csv')

# Convert timestamp to timezone-aware datetime in UTC+8 (Asia/Shanghai)
# Keep original timestamp column as-is, add a compact datetime column for potential use
for df in (metric_df, trace_df, log_df, error_df):
    if 'timestamp' in df.columns:
        df['dt_local'] = pd.to_datetime(df['timestamp'], unit='s', utc=True').dt.tz_convert(tz)

# --- metric.csv aggregates ---
metric_pairs = (
    metric_df
    .groupby(['cmdb_id', 'kpi_name'])
    .size()
    .reset_index(name='count')
    .sort_values('count', ascending=False)
)
metric_pairs_top20 = metric_pairs.head(20)

