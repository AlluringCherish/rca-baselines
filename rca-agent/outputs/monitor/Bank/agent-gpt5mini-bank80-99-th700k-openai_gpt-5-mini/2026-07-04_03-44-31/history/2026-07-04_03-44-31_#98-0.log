        if pd.isna(p5):
            low_count = 0
        else:
            low_count = int((df['value'] <= p5).sum())
        breach_count = high_count + low_count
        earliest_breach_ts = None
        if breach_count > 0:
            breaches = df[( (pd.notna(p95) & (df['value'] >= p95)) | (pd.notna(p5) & (df['value'] <= p5)) )]
            earliest_breach_ts = breaches['dt'].min()
        # severities
        sev_h = df.loc[df['value'] >= p95, 'value'].apply(lambda v: safe_div(v,p95)).max() if pd.notna(p95) and (df['value']>=p95).any() else np.nan
        sev_l = df.loc[df['value'] <= p5, 'value'].apply(lambda v: safe_div(p5,v)).max() if pd.notna(p5) and (df['value']<=p5).any() else np.nan
        max_sev = np.nanmax([x for x in [sev_h, sev_l] if not pd.isna(x)]) if not (pd.isna(sev_h) and pd.isna(sev_l)) else np.nan

        return pd.Series({
