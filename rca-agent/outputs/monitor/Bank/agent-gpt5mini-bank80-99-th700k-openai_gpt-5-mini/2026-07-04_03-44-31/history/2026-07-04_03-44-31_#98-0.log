import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Time window (inclusive) in UTC+8
start_dt = tz.localize(pd.to_datetime("2021-03-24 14:30"))
end_dt   = tz.localize(pd.to_datetime("2021-03-24 15:00"))

# Ensure metric_df exists and dt is timezone-aware Asia/Shanghai
metric_df['dt'] = pd.to_datetime(metric_df['dt']).dt.tz_convert(tz)

# Restrict to Tomcat03 and KPI name containing any of these substrings (case-insensitive)
substrs = ['JVM','CPU','Threads','Memory','GC']
pattern = '|'.join(substrs)
mask_kpi = metric_df['kpi_name'].str.contains(pattern, case=False, na=False)

# Compute global thresholds (p95 and p5) using the entire metric series BEFORE time filtering (Rule 9)
thresholds_p95 = metric_df.groupby(['cmdb_id','kpi_name'])['value'].quantile(0.95).reset_index().rename(columns={'value':'global_p95'})
thresholds_p5  = metric_df.groupby(['cmdb_id','kpi_name'])['value'].quantile(0.05).reset_index().rename(columns={'value':'global_p5'})
thresholds = thresholds_p95.merge(thresholds_p5, on=['cmdb_id','kpi_name'], how='outer')

# Filter rows in the desired window and matching Tomcat03 + KPI pattern
window_df = metric_df[
    (metric_df['cmdb_id']=='Tomcat03') &
    (metric_df['dt'] >= start_dt) &
    (metric_df['dt'] <= end_dt) &
    (mask_kpi)
].copy()

# Store full per-row results for later inspection (must include thresholds merged)
tomcat03_jvm_metrics_window = window_df.merge(thresholds, on=['cmdb_id','kpi_name'], how='left')

# If no rows, prepare empty summary
if tomcat03_jvm_metrics_window.empty:
    summary_df = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','sample_count_in_window','min_value','max_value','mean_value',
        'earliest_timestamp_in_window','latest_timestamp_in_window','global_p95','global_p5',
        'breach_count','earliest_breach_timestamp','max_breach_severity'
    ])
else:
    # Label per-row breaches and compute per-row severities
    def safe_div(a,b):
        return np.nan if pd.isna(a) or pd.isna(b) or b==0 else a/b

    tomcat03_jvm_metrics_window['is_high'] = tomcat03_jvm_metrics_window.apply(
