            'max_breach_severity': max_sev
        })

    agg_df = tomcat03_jvm_metrics_window.groupby(['cmdb_id','kpi_name']).apply(agg_row).reset_index(drop=True)

    # Format timestamps and round numeric columns for compactness
    agg_df['earliest_timestamp_in_window'] = agg_df['earliest_timestamp_in_window'].dt.strftime('%Y-%m-%d %H:%M:%S %Z')
    agg_df['latest_timestamp_in_window']   = agg_df['latest_timestamp_in_window'] = agg_df['latest_timestamp_in_window'] = agg_df['latest_timestamp_in_window'] = agg_df['latest_timestamp_in_window'] if 'latest_timestamp_in_window' in agg_df.columns else agg_df.pop('latest_timestamp_in_window', None)
    # Correction: we named latest column earlier as 'latest_timestamp_in_window' but stored as 'latest_timestamp_in_window'? Ensure correct:
    # Re-format latest timestamp from 'latest_timestamp_in_window' computed in agg_row was named 'latest_timestamp_in_window' as well.
    agg_df['latest_timestamp_in_window'] = pd.to_datetime(agg_df['latest_timestamp_in_window']).dt.tz_localize(None).astype(str)  # placeholder if needed
    # Better to recompute timestamp strings from original values:
    # Convert earliest/latest from epoch-aware strings: they were formatted above for earliest; for latest reformat properly:
