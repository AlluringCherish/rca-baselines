    tomcat03_jvm_metrics_window['is_low'] = tomcat03_jvm_metrics_window.apply(
        lambda r: (pd.notna(r['global_p5']) and r['value'] <= r['global_p5']), axis=1)

    tomcat03_jvm_metrics_window['sev_high'] = tomcat03_jvm_metrics_window.apply(
        lambda r: safe_div(r['value'], r['global_p95']), axis=1)
    tomcat03_jvm_metrics_window['sev_low'] = tomcat03_jvm_metrics_window.apply(
        lambda r: safe_div(r['global_p5'], r['value']), axis=1)

    # Aggregate per (cmdb_id, kpi_name)
    g = tomcat03_jvm_metrics_window.groupby(['cmdb_id','kpi_name'])
    agg = g.agg(
        sample_count_in_window = ('value','count'),
        min_value = ('value','min'),
        max_value = ('value','max'),
        mean_value = ('value','mean'),
        earliest_ts = ('dt','min'),
        latest_ts = ('dt','max'),
        global_p95 = ('global_p95','first'),
        global_p5  = ('global_p5','first'),
        breach_count = (lambda df: ((df['is_high']) | (df['is_low'])).sum())
    ).reset_index()

    # The above custom 'breach_count' agg may not be supported directly; recompute properly
    # Recompute using groupby apply to ensure correctness
    def agg_row(df):
        cmdb = df['cmdb_id'].iat[0]
        kpi = df['kpi_name'].iat[0]
        sample_count = int(df.shape[0])
        min_v = float(df['value'].min())
        max_v = float(df['value'].max())
        mean_v = float(df['value'].mean())
        earliest = df['dt'].min()
        latest = df['dt'].max()
        p95 = float(df['global_p95'].iat[0]) if pd.notna(df['global_p95'].iat[0]) else np.nan
        p5  = float(df['global_p5'].iat[0])  if pd.notna(df['global_p5'].iat[0])  else np.nan
        # breaches
