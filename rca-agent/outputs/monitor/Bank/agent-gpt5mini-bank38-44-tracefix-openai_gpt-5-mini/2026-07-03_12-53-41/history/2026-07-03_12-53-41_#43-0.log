import pandas as pd
import pytz

# timezone
tz = pytz.timezone('Asia/Shanghai')

# candidates and incident window
candidates = ['IG02','MG02','MG01','Tomcat02','Tomcat03','Tomcat04']
start = tz.localize(pd.to_datetime('2021-03-23 18:00:00'))
end = tz.localize(pd.to_datetime('2021-03-23 18:30:00'))

# Load and standardize metric, trace, log dataframes
df_metric = pd.read_csv('metric.csv')
df_metric = df_metric.rename(columns={'kpi_name': 'kpi_name'})
df_metric['source_file'] = 'metric.csv'

df_trace = pd.read_csv('trace.csv')
df_trace = df_trace.rename(columns={'trace_name': 'kpi_name'})
df_trace['source_file'] = 'trace.csv'

df_log = pd.read_csv('log.csv')
df_log = df_log.rename(columns={'log_name': 'kpi_name'})
df_log['source_file'] = 'log.csv'

# concat
df_all = pd.concat([df_metric, df_trace, df_log], ignore_index=True, sort=False)

# keep only candidates
df_all = df_all[df_all['cmdb_id'].isin(candidates)].copy()

# ensure numeric and timestamps
df_all['value'] = pd.to_numeric(df_all['value'], errors='coerce')
df_all['timestamp'] = pd.to_numeric(df_all['timestamp'], errors='coerce')
df_all['ts_dt'] = pd.to_datetime(df_all['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# common group keys
keys = ['source_file','cmdb_id','kpi_name']

def find_breaches(df_all, q=0.95):
    # 1) compute global quantile per group on full series (no time filter)
    thr = df_all.groupby(keys, as_index=False)['value'].quantile(q).rename(columns={'value': 'global_thr'})
    # 2) filter to incident window
    window_df = df_all[(df_all['ts_dt'] >= start) & (df_all['ts_dt'] <= end)].copy()
    if window_df.empty:
        return pd.DataFrame(columns=[
            'cmdb_id','source_file','kpi_name','global_thr','breach_timestamp','breach_value',
            'window_sample_count','count_anomalies'
        ])
    # window stats per group
    window_stats = window_df.groupby(keys, as_index=False).agg(
        window_sample_count = ('value','count'),
        window_min_timestamp = ('ts_dt','min'),
        window_max_timestamp = ('ts_dt','max'),
        window_min_value = ('value','min'),
        window_max_value = ('value','max'),
        window_mean = ('value','mean')
    )
    # merge threshold
    window_with_thr = window_df.merge(thr, on=keys, how='left')
    # anomalies where value > global_thr
    anoms = window_with_thr[window_with_thr['value'] > window_with_thr['global_thr']].copy()
    if anoms.empty:
        return pd.DataFrame(columns=[
            'cmdb_id','source_file','kpi_name','global_thr','breach_timestamp','breach_value',
            'window_sample_count','count_anomalies'
        ])
    # per-group anomaly counts and earliest anomaly timestamp
    anom_agg = anoms.groupby(keys, as_index=False).agg(
        count_anomalies = ('value','count'),
        earliest_anomaly_timestamp = ('ts_dt','min')
    )
    # get breach_value as the value at the earliest anomaly per group
    anoms_sorted = anoms.sort_values(by=keys + ['ts_dt'])
    anom_first = anoms_sorted.groupby(keys, as_index=False).first()[keys + ['ts_dt','value']]
    anom_first = anom_first.rename(columns={'ts_dt':'earliest_anomaly_timestamp','value':'breach_value'})
    # combine group info
    combined = anom_agg.merge(anom_first, on=keys, how='left')
    # attach threshold and window_sample_count
    combined = combined.merge(thr, on=keys, how='left')
    combined = combined.merge(window_stats[['source_file','cmdb_id','kpi_name','window_sample_count']], on=keys, how='left')
    # select and rename columns to match required output
    combined = combined.rename(columns={
        'global_thr':'global_p95' if q==0.95 else 'global_p90',
        'earliest_anomaly_timestamp':'breach_timestamp'
    })
    out_cols = ['cmdb_id','source_file','kpi_name',
                ('global_p95' if q==0.95 else 'global_p90'),
                'breach_timestamp','breach_value','window_sample_count','count_anomalies']
    # keep only relevant columns
    combined = combined[['cmdb_id','source_file','kpi_name', ('global_p95' if q==0.95 else 'global_p90'),
                         'breach_timestamp','breach_value','window_sample_count','count_anomalies']]
    # For consistency rename threshold col to 'global_p95' even if q==0.90 later (handled by caller)
    combined = combined.rename(columns={('global_p95' if q==0.95 else 'global_p90'):'global_p95'})
    return combined

# Try P95 first
breaches_p95 = find_breaches(df_all, q=0.95)

threshold_used = 'P95'
if breaches_p95.empty:
    # Try P90
    breaches_p90 = find_breaches(df_all, q=0.90)
    if breaches_p90.empty:
        result = pd.DataFrame(columns=[
            'cmdb_id','source_file','kpi_name','global_p95','breach_timestamp','breach_value',
            'window_sample_count','count_anomalies'
        ])
        threshold_used = 'NONE'
    else:
        # mark that P90 used (but keep column name global_p95 for compatibility)
        result = breaches_p90.copy()
        threshold_used = 'P90'
else:
    result = breaches_p95.copy()

# For each component select the single earliest breach across all source_files/KPIs
if not result.empty:
    # ensure breach_timestamp is datetime tz-aware
    result['breach_timestamp'] = pd.to_datetime(result['breach_timestamp'])
    earliest_per_component = result.sort_values(by='breach_timestamp', ascending=True).groupby('cmdb_id', as_index=False).first()
    # limit to up to one row per candidate component and sort by breach_timestamp ascending
    earliest_per_component = earliest_per_component.sort_values(by='breach_timestamp', ascending=True).head(6)
    # final columns and order as requested (global_p95 used as label even if it was actually P90)
    final = earliest_per_component[['cmdb_id','source_file','kpi_name','global_p95','breach_timestamp','breach_value','window_sample_count','count_anomalies']].reset_index(drop=True)
else:
    final = result  # empty df

# Output compact final result and which threshold was used
final, threshold_used
