def top_summaries(df, label_cols, n=3):
    if df.shape[0] == 0:
        return ["(none)"]
    rows = df.head(n)
    parts = []
    for _, r in rows.iterrows():
        if len(label_cols) == 2:
            parts.append(f"{r[label_cols[0]]}/{r[label_cols[1]]} (count={int(r['count'])}, mean={r['mean']})")
        else:
            parts.append(f"{r[label_cols[0]]} (count={int(r['count'])})")
    return parts

