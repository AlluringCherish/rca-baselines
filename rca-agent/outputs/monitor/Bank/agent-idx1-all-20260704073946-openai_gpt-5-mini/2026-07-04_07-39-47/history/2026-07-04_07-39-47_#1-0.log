# Build a plain-English summary string from existing kernel variables and display it.
import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Helper to format numbers compactly
def fmt_num(v):
    if pd.isna(v) or v is None:
        return "NA"
    try:
        v = float(v)
    except:
        return str(v)
    if abs(v) >= 1e6:
        return f"{v:.6e}"
    elif abs(v) >= 1:
        s = f"{v:.6f}".rstrip('0').rstrip('.')
        return s
    else:
        s = f"{v:.6f}".rstrip('0').rstrip('.')
        return s or "0"

# Locate expected variables
gv = globals()
missing = []
for name in ('metric_window','metric_anoms','agg_anom_summary'):
    if name not in gv:
        missing.append(name)

# Prefer agg_anom_summary_top if available for display
agg_df = gv.get('agg_anom_summary')
if agg_df is None and 'agg_anom_summary_top' in gv:
    agg_df = gv['agg_anom_summary_top']

lines = []
if missing:
    lines.append("Cannot produce full summary because the following kernel variable(s) are missing:")
    for m in missing:
        lines.append(f" - {m}")
    lines.append("Please run the anomaly detection steps to populate these variables.")
else:
    # Basic counts
    rows_in_metric_window = int(gv['metric_window'].shape[0])
    total_anom_rows = int(gv['metric_anoms'].shape[0])
    num_anom_groups = int(agg_df.shape[0]) if agg_df is not None else 0

    lines.append("Metric anomaly detection summary (window 2021-03-04 18:00:00 to 2021-03-04 18:30:00 Asia/Shanghai):")
    lines.append(f"- Rows in metric_window: {rows_in_metric_window}")
    lines.append(f"- Total anomaly rows detected (metric_anoms): {total_anom_rows}")
    lines.append(f"- Number of component-KPI groups with anomalies: {num_anom_groups}")
    lines.append("")

    if agg_df is None or agg_df.empty:
        lines.append("No anomalies found in the window (agg_anom_summary is empty).")
    else:
        lines.append("Top anomaly groups (up to 20) sorted by anomaly_count:")
        top = agg_df.sort_values('anomaly_count', ascending=False).head(20)
        for _, r in top.iterrows():
            cmdb = r.get('cmdb_id', '')
            kpi = r.get('kpi_name', '')
            ac = int(r.get('anomaly_count', 0))
            ets = r.get('earliest_anom_timestamp', None)
            # Format earliest timestamp if epoch-like, else keep as-is
            if pd.isna(ets) or ets is None:
                ets_str = "NA"
            else:
                try:
                    # if it's a string with date, use directly
                    if isinstance(ets, str) and "-" in ets:
                        ets_str = ets
                    else:
                        ets_str = pd.to_datetime(int(ets), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
                except:
                    ets_str = str(ets)
            maxv = fmt_num(r.get('max_value'))
            minv = fmt_num(r.get('min_value'))
            p95 = fmt_num(r.get('p95'))
            p5 = fmt_num(r.get('p5'))
            sev = r.get('severity_ratio', None)
            sev_str = fmt_num(sev) if sev is not None else "NA"
            breach = r.get('breach_pct', None)
            breach_str = (f"{round(float(breach),4)}%") if (breach is not None and not pd.isna(breach)) else "NA"

            lines.append(f"  - {cmdb} | {kpi}: anomalies={ac}, earliest={ets_str}, max={maxv}, min={minv}, p95={p95}, p5={p5}, severity_ratio={sev_str}, breach_pct={breach_str}")

lines.append("")
lines.append("Note: Anomalies were marked when value >= p95 or value <= p5 using global thresholds from agg_metric (computed across full metric.csv).")

final_summary = "\n".join(lines)
final_summary
