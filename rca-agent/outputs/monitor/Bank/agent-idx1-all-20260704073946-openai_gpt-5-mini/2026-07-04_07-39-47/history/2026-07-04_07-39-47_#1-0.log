import pandas as pd
import numpy as np

# Reuse existing dataframes: metric_df, trace_df, log_df
# Ensure 'value' columns are numeric (coerce non-numeric to NaN)
metric_df['value'] = pd.to_numeric(metric_df['value'], errors='coerce')
trace_df['value'] = pd.to_numeric(trace_df['value'], errors='coerce')
log_df['value'] = pd.to_numeric(log_df['value'], errors='coerce')

# Helper to build aggregated table given df and group cols + value col
def aggregate_percentiles(df, group_cols, value_col='value'):
    if value_col not in df.columns or df[value_col].dropna().empty:
        # Return empty dataframe with expected columns
        cols = group_cols + ['count', 'p95', 'p90', 'p50', 'p5']
        return pd.DataFrame(columns=cols)
    g = df.groupby(group_cols)[value_col]
    agg = g.agg(
        count='count',
        p95=lambda x: x.quantile(0.95),
        p90=lambda x: x.quantile(0.90),
        p50=lambda x: x.quantile(0.50),
        p5=lambda x: x.quantile(0.05),
    ).reset_index()
    # Ensure count is int and numeric cols rounded for compactness
    agg['count'] = agg['count'].astype(int)
    for c in ['p95','p90','p50','p5']:
        agg[c] = agg[c].astype(float).round(6)
    return agg

# 1) metric.csv aggregation
agg_metric = aggregate_percentiles(metric_df, ['cmdb_id', 'kpi_name'], 'value')

# Top 20 by count desc for display
agg_metric_top = agg_metric.sort_values('count', ascending=False).head(20)[
    ['cmdb_id', 'kpi_name', 'count', 'p95', 'p90', 'p50', 'p5']
]

# 2) trace.csv aggregation
agg_trace = aggregate_percentiles(trace_df, ['cmdb_id', 'trace_name'], 'value')
agg_trace_top = agg_trace.sort_values('count', ascending=False).head(20)[
    ['cmdb_id', 'trace_name', 'count', 'p95', 'p90', 'p50', 'p5']
]

# 3) log.csv aggregation
agg_log = aggregate_percentiles(log_df, ['cmdb_id', 'log_name'], 'value')
agg_log_top = agg_log.sort_values('count', ascending=False).head(20)[
    ['cmdb_id', 'log_name', 'count', 'p95', 'p90', 'p50', 'p5']
]

# Notes if any aggregated table is empty
notes = []
if agg_metric.empty:
    notes.append("agg_metric is empty (no numeric 'value' in metric.csv).")
if agg_trace.empty:
    notes.append("agg_trace is empty (no numeric 'value' in trace.csv).")
if agg_log.empty:
    notes.append("agg_log is empty (no numeric 'value' in log.csv).")
if not notes:
    notes = ["All aggregated tables computed successfully."]

# Display compact results (variables)
agg_metric, agg_metric_top, agg_trace, agg_trace_top, agg_log, agg_log_top, notes
