import pandas as pd
import pytz
from datetime import datetime

# Reuse existing variables if present, else load metric.csv
if 'metric_df' not in globals() or metric_df is None:
    try:
        metric_df = pd.read_csv("metric.csv")
    except Exception as e:
        error_note = f"Missing required input: metric.csv could not be loaded ({e})."
        error_note

# Check agg_metric presence
if 'agg_metric' not in globals() or agg_metric is None or agg_metric.empty:
    error_note = "Missing required input: agg_metric (precomputed thresholds) is not available in the kernel."
    error_note
else:
    # Ensure metric_df exists and is a DataFrame
    if 'metric_df' not in globals() or metric_df is None or metric_df.empty:
        error_note = "Missing required input: metric.csv (metric_df) is not available or empty."
        error_note
    else:
        # Set timezone (UTC+8)
        tz = pytz.timezone('Asia/Shanghai')

        # 1) Filter metric.csv to the incident window and save as metric_window
        start_local = tz.localize(datetime(2021, 3, 4, 18, 0, 0))
        end_local = tz.localize(datetime(2021, 3, 4, 18, 30, 0))
        start_ts = int(start_local.astimezone(pytz.UTC).timestamp())
        end_ts = int(end_local.astimezone(pytz.UTC).timestamp())

        # Ensure value numeric
        metric_df['value'] = pd.to_numeric(metric_df['value'], errors='coerce')

        metric_window = metric_df[(metric_df['timestamp'] >= start_ts) & (metric_df['timestamp'] <= end_ts)].copy()

        # 2) Join metric_window with agg_metric on (cmdb_id, kpi_name) to attach p95 and p5
        required_thresh_cols = {'cmdb_id','kpi_name','p95','p5'}
        if not required_thresh_cols.issubset(set(agg_metric.columns)):
            error_note = "agg_metric does not contain required columns: cmdb_id, kpi_name, p95, p5."
            error_note
        else:
            joined = metric_window.merge(agg_metric[['cmdb_id','kpi_name','p95','p5']],
                                         on=['cmdb_id','kpi_name'], how='left')

            # 2b) Skip rows whose group lacks p95/p5
            joined_thresh = joined.dropna(subset=['p95','p5']).copy()

            # 3) Mark anomalies where value >= p95 OR value <= p5
            metric_anoms = joined_thresh[(joined_thresh['value'] >= joined_thresh['p95']) |
                                         (joined_thresh['value'] <= joined_thresh['p5'])].copy()

            # 4 & 5) Aggregate metric_anoms by (cmdb_id, kpi_name)
            if metric_anoms.empty:
                agg_anom_summary = pd.DataFrame(columns=[
                    'cmdb_id','kpi_name','anomaly_count','earliest_anom_timestamp',
                    'max_value','min_value','p95','p5','severity_ratio','breach_pct'
                ])
            else:
                g = metric_anoms.groupby(['cmdb_id','kpi_name'])
                agg = g.agg(
                    anomaly_count = ('value', 'count'),
                    earliest_anom_timestamp = ('timestamp', 'min'),
                    max_value = ('value', 'max'),
                    min_value = ('value', 'min'),
                    p95 = ('p95', 'first'),
                    p5 = ('p5', 'first'),
                ).reset_index()

                # compute severity_ratio and breach_pct safely
                def compute_sev(row):
                    try:
                        p95v = float(row['p95'])
                        if p95v > 0:
                            return float(row['max_value']) / p95v
                    except:
                        pass
                    return None

                def compute_breach(row):
                    try:
                        p95v = float(row['p95'])
                        if p95v > 0:
                            return (float(row['max_value']) - p95v) / p95v * 100.0
                    except:
                        pass
                    return None

                agg['severity_ratio'] = agg.apply(compute_sev, axis=1)
                agg['breach_pct'] = agg.apply(compute_breach, axis=1)

                # format earliest timestamp to Asia/Shanghai string
                agg['earliest_anom_timestamp'] = agg['earliest_anom_timestamp'].apply(
                    lambda ts: pd.to_datetime(int(ts), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
                )

                # Round numeric columns for compactness
                for col in ['max_value','min_value','p95','p5']:
                    agg[col] = agg[col].astype(float).round(6)
                agg['severity_ratio'] = agg['severity_ratio'].apply(lambda v: round(v,6) if v is not None else None)
                agg['breach_pct'] = agg['breach_pct'].apply(lambda v: round(v,4) if v is not None else None)

                agg_anom_summary = agg[
                    ['cmdb_id','kpi_name','anomaly_count','earliest_anom_timestamp',
                     'max_value','min_value','p95','p5','severity_ratio','breach_pct']
                ].sort_values('anomaly_count', ascending=False).reset_index(drop=True)

            # keep top 20 for compact display
            agg_anom_summary_top = agg_anom_summary.head(20)

            # 6) Build compact result summary
            rows_in_metric_window = int(metric_window.shape[0])
            total_anom_rows = int(metric_anoms.shape[0])
            num_anom_groups = int(agg_anom_summary.shape[0])

            summary_info = pd.DataFrame([{
                'rows_in_metric_window': rows_in_metric_window,
                'total_anom_rows': total_anom_rows,
                'num_anom_groups': num_anom_groups
            }])

            # Display compact results (variable names)
            summary_info, agg_anom_summary_top
