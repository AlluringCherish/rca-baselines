import pandas as pd
import pytz
from datetime import datetime

# Preconditions: reuse metric_df and agg_metric from kernel
note = None
tz = pytz.timezone('Asia/Shanghai')

if 'metric_df' not in globals() or metric_df is None or metric_df.empty:
    note = "metric.csv (metric_df) is missing or empty. Cannot proceed."
elif 'agg_metric' not in globals() or agg_metric is None or agg_metric.empty:
    note = "agg_metric is missing or empty. Cannot proceed."
else:
    # 1) Filter metric.csv to the incident time window (UTC+8)
    start_local = tz.localize(datetime(2021, 3, 4, 18, 0, 0))
    end_local = tz.localize(datetime(2021, 3, 4, 18, 30, 0))
    # convert to UTC epoch seconds (telemetry timestamps are epoch seconds)
    start_ts = int(start_local.astimezone(pytz.UTC).timestamp())
    end_ts = int(end_local.astimezone(pytz.UTC).timestamp())
    metric_window = metric_df[(metric_df['timestamp'] >= start_ts) & (metric_df['timestamp'] <= end_ts)].copy()
    
    # 2) Join metric_window with agg_metric on (cmdb_id, kpi_name) to bring p95 and p5
    # Ensure agg_metric has necessary columns
    join_cols = ['cmdb_id', 'kpi_name']
    thresh_cols = ['p95', 'p5']
    if not set(join_cols + thresh_cols).issubset(set(agg_metric.columns)):
        note = "agg_metric does not contain required threshold columns (p95, p5)."
    else:
        joined = metric_window.merge(agg_metric[join_cols + thresh_cols], on=join_cols, how='left')
        
        # 3) Mark anomaly rows where value >= p95 OR value <= p5 (only where thresholds exist)
        # Ensure numeric
        joined['value'] = pd.to_numeric(joined['value'], errors='coerce')
        # Keep rows where at least one threshold exists (p95 and p5 not null). Instruction: include rows where p95 or p5 exist; skip groups without thresholds.
        # We'll require both p95 and p5 to be present to compute breaches per instruction #3 ("Include rows where p95 or p5 exist; skip groups without thresholds.")
        joined_thresh = joined.dropna(subset=['p95', 'p5']).copy()
        if joined_thresh.empty:
            metric_anoms = joined_thresh.iloc[0:0].copy()  # empty dataframe
        else:
            metric_anoms = joined_thresh[(joined_thresh['value'] >= joined_thresh['p95']) | (joined_thresh['value'] <= joined_thresh['p5'])].copy()
        
        # 5) Aggregate metric_anoms by (cmdb_id, kpi_name)
        if metric_anoms.empty:
            agg_anom_summary = pd.DataFrame(columns=[
                'cmdb_id','kpi_name','anomaly_count','earliest_anom_timestamp',
                'max_value','min_value','p95','p5','severity_ratio','breach_pct'
            ])
        else:
            g = metric_anoms.groupby(['cmdb_id','kpi_name'])
            agg = g.agg(
                anomaly_count = ('value', 'count'),
                earliest_anom_timestamp = ('timestamp', 'min'),
                max_value = ('value', 'max'),
                min_value = ('value', 'min'),
                p95 = ('p95', 'first'),
                p5 = ('p5', 'first'),
            ).reset_index()
            # compute severity_ratio and breach_pct
            def compute_severity(row):
                p95v = row['p95']
                maxv = row['max_value']
                if pd.isna(p95v) or p95v == 0:
                    return None
                return float(maxv) / float(p95v)
            def compute_breach_pct(row):
                p95v = row['p95']
                maxv = row['max_value']
                if pd.isna(p95v) or p95v == 0:
                    return None
                return (float(maxv) - float(p95v)) / float(p95v) * 100.0
            agg['severity_ratio'] = agg.apply(compute_severity, axis=1)
            agg['breach_pct'] = agg.apply(compute_breach_pct, axis=1)
            # format earliest timestamp into Asia/Shanghai human-readable string
            agg['earliest_anom_timestamp'] = agg['earliest_anom_timestamp'].apply(
                lambda ts: pd.to_datetime(int(ts), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
            )
            # Round numeric columns for compactness
            agg['max_value'] = agg['max_value'].astype(float).round(6)
            agg['min_value'] = agg['min_value'].astype(float).round(6)
            agg['p95'] = agg['p95'].astype(float).round(6)
            agg['p5'] = agg['p5'].astype(float).round(6)
            agg['severity_ratio'] = agg['severity_ratio'].apply(lambda v: round(v,6) if v is not None else None)
            agg['breach_pct'] = agg['breach_pct'].apply(lambda v: round(v,4) if v is not None else None)
            
            agg_anom_summary = agg[
                ['cmdb_id','kpi_name','anomaly_count','earliest_anom_timestamp',
                 'max_value','min_value','p95','p5','severity_ratio','breach_pct']
            ].sort_values('anomaly_count', ascending=False).reset_index(drop=True)
        
        # keep final top 20
        agg_anom_summary_top = agg_anom_summary.head(20)

# Final returned compact result per rules:
# If note exists, return it; otherwise return metric_window shape, metric_anoms shape, and top aggregated anomaly table
if note:
    note
else:
    metric_window.shape, metric_anoms.shape, agg_anom_summary_top
