import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Load CSV files into memory (reusing variable names if rerun in the same kernel)
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")
log_df = pd.read_csv("log.csv")
error_df = pd.read_csv("error_logs.csv")

# Helper to convert epoch seconds to Asia/Shanghai datetime string (compact)
def ts_to_shanghai_str(ts):
    if pd.isna(ts):
        return None
    return pd.to_datetime(int(ts), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

# Helper to build top-k list (formatted) for a given dataframe and column
def top_values_list(df, col, topn=20):
    if col not in df.columns:
        return []
    vc = df[col].value_counts().head(topn)
    return [f"{idx} ({int(cnt)})" for idx, cnt in vc.items()]

# Build summaries for each file
summaries = []

# metric.csv summary
metric_total = len(metric_df)
metric_min_ts = metric_df['timestamp'].min() if 'timestamp' in metric_df.columns else None
metric_max_ts = metric_df['timestamp'].max() if 'timestamp' in metric_df.columns else None
metric_cmdbs = list(pd.Series(metric_df['cmdb_id'].dropna().unique())[:50]) if 'cmdb_id' in metric_df.columns else []
metric_top_kpis = top_values_list(metric_df, 'kpi_name', topn=20)

summaries.append({
    "file_name": "metric.csv",
    "total_rows": metric_total,
    "min_timestamp": ts_to_shanghai_str(metric_min_ts),
    "max_timestamp": ts_to_shanghai_str(metric_max_ts),
    "unique_cmdb_ids": metric_cmdbs,
    "top_kpis": metric_top_kpis
})

# trace.csv summary
trace_total = len(trace_df)
trace_min_ts = trace_df['timestamp'].min() if 'timestamp' in trace_df.columns else None
trace_max_ts = trace_df['timestamp'].max() if 'timestamp' in trace_df.columns else None
trace_cmdbs = list(pd.Series(trace_df['cmdb_id'].dropna().unique())[:50]) if 'cmdb_id' in trace_df.columns else []
trace_top = top_values_list(trace_df, 'trace_name', topn=20)

summaries.append({
    "file_name": "trace.csv",
    "total_rows": trace_total,
    "min_timestamp": ts_to_shanghai_str(trace_min_ts),
    "max_timestamp": ts_to_shanghai_str(trace_max_ts),
    "unique_cmdb_ids": trace_cmdbs,
    "top_kpis": trace_top
})

# log.csv summary
log_total = len(log_df)
log_min_ts = log_df['timestamp'].min() if 'timestamp' in log_df.columns else None
log_max_ts = log_df['timestamp'].max() if 'timestamp' in log_df.columns else None
log_cmdbs = list(pd.Series(log_df['cmdb_id'].dropna().unique())[:50]) if 'cmdb_id' in log_df.columns else []
log_top = top_values_list(log_df, 'log_name', topn=20)

summaries.append({
    "file_name": "log.csv",
    "total_rows": log_total,
    "min_timestamp": ts_to_shanghai_str(log_min_ts),
    "max_timestamp": ts_to_shanghai_str(log_max_ts),
    "unique_cmdb_ids": log_cmdbs,
    "top_kpis": log_top
})

# error_logs.csv summary
err_total = len(error_df)
err_min_ts = error_df['timestamp'].min() if 'timestamp' in error_df.columns else None
err_max_ts = error_df['timestamp'].max() if 'timestamp' in error_df.columns else None
err_cmdbs = list(pd.Series(error_df['cmdb_id'].dropna().unique())[:50]) if 'cmdb_id' in error_df.columns else []
err_top_msgs = top_values_list(error_df, 'message', topn=20)

summaries.append({
    "file_name": "error_logs.csv",
    "total_rows": err_total,
    "min_timestamp": ts_to_shanghai_str(err_min_ts),
    "max_timestamp": ts_to_shanghai_str(err_max_ts),
    "unique_cmdb_ids": err_cmdbs,
    "top_kpis": err_top_msgs
})

# Present compact summary as a pandas DataFrame (compact fields only)
summary_df = pd.DataFrame(summaries)[["file_name", "total_rows", "min_timestamp", "max_timestamp", "unique_cmdb_ids", "top_kpis"]]

summary_df
