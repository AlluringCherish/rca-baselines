        display_df = agg_anom_summary.head(20) if isinstance(agg_anom_summary, pd.DataFrame) else pd.DataFrame()
    rows_in_metric_window = int(metric_window.shape[0]) if hasattr(metric_window, 'shape') else 0
    total_anom_rows = int(metric_anoms.shape[0]) if hasattr(metric_anoms, 'shape') else 0
    num_anom_groups = int(agg_anom_summary.shape[0]) if hasattr(agg_anom_summary, 'shape') else 0

    lines = []
    lines.append("Metric anomaly detection summary (window 2021-03-04 18:00:00 to 2021-03-04 18:30:00 Asia/Shanghai):")
    lines.append(f"- Rows in metric_window: {rows_in_metric_window}")
    lines.append(f"- Total anomaly rows detected (metric_anoms): {total_anom_rows}")
    lines.append(f"- Number of component-KPI groups with anomalies: {num_anom_groups}")
    lines.append("")

    if display_df is None or display_df.empty:
        lines.append("No anomaly groups to display (agg_anom_summary is empty).")
    else:
        lines.append("Top anomaly groups (up to 20) sorted by anomaly_count:")
        # Show up to 20 rows
        for _, r in display_df.head(20).iterrows():
            cmdb = r.get('cmdb_id', '')
            kpi = r.get('kpi_name', '')
            ac = int(r.get('anomaly_count', 0))
            ets = r.get('earliest_anom_timestamp', 'NA')
            # If earliest is epoch-like integer, convert to Asia/Shanghai string
            if not isinstance(ets, str):
                try:
                    ets = pd.to_datetime(int(ets), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')
                except:
                    ets = str(ets)
            maxv = fmt_num(r.get('max_value'))
            minv = fmt_num(r.get('min_value'))
            p95 = fmt_num(r.get('p95'))
            p5 = fmt_num(r.get('p5'))
            sev = fmt_num(r.get('severity_ratio')) if r.get('severity_ratio') is not None else "NA"
            breach = r.get('breach_pct')
            breach_str = (f"{round(float(breach),4)}%") if (breach is not None and not pd.isna(breach)) else "NA"
            lines.append(f"  - {cmdb} | {kpi}: anomalies={ac}, earliest={ets}, max={maxv}, min={minv}, p95={p95}, p5={p5}, severity_ratio={sev}, breach_pct={breach_str}")

    lines.append("")
    lines.append("Note: Anomalies were flagged when value >= p95 or value <= p5 using global thresholds from agg_metric (computed over full metric.csv).")

    summary_text = "\n".join(lines)

# Display the plain-English summary string
summary_text
