import os
import pandas as pd
import pytz

# Reuse variable names where appropriate
tz = pytz.timezone('Asia/Shanghai')  # per rule 10 (UTC+8) - kept for compliance though timestamps remain integers

# Filenames
f_metric = "metric.csv"
f_trace = "trace.csv"
f_log = "log.csv"
f_err = "error_logs.csv"

# Load CSVs into DataFrames (keep in memory, no files written)
df_metric = pd.read_csv(f_metric)
df_trace = pd.read_csv(f_trace)
df_log = pd.read_csv(f_log)
df_err = pd.read_csv(f_err)

# Ensure types
df_metric['timestamp'] = df_metric['timestamp'].astype(int)
df_trace['timestamp'] = df_trace['timestamp'].astype(int)
df_log['timestamp'] = df_log['timestamp'].astype(int)
df_err['timestamp'] = df_err['timestamp'].astype(int)

# Coerce value columns to numeric where present
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')
df_trace['value'] = pd.to_numeric(df_trace['value'], errors='coerce')
df_log['value'] = pd.to_numeric(df_log['value'], errors='coerce')

# 1) metric.csv summary: group by cmdb_id and kpi_name
metric_grp = df_metric.groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
metric_summary = metric_grp.agg(
    count_points=('value', 'count'),
    min_timestamp=('value', lambda x: df_metric.loc[x.index, 'timestamp'].min()),
    max_timestamp=('value', lambda x: df_metric.loc[x.index, 'timestamp'].max()),
    p95_value=('value', lambda x: x.quantile(0.95)),
    median_value=('value', 'median')
)
metric_summary = metric_summary.sort_values('count_points', ascending=False).head(20)

# 2) trace.csv summary: group by cmdb_id and trace_name
trace_grp = df_trace.groupby(['cmdb_id', 'trace_name'], as_index=False)['value']
trace_summary = trace_grp.agg(
    count_points=('value', 'count'),
    min_timestamp=('value', lambda x: df_trace.loc[x.index, 'timestamp'].min()),
    max_timestamp=('value', lambda x: df_trace.loc[x.index, 'timestamp'].max()),
    p95_value=('value', lambda x: x.quantile(0.95)),
    median_value=('value', 'median')
)
trace_summary = trace_summary.sort_values('count_points', ascending=False).head(20)

# 3) log.csv summary: group by cmdb_id and log_name
log_grp = df_log.groupby(['cmdb_id', 'log_name'], as_index=False)['value']
log_summary = log_grp.agg(
    count_points=('value', 'count'),
