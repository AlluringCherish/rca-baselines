            return "NA"
        try:
            if float(x).is_integer():
                return f"{int(x):,}"
        except Exception:
            pass
        x = float(x)
        if abs(x) >= 1000:
            return f"{x:,.0f}"
        if abs(x) >= 1:
            return f"{x:,.3f}".rstrip('0').rstrip('.')
        return f"{x:.6f}".rstrip('0').rstrip('.')
    
