import pandas as pd
import numpy as np
import pytz

# Reuse variables from kernel: metric_df, trace_df, log_df, error_df,
# metric_counts_df, trace_counts_df, log_counts_df

# Ensure timezone (UTC+8) and window boundaries
tz = pytz.timezone('Asia/Shanghai')
window_start = pd.Timestamp('2021-03-07 07:30:00').tz_localize(tz)
window_end = pd.Timestamp('2021-03-07 08:00:00').tz_localize(tz)
tiny_eps = 1e-9

# Prepare windowed DataFrames and keep them for later steps
metric_win = metric_df[(metric_df['_dt'] >= window_start) & (metric_df['_dt'] <= window_end)].copy()
trace_win = trace_df[(trace_df['_dt'] >= window_start) & (trace_df['_dt'] <= window_end)].copy()
log_win = log_df[(log_df['_dt'] >= window_start) & (log_df['_dt'] <= window_end)].copy()
error_win = error_df[(error_df['_dt'] >= window_start) & (error_df['_dt'] <= window_end)].copy()

# Helper function to compute anomalies given a window df and global p95 table
def compute_anomalies(window_df, global_p95_df, key_name, value_col='value'):
    # Merge to bring p95 into each row (inner join keeps only pairs with stored global p95)
    merged = window_df.merge(global_p95_df[['cmdb_id', key_name, 'p95']],
                             on=['cmdb_id', key_name], how='inner', validate='m:1')
    # Determine anomaly: if p95 == 0 => value > 0 else value > p95
    merged['is_anomaly'] = np.where(merged['p95'] == 0, merged[value_col] > 0, merged[value_col] > merged['p95'])
    # Group and aggregate
    grp = merged.groupby(['cmdb_id', key_name], dropna=False)
    agg = grp.agg(
        total_points_in_window=(value_col, 'count'),
        anomaly_count=('is_anomaly', 'sum'),
        earliest_anomaly_timestamp=(lambda df: df.loc[df['is_anomaly'], '_dt'].min() if df['is_anomaly'].any() else pd.NaT),
        max_value_in_window=(value_col, 'max'),
        p95=('p95', 'first')
    ).reset_index()
    # Severity calculation
    agg['severity'] = agg['max_value_in_window'] / agg['p95'].replace(0, tiny_eps)
    # Keep only rows with at least one anomaly
    agg = agg[agg['anomaly_count'] > 0].copy()
    # Round numeric columns for compactness
    agg['p95'] = agg['p95'].round(6)
    agg['max_value_in_window'] = agg['max_value_in_window'].round(6)
    agg['severity'] = agg['severity'].round(6)
    # Sort by anomaly_count desc and return full aggregated table and top-20 for display
    agg = agg.sort_values(['anomaly_count', 'severity'], ascending=[False, False]).reset_index(drop=True)
    return merged, agg

# Compute for metric.csv
metric_merged_win, metric_anomalies = compute_anomalies(metric_win, metric_counts_df, 'kpi_name')

# Compute for trace.csv
trace_merged_win, trace_anomalies = compute_anomalies(trace_win, trace_counts_df, 'trace_name')

# Compute for log.csv
log_merged_win, log_anomalies = compute_anomalies(log_win, log_counts_df, 'log_name')

# Prepare display tables (top 20 as requested, selected columns and ordered)
