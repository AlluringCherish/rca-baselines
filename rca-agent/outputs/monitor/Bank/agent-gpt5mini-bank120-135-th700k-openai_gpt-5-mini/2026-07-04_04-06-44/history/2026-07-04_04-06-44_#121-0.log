import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Load CSVs (they are in current working directory)
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')
df_log = pd.read_csv('log.csv')
df_error = pd.read_csv('error_logs.csv')

# Helper to convert timestamp seconds to timezone-aware ISO strings (compact)
def ts_range(col):
    if col.empty:
        return (None, None)
    dt = pd.to_datetime(col, unit='s', utc=True').dt.tz_convert(tz)
    mn = dt.min().isoformat()
    mx = dt.max().isoformat()
    return mn, mx

# Add datetime columns (kept as variables for potential reuse)
if 'timestamp' in df_metric.columns:
    dt_metric = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    dt_metric = pd.Series(dtype='datetime64[ns]')

if 'timestamp' in df_trace.columns:
    dt_trace = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    dt_trace = pd.Series(dtype='datetime64[ns]')

if 'timestamp' in df_log.columns:
    dt_log = pd.to_datetime(df_log['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    dt_log = pd.Series(dtype='datetime64[ns]')

if 'timestamp' in df_error.columns:
    dt_error = pd.to_datetime(df_error['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    dt_error = pd.Series(dtype='datetime64[ns]')

# Summaries helper
def basic_summary(df, dt_col):
    total_rows = int(df.shape[0])
    mn, mx = (None, None)
    if not dt_col.empty:
        mn = dt_col.min().isoformat()
        mx = dt_col.max().isoformat()
    unique_cmdb = sorted(df['cmdb_id'].dropna().unique().tolist()) if 'cmdb_id' in df.columns else []
    unique_cmdb_count = len(unique_cmdb)
    return total_rows, mn, mx, unique_cmdb, unique_cmdb_count

metric_rows, metric_min, metric_max, metric_cmdbs, metric_cmdb_count = basic_summary(df_metric, dt_metric)
trace_rows, trace_min, trace_max, trace_cmdbs, trace_cmdb_count = basic_summary(df_trace, dt_trace)
log_rows, log_min, log_max, log_cmdbs, log_cmdb_count = basic_summary(df_log, dt_log)
err_rows, err_min, err_max, err_cmdbs, err_cmdb_count = basic_summary(df_error, dt_error)

# Top pairs computations (limit to top 20)
def top_pairs(df, cols, topn=20):
    if not set(cols).issubset(df.columns) or df.empty:
        return []
    grp = df.groupby(cols).size().reset_index(name='count').sort_values('count', ascending=False).head(topn)
    # Convert to list of dicts for JSON-friendly output (compact)
    return grp.to_dict(orient='records')

metric_top_pairs = top_pairs(df_metric, ['cmdb_id', 'kpi_name'], topn=20)
trace_top_pairs = top_pairs(df_trace, ['cmdb_id', 'trace_name'], topn=20)
log_top_pairs = top_pairs(df_log, ['cmdb_id', 'log_name'], topn=20)

# error_logs: top (cmdb_id, message) pairs and aggregated per-cmdb_id counts + sample messages
if not df_error.empty and set(['cmdb_id', 'message']).issubset(df_error.columns):
    err_top_pairs = df_error.groupby(['cmdb_id', 'message']).size().reset_index(name='count') \
                    .sort_values('count', ascending=False).head(20).to_dict(orient='records')
    err_counts_per_cmdb = df_error.groupby('cmdb_id').size().reset_index(name='count') \
                            .sort_values('count', ascending=False)
    # sample up to 5 distinct messages per cmdb_id
    samples = df_error.groupby('cmdb_id')['message'].unique().apply(lambda arr: arr[:5]).reset_index()
    # Merge counts and samples
    err_per_cmdb = err_counts_per_cmdb.merge(samples, on='cmdb_id', how='left')
    err_per_cmdb = err_per_cmdb.rename(columns={'message': 'sample_messages'})
    # Convert to list of compact dicts
    err_per_cmdb_list = err_per_cmdb.to_dict(orient='records')
else:
    err_top_pairs = []
    err_per_cmdb_list = []

# Build compact JSON-friendly summary dictionary
summary = {
    'metric': {
        'total_rows': metric_rows,
        'time_range': {'min': metric_min, 'max': metric_max},
        'unique_cmdb_ids': metric_cmdbs,
        'unique_cmdb_count': metric_cmdb_count,
        'top_20_cmdb_kpi_pairs': metric_top_pairs  # list of dicts: cmdb_id, kpi_name, count
    },
    'trace': {
        'total_rows': trace_rows,
        'time_range': {'min': trace_min, 'max': trace_max},
        'unique_cmdb_ids': trace_cmdbs,
        'unique_cmdb_count': trace_cmdb_count,
        'top_20_cmdb_trace_pairs': trace_top_pairs  # list of dicts: cmdb_id, trace_name, count
    },
    'log': {
        'total_rows': log_rows,
        'time_range': {'min': log_min, 'max': log_max},
        'unique_cmdb_ids': log_cmdbs,
        'unique_cmdb_count': log_cmdb_count,
        'top_20_cmdb_log_pairs': log_top_pairs  # list of dicts: cmdb_id, log_name, count
    },
    'error_logs': {
        'total_rows': err_rows,
        'time_range': {'min': err_min, 'max': err_max},
        'unique_cmdb_ids': err_cmdbs,
        'unique_cmdb_count': err_cmdb_count,
        'top_20_cmdb_message_pairs': err_top_pairs,  # list of dicts: cmdb_id, message, count
        'counts_per_cmdb_with_samples': err_per_cmdb_list  # list of dicts: cmdb_id, count, sample_messages (<=5)
    }
}

