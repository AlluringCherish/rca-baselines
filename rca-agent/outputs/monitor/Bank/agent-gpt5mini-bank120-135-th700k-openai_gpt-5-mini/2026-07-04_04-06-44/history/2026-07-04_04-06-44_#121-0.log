import pandas as pd
import numpy as np
import pytz

# reuse df_metric if present, otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

sh = pytz.timezone('Asia/Shanghai')

# Ensure numeric and timestamps
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')
df_metric['ts_utc'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)
df_metric['ts_sh'] = df_metric['ts_utc'].dt.tz_convert(sh)

# 1) Compute global P95 per pair using full series (before filtering)
global_p95 = (
    df_metric
    .dropna(subset=['value'])
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_p95'})
)

# 2) Filter to incident window (inclusive) in UTC+8
window_start_sh = pd.Timestamp('2021-03-25 02:30:00').tz_localize(sh)
window_end_sh = pd.Timestamp('2021-03-25 03:00:00').tz_localize(sh)
df_window = df_metric[(df_metric['ts_sh'] >= window_start_sh) & (df_metric['ts_sh'] <= window_end_sh)].copy()

# 3) Merge global_p95 and mark strict anomalies (value > global_p95)
df_win = df_window.merge(global_p95, on=['cmdb_id', 'kpi_name'], how='left')
df_win['is_anom_strict'] = df_win['value'] > df_win['global_p95']

# helper to compute consecutive runs per group
def compute_runs(g):
    # g must be sorted by timestamp
    g = g.sort_values('timestamp').reset_index(drop=True)
    pts = int(g.shape[0])
    anomaly_count = int(g['is_anom_strict'].sum())
    max_value = g['value'].max() if pts>0 else None
    # earliest anomaly timestamp strict
    if anomaly_count == 0:
        earliest_anom_ts = None
        longest_run = 0
        longest_run_start_ts = None
    else:
        first_idx = g['is_anom_strict'].idxmax()  # first True index
        earliest_anom_ts = g.loc[first_idx, 'ts_sh']
        # compute diffs in seconds
        g['ts_diff'] = g['timestamp'].diff().fillna(9999).astype(int)
        # new sequence starts when is_anom_strict is True and either previous was not anomaly or time diff != 60
        g['prev_is_anom'] = g['is_anom_strict'].shift(fill_value=False)
        g['new_seq'] = (g['is_anom_strict']) & ((g['ts_diff'] != 60) | (~g['prev_is_anom']))
        # sequence id (cumsum of new_seq) but only meaningful for anomaly rows
        g['seq_id'] = np.where(g['is_anom_strict'], g['new_seq'].cumsum(), np.nan)
        # get run lengths and start timestamps
        runs = (
            g[g['is_anom_strict']]
            .groupby('seq_id', as_index=False)
            .agg(run_len=('seq_id','size'), run_start_idx=('seq_id','first'))
        )
        # map run_start_idx to actual timestamp value: find first timestamp in each seq_id group
        if not runs.empty:
            run_starts = g[g['is_anom_strict']].groupby('seq_id', as_index=False).agg(start_ts=('ts_sh','first'))
            runs = runs.merge(run_starts, on='seq_id', how='left')
            # pick longest run (if tie, earliest start)
            runs = runs.sort_values(['run_len','start_ts'], ascending=[False, True]).reset_index(drop=True)
            longest_run = int(runs.loc[0, 'run_len'])
            longest_run_start_ts = runs.loc[0, 'start_ts']
        else:
            longest_run = 0
            longest_run_start_ts = None
    return pd.Series({
        'points_in_window': pts,
        'anomaly_count_strict': anomaly_count,
        'earliest_anomaly_timestamp_strict': earliest_anom_ts,
        'max_value_in_window': max_value,
        'longest_consecutive_anomalous_run': longest_run,
        'start_timestamp_of_longest_run': longest_run_start_ts
    })

# 4) Group by pair and compute aggregates
grouped = df_win.groupby(['cmdb_id', 'kpi_name'])
agg_basic = grouped.agg(points_in_window=('value','size'),
                        max_value_in_window=('value','max'),
                        anomaly_count_strict=('is_anom_strict','sum')).reset_index()

# compute runs using apply on each group (operate on original df_win to preserve rows)
runs_df = grouped.apply(compute_runs).reset_index()

# merge with global_p95
summary_df = (
    agg_basic
    .merge(global_p95, on=['cmdb_id','kpi_name'], how='left')
    .merge(runs_df, on=['cmdb_id','kpi_name'], how='left')
)

# format timestamp fields to strings in UTC+8 or None
def fmt(ts):
    if pd.isna(ts):
        return None
    return pd.to_datetime(ts).tz_convert(sh).strftime('%Y-%m-%d %H:%M:%S %Z')

summary_df['earliest_anomaly_timestamp_strict'] = summary_df['earliest_anomaly_timestamp_strict'].apply(fmt)
summary_df['start_timestamp_of_longest_run'] = summary_df['start_timestamp_of_longest_run'].apply(fmt)

# ensure integer types for counts
summary_df['points_in_window'] = summary_df['points_in_window'].astype(int)
summary_df['anomaly_count_strict'] = summary_df['anomaly_count_strict'].astype(int)
summary_df['longest_consecutive_anomalous_run'] = summary_df['longest_consecutive_anomalous_run'].fillna(0).astype(int)

# 5) Sort by longest_consecutive_anomalous_run desc, then anomaly_count_strict desc. Take top 20.
summary_sorted = summary_df.sort_values(['longest_consecutive_anomalous_run','anomaly_count_strict'], ascending=[False, False]).reset_index(drop=True)
top20 = summary_sorted.head(20).copy()

# Select and order required columns
top20 = top20[[
    'cmdb_id',
    'kpi_name',
    'global_p95',
    'points_in_window',
    'anomaly_count_strict',
    'earliest_anomaly_timestamp_strict',
    'max_value_in_window',
    'longest_consecutive_anomalous_run',
    'start_timestamp_of_longest_run'
]]

# 6) Count pairs with longest_consecutive_anomalous_run >= 3 (candidate faults)
candidate_faults_count = int((summary_df['longest_consecutive_anomalous_run'] >= 3).sum())

# Prepare JSON-friendly result dict
result = {
    "window_start": window_start_sh.strftime('%Y-%m-%d %H:%M:%S %Z'),
    "window_end": window_end_sh.strftime('%Y-%m-%d %H:%M:%S %Z'),
    "total_pairs_in_window": int(summary_df.shape[0]),
    "candidate_faults_count_longest_run_ge_3": candidate_faults_count,
    "top_20_pairs_by_longest_run": top20.to_dict(orient='records')
}

