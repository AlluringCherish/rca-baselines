import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse thresholds_df and metric_incident_df from kernel.
# If a per-series summary (summary_df) exists reuse it; otherwise compute per-series anomaly stats.

try:
    summary_df  # try to use existing per-series summary if present
    use_existing_summary = True
except NameError:
    use_existing_summary = False

if use_existing_summary:
    # summary_df was created earlier and contains per-series stats for the incident window.
    per_series = summary_df.copy()
    # Ensure columns exist and keep required ones
    needed_cols = ['cmdb_id', 'kpi_name', 'anomaly_count', 'earliest_anomaly_ts', 'p95_threshold', 'max_value_in_window', 'max_over_threshold_ratio']
    # If some columns missing, fall back to recompute
    if not set(needed_cols).issubset(per_series.columns):
        use_existing_summary = False

if not use_existing_summary:
    # Merge incident-window rows with thresholds to evaluate anomalies
    merged = metric_incident_df.merge(thresholds_df, on=['cmdb_id', 'kpi_name'], how='left')
    # Identify anomaly rows
    anomaly_rows = merged[merged['p95_threshold'].notna() & (merged['value'] >= merged['p95_threshold'])].copy()
    # Per-series max value in window
    max_in_window = (
        metric_incident_df
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
        .max()
        .rename(columns={'value': 'max_value_in_window'})
    )
    # Aggregate anomaly rows
    if not anomaly_rows.empty:
        anomaly_agg = (
            anomaly_rows
            .groupby(['cmdb_id', 'kpi_name'], as_index=False)
            .agg(
                anomaly_count=('value', 'size'),
                earliest_anomaly_ts=('ts', 'min')
            )
        )
    else:
        anomaly_agg = pd.DataFrame(columns=['cmdb_id', 'kpi_name', 'anomaly_count', 'earliest_anomaly_ts'])
    # Build per_series dataframe
    per_series = (
        max_in_window
        .merge(thresholds_df, on=['cmdb_id', 'kpi_name'], how='left')
        .merge(anomaly_agg, on=['cmdb_id', 'kpi_name'], how='left')
    )
    per_series['anomaly_count'] = per_series['anomaly_count'].fillna(0).astype(int)
    # ensure earliest_anomaly_ts is tz-aware (Asia/Shanghai) or NaT
    def to_tz(x):
        if pd.isna(x):
            return pd.NaT
        # x may already be tz-aware or naive timestamp
        ts = pd.to_datetime(x)
        if ts.tzinfo is None:
            return ts.tz_localize(tz)
        return ts.tz_convert(tz)
    per_series['earliest_anomaly_ts'] = per_series['earliest_anomaly_ts'].apply(to_tz)
    # compute safe ratio
    def safe_ratio_row(r):
        th = r['p95_threshold']
        mv = r['max_value_in_window']
        if pd.isna(th) or th == 0:
            return np.nan
        return mv / th
    per_series['max_over_threshold_ratio'] = per_series.apply(safe_ratio_row, axis=1)

# Now aggregate by cmdb_id
# For top_kpi selection we need the kpi with highest max_over_threshold_ratio per component
# Prepare a helper DataFrame with the per-series fields required
series_for_comp = per_series.loc[:, ['cmdb_id', 'kpi_name', 'anomaly_count', 'earliest_anomaly_ts', 'max_over_threshold_ratio']].copy()

# Compute per-component aggregates
# num_kpi_anomalies: count of distinct kpi_name with anomaly_count>0
num_kpi_anomalies = (
    series_for_comp[series_for_comp['anomaly_count'] > 0]
    .groupby('cmdb_id', as_index=False)['kpi_name']
    .nunique()
    .rename(columns={'kpi_name': 'num_kpi_anomalies'})
)

# total_anomaly_points: sum of anomaly_count
total_anomaly_points = (
    series_for_comp.groupby('cmdb_id', as_index=False)['anomaly_count']
    .sum()
    .rename(columns={'anomaly_count': 'total_anomaly_points'})
)

# earliest_anomaly_ts per component
earliest_per_comp = (
    series_for_comp[series_for_comp['anomaly_count'] > 0]
    .groupby('cmdb_id', as_index=False)['earliest_anomaly_ts']
    .min()
)

# max_over_threshold_ratio per component
max_ratio_per_comp = (
    series_for_comp.groupby('cmdb_id', as_index=False)['max_over_threshold_ratio']
    .max()
    .rename(columns={'max_over_threshold_ratio': 'max_over_threshold_ratio'})
)

# top_kpi per component: choose kpi with highest ratio; if tie choose the one with largest anomaly_count, then lexicographically
# Build helper to rank KPIs per component
rank_df = series_for_comp.copy()
# Replace NaN ratios with -inf to avoid selecting them as top
rank_df['ratio_for_rank'] = rank_df['max_over_threshold_ratio'].fillna(-np.inf)
rank_df = rank_df.sort_values(['cmdb_id', 'ratio_for_rank', 'anomaly_count', 'kpi_name'], ascending=[True, False, False, True])
top_kpi_per_comp = rank_df.groupby('cmdb_id', as_index=False).first()[['cmdb_id', 'kpi_name']].rename(columns={'kpi_name': 'top_kpi'})

# Compose component_anomaly_df by merging all pieces
component_anomaly_df = (
    total_anomaly_points
    .merge(num_kpi_anomalies, on='cmdb_id', how='left')
    .merge(earliest_per_comp, on='cmdb_id', how='left')
    .merge(max_ratio_per_comp, on='cmdb_id', how='left')
    .merge(top_kpi_per_comp, on='cmdb_id', how='left')
)

# Fill NaNs for components with no KPI anomalies
component_anomaly_df['num_kpi_anomalies'] = component_anomaly_df['num_kpi_anomalies'].fillna(0).astype(int)
# earliest_anomaly_ts may be NaT for components without anomalies; keep as tz-aware or NaT
component_anomaly_df['earliest_anomaly_ts'] = component_anomaly_df['earliest_anomaly_ts'].apply(lambda x: to_tz(x) if not pd.isna(x) else pd.NaT)
# max_over_threshold_ratio NaNs remain as NaN
# top_kpi fill with None where missing
component_anomaly_df['top_kpi'] = component_anomaly_df['top_kpi'].where(component_anomaly_df['top_kpi'].notna(), None)

# Sort and prepare compact top-20 display
component_anomaly_df = component_anomaly_df.sort_values(by=['total_anomaly_points', 'max_over_threshold_ratio'], ascending=[False, False]).reset_index(drop=True)

# Convert earliest_anomaly_ts to ISO strings for compact display in top table
display_df = component_anomaly_df.copy()
display_df['earliest_anomaly_ts'] = display_df['earliest_anomaly_ts'].apply(lambda x: x.isoformat() if not pd.isna(x) else None)

top20_components = display_df.loc[:, ['cmdb_id', 'num_kpi_anomalies', 'total_anomaly_points', 'earliest_anomaly_ts', 'max_over_threshold_ratio', 'top_kpi']].head(20)

# Total number of components scanned (those appearing in incident window)
total_components_scanned = component_anomaly_df.shape[0]

# Store component_anomaly_df in kernel (already assigned) and output compact results
top20_components, total_components_scanned, component_anomaly_df.shape
