        df[col + "_dt"] = pd.to_datetime(df[col], utc=True, errors='coerce').dt.tz_convert(tz)

# Ensure severity_ratio numeric
df['severity_ratio'] = pd.to_numeric(df['severity_ratio'], errors='coerce')

# Compute per-cmdb aggregates
agg_funcs = {
