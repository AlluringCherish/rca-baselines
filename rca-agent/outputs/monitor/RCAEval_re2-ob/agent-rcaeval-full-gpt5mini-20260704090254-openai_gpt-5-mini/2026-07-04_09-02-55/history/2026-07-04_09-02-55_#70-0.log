# Reuse existing 'metric' if available; otherwise load it.
import os
import pandas as pd

if 'metric' not in globals():
    metric = pd.read_csv("metric.csv")
    metric["timestamp"] = pd.to_datetime(pd.to_numeric(metric["timestamp"], errors="coerce"), unit="s", utc=True)
else:
    # ensure timestamp parsed (in case kernel state changed)
    if "timestamp" in metric.columns and metric["timestamp"].dtype == object:
        metric["timestamp"] = pd.to_datetime(pd.to_numeric(metric["timestamp"], errors="coerce"), unit="s", utc=True)

# Ensure numeric values
metric["value"] = pd.to_numeric(metric["value"], errors="coerce")

# 1) Compute global P95 per (cmdb_id, kpi_name) across full series
grp_cols = ["cmdb_id", "kpi_name"]
global_p95 = metric.groupby(grp_cols, dropna=False)["value"].quantile(0.95).reset_index().rename(columns={"value": "global_p95"})

# 2) Filter metric to the incident window (inclusive)
start = pd.to_datetime("2024-01-17 16:26:17", utc=True)
end = pd.to_datetime("2024-01-17 16:56:17", utc=True)
metric_window = metric[(metric["timestamp"] >= start) & (metric["timestamp"] <= end)].copy()

# 3) For candidate services, compute required aggregates per KPI series
candidates = ["checkoutservice", "currencyservice", "emailservice", "productcatalogservice", "recommendationservice"]

# Keep only candidate cmdbs
metric_window_candidates = metric_window[metric_window["cmdb_id"].isin(candidates)].copy()

# Merge global_p95 onto window rows so each row knows its series threshold
metric_window_candidates = metric_window_candidates.merge(global_p95, on=grp_cols, how="left")

# Compute per-series aggregations within the incident window
# incident_point_count, breach_count (value > global_p95), earliest_breach_timestamp (if any), max_value_in_incident
def earliest_breach_ts(x):
    breaches = x.loc[x["value"] > x["global_p95"], "timestamp"]
    return breaches.min() if not breaches.empty else pd.NaT

agg = metric_window_candidates.groupby(grp_cols, dropna=False).agg(
    incident_point_count = ("value", "count"),
    breach_count = (lambda df: df["value"] > df["global_p95"], "sum"),  # placeholder, will fix next
    max_value_in_incident = ("value", "max"),
).reset_index()

# The above lambda in agg is not valid in older pandas; compute breach_count and earliest separately
if "breach_count" not in agg.columns or agg["breach_count"].dtype == object:
    # compute properly
    g = metric_window_candidates.groupby(grp_cols, dropna=False)
    incident_point_count = g["value"].count().rename("incident_point_count")
    breach_count = g.apply(lambda d: (d["value"] > d["global_p95"]).sum()).rename("breach_count")
    max_value_in_incident = g["value"].max().rename("max_value_in_incident")
    earliest_breach_timestamp = g.apply(lambda d: (d.loc[d["value"] > d["global_p95"], "timestamp"].min() if (d["value"] > d["global_p95"]).any() else pd.NaT)).rename("earliest_breach_timestamp")
    agg = pd.concat([incident_point_count, breach_count, earliest_breach_timestamp, max_value_in_incident], axis=1).reset_index()

# 4) Keep only rows where breach_count > 0 and add global_p95 column
result = agg[agg["breach_count"] > 0].merge(global_p95, on=grp_cols, how="left")

# Select and order columns as requested
result = result[["cmdb_id", "kpi_name", "global_p95", "incident_point_count", "breach_count", "earliest_breach_timestamp", "max_value_in_incident"]]

# Sort by breach_count desc then max_value_in_incident desc, limit to top 50
result = result.sort_values(by=["breach_count", "max_value_in_incident"], ascending=[False, False]).reset_index(drop=True).head(50)

# Keep output compact
result
