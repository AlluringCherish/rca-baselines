import pandas as pd
import os

# Reuse metric if available, else load
if 'metric' not in globals():
    metric = pd.read_csv("metric.csv")

# Parse timestamp as datetime (unit='s', utc=True)
if "timestamp" in metric.columns:
    metric["timestamp"] = pd.to_datetime(pd.to_numeric(metric["timestamp"], errors="coerce"), unit="s", utc=True)
else:
    metric["timestamp"] = pd.to_datetime([], unit="s", utc=True)

