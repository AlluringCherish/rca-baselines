import pandas as pd
import numpy as np
import os

# Reuse existing 'metric' if present, else load
try:
    metric
except NameError:
    metric = pd.read_csv("metric.csv")

# Parse timestamp and ensure numeric value
metric["timestamp"] = pd.to_datetime(pd.to_numeric(metric["timestamp"], errors="coerce"), unit="s", utc=True)
metric["value"] = pd.to_numeric(metric["value"], errors="coerce")

# Candidate services
candidates = ["checkoutservice", "currencyservice", "emailservice", "productcatalogservice", "recommendationservice"]

# Compute global P95 per (cmdb_id, kpi_name) for candidate services (using full series)
metric_candidates_full = metric[metric["cmdb_id"].isin(candidates)].copy()
grp_full = metric_candidates_full.groupby(["cmdb_id", "kpi_name"], dropna=False)["value"]
global_p95_df = grp_full.quantile(0.95).reset_index().rename(columns={"value": "global_p95"})

# Incident window (UTC)
start_ts = pd.to_datetime("2024-01-17 16:26:17", utc=True)
end_ts = pd.to_datetime("2024-01-17 16:56:17", utc=True)

# Filter metric to incident window (inclusive)
metric_incident = metric_candidates_full[(metric_candidates_full["timestamp"] >= start_ts) &
                                        (metric_candidates_full["timestamp"] <= end_ts)].copy()

# Aggregate incident stats per group
if metric_incident.empty:
    incident_agg = pd.DataFrame(columns=[
        "cmdb_id","kpi_name","incident_point_count","breach_count","earliest_breach_timestamp","max_value_in_incident"
    ])
else:
    grp_inc = metric_incident.groupby(["cmdb_id", "kpi_name"], dropna=False)
    incident_agg = grp_inc.agg(
        incident_point_count=("value", "count"),
        max_value_in_incident=("value", "max"),
    ).reset_index()

    # Compute breach_count and earliest breach timestamp by comparing to global_p95
    # Merge global_p95 into incident rows to evaluate breaches
    incident_rows = metric_incident.merge(global_p95_df, on=["cmdb_id", "kpi_name"], how="left")
    incident_rows["is_breach"] = incident_rows["value"] > incident_rows["global_p95"]

    # breach_count per group
    breaches = incident_rows.groupby(["cmdb_id", "kpi_name"], dropna=False).agg(
        breach_count=("is_breach", "sum"),
        earliest_breach_timestamp=("timestamp", lambda s: s[incident_rows.loc[s.index, "is_breach"]].min() if s.size>0 else pd.NaT)
    ).reset_index()

    # Merge aggregated incident stats with breaches and global_p95
    incident_agg = incident_agg.merge(breaches, on=["cmdb_id", "kpi_name"], how="left")
    incident_agg = incident_agg.merge(global_p95_df, on=["cmdb_id", "kpi_name"], how="left")

# Fill NA breach_count with 0 and ensure types
incident_agg["breach_count"] = incident_agg["breach_count"].fillna(0).astype(int)
# earliest_breach_timestamp may be NaT; keep as datetime
# Compute severity = max_value_in_incident / global_p95 (handle zero or NaN global_p95)
incident_agg["severity"] = incident_agg.apply(
    lambda r: np.inf if (pd.notna(r["max_value_in_incident"]) and pd.notna(r["global_p95"]) and r["global_p95"] == 0)
    else (r["max_value_in_incident"] / r["global_p95"] if pd.notna(r["max_value_in_incident"]) and pd.notna(r["global_p95"]) else np.nan),
    axis=1
)

# Keep only rows where breach_count > 0
incident_breaches = incident_agg[incident_agg["breach_count"] > 0].copy()

# Select and order columns as requested
cols_out = ["cmdb_id", "kpi_name", "global_p95", "incident_point_count", "breach_count", "earliest_breach_timestamp", "max_value_in_incident", "severity"]
incident_breaches = incident_breaches[cols_out]

# Sort by severity desc, limit to top 20
incident_breaches = incident_breaches.sort_values(by="severity", ascending=False).reset_index(drop=True).head(20)

# Compact output
incident_breaches
