import pandas as pd

# Load CSVs
df_metric = pd.read_csv("metric.csv")
df_trace = pd.read_csv("trace.csv")
df_log = pd.read_csv("log.csv")
df_error = pd.read_csv("error_logs.csv")

# Parse timestamps to UTC datetimes as required (keep original unix seconds in 'timestamp')
df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)
df_trace['ts'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True)
df_log['ts'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True)
df_error['ts'] = pd.to_datetime(df_error['timestamp'], unit='s', utc=True)

# Helper to build file-level summary
def file_summary(df, fname):
    total_rows = int(df.shape[0])
    if total_rows == 0:
        ts_min = None
        ts_max = None
        distinct_cmdb = 0
    else:
        ts_min = int(df['timestamp'].min())
        ts_max = int(df['timestamp'].max())
        distinct_cmdb = int(df['cmdb_id'].nunique())
    return {"file": fname, "total_rows": total_rows, "ts_min": ts_min, "ts_max": ts_max, "distinct_cmdb": distinct_cmdb}

summary_rows = [
    file_summary(df_metric, "metric.csv"),
    file_summary(df_trace, "trace.csv"),
    file_summary(df_log, "log.csv"),
    file_summary(df_error, "error_logs.csv"),
]
file_summary_df = pd.DataFrame(summary_rows)

# Metric: distinct (cmdb_id, kpi_name) pairs with counts and ts min/max
metric_pairs = (
    df_metric
    .groupby(['cmdb_id','kpi_name'], dropna=False)['timestamp']
    .agg(count='count', ts_min='min', ts_max='max')
    .reset_index()
)
metric_pairs['file'] = 'metric.csv'
metric_pairs = metric_pairs.rename(columns={'kpi_name':'name_field'})
# reorder columns to match requested: file, cmdb_id, name_field, count, ts_min, ts_max
metric_pairs = metric_pairs[['file','cmdb_id','name_field','count','ts_min','ts_max']]
metric_pairs = metric_pairs.sort_values('count', ascending=False).reset_index(drop=True)

# Trace: distinct (cmdb_id, trace_name) pairs
trace_pairs = (
    df_trace
    .groupby(['cmdb_id','trace_name'], dropna=False)['timestamp']
    .agg(count='count', ts_min='min', ts_max='max')
    .reset_index()
)
trace_pairs['file'] = 'trace.csv'
trace_pairs = trace_pairs.rename(columns={'trace_name':'name_field'})
trace_pairs = trace_pairs[['file','cmdb_id','name_field','count','ts_min','ts_max']]
trace_pairs = trace_pairs.sort_values('count', ascending=False).reset_index(drop=True)

# Log: distinct (cmdb_id, log_name) pairs
log_pairs = (
    df_log
    .groupby(['cmdb_id','log_name'], dropna=False)['timestamp']
    .agg(count='count', ts_min='min', ts_max='max')
    .reset_index()
)
log_pairs['file'] = 'log.csv'
log_pairs = log_pairs.rename(columns={'log_name':'name_field'})
log_pairs = log_pairs[['file','cmdb_id','name_field','count','ts_min','ts_max']]
log_pairs = log_pairs.sort_values('count', ascending=False).reset_index(drop=True)

# Error logs: distinct cmdb_id with row counts and up to 5 sample messages
if 'message' in df_error.columns:
    samples = (
        df_error
        .groupby('cmdb_id', sort=False)
        .apply(lambda g: ' | '.join(g['message'].astype(str).head(5)))
        .reset_index(name='sample_messages')
    )
else:
    # if no message column, create an empty sample_messages
    samples = df_error[['cmdb_id']].drop_duplicates().assign(sample_messages='')

error_agg = (
    df_error
    .groupby('cmdb_id', dropna=False)['timestamp']
    .agg(count='count', ts_min='min', ts_max='max')
    .reset_index()
)
error_agg = error_agg.merge(samples, on='cmdb_id', how='left')
error_agg['file'] = 'error_logs.csv'
# Use 'sample_messages' as name_field for error_logs to fit requested columns; include sample_messages as extra column
error_agg = error_agg.rename(columns={'sample_messages':'name_field'})
error_agg = error_agg[['file','cmdb_id','name_field','count','ts_min','ts_max']]
error_agg = error_agg.sort_values('count', ascending=False).reset_index(drop=True)

# Limit outputs to top 50 rows where applicable
metric_pairs_top = metric_pairs.head(50)
trace_pairs_top = trace_pairs.head(50)
log_pairs_top = log_pairs.head(50)
error_agg_top = error_agg.head(50)

# Final compact outputs:
file_summary_df, metric_pairs_top, trace_pairs_top, log_pairs_top, error_agg_top
