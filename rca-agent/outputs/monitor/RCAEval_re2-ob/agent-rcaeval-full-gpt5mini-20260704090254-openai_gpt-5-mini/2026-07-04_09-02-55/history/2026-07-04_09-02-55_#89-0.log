trace_names_50 = pd.Series(sorted(trace['trace_name'].unique())[:50], name='trace_name_first_50')
trace_name_counts_top20 = trace['trace_name'].value_counts().reset_index().rename(columns={'index':'trace_name','trace_name':'count'}).head(20)

# --- log.csv summaries ---
