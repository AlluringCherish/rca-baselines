import pandas as pd
import numpy as np

# reuse metric if present, otherwise load and parse timestamps
if 'metric' not in globals():
    metric = pd.read_csv("metric.csv")
metric['timestamp'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)

# 1) compute global P95 per (cmdb_id, kpi_name) using full series
p95_df = metric.groupby(['cmdb_id', 'kpi_name'])['value'].quantile(0.95).reset_index().rename(columns={'value': 'global_p95'})

# 2) filter rows to the incident window (UTC)
start = pd.to_datetime('2024-01-18 01:39:03', utc=True)
end = pd.to_datetime('2024-01-18 02:09:03', utc=True)
metric_window = metric[(metric['timestamp'] >= start) & (metric['timestamp'] <= end)].copy()

# 3) mark rows in-window that exceed the global P95 (merge p95 before marking)
metric_window_with_p95 = metric_window.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')
metric_window_with_p95['above_p95'] = metric_window_with_p95['value'] > metric_window_with_p95['global_p95']

# Cache intermediate variables for follow-up steps
metric_p95_fullseries = p95_df
metric_window_rows = metric_window
metric_window_with_flags = metric_window_with_p95

# 4) aggregate per (cmdb_id, kpi_name)
# basic window aggregates
agg_window = metric_window_with_p95.groupby(['cmdb_id', 'kpi_name']).agg(
    count_window=('value', 'count'),
    earliest_window_ts=('timestamp', 'min'),
    latest_window_ts=('timestamp', 'max'),
    max_value_in_window=('value', 'max'),
    count_values_above_p95_in_window=('above_p95', 'sum')
).reset_index()

# ensure integer type for counts
agg_window['count_window'] = agg_window['count_window'].astype(int)
agg_window['count_values_above_p95_in_window'] = agg_window['count_values_above_p95_in_window'].astype(int)

# earliest anomaly timestamp per group
earliest_anom = metric_window_with_p95[metric_window_with_p95['above_p95']].copy()
earliest_anom = earliest_anom.sort_values('timestamp').groupby(['cmdb_id', 'kpi_name'])['timestamp'].first().reset_index().rename(columns={'timestamp':'earliest_anomaly_ts_in_window'})

# merge earliest anomaly (may introduce NaT for groups without anomalies)
agg_window = agg_window.merge(earliest_anom, on=['cmdb_id','kpi_name'], how='left')

# 5) compute longest consecutive anomaly run in minutes for each group
# We'll compute runs only using rows within the window and considering exact 60-second adjacency
def longest_consecutive_run(df_group):
    # df_group must be sorted by timestamp
    df = df_group.sort_values('timestamp')
    above = df['above_p95'].values
    if not above.any():
        return 0
    # take only rows where above_p95 is True
    df_true = df[df['above_p95']].copy()
    if df_true.shape[0] == 0:
        return 0
    # compute diff in seconds between consecutive True rows
    diffs = df_true['timestamp'].diff().dt.total_seconds().fillna(9999).values
    # start new run when diff != 60
    run_id = (diffs != 60).cumsum()
    run_lengths = pd.Series(run_id).value_counts().values
    return int(run_lengths.max())

# apply per group
longest_runs = metric_window_with_p95.groupby(['cmdb_id', 'kpi_name']).apply(longest_consecutive_run).reset_index().rename(columns={0:'longest_consecutive_anomaly_run_in_window'})

# 6) Compose final table: join p95 (global), agg_window, longest_runs
# Also ensure groups with zero window rows are included if they exist in p95 (but spec asks per (cmdb_id,kpi_name) - produce one row per group encountered in the window)
final = p95_df.merge(agg_window, on=['cmdb_id','kpi_name'], how='left').merge(longest_runs, on=['cmdb_id','kpi_name'], how='left')

# fill NaNs for groups with no window rows
final['count_window'] = final['count_window'].fillna(0).astype(int)
final['count_values_above_p95_in_window'] = final['count_values_above_p95_in_window'].fillna(0).astype(int)
final['earliest_window_ts'] = final['earliest_window_ts']  # leave NaT if missing
final['latest_window_ts'] = final['latest_window_ts']
final['earliest_anomaly_ts_in_window'] = final['earliest_anomaly_ts_in_window']
final['max_value_in_window'] = final['max_value_in_window'].astype(float)
final['longest_consecutive_anomaly_run_in_window'] = final['longest_consecutive_anomaly_run_in_window'].fillna(0).astype(int)

# 7) compute breach_ratio = max_value_in_window / global_p95 (handle division by zero and missing max)
final['breach_ratio'] = np.where(
    final['global_p95'] > 0,
    final['max_value_in_window'] / final['global_p95'],
    np.nan
)

# 8) Select and order columns as requested
final_table = final[[
    'cmdb_id',
    'kpi_name',
    'global_p95',
    'count_window',
    'earliest_window_ts',
    'latest_window_ts',
    'count_values_above_p95_in_window',
    'earliest_anomaly_ts_in_window',
    'longest_consecutive_anomaly_run_in_window',
    'max_value_in_window',
    'breach_ratio'
]]

# 9) Sort by longest_consecutive_anomaly_run_in_window desc, then breach_ratio desc
final_table_sorted = final_table.sort_values(by=['longest_consecutive_anomaly_run_in_window', 'breach_ratio'], ascending=[False, False])

# 10) keep full intermediate tables in kernel variables (already cached) and display top 20 rows compactly
metric_anomaly_summary_top20 = final_table_sorted.head(20)

# Display result (variable shows output)
metric_anomaly_summary_top20
