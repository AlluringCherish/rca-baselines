import pandas as pd

# reuse existing `metric` if present, otherwise load and parse timestamps
if 'metric' not in globals():
    metric = pd.read_csv("metric.csv")
metric['timestamp'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)

# 1) Calculate global P95 and total count per (cmdb_id, kpi_name) using the full series
p95_df = metric.groupby(['cmdb_id', 'kpi_name'])['value'].quantile(0.95).reset_index().rename(columns={'value': 'global_p95'})
count_total_df = metric.groupby(['cmdb_id', 'kpi_name'])['value'].count().reset_index().rename(columns={'value': 'count_total'})

baseline_df = p95_df.merge(count_total_df, on=['cmdb_id', 'kpi_name'])

# 2) Filter metric rows to the incident window (UTC)
start = pd.to_datetime('2024-01-18 01:39:03', utc=True)
end = pd.to_datetime('2024-01-18 02:09:03', utc=True)
metric_window = metric[(metric['timestamp'] >= start) & (metric['timestamp'] <= end)].copy()

# 3) Compute windowed aggregates per (cmdb_id, kpi_name)
count_window_df = metric_window.groupby(['cmdb_id', 'kpi_name'])['value'].count().reset_index().rename(columns={'value': 'count_window'})
earliest_window_df = metric_window.groupby(['cmdb_id', 'kpi_name'])['timestamp'].min().reset_index().rename(columns={'timestamp': 'earliest_window_ts'})
latest_window_df = metric_window.groupby(['cmdb_id', 'kpi_name'])['timestamp'].max().reset_index().rename(columns={'timestamp': 'latest_window_ts'})
max_value_window_df = metric_window.groupby(['cmdb_id', 'kpi_name'])['value'].max().reset_index().rename(columns={'value': 'max_value_in_window'})

# 4) Count values above the global P95 inside the window
# join global p95 onto the window rows, then count per group
metric_window_with_p95 = metric_window.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')
metric_window_with_p95['above_p95'] = metric_window_with_p95['value'] > metric_window_with_p95['global_p95']
above_counts_df = metric_window_with_p95.groupby(['cmdb_id', 'kpi_name'])['above_p95'].sum().reset_index().rename(columns={'above_p95': 'count_values_above_p95_in_window'})

# 5) Merge all results into final table (keep all groups present in baseline/global series)
result_df = baseline_df.merge(count_window_df, on=['cmdb_id', 'kpi_name'], how='left') \
                       .merge(earliest_window_df, on=['cmdb_id', 'kpi_name'], how='left') \
                       .merge(latest_window_df, on=['cmdb_id', 'kpi_name'], how='left') \
                       .merge(above_counts_df, on=['cmdb_id', 'kpi_name'], how='left') \
                       .merge(max_value_window_df, on=['cmdb_id', 'kpi_name'], how='left')

# fill NaNs for counts with 0 and ensure integer dtype for counts
result_df['count_window'] = result_df['count_window'].fillna(0).astype(int)
result_df['count_values_above_p95_in_window'] = result_df['count_values_above_p95_in_window'].fillna(0).astype(int)

# 6) Reorder columns as requested
result_df = result_df[['cmdb_id', 'kpi_name', 'global_p95', 'count_total', 'count_window',
                       'earliest_window_ts', 'latest_window_ts', 'count_values_above_p95_in_window',
                       'max_value_in_window']]

# 7) Sort by count_values_above_p95_in_window desc, then by count_window desc
result_df_sorted = result_df.sort_values(by=['count_values_above_p95_in_window', 'count_window'], ascending=[False, False])

# 8) Limit to top 50 rows and cache result variable for follow-up
metric_p95_window_summary_top50 = result_df_sorted.head(50)

# Display the compact table (cached variable shown as output)
metric_p95_window_summary_top50
