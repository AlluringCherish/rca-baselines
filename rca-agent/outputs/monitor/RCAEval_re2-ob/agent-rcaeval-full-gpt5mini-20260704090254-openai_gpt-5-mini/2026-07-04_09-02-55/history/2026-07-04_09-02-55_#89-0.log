metric_kpi_names_50 = pd.Series(sorted(metric['kpi_name'].unique())[:50], name='kpi_name_first_50')
metric_kpi_counts_top20 = metric['kpi_name'].value_counts().reset_index().rename(columns={'index':'kpi_name','kpi_name':'count'}).head(20)

# --- trace.csv summaries ---
trace_count = trace.shape[0]
trace_time_min = trace['timestamp'].min()
trace_time_max = trace['timestamp'].max()
