import pandas as pd
import numpy as np

# reuse existing variables if present, otherwise load and parse timestamps
if 'log' not in globals():
    log = pd.read_csv("log.csv")
log['timestamp'] = pd.to_datetime(log['timestamp'], unit='s', utc=True)

if 'error_logs' not in globals():
    error_logs = pd.read_csv("error_logs.csv")
error_logs['timestamp'] = pd.to_datetime(error_logs['timestamp'], unit='s', utc=True)

# 1) Compute global P95 per (cmdb_id, log_name) using the full log series
log_p95 = log.groupby(['cmdb_id', 'log_name'])['value'].quantile(0.95).reset_index().rename(columns={'value':'global_p95'})

# 2) Filter log rows to the incident window (UTC)
start = pd.to_datetime('2024-01-18 01:39:03', utc=True)
end = pd.to_datetime('2024-01-18 02:09:03', utc=True)
log_window = log[(log['timestamp'] >= start) & (log['timestamp'] <= end)].copy()

# 3) Merge global P95 onto window rows and mark above-P95
log_window_with_p95 = log_window.merge(log_p95, on=['cmdb_id','log_name'], how='left')
log_window_with_p95['above_p95'] = log_window_with_p95['value'] > log_window_with_p95['global_p95']

# 4) Focus on specified cmdb_ids
targets = ['recommendationservice', 'frontend', 'checkoutservice']
log_window_targets = log_window_with_p95[log_window_with_p95['cmdb_id'].isin(targets)].copy()

# 5) Aggregate per (cmdb_id, log_name)
agg_count = log_window_targets.groupby(['cmdb_id','log_name'])['value'].count().rename('count_window').reset_index()
agg_above = log_window_targets.groupby(['cmdb_id','log_name'])['above_p95'].sum().rename('count_above_p95_in_window').reset_index()
agg_max = log_window_targets.groupby(['cmdb_id','log_name'])['value'].max().rename('max_value_in_window').reset_index()
earliest_above = log_window_targets[log_window_targets['above_p95']].groupby(['cmdb_id','log_name'])['timestamp'].min().rename('earliest_above_p95_ts_in_window').reset_index()

result = agg_count.merge(agg_above, on=['cmdb_id','log_name'], how='left') \
                  .merge(earliest_above, on=['cmdb_id','log_name'], how='left') \
                  .merge(agg_max, on=['cmdb_id','log_name'], how='left') \
                  .merge(log_p95, on=['cmdb_id','log_name'], how='left')

# fill NaNs for numeric counts
result['count_window'] = result['count_window'].fillna(0).astype(int)
result['count_above_p95_in_window'] = result['count_above_p95_in_window'].fillna(0).astype(int)

# 6) compute breach_ratio = max_value_in_window / global_p95 (handle zeros and missing)
result['breach_ratio'] = np.where(
    (result['global_p95'].notna()) & (result['global_p95'] > 0),
    result['max_value_in_window'] / result['global_p95'],
    np.nan
)

# 7) Select columns and sort as requested
result = result[[
    'cmdb_id',
    'log_name',
    'global_p95',
    'count_window',
    'count_above_p95_in_window',
    'earliest_above_p95_ts_in_window',
    'max_value_in_window',
    'breach_ratio'
]]

result_sorted = result.sort_values(by=['count_above_p95_in_window','breach_ratio'], ascending=[False, False])

# limit to top 20 rows
log_p95_window_summary_top20 = result_sorted.head(20)

# 8) error_logs summary: count and up to first 10 samples (timestamp, cmdb_id, message)
error_logs_count = error_logs.shape[0]
if error_logs_count > 0:
    error_logs_samples_first10 = error_logs[['timestamp','cmdb_id','message']].head(10).reset_index(drop=True)
else:
    error_logs_samples_first10 = pd.DataFrame(columns=['timestamp','cmdb_id','message'])

# Display compact outputs
log_p95_window_summary_top20, error_logs_count, error_logs_samples_first10
