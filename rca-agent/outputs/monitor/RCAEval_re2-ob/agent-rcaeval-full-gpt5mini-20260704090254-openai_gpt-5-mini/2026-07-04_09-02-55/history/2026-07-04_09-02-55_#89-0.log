import pandas as pd
import numpy as np

# reuse existing `trace` if present, otherwise load and parse timestamps
if 'trace' not in globals():
    trace = pd.read_csv("trace.csv")
trace['timestamp'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True)

# 1) Compute global P95 per trace_name using the full series (global threshold)
trace_p95 = trace.groupby('trace_name')['value'].quantile(0.95).reset_index().rename(columns={'value':'global_p95'})

# 2) Filter trace rows to the incident window (UTC)
start = pd.to_datetime('2024-01-18 01:39:03', utc=True)
end = pd.to_datetime('2024-01-18 02:09:03', utc=True)
trace_window = trace[(trace['timestamp'] >= start) & (trace['timestamp'] <= end)].copy()

# 3) Keep only trace_name containing any of the specified substrings
substrs = ['recommendationservice', 'frontend', 'productcatalogservice', 'checkoutservice', 'paymentservice']
pattern = '|'.join(substrs)
trace_window_filtered = trace_window[trace_window['trace_name'].str.contains(pattern, regex=True)].copy()

# 4) Merge global P95 onto the windowed rows and mark above-P95
trace_window_with_p95 = trace_window_filtered.merge(trace_p95, on='trace_name', how='left')
trace_window_with_p95['above_p95'] = trace_window_with_p95['value'] > trace_window_with_p95['global_p95']

# Cache intermediate variables for follow-up
trace_p95_fullseries = trace_p95
trace_window_rows = trace_window
trace_window_filtered_rows = trace_window_filtered
trace_window_with_flags = trace_window_with_p95

# 5) Aggregate per trace_name
count_window = trace_window_with_p95.groupby('trace_name')['value'].count().rename('count_window').reset_index()
count_above = trace_window_with_p95.groupby('trace_name')['above_p95'].sum().rename('count_values_above_global_p95_in_window').reset_index()
max_value = trace_window_with_p95.groupby('trace_name')['value'].max().rename('max_value_in_window').reset_index()
earliest_anom = trace_window_with_p95[trace_window_with_p95['above_p95']].groupby('trace_name')['timestamp'].min().rename('earliest_anomaly_ts_in_window').reset_index()

# 6) Compose final table
result = count_window.merge(count_above, on='trace_name', how='left') \
                     .merge(earliest_anom, on='trace_name', how='left') \
                     .merge(max_value, on='trace_name', how='left') \
                     .merge(trace_p95, on='trace_name', how='left')

# 7) compute breach_ratio = max_value_in_window / global_p95 (handle zeros)
result['breach_ratio'] = np.where(result['global_p95'] > 0, result['max_value_in_window'] / result['global_p95'], np.nan)

# 8) Select and order columns as requested and sort
result = result[[
    'trace_name',
    'count_window',
    'count_values_above_global_p95_in_window',
    'earliest_anomaly_ts_in_window',
    'max_value_in_window',
    'global_p95',
    'breach_ratio'
]]

result_sorted = result.sort_values(by=['count_values_above_global_p95_in_window', 'breach_ratio'], ascending=[False, False])

# 9) Limit to top 20 rows and cache/display
trace_p95_window_summary_top20 = result_sorted.head(20)
trace_p95_window_summary_top20
