lines = []
lines.append("Log insights for incident window (2024-01-15T20:07:45Z — 2024-01-15T20:37:45Z):")

# Summarize row_count anomalies
row_count_anoms = anom_rows[anom_rows['log_name'].str.contains('row_count', na=False)]
