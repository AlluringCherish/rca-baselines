import pandas as pd

# load metric.csv (reuse existing variables if present is allowed but reload to be explicit)
df_metric = pd.read_csv('metric.csv')

# parse timestamp to UTC datetime per rule
df_metric['ts'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)

# candidate services
candidates = [
    'checkoutservice',
    'currencyservice',
    'emailservice',
    'productcatalogservice',
    'recommendationservice'
]

# Restrict to candidate cmdb_ids when computing pairs (but compute global P95 using the full series for each pair)
df_candidates = df_metric[df_metric['cmdb_id'].isin(candidates)].copy()

# Compute global P95 for each (cmdb_id, kpi_name) using the full available series for that pair
p95_df = (
    df_candidates
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_P95'})
)

# Define incident window in UTC
window_start = pd.Timestamp("2024-01-19T18:32:37", tz='UTC')
window_end = pd.Timestamp("2024-01-19T19:02:37", tz='UTC')

# Filter metric rows to the incident window (still only candidate services)
df_window = df_candidates[(df_candidates['ts'] >= window_start) & (df_candidates['ts'] <= window_end)].copy()

# Merge global P95 into window rows so we can flag values above P95
df_win_with_p95 = pd.merge(df_window, p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# Flag rows above global P95 (strictly above)
df_win_with_p95['above_p95'] = df_win_with_p95['value'] > df_win_with_p95['global_P95']

# Aggregate window metrics per pair
agg_window = (
    df_win_with_p95
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        total_points_in_window=('value', 'size'),
        points_above_P95_in_window=('above_p95', 'sum'),
        earliest_ts_above_P95=('ts', lambda s: s[s.index[df_win_with_p95.loc[s.index, 'above_p95']].tolist()].min() if (df_win_with_p95.loc[s.index, 'above_p95'].any()) else pd.NaT),
        max_value_in_window=('value', 'max')
    )
)

# The lambda above is a bit complex due to grouping context; use alternative clearer computation:
# Compute earliest_ts_above and points_above using grouped operations directly
points_above = (
    df_win_with_p95[df_win_with_p95['above_p95']]
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        points_above_P95_in_window=('above_p95', 'sum'),
        earliest_ts_above_P95=('ts', 'min')
    )
)

# total count and max per pair
count_max = (
    df_window
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        total_points_in_window=('value', 'size'),
        max_value_in_window=('value', 'max')
    )
)

# Start from p95_df (all pairs that exist for candidates), left-join aggregated window stats
result = p95_df.merge(count_max, on=['cmdb_id','kpi_name'], how='left') \
                .merge(points_above, on=['cmdb_id','kpi_name'], how='left')

# Fill NaNs for counts/points with 0 and keep earliest as None/null
result['total_points_in_window'] = result['total_points_in_window'].fillna(0).astype(int)
result['points_above_P95_in_window'] = result['points_above_P95_in_window'].fillna(0).astype(int)
result['earliest_timestamp_above_P95_in_window'] = result['earliest_ts_above_P95'].dt.tz_convert('UTC').dt.isoformat()
result['earliest_timestamp_above_P95_in_window'] = result['earliest_timestamp_above_P95_in_window'].where(result['points_above_P95_in_window']>0, None)
result['max_value_in_window'] = result['max_value_in_window']  # may be NaN if no points in window

# Select and order required columns
final_cols = [
    'cmdb_id',
    'kpi_name',
    'global_P95',
    'total_points_in_window',
    'points_above_P95_in_window',
    'earliest_timestamp_above_P95_in_window',
    'max_value_in_window'
]
result_df = result[final_cols].sort_values(['cmdb_id','kpi_name']).reset_index(drop=True)

# Keep output compact (limit to 100 rows)
result_df.head(100)
