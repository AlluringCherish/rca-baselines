import pandas as pd

# Reuse df_trace if available, else load
try:
    df_trace
except NameError:
    df_trace = pd.read_csv("trace.csv")

# Ensure timestamp_dt parsed as UTC datetime
if "timestamp_dt" not in df_trace.columns:
