# Restrict to requested cmdb_ids
selected_cmdbs = ["checkoutservice", "emailservice", "recommendationservice"]
df_subset = df_trace[df_trace["cmdb_id"].isin(selected_cmdbs)].copy()

# If subset is empty, prepare empty result
