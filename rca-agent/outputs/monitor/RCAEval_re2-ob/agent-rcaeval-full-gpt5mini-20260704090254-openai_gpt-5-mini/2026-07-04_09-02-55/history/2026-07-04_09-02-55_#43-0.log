import pandas as pd
import numpy as np
from pathlib import Path

# Load files
metric_fp = "metric.csv"
trace_fp = "trace.csv"
log_fp = "log.csv"
error_fp = "error_logs.csv"

df_metric = pd.read_csv(metric_fp)
df_trace = pd.read_csv(trace_fp)
df_log = pd.read_csv(log_fp)
df_err = pd.read_csv(error_fp)

# Parse timestamps to UTC datetimes
for df in (df_metric, df_trace, df_log, df_err):
    df['timestamp'] = pd.to_datetime(df['timestamp'], unit='s', utc=True)

# Helper to build summary
def file_summary(df, key_name_for_kpi=None, value_col='value', top_n=20, include_percentiles=False):
    min_ts = df['timestamp'].min().isoformat() if not df.empty else None
    max_ts = df['timestamp'].max().isoformat() if not df.empty else None
    unique_cmdb = sorted(df['cmdb_id'].dropna().unique().tolist())
    summary = {'min_timestamp': min_ts, 'max_timestamp': max_ts, 'unique_cmdb_id': unique_cmdb}
    if key_name_for_kpi:
        kpi_col = key_name_for_kpi
        grp = df.groupby(['cmdb_id', kpi_col])[value_col]
        # global aggregates per pair
        agg = grp.agg(count='count',
                      p95=lambda x: float(x.quantile(0.95)) if len(x) > 0 else np.nan,
                      p5=lambda x: float(x.quantile(0.05)) if len(x) > 0 else np.nan).reset_index()
        agg = agg.sort_values('count', ascending=False).head(top_n)
        # convert to JSON-serializable records
        agg_records = agg.to_dict(orient='records')
        summary['top_pairs'] = agg_records
    else:
        # for logs: just counts per (cmdb_id, log_name)
        grp = df.groupby(['cmdb_id', 'log_name']).size().reset_index(name='count')
        grp = grp.sort_values('count', ascending=False).head(top_n)
        summary['top_pairs'] = grp.to_dict(orient='records')
    return summary

# Build summaries
metric_summary = file_summary(df_metric, key_name_for_kpi='kpi_name', value_col='value', include_percentiles=True)
trace_summary = file_summary(df_trace, key_name_for_kpi='trace_name', value_col='value', include_percentiles=True)
log_summary = file_summary(df_log, key_name_for_kpi=None)

# error_logs: top 20 rows sorted by timestamp
err_top = df_err.sort_values('timestamp').head(20).copy()
err_top['timestamp'] = err_top['timestamp'].dt.isoformat()
err_top = err_top[['timestamp', 'cmdb_id', 'message']]

# Compose final JSON-serializable dict
results_summary = {
    'metric.csv': metric_summary,
    'trace.csv': trace_summary,
    'log.csv': log_summary,
    'error_logs.csv': {
        'min_timestamp': df_err['timestamp'].min().isoformat() if not df_err.empty else None,
        'max_timestamp': df_err['timestamp'].max().isoformat() if not df_err.empty else None,
        'unique_cmdb_id': sorted(df_err['cmdb_id'].dropna().unique().tolist()),
        'top_rows': err_top.to_dict(orient='records')
    }
}

