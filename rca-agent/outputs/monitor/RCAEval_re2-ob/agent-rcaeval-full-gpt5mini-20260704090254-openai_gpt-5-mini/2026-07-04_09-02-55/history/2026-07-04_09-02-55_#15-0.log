import pandas as pd
import numpy as np

# Reuse df_metric, and start/end timestamps from earlier session if available
# Ensure timestamps are datetime UTC
df_metric['timestamp'] = pd.to_datetime(df_metric['timestamp'], utc=True)

# Define target
service = 'checkoutservice'
kpis = ['cpu', 'mem', 'socket', 'latency-50', 'latency-90', 'workload']

# Ensure global P95s are computed from full series (do not recompute after windowing)
# Use df_metric full series grouped to get P95 (safe even if global_stats exists)
full_stats = (
    df_metric[df_metric['cmdb_id'] == service]
    .groupby('kpi_name')['value']
    .agg(P95=lambda x: x.quantile(0.95))
    .reset_index()
)

# Map P95 for our kpis (if a KPI missing from data, P95 will be NaN)
p95_map = full_stats.set_index('kpi_name')['P95'].to_dict()

# Incident window
start = pd.Timestamp('2024-01-19 09:10:13', tz='UTC')
end   = pd.Timestamp('2024-01-19 09:40:13', tz='UTC')

rows = []
for kpi in kpis:
    p95 = p95_map.get(kpi, np.nan)
    df_k = df_metric[
        (df_metric['cmdb_id'] == service) &
        (df_metric['kpi_name'] == kpi)
    ].copy()
    # Windowed rows
    df_k_window = df_k[df_k['timestamp'].between(start, end, inclusive='both')].sort_values('timestamp').reset_index(drop=True)
    # max in window (may be NaN if no points)
    max_in_window = df_k_window['value'].max() if not df_k_window.empty else np.nan

    # Find timestamps where value > P95 (global)
    if pd.isna(p95):
        # no global P95 -> no exceed info
        exceed_ts = pd.DatetimeIndex([])
    else:
        exceed = df_k_window['value'] > p95
        exceed_ts = pd.DatetimeIndex(df_k_window.loc[exceed, 'timestamp'])

    count_exceeds = len(exceed_ts)

    # Determine consecutive runs (consecutive minute timestamps)
    if count_exceeds == 0:
        number_of_runs = 0
        longest_run = 0
        earliest_run_start = pd.NaT
    else:
        # compute gaps in minutes
        diffs = exceed_ts.to_series().diff().fillna(pd.Timedelta(seconds=0))
        # new run where diff != 1 minute
        new_run = (diffs != pd.Timedelta(minutes=1))
        run_id = new_run.cumsum()
        runs = exceed_ts.to_series().groupby(run_id).agg(start=('first'), length=('size'))
        number_of_runs = runs.shape[0]
        longest_run = int(runs['length'].max())
        earliest_run_start = runs['start'].min()

    # severity_pct: (max_in_window - P95) / P95, guard divide by zero / NaN
    if pd.isna(p95) or pd.isna(max_in_window) or p95 == 0:
        severity_pct = np.nan
    else:
        severity_pct = (max_in_window - p95) / p95

    rows.append({
        'kpi_name': kpi,
        'P95': p95,
        'count_exceeds': int(count_exceeds),
        'number_of_runs': int(number_of_runs),
        'longest_run_length_minutes': int(longest_run),
        'earliest_run_start_timestamp': earliest_run_start,
        'max_in_window': max_in_window,
        'severity_pct': severity_pct
    })

summary_df = pd.DataFrame(rows)[
    ['kpi_name','P95','count_exceeds','number_of_runs','longest_run_length_minutes','earliest_run_start_timestamp','max_in_window','severity_pct']
]

