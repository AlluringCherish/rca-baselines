import pandas as pd
import numpy as np

# Reuse df_trace loaded earlier
# Candidate services
services = ['checkoutservice', 'currencyservice', 'emailservice', 'productcatalogservice', 'recommendationservice']

# Build regex to find trace_name referencing any of these services
pattern = '|'.join(services)

# Step 1: filter trace rows where trace_name references any candidate service
df_trace_sub = df_trace[df_trace['trace_name'].str.contains(pattern, na=False)].copy()

# Ensure timestamp is datetime UTC
df_trace_sub['timestamp'] = pd.to_datetime(df_trace_sub['timestamp'], utc=True)

# Step 2: compute global statistics per (cmdb_id, trace_name) across full series
agg_funcs = {
    'count': ('value', 'count'),
    'mean':  ('value', 'mean'),
    'min':   ('value', 'min'),
    'max':   ('value', 'max'),
    'P95':   ('value', lambda x: x.quantile(0.95)),
    'P90':   ('value', lambda x: x.quantile(0.90)),
    'P5':    ('value', lambda x: x.quantile(0.05)),
}
# Use groupby.agg with named tuples
global_trace_stats = df_trace_sub.groupby(['cmdb_id','trace_name']).agg(**agg_funcs).reset_index()
global_trace_stats = global_trace_stats.sort_values(['cmdb_id','trace_name']).reset_index(drop=True)

# Step 3: filter to incident window and compute window-level anomaly summary
# Reuse start/end defined earlier in session; if not present, define them
try:
    start, end
except NameError:
    start = pd.Timestamp('2024-01-19 09:10:13', tz='UTC')
    end   = pd.Timestamp('2024-01-19 09:40:13', tz='UTC')

df_trace_window = df_trace_sub[df_trace_sub['timestamp'].between(start, end, inclusive='both')].copy()

# Merge global P95 for comparison
df_tw = df_trace_window.merge(global_trace_stats[['cmdb_id','trace_name','P95']], on=['cmdb_id','trace_name'], how='left')

# Mark above P95
df_tw['above_P95'] = df_tw['value'] > df_tw['P95']

# Window aggregates
points_in_window = df_tw.groupby(['cmdb_id','trace_name'])['value'].count().rename('points_in_window')
points_above_P95 = df_tw.groupby(['cmdb_id','trace_name'])['above_P95'].sum().rename('points_above_P95')
max_in_window = df_tw.groupby(['cmdb_id','trace_name'])['value'].max().rename('max_in_window')
earliest_exceed = df_tw[df_tw['above_P95']].groupby(['cmdb_id','trace_name'])['timestamp'].min().rename('earliest_exceed_timestamp')

# Ensure every global series appears in the window summary (even with 0 points)
window_summary = (
    global_trace_stats[['cmdb_id','trace_name']]
    .merge(points_in_window.reset_index(), on=['cmdb_id','trace_name'], how='left')
    .merge(points_above_P95.reset_index(), on=['cmdb_id','trace_name'], how='left')
    .merge(earliest_exceed.reset_index(), on=['cmdb_id','trace_name'], how='left')
    .merge(max_in_window.reset_index(), on=['cmdb_id','trace_name'], how='left')
)

# Fill NaNs for counts with 0
window_summary['points_in_window'] = window_summary['points_in_window'].fillna(0).astype(int)
window_summary['points_above_P95'] = window_summary['points_above_P95'].fillna(0).astype(int)

# Final table formatting and sorting
global_table = global_trace_stats[['cmdb_id','trace_name','count','mean','min','max','P95','P90','P5']].sort_values(['cmdb_id','trace_name']).reset_index(drop=True)
window_table = window_summary[['cmdb_id','trace_name','points_in_window','points_above_P95','earliest_exceed_timestamp','max_in_window']].sort_values(['cmdb_id','trace_name']).reset_index(drop=True)

# Limit to <=20 rows as requested
global_table_head = global_table.head(20)
window_table_head = window_table.head(20)

# Display results (variables so IPython displays them)
global_table_head, window_table_head
