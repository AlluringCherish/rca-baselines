import pandas as pd
import numpy as np

# reuse df_metric loaded earlier in the session
# Step 1: restrict to the requested cmdb_ids
cmdb_list = ['checkoutservice', 'currencyservice', 'emailservice', 'productcatalogservice', 'recommendationservice']
df_sub = df_metric[df_metric['cmdb_id'].isin(cmdb_list)].copy()

# Ensure timestamp is datetime UTC (should already be)
df_sub['timestamp'] = pd.to_datetime(df_sub['timestamp'], utc=True)

# Step 2: compute global statistics per (cmdb_id, kpi_name) across the full series
global_stats = (
    df_sub
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(
        count='count',
        mean='mean',
        min='min',
        max='max',
        P95=lambda x: x.quantile(0.95),
        P90=lambda x: x.quantile(0.90),
        P5 = lambda x: x.quantile(0.05)
    )
    .reset_index()
    .sort_values(['cmdb_id', 'kpi_name'])
)

# Keep this in memory for later (global_stats)

# Step 3: filter to the incident window (UTC)
start = pd.Timestamp('2024-01-19 09:10:13', tz='UTC')
end   = pd.Timestamp('2024-01-19 09:40:13', tz='UTC')
df_window = df_sub[df_sub['timestamp'].between(start, end, inclusive='both')].copy()

# Merge global P95 into window rows so we can compare
df_win = df_window.merge(global_stats[['cmdb_id','kpi_name','P95']], on=['cmdb_id','kpi_name'], how='left')

# Mark rows above global P95 (strictly greater as requested)
df_win['above_P95'] = df_win['value'] > df_win['P95']

# Aggregates in the window
points_in_window = df_win.groupby(['cmdb_id','kpi_name'])['value'].count().rename('points_in_window')
points_above_P95 = df_win.groupby(['cmdb_id','kpi_name'])['above_P95'].sum().rename('points_above_P95')
max_in_window = df_win.groupby(['cmdb_id','kpi_name'])['value'].max().rename('max_in_window')
earliest_exceed = (
    df_win[df_win['above_P95']]
    .groupby(['cmdb_id','kpi_name'])['timestamp']
    .min()
    .rename('earliest_exceed_timestamp')
)

# Combine window aggregates into a single DataFrame
window_summary = (
    global_stats[['cmdb_id','kpi_name']]  # ensure all series appear even if 0 points in window
    .merge(points_in_window.reset_index(), on=['cmdb_id','kpi_name'], how='left')
    .merge(points_above_P95.reset_index(), on=['cmdb_id','kpi_name'], how='left')
    .merge(earliest_exceed.reset_index(), on=['cmdb_id','kpi_name'], how='left')
    .merge(max_in_window.reset_index(), on=['cmdb_id','kpi_name'], how='left')
)

