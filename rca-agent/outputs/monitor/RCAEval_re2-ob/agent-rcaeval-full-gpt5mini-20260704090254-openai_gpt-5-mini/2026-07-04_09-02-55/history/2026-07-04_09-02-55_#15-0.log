import pandas as pd

# Load CSVs
df_metric = pd.read_csv("metric.csv")
df_trace = pd.read_csv("trace.csv")
df_log = pd.read_csv("log.csv")
df_err = pd.read_csv("error_logs.csv")

# Parse timestamps to UTC datetimes
for df in (df_metric, df_trace, df_log, df_err):
    if 'timestamp' in df.columns:
        df['timestamp'] = pd.to_datetime(df['timestamp'], unit='s', utc=True)

# --- metric.csv inventory ---
metric_cmdbs = pd.DataFrame(sorted(df_metric['cmdb_id'].dropna().unique()), columns=['cmdb_id'])
metric_kpis_top20 = pd.DataFrame(sorted(df_metric['kpi_name'].dropna().unique())[:20], columns=['kpi_name'])
metric_kpi_counts_top20 = (
    df_metric.groupby('kpi_name', dropna=False).size()
    .sort_values(ascending=False)
    .head(20)
    .reset_index(name='count')
)
metric_samples = df_metric[['timestamp', 'cmdb_id', 'kpi_name', 'value']].head(5)

# --- trace.csv inventory ---
trace_cmdbs = pd.DataFrame(sorted(df_trace['cmdb_id'].dropna().unique()), columns=['cmdb_id'])
trace_names_top20 = pd.DataFrame(sorted(df_trace['trace_name'].dropna().unique())[:20], columns=['trace_name'])
trace_counts_top20 = (
    df_trace.groupby('trace_name', dropna=False).size()
    .sort_values(ascending=False)
    .head(20)
    .reset_index(name='count')
)
trace_samples = df_trace[['timestamp', 'cmdb_id', 'trace_name', 'value']].head(5)

# --- log.csv inventory ---
log_cmdbs = pd.DataFrame(sorted(df_log['cmdb_id'].dropna().unique()), columns=['cmdb_id'])
log_names_top20 = pd.DataFrame(sorted(df_log['log_name'].dropna().unique())[:20], columns=['log_name'])
log_counts_top20 = (
    df_log.groupby('log_name', dropna=False).size()
    .sort_values(ascending=False)
    .head(20)
    .reset_index(name='count')
)
log_samples = df_log[['timestamp', 'cmdb_id', 'log_name', 'value']].head(5)

# --- error_logs.csv inventory ---
err_cmdbs = pd.DataFrame(sorted(df_err['cmdb_id'].dropna().unique()), columns=['cmdb_id'])
err_recent = (
    df_err[['timestamp', 'cmdb_id', 'message']]
    .sort_values('timestamp', ascending=False)
    .head(5)
    .reset_index(drop=True)
)

# Display compact summaries (variables listed so IPython shows them)
metric_cmdbs, metric_kpis_top20, metric_kpi_counts_top20, metric_samples, \
trace_cmdbs, trace_names_top20, trace_counts_top20, trace_samples, \
log_cmdbs, log_names_top20, log_counts_top20, log_samples, \
err_cmdbs, err_recent
