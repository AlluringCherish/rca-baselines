import pandas as pd
import numpy as np

# Reuse df_log and df_err from earlier session; ensure timestamps are parsed as UTC datetimes
df_log['timestamp'] = pd.to_datetime(df_log['timestamp'], utc=True)
df_err['timestamp'] = pd.to_datetime(df_err['timestamp'], utc=True)

service = 'checkoutservice'
start = pd.Timestamp('2024-01-19 09:10:13', tz='UTC')
end   = pd.Timestamp('2024-01-19 09:40:13', tz='UTC')

# 1) Global stats from full series for checkoutservice
df_log_service = df_log[df_log['cmdb_id'] == service].copy()

log_stats = (
    df_log_service
    .groupby('log_name')['value']
    .agg(count='count', mean='mean', min='min', max='max', P95=lambda x: x.quantile(0.95))
    .reset_index()
)

# 2) Windowed analysis for checkoutservice
df_log_window = df_log_service[df_log_service['timestamp'].between(start, end, inclusive='both')].copy().sort_values('timestamp')

rows_in_window = int(df_log_window.shape[0])

# max(log.error_count) in-window
df_errcount_window = df_log_window[df_log_window['log_name'] == 'log.error_count']
max_error_count = df_errcount_window['value'].max() if not df_errcount_window.empty else np.nan

# timestamps where log.error_count > 0 (limit top 20)
error_count_positive_ts = df_errcount_window[df_errcount_window['value'] > 0][['timestamp','value']].sort_values('timestamp').head(20).reset_index(drop=True)

# row_count stats in-window (min/mean/max)
df_rowcount_window = df_log_window[df_log_window['log_name'] == 'log.row_count'].sort_values('timestamp').reset_index(drop=True)
if not df_rowcount_window.empty:
    rowcount_min = df_rowcount_window['value'].min()
    rowcount_mean = df_rowcount_window['value'].mean()
    rowcount_max = df_rowcount_window['value'].max()
else:
    rowcount_min = rowcount_mean = rowcount_max = np.nan

# earliest timestamp of notable change (>10% jump) in row_count compared to previous minute (if computable)
earliest_notable_change = pd.NaT
if not df_rowcount_window.empty and len(df_rowcount_window) >= 2:
    # compute previous value
    df_rowcount_window['prev'] = df_rowcount_window['value'].shift(1)
    # define notable change:
    # - if prev == 0 and current > 0 -> treat as notable (infinite pct)
    # - else if prev != 0 and abs(cur - prev)/prev > 0.10 -> notable
    def is_notable(cur, prev):
        if pd.isna(prev):
            return False
        if prev == 0:
            return cur > 0
        return abs(cur - prev) / prev > 0.10

    notable_mask = df_rowcount_window.apply(lambda r: is_notable(r['value'], r['prev']), axis=1)
    notable_idxs = df_rowcount_window[notable_mask].index
    if len(notable_idxs) > 0:
        earliest_notable_change = df_rowcount_window.loc[notable_idxs[0], 'timestamp']

# Assemble a compact window summary DataFrame (single row)
window_summary = pd.DataFrame([{
    'cmdb_id': service,
    'rows_in_window': rows_in_window,
    'max_log.error_count_in_window': max_error_count,
    'row_count_min_in_window': rowcount_min,
    'row_count_mean_in_window': rowcount_mean,
    'row_count_max_in_window': rowcount_max,
    'earliest_row_count_notable_change': earliest_notable_change
}])

# 3) error_logs.csv rows for checkoutservice within the window (up to 20 rows)
err_logs_service_window = (
    df_err[(df_err['cmdb_id'] == service) & df_err['timestamp'].between(start, end, inclusive='both')]
    [['timestamp','message']]
    .sort_values('timestamp', ascending=False)
    .head(20)
    .reset_index(drop=True)
)

# Display compact results
log_stats, window_summary, error_count_positive_ts, err_logs_service_window
