import pandas as pd
import numpy as np

# Reuse df_metric if available; otherwise load and parse timestamps
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
    df_metric['timestamp'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)

# Ensure timestamp parsed correctly (idempotent)
df_metric['timestamp'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True)

# 1) Define incident window (UTC)
start = pd.to_datetime('2024-01-20T04:36:00Z', utc=True)
end = pd.to_datetime('2024-01-20T05:06:00Z', utc=True)

# 2) Compute global P95 per (cmdb_id, kpi_name) from the full series BEFORE filtering
p95_global = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'], dropna=False)['value']
    .quantile(0.95)
    .reset_index(name='p95')
)

# 3) Filter metric.csv to the specified services and incident window
services = ["checkoutservice","currencyservice","emailservice","productcatalogservice","recommendationservice"]
df_window = df_metric[
    df_metric['cmdb_id'].isin(services) &
    (df_metric['timestamp'] >= start) &
    (df_metric['timestamp'] <= end)
].copy()

# If no in-window rows, produce empty summary
if df_window.shape[0] == 0:
    summary_df = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','count','anomaly_count','earliest_anom_ts','max_value','p95','ratio'
    ])
else:
    # Merge global p95 into the windowed rows to enable per-row anomaly checks
    df_win_with_p95 = df_window.merge(p95_global, on=['cmdb_id','kpi_name'], how='left')

    # Determine per-row anomaly boolean (value >= global p95). If p95 is NaN (no global data) treat as False.
    df_win_with_p95['is_anom'] = df_win_with_p95.apply(
        lambda r: False if pd.isna(r['p95']) else (r['value'] >= r['p95']),
        axis=1
    )

    # Aggregate per-group within window
    agg = df_win_with_p95.groupby(['cmdb_id','kpi_name'], dropna=False).agg(
        count = ('value', 'count'),
        anomaly_count = ('is_anom', 'sum'),
        # earliest anomaly timestamp: min timestamp where is_anom True
        earliest_anom_ts = (lambda x: x.loc[x['is_anom'], 'timestamp'].min(),) ,
        max_value = ('value', 'max'),
        p95 = ('p95', 'first')
    )

    # The above custom agg with lambda for earliest_anom_ts requires a workaround: compute separately
    grouped = df_win_with_p95.groupby(['cmdb_id','kpi_name'], dropna=False)
    summary = grouped.agg(
        count = ('value', 'count'),
        anomaly_count = ('is_anom', 'sum'),
        max_value = ('value', 'max'),
        p95 = ('p95', 'first')
    ).reset_index()

    # compute earliest anomaly timestamp per group
    earliest = (
        df_win_with_p95[df_win_with_p95['is_anom']]
        .groupby(['cmdb_id','kpi_name'], dropna=False)['timestamp']
        .min()
        .reset_index(name='earliest_anom_ts')
    )

    summary = summary.merge(earliest, on=['cmdb_id','kpi_name'], how='left')

    # Convert earliest_anom_ts to ISO UTC strings, keep NaT as NaN
    summary['earliest_anom_ts'] = pd.to_datetime(summary['earliest_anom_ts'], utc=True)
    summary['earliest_anom_ts'] = summary['earliest_anom_ts'].dt.strftime('%Y-%m-%dT%H:%M:%SZ')

    # For groups where earliest_anom_ts was NaT, strftime returns NaN; replace with pd.NA for cleanliness
    summary['earliest_anom_ts'] = summary['earliest_anom_ts'].where(summary['anomaly_count']>0, pd.NA)

    # Handle p95 == 0 to avoid division by zero; ratio = max_value / p95, use np.inf when p95 == 0 or NaN if p95 NaN
    def compute_ratio(row):
        p = row['p95']
        m = row['max_value']
        if pd.isna(p):
            return np.nan
        if p == 0:
            return np.inf
        return m / p

    summary['ratio'] = summary.apply(compute_ratio, axis=1)

    # Round numeric columns for compactness
    summary['p95'] = summary['p95'].astype(float).round(6)
    summary['max_value'] = summary['max_value'].astype(float).round(6)

    # Select and order columns as requested
    summary_df = summary[[
        'cmdb_id','kpi_name','count','anomaly_count','earliest_anom_ts','max_value','p95','ratio'
    ]]

    # Sort by anomaly_count desc, then ratio desc, limit to top 20
    summary_df = summary_df.sort_values(['anomaly_count','ratio'], ascending=[False, False]).head(20).reset_index(drop=True)

# Display the compact summary table
summary_df
