    df_error
except NameError:
    df_error = pd.read_csv('error_logs.csv')

# Parse timestamps (idempotent)
df_log['timestamp'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True)
df_error['timestamp'] = pd.to_datetime(df_error['timestamp'], unit='s', utc=True)

