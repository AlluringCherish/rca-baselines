import pandas as pd

# Reuse existing trace if present, otherwise load and parse
if 'trace' not in globals():
    trace = pd.read_csv("trace.csv")
trace['timestamp'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True)
trace['value'] = pd.to_numeric(trace['value'], errors='coerce')

# Candidate services and additional sources to include
services = [
    "checkoutservice",
    "currencyservice",
    "emailservice",
    "productcatalogservice",
    "recommendationservice",
]
include_sources = ['frontendservice', 'root']

# Build a regex to detect references to candidate services in trace_name
svc_regex = '|'.join([s for s in services])
# Also include patterns indicating calls from frontend or to a service
extra_patterns = r'from_frontendservice|to_'  # 'to_' will match e.g., to_currencyservice
pattern = rf'({svc_regex})|({extra_patterns})'

# Filter trace rows: keep rows where cmdb_id is a candidate service OR
# cmdb_id is frontendservice/root and trace_name indicates calls to/from candidate services
mask_services = trace['cmdb_id'].isin(services)
mask_sources = trace['cmdb_id'].isin(include_sources) & trace['trace_name'].str.contains(pattern, na=False)
t_sub = trace[mask_services | mask_sources].copy()

# Incident window (UTC inclusive)
window_start = pd.to_datetime("2024-01-16 06:54:01", utc=True)
window_end = pd.to_datetime("2024-01-16 07:24:01", utc=True)

# Group by (cmdb_id, trace_name) and compute global p95/p5 on full series (before window filtering)
grp = t_sub.groupby(['cmdb_id', 'trace_name'], dropna=False)

rows = []
for (cmdb_id, trace_name), g in grp:
    if pd.isna(trace_name):
        continue
    total_count = int(g.shape[0])
    p95 = float(g['value'].quantile(0.95))
    p5 = float(g['value'].quantile(0.05))
    # filter to incident window
    win = g[(g['timestamp'] >= window_start) & (g['timestamp'] <= window_end)]
    window_count = int(win.shape[0])
    if window_count == 0:
        anomalies_high = 0
        anomalies_low = 0
        earliest_ts = pd.NaT
    else:
        anomalies_high = int((win['value'] >= p95).sum())
        anomalies_low = int((win['value'] <= p5).sum())
        mask_anom = (win['value'] >= p95) | (win['value'] <= p5)
        earliest_ts = win.loc[mask_anom, 'timestamp'].min() if mask_anom.any() else pd.NaT

    rows.append({
        'cmdb_id': cmdb_id,
        'trace_name': trace_name,
        'total_count': total_count,
        'p95': p95,
        'p5': p5,
        'window_count': window_count,
        'anomalies_high': anomalies_high,
        'anomalies_low': anomalies_low,
        'earliest_anomaly_timestamp': earliest_ts,
    })

result_df = pd.DataFrame(rows)

# Keep only pairs with window_count > 0
result_df = result_df[result_df['window_count'] > 0].copy()

# Format earliest_anomaly_timestamp as ISO string or None
result_df['earliest_anomaly_timestamp'] = result_df['earliest_anomaly_timestamp'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
result_df['earliest_anomaly_timestamp'] = result_df['earliest_anomaly_timestamp'].where(result_df['earliest_anomaly_timestamp'].notna(), None)

# Sort by severity (anomalies_high, anomalies_low, window_count) and limit to top 50
result_df = result_df.sort_values(by=['anomalies_high', 'anomalies_low', 'window_count'], ascending=False)
result_df = result_df[['cmdb_id', 'trace_name', 'total_count', 'p95', 'p5', 'window_count', 'anomalies_high', 'anomalies_low', 'earliest_anomaly_timestamp']].head(50)

# Additionally, return up to 20 trace rows in the incident window where:
# cmdb_id is currencyservice OR trace_name contains "from_frontendservice" OR "to_currencyservice"
win_all = t_sub[(t_sub['timestamp'] >= window_start) & (t_sub['timestamp'] <= window_end)].copy()
filter_cond = (
    (win_all['cmdb_id'] == 'currencyservice') |
    (win_all['trace_name'].str.contains('from_frontendservice', na=False)) |
    (win_all['trace_name'].str.contains('to_currencyservice', na=False))
)
filtered_rows = win_all.loc[filter_cond, ['timestamp', 'cmdb_id', 'trace_name', 'value']].copy()
# Format timestamp to ISO string for compactness
filtered_rows['timestamp'] = filtered_rows['timestamp'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
filtered_rows = filtered_rows.head(20)

# Output the two compact results (DataFrames)
result_df, filtered_rows
