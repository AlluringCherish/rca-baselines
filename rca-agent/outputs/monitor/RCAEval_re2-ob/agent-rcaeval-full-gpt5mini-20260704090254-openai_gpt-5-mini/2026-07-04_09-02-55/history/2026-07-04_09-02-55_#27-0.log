import pandas as pd
import numpy as np

# Reuse existing metric and log if present; otherwise load and parse
if 'metric' not in globals():
    metric = pd.read_csv("metric.csv")
metric['timestamp'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)
metric['value'] = pd.to_numeric(metric['value'], errors='coerce')

if 'log' not in globals():
    log = pd.read_csv("log.csv")
log['timestamp'] = pd.to_datetime(log['timestamp'], unit='s', utc=True)
log['value'] = pd.to_numeric(log['value'], errors='coerce')

# Focus on currencyservice metrics
svc = 'currencyservice'
m_svc = metric[metric['cmdb_id'] == svc].copy()

# Incident window (UTC inclusive)
window_start = pd.to_datetime("2024-01-16 06:54:01", utc=True)
window_end = pd.to_datetime("2024-01-16 07:24:01", utc=True)

rows = []
grp = m_svc.groupby('kpi_name', dropna=False)
for kpi_name, g in grp:
    if pd.isna(kpi_name):
        continue
    total_count = int(g.shape[0])
    # Global thresholds computed on full series BEFORE window filtering
    p95 = float(g['value'].quantile(0.95))
    p5 = float(g['value'].quantile(0.05))
    # Window filtering
    win = g[(g['timestamp'] >= window_start) & (g['timestamp'] <= window_end)]
    window_count = int(win.shape[0])
    if window_count > 0:
        anomalies_high = int((win['value'] >= p95).sum())
        anomalies_low = int((win['value'] <= p5).sum())
        mask_anom = (win['value'] >= p95) | (win['value'] <= p5)
        earliest_ts = win.loc[mask_anom, 'timestamp'].min() if mask_anom.any() else pd.NaT
        window_max = float(win['value'].max()) if not win['value'].isna().all() else np.nan
        window_median = float(win['value'].median()) if not win['value'].isna().all() else np.nan
    else:
        anomalies_high = 0
        anomalies_low = 0
        earliest_ts = pd.NaT
        window_max = np.nan
        window_median = np.nan

    rows.append({
        'kpi_name': kpi_name,
        'total_count': total_count,
        'p95': p95,
        'p5': p5,
        'window_count': window_count,
        'anomalies_high': anomalies_high,
        'anomalies_low': anomalies_low,
        'earliest_anomaly_timestamp': earliest_ts,
        'window_max': window_max,
        'window_median': window_median,
    })

result_df = pd.DataFrame(rows)

# Keep all currencyservice kpi_names but limit output to top 50 rows after sorting by severity
result_df['earliest_anomaly_timestamp'] = pd.to_datetime(result_df['earliest_anomaly_timestamp'], utc=True)
result_df = result_df.sort_values(by=['anomalies_high', 'anomalies_low', 'window_count'], ascending=False).head(50)

# Format earliest_anomaly_timestamp as ISO string or None
result_df['earliest_anomaly_timestamp'] = result_df['earliest_anomaly_timestamp'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
result_df['earliest_anomaly_timestamp'] = result_df['earliest_anomaly_timestamp'].where(result_df['earliest_anomaly_timestamp'].notna(), None)

# Select and order columns as requested
result_df = result_df[['kpi_name', 'total_count', 'p95', 'p5', 'window_count', 'anomalies_high', 'anomalies_low', 'earliest_anomaly_timestamp', 'window_max', 'window_median']]

# Additionally, return any log.csv rows for currencyservice within the incident window (limit 20)
log_window = log[(log['cmdb_id'] == svc) & (log['timestamp'] >= window_start) & (log['timestamp'] <= window_end)].copy()
if not log_window.empty:
    log_window['timestamp'] = log_window['timestamp'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
    log_window = log_window[['timestamp', 'cmdb_id', 'log_name', 'value']].head(20)

# Output the compact results (DataFrames)
result_df, log_window
