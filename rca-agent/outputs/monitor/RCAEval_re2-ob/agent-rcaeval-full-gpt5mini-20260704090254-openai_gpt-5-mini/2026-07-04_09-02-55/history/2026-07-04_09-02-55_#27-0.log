import pandas as pd

# Reuse existing metric if present, otherwise load and parse timestamps
if 'metric' not in globals():
    metric = pd.read_csv("metric.csv")
    metric['timestamp'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)
else:
    # ensure timestamp parsed and in UTC
    if metric['timestamp'].dtype == 'int64' or metric['timestamp'].dtype == 'float64':
        metric['timestamp'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)
    else:
        metric['timestamp'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True)

# Ensure value is numeric
metric['value'] = pd.to_numeric(metric['value'], errors='coerce')

# Restrict to the five possible root-cause services
services = [
    "checkoutservice",
    "currencyservice",
    "emailservice",
    "productcatalogservice",
    "recommendationservice",
]
m5 = metric[metric['cmdb_id'].isin(services)].copy()

# Define incident window (UTC) inclusive
window_start = pd.to_datetime("2024-01-16 06:54:01", utc=True)
window_end = pd.to_datetime("2024-01-16 07:24:01", utc=True)

# Group by (cmdb_id, kpi_name) and compute global p95, p5, total_count
grp = m5.groupby(['cmdb_id', 'kpi_name'], dropna=False)

summary_rows = []
for (cmdb_id, kpi_name), group in grp:
    # skip if kpi_name is NaN
    if pd.isna(kpi_name):
        continue
    total_count = int(group.shape[0])
    # global thresholds computed on full series BEFORE filtering
    p95 = float(group['value'].quantile(0.95))
    p5 = float(group['value'].quantile(0.05))
    # filter to incident window
    window_df = group[(group['timestamp'] >= window_start) & (group['timestamp'] <= window_end)]
    window_count = int(window_df.shape[0])
    if window_count == 0:
        anomalies_high = 0
        anomalies_low = 0
        earliest_anom_ts = pd.NaT
    else:
        anomalies_high = int((window_df['value'] >= p95).sum())
        anomalies_low = int((window_df['value'] <= p5).sum())
        # find earliest timestamp among either high or low anomalies
        mask_anom = (window_df['value'] >= p95) | (window_df['value'] <= p5)
        if mask_anom.any():
            earliest_anom_ts = window_df.loc[mask_anom, 'timestamp'].min()
        else:
            earliest_anom_ts = pd.NaT

    summary_rows.append({
        'cmdb_id': cmdb_id,
        'kpi_name': kpi_name,
        'total_count': total_count,
        'p95': p95,
        'p5': p5,
        'window_count': window_count,
        'anomalies_high': anomalies_high,
        'anomalies_low': anomalies_low,
        'earliest_anomaly_timestamp': earliest_anom_ts,
    })

result_df = pd.DataFrame(summary_rows)

# Keep only pairs with window_count > 0
result_df = result_df[result_df['window_count'] > 0].copy()

# Format earliest_anomaly_timestamp as ISO strings (UTC) or None
result_df['earliest_anomaly_timestamp'] = result_df['earliest_anomaly_timestamp'].dt.strftime('%Y-%m-%dT%H:%M:%S%z')
result_df['earliest_anomaly_timestamp'] = result_df['earliest_anomaly_timestamp'].replace({pd.NaT: None})
result_df['earliest_anomaly_timestamp'] = result_df['earliest_anomaly_timestamp'].where(result_df['earliest_anomaly_timestamp'].notna(), None)

# Sort by anomalies_high desc, anomalies_low desc, window_count desc for priority
result_df = result_df.sort_values(by=['anomalies_high', 'anomalies_low', 'window_count'], ascending=False)

# Limit to top 50 rows (as requested) and present compact selected columns
result_df = result_df[['cmdb_id', 'kpi_name', 'total_count', 'p95', 'p5', 'window_count', 'anomalies_high', 'anomalies_low', 'earliest_anomaly_timestamp']].head(50)

# Display the result (variable output)
result_df
