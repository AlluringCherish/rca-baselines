        p05_value=('value', lambda x: float(x.quantile(0.05)))
    )
)

trace_window = trace_cand[(trace_cand['timestamp'] >= start_ts) & (trace_cand['timestamp'] <= end_ts)].copy()

trace_win_join = trace_window.merge(trace_thresholds, left_on=['cmdb_id','trace_name'], right_on=['cmdb_id','trace_name'], how='right')
trace_win_join['is_high'] = trace_win_join['value'].notna() & (trace_win_join['value'] > trace_win_join['p95_value'])
trace_win_join['is_low'] = trace_win_join['value'].notna() & (trace_win_join['value'] < trace_win_join['p05_value'])

trace_window_agg = (
    trace_win_join
    .groupby(['cmdb_id', 'trace_name', 'p95_value', 'p05_value'], as_index=False)
    .agg(
        count_in_window=('value', lambda x: int(x.notna().sum())),
        count_high_anom=('is_high', 'sum'),
        earliest_high_anom_timestamp_unix=('timestamp', lambda s: int(s[trace_win_join.loc[s.index, 'is_high']].min()) if (s[trace_win_join.loc[s.index, 'is_high']].notna().any()) else pd.NA),
        max_value_in_window=('value', lambda x: float(x.max()) if x.notna().any() else np.nan),
        count_low_anom=('is_low', 'sum'),
        earliest_low_anom_timestamp_unix=('timestamp', lambda s: int(s[trace_win_join.loc[s.index, 'is_low']].min()) if (s[trace_win_join.loc[s.index, 'is_low']].notna().any()) else pd.NA),
        min_value_in_window=('value', lambda x: float(x.min()) if x.notna().any() else np.nan)
    )
)

trace_window_agg['count_in_window'] = trace_window_agg['count_in_window'].astype(int)
trace_window_agg['count_high_anom'] = trace_window_agg['count_high_anom'].astype(int)
trace_window_agg['count_low_anom'] = trace_window_agg['count_low_anom'].astype(int)

trace_window_agg['severity_high'] = trace_window_agg.apply(compute_severity_high, axis=1)
trace_window_agg['severity_low'] = trace_window_agg.apply(compute_severity_low, axis=1)

trace_out = trace_window_agg.rename(columns={'cmdb_id':'component','trace_name':'KPI_name'})[[
    'component','KPI_name','count_in_window','count_high_anom','earliest_high_anom_timestamp_unix',
    'max_value_in_window','severity_high','count_low_anom','earliest_low_anom_timestamp_unix',
    'min_value_in_window','severity_low'
]].sort_values('severity_high', ascending=False).reset_index(drop=True)

trace_top20 = trace_out.head(20)

# --- Identify components with zero anomalies (both high and low) across metric+trace inside window ---
# Sum anomalies per component across both metric_out and trace_out
metric_anom_by_comp = metric_out.groupby('component', as_index=False).agg(total_high=('count_high_anom','sum'), total_low=('count_low_anom','sum'))
trace_anom_by_comp = trace_out.groupby('component', as_index=False).agg(total_high=('count_high_anom','sum'), total_low=('count_low_anom','sum'))

# Combine
anom_comb = pd.merge(
    pd.DataFrame({'component': candidates}),
    metric_anom_by_comp, on='component', how='left'
).merge(trace_anom_by_comp, on='component', how='left', suffixes=('_metric','_trace'))

anom_comb = anom_comb.fillna(0)
anom_comb['total_high'] = anom_comb['total_high_metric'] + anom_comb['total_high_trace']
anom_comb['total_low'] = anom_comb['total_low_metric'] + anom_comb['total_low_trace']

zero_anomaly_components = anom_comb[(anom_comb['total_high']==0) & (anom_comb['total_low']==0)]['component'].tolist()

# Final compact outputs: metric_top20, trace_top20, zero_anomaly_components
metric_top20, trace_top20, zero_anomaly_components
