# Reuse previously loaded DataFrames: metric, trace, log
import pandas as pd

candidates = [
    "checkoutservice",
    "currencyservice",
    "emailservice",
    "productcatalogservice",
    "recommendationservice"
]

# Metric aggregations
metric_filtered = metric[metric['cmdb_id'].isin(candidates)]
metric_agg = (
    metric_filtered
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        count=('value', 'count'),
        min_timestamp_unix=('timestamp', 'min'),
        max_timestamp_unix=('timestamp', 'max'),
        p95_value=('value', lambda x: float(x.quantile(0.95)))
    )
    .rename(columns={'cmdb_id': 'component', 'kpi_name': 'KPI_name'})
    .sort_values(['component', 'KPI_name'])
    .reset_index(drop=True)
)

# Trace aggregations
trace_filtered = trace[trace['cmdb_id'].isin(candidates)]
trace_agg = (
    trace_filtered
    .groupby(['cmdb_id', 'trace_name'], as_index=False)
    .agg(
        count=('value', 'count'),
        min_timestamp_unix=('timestamp', 'min'),
        max_timestamp_unix=('timestamp', 'max'),
        p95_value=('value', lambda x: float(x.quantile(0.95)))
    )
    .rename(columns={'cmdb_id': 'component', 'trace_name': 'KPI_name'})
    .sort_values(['component', 'KPI_name'])
    .reset_index(drop=True)
)

# Log aggregations
log_filtered = log[log['cmdb_id'].isin(candidates)]
log_agg = (
    log_filtered
    .groupby(['cmdb_id', 'log_name'], as_index=False)
    .agg(
        count=('value', 'count'),
        min_timestamp_unix=('timestamp', 'min'),
        max_timestamp_unix=('timestamp', 'max'),
        p95_value=('value', lambda x: float(x.quantile(0.95)))
    )
    .rename(columns={'cmdb_id': 'component', 'log_name': 'KPI_name'})
    .sort_values(['component', 'KPI_name'])
    .reset_index(drop=True)
)

# Limit overall output size to at most 100 rows (split proportionally if needed)
total_rows = len(metric_agg) + len(trace_agg) + len(log_agg)
if total_rows <= 100:
    metric_out, trace_out, log_out = metric_agg, trace_agg, log_agg
else:
    # allocate up to 100 rows across the three tables, preferring metric, then trace, then log
    remain = 100
    m_n = min(len(metric_agg), remain); remain -= m_n
    t_n = min(len(trace_agg), remain); remain -= t_n
    l_n = min(len(log_agg), remain)
    metric_out = metric_agg.head(m_n)
    trace_out = trace_agg.head(t_n)
    log_out = log_agg.head(l_n)

# Compact outputs (one row per component-KPI)
metric_out, trace_out, log_out
