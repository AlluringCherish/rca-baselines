}])

# error_logs.csv summary (top 10 messages)
err_rows = error_logs.shape[0]
err_cmdbs = sorted(error_logs['cmdb_id'].dropna().unique().tolist())
err_min_ts = int(error_logs['timestamp'].min()) if err_rows>0 else None
err_max_ts = int(error_logs['timestamp'].max()) if err_rows>0 else None
