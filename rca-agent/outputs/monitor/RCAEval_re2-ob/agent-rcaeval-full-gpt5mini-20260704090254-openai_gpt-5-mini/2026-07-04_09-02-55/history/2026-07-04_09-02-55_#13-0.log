import pandas as pd

# Helper to format list for compact display, show all if <=20 else top20 + note
def fmt_list(vals, limit=20):
    vals = list(vals)
    if len(vals) <= limit:
        return vals
    else:
        return vals[:limit] + [f"... ({len(vals)-limit} more)"]

# Load CSVs (they are in working directory)
metric = pd.read_csv("metric.csv")
trace = pd.read_csv("trace.csv")
log = pd.read_csv("log.csv")
error_logs = pd.read_csv("error_logs.csv")

# Parse timestamps to UTC datetime as required (keep original unix seconds for min/max)
for df in (metric, trace, log, error_logs):
    if 'timestamp' in df.columns:
        df['timestamp_dt'] = pd.to_datetime(df['timestamp'], unit='s', utc=True)

# Summaries
# metric.csv summary
metric_rows = metric.shape[0]
metric_cmdbs = sorted(metric['cmdb_id'].dropna().unique().tolist())
metric_min_ts = int(metric['timestamp'].min()) if metric_rows>0 else None
metric_max_ts = int(metric['timestamp'].max()) if metric_rows>0 else None
metric_kpi_counts = metric['kpi_name'].value_counts().reset_index()
metric_kpi_counts.columns = ['kpi_name', 'count']
metric_kpi_counts_top = metric_kpi_counts.head(20)

metric_summary = pd.DataFrame([{
    'file': 'metric.csv',
    'rows': metric_rows,
    'unique_cmdb_ids': fmt_list(metric_cmdbs, limit=20),
    'min_timestamp_unix': metric_min_ts,
    'max_timestamp_unix': metric_max_ts,
    'distinct_kpi_names': metric_kpi_counts.shape[0]
}])

# trace.csv summary
trace_rows = trace.shape[0]
trace_cmdbs = sorted(trace['cmdb_id'].dropna().unique().tolist())
trace_min_ts = int(trace['timestamp'].min()) if trace_rows>0 else None
trace_max_ts = int(trace['timestamp'].max()) if trace_rows>0 else None
trace_name_counts = trace['trace_name'].value_counts().reset_index()
trace_name_counts.columns = ['trace_name', 'count']
trace_name_counts_top = trace_name_counts.head(20)

trace_summary = pd.DataFrame([{
    'file': 'trace.csv',
    'rows': trace_rows,
    'unique_cmdb_ids': fmt_list(trace_cmdbs, limit=20),
    'min_timestamp_unix': trace_min_ts,
    'max_timestamp_unix': trace_max_ts,
    'distinct_trace_names': trace_name_counts.shape[0]
}])

# log.csv summary
log_rows = log.shape[0]
log_cmdbs = sorted(log['cmdb_id'].dropna().unique().tolist())
log_min_ts = int(log['timestamp'].min()) if log_rows>0 else None
log_max_ts = int(log['timestamp'].max()) if log_rows>0 else None
log_name_counts = log['log_name'].value_counts().reset_index()
log_name_counts.columns = ['log_name', 'count']
log_name_counts_top = log_name_counts.head(20)

log_summary = pd.DataFrame([{
    'file': 'log.csv',
    'rows': log_rows,
    'unique_cmdb_ids': fmt_list(log_cmdbs, limit=20),
    'min_timestamp_unix': log_min_ts,
    'max_timestamp_unix': log_max_ts,
