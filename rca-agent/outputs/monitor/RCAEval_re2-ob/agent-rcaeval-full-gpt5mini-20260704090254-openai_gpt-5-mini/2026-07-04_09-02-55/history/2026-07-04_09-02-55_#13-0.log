        if highs.any():
            earliest_anom = int(df_t.loc[highs, 'timestamp'].min())
        else:
            earliest_anom = pd.NA
        max_val = float(df_t['value'].max())
    trace_summary_rows.append({
        'component': component,
        'series_type': 'trace',
        'name': tname,
        'count_in_window': count_in_window,
        'count_consecutive_anom_runs': count_runs,
        'earliest_anom_timestamp_unix': earliest_anom,
        'max_value_in_window': max_val,
        'p95_global': p95
    })

trace_summary = pd.DataFrame(trace_summary_rows)
trace_summary = trace_summary.sort_values(by=['count_consecutive_anom_runs','max_value_in_window'], ascending=[False, False]).reset_index(drop=True).head(50)

