import pandas as pd
import numpy as np

# Reuse previously loaded DataFrames: metric, trace
# Candidates list (reuse)
candidates = [
    "checkoutservice",
    "currencyservice",
    "emailservice",
    "productcatalogservice",
    "recommendationservice"
]

# Incident window (UTC) -> unix seconds
start_ts = int(pd.Timestamp("2024-01-19 00:46:17", tz="UTC").timestamp())
end_ts = int(pd.Timestamp("2024-01-19 01:16:17", tz="UTC").timestamp())

# Sentinel for infinite severity when dividing by zero
SENTINEL = 1e9

# --- METRIC: compute global P95 and P05 per (component, kpi) using full series (before filtering) ---
metric_cand = metric[metric['cmdb_id'].isin(candidates)].copy()

metric_thresholds = (
    metric_cand
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        p95_value=('value', lambda x: float(x.quantile(0.95))),
        p05_value=('value', lambda x: float(x.quantile(0.05)))
    )
)

# Filter metric to incident window
metric_window = metric_cand[(metric_cand['timestamp'] >= start_ts) & (metric_cand['timestamp'] <= end_ts)].copy()

# Join thresholds onto window rows to mark anomalies
metric_win_join = metric_window.merge(metric_thresholds, left_on=['cmdb_id','kpi_name'], right_on=['cmdb_id','kpi_name'], how='right', suffixes=('','_thr'))
# Note: using right join ensures groups with no rows in window still appear (with NaNs from window columns)

# Create flags for anomalies per row (where value available)
metric_win_join['is_high'] = metric_win_join['value'].notna() & (metric_win_join['value'] > metric_win_join['p95_value'])
metric_win_join['is_low'] = metric_win_join['value'].notna() & (metric_win_join['value'] < metric_win_join['p05_value'])

# Aggregate per group
metric_window_agg = (
    metric_win_join
    .groupby(['cmdb_id', 'kpi_name', 'p95_value', 'p05_value'], as_index=False)
    .agg(
        count_in_window=('value', lambda x: int(x.notna().sum())),
        count_high_anom=('is_high', 'sum'),
        earliest_high_anom_timestamp_unix=('timestamp', lambda s: int(s[metric_win_join.loc[s.index, 'is_high']].min()) if (s[metric_win_join.loc[s.index, 'is_high']].notna().any()) else pd.NA),
        max_value_in_window=('value', lambda x: float(x.max()) if x.notna().any() else np.nan),
        count_low_anom=('is_low', 'sum'),
        earliest_low_anom_timestamp_unix=('timestamp', lambda s: int(s[metric_win_join.loc[s.index, 'is_low']].min()) if (s[metric_win_join.loc[s.index, 'is_low']].notna().any()) else pd.NA),
        min_value_in_window=('value', lambda x: float(x.min()) if x.notna().any() else np.nan)
    )
)

# Replace 0-length counts (they may be numpy int64) to python int
metric_window_agg['count_in_window'] = metric_window_agg['count_in_window'].astype(int)
metric_window_agg['count_high_anom'] = metric_window_agg['count_high_anom'].astype(int)
metric_window_agg['count_low_anom'] = metric_window_agg['count_low_anom'].astype(int)

# Compute severities according to rules
def compute_severity_high(row):
    p95 = row['p95_value']
    mv = row['max_value_in_window']
    if row['count_in_window'] == 0 or np.isnan(mv):
        return np.nan
    if p95 == 0:
        if mv > 0:
            return SENTINEL
        else:
            return np.nan
    return float(mv / p95)

def compute_severity_low(row):
    p05 = row['p05_value']
    mn = row['min_value_in_window']
    if row['count_in_window'] == 0 or np.isnan(mn):
        return np.nan
    if p05 > 0:
        if mn == 0:
            return SENTINEL
        return float(p05 / mn)
    return np.nan

metric_window_agg['severity_high'] = metric_window_agg.apply(compute_severity_high, axis=1)
metric_window_agg['severity_low'] = metric_window_agg.apply(compute_severity_low, axis=1)

# Rename columns for output consistency
metric_out = metric_window_agg.rename(columns={
    'cmdb_id':'component',
    'kpi_name':'KPI_name'
})[[
    'component','KPI_name','count_in_window','count_high_anom','earliest_high_anom_timestamp_unix',
    'max_value_in_window','severity_high','count_low_anom','earliest_low_anom_timestamp_unix',
    'min_value_in_window','severity_low'
]].sort_values('severity_high', ascending=False).reset_index(drop=True)

# Ensure rows exist for any (component,kpi) combos missing originally (should be covered by right join above)

# Limit to top 20 by severity_high
metric_top20 = metric_out.head(20)

# --- TRACE: same process for traces ---
trace_cand = trace[trace['cmdb_id'].isin(candidates)].copy()

trace_thresholds = (
