import pandas as pd
import numpy as np

# Reuse metric, trace DataFrames already loaded in the session.

# Parameters
component = 'recommendationservice'
start_ts = int(pd.Timestamp("2024-01-19 00:46:17", tz="UTC").timestamp())
end_ts = int(pd.Timestamp("2024-01-19 01:16:17", tz="UTC").timestamp())

# 1) Metric rows for recommendationservice inside window
metric_rec_all = metric[metric['cmdb_id'] == component].copy()

metric_rec_window = metric_rec_all[(metric_rec_all['timestamp'] >= start_ts) & (metric_rec_all['timestamp'] <= end_ts)].copy()
metric_rec_window = metric_rec_window[['timestamp', 'kpi_name', 'value']].sort_values('timestamp', ascending=True).reset_index(drop=True)
metric_rec_window = metric_rec_window.head(200)  # limit to 200 rows

# 2) Trace rows for recommendationservice inside window, filtered by trace_name patterns
# Patterns: contains 'from_root' or 'from_recommendationservice' or 'to_productcatalogservice'
trace_rec_all = trace[trace['cmdb_id'] == component].copy()
pattern = r'(from_root|from_recommendationservice|to_productcatalogservice)'
mask = trace_rec_all['trace_name'].str.contains(pattern, regex=True)
trace_rec_window = trace_rec_all[mask & (trace_rec_all['timestamp'] >= start_ts) & (trace_rec_all['timestamp'] <= end_ts)].copy()
trace_rec_window = trace_rec_window[['timestamp', 'trace_name', 'value']].sort_values('timestamp', ascending=True).reset_index(drop=True)
trace_rec_window = trace_rec_window.head(200)  # limit to 200 rows

# 3) Compact summary per KPI (metrics) and per trace_name (traces):
# Rule: compute global P95 using full series BEFORE filtering

# METRIC SUMMARY
# Compute global P95 per kpi_name for recommendationservice (full series)
metric_rec_thresholds = (
    metric_rec_all
    .groupby('kpi_name', as_index=True)['value']
    .quantile(0.95)
    .rename('p95')
    .to_frame()
)
kpi_list = metric_rec_thresholds.index.tolist()

metric_summary_rows = []
for kpi in kpi_list:
    p95 = float(metric_rec_thresholds.at[kpi, 'p95'])
    df_k = metric_rec_window[metric_rec_window['kpi_name'] == kpi].sort_values('timestamp')
    count_in_window = int(df_k.shape[0])
    if count_in_window == 0:
        count_runs = 0
        earliest_anom = pd.NA
        max_val = np.nan
    else:
        vals = df_k['value'].astype(float).to_numpy()
        highs = vals > p95
        # count consecutive runs of highs
        if highs.size == 0:
            count_runs = 0
        else:
            # transitions from False->True
            prev = np.concatenate(([False], highs[:-1]))
            count_runs = int(np.sum((~prev) & highs))
        # earliest anomaly timestamp
        if highs.any():
            earliest_anom = int(df_k.loc[highs, 'timestamp'].min())
        else:
            earliest_anom = pd.NA
        max_val = float(df_k['value'].max())
    metric_summary_rows.append({
        'component': component,
        'series_type': 'metric',
        'name': kpi,
        'count_in_window': count_in_window,
        'count_consecutive_anom_runs': count_runs,
        'earliest_anom_timestamp_unix': earliest_anom,
        'max_value_in_window': max_val,
        'p95_global': p95
    })

metric_summary = pd.DataFrame(metric_summary_rows)
metric_summary = metric_summary.sort_values(by=['count_consecutive_anom_runs','max_value_in_window'], ascending=[False, False]).reset_index(drop=True).head(50)

# TRACE SUMMARY
# Determine full set of trace_names for recommendationservice (we restrict to names matching the retrieval patterns AND any trace_names present for this component)
trace_rec_thresholds = (
    trace_rec_all
    .groupby('trace_name', as_index=True)['value']
    .quantile(0.95)
    .rename('p95')
    .to_frame()
)
trace_list = trace_rec_thresholds.index.tolist()

trace_summary_rows = []
for tname in trace_list:
    p95 = float(trace_rec_thresholds.at[tname, 'p95'])
    df_t = trace_rec_window[trace_rec_window['trace_name'] == tname].sort_values('timestamp')
    count_in_window = int(df_t.shape[0])
    if count_in_window == 0:
        count_runs = 0
        earliest_anom = pd.NA
        max_val = np.nan
    else:
        vals = df_t['value'].astype(float).to_numpy()
