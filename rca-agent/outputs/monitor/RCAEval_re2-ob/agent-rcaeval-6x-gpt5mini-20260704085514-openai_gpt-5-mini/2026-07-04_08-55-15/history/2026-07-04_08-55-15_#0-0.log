import pandas as pd

# Load CSVs (files are in current working directory)
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")
log_df = pd.read_csv("log.csv")
error_df = pd.read_csv("error_logs.csv")

# Parse timestamp to datetime with unit='s' and UTC
for df in (metric_df, trace_df, log_df, error_df):
    df['timestamp'] = pd.to_datetime(df['timestamp'], unit='s', utc=True)

# Helper to build compact report for a dataframe
def build_report(df, name_field):
    total_rows = df.shape[0]
    if total_rows:
        min_ts = df['timestamp'].min().isoformat()
        max_ts = df['timestamp'].max().isoformat()
    else:
        min_ts = None
        max_ts = None
    top_cmdb = df['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count').head(20)
    if name_field in df.columns:
        top_names = df[name_field].value_counts().rename_axis(name_field).reset_index(name='count').head(50)
    else:
        top_names = pd.DataFrame(columns=[name_field, 'count'])
    samples = df.head(5)
    summary = pd.Series({
        'file_rows': total_rows,
        'min_timestamp_utc': min_ts,
        'max_timestamp_utc': max_ts,
        'unique_cmdb_ids': df['cmdb_id'].nunique()
    })
    return summary, top_cmdb, top_names, samples

# Build reports
metric_report = build_report(metric_df, 'kpi_name')
trace_report = build_report(trace_df, 'trace_name')
log_report = build_report(log_df, 'log_name')
error_report = build_report(error_df, 'message')

# Display the four reports (each is a tuple: summary, top_cmdb, top_names, samples)
metric_report, trace_report, log_report, error_report
