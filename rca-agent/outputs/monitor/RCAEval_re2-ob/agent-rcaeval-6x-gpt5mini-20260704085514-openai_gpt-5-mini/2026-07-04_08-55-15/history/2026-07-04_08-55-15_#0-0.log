import pandas as pd
import numpy as np

# Reuse metric_df from kernel state

# 1) Compute global P95 thresholds per (cmdb_id, kpi_name) using full series
thresholds_df = metric_df.groupby(['cmdb_id', 'kpi_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value': 'p95'})

# 2) Filter metric_df to the incident window (inclusive) and store
start = pd.Timestamp('2024-01-15 21:21:06', tz='UTC')
end = pd.Timestamp('2024-01-15 21:51:06', tz='UTC')
metric_incident_df = metric_df[(metric_df['timestamp'] >= start) & (metric_df['timestamp'] <= end)].copy()

# 3) Merge p95 into incident data, flag anomalies, and aggregate per group
metric_incident_with_p95 = metric_incident_df.merge(thresholds_df, on=['cmdb_id', 'kpi_name'], how='left')

# If any p95 missing (shouldn't happen), fill with 0 to avoid errors (will produce inf ratio)
metric_incident_with_p95['p95'] = metric_incident_with_p95['p95'].fillna(0.0)

metric_incident_with_p95['is_anomaly'] = metric_incident_with_p95['value'] > metric_incident_with_p95['p95']

# Aggregations: n_points, anomaly_count, max_value, p95 (first)
group_summary = metric_incident_with_p95.groupby(['cmdb_id', 'kpi_name'], as_index=False).agg(
    n_points=('value', 'size'),
    anomaly_count=('is_anomaly', 'sum'),
    max_value=('value', 'max'),
    p95=('p95', 'first')
)

# Earliest anomaly timestamp per group (if any)
earliest_anom = (
    metric_incident_with_p95[metric_incident_with_p95['is_anomaly']]
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['timestamp']
    .min()
    .rename(columns={'timestamp': 'earliest_anomaly_timestamp'})
)

# Merge earliest anomaly timestamp into group_summary
group_anomaly_summary = group_summary.merge(earliest_anom, on=['cmdb_id', 'kpi_name'], how='left')

# Convert earliest timestamp to ISO UTC string (or None)
group_anomaly_summary['earliest_anomaly_timestamp_utc'] = group_anomaly_summary['earliest_anomaly_timestamp'].apply(
    lambda x: x.isoformat() if pd.notnull(x) else None
)

# Compute severity_ratio = max_value / p95, handle p95 == 0 => inf
def compute_severity(row):
    p95 = row['p95']
    if p95 == 0:
        return float('inf') if row['max_value'] > 0 else 0.0
    return row['max_value'] / p95

group_anomaly_summary['severity_ratio'] = group_anomaly_summary.apply(compute_severity, axis=1)

