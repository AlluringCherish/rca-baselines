import pandas as pd
import numpy as np

# Reuse thresholds_df and metric_incident_df from kernel state

# Merge p95 thresholds into incident data
inc = metric_incident_df.merge(thresholds_df, on=['cmdb_id', 'kpi_name'], how='left').copy()

# Fill missing p95 with 0.0 (handle later as inf)
inc['p95'] = inc['p95'].fillna(0.0)

# Mark anomaly points where value > p95
inc['is_anomaly'] = inc['value'] > inc['p95']

# Keep only anomaly rows for run detection
anom = inc[inc['is_anomaly']].copy()

# If no anomalies, create empty faults_df accordingly
if anom.empty:
    faults_df = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','start_timestamp_utc','end_timestamp_utc',
        'duration_minutes','n_points','max_value','p95_threshold','severity_ratio'
    ])
    faults_count = 0
    distinct_cmdb_count = 0
else:
    # Sort by group and timestamp
    anom = anom.sort_values(['cmdb_id','kpi_name','timestamp']).reset_index(drop=True)

    # Compute minute-diff within each group to find contiguous runs (diff == 1 minute)
    anom['prev_ts'] = anom.groupby(['cmdb_id','kpi_name'])['timestamp'].shift(1)
    anom['diff_min'] = (anom['timestamp'] - anom['prev_ts']) / pd.Timedelta(minutes=1)
    # Start of a new run when diff_min != 1 or previous is NaN
    anom['new_run'] = (anom['diff_min'] != 1) | anom['diff_min'].isna()
    # Unique run id per group
    anom['run_id'] = anom.groupby(['cmdb_id','kpi_name'])['new_run'].cumsum()

    # Aggregate each run
    runs = anom.groupby(['cmdb_id','kpi_name','run_id'], as_index=False).agg(
        start_timestamp=('timestamp', 'min'),
        end_timestamp=('timestamp', 'max'),
        n_points=('timestamp', 'size'),
        max_value=('value', 'max'),
        p95_threshold=('p95', 'first')
    )

    # Keep only runs with length >= 2
    runs = runs[runs['n_points'] >= 2].copy()

    # Compute duration_minutes as (end - start) in minutes (integer)
    runs['duration_minutes'] = ((runs['end_timestamp'] - runs['start_timestamp']) / pd.Timedelta(minutes=1)).astype(int)

    # Compute severity ratio = max_value / p95_threshold (handle p95==0)
    def sev_ratio(row):
        p = row['p95_threshold']
        if p == 0:
            return float('inf') if row['max_value'] > 0 else 0.0
        return row['max_value'] / p

    runs['severity_ratio'] = runs.apply(sev_ratio, axis=1)

    # Format timestamps as ISO UTC strings
    runs['start_timestamp_utc'] = runs['start_timestamp'].dt.tz_convert('UTC').dt.isoformat()
    runs['end_timestamp_utc'] = runs['end_timestamp'].dt.tz_convert('UTC').dt.isoformat()

    # Select and order columns as requested
    faults_df = runs[[
        'cmdb_id','kpi_name','start_timestamp_utc','end_timestamp_utc',
        'duration_minutes','n_points','max_value','p95_threshold','severity_ratio'
    ]].copy()

    # Round numeric columns for compactness
    faults_df['max_value'] = faults_df['max_value'].round(6)
    faults_df['p95_threshold'] = faults_df['p95_threshold'].round(6)
    # Keep severity_ratio as float; replace inf with np.inf for clarity
    faults_df['severity_ratio'] = faults_df['severity_ratio'].replace(np.inf, float('inf')).round(6)

    # Sort by severity_ratio desc then duration_minutes desc, keep top 20 for display later
    faults_df = faults_df.sort_values(['severity_ratio','duration_minutes'], ascending=[False, False]).reset_index(drop=True)

    faults_count = faults_df.shape[0]
    distinct_cmdb_count = faults_df['cmdb_id'].nunique()

# Final compact outputs: full faults_df stored in kernel, and compact displays
# Show top 20 rows (or fewer), total faults count, distinct cmdb count
faults_df_head = faults_df.head(20)
faults_df_head, faults_count, distinct_cmdb_count
