import pandas as pd
import numpy as np

# Reuse existing kernel variable log_df (timestamps already parsed to UTC)

# 1) Global P95 per cmdb_id and log_name (full series)
log_thresholds_df = (
    log_df.groupby(['cmdb_id', 'log_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'p95'})
)

# 2) Filter log_df to the incident window and store
start = pd.Timestamp('2024-01-15 21:21:06', tz='UTC')
end = pd.Timestamp('2024-01-15 21:51:06', tz='UTC')
log_incident_df = log_df[(log_df['timestamp'] >= start) & (log_df['timestamp'] <= end)].copy()

# 3) Join thresholds and mark anomaly points where value > p95
log_incident_with_p95 = log_incident_df.merge(log_thresholds_df, on=['cmdb_id', 'log_name'], how='left')
log_incident_with_p95['p95'] = log_incident_with_p95['p95'].fillna(0.0)
log_incident_with_p95['is_anomaly'] = log_incident_with_p95['value'] > log_incident_with_p95['p95']

# store anomalies only table
log_anomalies_df = log_incident_with_p95[log_incident_with_p95['is_anomaly']].copy()

# 4) Aggregate results for candidate services
candidates = ['checkoutservice', 'currencyservice', 'productcatalogservice', 'recommendationservice', 'emailservice']

# Keep only incident-window rows for candidate cmdb_ids
candidate_incident = log_incident_with_p95[log_incident_with_p95['cmdb_id'].isin(candidates)].copy()

# If none present, create empty summary
if candidate_incident.empty:
    candidate_agg_df = pd.DataFrame(columns=[
        'cmdb_id','log_name','n_points_in_window','anomaly_count',
        'earliest_anomaly_timestamp_utc','max_value','p95_threshold','severity_ratio'
    ])
else:
    # Aggregations per (cmdb_id, log_name)
    agg = candidate_incident.groupby(['cmdb_id', 'log_name'], as_index=False).agg(
        n_points_in_window=('value', 'size'),
        anomaly_count=('is_anomaly', 'sum'),
        max_value=('value', 'max'),
        p95_threshold=('p95', 'first')
    )

    # earliest anomaly timestamp per group (None if no anomalies)
    earliest = (
        candidate_incident[candidate_incident['is_anomaly']]
        .groupby(['cmdb_id', 'log_name'], as_index=False)['timestamp']
        .min()
        .rename(columns={'timestamp': 'earliest_anomaly_timestamp'})
    )
    agg = agg.merge(earliest, on=['cmdb_id', 'log_name'], how='left')
    agg['earliest_anomaly_timestamp_utc'] = agg['earliest_anomaly_timestamp'].apply(lambda x: x.isoformat() if pd.notnull(x) else None)

    # severity ratio (handle p95==0)
    agg['severity_ratio'] = np.where(
        agg['p95_threshold'] == 0,
        np.where(agg['max_value'] > 0, float('inf'), 0.0),
        agg['max_value'] / agg['p95_threshold']
    )

    # rounding for compactness
    agg['max_value'] = agg['max_value'].round(6)
    agg['p95_threshold'] = agg['p95_threshold'].round(6)
    # keep severity_ratio as-is (inf preserved), but round non-inf values
    agg['severity_ratio'] = agg['severity_ratio'].replace(np.inf, float('inf'))
    agg.loc[np.isfinite(agg['severity_ratio']), 'severity_ratio'] = agg.loc[np.isfinite(agg['severity_ratio']), 'severity_ratio'].round(6)

    # final select and sort (show candidate groups only, sorted by anomaly_count desc then severity desc)
    candidate_agg_df = agg[[
        'cmdb_id','log_name','n_points_in_window','anomaly_count','earliest_anomaly_timestamp_utc',
        'max_value','p95_threshold','severity_ratio'
    ]].sort_values(['anomaly_count','severity_ratio'], ascending=[False, False]).reset_index(drop=True)

# 5) Samples: up to 10 sample rows from log_incident_df for checkoutservice and currencyservice
checkout_samples = log_incident_df[log_incident_df['cmdb_id'] == 'checkoutservice'].sort_values('timestamp').head(10)
currency_samples = log_incident_df[log_incident_df['cmdb_id'] == 'currencyservice'].sort_values('timestamp').head(10)

# Compact summary stats
total_candidate_groups = candidate_agg_df.shape[0]
candidate_groups_with_anomalies = int((candidate_agg_df['anomaly_count'] > 0).sum())

# Store intermediate tables in kernel: log_thresholds_df, log_incident_df, log_anomalies_df (already assigned)
# Return compact results: thresholds head, incident shape, candidate aggregates (top rows), counts, and samples
log_thresholds_df_head = log_thresholds_df.head(50)
log_incident_shape = log_incident_df.shape

log_thresholds_df_head, log_incident_shape, total_candidate_groups, candidate_groups_with_anomalies, candidate_agg_df, checkout_samples, currency_samples
