import pandas as pd
import numpy as np

# Reuse trace_df from kernel

# 1) Compute global P95 threshold for each trace_name across full trace_df
trace_thresholds_df = trace_df.groupby('trace_name', as_index=False)['value'].quantile(0.95).rename(columns={'value': 'p95'})

# 2) Filter trace_df to the incident window and store
start = pd.Timestamp('2024-01-15 21:21:06', tz='UTC')
end = pd.Timestamp('2024-01-15 21:51:06', tz='UTC')
trace_incident_df = trace_df[(trace_df['timestamp'] >= start) & (trace_df['timestamp'] <= end)].copy()

# 3) Join incident data with thresholds and mark anomaly points
trace_incident_with_p95 = trace_incident_df.merge(trace_thresholds_df, on='trace_name', how='left')
trace_incident_with_p95['p95'] = trace_incident_with_p95['p95'].fillna(0.0)
trace_incident_with_p95['is_anomaly'] = trace_incident_with_p95['value'] > trace_incident_with_p95['p95']

# 4) From the anomaly points keep only trace_name rows that mention candidate services
candidates = ['checkoutservice','currencyservice','emailservice','productcatalogservice','recommendationservice']
pattern = '|'.join(candidates)
# overall counts of distinct trace_name groups scanned (within incident window)
total_trace_name_groups_scanned = trace_incident_with_p95['trace_name'].nunique()

# Overall aggregation per trace_name (within incident window)
overall_group = trace_incident_with_p95.groupby('trace_name', as_index=False).agg(
    n_points_in_window=('value', 'size'),
    anomaly_count=('is_anomaly', 'sum'),
    max_value=('value', 'max'),
    p95_threshold=('p95', 'first')
)

# earliest anomaly timestamp per trace_name (overall)
earliest_overall_anom = (
    trace_incident_with_p95[trace_incident_with_p95['is_anomaly']]
    .groupby('trace_name', as_index=False)['timestamp']
    .min()
    .rename(columns={'timestamp': 'earliest_anomaly_timestamp'})
)
overall_group = overall_group.merge(earliest_overall_anom, on='trace_name', how='left')
overall_group['earliest_anomaly_timestamp_utc'] = overall_group['earliest_anomaly_timestamp'].apply(lambda x: x.isoformat() if pd.notnull(x) else None)

overall_anomaly_groups = int((overall_group['anomaly_count'] > 0).sum())

# Candidate-related anomalous rows (only anomaly points and trace_name contains candidate)
trace_anomalies = trace_incident_with_p95[trace_incident_with_p95['is_anomaly']].copy()
candidate_anomalies_df = trace_anomalies[trace_anomalies['trace_name'].str.contains(pattern, case=False, regex=True)].copy()

# Number of distinct trace_name groups among candidate anomalies
candidate_anomaly_groups = int(candidate_anomalies_df['trace_name'].nunique())

# 5) Aggregate candidate-related anomalous trace rows by trace_name
# But include n_points_in_window (count of all points in incident window for those trace_names)
# Get list of candidate trace_names present in incident window
candidate_trace_names_in_window = trace_incident_with_p95[trace_incident_with_p95['trace_name'].str.contains(pattern, case=False, regex=True)]['trace_name'].unique()

# n_points_in_window per candidate trace_name (from trace_incident_with_p95)
n_points_map = trace_incident_with_p95[trace_incident_with_p95['trace_name'].isin(candidate_trace_names_in_window)].groupby('trace_name')['value'].size()

# p95 per trace_name from trace_thresholds_df
p95_map = trace_thresholds_df.set_index('trace_name')['p95']

# Aggregate anomaly info per candidate trace_name from candidate_anomalies_df
if candidate_anomalies_df.empty:
    candidate_summary_df = pd.DataFrame(columns=[
        'trace_name','n_points_in_window','anomaly_count','earliest_anomaly_timestamp_utc',
        'max_value','p95_threshold','severity_ratio'
    ])
else:
    agg = candidate_anomalies_df.groupby('trace_name', as_index=False).agg(
        anomaly_count=('is_anomaly', 'sum'),
        earliest_anomaly_timestamp=('timestamp', 'min'),
        max_value=('value', 'max')
    )

    # add n_points_in_window and p95 and compute severity
    agg['n_points_in_window'] = agg['trace_name'].map(n_points_map).fillna(0).astype(int)
    agg['p95_threshold'] = agg['trace_name'].map(p95_map).fillna(0.0)
    def compute_sev(r):
        p = r['p95_threshold']
        if p == 0:
            return float('inf') if r['max_value'] > 0 else 0.0
        return r['max_value'] / p
    agg['severity_ratio'] = agg.apply(compute_sev, axis=1)
    agg['earliest_anomaly_timestamp_utc'] = agg['earliest_anomaly_timestamp'].apply(lambda x: x.isoformat() if pd.notnull(x) else None)

    candidate_summary_df = agg[[
        'trace_name','n_points_in_window','anomaly_count','earliest_anomaly_timestamp_utc',
        'max_value','p95_threshold','severity_ratio'
    ]].copy()

    # Round numeric columns for compactness
    candidate_summary_df['max_value'] = candidate_summary_df['max_value'].round(6)
    candidate_summary_df['p95_threshold'] = candidate_summary_df['p95_threshold'].round(6)
    # keep severity_ratio as float (inf preserved)
    candidate_summary_df['severity_ratio'] = candidate_summary_df['severity_ratio'].replace(np.inf, float('inf'))

    # Sort as requested and keep top 20
    candidate_summary_df = candidate_summary_df.sort_values(['anomaly_count','severity_ratio'], ascending=[False, False]).reset_index(drop=True)
    candidate_summary_df = candidate_summary_df.head(20)

# Store intermediates in kernel: trace_thresholds_df, trace_incident_df, trace_incident_with_p95, trace_anomalies, candidate_anomalies_df, candidate_summary_df
trace_thresholds_df_head = trace_thresholds_df.head(50)  # compact display
trace_incident_shape = trace_incident_df.shape

# Return compact results: thresholds head, incident shape, totals, and candidate summary (top 20)
trace_thresholds_df_head, trace_incident_shape, total_trace_name_groups_scanned, overall_anomaly_groups, candidate_anomaly_groups, candidate_summary_df
