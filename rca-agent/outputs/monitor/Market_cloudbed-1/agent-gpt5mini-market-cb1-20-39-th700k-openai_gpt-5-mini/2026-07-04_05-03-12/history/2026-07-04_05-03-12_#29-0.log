        # anomalous if is_high or is_low
        anom_mask = g_sorted['anom_flag'].astype(bool).values
        if not anom_mask.any():
            longest_runs.append({'cmdb_id':cmdb,'kpi_name':kpi,'longest_run_min':0})
            continue
        # compute time differences in seconds between consecutive rows
        dt_diff = g_sorted['dt'].diff().dt.total_seconds().fillna(60).values
