import pandas as pd
import numpy as np
import pytz

# Reuse existing df_metric and df_trace in kernel
tz = pytz.timezone('Asia/Shanghai')

# Ensure df_trace has dt column in UTC+8
if 'dt' not in df_trace.columns:
    df_trace['dt'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
else:
    if df_trace['dt'].dt.tz is None:
        df_trace['dt'] = df_trace['dt'].dt.tz_localize(pytz.UTC).dt.tz_convert(tz)
    else:
        df_trace['dt'] = df_trace['dt'].dt.tz_convert(tz)

# 1) find cmdb_ids that have kpi_name containing 'container.node-1'
node1_pattern = 'container.node-1'
node1_cmdbs = pd.Series(df_metric.loc[df_metric['kpi_name'].str.contains(node1_pattern, case=False, na=False), 'cmdb_id'].unique()).sort_values().head(50).tolist()

# Incident window boundaries (inclusive)
start = pd.Timestamp('2022-03-20 22:00:00', tz=tz)
end   = pd.Timestamp('2022-03-20 22:30:00', tz=tz)

# Trace metric of interest
trace_metric = 'trace.self.duration_mean'

# 1b) Compute global p95 for trace.self.duration_mean per cmdb_id using full trace series
thr_trace_p95 = df_trace[df_trace['trace_name'] == trace_metric].groupby('cmdb_id')['value'].quantile(0.95).reset_index(name='p95')

# Prepare list to collect per-cmdb results
rows = []

for cmdb in node1_cmdbs:
    # get global p95 for this cmdb_id
    row_thr = thr_trace_p95[thr_trace_p95['cmdb_id']==cmdb]
    if row_thr.empty:
        # no global p95 (no full-series trace.self.duration_mean for this cmdb)
        continue
    p95 = float(row_thr['p95'].iloc[0])
    # filter df_trace for cmdb_id and trace_metric within incident window
    tw = df_trace[
        (df_trace['cmdb_id']==cmdb) &
        (df_trace['trace_name']==trace_metric) &
        (df_trace['dt'] >= start) & (df_trace['dt'] <= end)
    ].copy()
    if tw.empty:
        # still include count_in_window=0 rows? requirement says for each cmdb_id found, check df_trace restricted to window.
        rows.append({
            'cmdb_id': cmdb,
            'count_in_window': 0,
            'count_high': 0,
            'earliest_anom_ts': pd.NaT,
            'p95': p95,
            'max_in_window': np.nan,
            'mean_in_window': np.nan,
            'severity': np.nan
        })
        continue

    count_in_window = int(tw.shape[0])
    # count_high: points >= p95
    count_high = int((tw['value'] >= p95).sum())
    # earliest anomaly timestamp among points >= p95
    if count_high > 0:
        earliest_anom = tw.loc[tw['value'] >= p95, 'dt'].min()
    else:
