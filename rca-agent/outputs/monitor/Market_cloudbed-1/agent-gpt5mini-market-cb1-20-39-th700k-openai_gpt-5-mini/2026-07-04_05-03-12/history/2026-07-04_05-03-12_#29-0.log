    max_in_window = float(tw['value'].max())
    mean_in_window = float(tw['value'].mean())
    # severity
    if count_high > 0:
        if p95 == 0:
            severity = np.inf if max_in_window > 0 else np.nan
        else:
            severity = max_in_window / p95
    else:
        severity = np.nan

    rows.append({
        'cmdb_id': cmdb,
        'count_in_window': count_in_window,
        'count_high': count_high,
        'earliest_anom_ts': earliest_anom,
        'p95': p95,
        'max_in_window': max_in_window,
        'mean_in_window': mean_in_window,
