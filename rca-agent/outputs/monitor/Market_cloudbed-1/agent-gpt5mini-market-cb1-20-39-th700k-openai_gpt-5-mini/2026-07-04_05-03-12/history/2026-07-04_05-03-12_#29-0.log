    earliest_per_pair = anom_rows.groupby(['cmdb_id','kpi_name'])['dt'].min().reset_index(name='earliest_anom_ts')
else:
    earliest_per_pair = pd.DataFrame(columns=['cmdb_id','kpi_name','earliest_anom_ts'])
agg = agg.merge(earliest_per_pair, on=['cmdb_id','kpi_name'], how='left')

# compute severity metrics
def sev_high(row):
    if row['count_high'] <= 0:
        return np.nan
    p95 = row['p95']
    mx  = row['max_in_window']
    if pd.isna(p95) or p95 == 0:
