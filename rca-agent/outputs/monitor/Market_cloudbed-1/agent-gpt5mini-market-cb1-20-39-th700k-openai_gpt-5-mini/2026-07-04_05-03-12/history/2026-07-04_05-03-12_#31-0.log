import pandas as pd
import numpy as np
import pytz

# Reuse existing metric and tz if available
try:
    metric
except NameError:
    metric = pd.read_csv("metric.csv")
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Ensure numeric value column
metric['value'] = pd.to_numeric(metric['value'], errors='coerce')

# Ensure datetime column in Asia/Shanghai (UTC+8)
if 'dt' not in metric.columns:
    metric['dt'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Filter rows where kpi_name contains 'container.node-6' (exact substring)
mask_cn6 = metric['kpi_name'].astype(str).str.contains('container.node-6', na=False)
metric_cn6_all = metric[mask_cn6].copy()

# List of distinct cmdb_id that had any 'container.node-6' KPI (limit to 200)
cn6_cmdb_list_full = sorted(metric_cn6_all['cmdb_id'].dropna().unique().tolist())
cn6_cmdb_list = cn6_cmdb_list_full[:200]

# 1) Compute global P95 per (cmdb_id, kpi_name) using full series (do NOT filter by time)
p95_df = (
    metric_cn6_all
    .dropna(subset=['value'])
    .groupby(['cmdb_id','kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value':'p95'})
)

# 2) Filter to incident window inclusive
start_ts = pd.Timestamp("2022-03-20 14:00:00", tz=tz)
end_ts = pd.Timestamp("2022-03-20 14:30:00", tz=tz)
metric_cn6_win = metric_cn6_all[(metric_cn6_all['dt'] >= start_ts) & (metric_cn6_all['dt'] <= end_ts)].copy()

# 2/3) Merge p95 into window rows for comparison
win_with_p95 = metric_cn6_win.merge(p95_df, on=['cmdb_id','kpi_name'], how='left')

# Determine anomaly per row: if p95==0 -> anomalous when value>0; else value>=p95
win_with_p95['is_anom'] = np.where(
    win_with_p95['p95'].fillna(0) == 0,
    win_with_p95['value'] > 0,
    win_with_p95['value'] >= win_with_p95['p95']
)

# 2) Count how many timestamps in window per group have is_anom True
group_anom_counts = (
    win_with_p95[win_with_p95['is_anom']]
    .groupby(['cmdb_id','kpi_name'], as_index=False)
    .agg(anom_count=('is_anom','sum'), earliest_anom_ts=('dt','min'))
)

# Also compute max_value_in_window per group (needed for severity)
group_max_in_window = (
    metric_cn6_win.dropna(subset=['value'])
    .groupby(['cmdb_id','kpi_name'], as_index=False)['value']
    .max()
    .rename(columns={'value':'max_in_window'})
)

# Combine p95, anom counts, and max_in_window
group_stats = p95_df.merge(group_max_in_window, on=['cmdb_id','kpi_name'], how='left').merge(
    group_anom_counts, on=['cmdb_id','kpi_name'], how='left'
)

group_stats['anom_count'] = group_stats['anom_count'].fillna(0).astype(int)
# earliest_anom_ts may be NaT for groups without anomalies
group_stats['earliest_anom_ts_str'] = pd.to_datetime(group_stats['earliest_anom_ts']).dt.tz_localize(None)
# Compute severity per group where applicable:
def compute_sev(row):
    p95 = row['p95']
    maxv = row['max_in_window']
    if pd.isna(maxv):
        return np.nan
    if p95 == 0 or pd.isna(p95):
        return (maxv - (p95 if not pd.isna(p95) else 0))
    else:
        return (maxv - p95) / p95

group_stats['severity'] = group_stats.apply(compute_sev, axis=1)

# 3) For each cmdb_id produce aggregated metrics:
# anomalous_kpi_count = number of distinct kpi_names where anom_count>0
anom_kpi_counts = (
    group_stats[group_stats['anom_count'] > 0]
    .groupby('cmdb_id', as_index=False)
    .agg(anomalous_kpi_count=('kpi_name','nunique'),
         earliest_anom_ts=('earliest_anom_ts','min'),
         max_severity=('severity','max'))
)

# For cmdb_ids that have zero anomalous_kpi_count, ensure they appear with zeros if desired.
# But requirement is to identify cmdb_ids among those rows; we report those with anomalies primarily.
# Prepare final cmdb-level table, including cmdbs that had container.node-6 KPI but no anomalies (count=0)
all_cmdb_df = pd.DataFrame({'cmdb_id': cn6_cmdb_list})
anom_kpi_counts_full = all_cmdb_df.merge(anom_kpi_counts, on='cmdb_id', how='left')
anom_kpi_counts_full['anomalous_kpi_count'] = anom_kpi_counts_full['anomalous_kpi_count'].fillna(0).astype(int)
anom_kpi_counts_full['earliest_anom_ts'] = pd.to_datetime(anom_kpi_counts_full['earliest_anom_ts']).dt.tz_localize(tz).dt.strftime("%Y-%m-%d %H:%M:%S %Z")
anom_kpi_counts_full['earliest_anom_ts'] = anom_kpi_counts_full['earliest_anom_ts'].replace({pd.NaT: None})
anom_kpi_counts_full['max_severity'] = anom_kpi_counts_full['max_severity'].astype(float)

# 4) Return compact table: top 20 cmdb_id sorted by anomalous_kpi_count desc with requested columns
result = anom_kpi_counts_full.sort_values(by=['anomalous_kpi_count','max_severity'], ascending=[False, False]) \
    .reset_index(drop=True)[['cmdb_id','anomalous_kpi_count','earliest_anom_ts','max_severity']].head(20)

# Also return full list (up to 200) of distinct cmdb_id that had any 'container.node-6' KPI
cn6_cmdb_list_limited = cn6_cmdb_list  # already limited to 200

# Display compact outputs (as variables for IPython)
result, cn6_cmdb_list_limited
