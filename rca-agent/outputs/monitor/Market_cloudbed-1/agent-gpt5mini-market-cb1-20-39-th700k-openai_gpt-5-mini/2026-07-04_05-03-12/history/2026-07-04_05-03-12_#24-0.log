import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')  # UTC+8 as required

# Load CSV files
metric_df = pd.read_csv('metric.csv')
trace_df = pd.read_csv('trace.csv')
log_df = pd.read_csv('log.csv')
error_df = pd.read_csv('error_logs.csv')

def compact_summary(df, name_col=None, value_name=None):
    # Basic stats
    row_count = len(df)
    if 'timestamp' in df.columns and row_count > 0:
        min_ts = int(df['timestamp'].min())
        max_ts = int(df['timestamp'].max())
    else:
        min_ts = None
        max_ts = None
    stats = pd.DataFrame([{
        'file': value_name,
        'row_count': row_count,
        'min_timestamp': min_ts,
        'max_timestamp': max_ts
    }])
    # top cmdb_id
    if 'cmdb_id' in df.columns:
        top_cmdb = df['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count').head(20)
    else:
        top_cmdb = pd.DataFrame(columns=['cmdb_id','count'])
    # top name column if provided
    if name_col and name_col in df.columns:
        top_names = df[name_col].value_counts().rename_axis(name_col).reset_index(name='count').head(20)
    else:
        top_names = pd.DataFrame(columns=[name_col or 'name','count'])
    return stats, top_cmdb, top_names

metric_stats, metric_top_cmdb, metric_top_kpi = compact_summary(metric_df, name_col='kpi_name', value_name='metric.csv')
trace_stats, trace_top_cmdb, trace_top_name = compact_summary(trace_df, name_col='trace_name', value_name='trace.csv')
log_stats, log_top_cmdb, log_top_name = compact_summary(log_df, name_col='log_name', value_name='log.csv')
error_stats, error_top_cmdb, error_top_none = compact_summary(error_df, name_col=None, value_name='error_logs.csv')

# Keep final output compact: show per-file stats and top lists (each limited to 20 rows)
metric_stats, metric_top_cmdb, metric_top_kpi, trace_stats, trace_top_cmdb, trace_top_name, log_stats, log_top_cmdb, log_top_name, error_stats, error_top_cmdb
