import pandas as pd
import numpy as np
import pytz
import re
from datetime import datetime

# Reuse previously loaded DataFrames if available, otherwise load
try:
    error_df
except NameError:
    error_df = pd.read_csv('error_logs.csv')
try:
    log_df
except NameError:
    log_df = pd.read_csv('log.csv')
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')

# Timezone and incident window (UTC+8)
tz = pytz.timezone('Asia/Shanghai')
start_ts = int(tz.localize(datetime(2022,3,20,22,30,0)).timestamp())
end_ts   = int(tz.localize(datetime(2022,3,20,23,0,0)).timestamp())

# 1) error_logs.csv: all rows in the incident window (timestamp, cmdb_id, message)
err_in_window = error_df[error_df['timestamp'].between(start_ts, end_ts)][['timestamp','cmdb_id','message']].reset_index(drop=True)

# 2) log.csv: filter to incident window, focus on log.error_count or log.row_count,
#    group by cmdb_id and log_name and compute sum_value, max_value, earliest_timestamp_where_value_gt_0
log_window = log_df[log_df['timestamp'].between(start_ts, end_ts)].copy()
# Keep only the two log names of interest (case-sensitive per schema)
log_names_of_interest = ['log.error_count', 'log.row_count']
log_filtered = log_window[log_window['log_name'].isin(log_names_of_interest)].copy()

if log_filtered.shape[0] > 0:
    def agg_logs(g):
        sum_value = float(g['value'].sum())
        max_value = float(g['value'].max())
        mask = g['value'] > 0
        earliest_gt0 = int(g.loc[mask, 'timestamp'].min()) if mask.any() else np.nan
        return pd.Series({
            'sum_value': sum_value,
            'max_value': max_value,
            'earliest_timestamp_where_value_gt_0': earliest_gt0
        })
    log_agg = (log_filtered.groupby(['cmdb_id','log_name'], sort=False)
                        .apply(agg_logs)
                        .reset_index()
                        .sort_values(by='sum_value', ascending=False)
                        .head(20)
                        .reset_index(drop=True))
else:
    log_agg = pd.DataFrame(columns=['cmdb_id','log_name','sum_value','max_value','earliest_timestamp_where_value_gt_0'])

# 3) metric.csv: select KPIs containing error/transmit/receive error patterns (node-5 and node-6 included)
#    Patterns: 'receive_errors', 'transmit_errors', 'network_receive_errors', 'network_transmit_errors'
err_patterns = ['receive_errors', 'transmit_errors', 'network_receive_errors', 'network_transmit_errors']
err_pattern = '|'.join(re.escape(p) for p in err_patterns)

metric_kpi_series = metric_df['kpi_name'].astype(str)
mask_err_kpis = metric_kpi_series.str.contains(err_pattern, case=False, na=False, regex=True)

metric_err_rows = metric_df[mask_err_kpis & metric_df['timestamp'].between(start_ts, end_ts)].copy()

if metric_err_rows.shape[0] > 0:
    # For each (cmdb_id, kpi_name) compute max_value_in_window, count_nonzero_points, earliest timestamp where value>0
    def agg_metric_err(g):
        max_val = float(g['value'].max())
        nonzero_mask = g['value'] > 0
        count_nonzero = int(nonzero_mask.sum())
        earliest_nonzero = int(g.loc[nonzero_mask, 'timestamp'].min()) if count_nonzero > 0 else np.nan
        return pd.Series({
            'max_value_in_window': max_val,
            'count_nonzero_points': count_nonzero,
            'earliest_nonzero_timestamp': earliest_nonzero
        })
    metric_err_agg = (metric_err_rows.groupby(['cmdb_id','kpi_name'], sort=False)
                                 .apply(agg_metric_err)
                                 .reset_index())
    metric_err_agg = metric_err_agg.sort_values(by='max_value_in_window', ascending=False).head(20).reset_index(drop=True)
else:
    metric_err_agg = pd.DataFrame(columns=['cmdb_id','kpi_name','max_value_in_window','count_nonzero_points','earliest_nonzero_timestamp'])

# Return the three compact tables (variable names are used so IPython will display them)
err_in_window, log_agg, metric_err_agg
