import pandas as pd
import numpy as np
import pytz
import re
from datetime import datetime

# Reuse metric_df if available
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')

# Ensure timezone (UTC+8) and incident window
tz = pytz.timezone('Asia/Shanghai')
start_ts = int(tz.localize(datetime(2022,3,20,22,30,0)).timestamp())
end_ts   = int(tz.localize(datetime(2022,3,20,23,0,0)).timestamp())

# Include/exclude patterns for dynamic KPIs (as requested)
includes = [
    'container_network', 'transmit_MB', 'receive_MB', 'transmit_packets', 'receive_packets',
    'transmit_errors', 'receive_errors', 'container_memory', 'container_cpu', 'cpu_usage',
    'container_cpu_cfs', 'fs_reads', 'fs_writes', 'reads_MB', 'writes_MB', 'read_seconds',
    'write_seconds'
]
excludes = [
    'start_time', 'LastGcInfo', 'CollectionCount', 'TotalCompilation', 'CommittedVirtualMemory',
    'system.disk.total', 'limit', 'capacity', 'total', 'max_usage', 'count', 'uptime'
]

inc_pattern = '|'.join(re.escape(s) for s in includes)
exc_pattern = '|'.join(re.escape(s) for s in excludes)

# 1) Select matching KPI rows (includes present AND excludes absent)
kpi_series = metric_df['kpi_name'].astype(str)
mask_inc = kpi_series.str.contains(inc_pattern, case=False, na=False, regex=True)
mask_exc = kpi_series.str.contains(exc_pattern, case=False, na=False, regex=True)
matching_rows = metric_df[mask_inc & (~mask_exc)].copy()

# 2) Compute global P95 per (cmdb_id, kpi_name) using the full series (before window filtering)
global_p95 = (matching_rows
              .groupby(['cmdb_id','kpi_name'], as_index=False)['value']
              .quantile(0.95)
              .rename(columns={'value':'global_p95'}))

# 3) Discard pairs with global_p95 == 0
p95_positive = global_p95[global_p95['global_p95'] > 0].copy()

# If no pairs remain after excluding zero-P95, prepare fallback
if p95_positive.shape[0] == 0:
    # Compute window max per pair (for all matching rows) and return top 20 by max_value_in_window desc
    window_all = matching_rows[matching_rows['timestamp'].between(start_ts, end_ts)].copy()
    if window_all.shape[0] == 0:
        result = pd.DataFrame([{
            'message': 'No matching dynamic KPI pairs with non-zero global P95 found, and no window data available.'
        }])
    else:
        fallback = (window_all.groupby(['cmdb_id','kpi_name'], as_index=False)['value']
                    .max()
                    .rename(columns={'value':'max_value_in_window'}))
        fallback = fallback.sort_values('max_value_in_window', ascending=False).head(20)
        result = fallback[['cmdb_id','kpi_name','max_value_in_window']]
else:
    # 4) Filter window rows and keep only pairs with positive P95 (merge)
    window = matching_rows[matching_rows['timestamp'].between(start_ts, end_ts)].copy()
    # Merge only the positive-p95 pairs to ensure we consider only those pairs
    window_pos = window.merge(p95_positive, on=['cmdb_id','kpi_name'], how='inner')

    # 5) For each pair compute required aggregates
    if window_pos.shape[0] == 0:
        # No window data for positive-p95 pairs
        result = pd.DataFrame([{
            'message': 'No window points found for KPI pairs with positive global P95.'
        }])
    else:
        agg_max = (window_pos.groupby(['cmdb_id','kpi_name'], as_index=False)
                   .agg(max_value_in_window=('value','max')))
        # Merge global_p95
        agg = agg_max.merge(p95_positive, on=['cmdb_id','kpi_name'], how='left')
        # Compute ratio
        agg['ratio'] = agg['max_value_in_window'] / agg['global_p95']
        # Compute anomaly_count and earliest_anomaly_timestamp
        def compute_counts(group):
            gp = group['global_p95'].iloc[0]
            mask = group['value'] >= gp
            anomaly_count = int(mask.sum())
            earliest = int(group.loc[mask, 'timestamp'].min()) if anomaly_count>0 else np.nan
            return pd.Series({'anomaly_count': anomaly_count, 'earliest_anomaly_timestamp': earliest})
        counts = (window_pos.groupby(['cmdb_id','kpi_name'], sort=False).apply(compute_counts).reset_index())
        # Combine
        agg = agg.merge(counts, on=['cmdb_id','kpi_name'], how='left')
        # Keep only pairs that have at least one window point (max_value_in_window not null)
        agg = agg[~agg['max_value_in_window'].isna()].copy()
        # Sort by ratio desc and take top 20
        agg_sorted = agg.sort_values(by='ratio', ascending=False).head(20)
        # Select requested columns and order
        result = agg_sorted[['cmdb_id','kpi_name','ratio','anomaly_count','earliest_anomaly_timestamp','max_value_in_window','global_p95']].reset_index(drop=True)

# Display compact result
result
