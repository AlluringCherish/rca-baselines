import pandas as pd
import pytz
from datetime import datetime
import re

# Reuse metric_df if already loaded; otherwise load it
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')

tz = pytz.timezone('Asia/Shanghai')  # UTC+8

# Keywords/substrings to match (case-insensitive)
keywords = [
    'cpu', 'memory', 'mem', 'container_cpu', 'container_memory', 'network', 'transmit',
    'receive', 'packet', 'error', 'retransmit', 'retransmission', 'fs', 'read',
    'write', 'io', 'disk', 'blk'
]
pattern = '|'.join([re.escape(k) for k in keywords])

# 1) Find matching rows where kpi_name contains any of the substrings (case-insensitive)
mask_kpi = metric_df['kpi_name'].str.contains(pattern, case=False, na=False, regex=True)
matching = metric_df.loc[mask_kpi].copy()

# Distinct (cmdb_id, kpi_name) pairs count
distinct_pairs_count = matching[['cmdb_id', 'kpi_name']].drop_duplicates().shape[0]

# Additional counts for context
total_matching_rows = matching.shape[0]
unique_kpi_names_count = matching['kpi_name'].nunique()
unique_cmdb_count = matching['cmdb_id'].nunique()

# 2) Count how many matching metric rows fall inside the incident window 2022-03-20 22:30:00–23:00:00 UTC+8
start_dt = tz.localize(datetime(2022, 3, 20, 22, 30, 0))
end_dt   = tz.localize(datetime(2022, 3, 20, 23, 0, 0))
start_ts = int(start_dt.timestamp())
end_ts   = int(end_dt.timestamp())

matching_window = matching[matching['timestamp'].between(start_ts, end_ts)].copy()
window_rows_count = matching_window.shape[0]
window_distinct_pairs_count = matching_window[['cmdb_id','kpi_name']].drop_duplicates().shape[0]

# 3) Compact lists:
# Top 20 matching kpi_name values with their global total counts (most frequent first)
top_kpis = matching['kpi_name'].value_counts().rename_axis('kpi_name').reset_index(name='global_count').head(20)

# Up to 20 distinct cmdb_id examples for these matching KPIs (with counts)
top_cmdbs = matching['cmdb_id'].value_counts().rename_axis('cmdb_id').reset_index(name='count').head(20)

# min and max timestamps observed among matching rows (if any)
if total_matching_rows > 0:
    min_timestamp_matching = int(matching['timestamp'].min())
    max_timestamp_matching = int(matching['timestamp'].max())
else:
    min_timestamp_matching = None
    max_timestamp_matching = None

# Compact summary DataFrame
summary = pd.DataFrame([{
    'distinct_pairs_matching': distinct_pairs_count,
    'total_matching_rows': total_matching_rows,
    'unique_kpi_names': unique_kpi_names_count,
    'unique_cmdb_ids': unique_cmdb_count,
    'window_rows_count': window_rows_count,
    'window_distinct_pairs_count': window_distinct_pairs_count,
    'min_timestamp_matching': min_timestamp_matching,
    'max_timestamp_matching': max_timestamp_matching
}])

# Display compact results: summary, top_kpis, top_cmdbs
summary, top_kpis, top_cmdbs
