import pandas as pd
import numpy as np
import pytz
import re
from datetime import datetime

# Reuse metric_df if available, else load
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')

tz = pytz.timezone('Asia/Shanghai')  # UTC+8

# Define incident window (inclusive)
start_dt = tz.localize(datetime(2022, 3, 20, 22, 30, 0))
end_dt   = tz.localize(datetime(2022, 3, 20, 23,  0, 0))
start_ts = int(start_dt.timestamp())
end_ts   = int(end_dt.timestamp())

# Keywords (case-insensitive) to match within kpi_name
keywords = [
    'cpu', 'memory', 'container_cpu', 'container_memory', 'network', 'transmit',
    'receive', 'packet', 'error', 'retransmit', 'retransmission', 'fs_read',
    'fs_write', 'read_seconds', 'write_seconds', 'io', 'disk.read', 'disk.write'
]
pattern = '|'.join([re.escape(k) for k in keywords])

# Select distinct (cmdb_id, kpi_name) pairs whose kpi_name matches any keyword (case-insensitive)
mask_kpi = metric_df['kpi_name'].str.contains(pattern, case=False, na=False, regex=True)
selected_df = metric_df.loc[mask_kpi, ['cmdb_id', 'kpi_name']].drop_duplicates()

# If none selected, return empty DataFrame
if selected_df.shape[0] == 0:
    result_df = pd.DataFrame(columns=['cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp','max_value_in_window','global_p95'])
    result_df
else:
    # Compute global P95 for all (cmdb_id, kpi_name) pairs but only keep selected pairs
    global_p95 = metric_df.groupby(['cmdb_id', 'kpi_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value':'global_p95'})

    # Keep only selected pairs in global_p95
    sel_keys = selected_df.merge(global_p95, on=['cmdb_id','kpi_name'], how='left')[['cmdb_id','kpi_name','global_p95']]

    # Filter the metric data to incident window
    window_df = metric_df[metric_df['timestamp'].between(start_ts, end_ts)].copy()

    # Keep only selected pairs in the window
    window_sel = window_df.merge(sel_keys, on=['cmdb_id','kpi_name'], how='inner')

    # If window_sel is empty still we may want to show top ratios from selected pairs with no window points.
    # Aggregate per pair in window_sel
    if window_sel.shape[0] > 0:
        def agg_group(g):
            gp95 = g['global_p95'].iloc[0]
            mask = g['value'] >= gp95
            anomaly_count = int(mask.sum())
            earliest = int(g.loc[mask, 'timestamp'].min()) if anomaly_count > 0 else np.nan
            max_val = float(g['value'].max())
            return pd.Series({
                'anomaly_count': anomaly_count,
                'earliest_anomaly_timestamp': earliest,
                'max_value_in_window': max_val,
                'global_p95': float(gp95)
            })

        agg = window_sel.groupby(['cmdb_id','kpi_name'], as_index=False).apply(agg_group).reset_index(drop=True)
    else:
        # No points in window for selected pairs -> create a DataFrame with selected pairs and NaNs for window stats
        agg = sel_keys.copy()
        agg['anomaly_count'] = 0
        agg['earliest_anomaly_timestamp'] = np.nan
        agg['max_value_in_window'] = np.nan
        # ensure global_p95 is float
        agg['global_p95'] = agg['global_p95'].astype(float)
        agg = agg[['cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp','max_value_in_window','global_p95']]

    # Determine if any anomalies found
    total_anomalies = int(agg['anomaly_count'].sum())

    if total_anomalies > 0:
        top20 = agg.sort_values(by=['anomaly_count','max_value_in_window'], ascending=[False, False]).head(20)
    else:
        # Need ratio = max_value_in_window / global_p95; handle zeros and NaNs
        def compute_ratio(row):
            gp = row['global_p95']
            mv = row['max_value_in_window']
            # If no window datapoint (mv is NaN), treat ratio as 0 to deprioritize
            if pd.isna(mv):
                return 0.0
            if gp == 0:
                if mv > 0:
                    return np.inf
                else:
                    return 0.0
            return mv / gp
        agg['relative_breach'] = agg.apply(compute_ratio, axis=1)
        top20 = agg.sort_values(by='relative_breach', ascending=False).head(20)

    # Keep only requested columns and keep compact
    cols = ['cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp','max_value_in_window','global_p95']
    top20_display = top20[cols].reset_index(drop=True)
    top20_display
