import pandas as pd
import numpy as np
import pytz
from datetime import datetime

# Reuse metric_df if available
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')

tz = pytz.timezone('Asia/Shanghai')
start_ts = int(tz.localize(datetime(2022,3,20,22,30,0)).timestamp())
end_ts   = int(tz.localize(datetime(2022,3,20,23,0,0)).timestamp())

nodes = [f'node-{i}' for i in range(1,7)]
kpi_suffixes = ['container_cpu_usage_seconds', 'container_memory_rss', 'container_network_receive_MB', 'container_network_transmit_MB']

rows = []
# For each node and suffix, aggregate per-minute by summing matching metric rows
for node in nodes:
    node_prefix = f'container.{node}.'
    for suffix in kpi_suffixes:
        pattern = node_prefix + suffix  # case-sensitive literal substring match as requested
        # select rows whose kpi_name contains the exact pattern (case-sensitive)
        mask = metric_df['kpi_name'].astype(str).str.contains(pattern, regex=False)
        subset = metric_df.loc[mask, ['timestamp','value']].copy()
        if subset.shape[0] == 0:
            # no data for this node-suffix
            rows.append({
                'node': node,
                'kpi_suffix': suffix,
                'anomaly_count': 0,
                'earliest_anomaly_timestamp': np.nan,
                'max_value_in_window': np.nan,
                'global_p95': np.nan
            })
            continue
        # aggregate per timestamp (sum)
        agg_all = subset.groupby('timestamp', sort=True)['value'].sum().reset_index(name='value')
        # compute global P95 from the full aggregated series (rule: compute BEFORE window filtering)
        global_p95 = float(agg_all['value'].quantile(0.95))
        # restrict to incident window
        agg_window = agg_all[agg_all['timestamp'].between(start_ts, end_ts)].copy()
        if agg_window.shape[0] == 0:
            anomaly_count = 0
            earliest = np.nan
            max_in_win = np.nan
        else:
            mask_breach = agg_window['value'] >= global_p95
            anomaly_count = int(mask_breach.sum())
            earliest = int(agg_window.loc[mask_breach, 'timestamp'].min()) if anomaly_count>0 else np.nan
            max_in_win = float(agg_window['value'].max())
        rows.append({
            'node': node,
            'kpi_suffix': suffix,
            'anomaly_count': int(anomaly_count),
            'earliest_anomaly_timestamp': earliest,
            'max_value_in_window': max_in_win,
            'global_p95': global_p95
        })

result_df = pd.DataFrame(rows)
# sort by anomaly_count desc then max_value_in_window desc
result_df.sort_values(by=['anomaly_count','max_value_in_window'], ascending=[False, False], inplace=True)
# keep compact output (up to 24 rows)
result_df.reset_index(drop=True, inplace=True)
result_df
