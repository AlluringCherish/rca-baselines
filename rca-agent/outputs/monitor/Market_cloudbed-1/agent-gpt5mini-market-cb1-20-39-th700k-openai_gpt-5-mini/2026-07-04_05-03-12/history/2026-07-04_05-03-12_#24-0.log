import pandas as pd
import numpy as np
import pytz
from datetime import datetime

# Reuse metric_df if already loaded; otherwise load it
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')

tz = pytz.timezone('Asia/Shanghai')  # UTC+8

# 1) Compute global P95 per (cmdb_id, kpi_name) using entire series (before any filtering)
global_p95 = metric_df.groupby(['cmdb_id', 'kpi_name'])['value'].quantile(0.95).reset_index(name='global_p95')

# 2) Define incident window in UTC+8 and convert to epoch seconds
start_dt = tz.localize(datetime(2022, 3, 20, 22, 30, 0))
end_dt   = tz.localize(datetime(2022, 3, 20, 23,  0, 0))
start_ts = int(start_dt.timestamp())
end_ts   = int(end_dt.timestamp())

# 3) Filter metric_df to the incident window (inclusive)
window_df = metric_df[metric_df['timestamp'].between(start_ts, end_ts)].copy()

# Merge global_p95 into windowed data so we can compare each point to its global threshold
window_merged = window_df.merge(global_p95, on=['cmdb_id', 'kpi_name'], how='left')

# 4) For each (cmdb_id, kpi_name) in the window compute required aggregates:
#    - anomaly_count: number of points with value >= global_p95
#    - earliest_anomaly_timestamp: earliest timestamp in window where value >= global_p95
#    - max_value_in_window: max(value) in the window
#    - global_p95 (from precomputed)
def agg_group(g):
    gp95 = g['global_p95'].iloc[0]
    mask = g['value'] >= gp95
    anomaly_count = int(mask.sum())
    if anomaly_count > 0:
        earliest = int(g.loc[mask, 'timestamp'].min())
    else:
        earliest = np.nan
    max_val = float(g['value'].max())
    return pd.Series({
        'anomaly_count': anomaly_count,
        'earliest_anomaly_timestamp': earliest,
        'max_value_in_window': max_val,
        'global_p95': float(gp95)
    })

agg = window_merged.groupby(['cmdb_id', 'kpi_name']).apply(agg_group).reset_index()

# 5) Select top 20 by anomaly_count (desc). If no anomalies at all (all zeros), return top 20 by relative breach.
total_anomalies = int(agg['anomaly_count'].sum())

if total_anomalies > 0:
    top20 = agg.sort_values(by=['anomaly_count', 'max_value_in_window'], ascending=[False, False]).head(20)
else:
    # compute relative breach = max_value_in_window / global_p95
    # handle zero or negative global_p95 by assigning inf when global_p95 == 0 and max_value>0
    eps = 1e-12
    def compute_ratio(row):
        gp = row['global_p95']
        mv = row['max_value_in_window']
        if gp == 0:
            if mv > 0:
                return np.inf
            else:
                return 0.0
        else:
            return mv / gp
    agg['relative_breach'] = agg.apply(compute_ratio, axis=1)
    top20 = agg.sort_values(by='relative_breach', ascending=False).head(20)

# Keep output compact: selected columns and ensure ordering
cols = ['cmdb_id', 'kpi_name', 'anomaly_count', 'earliest_anomaly_timestamp', 'max_value_in_window', 'global_p95']
# If relative_breach was added, ensure it's not shown unless no anomalies (but requirement says only aggregated rows)
top20_display = top20[cols].copy()

top20_display
