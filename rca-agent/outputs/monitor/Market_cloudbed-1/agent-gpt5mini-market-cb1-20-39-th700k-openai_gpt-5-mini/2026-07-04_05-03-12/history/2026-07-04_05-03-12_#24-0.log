import pandas as pd

# Reuse metric_df if available, else load
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')

# Case-sensitive literal substring match for both 'node-6' and 'network'
mask_node6_network = metric_df['kpi_name'].astype(str).str.contains('node-6', regex=False) & \
                     metric_df['kpi_name'].astype(str).str.contains('network', regex=False)

filtered = metric_df.loc[mask_node6_network].copy()

if filtered.shape[0] == 0:
    result = pd.DataFrame(columns=['kpi_name','total_count','example_cmdb_ids'])
else:
    # Total counts per kpi_name
    total_counts = (filtered['kpi_name']
                    .value_counts()
                    .rename_axis('kpi_name')
                    .reset_index(name='total_count'))
    top_kpis = total_counts.head(50).copy()

    # Per-kpi per-cmdb counts and top 5 examples as "cmdb_id:count"
    per_kpi_cmdb = (filtered.groupby(['kpi_name','cmdb_id'], sort=False)
                             .size()
                             .rename('cmdb_count')
                             .reset_index())
    def top5_examples(g):
        top5 = g.sort_values('cmdb_count', ascending=False).head(5)
        return ', '.join([f"{r.cmdb_id}:{int(r.cmdb_count)}" for r in top5.itertuples(index=False)])
    examples = (per_kpi_cmdb.groupby('kpi_name', sort=False)
                              .apply(top5_examples)
                              .rename('example_cmdb_ids')
                              .reset_index())

    # Combine and keep compact
    result = top_kpis.merge(examples, on='kpi_name', how='left')
    result = result[['kpi_name','total_count','example_cmdb_ids']]

result
