import pandas as pd
import re
import pytz
from datetime import datetime

# Reuse metric_df if already loaded; otherwise load it
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')

tz = pytz.timezone('Asia/Shanghai')
# Incident window (inclusive) in UTC+8
start_ts = int(tz.localize(datetime(2022,3,20,22,30,0)).timestamp())
end_ts   = int(tz.localize(datetime(2022,3,20,23,0,0)).timestamp())

# Include and exclude substrings (case-insensitive)
includes = [
    'usage', 'util', 'rss', 'percent', '%', 'cpu', 'memory', 'mem', 'container_cpu',
    'container_memory', 'network', 'transmit', 'receive', 'MB', 'bytes', 'packet',
    'error', 'errors', 'retransmit', 'retransmission', 'fs_reads', 'fs_writes',
    'reads', 'writes', 'read_seconds', 'write_seconds', 'io', 'throughput'
]
excludes = [
    'start_time', 'StartTime', 'LastGcInfo', 'CollectionCount', 'TotalCompilation',
    'CommittedVirtualMemory', 'system.disk.total', 'container_start_time', 'limit',
    'capacity', 'total', 'max_usage', 'max', 'count', 'uptime'
]

# Build regex patterns (case-insensitive). Escape includes to handle special chars like '%'
inc_pattern = '|'.join(re.escape(s) for s in includes)
exc_pattern = '|'.join(re.escape(s) for s in excludes)

# Identify kpi_name values that match includes and do NOT match excludes
kpi_series = metric_df['kpi_name'].astype(str)
mask_inc = kpi_series.str.contains(inc_pattern, case=False, na=False, regex=True)
mask_exc = kpi_series.str.contains(exc_pattern, case=False, na=False, regex=True)
matching_kpis = kpi_series[mask_inc & (~mask_exc)].unique()

# If none, return empty DataFrame with columns
if len(matching_kpis) == 0:
    result_df = pd.DataFrame(columns=['kpi_name','total_count','window_count','example_cmdb_ids'])
else:
    # Restrict to matching rows
    matching_rows = metric_df[metric_df['kpi_name'].isin(matching_kpis)].copy()
    # Total counts per kpi_name across full file
    total_counts = matching_rows.groupby('kpi_name', sort=False).size().rename('total_count').reset_index()
    # Window counts per kpi_name
    window_rows = matching_rows[matching_rows['timestamp'].between(start_ts, end_ts)].copy()
    window_counts = window_rows.groupby('kpi_name', sort=False).size().rename('window_count').reset_index()
    # Merge counts, fill missing window_count with 0
    counts = total_counts.merge(window_counts, on='kpi_name', how='left').fillna({'window_count':0})
    counts['window_count'] = counts['window_count'].astype(int)
    # For each kpi_name get up to 5 example cmdb_id values with their counts (most frequent first) across full file
    top_cmdbs = (matching_rows.groupby(['kpi_name','cmdb_id'], sort=False)
                            .size()
                            .rename('cmdb_count')
                            .reset_index()
                            .sort_values(['kpi_name','cmdb_count'], ascending=[True, False]))
    # Aggregate top 5 per kpi_name into a compact string
    def top5_cmdb_str(g):
        top5 = g.head(5)
        return ', '.join([f"{row.cmdb_id}:{int(row.cmdb_count)}" for row in top5.itertuples(index=False)])
    examples = top_cmdbs.groupby('kpi_name', sort=False).apply(top5_cmdb_str).rename('example_cmdb_ids').reset_index()
    # Combine everything
    result_df = counts.merge(examples, on='kpi_name', how='left')
    # Sort by window_count desc, then total_count desc, and limit to top 50
    result_df = result_df.sort_values(['window_count','total_count'], ascending=[False, False]).head(50).reset_index(drop=True)

# Keep output compact: selected columns only
result_df[['kpi_name','total_count','window_count','example_cmdb_ids']]
