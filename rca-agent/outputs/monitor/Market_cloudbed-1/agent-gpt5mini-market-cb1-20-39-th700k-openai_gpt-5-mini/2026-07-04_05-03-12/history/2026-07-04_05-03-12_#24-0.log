import pandas as pd
import numpy as np
import re
import pytz
from datetime import datetime

# Reuse metric_df and tz/start_ts/end_ts if available, otherwise initialize
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Incident window (UTC+8)
start_ts = int(tz.localize(datetime(2022,3,20,22,30,0)).timestamp())
end_ts   = int(tz.localize(datetime(2022,3,20,23,0,0)).timestamp())

# Include and exclude substring lists (case-insensitive)
includes = [
    'container_network', 'transmit_MB', 'receive_MB', 'transmit_packets', 'receive_packets',
    'transmit_errors', 'receive_errors', 'container_memory', 'container_cpu', 'cpu_usage',
    'container_cpu_cfs', 'fs_reads', 'fs_writes', 'reads_MB', 'writes_MB', 'read_seconds',
    'write_seconds'
]
excludes = [
    'start_time', 'LastGcInfo', 'CollectionCount', 'TotalCompilation', 'CommittedVirtualMemory',
    'system.disk.total', 'limit', 'capacity', 'total', 'max_usage', 'count', 'uptime'
]

inc_pattern = '|'.join(re.escape(s) for s in includes)
exc_pattern = '|'.join(re.escape(s) for s in excludes)

# 1) Select matching rows (includes present AND excludes absent)
kpi_series = metric_df['kpi_name'].astype(str)
mask_inc = kpi_series.str.contains(inc_pattern, case=False, na=False, regex=True)
mask_exc = kpi_series.str.contains(exc_pattern, case=False, na=False, regex=True)
matching_rows = metric_df[mask_inc & (~mask_exc)].copy()

# If no matching rows, return empty DataFrame
if matching_rows.shape[0] == 0:
    top20_display = pd.DataFrame(columns=['cmdb_id','kpi_name','anomaly_count','max_run_length','earliest_longest_run_start','max_value_in_window','global_p95'])
else:
    # 2) Compute global P95 per (cmdb_id, kpi_name) using full series (before window filtering)
    global_p95 = (matching_rows
                  .groupby(['cmdb_id','kpi_name'], as_index=False)['value']
                  .quantile(0.95)
                  .rename(columns={'value':'global_p95'}))

    # 3) Filter matching rows to incident window and merge global_p95
    window = matching_rows[matching_rows['timestamp'].between(start_ts, end_ts)].copy()
    if window.shape[0] == 0:
        # No window rows -> empty result
        top20_display = pd.DataFrame(columns=['cmdb_id','kpi_name','anomaly_count','max_run_length','earliest_longest_run_start','max_value_in_window','global_p95'])
    else:
        window = window.merge(global_p95, on=['cmdb_id','kpi_name'], how='left')
        window.sort_values(['cmdb_id','kpi_name','timestamp'], inplace=True)

        # 4) Mark breaches where value >= global_p95 (threshold computed globally)
        window['breach'] = window['value'] >= window['global_p95']

        # 5) For each pair compute aggregates and consecutive one-minute runs
        def compute_runs(g):
            timestamps = g['timestamp'].values
            values = g['value'].values
            gp95 = float(g['global_p95'].iloc[0])
            breach_mask = g['breach'].values.astype(bool)
            anomaly_count = int(breach_mask.sum())
            max_val = float(values.max()) if len(values) > 0 else np.nan

            if anomaly_count == 0:
                return pd.Series({
                    'anomaly_count': 0,
                    'max_run_length': 0,
                    'earliest_longest_run_start': np.nan,
                    'max_value_in_window': max_val,
                    'global_p95': gp95
                })

            runs = []
            run_start = None
            run_len = 0
            prev_ts = None
            for b, ts in zip(breach_mask, timestamps):
                if b:
                    if run_len == 0:
                        run_start = ts
                        run_len = 1
                    else:
                        if ts == prev_ts + 60:
                            run_len += 1
                        else:
                            runs.append((run_start, run_len))
                            run_start = ts
                            run_len = 1
                else:
                    if run_len > 0:
                        runs.append((run_start, run_len))
                        run_len = 0
                        run_start = None
                prev_ts = ts
            if run_len > 0:
                runs.append((run_start, run_len))

            if len(runs) == 0:
                max_run_length = 0
                earliest_longest = np.nan
            else:
                max_run_length = max(r[1] for r in runs)
                candidates = [r[0] for r in runs if r[1] == max_run_length]
                earliest_longest = int(min(candidates)) if candidates else np.nan

            return pd.Series({
                'anomaly_count': int(anomaly_count),
                'max_run_length': int(max_run_length),
                'earliest_longest_run_start': earliest_longest,
                'max_value_in_window': max_val,
                'global_p95': gp95
            })

        agg = window.groupby(['cmdb_id','kpi_name'], sort=False).apply(compute_runs).reset_index()

        # 6) Sort and pick top 20 by max_run_length desc, then anomaly_count desc
        top20 = agg.sort_values(by=['max_run_length','anomaly_count'], ascending=[False, False]).head(20)

        cols = ['cmdb_id','kpi_name','anomaly_count','max_run_length','earliest_longest_run_start','max_value_in_window','global_p95']
        top20_display = top20[cols].reset_index(drop=True)

# Final compact output
top20_display
