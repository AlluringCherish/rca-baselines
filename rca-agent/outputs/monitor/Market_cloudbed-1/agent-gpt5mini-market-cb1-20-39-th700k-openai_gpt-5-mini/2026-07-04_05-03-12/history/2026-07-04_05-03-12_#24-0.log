# Keywords/substrings (case-insensitive) — dynamic set per your request
keywords = [
    'cpu', 'memory', 'mem', 'container_cpu', 'container_memory', 'network', 'transmit',
    'receive', 'packet', 'error', 'retransmit', 'retransmission', 'fs', 'read',
    'write', 'io', 'disk', 'blk'
]
pattern = '|'.join([re.escape(k) for k in keywords])

# Incident window (inclusive)
start_dt = tz.localize(datetime(2022, 3, 20, 22, 30, 0))
end_dt   = tz.localize(datetime(2022, 3, 20, 23,  0, 0))
start_ts = int(start_dt.timestamp())
end_ts   = int(end_dt.timestamp())

# 1) Restrict metric_df to KPI names matching keywords (case-insensitive)
selected_mask = metric_df['kpi_name'].str.contains(pattern, case=False, na=False, regex=True)
sel_df = metric_df.loc[selected_mask].copy()

# 2) Compute global P95 per (cmdb_id, kpi_name) using the full available series (before window filtering)
global_p95 = sel_df.groupby(['cmdb_id', 'kpi_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value':'global_p95'})

# 3) Filter selected data to the incident window and merge global_p95
window = sel_df[sel_df['timestamp'].between(start_ts, end_ts)].copy()
window = window.merge(global_p95, on=['cmdb_id','kpi_name'], how='left')

# Ensure sorting for run detection
window.sort_values(['cmdb_id','kpi_name','timestamp'], inplace=True)

# 4) Mark breach points where value >= global_p95
window['breach'] = window['value'] >= window['global_p95']

# 5) For each (cmdb_id,kpi_name) group compute aggregates including consecutive one-minute runs
def compute_runs(g):
    # g is already sorted by timestamp
    timestamps = g['timestamp'].values
    values = g['value'].values
    gp95 = float(g['global_p95'].iloc[0])
    breach_mask = g['breach'].values.astype(bool)
    anomaly_count = int(breach_mask.sum())
    max_val = float(values.max()) if len(values)>0 else np.nan

    if anomaly_count == 0:
        return pd.Series({
            'anomaly_count': 0,
            'max_run_length': 0,
            'earliest_longest_run_start': np.nan,
            'max_value_in_window': max_val,
            'global_p95': gp95
        })

    # Identify consecutive one-minute runs among breach points
    runs = []
    run_start = None
    run_len = 0
    prev_ts = None
    for b, ts in zip(breach_mask, timestamps):
        if b:
            if run_len == 0:
                run_start = ts
                run_len = 1
            else:
                # continue run only if timestamp is exactly previous + 60 seconds
                if ts == prev_ts + 60:
                    run_len += 1
                else:
                    runs.append((run_start, run_len))
                    run_start = ts
                    run_len = 1
        else:
            if run_len > 0:
                runs.append((run_start, run_len))
                run_len = 0
                run_start = None
        prev_ts = ts
    if run_len > 0:
        runs.append((run_start, run_len))

    if len(runs) == 0:
        max_run_length = 0
        earliest_longest = np.nan
    else:
        max_run_length = max(r[1] for r in runs)
        candidates = [r[0] for r in runs if r[1] == max_run_length]
        earliest_longest = int(min(candidates)) if candidates else np.nan

    return pd.Series({
        'anomaly_count': int(anomaly_count),
        'max_run_length': int(max_run_length),
        'earliest_longest_run_start': earliest_longest,
        'max_value_in_window': max_val,
        'global_p95': gp95
    })

# Apply aggregation per pair
agg = window.groupby(['cmdb_id','kpi_name'], sort=False).apply(compute_runs).reset_index()

# 6) Sort by max_run_length (desc) then anomaly_count (desc) and keep top 20
top20 = agg.sort_values(by=['max_run_length','anomaly_count'], ascending=[False, False]).head(20)

# Final compact table with requested columns
cols = ['cmdb_id','kpi_name','anomaly_count','max_run_length','earliest_longest_run_start','max_value_in_window','global_p95']
top20_display = top20[cols].reset_index(drop=True)

