import pandas as pd
import numpy as np
import pytz
from datetime import datetime

# Reuse trace_df if available, else load
try:
    trace_df
except NameError:
    trace_df = pd.read_csv('trace.csv')

# Ensure timezone and window timestamps (UTC+8)
tz = pytz.timezone('Asia/Shanghai')
start_ts = int(tz.localize(datetime(2022,3,20,22,30,0)).timestamp())
end_ts   = int(tz.localize(datetime(2022,3,20,23,0,0)).timestamp())

# 1) Compute global P95 per (cmdb_id, trace_name) using the full series (before filtering)
global_p95 = trace_df.groupby(['cmdb_id','trace_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value':'global_p95'})

# 2) Filter trace data to the incident window
window_df = trace_df[trace_df['timestamp'].between(start_ts, end_ts)].copy()

# 3) Merge global_p95 into windowed data to evaluate breaches
window_merged = window_df.merge(global_p95, on=['cmdb_id','trace_name'], how='left')

# 4) For each pair present in the window, compute anomaly_count, earliest anomaly timestamp, and max value in window
def agg_window(g):
    gp95 = g['global_p95'].iloc[0]
    mask = g['value'] >= gp95
    anomaly_count = int(mask.sum())
    earliest = int(g.loc[mask, 'timestamp'].min()) if anomaly_count > 0 else np.nan
    max_in_win = float(g['value'].max())
    return pd.Series({
        'anomaly_count': anomaly_count,
        'earliest_anomaly_timestamp': earliest,
        'max_value_in_window': max_in_win,
        'global_p95': float(gp95)
    })

if window_merged.shape[0] > 0:
    agg_windowed = window_merged.groupby(['cmdb_id','trace_name'], sort=False).apply(agg_window).reset_index()
else:
    agg_windowed = pd.DataFrame(columns=['cmdb_id','trace_name','anomaly_count','earliest_anomaly_timestamp','max_value_in_window','global_p95'])

# 5) Determine top results
total_anomalies = int(agg_windowed['anomaly_count'].sum()) if not agg_windowed.empty else 0

if total_anomalies > 0:
    # Sort by anomaly_count desc, then earliest timestamp asc
    top20 = agg_windowed.sort_values(by=['anomaly_count','earliest_anomaly_timestamp'], ascending=[False, True]).head(20)
else:
    # No anomalies in-window: rank by ratio max_value_in_window / global_p95 across all trace pairs
    # Get max value in window per pair (may be missing for many pairs)
    window_max = window_df.groupby(['cmdb_id','trace_name'], sort=False)['value'].max().reset_index(name='max_value_in_window')
    # Merge with global_p95 to compute ratio
    ratio_df = global_p95.merge(window_max, on=['cmdb_id','trace_name'], how='left')
    # Compute ratio with safe handling for zeros and NaNs
    def compute_ratio(row):
        gp = row['global_p95']
        mv = row['max_value_in_window']
        if pd.isna(mv):
            return 0.0
        if gp == 0:
            return np.inf if mv > 0 else 0.0
        return mv / gp
    ratio_df['ratio'] = ratio_df.apply(compute_ratio, axis=1)
    # For display, fill missing max_value_in_window with NaN and keep global_p95
    ratio_df.rename(columns={'global_p95':'global_p95'}, inplace=True)
    top_ratio = ratio_df.sort_values(by='ratio', ascending=False).head(20)
    # Prepare columns to match expected output
    top20 = top_ratio[['cmdb_id','trace_name']].copy()
    top20['anomaly_count'] = 0
    top20['earliest_anomaly_timestamp'] = np.nan
    top20['max_value_in_window'] = top_ratio['max_value_in_window']
    top20['global_p95'] = top_ratio['global_p95']

# Final compact table: selected columns only
cols = ['cmdb_id','trace_name','anomaly_count','earliest_anomaly_timestamp','max_value_in_window','global_p95']
top20_display = top20[cols].reset_index(drop=True)

top20_display
