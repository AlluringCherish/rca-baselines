import pandas as pd
import pytz

# Read CSV files (they are in the current working directory)
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")
log_df = pd.read_csv("log.csv")
error_logs_df = pd.read_csv("error_logs.csv")

# Helper to summarize a dataframe file
def summarize_df(df, cmdb_col, name_col=None, top_cols=None, list_limit=50, top_n=10):
    total_rows = int(df.shape[0])
    if cmdb_col in df.columns:
        unique_cmdb = pd.Series(df[cmdb_col].dropna().unique())
        unique_cmdb_list = unique_cmdb.iloc[:list_limit].tolist()
        unique_cmdb_count = int(unique_cmdb.size)
    else:
        unique_cmdb_list = []
        unique_cmdb_count = 0

    if name_col and name_col in df.columns:
        unique_names = pd.Series(df[name_col].dropna().unique())
        unique_names_list = unique_names.iloc[:list_limit].tolist()
        unique_names_count = int(unique_names.size)
    else:
        unique_names_list = []
        unique_names_count = 0

    # Select top columns if available, else take first 4 columns
    if top_cols:
        available_top_cols = [c for c in top_cols if c in df.columns]
    else:
        available_top_cols = df.columns.tolist()[:4]
    top_rows = df.loc[:, available_top_cols].head(top_n)

    return {
        "total_rows": total_rows,
        "unique_cmdb_count": unique_cmdb_count,
        "unique_cmdb_list": unique_cmdb_list,
        "unique_names_count": unique_names_count,
        "unique_names_list": unique_names_list,
        "top_rows": top_rows
    }

# Summarize each file according to requested fields
metric_summary = summarize_df(
    metric_df,
    cmdb_col="cmdb_id",
    name_col="kpi_name",
    top_cols=["timestamp", "cmdb_id", "kpi_name", "value"]
)

trace_summary = summarize_df(
    trace_df,
    cmdb_col="cmdb_id",
    name_col="trace_name",
    top_cols=["timestamp", "cmdb_id", "trace_name", "value"]
)

log_summary = summarize_df(
    log_df,
    cmdb_col="cmdb_id",
    name_col="log_name",
    top_cols=["timestamp", "cmdb_id", "log_name", "value"]
)

error_logs_summary = summarize_df(
    error_logs_df,
    cmdb_col="cmdb_id",
    name_col=None,
    top_cols=["timestamp", "cmdb_id", "message"]
)

# Prepare compact JSON-friendly result structure
result = {
    "metric.csv": {
        "total_rows": metric_summary["total_rows"],
        "unique_cmdb_count": metric_summary["unique_cmdb_count"],
        "unique_cmdb_list (<=50)": metric_summary["unique_cmdb_list"],
        "unique_kpi_count": metric_summary["unique_names_count"],
        "unique_kpi_list (<=50)": metric_summary["unique_names_list"],
        "top_10_rows": metric_summary["top_rows"]
    },
    "trace.csv": {
        "total_rows": trace_summary["total_rows"],
        "unique_cmdb_count": trace_summary["unique_cmdb_count"],
        "unique_cmdb_list (<=50)": trace_summary["unique_cmdb_list"],
        "unique_trace_count": trace_summary["unique_names_count"],
        "unique_trace_list (<=50)": trace_summary["unique_names_list"],
        "top_10_rows": trace_summary["top_rows"]
    },
    "log.csv": {
        "total_rows": log_summary["total_rows"],
        "unique_cmdb_count": log_summary["unique_cmdb_count"],
        "unique_cmdb_list (<=50)": log_summary["unique_cmdb_list"],
        "unique_log_count": log_summary["unique_names_count"],
        "unique_log_list (<=50)": log_summary["unique_names_list"],
        "top_10_rows": log_summary["top_rows"]
    },
    "error_logs.csv": {
        "total_rows": error_logs_summary["total_rows"],
        "unique_cmdb_count": error_logs_summary["unique_cmdb_count"],
        "unique_cmdb_list (<=50)": error_logs_summary["unique_cmdb_list"],
        "top_10_rows": error_logs_summary["top_rows"]
    },
    # Note: timezone used for interpretation in further analysis if needed:
    "timezone": str(pytz.timezone("Asia/Shanghai"))
}

