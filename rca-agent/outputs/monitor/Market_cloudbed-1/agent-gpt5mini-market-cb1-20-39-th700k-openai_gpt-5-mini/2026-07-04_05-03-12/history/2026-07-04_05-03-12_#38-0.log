import pandas as pd
import pytz
from datetime import datetime

# Reuse trace_df if present; otherwise read from file
try:
    trace_df
except NameError:
    trace_df = pd.read_csv("trace.csv")

# 1) Compute global P95 and P5 for each (cmdb_id, trace_name) across the full series
trace_thr = (
    trace_df
    .groupby(['cmdb_id', 'trace_name'])['value']
    .agg(global_p95=lambda s: s.quantile(0.95), global_p5=lambda s: s.quantile(0.05))
    .reset_index()
)

# 2) Define incident window in Asia/Shanghai (UTC+8) and filter trace_df
tz = pytz.timezone('Asia/Shanghai')
start_dt = tz.localize(datetime(2022, 3, 21, 3, 30, 0))
end_dt   = tz.localize(datetime(2022, 3, 21, 4,  0, 0))
start_ts = int(start_dt.timestamp())
end_ts   = int(end_dt.timestamp())

trace_window = trace_df[(trace_df['timestamp'] >= start_ts) & (trace_df['timestamp'] <= end_ts)].copy()

# 3) Join thresholds into the windowed rows and mark anomalies
trace_win_with_thr = trace_window.merge(trace_thr, on=['cmdb_id', 'trace_name'], how='left')
trace_win_with_thr['anomaly'] = (trace_win_with_thr['value'] >= trace_win_with_thr['global_p95']) | (trace_win_with_thr['value'] <= trace_win_with_thr['global_p5'])

# Window-level stats (max/min within the window for each pair)
trace_window_stats = (
    trace_window
    .groupby(['cmdb_id', 'trace_name'])['value']
    .agg(window_max_value='max', window_min_value='min', window_row_count='size')
    .reset_index()
)

# Anomaly-specific stats inside the window
anomaly_rows_trace = trace_win_with_thr[trace_win_with_thr['anomaly']]
if not anomaly_rows_trace.empty:
    trace_anomaly_stats = (
        anomaly_rows_trace
        .groupby(['cmdb_id', 'trace_name'])
        .agg(anomaly_count=('anomaly', 'sum'), earliest_anomaly_timestamp=('timestamp', 'min'))
        .reset_index()
    )

    # Merge everything: anomaly stats + window stats + global thresholds
    trace_merged = (
        trace_anomaly_stats
        .merge(trace_window_stats, on=['cmdb_id', 'trace_name'], how='left')
        .merge(trace_thr, on=['cmdb_id', 'trace_name'], how='left')
    )

    # Select and order required columns, sort by anomaly_count desc, limit 20
    trace_result_df = trace_merged[[
        'cmdb_id',
        'trace_name',
        'anomaly_count',
        'earliest_anomaly_timestamp',
        'window_max_value',
        'window_min_value',
        'global_p95',
        'global_p5'
    ]].sort_values(by='anomaly_count', ascending=False).head(20).reset_index(drop=True)
else:
    # Explicit empty indicator as requested
    trace_result_df = pd.DataFrame(columns=[
        'cmdb_id','trace_name','anomaly_count','earliest_anomaly_timestamp',
        'window_max_value','window_min_value','global_p95','global_p5'
    ])

# Display compact result (at most 20 rows)
trace_result_df
