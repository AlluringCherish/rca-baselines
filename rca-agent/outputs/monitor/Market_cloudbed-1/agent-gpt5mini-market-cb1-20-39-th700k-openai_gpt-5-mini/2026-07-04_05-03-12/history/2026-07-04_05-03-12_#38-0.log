import pandas as pd
import pytz
from datetime import datetime
import numpy as np

# Reuse metric_df from previous runs (it should exist in the kernel)
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

# 1) Compute global P95 and P5 for each kpi_name of node-6 using the full series (do NOT filter by time for thresholds)
node_id = 'node-6'
thr_node = (
    metric_df[metric_df['cmdb_id'] == node_id]
    .groupby('kpi_name')['value']
    .agg(global_p95=lambda s: s.quantile(0.95), global_p5=lambda s: s.quantile(0.05))
    .reset_index()
)

# 2) Define incident window in Asia/Shanghai (UTC+8) and filter metric_df to that window and node-6
tz = pytz.timezone('Asia/Shanghai')
start_dt = tz.localize(datetime(2022, 3, 21, 3, 30, 0))
end_dt   = tz.localize(datetime(2022, 3, 21, 4,  0, 0))
start_ts = int(start_dt.timestamp())
end_ts   = int(end_dt.timestamp())

window_node = metric_df[
    (metric_df['cmdb_id'] == node_id) &
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts)
].copy()

# 3) For each kpi_name in the window compute anomaly_count, earliest_anomaly_timestamp, window_max_value, window_min_value
win_with_thr = window_node.merge(thr_node, on='kpi_name', how='left')
win_with_thr['anomaly'] = (win_with_thr['value'] >= win_with_thr['global_p95']) | (win_with_thr['value'] <= win_with_thr['global_p5'])

window_stats_node = (
    window_node
    .groupby('kpi_name')['value']
    .agg(window_max_value='max', window_min_value='min', window_row_count='size')
    .reset_index()
)

anomaly_rows_node = win_with_thr[win_with_thr['anomaly']]
if not anomaly_rows_node.empty:
    anomaly_stats_node = (
        anomaly_rows_node
        .groupby('kpi_name')
        .agg(anomaly_count=('anomaly', 'sum'), earliest_anomaly_timestamp=('timestamp', 'min'))
        .reset_index()
    )

    merged_node = (
        anomaly_stats_node
        .merge(window_stats_node, on='kpi_name', how='left')
        .merge(thr_node, on='kpi_name', how='left')
    )

    # 4) Compute breach_pct using the formula with 1e-9 floor
    eps = 1e-9
    a = (merged_node['window_max_value'] - merged_node['global_p95']) / merged_node['global_p95'].abs().clip(lower=eps)
    b = (merged_node['global_p5'] - merged_node['window_min_value']) / merged_node['global_p5'].abs().clip(lower=eps)
    merged_node['breach_pct'] = np.maximum(a, b)

    # 5) Filter rows with anomaly_count>0 and breach_pct>0.5, sort and limit to 20
    result_df = (
        merged_node[merged_node['anomaly_count'] > 0]
        .loc[lambda df: df['breach_pct'] > 0.5]
        .sort_values(by='breach_pct', ascending=False)
        .reset_index(drop=True)
    )

    if not result_df.empty:
        result_df = result_df[[
            'kpi_name',
            'anomaly_count',
            'earliest_anomaly_timestamp',
            'window_max_value',
            'window_min_value',
            'global_p95',
            'global_p5',
            'breach_pct'
        ]].head(20)
    else:
        # explicit empty result indicator
        result_df = pd.DataFrame(columns=[
            'kpi_name','anomaly_count','earliest_anomaly_timestamp',
            'window_max_value','window_min_value','global_p95','global_p5','breach_pct'
        ])
else:
    # explicit empty result indicator when no anomaly rows
    result_df = pd.DataFrame(columns=[
        'kpi_name','anomaly_count','earliest_anomaly_timestamp',
        'window_max_value','window_min_value','global_p95','global_p5','breach_pct'
    ])

