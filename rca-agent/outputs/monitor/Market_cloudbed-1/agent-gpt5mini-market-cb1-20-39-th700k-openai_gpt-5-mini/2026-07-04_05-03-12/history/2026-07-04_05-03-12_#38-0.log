import pandas as pd
import pytz
from datetime import datetime
import numpy as np

# Reuse metric_df if present; otherwise read
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

# 1) Compute global P95 and P5 for each kpi_name of shippingservice2-0 using full series
ship_all = metric_df[metric_df['cmdb_id'] == 'shippingservice2-0']
thr_ship = (
    ship_all
    .groupby('kpi_name')['value']
    .agg(global_p95=lambda s: s.quantile(0.95), global_p5=lambda s: s.quantile(0.05))
    .reset_index()
)

# 2) Define incident window in Asia/Shanghai (UTC+8) and filter to that window and cmdb_id
tz = pytz.timezone('Asia/Shanghai')
start_dt = tz.localize(datetime(2022, 3, 21, 3, 30, 0))
end_dt   = tz.localize(datetime(2022, 3, 21, 4,  0, 0))
start_ts = int(start_dt.timestamp())
end_ts   = int(end_dt.timestamp())

window_ship = metric_df[
    (metric_df['cmdb_id'] == 'shippingservice2-0') &
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts)
].copy()

# 3) For each kpi_name in the window compute anomaly_count, earliest_anomaly_timestamp, window_max_value, window_min_value
# Join thresholds
win_with_thr = window_ship.merge(thr_ship, on='kpi_name', how='left')

# Mark anomalies
win_with_thr['anomaly'] = (win_with_thr['value'] >= win_with_thr['global_p95']) | (win_with_thr['value'] <= win_with_thr['global_p5'])

# Window stats per kpi
window_stats = (
    window_ship
    .groupby('kpi_name')['value']
    .agg(window_max_value='max', window_min_value='min', window_row_count='size')
    .reset_index()
)

# Anomaly stats per kpi
anomaly_rows = win_with_thr[win_with_thr['anomaly']]
if not anomaly_rows.empty:
    anomaly_stats = (
        anomaly_rows
        .groupby('kpi_name')
        .agg(anomaly_count=('anomaly', 'sum'), earliest_anomaly_timestamp=('timestamp', 'min'))
        .reset_index()
    )

    merged = (
        anomaly_stats
        .merge(window_stats, on='kpi_name', how='left')
        .merge(thr_ship, on='kpi_name', how='left')
    )

    # 4) Compute breach_pct
    eps = 1e-9
    # prevent division by zero by using max with eps
    a = (merged['window_max_value'] - merged['global_p95']) / merged['global_p95'].abs().clip(lower=eps)
    b = (merged['global_p5'] - merged['window_min_value']) / merged['global_p5'].abs().clip(lower=eps)
    merged['breach_pct'] = np.maximum(a, b)

    # 5) Filter rows with anomaly_count>0 and breach_pct>0.5, order by breach_pct desc, limit 20
    result_df = (
        merged[merged['anomaly_count'] > 0]
        .loc[lambda df: df['breach_pct'] > 0.5]
        .sort_values(by='breach_pct', ascending=False)
        .reset_index(drop=True)
    )

    # Select required columns and cap to 20
    if not result_df.empty:
        result_df = result_df[[
            'kpi_name',
            'anomaly_count',
            'earliest_anomaly_timestamp',
            'window_max_value',
            'window_min_value',
            'global_p95',
            'global_p5',
            'breach_pct'
        ]].head(20)
    else:
        result_df = pd.DataFrame(columns=[
            'kpi_name','anomaly_count','earliest_anomaly_timestamp',
            'window_max_value','window_min_value','global_p95','global_p5','breach_pct'
        ])
else:
    # explicit empty result indicator
    result_df = pd.DataFrame(columns=[
        'kpi_name','anomaly_count','earliest_anomaly_timestamp',
        'window_max_value','window_min_value','global_p95','global_p5','breach_pct'
    ])

# Display compact result (at most 20 rows)
result_df
