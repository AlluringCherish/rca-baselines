2026-07-04 05:04:24,981 | DEBUG | Raw Code:
import pandas as pd
import pytz
from datetime import datetime

# Reuse metric_df if present; otherwise read from file
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

# 1) Compute global P95 and P5 for each (cmdb_id, kpi_name) across the full series
thr = (
    metric_df
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(global_p95=lambda s: s.quantile(0.95), global_p5=lambda s: s.quantile(0.05))
    .reset_index()
)

# 2) Filter metric_df to the incident window in Asia/Shanghai (UTC+8)
tz = pytz.timezone('Asia/Shanghai')
start_dt = tz.localize(datetime(2022, 3, 21, 3, 30, 0))
end_dt   = tz.localize(datetime(2022, 3, 21, 4,  0, 0))
start_ts = int(start_dt.timestamp())
end_ts   = int(end_dt.timestamp())

window_df = metric_df[(metric_df['timestamp'] >= start_ts) & (metric_df['timestamp'] <= end_ts)].copy()

# 3) For each pair, count rows inside window that are anomalies (value >= global_p95 OR value <= global_p5)
# Join thresholds into the windowed rows
win_with_thr = window_df.merge(thr, on=['cmdb_id', 'kpi_name'], how='left')

# Mark anomaly rows
win_with_thr['anomaly'] = (win_with_thr['value'] >= win_with_thr['global_p95']) | (win_with_thr['value'] <= win_with_thr['global_p5'])

# Window-level stats (max/min within the window for each pair)
window_stats = (
    window_df
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(window_max_value='max', window_min_value='min', window_row_count='size')
    .reset_index()
)

# Anomaly-specific stats inside the window
anomaly_rows = win_with_thr[win_with_thr['anomaly']]
if not anomaly_rows.empty:
    anomaly_stats = (
        anomaly_rows
        .groupby(['cmdb_id', 'kpi_name'])
        .agg(anomaly_count=('anomaly', 'sum'), earliest_anomaly_timestamp=('timestamp', 'min'))
        .reset_index()
    )

    # Merge everything: anomaly stats + window stats + global thresholds
    merged = (
        anomaly_stats
        .merge(window_stats, on=['cmdb_id', 'kpi_name'], how='left')
        .merge(thr, on=['cmdb_id', 'kpi_name'], how='left')
    )

    # Select and order required columns
    result_df = merged[[
        'cmdb_id',
        'kpi_name',
        'anomaly_count',
        'earliest_anomaly_timestamp',
        'window_max_value',
        'window_min_value',
        'global_p95',
        'global_p5'
    ]].sort_values(by='anomaly_count', ascending=False).head(20).reset_index(drop=True)
else:
    # Explicit empty indicator as requested
    result_df = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp',
        'window_max_value','window_min_value','global_p95','global_p5'
    ])

# Display the compact result (at most 20 rows)
result_df
