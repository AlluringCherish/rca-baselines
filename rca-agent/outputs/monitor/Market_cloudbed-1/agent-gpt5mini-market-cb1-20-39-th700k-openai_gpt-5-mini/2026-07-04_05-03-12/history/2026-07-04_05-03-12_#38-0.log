import pandas as pd
import pytz
from datetime import datetime
import numpy as np

# Reuse metric_df if available
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

node_id = 'node-6'

# 1) Select kpi_names for node-6 containing 'system.cpu' or 'cpu' (case-sensitive)
node_df = metric_df[metric_df['cmdb_id'] == node_id]
cpu_mask = node_df['kpi_name'].str.contains('system.cpu') | node_df['kpi_name'].str.contains('cpu')
cpu_kpis = pd.Series(node_df.loc[cpu_mask, 'kpi_name'].dropna().unique()).reset_index(drop=True)

# 2) Compute global P95 and P5 for each selected kpi_name using the full series (thresholds computed globally)
thr_cpu = (
    metric_df[
        (metric_df['cmdb_id'] == node_id) &
        (metric_df['kpi_name'].isin(cpu_kpis))
    ]
    .groupby('kpi_name')['value']
    .agg(global_p95=lambda s: s.quantile(0.95), global_p5=lambda s: s.quantile(0.05))
    .reset_index()
)

# 3) Filter to incident window and node-6 and selected CPU KPIs
tz = pytz.timezone('Asia/Shanghai')
start_ts = int(tz.localize(datetime(2022,3,21,3,30,0)).timestamp())
end_ts   = int(tz.localize(datetime(2022,3,21,4,0,0)).timestamp())

window_node_cpu = metric_df[
    (metric_df['cmdb_id'] == node_id) &
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts) &
    (metric_df['kpi_name'].isin(cpu_kpis))
].copy()

# Join thresholds and mark anomalies
win_with_thr = window_node_cpu.merge(thr_cpu, on='kpi_name', how='left')
win_with_thr['anomaly'] = (win_with_thr['value'] >= win_with_thr['global_p95']) | (win_with_thr['value'] <= win_with_thr['global_p5'])

# Window stats per kpi
window_stats = (
    window_node_cpu
    .groupby('kpi_name')['value']
    .agg(window_max_value='max', window_min_value='min', window_row_count='size')
    .reset_index()
)

# Anomaly stats per kpi
anomaly_rows = win_with_thr[win_with_thr['anomaly']]
if not anomaly_rows.empty:
    anomaly_stats = (
        anomaly_rows
        .groupby('kpi_name')
        .agg(anomaly_count=('anomaly', 'sum'), earliest_anomaly_timestamp=('timestamp', 'min'))
        .reset_index()
    )

    merged = (
        anomaly_stats
        .merge(window_stats, on='kpi_name', how='left')
        .merge(thr_cpu, on='kpi_name', how='left')
    )

    # 4) Compute breach_pct with numerical floor eps
    eps = 1e-9
    a = (merged['window_max_value'] - merged['global_p95']) / merged['global_p95'].abs().clip(lower=eps)
    b = (merged['global_p5'] - merged['window_min_value']) / merged['global_p5'].abs().clip(lower=eps)
    merged['breach_pct'] = np.maximum(a, b)

    # 5) Filter results: anomaly_count>0 and breach_pct>0.5, sort by breach_pct desc, limit 20
    result_df = (
        merged[merged['anomaly_count'] > 0]
        .loc[lambda df: df['breach_pct'] > 0.5]
        .sort_values(by='breach_pct', ascending=False)
        .reset_index(drop=True)
    )

    if not result_df.empty:
        result_df = result_df[[
            'kpi_name',
            'anomaly_count',
            'earliest_anomaly_timestamp',
            'window_max_value',
            'window_min_value',
            'global_p95',
            'global_p5',
            'breach_pct'
        ]].head(20)
    else:
        result_df = pd.DataFrame(columns=[
            'kpi_name','anomaly_count','earliest_anomaly_timestamp',
            'window_max_value','window_min_value','global_p95','global_p5','breach_pct'
        ])
else:
    result_df = pd.DataFrame(columns=[
        'kpi_name','anomaly_count','earliest_anomaly_timestamp',
        'window_max_value','window_min_value','global_p95','global_p5','breach_pct'
    ])

# Display compact result (variable name for IPython)
result_df
