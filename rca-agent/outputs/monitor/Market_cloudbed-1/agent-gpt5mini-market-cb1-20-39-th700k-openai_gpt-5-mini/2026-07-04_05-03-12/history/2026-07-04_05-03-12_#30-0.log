import pandas as pd
import pytz

# reuse existing variables/dataframes where possible
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# ensure timezone-aware datetime column in df_metric
if 'dt' not in df_metric.columns:
    df_metric['dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Candidate cmdb_id list (top log candidates)
candidates = [
    "cartservice-0","cartservice-1","cartservice-2",
    "currencyservice-0","currencyservice-1","currencyservice-2",
    "frontend-1","frontend-2",
    "productcatalogservice-0","productcatalogservice-1",
    "recommendationservice-1","recommendationservice-2",
    "shippingservice-1",
    "adservice-0","adservice-1","adservice-2",
    "checkoutservice-0","checkoutservice-1",
    "emailservice-0","emailservice-2"
]

# 1) Compute global P95 for each (cmdb_id, kpi_name) pair across the full metric series (only for candidate cmdbs)
metric_candidates = df_metric[df_metric['cmdb_id'].isin(candidates)]
p95_df = metric_candidates.groupby(['cmdb_id', 'kpi_name'])['value'].quantile(0.95).reset_index().rename(columns={'value':'p95'})

# Keep only pairs with p95 > 0 (we will skip pairs where p95 == 0 as requested)
p95_pos = p95_df[p95_df['p95'] > 0].copy()

# 2) Filter metric rows to the window 2022-03-20 17:00:00 to 2022-03-20 17:30:00 (UTC+8)
start_dt = tz.localize(pd.Timestamp('2022-03-20 17:00:00'))
end_dt   = tz.localize(pd.Timestamp('2022-03-20 17:30:00'))
metric_window = metric_candidates[(metric_candidates['dt'] >= start_dt) & (metric_candidates['dt'] <= end_dt)].copy()

# Merge global p95 into windowed rows (only for pairs that had p95 > 0)
metric_window = metric_window.merge(p95_pos, on=['cmdb_id', 'kpi_name'], how='inner')

# Compute breach threshold = 1.5 * p95 and flag breaches
metric_window['breach_threshold'] = 1.5 * metric_window['p95']
metric_window['is_breach'] = metric_window['value'] >= metric_window['breach_threshold']

# Aggregate per (cmdb_id, kpi_name)
agg = metric_window.groupby(['cmdb_id', 'kpi_name']).agg(
    total_points_in_window=('value', 'size'),
    breach_count=('is_breach', 'sum'),
    max_value_in_window=('value', 'max'),
    p95=('p95', 'first')
).reset_index()

# earliest_breach_timestamp: first dt where is_breach True
earliest_breach = metric_window[metric_window['is_breach']].groupby(['cmdb_id', 'kpi_name'])['dt'].min().rename('earliest_breach_dt').reset_index()
agg = agg.merge(earliest_breach, on=['cmdb_id', 'kpi_name'], how='left')

# format earliest_breach_timestamp as string with timezone; keep NA if missing
agg['earliest_breach_timestamp'] = agg['earliest_breach_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
agg.loc[agg['earliest_breach_timestamp'].isna(), 'earliest_breach_timestamp'] = pd.NA

# Keep only pairs with breach_count > 0
result = agg[agg['breach_count'] > 0].copy()

# If no breaches found, return an empty DataFrame with the requested columns
output_cols = ['cmdb_id', 'kpi_name', 'total_points_in_window', 'breach_count',
               'earliest_breach_timestamp', 'max_value_in_window', 'p95']

if result.empty:
    final_result = pd.DataFrame(columns=output_cols)
else:
    # sort by breach_count desc, then earliest_breach_timestamp asc (convert to datetime for sorting; NaT last)
    result['_earliest_dt_sort'] = pd.to_datetime(result['earliest_breach_dt'])
    result_sorted = result.sort_values(by=['breach_count', '_earliest_dt_sort'], ascending=[False, True]).head(20)
    final_result = result_sorted[output_cols].reset_index(drop=True)

final_result
