# Reuse existing df_metric and tz if available
try:
    df_metric
except NameError:
    import pandas as pd
    df_metric = pd.read_csv('metric.csv')
try:
    tz
except NameError:
    import pytz
    tz = pytz.timezone('Asia/Shanghai')

# Ensure timezone-aware datetime column (UTC -> Asia/Shanghai)
if 'dt' not in df_metric.columns:
    df_metric['dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Candidate cmdb_ids and kpi substring
candidates = ["adservice-1","adservice-2"]
kpi_sub = "container_memory_failures"

# 1) Compute global P95 for each (cmdb_id, kpi_name) across the full metric series (for selected cmdbs & KPI substring)
mask_all = df_metric['cmdb_id'].isin(candidates) & df_metric['kpi_name'].str.contains(kpi_sub, na=False)
p95_df = df_metric[mask_all].groupby(['cmdb_id', 'kpi_name'])['value'].quantile(0.95).reset_index().rename(columns={'value':'p95'})

# 2) Filter rows to the time window (inclusive) in UTC+8
start_dt = tz.localize(pd.Timestamp('2022-03-20 17:00:00'))
end_dt   = tz.localize(pd.Timestamp('2022-03-20 17:30:00'))
mask_window = mask_all & (df_metric['dt'] >= start_dt) & (df_metric['dt'] <= end_dt)
metric_window = df_metric[mask_window].copy()

# Merge global p95 into the windowed rows (thresholds computed before filtering)
metric_window = metric_window.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# Compute breach threshold and filter rows where value >= 1.5 * p95
metric_window['breach_threshold'] = 1.5 * metric_window['p95']
breaches = metric_window[metric_window['value'] >= metric_window['breach_threshold']].copy()

# Prepare output columns and limit to top 20 rows (ordered by cmdb_id then timestamp)
result = breaches[['timestamp', 'cmdb_id', 'kpi_name', 'value', 'p95']].sort_values(by=['cmdb_id', 'timestamp']).head(20)

# Display compact result
result
