import pandas as pd
import pytz

# reuse existing df_log and tz if available, otherwise load/create
try:
    df_log
except NameError:
    df_log = pd.read_csv('log.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# ensure timezone-aware datetime column in df_log (UTC -> Asia/Shanghai)
if 'dt' not in df_log.columns:
    df_log['dt'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# candidates and window (inclusive) in UTC+8
candidates = ["cartservice-0", "cartservice-2"]
start_dt = tz.localize(pd.Timestamp('2022-03-20 17:00:00'))
end_dt = tz.localize(pd.Timestamp('2022-03-20 17:30:00'))

# filter rows
mask = (
    df_log['cmdb_id'].isin(candidates) &
    (df_log['log_name'] == 'log.error_count') &
    (df_log['dt'] >= start_dt) &
    (df_log['dt'] <= end_dt)
)
df_window = df_log.loc[mask].copy()

# aggregations
total_points = df_window.groupby('cmdb_id')['value'].size().rename('total_points_in_window')
nonzero_count = (df_window['value'] != 0).groupby(df_window['cmdb_id']).sum().rename('nonzero_count')
max_value = df_window.groupby('cmdb_id')['value'].max().rename('max_value_in_window')

# earliest nonzero timestamp
df_nonzero = df_window[df_window['value'] != 0]
earliest_nonzero = df_nonzero.groupby('cmdb_id')['dt'].min().rename('earliest_nonzero_dt')

# combine
agg = pd.concat([total_points, nonzero_count, max_value, earliest_nonzero], axis=1).reset_index()

# format earliest timestamp as string with timezone, keep NA where missing
agg['earliest_nonzero_timestamp'] = agg['earliest_nonzero_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
agg.loc[agg['earliest_nonzero_timestamp'].isna(), 'earliest_nonzero_timestamp'] = pd.NA

# select required columns, sort by cmdb_id, limit to up to 2 rows
result_df = agg[['cmdb_id', 'total_points_in_window', 'nonzero_count', 'earliest_nonzero_timestamp', 'max_value_in_window']].sort_values('cmdb_id').head(2).reset_index(drop=True)

