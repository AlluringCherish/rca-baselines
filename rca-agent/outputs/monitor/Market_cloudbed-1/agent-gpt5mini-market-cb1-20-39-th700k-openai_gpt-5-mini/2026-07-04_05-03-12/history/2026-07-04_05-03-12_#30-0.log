import pandas as pd
import pytz

# reuse existing df_log and tz if present, otherwise load
try:
    df_log
except NameError:
    df_log = pd.read_csv('log.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# ensure timezone-aware datetime column (UTC -> Asia/Shanghai)
if 'dt' not in df_log.columns:
    df_log['dt'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# define window (inclusive) in UTC+8
start_dt = tz.localize(pd.Timestamp('2022-03-20 17:00:00'))
end_dt = tz.localize(pd.Timestamp('2022-03-20 17:30:00'))

# filter to window
df_log_window = df_log[(df_log['dt'] >= start_dt) & (df_log['dt'] <= end_dt)].copy()

# compute aggregations
total_points = df_log_window.groupby(['cmdb_id', 'log_name'])['value'].size().rename('total_points_in_window')
nonzero_count = (df_log_window['value'] != 0).groupby([df_log_window['cmdb_id'], df_log_window['log_name']]).sum().rename('nonzero_count')
max_value = df_log_window.groupby(['cmdb_id', 'log_name'])['value'].max().rename('max_value_in_window')

# earliest nonzero timestamp
df_nonzero = df_log_window[df_log_window['value'] != 0]
earliest_nonzero = df_nonzero.groupby(['cmdb_id', 'log_name'])['dt'].min().rename('earliest_nonzero_dt')

# combine
agg = pd.concat([total_points, nonzero_count, max_value, earliest_nonzero], axis=1).reset_index()

# format earliest_nonzero timestamp as string with timezone, keep NA where missing
agg['earliest_nonzero_timestamp'] = agg['earliest_nonzero_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
agg.loc[agg['earliest_nonzero_timestamp'].isna(), 'earliest_nonzero_timestamp'] = pd.NA

# prepare sort: use datetime column (earliest_nonzero_dt) with NaT last
agg['_earliest_sort_dt'] = pd.to_datetime(agg['earliest_nonzero_dt'])

# select required columns and sort by nonzero_count desc, earliest_nonzero asc
result = agg[['cmdb_id', 'log_name', 'total_points_in_window', 'nonzero_count',
              'earliest_nonzero_timestamp', 'max_value_in_window', '_earliest_sort_dt']]

result_sorted = result.sort_values(by=['nonzero_count', '_earliest_sort_dt'], ascending=[False, True], na_position='last').head(20)

# drop helper sort column for final display
result_sorted = result_sorted.drop(columns=['_earliest_sort_dt'])

result_sorted
