import pandas as pd
import pytz

# reuse existing variables if present
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# ensure timezone-aware datetime column in UTC+8
if 'dt' not in df_trace.columns:
    df_trace['dt'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Compute global P95 and P5 for each (cmdb_id, trace_name) using all rows
p95 = df_trace.groupby(['cmdb_id', 'trace_name'])['value'].quantile(0.95).rename('p95').reset_index()
p5  = df_trace.groupby(['cmdb_id', 'trace_name'])['value'].quantile(0.05).rename('p5').reset_index()
thresholds = p95.merge(p5, on=['cmdb_id', 'trace_name'], how='outer')

# 2) Filter to the time window (inclusive) 2022-03-20 17:00:00 to 2022-03-20 17:30:00 UTC+8
start_dt = tz.localize(pd.Timestamp('2022-03-20 17:00:00'))
end_dt   = tz.localize(pd.Timestamp('2022-03-20 17:30:00'))
df_window = df_trace[(df_trace['dt'] >= start_dt) & (df_trace['dt'] <= end_dt)].copy()

# Merge thresholds into the windowed data so we can flag highs/lows
df_window = df_window.merge(thresholds, on=['cmdb_id', 'trace_name'], how='left')

# Flags
df_window['is_high'] = df_window['value'] >= df_window['p95']
df_window['is_low']  = df_window['value'] <= df_window['p5']

# Aggregations in window
agg_base = df_window.groupby(['cmdb_id', 'trace_name']).agg(
    total_points_in_window=('value', 'size'),
    count_high=('is_high', 'sum'),
    count_low=('is_low', 'sum'),
    max_value_in_window=('value', 'max'),
    min_value_in_window=('value', 'min'),
    p95=('p95', 'first'),
    p5 =('p5', 'first')
).reset_index()

# Earliest high/low timestamps per group (as datetime)
earliest_high = df_window[df_window['is_high']].groupby(['cmdb_id', 'trace_name'])['dt'].min().rename('earliest_high_dt').reset_index()
earliest_low  = df_window[df_window['is_low']].groupby(['cmdb_id', 'trace_name'])['dt'].min().rename('earliest_low_dt').reset_index()

# Merge earliest timestamps
agg = agg_base.merge(earliest_high, on=['cmdb_id', 'trace_name'], how='left').merge(earliest_low, on=['cmdb_id', 'trace_name'], how='left')

# For sorting, compute max_count and earliest_nonnull_dt (the earlier of high/low earliest)
agg['max_count'] = agg[['count_high', 'count_low']].max(axis=1)
agg['_earliest_sort_dt'] = agg[['earliest_high_dt', 'earliest_low_dt']].apply(
    lambda row: pd.to_datetime(row.dropna()).min() if row.dropna().size>0 else pd.NaT, axis=1
)

# Format earliest timestamps as strings for compact display
agg['earliest_high_timestamp'] = agg['earliest_high_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
agg.loc[agg['earliest_high_timestamp'].isna(), 'earliest_high_timestamp'] = pd.NA
agg['earliest_low_timestamp'] = agg['earliest_low_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
agg.loc[agg['earliest_low_timestamp'].isna(), 'earliest_low_timestamp'] = pd.NA

# Select required columns
result = agg[['cmdb_id', 'trace_name', 'total_points_in_window',
              'count_high', 'earliest_high_timestamp',
              'count_low', 'earliest_low_timestamp',
              'max_value_in_window', 'min_value_in_window', 'p95', 'p5', 'max_count', '_earliest_sort_dt']]

# 3) Sort by max(count_high,count_low) desc, then by earliest timestamp asc; limit to top 20
result_sorted = result.sort_values(by=['max_count', '_earliest_sort_dt'], ascending=[False, True]).head(20)

# Drop helper cols before display
result_sorted = result_sorted.drop(columns=['max_count', '_earliest_sort_dt'])

# Display compact top-20 result
result_sorted
