import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# reuse existing dataframes if present, otherwise load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')

# 1) set of unique cmdb_id values that appear in trace.csv
trace_cmdb_set = set(df_trace['cmdb_id'].unique())

# Prepare metric dataframe with timezone-aware datetime column (UTC->Asia/Shanghai)
if 'dt' not in df_metric.columns:
    df_metric['dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 2) For (cmdb_id,kpi_name) pairs where cmdb_id in trace set, compute global P95 using all metric rows for that pair
metric_pairs = df_metric[df_metric['cmdb_id'].isin(trace_cmdb_set)]
p95_series = metric_pairs.groupby(['cmdb_id', 'kpi_name'])['value'].quantile(0.95).rename('p95_threshold')
p95_df = p95_series.reset_index()

# 3) Filter metric rows to the time window 2022-03-20 17:00:00 to 2022-03-20 17:30:00 (UTC+8)
start_dt = tz.localize(pd.Timestamp('2022-03-20 17:00:00'))
end_dt = tz.localize(pd.Timestamp('2022-03-20 17:30:00'))
metric_window = metric_pairs[(df_metric['dt'] >= start_dt) & (df_metric['dt'] <= end_dt)].copy()

# Merge global p95 thresholds into windowed rows to evaluate anomalies
metric_window = metric_window.merge(p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# Flag anomalies where value >= global P95
metric_window['is_anomaly'] = metric_window['value'] >= metric_window['p95_threshold']

# 3) Aggregate per (cmdb_id,kpi_name)
agg = metric_window.groupby(['cmdb_id', 'kpi_name']).agg(
    total_points_in_window=('value', 'size'),
    anomaly_count=('is_anomaly', 'sum'),
    earliest_anomaly_dt=('dt', lambda s: s[metric_window.loc[s.index, 'is_anomaly']].min() if s.size>0 else pd.NaT),
    max_value_in_window=('value', 'max'),
    p95_threshold=('p95_threshold', 'first')
).reset_index()

# Normalize earliest_anomaly_dt to string for compact display (keep timezone info). If NaT, keep as None.
agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
agg.loc[agg['earliest_anomaly_timestamp'].isna(), 'earliest_anomaly_timestamp'] = pd.NA

# Select and order required columns only
result_df = agg[['cmdb_id', 'kpi_name', 'total_points_in_window', 'anomaly_count',
                 'earliest_anomaly_timestamp', 'max_value_in_window', 'p95_threshold']]

# 4) Return top 20 pairs ranked by anomaly_count (desc), tie by earliest_anomaly_timestamp (asc)
# For sorting, convert earliest_anomaly_timestamp back to datetime where possible to sort correctly, NaT last
result_df['_earliest_dt_sort'] = pd.to_datetime(result_df['earliest_anomaly_timestamp'], format='%Y-%m-%d %H:%M:%S%z', utc=True, errors='coerce')
result_df_sorted = result_df.sort_values(by=['anomaly_count', '_earliest_dt_sort'], ascending=[False, True]).head(20)

# Drop helper column before display
result_df_sorted = result_df_sorted.drop(columns=['_earliest_dt_sort'])

result_df_sorted
