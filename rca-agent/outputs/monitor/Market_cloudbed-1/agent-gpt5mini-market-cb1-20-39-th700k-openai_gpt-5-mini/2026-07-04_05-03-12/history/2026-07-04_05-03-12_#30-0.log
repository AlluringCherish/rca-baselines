import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Load CSV files
df_metric = pd.read_csv('metric.csv')
df_trace = pd.read_csv('trace.csv')
df_log = pd.read_csv('log.csv')
df_err = pd.read_csv('error_logs.csv')

# Helper to compute basic summary: total rows, min and max timestamp converted to Asia/Shanghai timezone
def basic_summary(df):
    total = int(df.shape[0])
    if total == 0:
        return pd.DataFrame([{'total_rows': total, 'min_timestamp': pd.NaT, 'max_timestamp': pd.NaT}])
    ts = pd.to_datetime(df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    return pd.DataFrame([{'total_rows': total, 'min_timestamp': ts.min(), 'max_timestamp': ts.max()}])

# Helper to get top N counts for a column
def top_counts(df, col, n=20):
    if col not in df.columns:
        return pd.DataFrame(columns=[col, 'count'])
    vc = df[col].value_counts().reset_index()
    vc.columns = [col, 'count']
    return vc.head(n)

# Compute summaries
metric_basic = basic_summary(df_metric)
trace_basic = basic_summary(df_trace)
log_basic = basic_summary(df_log)
err_basic = basic_summary(df_err)

# Top cmdb_id for each file (up to 20)
metric_cmdb_top = top_counts(df_metric, 'cmdb_id', 20)
trace_cmdb_top = top_counts(df_trace, 'cmdb_id', 20)
log_cmdb_top = top_counts(df_log, 'cmdb_id', 20)
err_cmdb_top = top_counts(df_err, 'cmdb_id', 20)

# Metric-specific top KPI names
metric_kpi_top = top_counts(df_metric, 'kpi_name', 20)

# Trace-specific top trace names
trace_trace_top = top_counts(df_trace, 'trace_name', 20)

# Log-specific top log names
log_log_top = top_counts(df_log, 'log_name', 20)

# Compact final display (limited to top 20 where applicable)
metric_basic, metric_cmdb_top, metric_kpi_top, trace_basic, trace_cmdb_top, trace_trace_top, log_basic, log_cmdb_top, log_log_top, err_basic, err_cmdb_top
