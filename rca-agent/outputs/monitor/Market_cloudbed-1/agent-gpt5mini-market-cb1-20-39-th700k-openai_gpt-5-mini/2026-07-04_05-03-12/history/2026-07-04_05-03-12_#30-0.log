import pandas as pd
import pytz

# reuse existing df_trace and tz if available
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# ensure timezone-aware datetime column in df_trace
if 'dt' not in df_trace.columns:
    df_trace['dt'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# candidate cmdb_ids
candidates = [
    "adservice-1","adservice-2","frontend-1",
    "cartservice-0","cartservice-2",
    "currencyservice-0","currencyservice-1","currencyservice-2",
    "checkoutservice-1","shippingservice-1"
]

# time window (inclusive) in UTC+8
start_dt = tz.localize(pd.Timestamp('2022-03-20 17:00:00'))
end_dt   = tz.localize(pd.Timestamp('2022-03-20 17:30:00'))

# filter trace rows to candidates and time window
df_cand = df_trace[df_trace['cmdb_id'].isin(candidates)].copy()
df_window = df_cand[(df_cand['dt'] >= start_dt) & (df_cand['dt'] <= end_dt)].copy()

# total points per group
total_pts = df_window.groupby(['cmdb_id', 'trace_name'])['value'].size().rename('total_points_in_window')

# nonzero count per group
nonzero_cnt = (df_window['value'] != 0).groupby([df_window['cmdb_id'], df_window['trace_name']]).sum().rename('nonzero_count')

# max value per group
max_val = df_window.groupby(['cmdb_id', 'trace_name'])['value'].max().rename('max_value_in_window')

# earliest nonzero timestamp per group
df_nonzero = df_window[df_window['value'] != 0]
earliest_nonzero = df_nonzero.groupby(['cmdb_id', 'trace_name'])['dt'].min().rename('earliest_nonzero_dt')

# combine aggregates
agg = pd.concat([total_pts, nonzero_cnt, max_val, earliest_nonzero], axis=1).reset_index()

# format earliest_nonzero timestamp as string with timezone, keep NA when missing
agg['earliest_nonzero_timestamp'] = agg['earliest_nonzero_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
agg.loc[agg['earliest_nonzero_timestamp'].isna(), 'earliest_nonzero_timestamp'] = pd.NA

# keep only rows with nonzero_count > 0
agg_nonzero = agg[agg['nonzero_count'] > 0].copy()

# prepare sorting: convert earliest_nonzero_dt to datetime for correct ordering (NaT last)
agg_nonzero['_earliest_sort_dt'] = pd.to_datetime(agg_nonzero['earliest_nonzero_dt'])

# select requested columns and order
result = agg_nonzero[['cmdb_id', 'trace_name', 'total_points_in_window', 'nonzero_count',
                      'earliest_nonzero_timestamp', 'max_value_in_window', '_earliest_sort_dt']]

result_sorted = result.sort_values(by=['nonzero_count', '_earliest_sort_dt'], ascending=[False, True], na_position='last').head(20)

# drop helper sort column for final display
final_result = result_sorted.drop(columns=['_earliest_sort_dt']).reset_index(drop=True)

final_result
