import pandas as pd
import pytz

# reuse existing df_trace and tz if available
try:
    df_trace
except NameError:
    df_trace = pd.read_csv('trace.csv')

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# ensure timezone-aware datetime column in df_trace (UTC -> Asia/Shanghai)
if 'dt' not in df_trace.columns:
    df_trace['dt'] = pd.to_datetime(df_trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Candidates and time window (inclusive) in UTC+8
candidates = ["cartservice-2", "cartservice-0"]
start_dt = tz.localize(pd.Timestamp('2022-03-20 17:00:00'))
end_dt   = tz.localize(pd.Timestamp('2022-03-20 17:30:00'))

# 1) Compute global P95 per (cmdb_id, trace_name) using entire trace series for the candidate cmdb_ids
p95_df = (
    df_trace[df_trace['cmdb_id'].isin(candidates)]
    .groupby(['cmdb_id', 'trace_name'])['value']
    .quantile(0.95)
    .rename('p95')
    .reset_index()
)

# 2) Filter rows to the time window and merge p95 thresholds (thresholds computed BEFORE filtering)
df_window = df_trace[
    (df_trace['cmdb_id'].isin(candidates)) &
    (df_trace['dt'] >= start_dt) &
    (df_trace['dt'] <= end_dt)
].copy()

df_window = df_window.merge(p95_df, on=['cmdb_id', 'trace_name'], how='left')

# Flag anomalies where value >= global P95
df_window['is_anomaly'] = df_window['value'] >= df_window['p95']

# Aggregate per (cmdb_id, trace_name)
agg = df_window.groupby(['cmdb_id', 'trace_name']).agg(
    total_points_in_window=('value', 'size'),
    anomaly_count=('is_anomaly', 'sum'),
    earliest_anomaly_dt=('dt', lambda s: s[df_window.loc[s.index, 'is_anomaly']].min() if s.size>0 else pd.NaT),
    max_value_in_window=('value', 'max'),
    p95=('p95', 'first')
).reset_index()

# Format earliest anomaly timestamp for display
agg['earliest_anomaly_timestamp'] = agg['earliest_anomaly_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
agg.loc[agg['earliest_anomaly_timestamp'].isna(), 'earliest_anomaly_timestamp'] = pd.NA

# 3) Filter to rows with anomaly_count > 0, sort and limit to top 20
agg['_earliest_sort_dt'] = pd.to_datetime(agg['earliest_anomaly_dt'])
result_df_sorted = (
    agg[agg['anomaly_count'] > 0]
    .sort_values(by=['anomaly_count', '_earliest_sort_dt'], ascending=[False, True])
    .head(20)
)

# Select and order required columns only
result_df_sorted = result_df_sorted[
    ['cmdb_id', 'trace_name', 'total_points_in_window', 'anomaly_count',
     'earliest_anomaly_timestamp', 'max_value_in_window', 'p95']
].reset_index(drop=True)

result_df_sorted
