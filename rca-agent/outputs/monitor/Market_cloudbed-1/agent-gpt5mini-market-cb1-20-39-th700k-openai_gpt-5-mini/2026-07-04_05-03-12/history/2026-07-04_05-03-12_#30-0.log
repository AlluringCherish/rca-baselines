import pandas as pd
import pytz

# reuse existing dataframes and timezone if present
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')
try:
    df_log
except NameError:
    df_log = pd.read_csv('log.csv')
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# ensure timezone-aware datetime column in df_metric
if 'dt' not in df_metric.columns:
    df_metric['dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# ensure timezone-aware datetime column in df_log
if 'dt' not in df_log.columns:
    df_log['dt'] = pd.to_datetime(df_log['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# define window (inclusive) in UTC+8
start_dt = tz.localize(pd.Timestamp('2022-03-20 17:00:00'))
end_dt   = tz.localize(pd.Timestamp('2022-03-20 17:30:00'))

# Part 1: metric rows for adservice-1 and adservice-2 with container_memory_failures and value > 0 in the window
candidates = ["adservice-1", "adservice-2"]
mask_metric = (
    df_metric['cmdb_id'].isin(candidates) &
    df_metric['kpi_name'].str.contains("container_memory_failures", na=False) &
    (df_metric['dt'] >= start_dt) & (df_metric['dt'] <= end_dt) &
    (df_metric['value'] > 0)
)
metric_pos = df_metric.loc[mask_metric, ['timestamp', 'cmdb_id', 'kpi_name', 'value']].sort_values(by=['cmdb_id','timestamp']).head(20)

# Part 2: log summary for adservice-1 and adservice-2 where log_name == "log.error_count" in the window
mask_log = (
    df_log['cmdb_id'].isin(candidates) &
    (df_log['log_name'] == 'log.error_count') &
    (df_log['dt'] >= start_dt) & (df_log['dt'] <= end_dt)
)
df_log_window = df_log.loc[mask_log].copy()

# Aggregations per cmdb_id
total_points = df_log_window.groupby('cmdb_id')['value'].size().rename('total_points_in_window')
nonzero_count = (df_log_window['value'] != 0).groupby(df_log_window['cmdb_id']).sum().rename('nonzero_count')
max_value = df_log_window.groupby('cmdb_id')['value'].max().rename('max_value_in_window')

# earliest nonzero timestamp
df_log_nonzero = df_log_window[df_log_window['value'] != 0]
earliest_nonzero = df_log_nonzero.groupby('cmdb_id')['dt'].min().rename('earliest_nonzero_dt')

log_agg = pd.concat([total_points, nonzero_count, max_value, earliest_nonzero], axis=1).reset_index()

# format earliest_nonzero_timestamp as string with timezone; keep NA where missing
log_agg['earliest_nonzero_timestamp'] = log_agg['earliest_nonzero_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
log_agg.loc[log_agg['earliest_nonzero_timestamp'].isna(), 'earliest_nonzero_timestamp'] = pd.NA

# Select requested output columns and limit to up to 2 rows (one per cmdb_id)
log_summary = log_agg[['cmdb_id', 'total_points_in_window', 'nonzero_count', 'earliest_nonzero_timestamp', 'max_value_in_window']].sort_values(by=['cmdb_id']).head(2).reset_index(drop=True)

# Display compact results
metric_pos, log_summary
