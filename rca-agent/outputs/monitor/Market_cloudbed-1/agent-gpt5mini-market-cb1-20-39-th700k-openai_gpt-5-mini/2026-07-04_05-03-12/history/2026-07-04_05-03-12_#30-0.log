import pandas as pd
import pytz

# reuse existing df_metric and tz if present
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# ensure timezone-aware datetime column (UTC -> Asia/Shanghai)
if 'dt' not in df_metric.columns:
    df_metric['dt'] = pd.to_datetime(df_metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Candidates and KPI substring
candidates = ["cartservice-2", "cartservice-0"]
kpi_sub = "container_network_receive_MB"

# 1) Compute global P95 for each (cmdb_id, kpi_name) across the full series (only for candidate cmdb_ids & KPI substring)
mask_all = df_metric['cmdb_id'].isin(candidates) & df_metric['kpi_name'].str.contains(kpi_sub, na=False)
p95_all = df_metric[mask_all].groupby(['cmdb_id', 'kpi_name'])['value'].quantile(0.95).reset_index().rename(columns={'value':'p95'})

# Keep only pairs with p95 > 0 (skip p95 == 0)
p95_pos = p95_all[p95_all['p95'] > 0].copy()

# If no positive P95 pairs, produce empty DataFrame with required columns
output_cols = ['timestamp', 'cmdb_id', 'kpi_name', 'value', 'p95']
if p95_pos.empty:
    breaches_result = pd.DataFrame(columns=output_cols)
else:
    # 2) Filter metric rows to the window 2022-03-20 17:00:00 - 2022-03-20 17:30:00 UTC+8
