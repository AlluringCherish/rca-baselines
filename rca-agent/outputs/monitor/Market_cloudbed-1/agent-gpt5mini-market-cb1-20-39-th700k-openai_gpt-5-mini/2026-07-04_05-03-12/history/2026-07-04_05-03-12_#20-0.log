    # For lower side: (p5 - min)/|p5|
    rel_down = (agg_df['p5'] - agg_df['min_value_in_window']) / denom_p5

    # If p95 or p5 are NaN, produce 0 relative breach
    rel_up = rel_up.fillna(0)
    rel_down = rel_down.fillna(0)

    agg_df['relative_breach'] = np.maximum(rel_up, rel_down)

    # Keep requested columns and sort by relative_breach desc, limit to top 20
    result_top20 = agg_df[[
        'cmdb_id','kpi_name','count_in_window','mean_in_window','max_value_in_window','min_value_in_window',
