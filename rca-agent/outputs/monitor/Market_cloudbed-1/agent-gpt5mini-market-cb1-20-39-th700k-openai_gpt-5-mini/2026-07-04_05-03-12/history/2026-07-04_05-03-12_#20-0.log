    agg_df['negative_breach_count'] = agg_df['negative_breach_count'].astype(int)
    agg_df['count_in_window'] = agg_df['count_in_window'].astype(int)

    # (4) Compute relative_breach as specified
    # Avoid division by zero by using denom = max(abs(p95), 1e-9)
    denom_p95 = agg_df['p95'].abs().replace(0, 1e-9)
    denom_p5  = agg_df['p5'].abs().replace(0, 1e-9)

