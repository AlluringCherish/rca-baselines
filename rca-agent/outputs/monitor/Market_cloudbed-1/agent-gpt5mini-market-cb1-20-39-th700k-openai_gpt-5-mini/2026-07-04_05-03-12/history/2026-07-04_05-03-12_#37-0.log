import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# reuse df_metric if available, else load
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv')

# Ensure correct dtypes
df_metric['timestamp'] = pd.to_numeric(df_metric['timestamp'], errors='coerce').astype('Int64')
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')

# 1) Compute global P95 and P5, and global min/max per (cmdb_id, kpi_name) using the entire series
quantiles = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .quantile([0.95, 0.05])
    .unstack(level=-1)
    .rename(columns={0.95: 'global_P95', 0.05: 'global_P5'})
    .reset_index()
)

minmax = (
    df_metric
    .groupby(['cmdb_id', 'kpi_name'])['value']
    .agg(global_min='min', global_max='max')
    .reset_index()
)

group_stats = quantiles.merge(minmax, on=['cmdb_id', 'kpi_name'], how='inner')

# Drop groups with NaN thresholds (if any)
group_stats = group_stats.dropna(subset=['global_P95', 'global_P5', 'global_min', 'global_max'])

# Identify and exclude constant groups: where global_P95 == global_P5 OR global_min == global_max
non_constant_groups = group_stats[
    (group_stats['global_P95'] != group_stats['global_P5']) &
    (group_stats['global_min'] != group_stats['global_max'])
].copy()

# If no non-constant groups, return empty DataFrame with desired columns
cols_out = ['cmdb_id', 'kpi_name', 'total_points_in_window', 'anomaly_count_high',
            'anomaly_count_low', 'earliest_anomaly_ts', 'max_value_in_window',
            'min_value_in_window', 'global_P95', 'global_P5']

if non_constant_groups.empty:
    result = pd.DataFrame(columns=cols_out)
    result
else:
    # 2) Filter metric.csv to incident window: 2022-03-21 02:00:00 to 02:30:00 (UTC+8)
    start_local = pd.Timestamp('2022-03-21 02:00:00', tz=tz)
    end_local = pd.Timestamp('2022-03-21 02:30:00', tz=tz)
    start_epoch = int(start_local.tz_convert('UTC').timestamp())
    end_epoch = int(end_local.tz_convert('UTC').timestamp())

    df_window = df_metric[
        (df_metric['timestamp'] >= start_epoch) & (df_metric['timestamp'] <= end_epoch)
    ].copy()

    # 3) Keep only non-constant groups in the window
    df_window = df_window.merge(
        non_constant_groups[['cmdb_id', 'kpi_name', 'global_P95', 'global_P5']],
        on=['cmdb_id', 'kpi_name'],
        how='inner'
    )

    if df_window.empty:
        result = pd.DataFrame(columns=cols_out)
        result
    else:
        # Flags for anomalies based on precomputed global thresholds
        df_window['anom_high'] = df_window['value'] >= df_window['global_P95']
        df_window['anom_low'] = df_window['value'] <= df_window['global_P5']
        df_window['is_anom'] = df_window['anom_high'] | df_window['anom_low']

        # Aggregations per group within window
        agg = df_window.groupby(['cmdb_id', 'kpi_name']).agg(
            total_points_in_window=('value', 'size'),
            anomaly_count_high=('anom_high', 'sum'),
            anomaly_count_low=('anom_low', 'sum'),
            max_value_in_window=('value', 'max'),
            min_value_in_window=('value', 'min'),
            # earliest anomaly epoch: min timestamp where is_anom True, else NA
            earliest_anom_epoch=('timestamp', lambda s: int(s[s.index][s[s.index].map(df_window['is_anom'])].min()) if any(df_window.loc[s.index, 'is_anom']) else pd.NA),
        ).reset_index()

        # Note: the lambda above is a bit convoluted due to index mapping; simplify robustly:
        # Build earliest_anom by explicit group operation to avoid index confusion
        def compute_earliest_anom(gr):
            anom_rows = gr[gr['is_anom']]
            if anom_rows.empty:
                return pd.NA
            return int(anom_rows['timestamp'].min())

        earliest = df_window.groupby(['cmdb_id', 'kpi_name']).apply(compute_earliest_anom).reset_index()
        earliest.columns = ['cmdb_id', 'kpi_name', 'earliest_anom_epoch']
        agg = agg.drop(columns=['earliest_anom_epoch'], errors='ignore').merge(earliest, on=['cmdb_id', 'kpi_name'], how='left')

        # Attach global thresholds from non_constant_groups
        agg = agg.merge(
            non_constant_groups[['cmdb_id', 'kpi_name', 'global_P95', 'global_P5']],
            on=['cmdb_id', 'kpi_name'],
            how='left'
        )

        # Convert earliest epoch to localized string
        def epoch_to_local_str(x):
            if pd.isna(x):
                return pd.NA
            return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

        agg['earliest_anomaly_ts'] = agg['earliest_anom_epoch'].apply(epoch_to_local_str)

        # Compute anomaly total for ranking
        agg['anomaly_total'] = agg['anomaly_count_high'] + agg['anomaly_count_low']

        # 4) Rank and select top 20
        result = (
            agg
            .sort_values(by=['anomaly_total', 'earliest_anom_epoch'], ascending=[False, True])
            .loc[:, ['cmdb_id', 'kpi_name', 'total_points_in_window',
                     'anomaly_count_high', 'anomaly_count_low', 'earliest_anomaly_ts',
                     'max_value_in_window', 'min_value_in_window', 'global_P95', 'global_P5']]
            .head(20)
            .reset_index(drop=True)
        )

