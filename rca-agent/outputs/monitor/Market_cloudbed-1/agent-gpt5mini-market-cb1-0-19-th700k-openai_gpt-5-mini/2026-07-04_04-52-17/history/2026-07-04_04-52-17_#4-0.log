import pandas as pd
import numpy as np
import pytz

# Reuse variables from kernel:
# metric_cats_full_df, thresholds_df, per_series_results_df, window_with_thresh should exist from prior steps.

tz = pytz.timezone('Asia/Shanghai')
incident_start = tz.localize(pd.Timestamp('2022-03-20 11:00:00'))
incident_end   = tz.localize(pd.Timestamp('2022-03-20 11:30:00'))

target_cmdb = 'shippingservice-1'

# 1) Identify series for shippingservice-1 with anomaly_count >= 1 (from per_series_results_df)
shipping_series_df = per_series_results_df[per_series_results_df['cmdb_id'] == target_cmdb].copy()
shipping_anom_series_df = shipping_series_df[shipping_series_df['anomaly_count'] > 0].copy()
shipping_kpi_names = shipping_anom_series_df['kpi_name'].sort_values().unique()

# Keep list of kpi_name values considered
shipping_kpi_list = pd.Series(shipping_kpi_names, name='kpi_name')

# Prepare windowed rows (we already computed window_with_thresh earlier)
# Ensure window_with_thresh has dt column; if not, create it from timestamp
if 'dt' not in window_with_thresh.columns:
    window_with_thresh['dt'] = pd.to_datetime(window_with_thresh['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Filter window rows for the target cmdb and the KPIs of interest
shipping_window_rows = window_with_thresh[(window_with_thresh['cmdb_id'] == target_cmdb) & 
                                          (window_with_thresh['kpi_name'].isin(shipping_kpi_names))].copy()

# Function to compute fault-segmentation metrics for one series (df within window, with is_anomaly boolean and dt sorted)
def compute_fault_segments(df_window_series, threshold_type, global_threshold):
    # df_window_series expected sorted by dt
    # total anomaly points:
    total_anomaly_points = int(df_window_series['is_anomaly'].sum())
    # select anomaly rows
    anoms = df_window_series[df_window_series['is_anomaly']].sort_values('dt')
    if anoms.empty:
        return {
            'total_anomaly_points': 0,
            'num_fault_segments': 0,
            'longest_segment_length_minutes': 0,
            'earliest_timestamp_of_longest_segment': pd.NaT,
            'max_value_within_longest_segment': np.nan
        }
    # compute consecutive runs where diff == 1 minute
    diffs = anoms['dt'].diff()
    new_group = (diffs != pd.Timedelta(minutes=1))
    seg_id = new_group.cumsum()
    segs = anoms.assign(seg_id=seg_id.values)
    seg_stats = segs.groupby('seg_id').agg(
        seg_len=('dt','count'),
        seg_start=('dt','min'),
        seg_maxval=('value','max')
    ).reset_index()
    # number of fault segments
    num_fault_segments = int(seg_stats.shape[0])
    # longest segment
    longest_idx = seg_stats['seg_len'].idxmax()
    longest = seg_stats.loc[longest_idx]
    longest_len = int(longest['seg_len'])
    earliest_of_longest = longest['seg_start']
    max_val_longest = float(longest['seg_maxval'])
    return {
        'total_anomaly_points': total_anomaly_points,
        'num_fault_segments': num_fault_segments,
        'longest_segment_length_minutes': longest_len,
        'earliest_timestamp_of_longest_segment': earliest_of_longest,
        'max_value_within_longest_segment': max_val_longest
    }

# Iterate over each KPI and compute requested metrics
rows = []
# Ensure shipping_window_rows sorted by dt for grouping
shipping_window_rows = shipping_window_rows.sort_values(['kpi_name','dt']).copy()

for kpi in shipping_kpi_names:
    dfk = shipping_window_rows[shipping_window_rows['kpi_name'] == kpi].copy().sort_values('dt')
    # Get threshold info from shipping_anom_series_df
    meta = shipping_anom_series_df[shipping_anom_series_df['kpi_name'] == kpi].iloc[0]
    threshold_type = meta['threshold_type']
    global_threshold = meta['global_threshold']
    # compute fault segments and stats
    seg_stats = compute_fault_segments(dfk, threshold_type, global_threshold)
    rows.append({
        'cmdb_id': target_cmdb,
        'kpi_name': kpi,
        'total_anomaly_points': seg_stats['total_anomaly_points'],
        'num_fault_segments': seg_stats['num_fault_segments'],
        'longest_segment_length_minutes': seg_stats['longest_segment_length_minutes'],
        'earliest_timestamp_of_longest_segment': seg_stats['earliest_timestamp_of_longest_segment'],
        'max_value_within_longest_segment': seg_stats['max_value_within_longest_segment'],
        'global_threshold_type': threshold_type,
        'global_threshold_value': global_threshold,
        'severity': float(meta.get('severity', np.nan)),
        'points_in_window': int(meta.get('points_in_window', 0))
    })

shipping_fault_summary_df = pd.DataFrame(rows).sort_values(by=['severity'], ascending=False).reset_index(drop=True)

# 2) Top 3 shippingservice-1 kpi_names by severity from that list
top3 = shipping_fault_summary_df.sort_values('severity', ascending=False).head(3)
top3_kpis = top3['kpi_name'].tolist()

# For each top3 KPI, extract raw metric rows within the incident window (timestamp, cmdb_id, kpi_name, value),
# ordered by timestamp ascending, limited to 50 rows.
top3_raw_rows = {}
for kpi in top3_kpis:
    raw_rows = shipping_window_rows[shipping_window_rows['kpi_name'] == kpi].sort_values('dt').copy()
    # keep columns timestamp (original seconds), cmdb_id, kpi_name, value
    # ensure timestamp column exists; it does in window_with_thresh
    excerpt = raw_rows.loc[:, ['timestamp','cmdb_id','kpi_name','value']].head(50).reset_index(drop=True)
    top3_raw_rows[kpi] = excerpt

# Store full intermediate results in kernel variables for follow-up
shipping_fault_summary_df_full = shipping_fault_summary_df.copy()
shipping_window_rows_full = shipping_window_rows.copy()
shipping_anom_series_df_full = shipping_anom_series_df.copy()

# Compact outputs:
# - shipping_fault_summary_df (one row per KPI for shippingservice-1)
# - shipping_kpi_list (series of kpi_names considered)
# - top3_raw_rows (dict of small DataFrames, up to 50 rows each)

shipping_fault_summary_df, shipping_kpi_list, top3_raw_rows
