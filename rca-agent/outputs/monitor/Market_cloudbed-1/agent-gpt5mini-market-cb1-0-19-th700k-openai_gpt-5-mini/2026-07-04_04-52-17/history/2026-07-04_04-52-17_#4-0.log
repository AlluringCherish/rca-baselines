import pandas as pd
import numpy as np
import pytz

# Reuse metric_df from kernel
# Define categories to scan (non-zero matches from earlier step)
categories = ['cpu','memory','heap','jvm','network','packet','io','read','write','disk','fs']

# Build mask for kpi_name containing any of the category keywords (case-insensitive)
cat_pattern = "(" + ")|(".join(categories) + ")"
mask_cat = metric_df['kpi_name'].str.contains(cat_pattern, case=False, na=False, regex=True)

# Filtered full series for those categories (store for later)
metric_cats_full_df = metric_df[mask_cat].copy()

# Ensure timestamp is converted once to Asia/Shanghai tz-aware datetime for consistent filtering/outputs
tz = pytz.timezone('Asia/Shanghai')
metric_cats_full_df['dt'] = pd.to_datetime(metric_cats_full_df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Compute global thresholds (P95 and P5) per (cmdb_id, kpi_name) using the entire available series (rule 9)
grp = metric_cats_full_df.groupby(['cmdb_id', 'kpi_name'])['value']
thresholds_df = grp.agg(p95=lambda s: s.quantile(0.95), p5=lambda s: s.quantile(0.05)).reset_index()

# Detect traffic-like KPIs (case-insensitive substring match)
traffic_terms = ['req','qps','throughput','success','ss','rate','count']
traffic_pattern = "(" + ")|(".join(traffic_terms) + ")"
thresholds_df['is_traffic_like'] = thresholds_df['kpi_name'].str.contains(traffic_pattern, case=False, na=False, regex=True)

# Decide which global threshold to use per series
thresholds_df['threshold_type'] = np.where(thresholds_df['is_traffic_like'], 'P5', 'P95')
thresholds_df['global_threshold'] = np.where(thresholds_df['is_traffic_like'], thresholds_df['p5'], thresholds_df['p95'])

# Incident window in Asia/Shanghai (inclusive)
start_window = tz.localize(pd.Timestamp('2022-03-20 11:00:00'))
end_window   = tz.localize(pd.Timestamp('2022-03-20 11:30:00'))

# Filter original metric_df to incident window (but only for the selected category series)
# Convert timestamp to dt if not already in metric_df
# We'll reuse metric_cats_full_df which already has 'dt'
window_df = metric_cats_full_df[(metric_cats_full_df['dt'] >= start_window) & (metric_cats_full_df['dt'] <= end_window)].copy()

# Merge the global thresholds into the windowed rows so we can compute per-row anomaly flags
window_with_thresh = window_df.merge(thresholds_df[['cmdb_id','kpi_name','threshold_type','global_threshold']],
                                     on=['cmdb_id','kpi_name'], how='left')

# Define anomaly condition per row
# For P95-used series: anomaly if value > global_threshold
# For P5-used (traffic-like): anomaly if value < global_threshold
def compute_anomaly_flag(row):
    thr = row['global_threshold']
    if pd.isna(thr):
        return False
    if row['threshold_type'] == 'P95':
        return row['value'] > thr
    else:
        return row['value'] < thr

window_with_thresh['is_anomaly'] = window_with_thresh.apply(compute_anomaly_flag, axis=1)

# Aggregate within window per series
agg_window = window_with_thresh.groupby(['cmdb_id','kpi_name','threshold_type','global_threshold']).agg(
    anomaly_count=('is_anomaly', 'sum'),
    earliest_anom_dt=('dt', lambda s: s[s.index.isin(window_with_thresh[window_with_thresh['is_anomaly']].index)].min() if s.size>0 else pd.NaT),
    max_value_in_window=('value','max'),
    min_value_in_window=('value','min'),
    points_in_window=('value','count')
).reset_index()

# The above earliest_anom_dt lambda is a bit complex; simpler compute earliest per-group using where:
# Recompute earliest properly to avoid issues
anom_rows = window_with_thresh[window_with_thresh['is_anomaly']].copy()
earliest = anom_rows.groupby(['cmdb_id','kpi_name'])['dt'].min().reset_index().rename(columns={'dt':'earliest_anom_dt'})
# Merge earliest into agg_window
agg_window = agg_window.drop(columns=['earliest_anom_dt']).merge(earliest, on=['cmdb_id','kpi_name'], how='left')

# Now ensure we include series that had no points in the window: left-join thresholds_df with agg_window
per_series_results_df = thresholds_df.merge(
    agg_window,
    on=['cmdb_id','kpi_name','threshold_type','global_threshold'],
    how='left'
)

# Fill missing numeric aggregates for series with no data in window
per_series_results_df['anomaly_count'] = per_series_results_df['anomaly_count'].fillna(0).astype(int)
per_series_results_df['points_in_window'] = per_series_results_df['points_in_window'].fillna(0).astype(int)
per_series_results_df['max_value_in_window'] = per_series_results_df['max_value_in_window']
per_series_results_df['min_value_in_window'] = per_series_results_df['min_value_in_window']

# earliest_anom_dt may be NaT where no anomaly; keep as-is (NaT)
# Compute severity:
# For P95-used: severity = (max_value_in_window - threshold)/threshold  (only meaningful if anomaly_count>0)
# For P5-used: severity = (threshold - min_value_in_window)/threshold  (only meaningful if anomaly_count>0)
def compute_severity(row):
    thr = row['global_threshold']
    if pd.isna(thr) or thr == 0:
        return np.nan
    if row['threshold_type'] == 'P95':
        extremal = row['max_value_in_window']
        if pd.isna(extremal):
            return np.nan
        return (extremal - thr) / thr
    else:
        extremal = row['min_value_in_window']
        if pd.isna(extremal):
            return np.nan
        return (thr - extremal) / thr

per_series_results_df['severity'] = per_series_results_df.apply(compute_severity, axis=1)

# For display, format earliest_anom_dt as string in Asia/Shanghai, keep NaT as NaN
per_series_results_df['earliest_anom_ts'] = per_series_results_df['earliest_anom_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
# If NaT, result will be NaN; replace 'None' string with NaN
per_series_results_df['earliest_anom_ts'] = per_series_results_df['earliest_anom_ts'].replace({None: np.nan})

# Compact result table: select requested columns and sort by severity desc
compact_cols = ['cmdb_id','kpi_name','anomaly_count','earliest_anom_ts','max_value_in_window','min_value_in_window','global_threshold','threshold_type','severity']
compact_results_df = per_series_results_df[compact_cols].copy()
compact_results_df = compact_results_df.sort_values(by='severity', ascending=False)

# Top 20 candidates
top20_compact = compact_results_df.head(20).reset_index(drop=True)

# Counts
total_series_scanned = per_series_results_df.shape[0]
series_with_anomaly = (per_series_results_df['anomaly_count'] > 0).sum()

# Keep full per-series results in kernel variable per_series_results_df (already set)
# Also keep window_with_thresh and window_df for follow-up
per_series_results_df, top20_compact, total_series_scanned, series_with_anomaly
