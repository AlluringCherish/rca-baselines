import pandas as pd
import pytz

# Load CSV files into DataFrames (keep variables in kernel)
metric_df = pd.read_csv('metric.csv')
trace_df = pd.read_csv('trace.csv')
log_df = pd.read_csv('log.csv')
error_logs_df = pd.read_csv('error_logs.csv')

# UTC+8 timezone
tz = pytz.timezone('Asia/Shanghai')

# Helper to convert timestamp column (seconds) to tz-aware datetimes in Asia/Shanghai
def to_shanghai_dt(ser):
    return pd.to_datetime(ser, unit='s', utc=True).dt.tz_convert(tz)

# Summaries for metric.csv
metric_ts = to_shanghai_dt(metric_df['timestamp']) if 'timestamp' in metric_df.columns else pd.Series(dtype='datetime64[ns]')
metric_unique_cmdb = metric_df['cmdb_id'].unique() if 'cmdb_id' in metric_df.columns else []
metric_unique_kpi = metric_df['kpi_name'].unique() if 'kpi_name' in metric_df.columns else []
metric_summary = pd.DataFrame([{
    'file': 'metric.csv',
    'total_rows': metric_df.shape[0],
    'unique_cmdb_count': len(metric_unique_cmdb),
    'cmdb_sample_top20': list(metric_unique_cmdb[:20]),
    'unique_kpi_count': len(metric_unique_kpi),
    'kpi_sample_top20': list(metric_unique_kpi[:20]),
    'min_timestamp_shanghai': metric_ts.min(),
    'max_timestamp_shanghai': metric_ts.max()
}])

# Summaries for trace.csv
trace_ts = to_shanghai_dt(trace_df['timestamp']) if 'timestamp' in trace_df.columns else pd.Series(dtype='datetime64[ns]')
trace_unique_cmdb = trace_df['cmdb_id'].unique() if 'cmdb_id' in trace_df.columns else []
trace_unique_trace = trace_df['trace_name'].unique() if 'trace_name' in trace_df.columns else []
trace_summary = pd.DataFrame([{
    'file': 'trace.csv',
    'total_rows': trace_df.shape[0],
    'unique_cmdb_count': len(trace_unique_cmdb),
    'cmdb_sample_top20': list(trace_unique_cmdb[:20]),
    'unique_trace_count': len(trace_unique_trace),
    'trace_sample_top20': list(trace_unique_trace[:20]),
    'min_timestamp_shanghai': trace_ts.min(),
    'max_timestamp_shanghai': trace_ts.max()
}])

# Summaries for log.csv
log_ts = to_shanghai_dt(log_df['timestamp']) if 'timestamp' in log_df.columns else pd.Series(dtype='datetime64[ns]')
log_unique_cmdb = log_df['cmdb_id'].unique() if 'cmdb_id' in log_df.columns else []
log_unique_logname = log_df['log_name'].unique() if 'log_name' in log_df.columns else []
log_summary = pd.DataFrame([{
    'file': 'log.csv',
    'total_rows': log_df.shape[0],
    'unique_cmdb_count': len(log_unique_cmdb),
    'cmdb_sample_top20': list(log_unique_cmdb[:20]),
    'unique_logname_count': len(log_unique_logname),
    'logname_sample_top20': list(log_unique_logname[:20]),
    'min_timestamp_shanghai': log_ts.min(),
    'max_timestamp_shanghai': log_ts.max()
}])

# Summaries for error_logs.csv and up to 10 sample rows (timestamp converted)
error_ts = to_shanghai_dt(error_logs_df['timestamp']) if 'timestamp' in error_logs_df.columns else pd.Series(dtype='datetime64[ns]')
error_unique_cmdb = error_logs_df['cmdb_id'].unique() if 'cmdb_id' in error_logs_df.columns else []
error_logs_summary = pd.DataFrame([{
    'file': 'error_logs.csv',
    'total_rows': error_logs_df.shape[0],
    'unique_cmdb_count': len(error_unique_cmdb),
    'cmdb_sample_top20': list(error_unique_cmdb[:20]),
    'min_timestamp_shanghai': error_ts.min(),
    'max_timestamp_shanghai': error_ts.max()
}])

# Prepare up to 10 sample rows with converted timestamp column
if 'timestamp' in error_logs_df.columns:
    error_logs_sample = error_logs_df.copy().loc[:, ['timestamp', 'cmdb_id', 'message']].head(10)
    error_logs_sample['timestamp'] = to_shanghai_dt(error_logs_sample['timestamp'])
else:
    error_logs_sample = pd.DataFrame(columns=['timestamp', 'cmdb_id', 'message'])

# Display compact summaries (use variable names as output)
metric_summary, trace_summary, log_summary, error_logs_summary, error_logs_sample
