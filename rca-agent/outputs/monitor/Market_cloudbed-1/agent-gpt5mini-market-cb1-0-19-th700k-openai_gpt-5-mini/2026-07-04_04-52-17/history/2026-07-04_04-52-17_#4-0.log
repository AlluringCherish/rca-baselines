import pandas as pd
import numpy as np
import pytz

# Reuse metric_df from kernel
tz = pytz.timezone('Asia/Shanghai')

# --------------- Selection criteria ---------------
cmdb_targets = ['shippingservice-1', 'node-6']
substrs = [
    'memory_fail','fs_reads','fs_writes','fs_reads_MB','cpu','network_receive',
    'system.io','disk','await','w_await','svctm','io','memory'
]
# build regex pattern for kpi_name matching (case-insensitive)
pattern = "(" + ")|(".join(substrs) + ")"

# Traffic-like terms -> use P5
traffic_terms = ['req','qps','throughput','success','ss','rate','count']
traffic_pattern = "(" + ")|(".join(traffic_terms) + ")"

# 1) Compute global thresholds (using full available series) for selected series
# First filter full metric_df to only the target cmdbs and kpi_name matching substrings (full time series)
selected_full = metric_df[
    metric_df['cmdb_id'].isin(cmdb_targets) &
    metric_df['kpi_name'].str.contains(pattern, case=False, na=False, regex=True)
].copy()

# Ensure numeric values
selected_full['value'] = pd.to_numeric(selected_full['value'], errors='coerce')

# Compute p95 and p5 per series (cmdb_id, kpi_name) using entire series (rule 9)
thr = selected_full.groupby(['cmdb_id','kpi_name'], as_index=False)['value'].agg(
    p95=lambda s: s.quantile(0.95),
    p5 =lambda s: s.quantile(0.05)
)

# detect traffic-like KPIs
thr['is_traffic_like'] = thr['kpi_name'].str.contains(traffic_pattern, case=False, na=False, regex=True)
thr['threshold_type'] = np.where(thr['is_traffic_like'], 'P5', 'P95')
thr['global_threshold'] = np.where(thr['is_traffic_like'], thr['p5'], thr['p95'])

# store thresholds in kernel variable
shipping_node_thresholds_df = thr.copy()

# 2) Filter to incident window (Asia/Shanghai inclusive)
start_win = tz.localize(pd.Timestamp('2022-03-20 11:00:00'))
end_win   = tz.localize(pd.Timestamp('2022-03-20 11:30:00'))

# convert timestamps to tz-aware datetimes for selected_full (if not already)
selected_full['dt'] = pd.to_datetime(selected_full['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
window_rows = selected_full[(selected_full['dt'] >= start_win) & (selected_full['dt'] <= end_win)].copy()

# 3) Merge thresholds into window rows and compute anomaly flags
window_with_thr = window_rows.merge(
    thr[['cmdb_id','kpi_name','threshold_type','global_threshold','p95','p5']],
    on=['cmdb_id','kpi_name'],
    how='left'
)

# anomaly condition per row
def is_anom_row(r):
    thrv = r['global_threshold']
    if pd.isna(thrv):
        return False
    if r['threshold_type'] == 'P95':
        return r['value'] > thrv
    else:
        return r['value'] < thrv

window_with_thr['is_anomaly'] = window_with_thr.apply(is_anom_row, axis=1)

# Aggregate within window per series
agg_win = window_with_thr.groupby(['cmdb_id','kpi_name','threshold_type','global_threshold'], as_index=False).agg(
    anomaly_count=('is_anomaly','sum'),
    earliest_anom_dt=('dt', lambda s: s[window_with_thr.loc[s.index,'is_anomaly']].min() if len(s)>0 else pd.NaT),
    max_value_in_window=('value','max'),
    min_value_in_window=('value','min'),
    points_in_window=('value','count')
)

#  Include series that had no rows in the window: left-join thresholds (full series) with agg_win
per_series = thr.merge(
    agg_win,
    on=['cmdb_id','kpi_name','threshold_type','global_threshold'],
    how='left'
)

# Fill missing aggregates for series with no data in window
per_series['anomaly_count'] = per_series['anomaly_count'].fillna(0).astype(int)
per_series['points_in_window'] = per_series['points_in_window'].fillna(0).astype(int)
# max/min may be NaN for no-data series; keep as NaN

# compute severity
def compute_sev(r):
    thrv = r['global_threshold']
    if pd.isna(thrv) or thrv == 0:
        return np.nan
    if r['threshold_type'] == 'P95':
        mv = r['max_value_in_window']
        if pd.isna(mv):
            return np.nan
        return (mv - thrv) / thrv
    else:
        mn = r['min_value_in_window']
        if pd.isna(mn):
            return np.nan
        return (thrv - mn) / thrv

per_series['severity'] = per_series.apply(compute_sev, axis=1)

# format earliest timestamp string
per_series['earliest_anomaly_timestamp'] = per_series['earliest_anom_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')

# 4) Prepare compact top-20 table sorted by severity desc
compact_cols = [
    'cmdb_id','kpi_name','anomaly_count','earliest_anomaly_timestamp',
    'max_value_in_window','min_value_in_window','global_threshold','threshold_type','severity'
]
compact_results = per_series[compact_cols].sort_values(by='severity', ascending=False).reset_index(drop=True)
top20_compact = compact_results.head(20)

# Summary numbers
total_series_scanned = per_series.shape[0]
series_with_anomaly = int((per_series['anomaly_count'] > 0).sum())

# Top 2 shippingservice-1 kpi_names by severity for raw-row excerpts
top2_ship = per_series[per_series['cmdb_id']=='shippingservice-1'].sort_values('severity', ascending=False).head(2)
top2_kpis = top2_ship['kpi_name'].tolist()

# Extract raw metric rows within window for these top2 kpis (limit 50 rows each, ordered by timestamp asc)
top2_raw = {}
for kpi in top2_kpis:
    dfraw = window_with_thr[(window_with_thr['cmdb_id']=='shippingservice-1') & (window_with_thr['kpi_name']==kpi)].sort_values('dt')
    excerpt = dfraw.loc[:, ['timestamp','cmdb_id','kpi_name','value']].head(50).reset_index(drop=True)
    top2_raw[kpi] = excerpt

# Store intermediate results in kernel variables for follow-up
selected_full_df = selected_full.copy()
window_with_thr_full = window_with_thr.copy()
per_series_selected_full = per_series.copy()

# Final compact outputs (variables to display)
top20_compact, total_series_scanned, series_with_anomaly, top2_raw
