import pandas as pd
import pytz
import numpy as np

# reuse existing DataFrames from kernel: log_df, trace_df, metric_df
tz = pytz.timezone('Asia/Shanghai')
start_win = tz.localize(pd.Timestamp('2022-03-20 11:15:00'))
end_win   = tz.localize(pd.Timestamp('2022-03-20 11:25:00'))

# Helper to add tz-aware datetime column 'dt' (Asia/Shanghai) to a DataFrame with 'timestamp' (seconds)
def ensure_dt(df):
    if 'dt' not in df.columns:
        df['dt'] = pd.to_datetime(df['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    return df

# ----------------------------
# 1) Logs: shippingservice-1 or node-6 in 11:15-11:25
# ----------------------------
log_df = ensure_dt(log_df.copy())
log_targets = ['shippingservice-1', 'node-6']
filtered_log_rows = log_df[
    log_df['cmdb_id'].isin(log_targets) &
    (log_df['dt'] >= start_win) & (log_df['dt'] <= end_win)
].copy()

# ensure numeric value column
filtered_log_rows['value'] = pd.to_numeric(filtered_log_rows['value'], errors='coerce')

total_log_rows = int(filtered_log_rows.shape[0])
error_count_positive = int(((filtered_log_rows['log_name']=='log.error_count') & (filtered_log_rows['value']>0)).sum())

# sample rows up to 50, ordered by dt ascending, with requested columns
log_samples_df = (
    filtered_log_rows.sort_values('dt')
    .loc[:, ['dt','cmdb_id','log_name','value']]
    .head(50)
    .copy()
)
log_samples_df['timestamp'] = log_samples_df['dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
log_samples_df = log_samples_df.loc[:, ['timestamp','cmdb_id','log_name','value']]

# compact summary DataFrame for logs
log_summary_df = pd.DataFrame([{
    'total_rows_found': total_log_rows,
    'log.error_count_>0_rows': error_count_positive,
    'sample_rows_returned': int(log_samples_df.shape[0])
}])

# ----------------------------
# 2) Traces: shippingservice-1 in 11:15-11:25
# ----------------------------
trace_df = ensure_dt(trace_df.copy())
filtered_trace_rows = trace_df[
    (trace_df['cmdb_id']=='shippingservice-1') &
    (trace_df['dt'] >= start_win) & (trace_df['dt'] <= end_win)
].copy()

filtered_trace_rows['value'] = pd.to_numeric(filtered_trace_rows['value'], errors='coerce')
trace_count = int(filtered_trace_rows.shape[0])
trace_unique_names = sorted(filtered_trace_rows['trace_name'].dropna().unique())[:20]

trace_samples_df = (
    filtered_trace_rows.sort_values('dt')
    .loc[:, ['dt','cmdb_id','trace_name','value']]
    .head(50)
    .copy()
)
trace_samples_df['timestamp'] = trace_samples_df['dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
trace_samples_df = trace_samples_df.loc[:, ['timestamp','cmdb_id','trace_name','value']]

trace_info_df = pd.DataFrame([{
    'rows_in_window': trace_count,
    'unique_trace_name_count': int(len(filtered_trace_rows['trace_name'].dropna().unique())),
    'trace_name_examples_up_to_20': trace_unique_names,
    'sample_rows_returned': int(trace_samples_df.shape[0])
}])

# ----------------------------
# 3) Metrics: shippingservice-1 OR node-6, kpi_name substrings, 11:15-11:25
# ----------------------------
metric_df = ensure_dt(metric_df.copy())
metric_df['value'] = pd.to_numeric(metric_df['value'], errors='coerce')

substrs = [
    'container_memory_fail','container_fs_reads','container_fs_reads_MB','fs_reads','fs_writes',
    'system.io','cpu','iowait','await','w_await','svctm','io','memory'
]
pattern = "(" + ")|(".join(substrs) + ")"

metric_targets = ['shippingservice-1', 'node-6']
filtered_metric_rows = metric_df[
    metric_df['cmdb_id'].isin(metric_targets) &
    metric_df['kpi_name'].str.contains(pattern, case=False, na=False, regex=True) &
    (metric_df['dt'] >= start_win) & (metric_df['dt'] <= end_win)
].copy()

# distinct pairs and total rows
distinct_pairs_count = int(filtered_metric_rows[['cmdb_id','kpi_name']].drop_duplicates().shape[0])
total_metric_rows = int(filtered_metric_rows.shape[0])

# sample up to 50 per cmdb_id then overall up to 100 rows, ordered by dt asc
samples_per_cmdb = []
for cmdb in sorted(filtered_metric_rows['cmdb_id'].unique()):
    grp = filtered_metric_rows[filtered_metric_rows['cmdb_id']==cmdb].sort_values('dt').head(50)
    samples_per_cmdb.append(grp)
if samples_per_cmdb:
    metric_samples_df = pd.concat(samples_per_cmdb, ignore_index=True).sort_values('dt').head(100).copy()
else:
    metric_samples_df = filtered_metric_rows.head(0).copy()

metric_samples_df['timestamp'] = metric_samples_df['dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')
metric_samples_df = metric_samples_df.loc[:, ['timestamp','cmdb_id','kpi_name','value']]

metric_info_df = pd.DataFrame([{
    'distinct_cmdb_kpi_pairs': distinct_pairs_count,
    'total_rows': total_metric_rows,
    'sample_rows_returned': int(metric_samples_df.shape[0])
}])

# Store full intermediate results in kernel variables for follow-up
logs_window_full = filtered_log_rows.copy()
traces_window_full = filtered_trace_rows.copy()
metrics_window_full = filtered_metric_rows.copy()

# Final compact outputs (variables to display)
log_summary_df, log_samples_df, trace_info_df, trace_samples_df, metric_info_df, metric_samples_df
