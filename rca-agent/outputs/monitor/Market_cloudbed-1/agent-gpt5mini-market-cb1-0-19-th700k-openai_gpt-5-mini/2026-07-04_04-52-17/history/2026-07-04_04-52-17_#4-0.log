import pandas as pd
import numpy as np
import pytz

# Reuse trace_df from kernel
tz = pytz.timezone('Asia/Shanghai')

# 1) Compute global P95 per (cmdb_id, trace_name) using the full series
trace_full = trace_df.copy()
trace_full['value'] = pd.to_numeric(trace_full['value'], errors='coerce')
p95_df = trace_full.groupby(['cmdb_id','trace_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value':'global_p95'})

# 2) Filter trace_df to the incident window (inclusive) and ensure timezone-aware datetimes
trace_full['dt'] = pd.to_datetime(trace_full['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
start_window = tz.localize(pd.Timestamp('2022-03-20 11:00:00'))
end_window   = tz.localize(pd.Timestamp('2022-03-20 11:30:00'))
trace_window = trace_full[(trace_full['dt'] >= start_window) & (trace_full['dt'] <= end_window)].copy()

# 3) Merge global P95 into windowed rows and compute per-series aggregates
trace_win_with_p95 = trace_window.merge(p95_df, on=['cmdb_id','trace_name'], how='left')

# Anomaly condition: value > global_p95
trace_win_with_p95['is_anomaly'] = trace_win_with_p95['value'] > trace_win_with_p95['global_p95']

# Aggregate within window per series
agg = trace_win_with_p95.groupby(['cmdb_id','trace_name','global_p95'], as_index=False).agg(
    anomaly_count=('is_anomaly','sum'),
    earliest_anomaly_dt=('dt', lambda s: s[trace_win_with_p95.loc[s.index,'is_anomaly']].min() if len(s)>0 else pd.NaT),
    max_value_in_window=('value','max'),
    min_value_in_window=('value','min')
)

# If a series had no rows in window, ensure it's represented (left-join p95_df)
per_series_trace_results_df = p95_df.merge(agg, on=['cmdb_id','trace_name','global_p95'], how='left')

# Fill NaNs for series with no data in window
per_series_trace_results_df['anomaly_count'] = per_series_trace_results_df['anomaly_count'].fillna(0).astype(int)
per_series_trace_results_df['max_value_in_window'] = per_series_trace_results_df['max_value_in_window']
per_series_trace_results_df['min_value_in_window'] = per_series_trace_results_df['min_value_in_window']
per_series_trace_results_df['earliest_anomaly_dt'] = per_series_trace_results_df['earliest_anomaly_dt']

# Compute severity = (max_value_in_window - global_p95) / global_p95 ; handle global_p95==0 -> NaN
def calc_sev(row):
    p = row['global_p95']
    mv = row['max_value_in_window']
    if pd.isna(p) or p == 0 or pd.isna(mv):
        return np.nan
    return (mv - p) / p

per_series_trace_results_df['severity'] = per_series_trace_results_df.apply(calc_sev, axis=1)

# Format earliest_anomaly_timestamp as string (Asia/Shanghai) for display
per_series_trace_results_df['earliest_anomaly_timestamp'] = per_series_trace_results_df['earliest_anomaly_dt'].dt.strftime('%Y-%m-%d %H:%M:%S%z')

# 4) Prepare compact top-20 table sorted by severity descending
compact_cols = ['cmdb_id','trace_name','anomaly_count','earliest_anomaly_timestamp','max_value_in_window','min_value_in_window','global_p95','severity']
compact_results = per_series_trace_results_df[compact_cols].sort_values(by='severity', ascending=False)

top20_trace_compact = compact_results.head(20).reset_index(drop=True)

# Summary numbers
total_series_scanned = per_series_trace_results_df.shape[0]
series_with_anomaly_count = int((per_series_trace_results_df['anomaly_count'] > 0).sum())

# List up to 20 unique cmdb_id values that had trace anomalies (alphabetical)
anomaly_cmdbs = sorted(per_series_trace_results_df.loc[per_series_trace_results_df['anomaly_count']>0, 'cmdb_id'].unique())
anomaly_cmdbs_sample = anomaly_cmdbs[:20]

# Keep full intermediate results in kernel variables:
per_series_trace_results_df_full = per_series_trace_results_df.copy()
trace_win_with_p95_full = trace_win_with_p95.copy()
p95_df_full = p95_df.copy()

# Display compact outputs (variable names)
top20_trace_compact, total_series_scanned, series_with_anomaly_count, anomaly_cmdbs_sample
