trace_window_anom_df['is_anom'] = trace_window_anom_df['is_anom'].astype(bool)

# Pre-filter anomalous rows
anom_rows = trace_window_anom_df[trace_window_anom_df['is_anom']].copy()

candidates = ['cartservice2-0','emailservice-0','shippingservice2-0']

rows = []
for c in candidates:
    prefix_to = f"trace.to_{c}"
    prefix_from = f"trace.from_{c}"
    # anomalous 'to' and 'from' rows for this candidate
    to_rows = anom_rows[anom_rows['trace_name'].str.startswith(prefix_to, na=False)].copy()
    from_rows = anom_rows[anom_rows['trace_name'].str.startswith(prefix_from, na=False)].copy()
    count_to_traces = int(to_rows.shape[0])
    count_from_traces = int(from_rows.shape[0])
    earliest_to_trace = to_rows['dt'].min() if not to_rows.empty else pd.NaT
    earliest_from_trace = from_rows['dt'].min() if not from_rows.empty else pd.NaT

    # top_callers: for each 'to' trace occurrence, look for anomalous 'from_' rows at the same timestamp
    # and extract caller name from trace_name pattern 'trace.from_<caller>...'
    caller_counter = Counter()
    if not to_rows.empty:
        # get anomalous 'from_' rows (any caller) for matching timestamps
        potential_callers = anom_rows[anom_rows['trace_name'].str.startswith('trace.from_', na=False)].copy()
        if not potential_callers.empty:
            # map timestamps to callers at that timestamp
            for t in to_rows['dt'].unique():
                callers_at_t = potential_callers[potential_callers['dt'] == t]
                if callers_at_t.empty:
                    continue
                # extract caller id from trace_name e.g., 'trace.from_frontend-0.duration_mean' -> 'frontend-0'
                callers = callers_at_t['trace_name'].str.replace(r'^trace\.from_', '', regex=True).str.split('.', n=1).str[0]
                caller_counter.update(callers.dropna().tolist())
    # prepare top 5 callers as "caller::count" strings
    top_callers = [f"{caller}::{cnt}" for caller, cnt in caller_counter.most_common(5)]

    # max_metric_severity from per_component_df (if available)
    if 'per_component_df' in globals() and 'max_severity' in per_component_df.columns:
        sev_row = per_component_df[per_component_df['cmdb_id'] == c]
        max_metric_severity = float(sev_row['max_severity'].iloc[0]) if not sev_row.empty else np.nan
    else:
        # fallback: try true_candidate_df severity max for this cmdb_id
        if 'true_candidate_df' in globals() and 'severity' in true_candidate_df.columns:
            tmp = true_candidate_df[true_candidate_df['cmdb_id'] == c]
            max_metric_severity = float(tmp['severity'].max()) if not tmp.empty else np.nan
        else:
            max_metric_severity = np.nan

    rows.append({
        'candidate': c,
        'count_to_traces': count_to_traces,
        'count_from_traces': count_from_traces,
        'earliest_to_trace': earliest_to_trace,
        'earliest_from_trace': earliest_from_trace,
        'top_callers': top_callers,
        'max_metric_severity': max_metric_severity
    })

candidate_trace_role_df = pd.DataFrame(rows)

# Global summaries
# overall_most_to_traces_candidate: candidate with highest count_to_traces and its count
if not candidate_trace_role_df.empty:
    top_row = candidate_trace_role_df.sort_values('count_to_traces', ascending=False).iloc[0]
    overall_most_to_traces_candidate = (top_row['candidate'], int(top_row['count_to_traces']))
else:
    overall_most_to_traces_candidate = (None, 0)

# combined_earliest_anomaly among all 'to_' and 'from_' anomalous trace rows for these candidates
mask_tofrom = anom_rows['trace_name'].apply(lambda x: any(x.startswith(pref) for pref in
                                                        [f"trace.to_{c}" for c in candidates] +
                                                        [f"trace.from_{c}" for c in candidates]), na=False)
relevant_rows = anom_rows[mask_tofrom]
