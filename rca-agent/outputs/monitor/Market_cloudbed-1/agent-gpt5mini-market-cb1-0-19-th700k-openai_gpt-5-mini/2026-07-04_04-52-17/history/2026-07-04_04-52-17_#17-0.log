    if pd.isna(p95) and pd.isna(p5):
        return 0.0
    # above P95
    if (not pd.isna(p95)) and (maxv > p95):
        denom = max(1e-9, abs(p95))
        sev = (maxv - p95) / denom
        return float(sev)
    # below P5
    if (not pd.isna(p5)) and (minv < p5):
        denom = max(1e-9, abs(p5))
        sev = (p5 - minv) / denom
        return float(sev)
    return 0.0

