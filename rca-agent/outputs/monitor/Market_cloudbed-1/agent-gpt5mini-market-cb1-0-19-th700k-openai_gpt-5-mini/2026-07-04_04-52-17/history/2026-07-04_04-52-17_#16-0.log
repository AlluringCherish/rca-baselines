import pandas as pd
import numpy as np
import pytz
from datetime import datetime

# Reuse existing df_metric if available
try:
    df_metric
except NameError:
    df_metric = pd.read_csv('metric.csv', dtype={'timestamp': int})

# Ensure timestamp integer
df_metric['timestamp'] = df_metric['timestamp'].astype(int)

# Target components
targets = ['checkoutservice-1', 'frontend-2']

# 1) Compute global P95 and P5 per (cmdb_id, kpi_name) for the full series (reuse thresholds if present)
try:
    thresholds
except NameError:
    thresholds = df_metric.groupby(['cmdb_id', 'kpi_name'])['value'].agg(
        global_p95 = lambda x: float(np.percentile(x.values, 95)),
        global_p5  = lambda x: float(np.percentile(x.values, 5))
    ).reset_index()

# Filter thresholds to the two target cmdb_ids
thr_targets = thresholds[thresholds['cmdb_id'].isin(targets)].copy()

# 2) Exclude series where global_p95 == global_p5 (constant/config metrics)
thr_variable = thr_targets[thr_targets['global_p95'] != thr_targets['global_p5']].copy()

# 3) Define incident window March 20, 2022 18:00 to 18:30 (UTC+8) and filter metric points into that window
tz = pytz.timezone('Asia/Shanghai')
start_local = tz.localize(datetime(2022, 3, 20, 18, 0, 0))
end_local   = tz.localize(datetime(2022, 3, 20, 18, 30, 0))
start_ts = int(start_local.astimezone(pytz.utc).timestamp())
end_ts   = int(end_local.astimezone(pytz.utc).timestamp())

df_window_all = df_metric[(df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] <= end_ts)].copy()

# Keep only target cmdb_id series and only non-constant series
df_window = df_window_all[df_window_all['cmdb_id'].isin(targets)].merge(
    thr_variable, on=['cmdb_id','kpi_name'], how='inner'
)

# 4) Identify anomaly points: value >= global_p95 OR value <= global_p5
df_window['is_anom'] = (df_window['value'] >= df_window['global_p95']) | (df_window['value'] <= df_window['global_p5'])

# Keep only anomaly points for run grouping
df_anom_points = df_window[df_window['is_anom']].copy()

# Prepare container for per-KPI aggregation
if df_anom_points.empty:
    # empty result with required columns
    result_cols = ['cmdb_id','kpi_name','anomaly_count','number_of_fault_runs',
                   'earliest_fault_ts','latest_fault_ts','window_min_value','window_max_value',
                   'global_p95','global_p5','severity_score']
    result_df = pd.DataFrame(columns=result_cols)
else:
    # For window-level min/max for the KPI (consider only points inside the window, even non-anom points)
    window_stats = df_window_all[df_window_all['cmdb_id'].isin(targets)].groupby(['cmdb_id','kpi_name'])['value'].agg(
        window_min_value = 'min',
        window_max_value = 'max'
    ).reset_index()

    # Group anomaly points by series and compute runs (consecutive timestamps differ by exactly 60s)
    def summarize_runs(df):
        df = df.sort_values('timestamp')
        # identify start of a new run where diff != 60
        diffs = df['timestamp'].diff().fillna(999999)
        run_id = (diffs != 60).cumsum()
        runs = df.groupby(run_id)['timestamp'].agg(start_ts=('min'), end_ts=('max'), count=('count'))
        anomaly_count = int(df.shape[0])
        number_of_fault_runs = int(runs.shape[0])
        earliest_fault_ts = int(runs['start_ts'].min())
        latest_fault_ts = int(runs['end_ts'].max())
        return pd.Series({
            'anomaly_count': anomaly_count,
            'number_of_fault_runs': number_of_fault_runs,
            'earliest_fault_ts': earliest_fault_ts,
            'latest_fault_ts': latest_fault_ts
        })

    anom_summary = df_anom_points.groupby(['cmdb_id','kpi_name']).apply(summarize_runs).reset_index()

    # Merge with thresholds and window stats
    anom_agg = anom_summary.merge(thr_variable, on=['cmdb_id','kpi_name'], how='left') \
                          .merge(window_stats, on=['cmdb_id','kpi_name'], how='left')

    # Compute severity_score per spec:
    # severity = max(window_max - global_p95 (if any point > p95), global_p5 - window_min (if any point < p5))
    # We need to know if any point exceeded p95 or fell below p5 within the window for that KPI.
    # Compute flags from df_window (not only anomaly points) grouped per series.
    flags = df_window.groupby(['cmdb_id','kpi_name']).agg(
        any_above_p95 = ('value', lambda x, g=thr_variable: (x >= x.name) )  # placeholder, will replace below
    ).reset_index(drop=True)  # placeholder not used
    # Instead compute directly using merges:
    # For each series in anom_agg, compute window_max_value and window_min_value are available; use them to determine which side triggered.

    def compute_severity(row):
        wmax = row['window_max_value']
        wmin = row['window_min_value']
        p95 = row['global_p95']
        p5  = row['global_p5']
        sev1 = (wmax - p95) if (wmax > p95) else 0.0
        sev2 = (p5 - wmin) if (wmin < p5) else 0.0
        return float(max(sev1, sev2))

    # Ensure window_min/max are numeric (they may be NaN if no points in window)
    anom_agg['window_min_value'] = pd.to_numeric(anom_agg['window_min_value'], errors='coerce')
    anom_agg['window_max_value'] = pd.to_numeric(anom_agg['window_max_value'], errors='coerce')

    anom_agg['severity_score'] = anom_agg.apply(compute_severity, axis=1)

    # Ensure integer timestamps
    anom_agg['earliest_fault_ts'] = anom_agg['earliest_fault_ts'].astype(int)
    anom_agg['latest_fault_ts']   = anom_agg['latest_fault_ts'].astype(int)

    # Final compact table: select columns and order by severity desc then anomaly_count desc
    result_df = anom_agg[['cmdb_id','kpi_name','anomaly_count','number_of_fault_runs',
                         'earliest_fault_ts','latest_fault_ts','window_min_value','window_max_value',
                         'global_p95','global_p5','severity_score']].sort_values(
                             by=['severity_score','anomaly_count'], ascending=[False, False]
                         ).head(20)

# Display compact result (stored in variable result_df)
result_df
