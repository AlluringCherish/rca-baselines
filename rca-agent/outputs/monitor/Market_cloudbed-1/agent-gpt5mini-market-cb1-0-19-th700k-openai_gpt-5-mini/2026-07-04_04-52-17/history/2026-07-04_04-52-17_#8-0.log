    group_summaries.append({
        'group_name': gname,
        'distinct_series_with_runs': int(distinct_series_with_runs),
        'total_runs': int(total_runs),
        'total_anomaly_points': int(total_anomaly_points),
        'max_run_severity': max_run_severity,
