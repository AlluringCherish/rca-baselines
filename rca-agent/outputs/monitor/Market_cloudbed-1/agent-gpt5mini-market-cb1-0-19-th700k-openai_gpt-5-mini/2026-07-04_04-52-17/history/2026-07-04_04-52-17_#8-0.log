        total_runs = 0
        total_anomaly_points = 0
        max_run_severity = np.nan
        earliest_run_start = pd.NaT
        latest_run_end = pd.NaT
        top5_df = pd.DataFrame(columns=['cmdb_id','kpi_name','series_max_run_severity','earliest_run_start'])
    else:
