import pandas as pd
import numpy as np
import pytz

# reuse df_metric and tz from kernel
tz = pytz.timezone('Asia/Shanghai')

# Ensure value numeric and ts_dt present
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')
if 'ts_dt' not in df_metric.columns:
    df_metric['ts_dt'] = pd.to_datetime(df_metric['timestamp'].astype(int), unit='s', utc=True).dt.tz_convert(tz)

# 1) Extract node identifier from kpi_name: 'node-N' or 'no-node'
# Create a series-level node_id extractor (will be applied to kpi_name)
def extract_node_id(kpi):
    m = pd.Series(kpi).str.extract(r'container\.node-(\d+)')[0]
    return m.apply(lambda x: f'node-{x}' if pd.notna(x) else 'no-node')[0]

# For efficiency, compute node_id per unique kpi_name and map
unique_kpis = df_metric['kpi_name'].unique()
kpi_node_map = pd.Series(unique_kpis).str.extract(r'container\.node-(\d+)')[0].fillna('')
kpi_node_map = pd.Series(kpi_node_map.index, index=kpi_node_map.index)  # placeholder to maintain shape
# Build mapping properly
kpi_node_map = pd.Series(unique_kpis).apply(lambda k: (f"node-{pd.Series([k]).str.extract(r'container\.node-(\\d+)')[0]}" if pd.Series([k]).str.contains(r'container\.node-').bool() else 'no-node'))
kpi_node_map.index = unique_kpis
# Now we have mapping from kpi_name -> node_id
kpi_to_node = kpi_node_map.to_dict()

# 2) Compute global_p95 and global_p05 for every (cmdb_id, kpi_name) series (full series)
series_stats = (df_metric.groupby(['cmdb_id','kpi_name'], dropna=False)['value']
                .agg(total_count='size',
                     global_p95=lambda s: s.quantile(0.95),
                     global_p05=lambda s: s.quantile(0.05))
                .reset_index())

# attach node_id to series_stats via kpi_name mapping
series_stats['node_id'] = series_stats['kpi_name'].map(kpi_to_node).fillna('no-node')

# 3) Filter to failure window and count anomaly points per series
start = pd.Timestamp('2022-03-20 13:00:00', tz=tz)
end = pd.Timestamp('2022-03-20 13:30:00', tz=tz)
df_metric['in_window'] = df_metric['ts_dt'].between(start, end)

# window records
window_records = df_metric[df_metric['in_window']].copy()

# merge global thresholds into window_records (thresholds computed on full series)
window_records = window_records.merge(series_stats[['cmdb_id','kpi_name','global_p95','global_p05']],
                                      on=['cmdb_id','kpi_name'], how='left')

# identify anomalies
window_records['anomaly_high'] = (window_records['value'] > window_records['global_p95']).fillna(False)
window_records['anomaly_low'] = (window_records['value'] < window_records['global_p05']).fillna(False)
window_records['is_anomaly'] = window_records['anomaly_high'] | window_records['anomaly_low']

# per-series window counts and anomaly counts/timestamps
window_counts = (window_records.groupby(['cmdb_id','kpi_name'], sort=False)
                 .size().reset_index(name='series_window_count'))

anomaly_points = window_records[window_records['is_anomaly']].copy()

series_anom_stats = (anomaly_points.groupby(['cmdb_id','kpi_name'], sort=False)
                     .agg(series_anomaly_points=('is_anomaly','sum'),
                          series_anomaly_high=('anomaly_high','sum'),
                          series_anomaly_low=('anomaly_low','sum'),
                          earliest_anomaly_timestamp=('ts_dt','min'),
                          latest_anomaly_timestamp=('ts_dt','max'))
                     .reset_index())

# combine into series_summary (ensure series with zero anomalies are represented)
series_summary = series_stats.merge(window_counts, on=['cmdb_id','kpi_name'], how='left')
series_summary = series_summary.merge(series_anom_stats, on=['cmdb_id','kpi_name'], how='left')

# fill NaNs for series with no window rows or no anomalies
series_summary['series_window_count'] = series_summary['series_window_count'].fillna(0).astype(int)
series_summary['series_anomaly_points'] = series_summary['series_anomaly_points'].fillna(0).astype(int)
series_summary['series_anomaly_high'] = series_summary.get('series_anomaly_high', pd.Series([0]*len(series_summary))).fillna(0).astype(int)
series_summary['series_anomaly_low'] = series_summary.get('series_anomaly_low', pd.Series([0]*len(series_summary))).fillna(0).astype(int)
series_summary['earliest_anomaly_timestamp'] = series_summary['earliest_anomaly_timestamp'].fillna(pd.NaT)
series_summary['latest_anomaly_timestamp'] = series_summary['latest_anomaly_timestamp'].fillna(pd.NaT)

# 4) Aggregate anomaly counts per node_id
# Number of distinct series with at least one anomaly
node_group = series_summary.groupby('node_id', sort=False).agg(
    distinct_series_with_anomaly=('series_anomaly_points', lambda s: int((s>0).sum())),
    total_anomaly_points=('series_anomaly_points', 'sum')
).reset_index()

# earliest and latest anomaly timestamps across node (use anomaly_points with node mapping)
if not anomaly_points.empty:
    anomaly_points['node_id'] = anomaly_points['kpi_name'].map(kpi_to_node).fillna('no-node')
    node_time = (anomaly_points.groupby('node_id', sort=False)
                 .agg(earliest_anomaly_timestamp=('ts_dt','min'),
                      latest_anomaly_timestamp=('ts_dt','max'))
                 .reset_index())
else:
    node_time = pd.DataFrame(columns=['node_id','earliest_anomaly_timestamp','latest_anomaly_timestamp'])

node_summary = node_group.merge(node_time, on='node_id', how='left')
node_summary['earliest_anomaly_timestamp'] = node_summary['earliest_anomaly_timestamp'].fillna(pd.NaT)
node_summary['latest_anomaly_timestamp'] = node_summary['latest_anomaly_timestamp'].fillna(pd.NaT)

# 5) Compact table: top 10 node identifiers sorted by total_anomaly_points desc
node_summary_top10 = node_summary.sort_values('total_anomaly_points', ascending=False).head(10).reset_index(drop=True)

# 6) For the top node_id, list up to 10 (cmdb_id,kpi_name) series contributing most anomaly points
if not node_summary_top10.empty and node_summary_top10['total_anomaly_points'].sum() > 0:
    top_node = node_summary_top10.iloc[0]['node_id']
    top_node_series = series_summary[series_summary['node_id'] == top_node].copy()
    # consider only series with at least one anomaly
    top_node_series = top_node_series[top_node_series['series_anomaly_points']>0].copy()
    top_node_series_top10 = (top_node_series.sort_values('series_anomaly_points', ascending=False)
                             [['cmdb_id','kpi_name','series_anomaly_points','earliest_anomaly_timestamp']]
                             .head(10)
                             .reset_index(drop=True))
else:
    top_node = None
    top_node_series_top10 = pd.DataFrame(columns=['cmdb_id','kpi_name','series_anomaly_points','earliest_anomaly_timestamp'])

# Keep intermediate variables in kernel for further analysis:
# series_stats, series_summary, window_records, anomaly_points, node_summary

# Final compact outputs
node_summary_top10, top_node_series_top10
