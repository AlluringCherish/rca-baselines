import pandas as pd
import numpy as np
import pytz

# reuse existing kernel variables where available
tz = pytz.timezone('Asia/Shanghai')

# Ensure df_metric and ts_dt exist
df_metric['value'] = pd.to_numeric(df_metric['value'], errors='coerce')
if 'ts_dt' not in df_metric.columns:
    df_metric['ts_dt'] = pd.to_datetime(df_metric['timestamp'].astype(int), unit='s', utc=True).dt.tz_convert(tz)

# Ensure global series_stats exists (global P95/P05 per (cmdb_id,kpi_name))
if 'series_stats' not in globals():
    series_stats = (df_metric.groupby(['cmdb_id','kpi_name'], dropna=False)['value']
                    .agg(total_count='size',
                         global_p95=lambda s: s.quantile(0.95),
                         global_p05=lambda s: s.quantile(0.05))
                    .reset_index())

# Window selection
start = pd.Timestamp('2022-03-20 13:00:00', tz=tz)
end = pd.Timestamp('2022-03-20 13:30:00', tz=tz)
window_metric_df = df_metric[df_metric['ts_dt'].between(start, end)].copy()

# Merge global thresholds into window data (rule: thresholds from full series)
window_metric_df = window_metric_df.merge(
    series_stats[['cmdb_id','kpi_name','global_p95','global_p05']],
    on=['cmdb_id','kpi_name'], how='left'
)

# Identify anomaly points in window
window_metric_df['anomaly_type'] = np.where(window_metric_df['value'] > window_metric_df['global_p95'], 'high',
                                            np.where(window_metric_df['value'] < window_metric_df['global_p05'], 'low', None))
anomalies_df = window_metric_df[window_metric_df['anomaly_type'].notna()].copy()

# Define groups
groups = {
    'adservice': lambda df: df['cmdb_id'].str.startswith('adservice', na=False),
    'shippingservice2-0': lambda df: df['cmdb_id'] == 'shippingservice2-0',
    'node-6': lambda df: df['kpi_name'].str.contains('container.node-6', na=False)
}

# Helper to compute runs for a subset of anomalies (for one series)
def compute_runs_for_series(g):
    # g: anomalies rows for one series sorted by ts_dt
    g = g.sort_values('ts_dt').copy()
    if g.shape[0] == 0:
        return pd.DataFrame(columns=[
            'cmdb_id','kpi_name','start_timestamp','end_timestamp','length_in_points',
            'max_value','min_value','run_type','run_severity'])
    g['diff_min'] = g['ts_dt'].diff().dt.total_seconds().div(60).fillna(0)
    g['run_id'] = (g['diff_min'] != 1).cumsum()
    runs = (g.groupby('run_id', sort=False).agg(
        cmdb_id=('cmdb_id','first'),
        kpi_name=('kpi_name','first'),
        start_timestamp=('ts_dt','min'),
        end_timestamp=('ts_dt','max'),
        length_in_points=('ts_dt','size'),
        max_value=('value','max'),
        min_value=('value','min'),
        anomaly_types=('anomaly_type', lambda s: sorted(set(s)))
    ).reset_index(drop=True))
    # map thresholds for the series
    # thresholds are same for all rows in g
    gp95 = g['global_p95'].iloc[0]
    gp05 = g['global_p05'].iloc[0]
    def classify_and_sev(types, max_v, min_v):
        types_set = set(types)
        if types_set == {'high'}:
            typ = 'high'
            sev = (max_v - gp95) / gp95 if gp95 not in (0, np.nan) else np.nan
            return typ, float(sev)
        elif types_set == {'low'}:
            typ = 'low'
            sev = (gp05 - min_v) / gp05 if gp05 not in (0, np.nan) else np.nan
            return typ, float(sev)
        else:
            typ = 'mixed'
            sev_high = (max_v - gp95) / gp95 if gp95 not in (0, np.nan) else np.nan
            sev_low = (gp05 - min_v) / gp05 if gp05 not in (0, np.nan) else np.nan
            # for mixed, store the larger single-sided fraction for ranking, but keep both in text
            return typ, (float(sev_high) if not pd.isna(sev_high) else np.nan, float(sev_low) if not pd.isna(sev_low) else np.nan)
    runs[['run_type','run_severity_raw']] = runs.apply(
        lambda r: pd.Series(classify_and_sev(r['anomaly_types'], r['max_value'], r['min_value'])),
        axis=1
    )
    # Normalize run_severity numeric for comparisons: for mixed take max of the two
    def normalize_sev(x):
        if isinstance(x, tuple):
            vals = [v for v in x if (v is not None and not np.isnan(v))]
            return max(vals) if vals else np.nan
        else:
            return x
    runs['run_severity'] = runs['run_severity_raw'].apply(normalize_sev)
    # convert mixed severity raw to readable string
    def fmt_raw(x):
        if isinstance(x, tuple):
            h, l = x
            return f"high:{h:.6f},low:{l:.6f}"
        elif pd.isna(x):
            return np.nan
        else:
            return f"{x:.6f}"
    runs['run_severity_txt'] = runs['run_severity_raw'].apply(fmt_raw)
    # select output columns
    runs_out = runs[['cmdb_id','kpi_name','start_timestamp','end_timestamp','length_in_points',
                     'max_value','min_value','run_type','run_severity','run_severity_txt']].copy()
    return runs_out

# Compute runs for all anomaly series once and cache
if not anomalies_df.empty:
    # group anomalies by series
    grouped = anomalies_df.groupby(['cmdb_id','kpi_name'], sort=False)
    runs_list = []
    for (cmdb,kpi), g in grouped:
        runs = compute_runs_for_series(g)
        runs_list.append(runs)
    runs_all = pd.concat(runs_list, ignore_index=True) if runs_list else pd.DataFrame(columns=[
        'cmdb_id','kpi_name','start_timestamp','end_timestamp','length_in_points',
        'max_value','min_value','run_type','run_severity','run_severity_txt'])
else:
    runs_all = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','start_timestamp','end_timestamp','length_in_points',
        'max_value','min_value','run_type','run_severity','run_severity_txt'])

# For each group, aggregate required metrics
group_summaries = []
group_top_series = {}

for gname, gfunc in groups.items():
    # series belonging to group (based on full series list series_stats)
    mask_series = series_stats['cmdb_id'].apply(lambda x: gfunc(pd.Series([x])).iloc[0]) if gname != 'node-6' else series_stats['kpi_name'].str.contains('container.node-6', na=False)
    # For adservice and shippingservice2-0, use lambda on series_stats rows
    if gname == 'adservice':
        series_mask = series_stats['cmdb_id'].str.startswith('adservice', na=False)
    elif gname == 'shippingservice2-0':
        series_mask = series_stats['cmdb_id'] == 'shippingservice2-0'
    else:
        series_mask = series_stats['kpi_name'].str.contains('container.node-6', na=False)
    series_list = series_stats[series_mask][['cmdb_id','kpi_name']].drop_duplicates()
    # runs belonging to this group
    runs_grp = runs_all.merge(series_list, on=['cmdb_id','kpi_name'], how='inner')
    if runs_grp.empty:
        distinct_series_with_runs = 0
        total_runs = 0
        total_anomaly_points = 0
        max_run_severity = np.nan
        earliest_run_start = pd.NaT
        latest_run_end = pd.NaT
    else:
        distinct_series_with_runs = runs_grp[['cmdb_id','kpi_name']].drop_duplicates().shape[0]
        total_runs = runs_grp.shape[0]
        # total anomaly points: sum of lengths across runs
        total_anomaly_points = int(runs_grp['length_in_points'].sum())
        # max single-sided fraction observed in group (use run_severity numeric)
        max_run_severity = float(runs_grp['run_severity'].replace([np.inf,-np.inf], np.nan).dropna().max()) if runs_grp['run_severity'].notna().any() else np.nan
        earliest_run_start = runs_grp['start_timestamp'].min()
        latest_run_end = runs_grp['end_timestamp'].max()
    group_summaries.append({
        'group_name': gname,
        'distinct_series_with_runs': int(distinct_series_with_runs),
        'total_runs': int(total_runs),
        'total_anomaly_points': int(total_anomaly_points),
        'max_run_severity': max_run_severity,
        'earliest_run_start': earliest_run_start,
        'latest_run_end': latest_run_end
    })
    # Per-group top 5 series by series_max_run_severity
    if not runs_grp.empty:
        per_series = (runs_grp.groupby(['cmdb_id','kpi_name'], as_index=False).agg(
            series_max_run_severity=('run_severity','max'),
            earliest_run_start=('start_timestamp','min'),
            total_runs_series=('length_in_points','size')
        ).sort_values(['series_max_run_severity','total_runs_series'], ascending=[False, False]).head(5))
        group_top_series[gname] = per_series[['cmdb_id','kpi_name','series_max_run_severity','earliest_run_start']]
    else:
        group_top_series[gname] = pd.DataFrame(columns=['cmdb_id','kpi_name','series_max_run_severity','earliest_run_start'])

# Assemble group summary DataFrame
group_summary_df = pd.DataFrame(group_summaries)[[
    'group_name','distinct_series_with_runs','total_runs','total_anomaly_points',
    'max_run_severity','earliest_run_start','latest_run_end'
]]

# Prepare top-5 DataFrames for each group (limit rows)
top5_ad = group_top_series['adservice']
top5_ship = group_top_series['shippingservice2-0']
top5_node6 = group_top_series['node-6']

# Final compact outputs (3-row group summary and three small top-5 lists)
group_summary_df, top5_ad, top5_ship, top5_node6
