import pandas as pd
import numpy as np
import pytz

# Reuse cached dataframes if present
try:
    df_log
except NameError:
    df_log = pd.read_csv("log.csv")

# suspects list from kernel (from previous step). Fallback if not present.
try:
    suspects_df
    suspects_list = suspects_df['cmdb_id'].tolist()
except NameError:
    # fallback: user-provided suspect list
    suspects_list = ['checkoutservice2-0', 'checkoutservice-0', 'checkoutservice-1', 'frontend2-0', 'frontend-0']

tz = pytz.timezone('Asia/Shanghai')

# 1) Compute global thresholds (p95, p05) per (cmdb_id, log_name) using full df_log
grp = df_log.groupby(['cmdb_id','log_name'])['value']
log_thresholds_df = (
    grp.agg(sample_count='count')
    .reset_index()
)
if not log_thresholds_df.empty:
    quant = (
        df_log
        .groupby(['cmdb_id','log_name'])['value']
        .agg(p95=lambda s: s.quantile(0.95), p05=lambda s: s.quantile(0.05))
        .reset_index()
    )
    log_thresholds_df = log_thresholds_df.merge(quant, on=['cmdb_id','log_name'], how='left')
else:
    log_thresholds_df = pd.DataFrame(columns=['cmdb_id','log_name','sample_count','p95','p05'])

# 2) Filter df_log to incident window and save as df_log_window
start_epoch = int(pd.Timestamp('2022-03-20 10:00:00', tz=tz).tz_convert('UTC').timestamp())
end_epoch   = int(pd.Timestamp('2022-03-20 10:30:00', tz=tz).tz_convert('UTC').timestamp())

df_log_window = df_log[(df_log['timestamp'] >= start_epoch) & (df_log['timestamp'] <= end_epoch)].copy()

# 3) For only suspect cmdb_ids, join thresholds with df_log_window and compute aggregates
suspect_thresholds = log_thresholds_df[log_thresholds_df['cmdb_id'].isin(suspects_list)].copy()

if suspect_thresholds.empty:
    suspect_log_anomalies_df = pd.DataFrame(columns=[
        'cmdb_id','log_name','p95','p05','total_points','count_high','count_low',
        'earliest_anomaly_ts','max_value_window','min_value_window','severity','anomaly_count'
    ])
else:
    merged = df_log_window.merge(
        suspect_thresholds[['cmdb_id','log_name','p95','p05','sample_count']],
        on=['cmdb_id','log_name'],
        how='inner'
    )
    if not merged.empty:
        merged['is_high'] = merged['value'] >= merged['p95']
        merged['is_low'] = merged['value'] <= merged['p05']
        merged['anomaly_ts'] = merged['timestamp'].where(merged['is_high'] | merged['is_low'], np.nan)

        agg = (
            merged.groupby(['cmdb_id','log_name','p95','p05','sample_count'], dropna=False)
            .agg(
                total_points=('value','count'),
                count_high=('is_high','sum'),
                count_low=('is_low','sum'),
                earliest_anomaly_ts_raw=('anomaly_ts','min'),
                max_value_window=('value','max'),
                min_value_window=('value','min')
            )
            .reset_index()
        )
    else:
        agg = pd.DataFrame(columns=['cmdb_id','log_name','p95','p05','sample_count',
                                    'total_points','count_high','count_low','earliest_anomaly_ts_raw',
                                    'max_value_window','min_value_window'])

    suspect_log_anomalies_df = suspect_thresholds.merge(
        agg,
        on=['cmdb_id','log_name','p95','p05','sample_count'],
        how='left'
    )

    # fill missing numeric aggregates
    suspect_log_anomalies_df['total_points'] = suspect_log_anomalies_df['total_points'].fillna(0).astype(int)
    suspect_log_anomalies_df['count_high'] = suspect_log_anomalies_df['count_high'].fillna(0).astype(int)
    suspect_log_anomalies_df['count_low'] = suspect_log_anomalies_df['count_low'].fillna(0).astype(int)

    # convert earliest anomaly ts to Asia/Shanghai ISO
    def to_shanghai_iso(x):
        if pd.isna(x):
            return pd.NA
        return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).isoformat()
    suspect_log_anomalies_df['earliest_anomaly_ts'] = suspect_log_anomalies_df['earliest_anomaly_ts_raw'].apply(lambda x: to_shanghai_iso(x))

    # compute severity_high and severity_low then severity as larger (absolute not needed for logs but follow rule)
    def sev_high(row):
        mv = row['max_value_window']
        p95 = row['p95']
        if pd.isna(mv):
            return np.nan
        if p95 > 0:
            return (mv - p95) / p95
        else:
            return mv - p95

    def sev_low(row):
        mn = row['min_value_window']
        p05 = row['p05']
        if pd.isna(mn):
            return np.nan
        if p05 > 0:
            return (p05 - mn) / p05
        else:
            return p05 - mn

    suspect_log_anomalies_df['severity_high'] = suspect_log_anomalies_df.apply(sev_high, axis=1)
    suspect_log_anomalies_df['severity_low'] = suspect_log_anomalies_df.apply(sev_low, axis=1)

    _sh = suspect_log_anomalies_df['severity_high'].to_numpy(dtype=float)
    _sl = suspect_log_anomalies_df['severity_low'].to_numpy(dtype=float)
    with np.errstate(invalid='ignore'):
        severity_vals = np.nanmax(np.vstack([np.abs(_sh), np.abs(_sl)]), axis=0)
    suspect_log_anomalies_df['severity'] = severity_vals
    suspect_log_anomalies_df['anomaly_count'] = suspect_log_anomalies_df['count_high'] + suspect_log_anomalies_df['count_low']

# Cache log_thresholds_df and suspect_log_anomalies_df and df_log_window in kernel (variables already assigned)

# 4) Prepare compact outputs
n_pairs_inspected = int(suspect_thresholds.shape[0])
n_pairs_with_anomaly = int((suspect_log_anomalies_df['anomaly_count'] > 0).sum()) if not suspect_log_anomalies_df.empty else 0

out_cols = ['cmdb_id','log_name','p95','p05','total_points','count_high','count_low',
            'earliest_anomaly_ts','max_value_window','min_value_window','severity']

suspect_log_top20 = (
    suspect_log_anomalies_df.loc[:, out_cols]
    .sort_values(['severity','anomaly_count'], ascending=[False, False])
    .head(20)
    .reset_index(drop=True)
)

# Return compact summary variables (they are cached in kernel)
suspects_list, n_pairs_inspected, n_pairs_with_anomaly, suspect_log_top20
