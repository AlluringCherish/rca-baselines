        agg = pd.DataFrame(columns=['cmdb_id','log_name','p95','p05','sample_count',
                                    'total_points','count_high','count_low','earliest_anomaly_ts_raw',
                                    'max_value_window','min_value_window'])

    suspect_log_anomalies_df = suspect_thresholds.merge(
        agg,
        on=['cmdb_id','log_name','p95','p05','sample_count'],
        how='left'
    )

    # fill missing numeric aggregates
    suspect_log_anomalies_df['total_points'] = suspect_log_anomalies_df['total_points'].fillna(0).astype(int)
    suspect_log_anomalies_df['count_high'] = suspect_log_anomalies_df['count_high'].fillna(0).astype(int)
    suspect_log_anomalies_df['count_low'] = suspect_log_anomalies_df['count_low'].fillna(0).astype(int)

    # convert earliest anomaly ts to Asia/Shanghai ISO or NA
    def to_shanghai_iso(x):
        if pd.isna(x):
            return pd.NA
        return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).isoformat()
    suspect_log_anomalies_df['earliest_anomaly_ts'] = suspect_log_anomalies_df['earliest_anomaly_ts_raw'].apply(lambda x: to_shanghai_iso(x))

    # compute severity_high and severity_low then severity = max(severity_high, severity_low) per instruction
    def sev_high(row):
        mv = row['max_value_window']
        p95 = row['p95']
        if pd.isna(mv):
            return np.nan
        if p95 > 0:
            return (mv - p95) / p95
        else:
            return mv - p95

    def sev_low(row):
        mn = row['min_value_window']
        p05 = row['p05']
        if pd.isna(mn):
            return np.nan
        if p05 > 0:
            return (p05 - mn) / p05
        else:
            return p05 - mn

    suspect_log_anomalies_df['severity_high'] = suspect_log_anomalies_df.apply(sev_high, axis=1)
    suspect_log_anomalies_df['severity_low'] = suspect_log_anomalies_df.apply(sev_low, axis=1)

    # severity is the max of the two (not absolute, per instruction)
    _sh = suspect_log_anomalies_df['severity_high'].to_numpy(dtype=float)
    _sl = suspect_log_anomalies_df['severity_low'].to_numpy(dtype=float)
    with np.errstate(invalid='ignore'):
        severity_vals = np.nanmax(np.vstack([_sh, _sl]), axis=0)
    suspect_log_anomalies_df['severity'] = severity_vals
    suspect_log_anomalies_df['anomaly_count'] = suspect_log_anomalies_df['count_high'] + suspect_log_anomalies_df['count_low']

# Cache results in kernel: log_thresholds_df, df_log_window, suspect_log_anomalies_df (variables assigned)

# 4) Prepare compact outputs
n_pairs_inspected = int(suspect_thresholds.shape[0])
n_pairs_with_anomaly = int((suspect_log_anomalies_df['anomaly_count'] > 0).sum()) if not suspect_log_anomalies_df.empty else 0

out_cols = ['cmdb_id','log_name','p95','p05','total_points','count_high','count_low',
            'earliest_anomaly_ts','max_value_window','min_value_window','severity']

suspect_log_top20 = (
    suspect_log_anomalies_df.loc[:, out_cols] if not suspect_log_anomalies_df.empty else suspect_log_anomalies_df[ out_cols ]
)

if not suspect_log_top20.empty:
    suspect_log_top20 = suspect_log_top20.sort_values(['severity','anomaly_count'], ascending=[False, False], na_position='last').head(20).reset_index(drop=True)

# Return compact summary variables (cached in kernel)
suspects_list, n_pairs_inspected, n_pairs_with_anomaly, suspect_log_top20
