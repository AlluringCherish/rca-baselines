agg_window = (
    df_metric_window[df_metric_window['cmdb_id'].isin(top_cmdb_list)]
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        count_window=('value', 'count'),
        max_value_window=('value', 'max'),
        min_value_window=('value', 'min')
    )
)

# To compute count_high/count_low and earliest anomaly timestamp, we will iterate per pair using vectorized filtering per group
results = []
for _, row in df_thresholds.iterrows():
