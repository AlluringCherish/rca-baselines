top_cmdb_list = top10_cmdb_counts['cmdb_id'].tolist()

# Filter df_metric to only those cmdb_id for threshold computation (but do NOT filter by time)
df_metric_topcmdb = df_metric[df_metric['cmdb_id'].isin(top_cmdb_list)].copy()

# Ensure 'value' is numeric
df_metric_topcmdb['value'] = pd.to_numeric(df_metric_topcmdb['value'], errors='coerce')

# Group and compute quantiles
df_thresholds = (
    df_metric_topcmdb
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .agg(p95=lambda s: s.quantile(0.95),
         p05=lambda s: s.quantile(0.05),
         count_total='count')
)

