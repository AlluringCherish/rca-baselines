    kpi = row['kpi_name']
    p95 = row['p95']
    p05 = row['p05']
    # subset window rows for this pair
    sub = df_metric_window[(df_metric_window['cmdb_id'] == cid) & (df_metric_window['kpi_name'] == kpi)]
    if sub.shape[0] == 0:
        count_high = 0
        count_low = 0
        earliest_anom_iso = pd.NA
        max_val = np.nan
        min_val = np.nan
    else:
