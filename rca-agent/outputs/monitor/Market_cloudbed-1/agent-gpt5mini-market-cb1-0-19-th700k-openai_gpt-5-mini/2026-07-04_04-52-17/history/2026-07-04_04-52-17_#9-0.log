import numpy as np
import pandas as pd
import pytz
import re

# reuse existing variables: metric, start_ts, end_ts, tz_sh
# ensure dtypes
metric['timestamp'] = metric['timestamp'].astype(int)
metric['value'] = pd.to_numeric(metric['value'], errors='coerce')

# candidate groups
group_a = [
    'checkoutservice-0','checkoutservice-1','checkoutservice-2','checkoutservice2-0',
    'cartservice-0','cartservice-1','cartservice-2','cartservice2-0',
    'productcatalogservice-1','shippingservice-1'
]
group_b = [
    'frontend-2','frontend-0','frontend-1',
    'recommendationservice-0','recommendationservice-1','recommendationservice-2',
    'checkoutservice-0','checkoutservice-1','cartservice-0','cartservice-2'
]

# substrings to match in kpi_name (case-insensitive)
substrs = [
    'cpu','cfs','throttl','mem','memory','jvm','heap','load','disk','io','read','write',
    'net','packet','retrans','thread','process','fd','jaeger','mesh','istio','response'
]
pattern = '|'.join(map(re.escape, substrs))

# helper function to produce summary table for a group
def summarize_group(cmdb_list, label):
    # filter metric for group and matching kpi_name
    df_grp = metric[metric['cmdb_id'].isin(cmdb_list) & metric['kpi_name'].str.contains(pattern, case=False, na=False)].copy()
    if df_grp.empty:
        return label, pd.DataFrame(columns=[
            'cmdb_id','kpi_name','global_count','p95','p5','window_count','anomaly_count',
            'earliest_anomaly_timestamp_in_window','max_value_in_window','min_value_in_window','severity_metric'
        ])
    # compute global thresholds on full series BEFORE window filtering
    full_stats = df_grp.groupby(['cmdb_id','kpi_name'], as_index=False)['value'].agg(
        global_count='count',
        p95=lambda x: float(x.quantile(0.95)),
        p5=lambda x: float(x.quantile(0.05))
    )

    # window slice
    df_window = df_grp[(df_grp['timestamp'] >= start_ts) & (df_grp['timestamp'] <= end_ts)].copy()
    # merge full stats into window rows for per-row anomaly detection
    if not df_window.empty:
        df_w = df_window.merge(full_stats, on=['cmdb_id','kpi_name'], how='left')

        # identify count/row style KPIs (treat drops)
        df_w['is_count_or_row'] = df_w['kpi_name'].str.contains('count|row', case=False, na=False)

        # anomaly rules
        df_w['is_anomaly'] = np.where(
            df_w['is_count_or_row'],
            df_w['value'] <= df_w['p5'],
            df_w['value'] >= df_w['p95']
        )

        # aggregate per pair within window
        window_agg = df_w.groupby(['cmdb_id','kpi_name'], as_index=False).agg(
            window_count=('value','count'),
            anomaly_count=('is_anomaly','sum'),
            earliest_anom_ts_numeric=('timestamp', lambda s: int(s[df_w.loc[s.index,'is_anomaly'].values.argmax()]) if s.index.size>0 and s[df_w.loc[s.index,'is_anomaly'].any() else None)
        )

        # The above earliest computation can be simpler: compute earliest per pair where is_anomaly True
        anom_rows = df_w[df_w['is_anomaly']].groupby(['cmdb_id','kpi_name'], as_index=False).agg(
            earliest_anom_ts_numeric=('timestamp','min')
        )

        # max/min in window per pair
        val_agg = df_w.groupby(['cmdb_id','kpi_name'], as_index=False).agg(
            max_value_in_window=('value','max'),
            min_value_in_window=('value','min')
        )

        # merge aggregates
        merged = full_stats.merge(val_agg, on=['cmdb_id','kpi_name'], how='left').merge(
            df_w.groupby(['cmdb_id','kpi_name'], as_index=False).agg(window_count=('value','count')), on=['cmdb_id','kpi_name'], how='left'
        ).merge(
            anom_rows, on=['cmdb_id','kpi_name'], how='left'
        ).merge(
            df_w.groupby(['cmdb_id','kpi_name'], as_index=False).agg(anomaly_count=('is_anomaly','sum')), on=['cmdb_id','kpi_name'], how='left'
        )
    else:
        # no window rows
        merged = full_stats.copy()
        merged['max_value_in_window'] = np.nan
        merged['min_value_in_window'] = np.nan
        merged['window_count'] = 0
        merged['anomaly_count'] = 0
        merged['earliest_anom_ts_numeric'] = np.nan

    # fill NaNs for counts
    merged['window_count'] = merged['window_count'].fillna(0).astype(int)
    merged['anomaly_count'] = merged['anomaly_count'].fillna(0).astype(int)

    # determine is_count_or_row per pair
    merged['is_count_or_row'] = merged['kpi_name'].str.contains('count|row', case=False, na=False)

    # compute severity_metric
    def compute_severity(row):
        if row['window_count'] == 0:
            return np.nan
        # if count/row-type: severity = p5 / min_value_in_window
        if row['is_count_or_row']:
            if pd.isna(row['min_value_in_window']) or row['min_value_in_window'] == 0:
                return np.nan
            return float(row['p5'] / row['min_value_in_window'])
        # otherwise severity = max_value_in_window / p95
        if pd.isna(row['max_value_in_window']) or row['p95'] == 0:
            return np.nan
        return float(row['max_value_in_window'] / row['p95'])

    merged['severity_metric'] = merged.apply(compute_severity, axis=1)

    # format earliest anomaly timestamps
    def fmt_ts(v):
        if pd.isna(v):
            return np.nan
        return pd.to_datetime(int(v), unit='s', utc=True).tz_convert(pytz.timezone('Asia/Shanghai')).strftime('%Y-%m-%d %H:%M:%S %Z')

    merged['earliest_anomaly_timestamp_in_window'] = merged.get('earliest_anom_ts_numeric').apply(fmt_ts) if 'earliest_anom_ts_numeric' in merged.columns else np.nan

    # prepare final columns
    final = merged[[
        'cmdb_id','kpi_name','global_count','p95','p5','window_count','anomaly_count',
        'earliest_anomaly_timestamp_in_window','max_value_in_window','min_value_in_window','severity_metric'
    ]].copy()

    # sort: earliest_anom asc (nulls last), then severity desc
    # convert earliest_anomaly_timestamp_in_window back to numeric for sorting
    def to_numeric_ts(s):
        return pd.to_datetime(s, utc=True).dt.tz_convert(pytz.timezone('Asia/Shanghai')).astype(int) // 10**9 if s.notna().any() else pd.Series([np.nan]*len(s))
    # create helper numeric column
    final['earliest_num'] = pd.to_datetime(final['earliest_anomaly_timestamp_in_window'], utc=True).dt.tz_convert(pytz.timezone('Asia/Shanghai')).astype('Int64').replace(pd.NaT, pd.NA)
    # sort with NaNs last
    final_sorted = final.sort_values(by=['earliest_num','severity_metric'], ascending=[True, False], na_position='last')

    # return top 10
    top10 = final_sorted.head(10).drop(columns=['earliest_num'])
    return label, top10

# produce summaries for Group A and Group B
label_a, group_a_table = summarize_group(group_a, 'Group A (13:30)')
label_b, group_b_table = summarize_group(group_b, 'Group B (13:31)')

label_a, group_a_table, label_b, group_b_table
