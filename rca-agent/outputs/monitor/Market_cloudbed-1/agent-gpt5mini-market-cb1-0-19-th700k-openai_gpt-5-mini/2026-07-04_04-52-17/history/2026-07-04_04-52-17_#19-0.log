import pandas as pd
import pytz

# reuse existing kernel variables if present: metric_df, p95_df, tz
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")
try:
    p95_df
except NameError:
    # compute global P95 if not present (must be computed on full series per rules)
    p95_df = metric_df.groupby(['cmdb_id', 'kpi_name'], as_index=False)['value'].quantile(0.95)
    p95_df = p95_df.rename(columns={'value': 'global_P95'})
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# Define incident window in epoch seconds (UTC) using Asia/Shanghai tz
start_local = pd.Timestamp("2022-03-20 19:30:00", tz=tz)
end_local   = pd.Timestamp("2022-03-20 20:00:00", tz=tz)
start_epoch = int(start_local.tz_convert('UTC').timestamp())
end_epoch   = int(end_local.tz_convert('UTC').timestamp())

# 1) Filter metric records to adservice and the incident window
ad_metric_window = metric_df[
    (metric_df['cmdb_id'] == 'adservice') &
    (metric_df['timestamp'] >= start_epoch) &
    (metric_df['timestamp'] <= end_epoch)
].copy()

# 2) Total distinct kpi_name candidates for adservice (computed from global p95 table)
ad_p95 = p95_df[p95_df['cmdb_id'] == 'adservice'].copy()
total_kpi_candidates_considered = int(ad_p95['kpi_name'].nunique())

# merge global P95 into the windowed adservice records
ad_metric_window = ad_metric_window.merge(ad_p95, on=['cmdb_id', 'kpi_name'], how='left')

# drop rows without a global_P95 (should be rare); mark breach where value > global_P95
ad_metric_window = ad_metric_window.dropna(subset=['global_P95'])
ad_metric_window['is_breach'] = ad_metric_window['value'] > ad_metric_window['global_P95']

# 2) For each minute timestamp, count distinct kpi_name with breach
# Group breaches by timestamp
breach_group = (
    ad_metric_window[ad_metric_window['is_breach']]
    .groupby('timestamp')
    .agg(
        breach_count = ('kpi_name', lambda s: int(s.nunique())),
        example_breached_kpis = ('kpi_name', lambda s: list(pd.unique(s)[:10]))
    )
    .reset_index()
)

# add total_kpi_candidates_considered column
breach_group['total_kpi_candidates_considered'] = total_kpi_candidates_considered

# convert timestamp to Asia/Shanghai ISO string for display
def ts_to_iso(ts):
    return pd.to_datetime(int(ts), unit='s', utc=True).tz_convert(tz).isoformat()

breach_group['timestamp_iso'] = breach_group['timestamp'].apply(ts_to_iso)

# reorder columns compactly
breach_group = breach_group[['timestamp_iso', 'breach_count', 'total_kpi_candidates_considered', 'example_breached_kpis']]

# 3) Top 10 timestamps by breach_count desc, then timestamp asc
top10_timestamps = breach_group.sort_values(by=['breach_count', 'timestamp_iso'], ascending=[False, True]).head(10).reset_index(drop=True)

# 4) Earliest timestamp in window where breach_count > 0, and full list (up to 20) of kpi_name that breached then
if not breach_group.empty:
    earliest_ts_iso = breach_group.loc[breach_group['breach_count']>0, 'timestamp_iso'].min()
    # map back to unix timestamp to get full list of KPIs at that timestamp
    # find unix ts corresponding to earliest_ts_iso
    earliest_row = breach_group[breach_group['timestamp_iso'] == earliest_ts_iso]
    if not earliest_row.empty:
        # get unix ts by converting back
        # find original unix ts via ad_metric_window
        earliest_unix = ad_metric_window[ad_metric_window['is_breach']].groupby('timestamp').size().reset_index().loc[
            lambda df: pd.to_datetime(df['timestamp'], unit='s', utc=True).tz_convert(tz).isoformat() == earliest_ts_iso, 'timestamp'
        ]
        if not earliest_unix.empty:
            earliest_unix = int(earliest_unix.iloc[0])
            kpis_at_earliest = sorted(ad_metric_window[(ad_metric_window['timestamp'] == earliest_unix) & (ad_metric_window['is_breach'])]['kpi_name'].unique())[:20].tolist()
        else:
            # fallback: take example list
            kpis_at_earliest = earliest_row['example_breached_kpis'].iloc[0][:20]
else:
    earliest_ts_iso = None
    kpis_at_earliest = []

# Prepare compact earliest summary as a small DataFrame
earliest_summary = pd.DataFrame([{
    'earliest_breach_timestamp': earliest_ts_iso,
    'num_kpi_breached_at_earliest': len(kpis_at_earliest),
    'kpi_names_at_earliest_timestamp': kpis_at_earliest
}])

# Display the compact results (top10 and earliest summary)
top10_timestamps, earliest_summary
