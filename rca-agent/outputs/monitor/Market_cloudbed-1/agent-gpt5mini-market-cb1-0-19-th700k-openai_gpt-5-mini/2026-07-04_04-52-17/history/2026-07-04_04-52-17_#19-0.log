import pandas as pd
import pytz

# reuse tz if present
try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# load log.csv (reuse variable if exists)
try:
    log_df
except NameError:
    log_df = pd.read_csv("log.csv")

# 1) Identify distinct cmdb_id values that contain 'adservice' (case-sensitive) and counts
ad_mask_all = log_df['cmdb_id'].astype(str).str.contains('adservice', na=False)
ad_counts_series = log_df.loc[ad_mask_all, 'cmdb_id'].value_counts()

if ad_counts_series.empty:
    ad_counts = pd.DataFrame(columns=['cmdb_id', 'row_count'])
else:
    ad_counts = ad_counts_series.reset_index().rename(columns={'index': 'cmdb_id', 'cmdb_id': 'row_count'})

# 2) Filter to incident window and only adservice-related cmdb_ids
start_local = pd.Timestamp("2022-03-20 19:30:00", tz=tz)
end_local   = pd.Timestamp("2022-03-20 20:00:00", tz=tz)
start_epoch = int(start_local.tz_convert('UTC').timestamp())
end_epoch   = int(end_local.tz_convert('UTC').timestamp())

ad_cmdb_ids = ad_counts['cmdb_id'].tolist() if not ad_counts.empty else []

window_logs = log_df[
    (log_df['timestamp'] >= start_epoch) &
    (log_df['timestamp'] <= end_epoch) &
    (log_df['cmdb_id'].isin(ad_cmdb_ids))
].copy()

# If no adservice-related rows in the window, prepare empty outputs
if window_logs.empty:
    agg_top20 = pd.DataFrame(columns=[
        'cmdb_id', 'total_points_in_window', 'sum_log_error_count',
        'max_log_error_count', 'earliest_timestamp_with_log_error_count_gt0', 'avg_log_row_count'
    ])
    raw_rows = pd.DataFrame(columns=['timestamp', 'cmdb_id', 'log_name', 'value'])
else:
    # 3) For each adservice-related cmdb_id compute aggregates
    # total_points_in_window (all log rows)
    total_points = (
        window_logs.groupby('cmdb_id', as_index=False)
        .agg(total_points_in_window=('timestamp', 'size'))
    )

    # sum and max of log.error_count per cmdb_id
    error_rows = window_logs[window_logs['log_name'] == 'log.error_count']
    if not error_rows.empty:
        err_agg = (
            error_rows.groupby('cmdb_id', as_index=False)
            .agg(
                sum_log_error_count=('value', 'sum'),
                max_log_error_count=('value', 'max')
            )
        )
    else:
        err_agg = pd.DataFrame({'cmdb_id': ad_cmdb_ids, 'sum_log_error_count': 0, 'max_log_error_count': 0.0})

    # earliest timestamp with log.error_count > 0
    err_pos = error_rows[error_rows['value'] > 0]
    if not err_pos.empty:
        earliest_err = (
            err_pos.groupby('cmdb_id', as_index=False)
            .agg(earliest_error_ts_unix=('timestamp', 'min'))
        )
    else:
        earliest_err = pd.DataFrame(columns=['cmdb_id', 'earliest_error_ts_unix'])

    # average log.row_count per cmdb_id
    rowcount_rows = window_logs[window_logs['log_name'] == 'log.row_count']
    if not rowcount_rows.empty:
        avg_rowcount = (
            rowcount_rows.groupby('cmdb_id', as_index=False)
            .agg(avg_log_row_count=('value', 'mean'))
        )
    else:
        avg_rowcount = pd.DataFrame({'cmdb_id': ad_cmdb_ids, 'avg_log_row_count': 0.0})

    # Merge all aggregates
    agg = total_points.merge(err_agg, on='cmdb_id', how='left') \
                      .merge(earliest_err, on='cmdb_id', how='left') \
                      .merge(avg_rowcount, on='cmdb_id', how='left')

    # fill NaNs
    agg['sum_log_error_count'] = agg['sum_log_error_count'].fillna(0).astype(int)
    agg['max_log_error_count'] = agg['max_log_error_count'].fillna(0).astype(float)
    agg['avg_log_row_count'] = agg['avg_log_row_count'].fillna(0.0)

    # convert earliest unix ts to ISO Asia/Shanghai or None
    def to_iso_local(x):
        if pd.isna(x):
            return None
        try:
            return pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).isoformat()
        except Exception:
            return None

    agg['earliest_timestamp_with_log_error_count_gt0'] = agg['earliest_error_ts_unix'].apply(to_iso_local) if 'earliest_error_ts_unix' in agg.columns else None
    if 'earliest_error_ts_unix' in agg.columns:
        agg = agg.drop(columns=['earliest_error_ts_unix'])

    # 4) Prepare compact table sorted by sum_log_error_count desc, top 20
    agg_top20 = agg.sort_values(by=['sum_log_error_count', 'total_points_in_window'], ascending=[False, False]).reset_index(drop=True).head(20)

    # Also return up to 20 raw log rows for adservice-related cmdb_ids within the window (include timestamp ISO)
    raw_rows = window_logs.loc[:, ['timestamp', 'cmdb_id', 'log_name', 'value']].copy()
    raw_rows['timestamp'] = raw_rows['timestamp'].apply(lambda t: pd.to_datetime(int(t), unit='s', utc=True).tz_convert(tz).isoformat())
    raw_rows = raw_rows.sort_values(by=['timestamp', 'cmdb_id']).head(20).reset_index(drop=True)

# Final compact outputs (JSON-serializable)
ad_counts, agg_top20, raw_rows
