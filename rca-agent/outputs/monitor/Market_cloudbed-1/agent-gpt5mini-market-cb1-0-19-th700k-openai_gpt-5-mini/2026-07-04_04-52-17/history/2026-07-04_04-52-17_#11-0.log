import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse metric DataFrame from kernel; ensure dt exists
if 'dt' not in metric.columns:
    metric['dt'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Rule 9: compute global P95 across the full metric series BEFORE filtering
global_p95_df = (
    metric
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
    .quantile(0.95)
    .rename(columns={'value': 'global_P95'})
)

# Merge global P95 into a working dataframe
metric_p = metric.merge(global_p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# Define UTC+8 inclusive window
start = pd.Timestamp('2022-03-20 14:00:00', tz=tz)
end = pd.Timestamp('2022-03-20 14:30:00', tz=tz)
start_iso = start.strftime('%Y-%m-%dT%H:%M:%S%z')

# Filter to the window
win = metric_p[(metric_p['dt'] >= start) & (metric_p['dt'] <= end)].copy()

# Aggregate basic per-pair window stats (points and max)
points_agg = (
    win
    .groupby(['cmdb_id', 'kpi_name'], as_index=False)
    .agg(
        points_in_window=('value', 'size'),
        max_value_in_window=('value', 'max')
    )
)

# Detect anomaly points (value >= global_P95)
win['is_anomaly'] = win['value'] >= win['global_P95']

# Subset anomaly points
anom = win[win['is_anomaly']].copy()

if anom.empty:
    # No anomalies in window at all -> empty result
    final_df = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','global_P95','points_in_window','total_segments_for_pair',
        'earliest_anomaly_timestamp_in_window','first_segment_start','first_segment_end',
        'first_segment_duration_minutes','second_segment_start','second_segment_end',
        'second_segment_duration_minutes','max_value_in_window','severity_ratio'
    ])
else:
    # Sort and compute consecutive-minute breaks (60s)
    anom = anom.sort_values(['cmdb_id','kpi_name','timestamp']).reset_index(drop=True)
    anom['prev_ts'] = anom.groupby(['cmdb_id','kpi_name'])['timestamp'].shift(1)
    anom['ts_diff'] = anom['timestamp'] - anom['prev_ts']
    anom['new_segment'] = (anom['prev_ts'].isna()) | (anom['ts_diff'] != 60)
    anom['segment_id'] = anom.groupby(['cmdb_id','kpi_name'])['new_segment'].cumsum()

    # Build segments dataframe
    segs = (
        anom
        .groupby(['cmdb_id','kpi_name','segment_id'], as_index=False)
        .agg(
            fault_start_ts_epoch=('timestamp','min'),
            fault_end_ts_epoch=('timestamp','max'),
            points_in_segment=('timestamp','size'),
            max_value_in_segment=('value','max')
        )
    )

    # Helper to convert epoch -> ISO+08:00
    def epoch_to_iso_series(s):
        return pd.to_datetime(s, unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%dT%H:%M:%S%z')

    segs['fault_start_iso'] = epoch_to_iso_series(segs['fault_start_ts_epoch'])
    segs['fault_end_iso'] = epoch_to_iso_series(segs['fault_end_ts_epoch'])

    # Compute per-pair segment summaries (take first two segments)
    def pick_first_two(g):
        g = g.sort_values('fault_start_ts_epoch').reset_index(drop=True)
        total = g.shape[0]
        first_start = g.loc[0, 'fault_start_iso']
        first_end = g.loc[0, 'fault_end_iso']
        first_dur = int(g.loc[0, 'points_in_segment'])
        second_start = pd.NA
        second_end = pd.NA
        second_dur = pd.NA
        if total > 1:
            second_start = g.loc[1, 'fault_start_iso']
            second_end = g.loc[1, 'fault_end_iso']
            second_dur = int(g.loc[1, 'points_in_segment'])
        return pd.Series({
            'total_segments_for_pair': int(total),
            'earliest_anomaly_ts_epoch': int(g.loc[0, 'fault_start_ts_epoch']),
            'earliest_anomaly_timestamp_in_window': first_start,
            'first_segment_start': first_start,
            'first_segment_end': first_end,
            'first_segment_duration_minutes': first_dur,
            'second_segment_start': second_start,
            'second_segment_end': second_end,
            'second_segment_duration_minutes': second_dur
        })

    per_pair_segs = segs.groupby(['cmdb_id','kpi_name']).apply(pick_first_two).reset_index()

    # Merge with points_agg and global_p95_df to get required fields
    merged = per_pair_segs.merge(points_agg, on=['cmdb_id','kpi_name'], how='left') \
                          .merge(global_p95_df, on=['cmdb_id','kpi_name'], how='left')

    # max_value_in_window may be NaN if no points in window (but we only have pairs with anomalies -> points exist)
    # For safety, fill max_value_in_window from win aggregation if missing
    merged['max_value_in_window'] = merged['max_value_in_window'].fillna(merged['max_value_in_segment'] if 'max_value_in_segment' in merged.columns else np.nan)

    # Compute severity_ratio with handling global_P95 == 0 or NaN
    merged['severity_ratio'] = np.where(
        (merged['global_P95'] == 0) | (merged['global_P95'].isna()),
        np.nan,
        merged['max_value_in_window'] / merged['global_P95']
    )

    # Format earliest_anomaly_timestamp_in_window already present; ensure NA where appropriate
    merged['earliest_anomaly_timestamp_in_window'] = merged['earliest_anomaly_timestamp_in_window'].fillna(pd.NA)

    # Select required columns
    final_df = merged[
        [
            'cmdb_id','kpi_name','global_P95','points_in_window','total_segments_for_pair',
            'earliest_anomaly_timestamp_in_window','first_segment_start','first_segment_end',
            'first_segment_duration_minutes','second_segment_start','second_segment_end',
            'second_segment_duration_minutes','max_value_in_window','severity_ratio'
        ]
    ].copy()

    # Filter: only keep rows where total_segments_for_pair > 1 OR earliest_anomaly_timestamp_in_window != start_iso
    cond = (final_df['total_segments_for_pair'] > 1) | (final_df['earliest_anomaly_timestamp_in_window'] != start_iso)
    final_df = final_df[cond].reset_index(drop=True)

    # Sorting: total_segments desc, then earliest_anomaly_timestamp_in_window asc (NA last)
    final_df = final_df.sort_values(
        by=['total_segments_for_pair', 'earliest_anomaly_timestamp_in_window'],
        ascending=[False, True],
        na_position='last'
    ).head(20).reset_index(drop=True)

    # Round numeric columns for compactness
    final_df['global_P95'] = final_df['global_P95'].round(6)
    final_df['max_value_in_window'] = final_df['max_value_in_window'].round(6)
    final_df['severity_ratio'] = final_df['severity_ratio'].round(6)

# Show compact result (top up to 20 rows)
final_df
