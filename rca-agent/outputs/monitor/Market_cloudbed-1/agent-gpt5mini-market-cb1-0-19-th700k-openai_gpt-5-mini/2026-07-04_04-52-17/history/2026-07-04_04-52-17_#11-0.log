import pandas as pd
import numpy as np
import pytz

# reuse existing DataFrames/variables from kernel if present: metric, global_p95_df
tz = pytz.timezone('Asia/Shanghai')

# Ensure metric has timezone-aware datetime column
if 'dt' not in metric.columns:
    metric['dt'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Ensure global_p95_df exists (compute if not)
if 'global_P95' not in globals() or 'global_p95_df' not in globals():
    global_p95_df = (
        metric
        .groupby(['cmdb_id', 'kpi_name'], as_index=False)['value']
        .quantile(0.95)
        .rename(columns={'value': 'global_P95'})
    )

# Merge global P95 into metric (reuse variable if exists)
metric_with_p95 = metric.merge(global_p95_df, on=['cmdb_id', 'kpi_name'], how='left')

# Define UTC+8 inclusive window
start = pd.Timestamp('2022-03-20 14:00:00', tz=tz)
end = pd.Timestamp('2022-03-20 14:30:00', tz=tz)

# Filter to window once for efficiency
win = metric_with_p95[(metric_with_p95['dt'] >= start) & (metric_with_p95['dt'] <= end)].copy()

# Prepare minute ticks (inclusive)
minutes = pd.date_range(start=start, end=end, freq='T', tz=tz)

rows = []
for minute in minutes:
    # Select rows exactly at this minute
    win_min = win[win['dt'] == minute]
    if win_min.empty:
        anomalous_count = 0
        top5_str = []
    else:
        # Determine anomaly rows where value >= global_P95 (global thresholds precomputed)
