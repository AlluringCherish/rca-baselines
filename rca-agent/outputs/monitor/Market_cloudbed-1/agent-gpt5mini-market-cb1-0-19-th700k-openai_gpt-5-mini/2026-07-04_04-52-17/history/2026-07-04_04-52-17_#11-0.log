        .nunique()
        .reset_index(name='anomalous_pairs_count')
    )
else:
    anom_counts = pd.DataFrame(columns=['timestamp','anomalous_pairs_count'])

# Merge counts into minute_df (fill missing with 0)
per_min_df = minute_df.merge(anom_counts, left_on='timestamp_epoch', right_on='timestamp', how='left')
per_min_df['anomalous_pairs_count'] = per_min_df['anomalous_pairs_count'].fillna(0).astype(int)
