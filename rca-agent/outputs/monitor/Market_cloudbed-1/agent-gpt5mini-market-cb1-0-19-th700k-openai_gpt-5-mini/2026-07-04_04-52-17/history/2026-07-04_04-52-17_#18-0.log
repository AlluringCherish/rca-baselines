import pandas as pd
import pytz

# Load CSV files into DataFrames (keep full dataframes in memory for next steps)
metric_df = pd.read_csv('metric.csv')
trace_df = pd.read_csv('trace.csv')
log_df = pd.read_csv('log.csv')
error_logs_df = pd.read_csv('error_logs.csv')

# --- metric.csv summaries ---
metric_cmdb_ids = pd.Series(sorted(metric_df['cmdb_id'].dropna().unique())[:50], name='cmdb_id')
metric_kpis = pd.Series(sorted(metric_df['kpi_name'].dropna().unique())[:50], name='kpi_name')
metric_top20 = (
    metric_df.groupby('cmdb_id')
    .size()
    .rename('count')
    .reset_index()
    .sort_values('count', ascending=False)
    .head(20)
)

# --- trace.csv summaries ---
trace_cmdb_ids = pd.Series(sorted(trace_df['cmdb_id'].dropna().unique())[:50], name='cmdb_id')
trace_names = pd.Series(sorted(trace_df['trace_name'].dropna().unique())[:50], name='trace_name')
trace_top20 = (
    trace_df.groupby('cmdb_id')
    .size()
    .rename('count')
    .reset_index()
    .sort_values('count', ascending=False)
    .head(20)
)

# --- log.csv summaries ---
log_cmdb_ids = pd.Series(sorted(log_df['cmdb_id'].dropna().unique())[:50], name='cmdb_id')
log_names = pd.Series(sorted(log_df['log_name'].dropna().unique())[:50], name='log_name')
log_top20 = (
    log_df.groupby('cmdb_id')
    .size()
    .rename('count')
    .reset_index()
    .sort_values('count', ascending=False)
    .head(20)
)

# --- error_logs.csv summaries ---
error_cmdb_ids = pd.Series(sorted(error_logs_df['cmdb_id'].dropna().unique()), name='cmdb_id')
error_total_count = len(error_logs_df)
error_samples = error_logs_df[['timestamp', 'cmdb_id', 'message']].copy()
# Truncate message to 200 chars for compact display
error_samples['message'] = error_samples['message'].astype(str).str.slice(0, 200)
error_samples = error_samples.head(10)

# Display compact labeled summaries (variables below will be the cell output)
metric_cmdb_ids, metric_kpis, metric_top20, trace_cmdb_ids, trace_names, trace_top20, log_cmdb_ids, log_names, log_top20, error_cmdb_ids, error_total_count, error_samples
