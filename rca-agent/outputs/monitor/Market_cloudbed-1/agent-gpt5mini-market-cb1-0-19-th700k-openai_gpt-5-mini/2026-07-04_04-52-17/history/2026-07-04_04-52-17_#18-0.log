import numpy as np
import pandas as pd

# Reuse existing variables: metric_df, metric_group_stats
# Compute P05 for each (cmdb_id, kpi_name) on the full series (global threshold)
metric_p05 = (
    metric_df.groupby(['cmdb_id', 'kpi_name'])['value']
    .quantile(0.05)
    .reset_index(name='p05')
)

# Merge P05 into metric_group_stats (which already contains p95, total_count, window_count, etc.)
metric_group_stats = metric_group_stats.merge(metric_p05, on=['cmdb_id', 'kpi_name'], how='left')

# Incident window bounds (already used earlier): start_ts, end_ts assumed present in kernel
# If not present, define them (UTC+8 window 2022-03-20 19:00 to 19:30)
try:
    start_ts, end_ts
except NameError:
    import pytz
    from datetime import datetime
    tz = pytz.timezone('Asia/Shanghai')
    window_start_local = tz.localize(datetime(2022, 3, 20, 19, 0, 0))
    window_end_local = tz.localize(datetime(2022, 3, 20, 19, 30, 0))
    start_ts = int(window_start_local.astimezone(pytz.utc).timestamp())
    end_ts = int(window_end_local.astimezone(pytz.utc).timestamp())

# Prepare container for per-group anomaly summaries
rows = []

# Limit to groups that had data in window (window_count > 0)
groups_in_window = metric_group_stats[metric_group_stats['window_count'] > 0].copy()

# For efficient lookups, index metric_df by group keys
# We'll iterate groups_in_window rows
for _, g in groups_in_window.iterrows():
    cmdb = g['cmdb_id']
    kpi = g['kpi_name']
    p95 = float(g['p95'])
    p05 = float(g['p05']) if not pd.isna(g['p05']) else np.nan
    total_count = int(g['total_count'])
    window_count = int(g['window_count'])

    # Filter window points for this group
    mask_group = (metric_df['cmdb_id'] == cmdb) & (metric_df['kpi_name'] == kpi)
    win_mask = mask_group & (metric_df['timestamp'] >= start_ts) & (metric_df['timestamp'] <= end_ts)
    df_win = metric_df.loc[win_mask, ['timestamp', 'value']].sort_values('timestamp').reset_index(drop=True)

    # init anomaly metrics
    anomaly_count_high = 0
    first_anomaly_ts_high = np.nan
    max_value_in_window = np.nan
    max_severity_high = 0.0
    longest_consec_high = 0
    first_consec_high_ts = np.nan

    anomaly_count_low = 0
    first_anomaly_ts_low = np.nan
    min_value_in_window = np.nan
    max_severity_low = 0.0
    longest_consec_low = 0
    first_consec_low_ts = np.nan

    if not df_win.empty:
        vals = df_win['value'].values
        ts = df_win['timestamp'].values

        # High-side anomalies: value > p95
        high_mask = vals > p95
        anomaly_count_high = int(np.sum(high_mask))
        if anomaly_count_high > 0:
            first_anomaly_ts_high = int(ts[np.where(high_mask)[0][0]])
            max_value_in_window = float(vals.max())
            # severity: (max_value - P95)/P95
            if p95 == 0:
                # mark infinite severity if numerator positive
                if max_value_in_window > 0:
                    max_severity_high = np.inf
                else:
                    max_severity_high = 0.0
            else:
                max_severity_high = float((max_value_in_window - p95) / p95)

            # longest consecutive run of high_mask
            df_run = pd.DataFrame({'mask': high_mask, 'timestamp': ts})
            df_run['grp'] = (df_run['mask'] != df_run['mask'].shift(1)).cumsum()
            high_runs = df_run[df_run['mask']].groupby('grp').agg(run_len=('mask', 'size'), start_ts=('timestamp', 'min')).reset_index()
            if not high_runs.empty:
                best = high_runs.sort_values(['run_len', 'start_ts'], ascending=[False, True]).iloc[0]
                longest_consec_high = int(best['run_len'])
                first_consec_high_ts = int(best['start_ts'])

        else:
            # set max_value_in_window/min_value_in_window even if no high anomalies
            max_value_in_window = float(vals.max())

        # Low-side anomalies: value <= p05
        low_mask = vals <= p05
        anomaly_count_low = int(np.sum(low_mask))
        if anomaly_count_low > 0:
            first_anomaly_ts_low = int(ts[np.where(low_mask)[0][0]])
            min_value_in_window = float(vals.min())
            denom = max(abs(p05), 1e-9)
            max_severity_low = float((p05 - min_value_in_window) / denom)

            # longest consecutive run of low_mask
            df_run = pd.DataFrame({'mask': low_mask, 'timestamp': ts})
            df_run['grp'] = (df_run['mask'] != df_run['mask'].shift(1)).cumsum()
            low_runs = df_run[df_run['mask']].groupby('grp').agg(run_len=('mask', 'size'), start_ts=('timestamp', 'min')).reset_index()
            if not low_runs.empty:
                bestl = low_runs.sort_values(['run_len', 'start_ts'], ascending=[False, True]).iloc[0]
                longest_consec_low = int(bestl['run_len'])
                first_consec_low_ts = int(bestl['start_ts'])
        else:
            # ensure min_value_in_window is set
            min_value_in_window = float(vals.min())

    # Append summary row
    rows.append({
        'cmdb_id': cmdb,
        'kpi_name': kpi,
        'p95': p95,
        'p05': p05,
        'total_count': total_count,
        'window_count': window_count,
        'anomaly_count_high': anomaly_count_high,
        'first_anomaly_ts_high': (int(first_anomaly_ts_high) if not pd.isna(first_anomaly_ts_high) else np.nan),
        'max_value_in_window': (float(max_value_in_window) if not pd.isna(max_value_in_window) else np.nan),
        'max_severity_high': max_severity_high,
        'longest_consec_high': longest_consec_high,
        'first_consec_high_ts': (int(first_consec_high_ts) if not pd.isna(first_consec_high_ts) else np.nan),
        'anomaly_count_low': anomaly_count_low,
        'first_anomaly_ts_low': (int(first_anomaly_ts_low) if not pd.isna(first_anomaly_ts_low) else np.nan),
        'min_value_in_window': (float(min_value_in_window) if not pd.isna(min_value_in_window) else np.nan),
        'max_severity_low': max_severity_low,
        'longest_consec_low': longest_consec_low,
        'first_consec_low_ts': (int(first_consec_low_ts) if not pd.isna(first_consec_low_ts) else np.nan)
    })

# Build DataFrame of anomaly summaries
metric_anomaly_stats = pd.DataFrame(rows)

# Identify groups with any anomaly (high or low)
metric_anomaly_stats['any_anomaly'] = (metric_anomaly_stats['anomaly_count_high'] > 0) | (metric_anomaly_stats['anomaly_count_low'] > 0)
metric_anomaly_any = metric_anomaly_stats[metric_anomaly_stats['any_anomaly']].copy()

# Count of metric groups with any anomaly
metric_groups_with_any_anomaly = int(metric_anomaly_any.shape[0])

# If there are anomalies, prepare top20 sorted by longest_consec_high desc then max_severity_high desc
if metric_groups_with_any_anomaly > 0:
    metric_anomaly_top20 = (
        metric_anomaly_any
        .sort_values(['longest_consec_high', 'max_severity_high'], ascending=[False, False])
        .loc[:, ['cmdb_id', 'kpi_name', 'p95', 'p05', 'total_count', 'window_count',
                 'anomaly_count_high', 'first_anomaly_ts_high', 'max_value_in_window', 'max_severity_high',
                 'longest_consec_high', 'first_consec_high_ts',
                 'anomaly_count_low', 'first_anomaly_ts_low', 'min_value_in_window', 'max_severity_low',
                 'longest_consec_low', 'first_consec_low_ts']]
        .head(20)
        .reset_index(drop=True)
    )
else:
    # empty DataFrame with columns for explicit empty indication
    metric_anomaly_top20 = pd.DataFrame(columns=[
        'cmdb_id', 'kpi_name', 'p95', 'p05', 'total_count', 'window_count',
        'anomaly_count_high', 'first_anomaly_ts_high', 'max_value_in_window', 'max_severity_high',
        'longest_consec_high', 'first_consec_high_ts',
        'anomaly_count_low', 'first_anomaly_ts_low', 'min_value_in_window', 'max_severity_low',
        'longest_consec_low', 'first_consec_low_ts'
    ])

# Final compact outputs for the kernel (store full metric_anomaly_stats and show top20 + count)
metric_anomaly_top20, metric_groups_with_any_anomaly, metric_anomaly_stats.shape
