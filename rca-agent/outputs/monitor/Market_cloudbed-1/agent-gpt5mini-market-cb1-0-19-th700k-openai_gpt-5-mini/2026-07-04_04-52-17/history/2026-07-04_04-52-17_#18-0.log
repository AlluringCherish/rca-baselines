import pandas as pd
import pytz
from datetime import datetime

# Reuse already loaded dataframes: metric_df, trace_df, log_df, error_logs_df

# 1) define incident window in UTC+8 (Asia/Shanghai) and convert to epoch seconds (UTC)
tz = pytz.timezone('Asia/Shanghai')
window_start_local = tz.localize(datetime(2022, 3, 20, 19, 0, 0))
window_end_local = tz.localize(datetime(2022, 3, 20, 19, 30, 0))
# epoch seconds (UTC) for filtering the timestamp columns
start_ts = int(window_start_local.astimezone(pytz.utc).timestamp())
end_ts = int(window_end_local.astimezone(pytz.utc).timestamp())

# --- Helper function to compute group-level p95 and counts (global), then window-level stats ---
def compute_group_stats(full_df, group_cols, value_col='value'):
    # global p95 and total_count (calculated on full series BEFORE window filtering)
    grouped = (
        full_df.groupby(group_cols)[value_col]
        .agg(p95=lambda x: x.quantile(0.95), total_count='count')
        .reset_index()
    )
    # window-filtered df
    window_df = full_df[(full_df['timestamp'] >= start_ts) & (full_df['timestamp'] <= end_ts)]
    # compute window stats
    window_stats = (
        window_df.groupby(group_cols)
        .agg(window_count=(value_col, 'count'),
             earliest_window_ts=('timestamp', 'min'),
             latest_window_ts=('timestamp', 'max'))
        .reset_index()
    )
    # merge and fill window_count with 0 when missing; keep timestamps as NaN when no data
    merged = grouped.merge(window_stats, on=group_cols, how='left')
    merged['window_count'] = merged['window_count'].fillna(0).astype(int)
    return merged

# --- Metric groups ---
metric_group_stats = compute_group_stats(metric_df, ['cmdb_id', 'kpi_name'], value_col='value')
# top 20 by window_count
metric_summary_top20 = (
    metric_group_stats.sort_values('window_count', ascending=False)
    .loc[:, ['cmdb_id', 'kpi_name', 'p95', 'total_count', 'window_count', 'earliest_window_ts', 'latest_window_ts']]
    .head(20)
)
metric_groups_with_window_count = int((metric_group_stats['window_count'] > 0).sum())

# --- Trace groups ---
trace_group_stats = compute_group_stats(trace_df, ['cmdb_id', 'trace_name'], value_col='value')
trace_summary_top20 = (
    trace_group_stats.sort_values('window_count', ascending=False)
    .loc[:, ['cmdb_id', 'trace_name', 'p95', 'total_count', 'window_count', 'earliest_window_ts', 'latest_window_ts']]
    .head(20)
)
trace_groups_with_window_count = int((trace_group_stats['window_count'] > 0).sum())

# --- Log groups ---
log_group_stats = compute_group_stats(log_df, ['cmdb_id', 'log_name'], value_col='value')
log_summary_top20 = (
    log_group_stats.sort_values('window_count', ascending=False)
    .loc[:, ['cmdb_id', 'log_name', 'p95', 'total_count', 'window_count', 'earliest_window_ts', 'latest_window_ts']]
    .head(20)
)
log_groups_with_window_count = int((log_group_stats['window_count'] > 0).sum())

# --- Error logs in window ---
error_total_count = len(error_logs_df)
error_in_window = error_logs_df[(error_logs_df['timestamp'] >= start_ts) & (error_logs_df['timestamp'] <= end_ts)].copy()
# truncate message to 200 chars for compact display
if not error_in_window.empty:
    error_in_window['message'] = error_in_window['message'].astype(str).str.slice(0, 200)
    error_window_rows_display = error_in_window.loc[:, ['timestamp', 'cmdb_id', 'message']].head(20)
else:
    # empty DataFrame with expected columns for explicit empty indication
    error_window_rows_display = pd.DataFrame(columns=['timestamp', 'cmdb_id', 'message'])

# Final compact outputs (these variables will be shown by the IPython Kernel)
metric_summary_top20, metric_groups_with_window_count, trace_summary_top20, trace_groups_with_window_count, log_summary_top20, log_groups_with_window_count, error_total_count, error_window_rows_display
