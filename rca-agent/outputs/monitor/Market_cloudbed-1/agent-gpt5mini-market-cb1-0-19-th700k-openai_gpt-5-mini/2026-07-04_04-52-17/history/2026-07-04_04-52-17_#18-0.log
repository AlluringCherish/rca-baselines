import numpy as np
import pandas as pd

# Reuse existing kernel variables: trace_df, trace_group_stats, start_ts, end_ts
# Do not overwrite trace_group_stats; create a merged copy for P05
trace_p05 = (
    trace_df.groupby(['cmdb_id', 'trace_name'])['value']
    .quantile(0.05)
    .reset_index(name='p05')
)

trace_group_stats2 = trace_group_stats.merge(trace_p05, on=['cmdb_id', 'trace_name'], how='left')

# Prepare container for per-group anomaly summaries
rows = []

# Limit to groups that had data in window (window_count > 0)
groups_in_window = trace_group_stats2[trace_group_stats2['window_count'] > 0].copy()

# Iterate groups and compute anomalies within the window
for _, g in groups_in_window.iterrows():
    cmdb = g['cmdb_id']
    trace_name = g['trace_name']
    p95 = float(g['p95'])
    p05 = float(g['p05']) if not pd.isna(g['p05']) else np.nan
    total_count = int(g['total_count'])
    window_count = int(g['window_count'])

    # Filter window points for this group
    mask_group = (trace_df['cmdb_id'] == cmdb) & (trace_df['trace_name'] == trace_name)
    win_mask = mask_group & (trace_df['timestamp'] >= start_ts) & (trace_df['timestamp'] <= end_ts)
    df_win = trace_df.loc[win_mask, ['timestamp', 'value']].sort_values('timestamp').reset_index(drop=True)

    # initialize anomaly metrics
    anomaly_count_high = 0
    first_anomaly_ts_high = np.nan
    max_value_in_window = np.nan
    max_severity_high = 0.0
    longest_consec_high = 0
    first_consec_high_ts = np.nan

    anomaly_count_low = 0
    first_anomaly_ts_low = np.nan
    min_value_in_window = np.nan
    max_severity_low = 0.0
    longest_consec_low = 0
    first_consec_low_ts = np.nan

    if not df_win.empty:
        vals = df_win['value'].values
        ts = df_win['timestamp'].values

        # High-side anomalies: value > p95
        high_mask = vals > p95
        anomaly_count_high = int(np.sum(high_mask))
        if anomaly_count_high > 0:
            first_anomaly_ts_high = int(ts[np.where(high_mask)[0][0]])
            max_value_in_window = float(vals.max())
            if p95 == 0:
                max_severity_high = np.inf if max_value_in_window > 0 else 0.0
            else:
                max_severity_high = float((max_value_in_window - p95) / p95)

            # longest consecutive run of high_mask
            df_run = pd.DataFrame({'mask': high_mask, 'timestamp': ts})
            df_run['grp'] = (df_run['mask'] != df_run['mask'].shift(1)).cumsum()
            high_runs = df_run[df_run['mask']].groupby('grp').agg(run_len=('mask', 'size'), start_ts=('timestamp', 'min')).reset_index()
            if not high_runs.empty:
                best = high_runs.sort_values(['run_len', 'start_ts'], ascending=[False, True]).iloc[0]
                longest_consec_high = int(best['run_len'])
                first_consec_high_ts = int(best['start_ts'])
        else:
            max_value_in_window = float(vals.max())

        # Low-side anomalies: value <= p05
        low_mask = vals <= p05
        anomaly_count_low = int(np.sum(low_mask))
        if anomaly_count_low > 0:
            first_anomaly_ts_low = int(ts[np.where(low_mask)[0][0]])
            min_value_in_window = float(vals.min())
            denom = max(abs(p05), 1e-9)
            max_severity_low = float((p05 - min_value_in_window) / denom)

            # longest consecutive run of low_mask
            df_run = pd.DataFrame({'mask': low_mask, 'timestamp': ts})
            df_run['grp'] = (df_run['mask'] != df_run['mask'].shift(1)).cumsum()
            low_runs = df_run[df_run['mask']].groupby('grp').agg(run_len=('mask', 'size'), start_ts=('timestamp', 'min')).reset_index()
            if not low_runs.empty:
                bestl = low_runs.sort_values(['run_len', 'start_ts'], ascending=[False, True]).iloc[0]
                longest_consec_low = int(bestl['run_len'])
                first_consec_low_ts = int(bestl['start_ts'])
        else:
            min_value_in_window = float(vals.min())

    # Append summary row
    rows.append({
        'cmdb_id': cmdb,
        'trace_name': trace_name,
        'p95': p95,
        'p05': p05,
        'total_count': total_count,
        'window_count': window_count,
        'anomaly_count_high': anomaly_count_high,
        'first_anomaly_ts_high': (int(first_anomaly_ts_high) if not pd.isna(first_anomaly_ts_high) else np.nan),
        'max_value_in_window': (float(max_value_in_window) if not pd.isna(max_value_in_window) else np.nan),
        'max_severity_high': max_severity_high,
        'longest_consec_high': longest_consec_high,
        'first_consec_high_ts': (int(first_consec_high_ts) if not pd.isna(first_consec_high_ts) else np.nan),
        'anomaly_count_low': anomaly_count_low,
        'first_anomaly_ts_low': (int(first_anomaly_ts_low) if not pd.isna(first_anomaly_ts_low) else np.nan),
        'min_value_in_window': (float(min_value_in_window) if not pd.isna(min_value_in_window) else np.nan),
