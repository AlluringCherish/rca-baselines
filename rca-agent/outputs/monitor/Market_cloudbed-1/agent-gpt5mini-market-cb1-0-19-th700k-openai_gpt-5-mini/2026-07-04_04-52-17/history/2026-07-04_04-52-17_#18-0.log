import numpy as np
import pandas as pd

# Reuse kernel variables: metric_anomaly_stats, log_df, error_logs_df, start_ts, end_ts
# 1) Extract pods with metric anomalies where kpi_name contains 'container.node-6'
pods_on_node6 = (
    metric_anomaly_stats[
        metric_anomaly_stats['any_anomaly'] & metric_anomaly_stats['kpi_name'].str.contains('container.node-6', na=False)
    ]['cmdb_id']
    .dropna()
    .astype(str)
    .sort_values()
    .unique()
)
# limit to 50
pods_on_node6 = pd.Series(pods_on_node6[:50], name='cmdb_id')

# 2) For log.csv: compute global P95 and P05 per (cmdb_id, log_name) using full series
log_p95 = log_df.groupby(['cmdb_id', 'log_name'])['value'].quantile(0.95).reset_index(name='p95')
log_p05 = log_df.groupby(['cmdb_id', 'log_name'])['value'].quantile(0.05).reset_index(name='p05')
log_group_meta = log_p95.merge(log_p05, on=['cmdb_id', 'log_name'], how='outer')

# Restrict to groups whose cmdb_id is in pods_on_node6
log_group_meta = log_group_meta[log_group_meta['cmdb_id'].isin(pods_on_node6.values)].copy()

# Prepare container for per-group log anomaly summaries
rows = []

# Pre-filter log_df to the pod set and window to speed repeated filtering
log_df_pods = log_df[log_df['cmdb_id'].isin(pods_on_node6.values)].copy()

# Iterate groups in meta
for _, g in log_group_meta.iterrows():
    cmdb = g['cmdb_id']
    log_name = g['log_name']
    p95 = float(g['p95'])
    p05 = float(g['p05'])
    # total_count on full series
    total_count = int(log_df[(log_df['cmdb_id'] == cmdb) & (log_df['log_name'] == log_name)].shape[0])

    # window points
    mask_group = (log_df_pods['cmdb_id'] == cmdb) & (log_df_pods['log_name'] == log_name)
    win_mask = mask_group & (log_df_pods['timestamp'] >= start_ts) & (log_df_pods['timestamp'] <= end_ts)
    df_win = log_df_pods.loc[win_mask, ['timestamp', 'value']].sort_values('timestamp').reset_index(drop=True)

    window_count = int(df_win.shape[0])

    # init anomaly metrics
    anomaly_count_high = 0
    first_anomaly_ts_high = np.nan
    max_value_in_window = np.nan
    max_severity_high = 0.0
    longest_consec_high = 0
    first_consec_high_ts = np.nan

    anomaly_count_low = 0
    first_anomaly_ts_low = np.nan
    min_value_in_window = np.nan
    max_severity_low = 0.0
    longest_consec_low = 0
    first_consec_low_ts = np.nan

    if not df_win.empty:
        vals = df_win['value'].values
        ts = df_win['timestamp'].values

        # high anomalies: value > p95
        high_mask = vals > p95
        anomaly_count_high = int(np.sum(high_mask))
        if anomaly_count_high > 0:
            first_anomaly_ts_high = int(ts[np.where(high_mask)[0][0]])
            max_value_in_window = float(vals.max())
            if p95 == 0:
                max_severity_high = np.inf if max_value_in_window > 0 else 0.0
            else:
                max_severity_high = float((max_value_in_window - p95) / p95)
            # longest consecutive high run
            df_run = pd.DataFrame({'mask': high_mask, 'timestamp': ts})
            df_run['grp'] = (df_run['mask'] != df_run['mask'].shift(1)).cumsum()
            high_runs = df_run[df_run['mask']].groupby('grp').agg(run_len=('mask','size'), start_ts=('timestamp','min')).reset_index()
            if not high_runs.empty:
                best = high_runs.sort_values(['run_len','start_ts'], ascending=[False, True]).iloc[0]
                longest_consec_high = int(best['run_len'])
                first_consec_high_ts = int(best['start_ts'])
        else:
            max_value_in_window = float(vals.max())

        # low anomalies: value <= p05
        low_mask = vals <= p05
        anomaly_count_low = int(np.sum(low_mask))
        if anomaly_count_low > 0:
            first_anomaly_ts_low = int(ts[np.where(low_mask)[0][0]])
            min_value_in_window = float(vals.min())
            denom = max(abs(p05), 1e-9)
            max_severity_low = float((p05 - min_value_in_window) / denom)
            # longest consecutive low run
            df_run = pd.DataFrame({'mask': low_mask, 'timestamp': ts})
            df_run['grp'] = (df_run['mask'] != df_run['mask'].shift(1)).cumsum()
            low_runs = df_run[df_run['mask']].groupby('grp').agg(run_len=('mask','size'), start_ts=('timestamp','min')).reset_index()
            if not low_runs.empty:
                bestl = low_runs.sort_values(['run_len','start_ts'], ascending=[False, True]).iloc[0]
                longest_consec_low = int(bestl['run_len'])
                first_consec_low_ts = int(bestl['start_ts'])
        else:
            min_value_in_window = float(vals.min())

    rows.append({
        'cmdb_id': cmdb,
        'log_name': log_name,
        'p95': p95,
        'p05': p05,
        'total_count': total_count,
        'window_count': window_count,
        'anomaly_count_low': anomaly_count_low,
        'first_anomaly_ts_low': (int(first_anomaly_ts_low) if not pd.isna(first_anomaly_ts_low) else np.nan),
        'min_value_in_window': (float(min_value_in_window) if not pd.isna(min_value_in_window) else np.nan),
        'longest_consec_low': longest_consec_low,
        'first_consec_low_ts': (int(first_consec_low_ts) if not pd.isna(first_consec_low_ts) else np.nan),
        'anomaly_count_high': anomaly_count_high,
        'first_anomaly_ts_high': (int(first_anomaly_ts_high) if not pd.isna(first_anomaly_ts_high) else np.nan),
        'max_value_in_window': (float(max_value_in_window) if not pd.isna(max_value_in_window) else np.nan),
        'longest_consec_high': longest_consec_high,
        'first_consec_high_ts': (int(first_consec_high_ts) if not pd.isna(first_consec_high_ts) else np.nan)
    })

# Build DataFrame
log_anomaly_stats = pd.DataFrame(rows)
log_anomaly_stats['any_anomaly'] = (log_anomaly_stats['anomaly_count_low'] > 0) | (log_anomaly_stats['anomaly_count_high'] > 0)

# Filter only groups with any anomaly and non-zero window_count
log_anomaly_any = log_anomaly_stats[log_anomaly_stats['any_anomaly'] & (log_anomaly_stats['window_count'] > 0)].copy()

# Count of log groups with any anomaly
num_log_groups_with_any_anomaly = int(log_anomaly_any.shape[0])

# Order by longest_consec_low desc then longest_consec_high desc and select top20
log_anomaly_top20 = (
    log_anomaly_any
    .sort_values(['longest_consec_low', 'longest_consec_high'], ascending=[False, False])
    .loc[:, ['cmdb_id', 'log_name', 'p95', 'p05', 'total_count', 'window_count',
             'anomaly_count_low', 'first_anomaly_ts_low', 'min_value_in_window', 'longest_consec_low', 'first_consec_low_ts',
             'anomaly_count_high', 'first_anomaly_ts_high', 'max_value_in_window', 'longest_consec_high', 'first_consec_high_ts']]
    .head(20)
    .reset_index(drop=True)
)

# 4) Error logs in window: use existing error_logs_df, filter by window and truncate message to 200 chars
error_in_window = error_logs_df[(error_logs_df['timestamp'] >= start_ts) & (error_logs_df['timestamp'] <= end_ts)].copy()
if not error_in_window.empty:
    error_in_window['message'] = error_in_window['message'].astype(str).str.slice(0, 200)
    error_window_rows_display = error_in_window.loc[:, ['timestamp', 'cmdb_id', 'message']].head(20).reset_index(drop=True)
else:
    error_window_rows_display = pd.DataFrame(columns=['timestamp', 'cmdb_id', 'message'])

# Final compact outputs (variables displayed by IPython)
pods_on_node6, log_anomaly_top20, num_log_groups_with_any_anomaly, error_window_rows_display
