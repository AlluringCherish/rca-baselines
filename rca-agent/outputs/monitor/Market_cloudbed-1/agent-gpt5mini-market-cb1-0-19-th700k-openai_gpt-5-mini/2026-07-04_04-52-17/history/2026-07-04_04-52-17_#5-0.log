import re
import pandas as pd

# Reuse trace_agg_df and trace_anomalies_df from kernel
df = trace_agg_df.copy()  # aggregated anomaly groups per (cmdb_id, trace_name)

# Allowed root-cause component set (nodes, pods, services) — same as used earlier
allowed_components = {
    # nodes
    'node-1','node-2','node-3','node-4','node-5','node-6',
    # pods
    'frontend-0','frontend-1','frontend-2','frontend2-0',
    'shippingservice-0','shippingservice-1','shippingservice-2','shippingservice2-0',
    'checkoutservice-0','checkoutservice-1','checkoutservice-2','checkoutservice2-0',
    'currencyservice-0','currencyservice-1','currencyservice-2','currencyservice2-0',
    'adservice-0','adservice-1','adservice-2','adservice2-0',
    'emailservice-0','emailservice-1','emailservice-2','emailservice2-0',
    'cartservice-0','cartservice-1','cartservice-2','cartservice2-0',
    'productcatalogservice-0','productcatalogservice-1','productcatalogservice-2','productcatalogservice2-0',
    'recommendationservice-0','recommendationservice-1','recommendationservice-2','recommendationservice2-0',
    'paymentservice-0','paymentservice-1','paymentservice-2','paymentservice2-0',
    # service-level
    'frontend','shippingservice','checkoutservice','currencyservice','adservice',
    'emailservice','cartservice','productcatalogservice','recommendationservice','paymentservice'
}

# 1) Select anomaly-flagged trace groups where trace_name indicates frontend origin
pattern_frontend = re.compile(r'from_frontend|trace\.from_frontend|mesh\.source\.frontend', flags=re.IGNORECASE)
df_frontend_origin = df[df['trace_name'].str.contains(pattern_frontend)].copy()

# Helper extraction functions
def extract_frontend_origin(name):
    ln = name.lower()
    m = re.search(r'from_frontend-([0-9]+)', ln)
    if m:
        return f'frontend-{m.group(1)}'
    # mesh.source.frontend or mesh.source.frontend2 -> map to service-level 'frontend' or 'frontend2'
    if 'mesh.source.frontend2' in ln:
        return 'frontend2'  # service-level (will be filtered against allowed set)
    if 'mesh.source.frontend' in ln:
        return 'frontend'
    # fallback: if contains 'from_frontend' but no index, return service-level
    if 'from_frontend' in ln:
        return 'frontend'
    return None

def extract_target_from_trace_name(name):
    ln = name.lower()
    # pattern: mesh.source.frontend.<target>
    m = re.search(r'mesh\.source\.frontend(?:2)?\.([a-z0-9\-]+)', ln)
    if m:
        return m.group(1)
    # pattern: .destination.<target>
    m = re.search(r'\.destination\.([a-z0-9\-]+)', ln)
    if m:
        return m.group(1)
    # pattern: .to_<target> or .to-<target> or .to.<target>
    m = re.search(r'\.to[_\.\-]?([a-z0-9\-]+)', ln)
    if m:
        return m.group(1)
    # pattern: .toService<target> or .toService_<target>
    m = re.search(r'\.to[_\-]?service[_\-]?([a-z0-9\-]+)', ln)
    if m:
        return m.group(1)
    # fallback: no extractable target
    return None

# Apply extraction
df_frontend_origin['frontend_origin'] = df_frontend_origin['trace_name'].apply(extract_frontend_origin)
df_frontend_origin['parsed_target_token'] = df_frontend_origin['trace_name'].apply(extract_target_from_trace_name)

# Normalize parsed_target_token to candidate target names and validate against allowed_components.
def normalize_and_validate_target(token, cmdb_id):
    if not token:
        # fallback: if cmdb_id itself is an allowed component, use it
        return cmdb_id if cmdb_id in allowed_components else None
    # direct match
    if token in allowed_components:
        return token
    # if token matches a service name (e.g., 'recommendationservice') and that's in allowed, accept it
    if token in allowed_components:
        return token
    # sometimes token is service base (without suffix) - accept if service-level present
    if token in {'frontend','shippingservice','checkoutservice','currencyservice','adservice','emailservice','cartservice','productcatalogservice','recommendationservice','paymentservice'}:
        return token
    # try to match token + '-0' etc (common pod suffix) if present in allowed
    for suffix in ['-0','-1','-2']:
        cand = token + suffix
        if cand in allowed_components:
            return cand
    # fallback to cmdb_id if it's allowed
    if cmdb_id in allowed_components:
        return cmdb_id
    return None

df_frontend_origin['target_component'] = df_frontend_origin.apply(lambda r: normalize_and_validate_target(r['parsed_target_token'], r['cmdb_id']), axis=1)

# Also validate frontend_origin is allowed: map 'frontend2' -> 'frontend2-0' if needed
def normalize_frontend(fn):
    if not fn:
        return None
    if fn in allowed_components:
        return fn
    # try with suffixes for pods
