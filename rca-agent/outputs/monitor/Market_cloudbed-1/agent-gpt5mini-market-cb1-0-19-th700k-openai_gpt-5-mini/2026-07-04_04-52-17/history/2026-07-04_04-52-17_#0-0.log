import pandas as pd
import pytz
from collections import OrderedDict

tz = pytz.timezone('Asia/Shanghai')

def fmt_ts_series(s):
    # s: pandas Series of epoch seconds
    if s is None:
        return (None, None)
    s_num = pd.to_numeric(s, errors='coerce').dropna()
    if s_num.empty:
        return (None, None)
    sdt = pd.to_datetime(s_num.astype(int), unit='s', utc=True).dt.tz_convert(tz)
    sdt_min = sdt.min()
    sdt_max = sdt.max()
    fmt = '%Y-%m-%d %H:%M:%S %z'
    return sdt_min.strftime(fmt), sdt_max.strftime(fmt)

def top_counts(series, topn=20):
    if series is None:
        return []
    vc = series.fillna('<<NA>>').value_counts().head(topn)
    return list(zip(vc.index.tolist(), vc.values.tolist()))

# Reuse df variable for memory efficiency
df = pd.read_csv('metric.csv')
metric_min_ts, metric_max_ts = fmt_ts_series(df.get('timestamp'))
metric_summary = OrderedDict([
    ('filename', 'metric.csv'),
    ('number_of_rows', int(df.shape[0])),
    ('min_timestamp', metric_min_ts),
    ('max_timestamp', metric_max_ts),
    ('unique_cmdb_id_count', int(df['cmdb_id'].nunique()) if 'cmdb_id' in df.columns else 0),
    ('top_20_cmdb_ids', top_counts(df['cmdb_id'] if 'cmdb_id' in df.columns else None, 20)),
    ('unique_kpi_name_count', int(df['kpi_name'].nunique()) if 'kpi_name' in df.columns else 0),
    ('top_20_kpi_names', top_counts(df['kpi_name'] if 'kpi_name' in df.columns else None, 20))
])

