import pandas as pd
import pytz
import re

tz = pytz.timezone('Asia/Shanghai')

# Load trace data (reuse variable if present)
try:
    trace_df
except NameError:
    trace_df = pd.read_csv('trace.csv')

# Ensure numeric types
trace_df['timestamp'] = pd.to_numeric(trace_df['timestamp'], errors='coerce')
trace_df['value'] = pd.to_numeric(trace_df['value'], errors='coerce')

# 1) Global P95 and P5 per (cmdb_id, trace_name) using entire trace.csv
g = trace_df.groupby(['cmdb_id', 'trace_name'])['value']
trace_p95 = g.quantile(0.95).rename('global_P95')
trace_p5 = g.quantile(0.05).rename('global_P5')
trace_thresholds = pd.concat([trace_p95, trace_p5], axis=1).reset_index()

# 2) Incident window filter (2022-03-20 09:00:00 +0800 to 2022-03-20 09:30:00 +0800 inclusive)
start_ts = int(pd.Timestamp('2022-03-20 09:00:00', tz=tz).tz_convert('UTC').timestamp())
end_ts = int(pd.Timestamp('2022-03-20 09:30:00', tz=tz).tz_convert('UTC').timestamp())

in_window = trace_df[
    (trace_df['timestamp'].notna()) &
    (trace_df['timestamp'] >= start_ts) &
    (trace_df['timestamp'] <= end_ts)
].copy()

# If no rows in window, prepare empty outputs
if in_window.empty:
    top_traces = pd.DataFrame(columns=[
        'cmdb_id','trace_name','global_P95','global_P5','points_in_window',
        'upper_anomaly_count','lower_anomaly_count',
        'earliest_upper_anomaly_timestamp','earliest_lower_anomaly_timestamp',
        'max_value_in_window','min_value_in_window'
    ])
    top_services = pd.DataFrame(columns=['service_name','total_anomalies','earliest_anomaly_timestamp'])
else:
    # 3) Merge thresholds into window rows and compute anomaly flags
    merged = in_window.merge(trace_thresholds, on=['cmdb_id','trace_name'], how='left')
    merged['is_upper'] = (merged['value'] >= merged['global_P95']).fillna(False)
    merged['is_lower'] = (merged['value'] <= merged['global_P5']).fillna(False)

    # 4) Aggregate per (cmdb_id, trace_name)
    agg = merged.groupby(['cmdb_id','trace_name']).agg(
        points_in_window = ('value','size'),
        upper_anomaly_count = ('is_upper','sum'),
        lower_anomaly_count = ('is_lower','sum'),
        max_value_in_window = ('value','max'),
        min_value_in_window = ('value','min')
    ).reset_index()

    # earliest timestamps for anomalies
    eu = merged.loc[merged['is_upper']].groupby(['cmdb_id','trace_name'])['timestamp'].min().rename('earliest_upper_ts').reset_index()
    el = merged.loc[merged['is_lower']].groupby(['cmdb_id','trace_name'])['timestamp'].min().rename('earliest_lower_ts').reset_index()

    agg = agg.merge(eu, on=['cmdb_id','trace_name'], how='left')
    agg = agg.merge(el, on=['cmdb_id','trace_name'], how='left')

    # attach global thresholds
    agg = agg.merge(trace_thresholds, on=['cmdb_id','trace_name'], how='left')

    # format earliest timestamps to Asia/Shanghai string or None
    def fmt_ts(v):
        if pd.isna(v):
            return None
        return pd.to_datetime(int(v), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %z')

    agg['earliest_upper_anomaly_timestamp'] = agg['earliest_upper_ts'].apply(fmt_ts)
    agg['earliest_lower_anomaly_timestamp'] = agg['earliest_lower_ts'].apply(fmt_ts)

    # select required columns and sort by total anomalies desc
    top_traces = agg[[
        'cmdb_id','trace_name','global_P95','global_P5','points_in_window',
        'upper_anomaly_count','lower_anomaly_count',
        'earliest_upper_anomaly_timestamp','earliest_lower_anomaly_timestamp',
        'max_value_in_window','min_value_in_window'
    ]].copy()
    top_traces['total_anomalies'] = top_traces['upper_anomaly_count'] + top_traces['lower_anomaly_count']
    top_traces = top_traces.sort_values(['total_anomalies','points_in_window'], ascending=[False, False]).head(20).reset_index(drop=True)
    top_traces = top_traces.drop(columns=['total_anomalies'])

    # 5) Aggregate by service_name derived from cmdb_id (remove trailing '-digits' if present)
    def service_name_from_cmdb(cmdb):
        m = re.match(r'^(.+)-\d+$', str(cmdb))
        return m.group(1) if m else cmdb

    merged['service_name'] = merged['cmdb_id'].apply(service_name_from_cmdb)

    # compute total anomalies per service and earliest anomaly timestamp across service
    merged['any_anom'] = merged['is_upper'] | merged['is_lower']
    # total anomalies per row = upper + lower; sum across service
    merged['row_anom_count'] = merged['is_upper'].astype(int) + merged['is_lower'].astype(int)

    svc_totals = merged.groupby('service_name').agg(
        total_anomalies = ('row_anom_count','sum'),
        earliest_anomaly_ts = ('timestamp', lambda s: s[merged.loc[s.index,'any_anom']].min() if True else None)
    ).reset_index()

    # The lambda above is tricky due to index alignment; compute earliest_anomaly_ts robustly:
    # recompute earliest per service by filtering any_anom True then groupby min
    svc_earliest = merged.loc[merged['any_anom']].groupby('service_name')['timestamp'].min().rename('earliest_anomaly_ts').reset_index()
    svc_totals = svc_totals.drop(columns=['earliest_anomaly_ts']).merge(svc_earliest, on='service_name', how='left')

    # format earliest timestamps
    svc_totals['earliest_anomaly_timestamp'] = svc_totals['earliest_anomaly_ts'].apply(lambda v: fmt_ts(v) if not pd.isna(v) else None)
    svc_totals = svc_totals[['service_name','total_anomalies','earliest_anomaly_timestamp']].sort_values('total_anomalies', ascending=False).head(10).reset_index(drop=True)

    top_services = svc_totals

# Display compact results: top_traces (top 20) and top_services (top 10)
top_traces, top_services
