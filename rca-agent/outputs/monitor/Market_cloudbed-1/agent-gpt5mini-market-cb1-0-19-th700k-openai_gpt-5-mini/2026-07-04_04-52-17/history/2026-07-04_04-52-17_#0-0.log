import pandas as pd
import pytz

# Reuse timezone variable pattern
tz = pytz.timezone('Asia/Shanghai')

# Helper to format epoch seconds to Asia/Shanghai tz string
def fmt_epoch_to_shanghai_series(s):
    s = pd.to_numeric(s, errors='coerce').dropna().astype(int)
    if s.empty:
        return pd.Series([], dtype=object)
    dt = pd.to_datetime(s, unit='s', utc=True).dt.tz_convert(tz)
    return dt.dt.strftime('%Y-%m-%d %H:%M:%S %z')

# Load metric data (reuse variable name if present)
metric_df = pd.read_csv('metric.csv')

# Ensure correct dtypes
metric_df['timestamp'] = pd.to_numeric(metric_df['timestamp'], errors='coerce').astype('Int64')
metric_df['value'] = pd.to_numeric(metric_df['value'], errors='coerce')

# 1) Compute global P95 and P5 per (cmdb_id, kpi_name) using entire file
group = metric_df.groupby(['cmdb_id', 'kpi_name'])['value']
p95 = group.quantile(0.95).rename('global_P95')
p5 = group.quantile(0.05).rename('global_P5')
thresholds = pd.concat([p95, p5], axis=1).reset_index()

# 2) Filter to the incident window (2022-03-20 09:00:00 +0800 to 2022-03-20 09:30:00 +0800 inclusive)
start_ts = int(pd.Timestamp('2022-03-20 09:00:00', tz=tz).tz_convert('UTC').timestamp())
end_ts = int(pd.Timestamp('2022-03-20 09:30:00', tz=tz).tz_convert('UTC').timestamp())

in_window = metric_df[
    (metric_df['timestamp'].notna()) &
    (metric_df['timestamp'].astype(int) >= start_ts) &
    (metric_df['timestamp'].astype(int) <= end_ts)
].copy()

# If no rows in window, return empty compact DataFrame
if in_window.empty:
    result_df = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','global_P95','global_P5','points_in_window',
        'upper_anomaly_count','lower_anomaly_count',
        'earliest_upper_anomaly_timestamp','earliest_lower_anomaly_timestamp',
        'max_value_in_window','min_value_in_window'
    ])
else:
    # Merge global thresholds into window rows
    merged = in_window.merge(thresholds, on=['cmdb_id','kpi_name'], how='left')

    # Define anomaly boolean columns based on global thresholds (global thresholds computed earlier)
    merged['is_upper'] = (merged['value'] >= merged['global_P95']).fillna(False)
    merged['is_lower'] = (merged['value'] <= merged['global_P5']).fillna(False)

    # Group window data to compute required aggregates
    gw = merged.groupby(['cmdb_id','kpi_name'])
    agg = gw.agg(
        points_in_window = ('value', 'size'),
        upper_anomaly_count = ('is_upper', 'sum'),
        lower_anomaly_count = ('is_lower', 'sum'),
        max_value_in_window = ('value', 'max'),
        min_value_in_window = ('value', 'min')
    ).reset_index()

    # Earliest anomaly timestamps (epoch seconds)
    eu = merged.loc[merged['is_upper']].groupby(['cmdb_id','kpi_name'])['timestamp'].min().rename('earliest_upper_ts')
    el = merged.loc[merged['is_lower']].groupby(['cmdb_id','kpi_name'])['timestamp'].min().rename('earliest_lower_ts')

    eu = eu.reset_index()
    el = el.reset_index()

    # Merge earliest timestamps
    agg = agg.merge(eu, on=['cmdb_id','kpi_name'], how='left')
    agg = agg.merge(el, on=['cmdb_id','kpi_name'], how='left')

    # Attach global thresholds
    agg = agg.merge(thresholds, on=['cmdb_id','kpi_name'], how='left')

    # Format earliest timestamps to Asia/Shanghai strings or None
    if 'earliest_upper_ts' in agg.columns:
        agg['earliest_upper_anomaly_timestamp'] = agg['earliest_upper_ts'].apply(
            lambda x: pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %z')
            if not pd.isna(x) else None
        )
        agg['earliest_lower_anomaly_timestamp'] = agg['earliest_lower_ts'].apply(
            lambda x: pd.to_datetime(int(x), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %z')
            if not pd.isna(x) else None
        )
    else:
        agg['earliest_upper_anomaly_timestamp'] = None
        agg['earliest_lower_anomaly_timestamp'] = None

    # Select and order required columns
    result_df = agg[[
        'cmdb_id','kpi_name','global_P95','global_P5','points_in_window',
        'upper_anomaly_count','lower_anomaly_count',
        'earliest_upper_anomaly_timestamp','earliest_lower_anomaly_timestamp',
        'max_value_in_window','min_value_in_window'
    ]].copy()

    # Sort by total anomaly count desc and take top 20
    result_df['total_anomalies'] = result_df['upper_anomaly_count'] + result_df['lower_anomaly_count']
    result_df = result_df.sort_values(['total_anomalies','points_in_window'], ascending=[False, False]).head(20)
    result_df = result_df.drop(columns=['total_anomalies']).reset_index(drop=True)

# Display compact result (top 20 rows as requested)
result_df
