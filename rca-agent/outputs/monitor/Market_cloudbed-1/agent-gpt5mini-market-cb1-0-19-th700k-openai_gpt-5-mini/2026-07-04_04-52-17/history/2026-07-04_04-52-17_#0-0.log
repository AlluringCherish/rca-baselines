metric_df['value'] = pd.to_numeric(metric_df['value'], errors='coerce')

# Incident window bounds (epoch seconds)
start_ts = int(pd.Timestamp('2022-03-20 09:00:00', tz=tz).tz_convert('UTC').timestamp())
end_ts   = int(pd.Timestamp('2022-03-20 09:30:00', tz=tz).tz_convert('UTC').timestamp())

# --- Part 1: Node-6 I/O fault intervals for system.io.rkb_s ---
node_kpi_row = thresholds[(thresholds['cmdb_id']=='node-6') & (thresholds['kpi_name']=='system.io.rkb_s')]
if node_kpi_row.empty:
    intervals_df = pd.DataFrame(columns=[
        'interval_start_timestamp','interval_end_timestamp','interval_length_in_minutes',
        'max_value_in_interval','global_P95','global_P5','relative_peak_severity'
    ])
else:
    gP95 = float(node_kpi_row['global_P95'].iloc[0])
    gP5  = float(node_kpi_row['global_P5'].iloc[0])

    node_series = metric_df[
        (metric_df['cmdb_id']=='node-6') &
        (metric_df['kpi_name']=='system.io.rkb_s') &
        (metric_df['timestamp'] >= start_ts) &
        (metric_df['timestamp'] <= end_ts)
    ].copy()

    if node_series.empty:
        intervals_df = pd.DataFrame(columns=[
            'interval_start_timestamp','interval_end_timestamp','interval_length_in_minutes',
            'max_value_in_interval','global_P95','global_P5','relative_peak_severity'
        ])
    else:
        # keep only points meeting threshold (value >= global P95)
        hits = node_series[node_series['value'] >= gP95].sort_values('timestamp').reset_index(drop=True)
        if hits.empty:
            intervals_df = pd.DataFrame(columns=[
                'interval_start_timestamp','interval_end_timestamp','interval_length_in_minutes',
                'max_value_in_interval','global_P95','global_P5','relative_peak_severity'
            ])
        else:
            # identify consecutive-minute runs (gap > 60 seconds breaks a run)
            hits['ts_diff'] = hits['timestamp'].diff().fillna(60)
            hits['run_id'] = (hits['ts_diff'] > 60).cumsum()
            runs = hits.groupby('run_id').agg(
                interval_start_ts = ('timestamp','min'),
                interval_end_ts   = ('timestamp','max'),
                interval_length_in_points = ('timestamp','size'),
                max_value_in_interval = ('value','max')
            ).reset_index(drop=True)

            # compute length in minutes (points are per-minute)
            runs['interval_length_in_minutes'] = runs['interval_length_in_points']

            # severity
            runs['global_P95'] = gP95
            runs['global_P5']  = gP5
            runs['relative_peak_severity'] = (runs['max_value_in_interval'] - gP95) / max(1e-9, abs(gP95))

            # format timestamps to Asia/Shanghai strings
            runs['interval_start_timestamp'] = pd.to_datetime(runs['interval_start_ts'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %z')
            runs['interval_end_timestamp'] = pd.to_datetime(runs['interval_end_ts'], unit='s', utc=True).dt.tz_convert(tz).dt.strftime('%Y-%m-%d %H:%M:%S %z')

            intervals_df = runs[[
                'interval_start_timestamp','interval_end_timestamp','interval_length_in_minutes',
                'max_value_in_interval','global_P95','global_P5','relative_peak_severity'
            ]].sort_values(['interval_length_in_minutes','relative_peak_severity'], ascending=[False, False]).head(10).reset_index(drop=True)

# --- Part 2: Impacted containers/services on node-6 ---
# Identify all (cmdb_id,kpi_name) where kpi_name contains 'container.node-6' (global thresholds computed earlier)
node6_kpi_thresholds = thresholds[thresholds['kpi_name'].str.contains('container.node-6', na=False)].copy()

# Filter metric rows in-window whose kpi_name contains 'container.node-6'
in_window_node6_kpis = metric_df[
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts) &
    (metric_df['kpi_name'].str.contains('container.node-6', na=False))
].copy()

if node6_kpi_thresholds.empty or in_window_node6_kpis.empty:
    impacted_df = pd.DataFrame(columns=[
        'cmdb_id','derived_service','earliest_anomaly_timestamp_on_node6',
        'total_kpis_on_node6','total_anomalies_on_node6'
    ])
else:
    merged = in_window_node6_kpis.merge(node6_kpi_thresholds, on=['cmdb_id','kpi_name'], how='left')
    # compute upper anomalies (value >= global_P95)
    merged['is_upper'] = (merged['value'] >= merged['global_P95']).fillna(False)

    # per (cmdb_id, kpi_name) compute upper counts and earliest ts
    per_kpi = merged.groupby(['cmdb_id','kpi_name']).agg(
        upper_anomaly_count = ('is_upper','sum'),
        earliest_upper_ts = ('timestamp', lambda s: s[merged.loc[s.index,'is_upper']].min() if True else np.nan)
    ).reset_index()

    # robust earliest computation
    eu = merged.loc[merged['is_upper']].groupby(['cmdb_id','kpi_name'])['timestamp'].min().rename('earliest_upper_ts').reset_index()
    per_kpi = per_kpi.drop(columns=['earliest_upper_ts'], errors='ignore').merge(eu, on=['cmdb_id','kpi_name'], how='left')

    # aggregate per cmdb_id
    per_kpi['upper_anomaly_count'] = per_kpi['upper_anomaly_count'].astype(int)
    svc_agg = per_kpi.groupby('cmdb_id').agg(
        total_kpis_on_node6 = ('kpi_name','nunique'),
        total_anomalies_on_node6 = ('upper_anomaly_count','sum'),
        earliest_upper_ts = ('earliest_upper_ts','min')
    ).reset_index()

    # derived_service by removing trailing -digits
    svc_agg['derived_service'] = svc_agg['cmdb_id'].astype(str).str.replace(r'-\d+$','', regex=True)

    # format earliest timestamp
    svc_agg['earliest_anomaly_timestamp_on_node6'] = svc_agg['earliest_upper_ts'].apply(
        lambda v: pd.to_datetime(int(v), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %z')
        if not pd.isna(v) else None
    )

    impacted_df = svc_agg[[
        'cmdb_id','derived_service','earliest_anomaly_timestamp_on_node6',
        'total_kpis_on_node6','total_anomalies_on_node6'
    ]].sort_values('total_anomalies_on_node6', ascending=False).head(20).reset_index(drop=True)

# Return compact results
intervals_df, impacted_df
