import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse log_df if present, otherwise read from file
try:
    log_df
except NameError:
    log_df = pd.read_csv('log.csv')

# Ensure numeric types
log_df['timestamp'] = pd.to_numeric(log_df['timestamp'], errors='coerce')
log_df['value'] = pd.to_numeric(log_df['value'], errors='coerce')

# 1) Compute global P95 and P5 per (cmdb_id, log_name) using the full series (before filtering)
grp = log_df.groupby(['cmdb_id', 'log_name'])['value']
global_p95 = grp.quantile(0.95).rename('global_P95')
global_p5 = grp.quantile(0.05).rename('global_P5')
thresholds = pd.concat([global_p95, global_p5], axis=1).reset_index()

# 2) Filter to incident window (2022-03-20 09:00:00 +0800 to 2022-03-20 09:30:00 +0800 inclusive)
start_ts = int(pd.Timestamp('2022-03-20 09:00:00', tz=tz).tz_convert('UTC').timestamp())
end_ts   = int(pd.Timestamp('2022-03-20 09:30:00', tz=tz).tz_convert('UTC').timestamp())

in_window = log_df[
    (log_df['timestamp'].notna()) &
    (log_df['timestamp'] >= start_ts) &
    (log_df['timestamp'] <= end_ts)
].copy()

# Prepare empty structures if no data in window
cols = [
    'cmdb_id','log_name','global_P95','global_P5','points_in_window',
    'upper_anomaly_count','lower_anomaly_count',
    'earliest_upper_anomaly_timestamp','earliest_lower_anomaly_timestamp',
    'max_value_in_window','min_value_in_window'
]

if in_window.empty:
    result_df = pd.DataFrame(columns=cols)
    error_components = pd.DataFrame(columns=['cmdb_id','error_timestamps_count','earliest_error_timestamp'])
else:
    # 3) Merge thresholds into window rows and compute anomaly flags
    merged = in_window.merge(thresholds, on=['cmdb_id','log_name'], how='left')
    merged['is_upper'] = (merged['value'] >= merged['global_P95']).fillna(False)
    merged['is_lower'] = (merged['value'] <= merged['global_P5']).fillna(False)

    # 4) Aggregate per (cmdb_id, log_name)
    agg = merged.groupby(['cmdb_id','log_name']).agg(
        points_in_window = ('value','size'),
        upper_anomaly_count = ('is_upper','sum'),
        lower_anomaly_count = ('is_lower','sum'),
        max_value_in_window = ('value','max'),
        min_value_in_window = ('value','min')
    ).reset_index()

    # earliest timestamps for anomalies (epoch seconds)
    eu = merged.loc[merged['is_upper']].groupby(['cmdb_id','log_name'])['timestamp'].min().rename('earliest_upper_ts').reset_index()
    el = merged.loc[merged['is_lower']].groupby(['cmdb_id','log_name'])['timestamp'].min().rename('earliest_lower_ts').reset_index()

    agg = agg.merge(eu, on=['cmdb_id','log_name'], how='left')
    agg = agg.merge(el, on=['cmdb_id','log_name'], how='left')

    # attach global thresholds (already computed before filtering)
    agg = agg.merge(thresholds, on=['cmdb_id','log_name'], how='left')

    # format earliest timestamps to Asia/Shanghai string or None
    def fmt_ts(v):
        if pd.isna(v):
            return None
        return pd.to_datetime(int(v), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %z')

    agg['earliest_upper_anomaly_timestamp'] = agg['earliest_upper_ts'].apply(fmt_ts)
    agg['earliest_lower_anomaly_timestamp'] = agg['earliest_lower_ts'].apply(fmt_ts)

    # select and reorder columns
    result_df = agg[[
        'cmdb_id','log_name','global_P95','global_P5','points_in_window',
        'upper_anomaly_count','lower_anomaly_count',
        'earliest_upper_anomaly_timestamp','earliest_lower_anomaly_timestamp',
        'max_value_in_window','min_value_in_window'
    ]].copy()

    # sort by total anomalies desc and keep top 20
    result_df['total_anomalies'] = result_df['upper_anomaly_count'] + result_df['lower_anomaly_count']
    result_df = result_df.sort_values(['total_anomalies','points_in_window'], ascending=[False, False]).head(20).reset_index(drop=True)
    result_df = result_df.drop(columns=['total_anomalies'])

    # 5) Components with log.error_count > 0 at any timestamp in the window
    err = in_window[(in_window['log_name'] == 'log.error_count') & (in_window['value'] > 0)].copy()
    if err.empty:
        error_components = pd.DataFrame(columns=['cmdb_id','error_timestamps_count','earliest_error_timestamp'])
    else:
        ec = err.groupby('cmdb_id').agg(
            error_timestamps_count = ('timestamp','size'),
            earliest_error_ts = ('timestamp','min')
        ).reset_index()
        ec['earliest_error_timestamp'] = ec['earliest_error_ts'].apply(lambda v: fmt_ts(v) if not pd.isna(v) else None)
        error_components = ec[['cmdb_id','error_timestamps_count','earliest_error_timestamp']].sort_values('error_timestamps_count', ascending=False).head(20).reset_index(drop=True)

# Display compact outputs: result_df (top 20) and error_components (top 20)
result_df, error_components
