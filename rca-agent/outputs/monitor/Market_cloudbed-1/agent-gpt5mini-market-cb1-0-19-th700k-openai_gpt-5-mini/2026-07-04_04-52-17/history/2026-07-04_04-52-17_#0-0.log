import pandas as pd
import pytz
import numpy as np

# Reuse existing trace_df if available, otherwise load
try:
    trace_df
except NameError:
    trace_df = pd.read_csv('trace.csv')

tz = pytz.timezone('Asia/Shanghai')

# Ensure correct dtypes
trace_df['timestamp'] = pd.to_numeric(trace_df['timestamp'], errors='coerce')
trace_df['value'] = pd.to_numeric(trace_df['value'], errors='coerce')

# 1) Compute global P95 and P5 per (cmdb_id, trace_name) using the full trace series
grp = trace_df.groupby(['cmdb_id', 'trace_name'])['value']
global_p95 = grp.quantile(0.95).rename('global_P95')
global_p5 = grp.quantile(0.05).rename('global_P5')
trace_thresholds = pd.concat([global_p95, global_p5], axis=1).reset_index()

# 2) Keep only non-constant series where global_P95 != global_P5
nonconst_thresholds = trace_thresholds[trace_thresholds['global_P95'] != trace_thresholds['global_P5']].copy()

# 3) Filter rows to incident window (inclusive)
start_ts = int(pd.Timestamp('2022-03-20 09:00:00', tz=tz).tz_convert('UTC').timestamp())
end_ts   = int(pd.Timestamp('2022-03-20 09:30:00', tz=tz).tz_convert('UTC').timestamp())

in_window = trace_df[
    (trace_df['timestamp'].notna()) &
    (trace_df['timestamp'] >= start_ts) &
    (trace_df['timestamp'] <= end_ts)
].copy()

# If there are no non-constant thresholds or no in-window rows, prepare empty result
cols = [
    'cmdb_id','trace_name','trace_metric_type','global_P95','global_P5','points_in_window',
    'upper_anomaly_count','lower_anomaly_count',
    'earliest_upper_anomaly_timestamp','earliest_lower_anomaly_timestamp',
    'max_value_in_window','min_value_in_window'
]

if nonconst_thresholds.empty or in_window.empty:
    result_df = pd.DataFrame(columns=cols)
else:
    # 4) Keep only rows in window belonging to non-constant trace series
    merged = in_window.merge(nonconst_thresholds, on=['cmdb_id','trace_name'], how='inner')

    # compute anomaly flags using global thresholds (computed before filtering)
    merged['is_upper'] = (merged['value'] >= merged['global_P95']).fillna(False)
    merged['is_lower'] = (merged['value'] <= merged['global_P5']).fillna(False)

    # aggregate per (cmdb_id, trace_name)
    agg = merged.groupby(['cmdb_id','trace_name']).agg(
        points_in_window = ('value','size'),
        upper_anomaly_count = ('is_upper','sum'),
        lower_anomaly_count = ('is_lower','sum'),
        max_value_in_window = ('value','max'),
        min_value_in_window = ('value','min')
    ).reset_index()

    # earliest anomaly timestamps (epoch seconds)
    eu = merged.loc[merged['is_upper']].groupby(['cmdb_id','trace_name'])['timestamp'].min().rename('earliest_upper_ts').reset_index()
    el = merged.loc[merged['is_lower']].groupby(['cmdb_id','trace_name'])['timestamp'].min().rename('earliest_lower_ts').reset_index()

    agg = agg.merge(eu, on=['cmdb_id','trace_name'], how='left')
    agg = agg.merge(el, on=['cmdb_id','trace_name'], how='left')

    # attach global thresholds
    agg = agg.merge(nonconst_thresholds, on=['cmdb_id','trace_name'], how='left')

    # infer trace_metric_type from trace_name
    def infer_trace_type(name):
        if pd.isna(name):
            return 'other'
        n = name.lower()
        if 'error_rate' in n:
            return 'error_rate'
        if 'duration_p95' in n or 'p95' in n:
            return 'duration_p95'
        if 'duration_mean' in n or 'mean' in n:
            return 'duration_mean'
        if 'row_count' in n or 'rowcount' in n:
            return 'row_count'
        return 'other'

    agg['trace_metric_type'] = agg['trace_name'].apply(infer_trace_type)

    # format earliest timestamps to Asia/Shanghai or None
    def fmt_ts(v):
        if pd.isna(v):
            return None
        return pd.to_datetime(int(v), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %z')

    agg['earliest_upper_anomaly_timestamp'] = agg['earliest_upper_ts'].apply(fmt_ts)
    agg['earliest_lower_anomaly_timestamp'] = agg['earliest_lower_ts'].apply(fmt_ts)

    # select and order required columns
    result_df = agg[[
        'cmdb_id','trace_name','trace_metric_type','global_P95','global_P5','points_in_window',
        'upper_anomaly_count','lower_anomaly_count',
        'earliest_upper_anomaly_timestamp','earliest_lower_anomaly_timestamp',
        'max_value_in_window','min_value_in_window'
    ]].copy()

    # sort by total anomalies desc and keep top 20
    result_df['total_anomalies'] = result_df['upper_anomaly_count'] + result_df['lower_anomaly_count']
    result_df = result_df.sort_values(['total_anomalies','points_in_window'], ascending=[False, False]).head(20).reset_index(drop=True)
    result_df = result_df.drop(columns=['total_anomalies'])

# Display compact top-20 result
