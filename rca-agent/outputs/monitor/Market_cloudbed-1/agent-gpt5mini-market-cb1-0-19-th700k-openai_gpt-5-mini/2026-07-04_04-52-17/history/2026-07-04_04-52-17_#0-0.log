            kpiform = [f"{k}:{int(c)}" for k,c in zip(kpis['kpi_name'], kpis['anomaly_count'])]
            top_kpis_list.append(kpiform)

        top_services['top_3_kpis'] = top_kpis_list

        service_summary = top_services[['service_name','total_anomalies','earliest_anomaly_timestamp','top_3_kpis']].copy()

