2026-07-04 04:57:36,139 | DEBUG | Raw Code:
import pandas as pd
import pytz
import numpy as np
import re

# Reuse metric_df if present, otherwise load
try:
    metric_df
except NameError:
    metric_df = pd.read_csv('metric.csv')

tz = pytz.timezone('Asia/Shanghai')

# Ensure correct dtypes
metric_df['timestamp'] = pd.to_numeric(metric_df['timestamp'], errors='coerce')
metric_df['value'] = pd.to_numeric(metric_df['value'], errors='coerce')

# 1) Global P95 and P5 per (cmdb_id, kpi_name)
grp = metric_df.groupby(['cmdb_id', 'kpi_name'])['value']
global_p95 = grp.quantile(0.95).rename('global_P95')
global_p5 = grp.quantile(0.05).rename('global_P5')
thresholds = pd.concat([global_p95, global_p5], axis=1).reset_index()

# 2) Non-constant pairs
nonconst_thresholds = thresholds[thresholds['global_P95'] != thresholds['global_P5']].copy()

# 3) Incident window filter
start_ts = int(pd.Timestamp('2022-03-20 09:00:00', tz=tz).tz_convert('UTC').timestamp())
end_ts   = int(pd.Timestamp('2022-03-20 09:30:00', tz=tz).tz_convert('UTC').timestamp())

in_window = metric_df[
    metric_df['timestamp'].notna() &
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts)
].copy()

# Prepare empty result if no data
if nonconst_thresholds.empty or in_window.empty:
    component_rank_df = pd.DataFrame(columns=[
        'component_level_name','level_type','max_kpi_severity','cause_kpi',
        'total_anomalies','earliest_anomaly_timestamp'
    ])
else:
    # 4) Merge to keep only non-constant pairs in-window
    merged = in_window.merge(nonconst_thresholds, on=['cmdb_id','kpi_name'], how='inner')
    if merged.empty:
        component_rank_df = pd.DataFrame(columns=[
            'component_level_name','level_type','max_kpi_severity','cause_kpi',
            'total_anomalies','earliest_anomaly_timestamp'
        ])
    else:
        merged['is_upper'] = (merged['value'] >= merged['global_P95']).fillna(False)
        merged['is_lower'] = (merged['value'] <= merged['global_P5']).fillna(False)

        # aggregate per (cmdb_id,kpi_name)
        pair_agg = merged.groupby(['cmdb_id','kpi_name','global_P95','global_P5'], dropna=False).agg(
            points_in_window = ('value','size'),
            upper_anomaly_count = ('is_upper','sum'),
            lower_anomaly_count = ('is_lower','sum'),
            max_value_in_window = ('value','max'),
            min_value_in_window = ('value','min')
        ).reset_index()

        # earliest anomaly timestamps per pair
        eu = merged.loc[merged['is_upper']].groupby(['cmdb_id','kpi_name'])['timestamp'].min().rename('earliest_upper_ts').reset_index()
        el = merged.loc[merged['is_lower']].groupby(['cmdb_id','kpi_name'])['timestamp'].min().rename('earliest_lower_ts').reset_index()
        pair_agg = pair_agg.merge(eu, on=['cmdb_id','kpi_name'], how='left').merge(el, on=['cmdb_id','kpi_name'], how='left')

        # severities
        def compute_upper_sev(row):
            if row['upper_anomaly_count'] <= 0:
                return 0.0
            denom = max(1e-9, abs(row['global_P95']))
            return (row['max_value_in_window'] - row['global_P95']) / denom

        def compute_lower_sev(row):
            if row['lower_anomaly_count'] <= 0:
                return 0.0
            denom = max(1e-9, abs(row['global_P5']))
            return (row['global_P5'] - row['min_value_in_window']) / denom

        pair_agg['upper_severity'] = pair_agg.apply(compute_upper_sev, axis=1)
        pair_agg['lower_severity'] = pair_agg.apply(compute_lower_sev, axis=1)
        pair_agg['kpi_severity'] = pair_agg[['upper_severity','lower_severity']].max(axis=1)

        # earliest any-anomaly ts per pair (epoch seconds)
        pair_agg['earliest_any_ts'] = pair_agg[['earliest_upper_ts','earliest_lower_ts']].min(axis=1)

        # 5) Derive component_level_name and level_type
        def component_level(cmdb):
            s = str(cmdb)
            if re.match(r'^node-\d+$', s):
                return s, 'node'
            svc = re.sub(r'-\d+$','', s)
            return svc, 'service'
        comp = pair_agg['cmdb_id'].astype(str).apply(lambda x: component_level(x))
        pair_agg['component_level_name'] = comp.apply(lambda x: x[0])
        pair_agg['level_type'] = comp.apply(lambda x: x[1])

        pair_agg['anomaly_count'] = pair_agg['upper_anomaly_count'] + pair_agg['lower_anomaly_count']

        # 6) Aggregate by component_level_name
        svc_agg = pair_agg.groupby(['component_level_name','level_type'], dropna=False).agg(
            total_anomalies = ('anomaly_count','sum'),
            max_kpi_severity = ('kpi_severity','max'),
            earliest_any_ts_component = ('earliest_any_ts','min')
        ).reset_index()

        # determine cause_kpi per component: pick kpi with max severity, tie-breaker earliest timestamp
        kp_candidates = pair_agg[['component_level_name','kpi_name','kpi_severity','earliest_any_ts']].copy()
        kp_candidates = kp_candidates.sort_values(['component_level_name','kpi_severity','earliest_any_ts'], ascending=[True, False, True])
        kp_top = kp_candidates.groupby('component_level_name', as_index=False).first().rename(columns={
            'kpi_name':'cause_kpi_name','kpi_severity':'cause_kpi_severity','earliest_any_ts':'cause_kpi_earliest_ts'
        })

        svc_agg = svc_agg.merge(kp_top, on='component_level_name', how='left')

        # format timestamps
        def fmt_ts(v):
            if pd.isna(v):
                return None
            return pd.to_datetime(int(v), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %z')

        svc_agg['cause_kpi'] = svc_agg.apply(
            lambda r: f"{r['cause_kpi_name']}:{float(r['cause_kpi_severity']):.6g}@{fmt_ts(r['cause_kpi_earliest_ts'])}"
            if pd.notna(r.get('cause_kpi_name')) else None,
            axis=1
        )

        svc_agg['earliest_anomaly_timestamp'] = svc_agg['earliest_any_ts_component'].apply(lambda v: fmt_ts(v) if not pd.isna(v) else None)

        component_rank_df = svc_agg[[
            'component_level_name','level_type','max_kpi_severity','cause_kpi','total_anomalies','earliest_anomaly_timestamp'
        ]].sort_values('max_kpi_severity', ascending=False).head(10).reset_index(drop=True)

