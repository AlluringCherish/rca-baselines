global_p95 = grp.quantile(0.95).rename('global_P95')
global_p5 = grp.quantile(0.05).rename('global_P5')
thresholds = pd.concat([global_p95, global_p5], axis=1).reset_index()

# 2) Keep only non-constant series where global_P95 != global_P5
nonconst_thresholds = thresholds[thresholds['global_P95'] != thresholds['global_P5']].copy()

# 3) Filter metric rows to incident window (2022-03-20 09:00:00 +0800 to 2022-03-20 09:30:00 +0800 inclusive)
start_ts = int(pd.Timestamp('2022-03-20 09:00:00', tz=tz).tz_convert('UTC').timestamp())
end_ts = int(pd.Timestamp('2022-03-20 09:30:00', tz=tz).tz_convert('UTC').timestamp())

in_window = metric_df[
    (metric_df['timestamp'].notna()) &
    (metric_df['timestamp'] >= start_ts) &
    (metric_df['timestamp'] <= end_ts)
].copy()

# 3.5) Keep only rows in the incident window that belong to non-constant (cmdb_id,kpi_name)
if nonconst_thresholds.empty or in_window.empty:
    # Prepare empty result structure if no data
    result_df = pd.DataFrame(columns=[
        'cmdb_id','kpi_name','global_P95','global_P5','points_in_window',
        'upper_anomaly_count','lower_anomaly_count',
        'earliest_upper_anomaly_timestamp','earliest_lower_anomaly_timestamp',
        'max_value_in_window','min_value_in_window'
    ])
    top_cmdbs = pd.DataFrame(columns=['cmdb_id','total_anomalies'])
else:
    merged = in_window.merge(nonconst_thresholds, on=['cmdb_id','kpi_name'], how='inner')

    # 4) Compute anomalies and aggregates
    merged['is_upper'] = (merged['value'] >= merged['global_P95']).fillna(False)
    merged['is_lower'] = (merged['value'] <= merged['global_P5']).fillna(False)

    agg = merged.groupby(['cmdb_id','kpi_name']).agg(
        points_in_window = ('value','size'),
        upper_anomaly_count = ('is_upper','sum'),
        lower_anomaly_count = ('is_lower','sum'),
        max_value_in_window = ('value','max'),
        min_value_in_window = ('value','min')
    ).reset_index()

    # earliest timestamps for anomalies (epoch seconds)
    eu = merged.loc[merged['is_upper']].groupby(['cmdb_id','kpi_name'])['timestamp'].min().rename('earliest_upper_ts').reset_index()
    el = merged.loc[merged['is_lower']].groupby(['cmdb_id','kpi_name'])['timestamp'].min().rename('earliest_lower_ts').reset_index()

    agg = agg.merge(eu, on=['cmdb_id','kpi_name'], how='left')
    agg = agg.merge(el, on=['cmdb_id','kpi_name'], how='left')

    # attach thresholds
    agg = agg.merge(nonconst_thresholds, on=['cmdb_id','kpi_name'], how='left')

    # format earliest timestamps to Asia/Shanghai or None
    def fmt_ts(v):
        if pd.isna(v):
            return None
        return pd.to_datetime(int(v), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %z')

    agg['earliest_upper_anomaly_timestamp'] = agg['earliest_upper_ts'].apply(fmt_ts)
    agg['earliest_lower_anomaly_timestamp'] = agg['earliest_lower_ts'].apply(fmt_ts)

    # select and reorder columns as requested
    result_df = agg[[
        'cmdb_id','kpi_name','global_P95','global_P5','points_in_window',
        'upper_anomaly_count','lower_anomaly_count',
        'earliest_upper_anomaly_timestamp','earliest_lower_anomaly_timestamp',
        'max_value_in_window','min_value_in_window'
    ]].copy()

    # 5) Sort by total anomalies desc and limit to top 20 rows
    result_df['total_anomalies'] = result_df['upper_anomaly_count'] + result_df['lower_anomaly_count']
    result_df = result_df.sort_values(['total_anomalies','points_in_window'], ascending=[False, False]).head(20).reset_index(drop=True)
    result_df = result_df.drop(columns=['total_anomalies'])

    # Also return top 10 cmdb_ids by total anomaly counts (sum across their KPIs)
    # Compute totals from the full aggregated set (not just top 20)
    totals = agg.copy()
    totals['total_anomalies'] = totals['upper_anomaly_count'] + totals['lower_anomaly_count']
    top_cmdbs = totals.groupby('cmdb_id')['total_anomalies'].sum().reset_index().sort_values('total_anomalies', ascending=False).head(10).reset_index(drop=True)

# Display compact outputs: result_df (top 20) and top_cmdbs (top 10)
result_df, top_cmdbs
