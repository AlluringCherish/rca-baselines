import pandas as pd
import pytz
from collections import OrderedDict

tz = pytz.timezone('Asia/Shanghai')

def fmt_ts_series(s):
    # s: pandas Series of epoch seconds
    if s.empty:
        return None
    sdt = pd.to_datetime(s, unit='s', utc=True).dt.tz_convert(tz)
    # format as string without microseconds, include offset
    return sdt.dt.strftime('%Y-%m-%d %H:%M:%S %z').min(), sdt.dt.strftime('%Y-%m-%d %H:%M:%S %z').max()

def top_counts(series, topn=20):
    if series is None or series.size == 0:
        return []
    vc = series.value_counts().head(topn)
    return list(zip(vc.index.tolist(), vc.values.tolist()))

# Load files (reusing variable name df for memory efficiency)
