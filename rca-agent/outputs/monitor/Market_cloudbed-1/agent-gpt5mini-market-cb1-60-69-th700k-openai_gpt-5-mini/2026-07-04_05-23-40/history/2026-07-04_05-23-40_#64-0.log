import pandas as pd
import pytz

# reuse metric_df and tz if available
try:
    metric_df
except NameError:
    metric_df = pd.read_csv("metric.csv")

try:
    tz
except NameError:
    tz = pytz.timezone('Asia/Shanghai')

# ensure timezone-aware timestamp column in Asia/Shanghai (UTC+8)
if 'ts' not in metric_df.columns:
    metric_df['ts'] = pd.to_datetime(metric_df['timestamp'].astype(int), unit='s', utc=True).dt.tz_convert(tz)

# incident window (inclusive)
start = pd.Timestamp('2022-03-21 22:00:00', tz=tz)
end = pd.Timestamp('2022-03-21 22:30:00', tz=tz)

# filter rows in window where kpi_name contains 'container.node-5' or 'container.node-6'
mask_window = (metric_df['ts'] >= start) & (metric_df['ts'] <= end)
mask_k5 = metric_df['kpi_name'].str.contains('container.node-5', na=False)
mask_k6 = metric_df['kpi_name'].str.contains('container.node-6', na=False)
mask = mask_window & (mask_k5 | mask_k6)

df_nodes = metric_df.loc[mask, ['cmdb_id','kpi_name','ts']].copy()

# aggregate per cmdb_id
def node_label_for_group(kpi_series):
    has5 = kpi_series.str.contains('container.node-5', na=False).any()
    has6 = kpi_series.str.contains('container.node-6', na=False).any()
    if has5 and has6:
        return 'both'
    if has5:
        return 'node-5'
    if has6:
        return 'node-6'
    return None

agg = (
    df_nodes
    .groupby('cmdb_id', observed=True)
    .agg(
        total_points_in_window=('kpi_name', 'size'),
        distinct_kpi_count_in_window=('kpi_name', 'nunique'),
        earliest_timestamp_in_window=('ts', 'min'),
        sample_kpi_names=('kpi_name', lambda s: list(pd.Series(s.unique()).astype(str)[:10])),
    )
    .reset_index()
)

# determine node_label per cmdb_id by checking kpi_names for substrings
# need the full set of kpi_names per cmdb_id to check both substrings
kpi_lists = df_nodes.groupby('cmdb_id', observed=True')['kpi_name'].apply(lambda s: list(pd.Series(s.unique()).astype(str))).rename('kpi_list').reset_index()
agg = agg.merge(kpi_lists, on='cmdb_id', how='left')

def determine_label(kpi_list):
    has5 = any('container.node-5' in k for k in kpi_list)
    has6 = any('container.node-6' in k for k in kpi_list)
    if has5 and has6:
        return 'both'
    if has5:
        return 'node-5'
    if has6:
        return 'node-6'
    return None

agg['node_label'] = agg['kpi_list'].apply(determine_label)
# format earliest timestamp to string in UTC+8 or None
def fmt_ts(x):
    if pd.isna(x):
        return None
    return pd.to_datetime(x).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S%z')

agg['earliest_timestamp_in_window'] = agg['earliest_timestamp_in_window'].apply(fmt_ts)

# keep requested columns and sort by total_points_in_window desc, limit top 20
result_df = agg[['cmdb_id','node_label','total_points_in_window','distinct_kpi_count_in_window','earliest_timestamp_in_window','sample_kpi_names']].sort_values('total_points_in_window', ascending=False).head(20).reset_index(drop=True)

# total number of distinct cmdb_id discovered
total_cmdbs = int(df_nodes['cmdb_id'].nunique())

# display compact results
result_df, total_cmdbs
