def fmt_ts(ts):
    if pd.isna(ts):
        return "N/A"
    return pd.to_datetime(int(ts), unit='s', utc=True).tz_convert(tz).strftime('%Y-%m-%d %H:%M:%S %Z')

def fmt_val(v):
    if pd.isna(v):
        return "N/A"
    return str(v)

