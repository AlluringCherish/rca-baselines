log_p95 = log_df.groupby(['cmdb_id','log_name'], as_index=False)['value'].quantile(0.95).rename(columns={'value':'p95'})
log_p05 = log_df.groupby(['cmdb_id','log_name'], as_index=False)['value'].quantile(0.05).rename(columns={'value':'p05'})
