import pandas as pd
import numpy as np
import pytz
from datetime import datetime

# Reuse cached dataframes and threshold tables: metric_df, trace_df, log_df, error_logs_df,
# metric_thresholds_df, trace_thresholds_df, log_thresholds_df

tz = pytz.timezone('Asia/Shanghai')  # UTC+8

# Incident window in UTC+8
start_dt = tz.localize(datetime(2022, 3, 21, 11, 30, 0))
end_dt = tz.localize(datetime(2022, 3, 21, 12, 0, 0))

# Convert to epoch seconds (UTC) to match timestamp field
start_ts = int(start_dt.astimezone(pytz.UTC).timestamp())
end_ts = int(end_dt.astimezone(pytz.UTC).timestamp())

# Helper to detect anomalies for a given df, threshold_df, and name fields
def detect_anomalies(data_df, thresholds_df, key_cols, name_col):
    # Filter incident window
    df_window = data_df[(data_df['timestamp'] >= start_ts) & (data_df['timestamp'] <= end_ts)].copy()
    if df_window.empty:
        return pd.DataFrame(columns=[key_cols[0], name_col, 'anomaly_type', 'anomaly_count',
                                     'earliest_anomaly_timestamp', 'max_value', 'min_value', 'p95', 'p5', 'severity'])
    # Merge with thresholds on (cmdb_id, name)
    merged = df_window.merge(thresholds_df, left_on=key_cols, right_on=key_cols, how='left', suffixes=('', '_th'))
    # Ensure p95 and p5 exist
    merged['p95'] = merged['p95'].astype(float)
    merged['p5'] = merged['p5'].astype(float)
    # Detect high and low breaches
    highs = merged[merged['value'] >= merged['p95']].copy()
    lows = merged[merged['value'] <= merged['p5']].copy()
    # Aggregate highs
    if not highs.empty:
        high_agg = highs.groupby([key_cols[0], name_col]).agg(
            anomaly_count=('value', 'count'),
            earliest_anomaly_timestamp=('timestamp', 'min'),
            max_value=('value', 'max'),
            min_value=('value', 'min'),
            p95=('p95', 'first'),
            p5=('p5', 'first')
        ).reset_index()
        # severity = (max_value - p95)/p95, handle p95==0
        high_agg['severity'] = np.where(high_agg['p95'] == 0,
                                        np.nan,
                                        (high_agg['max_value'] - high_agg['p95']) / high_agg['p95'])
        high_agg['anomaly_type'] = 'high'
    else:
        high_agg = pd.DataFrame(columns=[key_cols[0], name_col, 'anomaly_count',
                                         'earliest_anomaly_timestamp', 'max_value', 'min_value', 'p95', 'p5', 'severity', 'anomaly_type'])
    # Aggregate lows
    if not lows.empty:
        low_agg = lows.groupby([key_cols[0], name_col]).agg(
            anomaly_count=('value', 'count'),
            earliest_anomaly_timestamp=('timestamp', 'min'),
            max_value=('value', 'max'),
            min_value=('value', 'min'),
            p95=('p95', 'first'),
            p5=('p5', 'first')
        ).reset_index()
        # severity = (p5 - min_value)/p5, handle p5==0
        low_agg['severity'] = np.where(low_agg['p5'] == 0,
                                       np.nan,
                                       (low_agg['p5'] - low_agg['min_value']) / low_agg['p5'])
        low_agg['anomaly_type'] = 'low'
    else:
        low_agg = pd.DataFrame(columns=[key_cols[0], name_col, 'anomaly_count',
                                        'earliest_anomaly_timestamp', 'max_value', 'min_value', 'p95', 'p5', 'severity', 'anomaly_type'])
    # Combine
    anomalies = pd.concat([high_agg, low_agg], ignore_index=True, sort=False)
    # Ensure columns order
    anomalies = anomalies[[key_cols[0], name_col, 'anomaly_type', 'anomaly_count',
                           'earliest_anomaly_timestamp', 'max_value', 'min_value', 'p95', 'p5', 'severity']]
    # Sort for stability
    anomalies = anomalies.sort_values(['severity'], ascending=False).reset_index(drop=True)
    return anomalies

# Metric anomalies
metric_anomalies_df = detect_anomalies(metric_df, metric_thresholds_df, ['cmdb_id', 'kpi_name'], 'kpi_name')

# Trace anomalies
trace_anomalies_df = detect_anomalies(trace_df, trace_thresholds_df, ['cmdb_id', 'trace_name'], 'trace_name')

# Log anomalies
log_anomalies_df = detect_anomalies(log_df, log_thresholds_df, ['cmdb_id', 'log_name'], 'log_name')

# Prepare compact outputs (limit rows)
metric_anomalies_top20 = metric_anomalies_df.head(20)
trace_anomalies_top20 = trace_anomalies_df.head(20)
# log_anomalies_df likely small; show all but ensure limited shape
log_anomalies_compact = log_anomalies_df.copy()

# Counts of distinct anomalous (cmdb_id, KPI) pairs (count unique name pairs regardless of anomaly_type)
metric_distinct_count = metric_anomalies_df[[ 'cmdb_id', 'kpi_name']].drop_duplicates().shape[0] if not metric_anomalies_df.empty else 0
trace_distinct_count = trace_anomalies_df[[ 'cmdb_id', 'trace_name']].drop_duplicates().shape[0] if not trace_anomalies_df.empty else 0
log_distinct_count = log_anomalies_df[[ 'cmdb_id', 'log_name']].drop_duplicates().shape[0] if not log_anomalies_df.empty else 0

# Check error_logs_df emptiness
error_logs_empty = (error_logs_df is None) or error_logs_df.empty
error_logs_note = "empty" if error_logs_empty else f"has {len(error_logs_df)} rows"

# Final compact outputs as variables (displayed by IPython)
metric_anomalies_top20, trace_anomalies_top20, log_anomalies_compact, (metric_distinct_count, trace_distinct_count, log_distinct_count), error_logs_note
