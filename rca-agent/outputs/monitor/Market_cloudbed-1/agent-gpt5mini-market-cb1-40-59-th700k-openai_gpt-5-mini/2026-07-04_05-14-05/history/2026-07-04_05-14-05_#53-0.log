import pandas as pd

# Load CSVs into DataFrames and cache in kernel variables
metric_df = pd.read_csv("metric.csv")
trace_df = pd.read_csv("trace.csv")
log_df = pd.read_csv("log.csv")
error_logs_df = pd.read_csv("error_logs.csv")

def summarize_df(df, filename, kpi_col=None, message_col=None):
    # Basic counts and timestamp bounds
    n_rows = int(len(df))
    if n_rows > 0 and "timestamp" in df.columns:
        min_ts = int(df["timestamp"].min())
        max_ts = int(df["timestamp"].max())
    else:
        min_ts = None
        max_ts = None

    # cmdb_id summary
    if "cmdb_id" in df.columns and n_rows > 0:
        n_unique_cmdb = int(df["cmdb_id"].nunique())
        top_cmdbs = df["cmdb_id"].value_counts().index.astype(str).tolist()[:20]
    else:
        n_unique_cmdb = 0
        top_cmdbs = []

    # KPI or messages summary
    if kpi_col and kpi_col in df.columns and n_rows > 0:
        n_unique_kpi = int(df[kpi_col].nunique())
        top_kpis = df[kpi_col].value_counts().index.astype(str).tolist()[:20]
        kpi_or_messages = top_kpis
    elif message_col and message_col in df.columns and n_rows > 0:
        n_unique_kpi = 0
        top_msgs = df[message_col].dropna().astype(str).unique().tolist()[:20]
        kpi_or_messages = top_msgs
    else:
        n_unique_kpi = 0
        kpi_or_messages = []

    return {
        "filename": filename,
        "number_of_rows": n_rows,
        "min_timestamp": min_ts,
        "max_timestamp": max_ts,
        "number_of_unique_cmdb_id": n_unique_cmdb,
        "top_cmdb_id_values": top_cmdbs,
        "number_of_unique_KPI_names": n_unique_kpi,
        "top_KPI_names_or_messages_samples": kpi_or_messages
    }

inventory_summary = {
    "metric.csv": summarize_df(metric_df, "metric.csv", kpi_col="kpi_name"),
    "trace.csv": summarize_df(trace_df, "trace.csv", kpi_col="trace_name"),
    "log.csv": summarize_df(log_df, "log.csv", kpi_col="log_name"),
    "error_logs.csv": summarize_df(error_logs_df, "error_logs.csv", message_col="message")
}

inventory_summary
