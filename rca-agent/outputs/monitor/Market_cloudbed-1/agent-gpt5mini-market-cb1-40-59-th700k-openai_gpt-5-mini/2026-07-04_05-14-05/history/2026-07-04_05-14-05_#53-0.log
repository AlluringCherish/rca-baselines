import pandas as pd
import numpy as np
import pytz
from datetime import datetime

# Reuse cached metric_anomalies_df
tz = pytz.timezone('Asia/Shanghai')

# Ensure metric_anomalies_df exists
if 'metric_anomalies_df' not in globals() or metric_anomalies_df is None or metric_anomalies_df.empty:
    node6_agg_df = pd.DataFrame({"note": ["metric_anomalies_df is missing or empty."]})
    node6_affected_count = 0
else:
    df = metric_anomalies_df.copy()
    # Ensure relevant columns are correct types
    df['kpi_name'] = df['kpi_name'].astype(str)
    df['cmdb_id'] = df['cmdb_id'].astype(str)
    df['severity'] = pd.to_numeric(df['severity'], errors='coerce')
    df['earliest_anomaly_timestamp'] = pd.to_numeric(df['earliest_anomaly_timestamp'], errors='coerce')

    # Filter kpi_name containing 'container.node-6'
    node6_rows = df[df['kpi_name'].str.contains('container.node-6', na=False)].copy()

    if node6_rows.empty:
        node6_agg_df = pd.DataFrame({"note": ["No node-6 container.* KPI anomalies found."]})
        node6_affected_count = 0
    else:
        # Helper to format timestamp to UTC+8 string
        def fmt_ts(epoch):
            try:
                return datetime.fromtimestamp(int(epoch), pytz.UTC).astimezone(tz).strftime('%Y-%m-%d %H:%M:%S %z')
            except Exception:
                return ""

        # Aggregate per cmdb_id
        def make_examples(subdf, top_n=5):
            s = subdf.sort_values('severity', ascending=False, na_position='last')
            out = []
            for _, r in s.head(top_n).iterrows():
                ts = fmt_ts(r['earliest_anomaly_timestamp'])
                sev = r['severity']
                sev_str = f"{sev:.6f}" if pd.notna(sev) else "NaN"
                out.append(f"{r['kpi_name']} | {ts} | {sev_str}")
            return out

        agg_records = []
        grouped = node6_rows.groupby('cmdb_id')
        for cmdb, g in grouped:
            distinct_kpi_count = int(g['kpi_name'].nunique())
            earliest_ts = int(g['earliest_anomaly_timestamp'].min())
            latest_ts = int(g['earliest_anomaly_timestamp'].max())
            max_sev = float(np.nanmax(g['severity'].values)) if g['severity'].notna().any() else np.nan
            median_sev = float(np.nanmedian(g['severity'].values)) if g['severity'].notna().any() else np.nan
            examples = make_examples(g, top_n=5)
            agg_records.append({
                'cmdb_id': cmdb,
                'distinct_kpi_count': distinct_kpi_count,
                'earliest_anomaly_timestamp': fmt_ts(earliest_ts),
                'latest_anomaly_timestamp': fmt_ts(latest_ts),
                'max_severity': max_sev,
                'median_severity': median_sev,
                'example_kpis': examples
            })

        node6_agg_df = pd.DataFrame.from_records(agg_records)
        # Sort by distinct_kpi_count desc then max_severity desc
        node6_agg_df = node6_agg_df.sort_values(['distinct_kpi_count','max_severity'], ascending=[False, False]).reset_index(drop=True)
        node6_agg_df = node6_agg_df.head(20)
        node6_affected_count = int(node6_agg_df['cmdb_id'].nunique())

# Display compact results (DataFrame and count)
node6_agg_df, node6_affected_count
