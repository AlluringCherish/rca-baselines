        retrans_io_detailed_df['earliest_ts_str'] = retrans_io_detailed_df['earliest_anomaly_timestamp'].apply(lambda x: fmt_ts(x) if pd.notna(x) else "")

        # Prepare compact detailed head sorted by earliest_anomaly_timestamp ascending
        retrans_io_detailed_df_head = retrans_io_detailed_df.sort_values('earliest_anomaly_timestamp', ascending=True).head(20)[
            ['cmdb_id', 'kpi_name', 'anomaly_type', 'anomaly_count', 'earliest_ts_str', 'max_value', 'min_value', 'p95', 'p5', 'severity']
        ].rename(columns={'earliest_ts_str': 'earliest_anomaly_timestamp'})

        # Aggregation per node
        g = retrans_io_detailed_df.groupby('cmdb_id')
        agg_records = g.agg(
            retrans_io_anomaly_count = ('kpi_name', lambda x: int(x.nunique()) if x.notna().any() else 0),
            earliest_retrans_io_timestamp = ('earliest_anomaly_timestamp', 'min'),
