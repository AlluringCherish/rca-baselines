import pandas as pd
import numpy as np
import pytz
from datetime import datetime

# Reuse cached metric_anomalies_df from kernel
tz = pytz.timezone('Asia/Shanghai')  # UTC+8

# Check existence and non-empty
if 'metric_anomalies_df' not in globals() or metric_anomalies_df is None or metric_anomalies_df.empty:
    node_summary_df = pd.DataFrame({"note": ["No node-level anomalies found in metric_anomalies_df."]})
else:
    # Filter rows where cmdb_id starts with 'node-'
    node_rows = metric_anomalies_df[metric_anomalies_df['cmdb_id'].astype(str).str.startswith('node-')].copy()
    if node_rows.empty:
        node_summary_df = pd.DataFrame({"note": ["No node-level anomalies found in metric_anomalies_df."]})
    else:
        # Ensure numeric severity
        node_rows['severity'] = pd.to_numeric(node_rows['severity'], errors='coerce')
        node_rows['earliest_anomaly_timestamp'] = pd.to_numeric(node_rows['earliest_anomaly_timestamp'], errors='coerce')

        # Helper to format timestamp to UTC+8 human-readable string
        def fmt_ts(epoch):
            try:
                return datetime.fromtimestamp(int(epoch), pytz.UTC).astimezone(tz).strftime('%Y-%m-%d %H:%M:%S %z')
            except Exception:
                return ""

        # Aggregate per node
        def make_example_kpis(subdf, top_n=5):
            # sort by severity desc (NaNs go last), then by earliest timestamp asc
            s = subdf.sort_values(['severity', 'earliest_anomaly_timestamp'], ascending=[False, True])
            rows = []
            for _, r in s.head(top_n).iterrows():
                ts_str = fmt_ts(r['earliest_anomaly_timestamp'])
                sev = r['severity']
                sev_str = f"{sev:.6f}" if pd.notna(sev) else "NaN"
                rows.append(f"{r['kpi_name']} | {ts_str} | {sev_str}")
            return rows

        grouped = node_rows.groupby('cmdb_id')

        records = []
        for node, g in grouped:
            num_kpis = int(g['kpi_name'].nunique())
            earliest_ts = int(g['earliest_anomaly_timestamp'].min())
            latest_ts = int(g['earliest_anomaly_timestamp'].max())
            # max severity (ignore NaN)
            max_sev = np.nan
            try:
                max_sev = float(np.nanmax(g['severity'].values))
            except Exception:
                max_sev = np.nan
            # median severity (ignore NaN)
            try:
                median_sev = float(np.nanmedian(g['severity'].values))
            except Exception:
                median_sev = np.nan
            example_kpis = make_example_kpis(g, top_n=5)
            records.append({
                'node': node,
                'num_anomalous_kpis': num_kpis,
                'earliest_anomaly_timestamp': fmt_ts(earliest_ts),
                'latest_anomaly_timestamp': fmt_ts(latest_ts),
                'max_severity': max_sev,
                'median_severity': median_sev,
                'example_kpis': example_kpis
            })

        node_summary_df = pd.DataFrame.from_records(records)

        # Sort by earliest_anomaly_timestamp ascending (convert back to epoch for sorting)
        def epoch_from_fmt(s):
            try:
                return int(datetime.strptime(s[:-6], '%Y-%m-%d %H:%M:%S').replace(tzinfo=tz).astimezone(pytz.UTC).timestamp())
            except Exception:
                return 0

        node_summary_df['__sort_epoch'] = node_summary_df['earliest_anomaly_timestamp'].apply(
            lambda x: epoch_from_fmt(x) if isinstance(x, str) and x else 0
        )
        node_summary_df = node_summary_df.sort_values('__sort_epoch', ascending=True).drop(columns='__sort_epoch').reset_index(drop=True)

# Final compact table (max 6 rows as there are up to 6 nodes)
node_summary_df = node_summary_df.head(6)
node_summary_df
