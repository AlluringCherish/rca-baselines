import pandas as pd
import numpy as np
import pytz
from datetime import datetime

# Reuse cached metric_anomalies_df from kernel
tz = pytz.timezone('Asia/Shanghai')

# Check metric_anomalies_df exists
if 'metric_anomalies_df' not in globals() or metric_anomalies_df is None or metric_anomalies_df.empty:
    retrans_io_detailed_df = pd.DataFrame({"note": ["metric_anomalies_df is missing or empty."]})
    retrans_io_agg_df = pd.DataFrame({"note": ["metric_anomalies_df is missing or empty."]})
    retrans_io_detailed_df_head = retrans_io_detailed_df
    retrans_io_agg_df_head = retrans_io_agg_df
else:
    df = metric_anomalies_df.copy()
    # Ensure numeric fields
    df['earliest_anomaly_timestamp'] = pd.to_numeric(df['earliest_anomaly_timestamp'], errors='coerce')
    df['severity'] = pd.to_numeric(df['severity'], errors='coerce')
    # Filter cmdb_id starts with 'node-'
    node_mask = df['cmdb_id'].astype(str).str.startswith('node-')
    node_df = df[node_mask].copy()
    # Substring list (case-sensitive)
    substrings = [
        'retrans', 'tcp.retrans', 'system.net', 'system.io', 'io.r', 'io.w', 'io.rkb',
        'io.r_s', 'io.wkb', 'io.w_s', 'fs_reads', 'fs_writes'
    ]
    # Build regex pattern ensuring any substring match
    import re
    escaped = [re.escape(s) for s in substrings]
    pattern = "(" + "|".join(escaped) + ")"
    match_mask = node_df['kpi_name'].astype(str).str.contains(pattern, regex=True, na=False)
    retrans_io_df = node_df[match_mask].copy()

    # Cache full detailed filtered table
    retrans_io_detailed_df = retrans_io_df.copy()

    # Helper to format epoch -> UTC+8 string
    def fmt_ts(epoch):
        try:
            return datetime.fromtimestamp(int(epoch), pytz.UTC).astimezone(tz).strftime('%Y-%m-%d %H:%M:%S %z')
        except Exception:
            return ""

    # Prepare detailed compact view: select and format columns
    if retrans_io_detailed_df.empty:
        retrans_io_detailed_df_head = pd.DataFrame({"note": ["No retrans/IO anomalies found on nodes."]})
        retrans_io_agg_df = pd.DataFrame({"note": ["No retrans/IO anomalies found on nodes."]})
        retrans_io_agg_df_head = retrans_io_agg_df
    else:
