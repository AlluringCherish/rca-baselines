        agg_df['latest_retrans_io_timestamp'] = agg_df['latest_retrans_io_timestamp'].apply(lambda x: fmt_ts(x) if pd.notna(x) else "")

        # Sort by earliest_retrans_io_timestamp ascending (convert back epoch for sorting)
        def epoch_from_fmt(s):
            try:
                return int(datetime.strptime(s[:-6], '%Y-%m-%d %H:%M:%S').replace(tzinfo=tz).astimezone(pytz.UTC).timestamp())
            except Exception:
                return 0
        agg_df['__sort_epoch'] = agg_df['earliest_retrans_io_timestamp'].apply(lambda x: epoch_from_fmt(x) if x else 0)
        retrans_io_agg_df = agg_df.sort_values('__sort_epoch', ascending=True).drop(columns='__sort_epoch').reset_index(drop=True)

        # Compact aggregated head (limit 20)
