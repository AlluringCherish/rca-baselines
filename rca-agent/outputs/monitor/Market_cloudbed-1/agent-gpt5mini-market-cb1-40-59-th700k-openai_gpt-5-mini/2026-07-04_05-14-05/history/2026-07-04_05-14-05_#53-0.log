import pandas as pd
import pytz

# reuse cached dataframes: metric_df, trace_df, log_df, error_logs_df
tz = pytz.timezone('Asia/Shanghai')  # timezone object for UTC+8 (required by rules)

# 1) metric_df thresholds
metric_group = metric_df.groupby(['cmdb_id', 'kpi_name'])['value']
metric_thresholds_df = metric_group.agg(
    count='count',
    min='min',
    p5=lambda x: x.quantile(0.05),
    p50=lambda x: x.quantile(0.50),
    p95=lambda x: x.quantile(0.95),
    p99=lambda x: x.quantile(0.99),
    max='max',
    mean='mean'
).reset_index()

# Ensure column order
metric_thresholds_df = metric_thresholds_df[
    ['cmdb_id', 'kpi_name', 'count', 'min', 'p5', 'p50', 'p95', 'p99', 'max', 'mean']
]

# top 20 by p95 descending
metric_top20 = metric_thresholds_df.sort_values('p95', ascending=False).head(20)

# 2) trace_df thresholds
trace_group = trace_df.groupby(['cmdb_id', 'trace_name'])['value']
trace_thresholds_df = trace_group.agg(
    count='count',
    min='min',
    p5=lambda x: x.quantile(0.05),
    p50=lambda x: x.quantile(0.50),
    p95=lambda x: x.quantile(0.95),
    p99=lambda x: x.quantile(0.99),
    max='max',
    mean='mean'
).reset_index()

trace_thresholds_df = trace_thresholds_df[
    ['cmdb_id', 'trace_name', 'count', 'min', 'p5', 'p50', 'p95', 'p99', 'max', 'mean']
]

trace_top20 = trace_thresholds_df.sort_values('p95', ascending=False).head(20)

# 3) log_df thresholds
log_group = log_df.groupby(['cmdb_id', 'log_name'])['value']
log_thresholds_df = log_group.agg(
    count='count',
    min='min',
    p5=lambda x: x.quantile(0.05),
    p50=lambda x: x.quantile(0.50),
    p95=lambda x: x.quantile(0.95),
    p99=lambda x: x.quantile(0.99),
    max='max',
    mean='mean'
).reset_index()

log_thresholds_df = log_thresholds_df[
    ['cmdb_id', 'log_name', 'count', 'min', 'p5', 'p50', 'p95', 'p99', 'max', 'mean']
]

# 4) error_logs_df check
if error_logs_df is None or error_logs_df.empty:
    error_note = "error_logs_df is empty (no error log entries)."
else:
    error_note = f"error_logs_df has {len(error_logs_df)} rows."

# Display compact summaries (variables, not prints)
metric_top20, trace_top20, log_thresholds_df, error_note
