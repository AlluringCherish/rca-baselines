import pandas as pd
import numpy as np

# Reuse cached variables: thresholds_df, df_metric_window
# If they don't exist, raise informative error (they should exist per prior steps)
try:
    thresholds_df
    df_metric_window
except NameError as e:
    raise

# Merge window rows with full-series thresholds so each row has p95/p5
df_win_thresh = df_metric_window.merge(
    thresholds_df, on=['cmdb_id', 'kpi_name'], how='left'
)

# Mark anomalies relative to group thresholds
df_win_thresh['is_high'] = df_win_thresh['value'] >= df_win_thresh['p95']
df_win_thresh['is_low'] = df_win_thresh['value'] <= df_win_thresh['p5']

# Consider only rows that are anomalous (either high or low)
df_anom = df_win_thresh[df_win_thresh['is_high'] | df_win_thresh['is_low']].copy()

# Per-timestamp counts
per_ts = (
    df_anom.groupby('timestamp')
    .agg(
        high_count = ('is_high', 'sum'),
        low_count = ('is_low', 'sum')
    )
    .reset_index()
)
per_ts['total_anomalies'] = per_ts['high_count'] + per_ts['low_count']

# Total number of distinct timestamps that had any anomalies
total_anomalous_timestamps = int(per_ts.shape[0])

# Top 10 timestamps by total_anomalies (tie-breaker: high_count desc, timestamp asc)
top10_ts_df = per_ts.sort_values(
    by=['total_anomalies','high_count','timestamp'],
    ascending=[False, False, True]
).head(10)[['timestamp','total_anomalies','high_count','low_count']].reset_index(drop=True)

# For each top timestamp, collect up to 10 example affected rows preferring highs first
top_ts_list = top10_ts_df['timestamp'].tolist()
# Prepare anomaly_type column for sorting preference
df_anom['anomaly_type'] = np.where(df_anom['is_high'], 'high',
                                  np.where(df_anom['is_low'], 'low', 'none'))

# Order by timestamp, prefer high anomalies, then larger severity (relative to p95/p5)
# Compute simple severity for ordering: for highs value/p95, for lows p5/value
def compute_sev(row):
    try:
        if row['anomaly_type'] == 'high':
            return float(row['value']) / float(row['p95']) if row['p95'] else np.nan
        if row['anomaly_type'] == 'low':
            return float(row['p5']) / float(row['value']) if row['value'] else np.nan
    except Exception:
        return np.nan

df_anom['sev'] = df_anom.apply(compute_sev, axis=1)

# Filter to only top timestamps and sort: timestamp asc, high first, severity desc
df_examples_candidates = df_anom[df_anom['timestamp'].isin(top_ts_list)].copy()
df_examples_candidates.sort_values(
    by=['timestamp', df_examples_candidates['anomaly_type'].map({'high':0,'low':1}), 'sev'],
    ascending=[True, True, False],
    inplace=True
)

# For each timestamp take up to 10 example rows
examples_list = []
for ts in top_ts_list:
    tmp = df_examples_candidates[df_examples_candidates['timestamp']==ts]
    if tmp.shape[0] > 0:
        sel = tmp.head(10)[['timestamp','cmdb_id','kpi_name','value','anomaly_type']].copy()
        examples_list.append(sel)
# Concatenate examples into one compact DataFrame (ordered by timestamp)
if examples_list:
    examples_df = pd.concat(examples_list, ignore_index=True)
else:
    examples_df = pd.DataFrame(columns=['timestamp','cmdb_id','kpi_name','value','anomaly_type'])

# Keep full intermediates in kernel for later inspection
per_ts_full = per_ts  # full per-timestamp counts (intermediate)
df_anom_full = df_anom  # full anomalous rows in window (intermediate)

# Final compact outputs
top10_ts_df, examples_df.head(100), total_anomalous_timestamps
