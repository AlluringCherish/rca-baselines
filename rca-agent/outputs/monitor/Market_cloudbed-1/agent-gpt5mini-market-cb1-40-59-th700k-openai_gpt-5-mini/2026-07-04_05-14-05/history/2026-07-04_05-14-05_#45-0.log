import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse previously computed variables where available: 'matching' and 'trace'
assert 'trace' in globals(), "trace dataframe not found in kernel."
assert 'matching' in globals(), "matching dataframe (earliest-anomaly per-series) not found."

# 1) Identify set of cmdb_id values from 'matching' where earliest_anomaly_dt == minimum earliest anomaly
# (matching already contains rows filtered to min timestamp in prior step)
cmdb_list = pd.DataFrame({'cmdb_id': matching['cmdb_id'].unique()})
# keep it compact
cmdb_list = cmdb_list.reset_index(drop=True)

# 2) Compute global p95 and p5 for each (cmdb_id, trace_name) over full trace.csv
# Reuse trace_stats if present; otherwise compute
if 'trace_stats' in globals():
    global_thresholds = trace_stats[['cmdb_id','trace_name','p95','p5']].copy()
else:
    trace['timestamp'] = trace['timestamp'].astype(int)
    trace['dt'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)
    grp = trace.groupby(['cmdb_id','trace_name'])['value']
    global_thresholds = grp.agg(
        p95 = lambda x: x.quantile(0.95),
        p5  = lambda x: x.quantile(0.05)
    ).reset_index()

# 3) Filter trace.csv to incident window and restrict to cmdb_ids in cmdb_list
start = pd.Timestamp('2022-03-21 08:00:00', tz=tz)
end   = pd.Timestamp('2022-03-21 08:30:00', tz=tz)
trace['dt'] = pd.to_datetime(trace['timestamp'].astype(int), unit='s', utc=True).dt.tz_convert(tz)

trace_win = trace[trace['dt'].between(start, end)].copy()
trace_win_cmdb = trace_win[trace_win['cmdb_id'].isin(cmdb_list['cmdb_id'])].copy()

# 4) For each (cmdb_id, trace_name) compute requested window aggregates using global thresholds
trace_win_cmdb = trace_win_cmdb.merge(global_thresholds, on=['cmdb_id','trace_name'], how='left')

trace_win_cmdb['anomaly_high'] = trace_win_cmdb['value'] > trace_win_cmdb['p95']
trace_win_cmdb['anomaly_low']  = trace_win_cmdb['value'] < trace_win_cmdb['p5']

# earliest anomaly dt in window (where either high or low)
earliest = trace_win_cmdb.loc[trace_win_cmdb['anomaly_high'] | trace_win_cmdb['anomaly_low'], 
                              ['cmdb_id','trace_name','dt']].copy()
if not earliest.empty:
    earliest = earliest.groupby(['cmdb_id','trace_name'])['dt'].min().reset_index().rename(columns={'dt':'earliest_anomaly_dt_in_window'})
else:
    earliest = pd.DataFrame(columns=['cmdb_id','trace_name','earliest_anomaly_dt_in_window'])

agg = trace_win_cmdb.groupby(['cmdb_id','trace_name']).agg(
    count_in_window = ('value','count'),
    max_in_window = ('value','max'),
    min_in_window = ('value','min'),
    anomalies_high = ('anomaly_high','sum'),
    anomalies_low  = ('anomaly_low','sum')
).reset_index()

agg = agg.merge(global_thresholds, on=['cmdb_id','trace_name'], how='left')
agg = agg.merge(earliest, on=['cmdb_id','trace_name'], how='left')

# 5) Flag likely_faulty_in_traces: True if this series has anomalies (high or low) AND trace_name indicates error_rate or duration
def likely_faulty(row):
    if (row.get('anomalies_high',0) + row.get('anomalies_low',0)) == 0:
        return False
    tn = row.get('trace_name','').lower()
    # look for typical trace indicators
    if ('error_rate' in tn) or ('error' in tn and 'rate' in tn) or ('duration' in tn) or ('latency' in tn):
        return True
    return False

agg['anomalies_high'] = agg['anomalies_high'].fillna(0).astype(int)
agg['anomalies_low'] = agg['anomalies_low'].fillna(0).astype(int)
agg['likely_faulty_in_traces'] = agg.apply(likely_faulty, axis=1)

# Sorting by total anomalies desc then max_in_window desc
agg['total_anoms'] = agg['anomalies_high'] + agg['anomalies_low']
result = agg.sort_values(by=['total_anoms','max_in_window'], ascending=[False, False])

# Keep compact: select requested columns and top 20
result_top20 = result[[
    'cmdb_id','trace_name','count_in_window','anomalies_high','anomalies_low',
    'earliest_anomaly_dt_in_window','p95','p5','max_in_window','min_in_window','likely_faulty_in_traces'
]].head(20).reset_index(drop=True)

# Also compute total number of distinct trace series scanned for these components (using global_thresholds)
series_for_components = global_thresholds[global_thresholds['cmdb_id'].isin(cmdb_list['cmdb_id'])]
total_series_scanned = series_for_components.shape[0]

# Final compact outputs
cmdb_list, total_series_scanned, result_top20
