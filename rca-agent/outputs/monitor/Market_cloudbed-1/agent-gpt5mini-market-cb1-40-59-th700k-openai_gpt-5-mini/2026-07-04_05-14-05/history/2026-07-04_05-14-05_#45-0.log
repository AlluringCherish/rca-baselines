import pandas as pd
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Load CSVs (files are in current working directory per task)
metric = pd.read_csv('metric.csv')
trace = pd.read_csv('trace.csv')
log = pd.read_csv('log.csv')
error_logs = pd.read_csv('error_logs.csv')

# Helper to compute min/max timestamp as timezone-aware datetimes (UTC->Asia/Shanghai)
def time_bounds(df, ts_col='timestamp'):
    if ts_col not in df.columns or df[ts_col].dropna().empty:
        return pd.NaT, pd.NaT
    ts_series = pd.to_datetime(df[ts_col].astype(int), unit='s', utc=True)
    ts_series = ts_series.dt.tz_convert(tz)
    return ts_series.min(), ts_series.max()

# Overviews: total rows and min/max timestamps
metric_min_ts, metric_max_ts = time_bounds(metric, 'timestamp')
trace_min_ts, trace_max_ts = time_bounds(trace, 'timestamp')
log_min_ts, log_max_ts = time_bounds(log, 'timestamp')
error_min_ts, error_max_ts = time_bounds(error_logs, 'timestamp')

metric_overview = pd.DataFrame({
    'rows': [len(metric)],
    'min_timestamp_Asia/Shanghai': [metric_min_ts],
    'max_timestamp_Asia/Shanghai': [metric_max_ts]
})

trace_overview = pd.DataFrame({
    'rows': [len(trace)],
    'min_timestamp_Asia/Shanghai': [trace_min_ts],
    'max_timestamp_Asia/Shanghai': [trace_max_ts]
})

log_overview = pd.DataFrame({
    'rows': [len(log)],
    'min_timestamp_Asia/Shanghai': [log_min_ts],
    'max_timestamp_Asia/Shanghai': [log_max_ts]
})

error_overview = pd.DataFrame({
    'rows': [len(error_logs)],
    'min_timestamp_Asia/Shanghai': [error_min_ts],
    'max_timestamp_Asia/Shanghai': [error_max_ts]
})

# Top 20 cmdb_id and counts for each file
metric_cmdb_top = metric['cmdb_id'].value_counts().head(20).reset_index().rename(columns={'index':'cmdb_id', 'cmdb_id':'count'})
trace_cmdb_top = trace['cmdb_id'].value_counts().head(20).reset_index().rename(columns={'index':'cmdb_id', 'cmdb_id':'count'})
log_cmdb_top = log['cmdb_id'].value_counts().head(20).reset_index().rename(columns={'index':'cmdb_id', 'cmdb_id':'count'})
error_cmdb_top = error_logs['cmdb_id'].value_counts().head(20).reset_index().rename(columns={'index':'cmdb_id', 'cmdb_id':'count'})

# Unique KPI/trace/log/message counts (top 20)
metric_kpi_top = metric['kpi_name'].value_counts().head(20).reset_index().rename(columns={'index':'kpi_name', 'kpi_name':'count'})
trace_name_top = trace['trace_name'].value_counts().head(20).reset_index().rename(columns={'index':'trace_name', 'trace_name':'count'})
log_name_top = log['log_name'].value_counts().head(20).reset_index().rename(columns={'index':'log_name', 'log_name':'count'})
error_message_top = error_logs['message'].value_counts().head(20).reset_index().rename(columns={'index':'message', 'message':'count'})

# Display compact results (limited to top 20 where applicable)
metric_overview, metric_cmdb_top, metric_kpi_top, \
trace_overview, trace_cmdb_top, trace_name_top, \
log_overview, log_cmdb_top, log_name_top, \
error_overview, error_cmdb_top, error_message_top
