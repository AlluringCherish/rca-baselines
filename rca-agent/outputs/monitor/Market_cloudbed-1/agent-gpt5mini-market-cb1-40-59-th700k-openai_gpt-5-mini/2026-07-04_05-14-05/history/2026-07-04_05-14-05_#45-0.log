import pandas as pd
import numpy as np

# Reuse 'out' DataFrame computed earlier which contains per-series results within the window.
# Columns expected: ['cmdb_id','kpi_name','count_all','count_in_window','anomalies_count',
# 'earliest_anomaly_dt','p95_value','max_value_in_window','percent_exceedance','p90_detected_when_p95_none']

# Ensure out exists
assert 'out' in globals(), "Variable 'out' not found in the environment."

df = out.copy()

# Helper to produce top kpis per component
def top_kpis_list(g, top_n=5):
    anoms = g[g['anomalies_count'] > 0].copy()
    if anoms.empty:
        return ""
    # For ranking, treat NaN percent_exceedance (from p95==0) as +inf so they appear first
    anoms['_rank_key'] = anoms['percent_exceedance'].fillna(np.inf)
    topk = anoms.sort_values('_rank_key', ascending=False)['kpi_name'].head(top_n).tolist()
    # join with comma, keep compact
    return ",".join(topk)

# Aggregate per cmdb_id
agg = df.groupby('cmdb_id').apply(lambda g: pd.Series({
    'series_present': int(g['kpi_name'].nunique()),
    'series_with_anomaly': int((g['anomalies_count'] > 0).sum()),
    'total_anomalies': int(g['anomalies_count'].sum()),
    'earliest_anomaly_dt': (g.loc[g['anomalies_count']>0, 'earliest_anomaly_dt'].min() 
                            if (g['anomalies_count']>0).any() else pd.NaT),
    'max_percent_exceedance': (g['percent_exceedance'].max(skipna=True) 
                               if g['percent_exceedance'].notna().any() else np.nan),
    'top_kpis_with_anomalies': top_kpis_list(g, top_n=5)
})).reset_index()

# Sorting as requested
agg_sorted = agg.sort_values(
    by=['series_with_anomaly','total_anomalies','max_percent_exceedance'],
    ascending=[False, False, False]
).reset_index(drop=True)

# Limit to top 20 rows for compact display
comp_table_top20 = agg_sorted.head(20)

# Total number of components scanned
num_components = agg_sorted.shape[0]

# Display compact results: number of components and top-20 aggregated table
num_components, comp_table_top20[['cmdb_id','series_present','series_with_anomaly','total_anomalies',
                                 'earliest_anomaly_dt','max_percent_exceedance','top_kpis_with_anomalies']].head(20)
