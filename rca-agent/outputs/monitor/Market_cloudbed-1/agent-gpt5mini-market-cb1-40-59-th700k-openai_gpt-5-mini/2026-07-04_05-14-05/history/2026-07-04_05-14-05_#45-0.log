import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse existing dataframes: metric, log, error_logs
# Ensure timestamp/dt columns
metric['timestamp'] = metric['timestamp'].astype(int)
metric['dt'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

log['timestamp'] = log['timestamp'].astype(int)
log['dt'] = pd.to_datetime(log['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

error_logs['timestamp'] = error_logs['timestamp'].astype(int)
error_logs['dt'] = pd.to_datetime(error_logs['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# Incident window (inclusive)
start = pd.Timestamp('2022-03-21 08:00:00', tz=tz)
end = pd.Timestamp('2022-03-21 08:30:00', tz=tz)

# Target component
comp = 'productcatalogservice-0'

# 1) Memory-related KPI selection (case-sensitive substrings)
substrs = ['memory','memory_fail','rss','working_set','oom','fail']
pattern = "(" + "|".join([s.replace('.', r'\.') for s in substrs]) + ")"

mc = metric[metric['cmdb_id'] == comp].copy()
# find kpis matching any substring (case-sensitive)
mem_kpis = mc[mc['kpi_name'].str.contains(pattern, regex=True, na=False)]['kpi_name'].unique().tolist()

# Compute global stats per kpi_name (over full metric.csv) for these memory-related KPIs
if len(mem_kpis) > 0:
    mem_full = mc[mc['kpi_name'].isin(mem_kpis)].copy()
    grp = mem_full.groupby('kpi_name')['value']
    mem_stats = grp.agg(
        count_all = 'count',
        min_value = 'min',
        max_value = 'max',
        p50 = lambda x: x.quantile(0.50),
        p90 = lambda x: x.quantile(0.90),
        p95 = lambda x: x.quantile(0.95),
        p99 = lambda x: x.quantile(0.99)
    ).reset_index()

    # Windowed metrics
    mem_win = mem_full[mem_full['dt'].between(start, end)].copy()
    # Merge p95 into window points for anomaly detection
    mem_win = mem_win.merge(mem_stats[['kpi_name','p95']], on='kpi_name', how='left')
    mem_win['is_anom'] = mem_win['value'] > mem_win['p95']

    # Aggregate per kpi_name in window
    mem_win_agg = mem_win.groupby('kpi_name').agg(
        count_in_window = ('value','count'),
        anomalies_count = ('is_anom','sum'),
        earliest_anomaly_dt = ('dt', lambda x: x[mem_win.loc[x.index,'is_anom']].min() if (mem_win.loc[x.index,'is_anom'].any()) else pd.NaT),
        max_value_in_window = ('value','max')
    ).reset_index()

    # Merge with global p95
    mem_summary = mem_stats.merge(mem_win_agg, on='kpi_name', how='left')
    mem_summary['count_in_window'] = mem_summary['count_in_window'].fillna(0).astype(int)
    mem_summary['anomalies_count'] = mem_summary['anomalies_count'].fillna(0).astype(int)
    mem_summary['earliest_anomaly_dt'] = mem_summary['earliest_anomaly_dt']
    mem_summary['max_value_in_window'] = mem_summary['max_value_in_window']
    mem_summary['p95_value'] = mem_summary['p95']
    # percent_exceedance
    def pct_exc(r):
        p95v = r['p95_value']
        mx = r['max_value_in_window']
        if pd.isna(mx):
            return np.nan
        if pd.isna(p95v) or p95v == 0:
            return np.inf
        return 100.0 * (mx - p95v) / p95v
    mem_summary['percent_exceedance'] = mem_summary.apply(pct_exc, axis=1)
    # sort as requested
    mem_summary = mem_summary.sort_values(by=['anomalies_count','percent_exceedance'], ascending=[False, False]).reset_index(drop=True)
    mem_summary_display = mem_summary[[
        'kpi_name','count_all','p50','p90','p95','p99','min_value','max_value',
        'count_in_window','anomalies_count','earliest_anomaly_dt','max_value_in_window','p95_value','percent_exceedance'
    ]].head(20)
else:
    mem_summary_display = pd.DataFrame(columns=[
        'kpi_name','count_all','p50','p90','p95','p99','min_value','max_value',
        'count_in_window','anomalies_count','earliest_anomaly_dt','max_value_in_window','p95_value','percent_exceedance'
    ])

# 2) Other KPIs for the component that had anomalies in window (non-memory), top 20 by count_all
# Compute global p95 for all kpis of the component (global before filtering)
comp_grp = mc.groupby('kpi_name')['value']
comp_stats = comp_grp.agg(
    count_all='count',
    p95=lambda x: x.quantile(0.95)
).reset_index()

# Windowed comp data merged with p95
comp_win = mc[mc['dt'].between(start, end)].copy()
comp_win = comp_win.merge(comp_stats, on='kpi_name', how='left')
comp_win['is_anom'] = comp_win['value'] > comp_win['p95']

# Aggregate per kpi_name
comp_win_agg = comp_win.groupby('kpi_name').agg(
    count_in_window=('value','count'),
    anomalies_count=('is_anom','sum'),
    earliest_anomaly_dt=('dt', lambda x: x[x.index[comp_win.loc[x.index,'is_anom']].tolist()].min() 
                         if comp_win.loc[x.index,'is_anom'].any() else pd.NaT),
    max_value_in_window=('value','max')
).reset_index()

# Merge stats
comp_all = comp_stats.merge(comp_win_agg, on='kpi_name', how='left')
comp_all['count_in_window'] = comp_all['count_in_window'].fillna(0).astype(int)
comp_all['anomalies_count'] = comp_all['anomalies_count'].fillna(0).astype(int)
comp_all['earliest_anomaly_dt'] = comp_all['earliest_anomaly_dt']
comp_all['max_value_in_window'] = comp_all['max_value_in_window']

# percent_exceedance
def pct_exc2(r):
    p95v = r['p95']
    mx = r['max_value_in_window']
    if pd.isna(mx):
        return np.nan
    if pd.isna(p95v) or p95v == 0:
        return np.inf
    return 100.0 * (mx - p95v) / p95v
comp_all['percent_exceedance'] = comp_all.apply(pct_exc2, axis=1)

# Select other KPIs with anomalies_count>0 but exclude memory_kpis (if present)
other_anoms = comp_all[(comp_all['anomalies_count'] > 0) & (~comp_all['kpi_name'].isin(mem_kpis))].copy()
other_anoms = other_anoms.sort_values(by='count_all', ascending=False).head(20)
other_anoms_display = other_anoms[[
    'kpi_name','count_all','count_in_window','anomalies_count','earliest_anomaly_dt','percent_exceedance'
]]

# 3) Logs for the component in the window
log_comp_win = log[(log['cmdb_id'] == comp) & (log['dt'].between(start, end))].copy()
log_rows_count = log_comp_win.shape[0]

if log_rows_count == 0:
    log_name_counts = pd.DataFrame()  # empty
    log_messages_counts = pd.DataFrame()  # empty
else:
    # distinct log_name values with counts
    if 'log_name' in log_comp_win.columns:
        log_name_counts = log_comp_win['log_name'].value_counts().head(20).reset_index().rename(columns={'index':'log_name','log_name':'count'})
    else:
        log_name_counts = pd.DataFrame()
    # messages: log.csv may not contain raw messages; check column
    if 'message' in log_comp_win.columns:
        log_messages_counts = log_comp_win['message'].value_counts().head(20).reset_index().rename(columns={'index':'message','message':'count'})
    else:
        # no message column in log.csv
        log_messages_counts = pd.DataFrame(columns=['message','count'])

# 4) error_logs for the component in the window
err_comp_win = error_logs[(error_logs['cmdb_id'] == comp) & (error_logs['dt'].between(start, end))].copy()
err_rows_count = err_comp_win.shape[0]
if err_rows_count == 0:
    error_top = pd.DataFrame(columns=['message','count'])
else:
    if 'message' in err_comp_win.columns:
        error_top = err_comp_win['message'].value_counts().head(20).reset_index().rename(columns={'index':'message','message':'count'})
    else:
        error_top = pd.DataFrame(columns=['message','count'])

# 5) Conclusion boolean: strong metric+log evidence of memory/container failure at 08:00?
# Define "strong evidence" as: at least one memory-related KPI with anomalies_count>0 AND (logs or error_logs present OR multiple memory KPIs anomalous)
mem_anom_count = 0
if len(mem_kpis) > 0:
    mem_anom_count = mem_summary['anomalies_count'].sum()
multiple_mem_anoms = mem_anom_count >= 2  # heuristic
logs_present = log_rows_count > 0 or err_rows_count > 0
strong_evidence = bool((mem_anom_count > 0 and logs_present) or multiple_mem_anoms)

# Prepare compact outputs (limited to top 20 where applicable)
mem_summary_display, other_anoms_display, log_rows_count, log_name_counts.head(20), log_messages_counts.head(20), err_rows_count, error_top.head(20), strong_evidence
