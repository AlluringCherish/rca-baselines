import pandas as pd
import numpy as np
import pytz

# reuse existing 'trace' dataframe loaded earlier
tz = pytz.timezone('Asia/Shanghai')

# Ensure timestamp and dt with Asia/Shanghai tz
trace['timestamp'] = trace['timestamp'].astype(int)
trace['dt'] = pd.to_datetime(trace['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Global statistics per (cmdb_id, trace_name) over full file
grp = trace.groupby(['cmdb_id','trace_name'])['value']
trace_stats = grp.agg(
    count_all = 'count',
    min_value = 'min',
    max_value = 'max',
    p5  = lambda x: x.quantile(0.05),
    p50 = lambda x: x.quantile(0.50),
    p90 = lambda x: x.quantile(0.90),
    p95 = lambda x: x.quantile(0.95)
).reset_index()

total_series_count = trace_stats.shape[0]

# 2) Filter to incident window (inclusive) 2022-03-21 08:00 to 08:30 Asia/Shanghai
start = pd.Timestamp('2022-03-21 08:00:00', tz=tz)
end   = pd.Timestamp('2022-03-21 08:30:00', tz=tz)
trace_win = trace[trace['dt'].between(start, end)].copy()

# Merge global thresholds into windowed points
trace_win = trace_win.merge(trace_stats[['cmdb_id','trace_name','p5','p95','count_all']], on=['cmdb_id','trace_name'], how='left')

# Define anomaly flags using global thresholds
trace_win['is_high'] = trace_win['value'] > trace_win['p95']
trace_win['is_low']  = trace_win['value'] < trace_win['p5']

# Aggregate per (cmdb_id, trace_name) within window
agg_win = trace_win.groupby(['cmdb_id','trace_name']).agg(
    count_in_window = ('value','count'),
    max_in_window = ('value','max'),
    min_in_window = ('value','min'),
    anomalies_high = ('is_high','sum'),
    anomalies_low  = ('is_low','sum'),
    earliest_anom_dt = (lambda df: df.loc[df['is_high'] | df['is_low'], 'dt'].min() if ((df['is_high'] | df['is_low']).any()) else pd.NaT)
).reset_index()

# Note: above lambda not applied correctly inside agg for earliest_anom_dt; compute separately
# Recompute earliest_anom_dt properly:
earliest = trace_win.loc[trace_win['is_high'] | trace_win['is_low'], ['cmdb_id','trace_name','dt']].copy()
if not earliest.empty:
    earliest = earliest.groupby(['cmdb_id','trace_name'])['dt'].min().reset_index().rename(columns={'dt':'earliest_anom_dt'})
else:
    # empty DataFrame with correct columns
    earliest = pd.DataFrame(columns=['cmdb_id','trace_name','earliest_anom_dt'])

# Recompute other aggregates (count_in_window, max/min, anomalies counts)
agg_basic = trace_win.groupby(['cmdb_id','trace_name']).agg(
    count_in_window = ('value','count'),
    max_in_window = ('value','max'),
    min_in_window = ('value','min'),
    anomalies_high = ('is_high','sum'),
    anomalies_low  = ('is_low','sum')
).reset_index()

# Merge earliest timestamps
agg_win = agg_basic.merge(earliest, on=['cmdb_id','trace_name'], how='left')

# Merge global stats (p95, p5, count_all)
agg_win = agg_win.merge(trace_stats[['cmdb_id','trace_name','p95','p5','count_all']], on=['cmdb_id','trace_name'], how='left')

# Flag series with no anomalies at p95/p5
agg_win['no_p95_p5_anomalies'] = ((agg_win['anomalies_high'] == 0) & (agg_win['anomalies_low'] == 0))

# 3) Prepare final top-20 table sorted by total anomalies desc then max_in_window desc
agg_win['total_anomalies'] = agg_win['anomalies_high'] + agg_win['anomalies_low']

top20 = agg_win.sort_values(by=['total_anomalies','max_in_window'], ascending=[False, False]).head(20)

# Select and order columns as requested
top20 = top20[[
    'cmdb_id','trace_name','count_all','count_in_window',
    'anomalies_high','anomalies_low','earliest_anom_dt',
    'p95','p5','max_in_window','min_in_window','no_p95_p5_anomalies'
]]

# Compact display: total number of series scanned and top20 table
total_series_count, top20
