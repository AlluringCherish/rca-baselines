import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# reuse existing 'metric' dataframe from earlier execution
# ensure timestamp/datetime column in Asia/Shanghai tz
metric['timestamp'] = metric['timestamp'].astype(int)
metric['dt'] = pd.to_datetime(metric['timestamp'], unit='s', utc=True).dt.tz_convert(tz)

# 1) Global statistics per (cmdb_id, kpi_name)
grp = metric.groupby(['cmdb_id', 'kpi_name'])['value']
series_stats = grp.agg(
    count_all = 'count',
    min_value = 'min',
    max_value = 'max',
    p50 = lambda x: x.quantile(0.50),
    p90 = lambda x: x.quantile(0.90),
    p95 = lambda x: x.quantile(0.95),
    p99 = lambda x: x.quantile(0.99)
).reset_index()

total_series_count = series_stats.shape[0]

# 2) Filter to incident window (inclusive) 2022-03-21 08:00 to 08:30 Asia/Shanghai
start = pd.Timestamp('2022-03-21 08:00:00', tz=tz)
end   = pd.Timestamp('2022-03-21 08:30:00', tz=tz)
metric_win = metric[metric['dt'].between(start, end)].copy()

# Aggregates in window per series
win_agg = metric_win.groupby(['cmdb_id','kpi_name'])['value'].agg(
    count_in_window = 'count',
    max_value_in_window = 'max'
).reset_index()

# Merge global p95/p90 into window points for anomaly detection
metric_win = metric_win.merge(series_stats[['cmdb_id','kpi_name','p95','p90']], on=['cmdb_id','kpi_name'], how='left')

metric_win['is_anom_p95'] = metric_win['value'] > metric_win['p95']
metric_win['is_anom_p90'] = metric_win['value'] > metric_win['p90']

# anomalies counts and earliest anomaly timestamp (for p95)
anoms_p95 = metric_win[metric_win['is_anom_p95']].groupby(['cmdb_id','kpi_name']).agg(
    anomalies_count = ('value','count'),
    earliest_anomaly_dt = ('dt','min')
).reset_index()

# anomalies at p90 (for fallback)
anoms_p90 = metric_win[metric_win['is_anom_p90']].groupby(['cmdb_id','kpi_name']).agg(
    anomalies_count_p90 = ('value','count')
).reset_index()

# assemble per-series result for series present in window
res = win_agg.merge(series_stats, on=['cmdb_id','kpi_name'], how='left')
res = res.merge(anoms_p95, on=['cmdb_id','kpi_name'], how='left')
res = res.merge(anoms_p90, on=['cmdb_id','kpi_name'], how='left')

# fill NAs and compute derived fields
res['anomalies_count'] = res['anomalies_count'].fillna(0).astype(int)
res['earliest_anomaly_dt'] = res['earliest_anomaly_dt']  # may be NaT for none
res['p95_value'] = res['p95']
res['max_value_in_window'] = res['max_value_in_window']

# percent_exceedance: 100*(max - p95)/p95 ; if p95==0 -> NaN
def percent_exceedance(row):
    p95v = row['p95_value']
    mx = row['max_value_in_window']
    if pd.isna(p95v) or p95v == 0:
        return np.nan
    return 100.0 * (mx - p95v) / p95v

res['percent_exceedance'] = res.apply(percent_exceedance, axis=1)

# p90 fallback boolean: True if no p95 anomalies but p90 anomalies exist
res['anomalies_count_p90'] = res['anomalies_count_p90'].fillna(0).astype(int)
res['p90_detected_when_p95_none'] = ((res['anomalies_count'] == 0) & (res['anomalies_count_p90'] > 0))

# Select and sort top candidates
out = res[[
    'cmdb_id','kpi_name','count_all','count_in_window','anomalies_count',
    'earliest_anomaly_dt','p95_value','max_value_in_window','percent_exceedance',
    'p90_detected_when_p95_none'
]].copy()

# sort by anomalies_count desc then percent_exceedance desc
out_sorted = out.sort_values(by=['anomalies_count','percent_exceedance'], ascending=[False, False])

top20 = out_sorted.head(20).reset_index(drop=True)

# final compact outputs: total number of series scanned (global) and top20 table
total_series_count, top20
