import pandas as pd
import numpy as np
import pytz

tz = pytz.timezone('Asia/Shanghai')

# Reuse 'out' DataFrame from previous computations
assert 'out' in globals(), "Variable 'out' not found."

# Ensure earliest_anomaly_dt is datetime with Asia/Shanghai tz
if out['earliest_anomaly_dt'].dtype == object:
    out['earliest_anomaly_dt'] = pd.to_datetime(out['earliest_anomaly_dt'])
# If tz-naive, localize to Asia/Shanghai (but prefer to preserve existing tz-aware)
if out['earliest_anomaly_dt'].dt.tz is None:
    try:
        out['earliest_anomaly_dt'] = out['earliest_anomaly_dt'].dt.tz_localize(tz)
    except Exception:
        # if localization fails (e.g., all NaT), leave as is
        pass

# 1) Find minimum earliest_anomaly_dt excluding NaT
valid_earliest = out['earliest_anomaly_dt'].dropna()
if valid_earliest.empty:
    min_ts = pd.NaT
else:
    min_ts = valid_earliest.min()

# 2) Filter rows whose earliest_anomaly_dt equals min_ts
if pd.isna(min_ts):
    matching = out.iloc[0:0]  # empty dataframe with same columns
else:
    matching = out[out['earliest_anomaly_dt'] == min_ts].copy()

# Select required columns and limit to top 20 (sort by percent_exceedance desc for consistency)
cols = ['cmdb_id','kpi_name','count_all','count_in_window','anomalies_count',
        'earliest_anomaly_dt','p95_value','max_value_in_window','percent_exceedance']
matching = matching[cols].sort_values(by=['percent_exceedance','anomalies_count'], ascending=[False, False]).head(20).reset_index(drop=True)

# 3) Summary: min timestamp, number of series, breakdown node-level vs others
num_series = matching.shape[0]
if num_series > 0:
    node_mask = matching['cmdb_id'].str.startswith('node-')
    node_count = int(node_mask.sum())
    other_count = int(num_series - node_count)
else:
    node_count = 0
    other_count = 0

summary = pd.DataFrame({
    'min_earliest_anomaly_dt': [min_ts],
    'series_triggered_at_min_ts': [num_series],
    'node_level_count': [node_count],
    'pod_or_service_level_count': [other_count]
})

# Display compact results: summary and matching rows (max 20)
summary, matching
