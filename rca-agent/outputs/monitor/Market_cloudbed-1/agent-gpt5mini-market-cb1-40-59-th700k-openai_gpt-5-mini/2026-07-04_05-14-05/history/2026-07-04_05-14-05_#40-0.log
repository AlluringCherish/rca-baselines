import pandas as pd
import numpy as np
import pytz

# Reuse existing kernel variables: metric_with_anomaly, metric_agg_full
tz = pytz.timezone('Asia/Shanghai')

# Candidate cmdb_ids
candidates = [
    "node-1","node-2","node-3","node-4","node-5","node-6",
    "checkoutservice-0","checkoutservice-1","checkoutservice-2","checkoutservice2-0",
    "cartservice-0","cartservice-1","cartservice-2","cartservice2-0",
    "productcatalogservice-0","productcatalogservice-1","productcatalogservice-2"
]

# Ensure timestamp_dt exists and is timezone-aware
if 'timestamp_dt' not in metric_with_anomaly.columns:
    metric_with_anomaly['timestamp_dt'] = pd.to_datetime(metric_with_anomaly['timestamp'].astype(int), unit='s', utc=True).dt.tz_convert(tz)

# Merge global thresholds from metric_agg_full (use p95/p5 global before filtering)
thresholds = metric_agg_full[['cmdb_id','kpi_name','p95','p5']].drop_duplicates()
m = metric_with_anomaly.merge(thresholds, on=['cmdb_id','kpi_name'], how='left', validate='m:1')

# Incident window bounds (UTC+8)
start_ts = pd.Timestamp('2022-03-21T05:00:00', tz=tz)
end_ts   = pd.Timestamp('2022-03-21T05:30:00', tz=tz)

# Filter to window and candidate cmdb_ids
m_window = m[(m['timestamp_dt'] >= start_ts) & (m['timestamp_dt'] <= end_ts) & (m['cmdb_id'].isin(candidates))].copy()

# Helper: infer reason tag from kpi_name
def infer_reason(kpi):
    k = (kpi or "").lower()
    if 'memory_fail' in k or 'memory.fail' in k or 'memory_failures' in k:
        return 'memory_failures'
    if 'fs_reads' in k or 'fs.read' in k or 'reads' in k or '/dev/vda' in k or 'r_s' in k or 'rkb_s' in k or 'r_await' in k:
        return 'io_read'
    if 'fs_writes' in k or 'fs.write' in k or 'writes' in k or 'w_s' in k or 'w_await' in k:
        return 'io_write'
    if ('cpu' in k) and ('throttl' in k or 'cfs' in k or 'cfs_throttled' in k):
        return 'cpu_throttle'
    if 'cpu' in k:
        return 'cpu_throttle'
    return 'other'

# Prepare container for detected sustained faults
sustained_rows = []

# Group by (cmdb_id,kpi_name) and scan time-ordered points
grouped = m_window.sort_values(['cmdb_id','kpi_name','timestamp_dt']).groupby(['cmdb_id','kpi_name'], sort=False)

for (cmdb,kpi), g in grouped:
    # global p95/p5 for the group
    p95_vals = g['p95'].dropna().unique()
    p5_vals = g['p5'].dropna().unique()
    p95 = float(p95_vals[0]) if p95_vals.size>0 else np.nan
    p5 = float(p5_vals[0]) if p5_vals.size>0 else np.nan

    # arrays
    vals = pd.to_numeric(g['value'], errors='coerce').to_numpy()
    times = g['timestamp_dt'].to_numpy()
    n = len(vals)
    if n < 3:
        continue

    # Build boolean mask per point for sustained condition
    conds = np.zeros(n, dtype=bool)
    for i, v in enumerate(vals):
        if np.isnan(p95):
            conds[i] = False
        elif p95 > 0:
            if pd.notnull(v) and v > p95 and ((v - p95) / p95) > 0.5:
                conds[i] = True
        else:
            # p95 == 0 or effectively zero
            if pd.notnull(v) and v > 0:
                conds[i] = True

    # Find earliest run of at least 3 consecutive True
    i = 0
    while i < n:
        if conds[i]:
            j = i
            while j < n and conds[j]:
                j += 1
            cur_len = j - i
            if cur_len >= 3:
                run_vals = vals[i:j]
                run_times = times[i:j]
                max_in_run = np.nanmax(run_vals)
                min_in_run = np.nanmin(run_vals)
                earliest_ts = run_times[0]
                # ensure ISO string in UTC+8
                earliest_iso = earliest_ts.tz_convert(tz).isoformat() if pd.notnull(earliest_ts) else None
                sustained_rows.append({
                    'cmdb_id': cmdb,
                    'kpi_name': kpi,
                    'earliest_sustained_fault_timestamp': earliest_iso,
                    'run_length': int(cur_len),
                    'p95': p95 if not np.isnan(p95) else None,
                    'p5': p5 if not np.isnan(p5) else None,
                    'max_value_in_run': float(max_in_run) if not np.isnan(max_in_run) else None,
                    'min_value_in_run': float(min_in_run) if not np.isnan(min_in_run) else None,
                    'reason': infer_reason(kpi)
                })
                break  # only earliest sustained run per group
            else:
                i = j
        else:
            i += 1

# Build DataFrame of sustained faults
sustained_df = pd.DataFrame(sustained_rows)

# Sort by earliest timestamp ascending and limit top 20
if not sustained_df.empty:
    # parse timestamps to ensure proper ordering; they are ISO with tz info
    sustained_df['earliest_parsed'] = pd.to_datetime(sustained_df['earliest_sustained_fault_timestamp'])
    sustained_df_sorted = sustained_df.sort_values('earliest_parsed', ascending=True).head(20).reset_index(drop=True)
    faults_top20 = sustained_df_sorted[[
        'cmdb_id','kpi_name','earliest_sustained_fault_timestamp','run_length','p95','p5','max_value_in_run','min_value_in_run','reason'
    ]]
else:
    faults_top20 = pd.DataFrame(columns=['cmdb_id','kpi_name','earliest_sustained_fault_timestamp','run_length','p95','p5','max_value_in_run','min_value_in_run','reason'])

# Total number of groups with sustained faults
n_sustained_groups = sustained_df.shape[0]

# Keep full intermediate results in kernel
sustained_full_df = sustained_df
metric_window_filtered = m_window

# Return compact outputs
