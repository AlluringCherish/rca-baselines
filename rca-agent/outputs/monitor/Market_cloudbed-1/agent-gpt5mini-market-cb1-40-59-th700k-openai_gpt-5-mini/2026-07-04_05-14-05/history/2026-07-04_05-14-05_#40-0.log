import pandas as pd
import numpy as np
import pytz

# Reuse existing kernel variables: metric_with_anomaly, metric_agg_full
tz = pytz.timezone('Asia/Shanghai')

# Candidate cmdb_ids
candidates = [
    "node-1","node-2","node-3","node-4","node-5","node-6",
    "checkoutservice-0","checkoutservice-1","checkoutservice-2","checkoutservice2-0",
    "cartservice-0","cartservice-1","cartservice-2","cartservice2-0",
    "productcatalogservice-0","productcatalogservice-1","productcatalogservice-2"
]

# Ensure metric_with_anomaly has timezone-aware timestamp_dt
if 'timestamp_dt' not in metric_with_anomaly.columns:
    metric_with_anomaly['timestamp_dt'] = pd.to_datetime(metric_with_anomaly['timestamp'].astype(int), unit='s', utc=True).dt.tz_convert(tz)

# Merge global thresholds from metric_agg_full to ensure p95/p5 are the global ones (rule 9)
thresholds = metric_agg_full[['cmdb_id','kpi_name','p95','p5']].drop_duplicates()
m = metric_with_anomaly.merge(thresholds, on=['cmdb_id','kpi_name'], how='left', suffixes=('','_global'), validate='m:1')

# Incident window bounds (UTC+8)
start_ts = pd.Timestamp('2022-03-21T05:00:00', tz=tz)
end_ts   = pd.Timestamp('2022-03-21T05:30:00', tz=tz)

# Filter to window and candidate cmdb_ids
m_window = m[(m['timestamp_dt'] >= start_ts) & (m['timestamp_dt'] <= end_ts) & (m['cmdb_id'].isin(candidates))].copy()

# Prepare container for detected sustained faults
sustained_rows = []

# Helper: infer reason tag from kpi_name
def infer_reason(kpi):
    k = kpi.lower()
    if 'memory_fail' in k or 'memory.fail' in k or 'memory_failures' in k:
        return 'memory_failures'
    if 'fs_reads' in k or 'fs.read' in k or 'reads' in k or '/dev/vda' in k or 'r_s' in k or 'rkb_s' in k or 'r_await' in k:
        return 'io_read'
    if 'fs_writes' in k or 'fs.write' in k or 'writes' in k or 'w_s' in k or 'w_await' in k:
        return 'io_write'
    if 'cpu_cfs_throttled' in k or 'cpu.throttled' in k or 'cpu' in k and ('throttl' in k or 'cfs' in k):
        return 'cpu_throttle'
    # fallback: check cpu keywords
    if 'cpu' in k:
        return 'cpu_throttle'
    return 'other'

