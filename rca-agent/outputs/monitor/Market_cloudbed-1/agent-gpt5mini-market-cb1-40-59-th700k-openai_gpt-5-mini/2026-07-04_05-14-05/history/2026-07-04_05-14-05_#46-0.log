import pandas as pd
import pytz

# reuse timezone variable per rules
tz = pytz.timezone('Asia/Shanghai')

# Reuse previously loaded DataFrames if present; otherwise load them
try:
    df_metric
except NameError:
    df_metric = pd.read_csv("metric.csv")
try:
    df_trace
except NameError:
    df_trace = pd.read_csv("trace.csv")
try:
    df_log
except NameError:
    df_log = pd.read_csv("log.csv")

# 1) Compute global P95 grouped by (cmdb_id, KPI_name) for each file
metric_p95 = df_metric.groupby(['cmdb_id', 'kpi_name'])['value'].quantile(0.95).reset_index().rename(columns={'kpi_name': 'KPI_name', 'value': 'p95'})
metric_p95 = metric_p95.sort_values('p95', ascending=False).reset_index(drop=True)

trace_p95 = df_trace.groupby(['cmdb_id', 'trace_name'])['value'].quantile(0.95).reset_index().rename(columns={'trace_name': 'KPI_name', 'value': 'p95'})
trace_p95 = trace_p95.sort_values('p95', ascending=False).reset_index(drop=True)

log_p95 = df_log.groupby(['cmdb_id', 'log_name'])['value'].quantile(0.95).reset_index().rename(columns={'log_name': 'KPI_name', 'value': 'p95'})
log_p95 = log_p95.sort_values('p95', ascending=False).reset_index(drop=True)

# 2) Variables metric_p95, trace_p95, log_p95 are stored in kernel (as DataFrames) per requirement

# 3) Build compact summary dictionary with group counts and top 20 groups
p95_summary = {
    "metric.csv": {
        "group_count": int(metric_p95.shape[0]),
        "top_p95": metric_p95[['cmdb_id', 'KPI_name', 'p95']].head(20)
    },
    "trace.csv": {
        "group_count": int(trace_p95.shape[0]),
        "top_p95": trace_p95[['cmdb_id', 'KPI_name', 'p95']].head(20)
    },
    "log.csv": {
        "group_count": int(log_p95.shape[0]),
        "top_p95": log_p95[['cmdb_id', 'KPI_name', 'p95']].head(20)
    }
}

p95_summary
