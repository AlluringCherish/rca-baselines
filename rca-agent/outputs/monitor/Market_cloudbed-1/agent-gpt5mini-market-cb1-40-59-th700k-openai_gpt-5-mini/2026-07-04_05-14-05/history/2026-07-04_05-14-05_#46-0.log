import pandas as pd
import numpy as np
from datetime import datetime
import pytz

# Reuse existing kernel variables if present
# df_metric, df_trace, df_log, metric_p95, trace_p95, log_p95 should exist from prior steps

tz = pytz.timezone('Asia/Shanghai')

# 1) Compute start/end timestamps for March 21, 2022 08:30 to 09:00 (UTC+8)
start_dt = tz.localize(datetime(2022, 3, 21, 8, 30, 0))
end_dt = tz.localize(datetime(2022, 3, 21, 9, 0, 0))
start_ts = int(start_dt.astimezone(pytz.utc).timestamp())
end_ts = int(end_dt.astimezone(pytz.utc).timestamp())

# 1) Filter windows (inclusive)
metric_window = df_metric[(df_metric['timestamp'] >= start_ts) & (df_metric['timestamp'] <= end_ts)].copy()
trace_window = df_trace[(df_trace['timestamp'] >= start_ts) & (df_trace['timestamp'] <= end_ts)].copy()
log_window = df_log[(df_log['timestamp'] >= start_ts) & (df_log['timestamp'] <= end_ts)].copy()

# 2) Join filtered data with corresponding P95 table
# Ensure metric_p95, trace_p95, log_p95 exist
# For consistent grouping, create a KPI_name column in each window from original KPI column
metric_window['KPI_name'] = metric_window['kpi_name']
trace_window['KPI_name'] = trace_window['trace_name']
log_window['KPI_name'] = log_window['log_name']

# Merge on (cmdb_id, KPI_name)
metric_merged = metric_window.merge(metric_p95[['cmdb_id', 'KPI_name', 'p95']],
                                    on=['cmdb_id', 'KPI_name'],
                                    how='left')
trace_merged = trace_window.merge(trace_p95[['cmdb_id', 'KPI_name', 'p95']],
                                  on=['cmdb_id', 'KPI_name'],
                                  how='left')
log_merged = log_window.merge(log_p95[['cmdb_id', 'KPI_name', 'p95']],
                              on=['cmdb_id', 'KPI_name'],
                              how='left')

# 3) For each (cmdb_id, KPI_name) group compute aggregates
def compute_window_aggregates(df):
    # create is_anom flag (value > p95). If p95 is NaN, comparison yields False.
    df['is_anom'] = df['value'] > df['p95']
    # group
    g = df.groupby(['cmdb_id', 'KPI_name'], dropna=False)
    agg = g.agg(
        total_points = ('value', 'size'),
        anomaly_count = ('is_anom', 'sum'),
        max_value_in_window = ('value', 'max'),
        # p95 should be identical within group; take first
        p95 = ('p95', 'first')
    ).reset_index()
    # earliest_anomaly_ts: compute per-group minimum timestamp where is_anom is True
    earliest = df.loc[df['is_anom']].groupby(['cmdb_id', 'KPI_name'])['timestamp'].min().reset_index().rename(columns={'timestamp': 'earliest_anomaly_ts'})
    agg = agg.merge(earliest, on=['cmdb_id', 'KPI_name'], how='left')
    # severity_ratio: (max - p95)/p95, null if p95==0 or p95 is NaN
    def compute_sev(row):
        p = row['p95']
        mv = row['max_value_in_window']
        if pd.isna(p) or p == 0:
            return np.nan
        return (mv - p) / p
    agg['severity_ratio'] = agg.apply(compute_sev, axis=1)
    # Convert anomaly_count to int
    agg['anomaly_count'] = agg['anomaly_count'].astype(int)
    # earliest_anomaly_ts keep as numeric timestamp or NaN
    return agg

metric_aggr = compute_window_aggregates(metric_merged)
trace_aggr = compute_window_aggregates(trace_merged)
log_aggr = compute_window_aggregates(log_merged)

# 4) Build result dictionaries
def build_result(aggr_df):
    group_count_in_window = int(aggr_df.shape[0])
    # filter anomaly_count > 0
    anomalies = aggr_df[aggr_df['anomaly_count'] > 0].copy()
    # sort by anomaly_count desc then severity_ratio desc (NaNs last)
    anomalies = anomalies.sort_values(by=['anomaly_count', 'severity_ratio'], ascending=[False, False])
    top_anomalies = anomalies[['cmdb_id', 'KPI_name', 'total_points', 'anomaly_count', 'earliest_anomaly_ts', 'p95', 'max_value_in_window', 'severity_ratio']].head(20)
    return {"group_count_in_window": group_count_in_window, "top_anomalies": top_anomalies}

result_metric = build_result(metric_aggr)
result_trace = build_result(trace_aggr)
result_log = build_result(log_aggr)

final_results = {
    "metric.csv": result_metric,
    "trace.csv": result_trace,
    "log.csv": result_log
}

# Display the compact final_results dictionary (DataFrames for top_anomalies kept compact via head(20))
final_results
